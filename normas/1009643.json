{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br></div>", "i": 8816496}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 2.097, de 30 de octubre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  </div><br><br><div class=\"p\">Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=223142&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 252, de fecha 22 de enero de 2004, del Ministerio de Defensa Nacional</a>, Subsecretar&#xED;a de Marina, en el sentido de reemplazar el p&#xE1;rrafo 4.- por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;4.- El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n exenta N&#xBA; 2.616, de fecha 28 de octubre de 2003 y modificada por la resoluci&#xF3;n exenta N&#xBA; 280, de fecha 27 de enero de 2006, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;.</div><br><br></div>", "i": 8816497, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de noviembre de 2009.- Por la Sra. Subsecretaria, Humberto Ram&#xED;rez Navarro, Subjefe Subsecretar&#xED;a de Marina.</div><br></div>", "i": 8816498}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2097", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2097"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [