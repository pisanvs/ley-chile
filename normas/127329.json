{"html": [{"t": "<div><div class=\"p\">CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGROINDUSTRIAS CEPIA S.A.</div><br><br><br></div>", "i": 6139754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 77.- Certifico que Agroindustrias Cepia S.A., Rut.: 79.711.330-1, cumple los requisitos establecidos en la Res. N&#xBA; Ex. 5.101 de 31.08.98 publicada en el Diario Oficial de 05.09.98 y que en consecuencia tiene la calidad de agente retenedor del Impuesto al Valor Agregado, en las compras de productos silvestres que efect&#xFA;e durante el per&#xED;odo comprendido entre el 1&#xBA; del mes siguiente al de la publicaci&#xF3;n de este certificado en el Diario Oficial y el 31 de agosto de 1999.</div><br></div>", "i": 6139755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de octubre de 1998.- Hugo Horta Barahona, Director Regional.</div><br></div>", "i": 6139756}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "77", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-77"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO CENTRO"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A\nAGROINDUSTRIAS CEPIA S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "AGROINDUSTRIAS CEPIA S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-10-30", "doble_articulado": false, "id_norma": "127329", "numero_fuente": "36218", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-11-19", "vigencias": [{"desde": "1998-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":