{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA FRIOMAR LTDA. PARA REEMPLAZAR INSTALACIONES QUE INDICA</div><br><br><br></div>", "i": 6359099}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 251, de 28 de Noviembre de 1979, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la sociedad &quot;Pesquera Friomar Ltda.&quot; para reemplazar las c&#xE1;maras de almacenamiento de la planta de congelado que tiene autorizada operar por decreto de Agricultura N&#xB0; 162, de 1975, y agregar otras, quedando como sigue: 2 c&#xE1;maras de almacenamiento, con capacidad de 180 toneladas, o 170 m3. cada una; un t&#xFA;nel de congelaci&#xF3;n, de 45 m3.; una antec&#xE1;mara, de 36 m3., y una sala de empaque, de 120 m3.</div><br></div>", "i": 6359100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Radic Prado, Subsecretario de pesca. </div></div>", "i": 6359101}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "251", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-251"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA FRIOMAR LTDA. PARA REEMPLAZAR INSTALACIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1979-11-28", "fecha_derogacion": "2001-11-20", "doble_articulado": false, "id_norma": "192027", "numero_fuente": "30533", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1979-12-06", "vigencias": [{"desde": "2001-11-20", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"des