{"html": [{"t": "<div><div class=\"p\">DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE HIJUELAS </div><br></div>", "i": 6061304}, {"t": "<div><br><div class=\"p\">Servicio Agr&#xED;cola y Ganadero, mediante Resoluci&#xF3;n Exenta No.</div><div class=\"p\">1.467, de 05 de Octubre de 1990, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 28 y sitios 1 al 56 del Proyecto de Divisi&#xF3;n de los terrenos de la Cooperativa de Reforma Agraria &quot;Los Pinos de Romeral Ltda.&quot;, de la Comuna de Hijuelas, V Regi&#xF3;n, formado por el predio &quot;Los Pinos de Romeral&quot;, los Derechos de Aguas se extraen de los Canales La Sombra y Romeral, ambos derivados del r&#xED;o Aconcagua. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6061305}, {"t": "<div><div class=\"p\">- Director Nacional.</div><br></div>", "i": 6061306}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1467 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1467 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE HIJUELAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-05", "doble_articulado": false, "id_norma": "82017", "numero_fuente": "33793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-10-15", "vigencias": [{"desde": "1990-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-10-15", "fin_vigencia": ""}, "vigenc