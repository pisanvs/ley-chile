{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 121 EXENTA, DE 1998</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 101 exenta.- Santiago, 12 de marzo de 2003.- Visto: Los D.S. N&#xBA;s 212/92 y 237/92, ambos del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes,</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br><br></div>", "i": 6421460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 121 de 1998, de esta Secretar&#xED;a Regional Ministerial, en el sentido de sustituir el primer guarismo 100 por 50 y suprimir el segundo guarismo 100.</div><br><div class=\"p\">&nbsp; &nbsp;  2.- La modificaci&#xF3;n anterior entrar&#xE1; en vigencia en la fecha de su publicaci&#xF3;n.</div><br><br></div>", "i": 6421461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Silvio Albarr&#xE1;n Alb&#xE1;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6421462}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "101 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-101 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "MODIFICA RESOLUCION Nº 121 EXENTA, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-12", "doble_articulado": false, "id_norma": "209561", "numero_fuente": "37542", "tipo_version": "3", "tipo_version_s": "Única", "fecha_pub