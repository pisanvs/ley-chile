{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6215629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 3.544 del 30 de noviembre de 1999, se expropiaron los lotes de terreno N&#xBA;s. 36, 38 y 51, superficies 115.000 m&#xB2;, 15.000 m&#xB2; y 123.300 m&#xB2;, respectivamente, roles de aval&#xFA;os 402-8 y 402-13, comuna de Vicu&#xF1;a, para la obra &apos;&apos;Embalse Puclaro, Sector Punta Azul y San Carlos III Etapa&apos;&apos;; y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Carlos An&#xED;bal Mart&#xED;nez y Otra y Jorge Orlando Dur&#xE1;n Ramos, ascendente a las cantidades de $110.762.992.- para los lote N&#xBA;s. 36 y 38 y $74.655.080.- para el lote N&#xBA; 51.</div><br></div>", "i": 6215630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6215631}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3544", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3544"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-30", "doble_articulado": false, "id_norma": "150250", "numero_fuente": "36552", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-03", "vigencias": [{"desde": "2000-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fec