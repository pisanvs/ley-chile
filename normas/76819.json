{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 949 EXENTO, DE&nbsp; 1997 </div></div>", "i": 6049105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 949 de fecha 2 de septiembre de 1997 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Inacap, las modificaciones introducidas al plan y programas de estudios de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica para ser impartida a contar del a&#xF1;o 1997, con la siguiente denominaci&#xF3;n:</div><br><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp;  : Analista Qu&#xED;mico.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp; &nbsp; : T&#xE9;cnico Analista Qu&#xED;mico con menci&#xF3;n en F&#xE1;rmacos</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; y Alimentos.</div><br><br><div class=\"p\">Cambia por&nbsp; &nbsp; :</div><br><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp;  : Analista Qu&#xED;mico.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp; &nbsp; : T&#xE9;cnico Analista Qu&#xED;mico.</div><br></div>", "i": 6049106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de octubre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6049107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "949 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-949 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 949 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA INACAP", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "MODIFICACION", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogac