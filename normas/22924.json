{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Fija en Paris la residencia del Consulado Jeneral de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1798.- Santiago, a 24 de Enero de 1906.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5951220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- El Consulado Jeneral de la Rep&#xFA;blica en Francia tendr&#xE1; su residencia en Par&#xED;s. </div></div>", "i": 5951221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- F. Puga Borne.</div><br></div>", "i": 5951222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1798", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1798"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "FIJA EN PARIS LA RESIDENCIA DEL CONSULADO JENERAL DE LA REPUBLICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FRANCIA", "CONSULADO GENERAL DE LA REPUBLICA EN", "FRANCIA", "RESIDENCIA", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-01-24", "doble_articulado": false, "id_norma": "22924", "numero_fuente": "8412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-01-24", "vigencias": [{"desde": "1906-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":