{"html": [{"t": "<div><div class=\"p\">&#xFEFF;Sueldos de los sarjentos mayores i ayudantes mayores</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Abril 6 de 1814.</div></div>", "i": 10209222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Habi&#xE9;ndose creado Planas Mayores veteranas en los Cuerpos de Milicias de Caballer&#xED;as para su instruccion i disciplina sin que este nuevo establecimiento tenga se&#xF1;alado sueldo a ella, he venido en declarar lo siguiente:</div><div class=\"p\">&nbsp; &nbsp;  A los Sarjentos Mayores el sueldo l&#xED;quido de $ 60.</div><div class=\"p\">&nbsp; &nbsp;  A los Ayudantes mayores, 35 id.</div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon en las Oficinas del Estado, circ&#xFA;lese i transcr&#xED;base en El Monitor.-</div></div>", "i": 10209223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lastra.-Orjera, secretario.</div></div>", "i": 10209224}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Sueldos de los sarjentos mayores i ayudantes mayores", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-04-06", "doble_articulado": false, "id_norma": "1154951", "numero_fuente": "1814", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-04-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i