{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6564224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.409, de 30 de noviembre de 2005, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del decreto MOP N&#xBA; 2.087, de 30 de octubre de 1998, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n, del lote de terreno N&#xBA; 6, que figura a nombre de Isa&#xED;as Delgado Tejeda. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n, fijada por la comisi&#xF3;n de peritos con fecha 6 de noviembre de 1997, ascendente a la cantidad de $105.999.</div><br></div>", "i": 6564225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6564226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1409", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1409"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-30", "doble_articulado": false, "id_norma": "248090", "numero_fuente": "38414", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-15", "vigencias": [{"desde": "2006-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones