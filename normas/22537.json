{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Elecciones Lei n&#xFA;m. 1,295.- Santiago, a 27 de Diciembre de 1899.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 8274244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Lo dispuesto en el inciso final del art&#xED;culo 65 (49) de la Lei de Elecciones rejir&#xE1; tambi&#xE9;n en caso de que se compruebe judicialmente la existencia de adulteraciones en el ejemplar del rejistro que guarda el Tesorero Municipal.</div><div class=\"p\">&nbsp; &nbsp; El Juez dar&#xE1; la &#xF3;rden de entrega de oficio o a peticion de cualquier ciudadano.</div><br><br></div>", "i": 8274245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- El&#xED;as Fern&#xE1;ndez A.</div><br></div>", "i": 8274246}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1295", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1295"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Elecciones", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELECCIONES", "REGISTRO ELECTORAL", "ADULTERACION", "COMPROBACION JUDICIAL", "COMISARIO", "JUEZ LETRAS", "ANTECEDENTES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-27", "doble_articulado": false, "id_norma": "22537", "numero_fuente": "6482", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-12-27", "vigencias": [{"desde": "1899-12-27", "hasta": "", "tipo_ve