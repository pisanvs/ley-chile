{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0; 638, de 30 de octubre de 1995, se expropiaron los lotes de terreno N&#xBA;s. 3, 5, 9, 10 y 19, superficies 699, 3.110, 152, 160 y 1.120 M2., respectivamente, roles de aval&#xFA;o N&#xBA;s. 337-60, 333-48, 336-26, 336-1, comunas de Nacimiento y Santa Juana, para la obra Camino de la Madera, sector Bifurcaci&#xF3;n Diuqu&#xED;n-Santa Juana y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Reineria Gonz&#xE1;lez Medina, Luis Medina Medina, Eduardo Mart&#xED;nez Mart&#xED;nez y Teresila Fuentes Medina, ascendente a las cantidades de $ 110.931, $658.076, $66.019 y $177.744.</div><br></div>", "i": 6743152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743153}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "638", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-638"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-30", "doble_articulado": false, "id_norma": "218628", "numero_fuente": "35331", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-01", "vigencias": [{"desde": "1995-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CM