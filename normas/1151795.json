{"html": [{"t": "<div><div class=\"p\">ADICION AL DECRETO ANTERIOR.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 12 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto:</div></div>", "i": 10182108}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En caso de ausencia, enfermedad o muerte del Presidente nombrado para el Consejo Directorial, le subrogar&#xE1; el Presidente de la Suprema Corte de Justicia.</div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; En caso de ausencia, enfermedad o muerte de alguno de los Ministros, el despacho de sus departamentos continuar&#xE1; sirvi&#xE9;ndose por los oficiales mayores de ellos, pero no entrar&#xE0; ninguno a subrogarles en el Consejo. </div><div class=\"p\">&nbsp; &nbsp;  3.&#xB0; Comun&#xED;quese e imprimase.</div></div>", "i": 10182109}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  -----&nbsp;  Campino.</div></div>", "i": 10182110}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE INTERIOR"], "titulo_norma": "ADICION AL DECRETO ANTERIOR.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-11-12", "doble_articulado": false, "id_norma": "1151795", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-11-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-11-12", "fin_vigenc