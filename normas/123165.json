{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6125770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. No. 876, de 30 de junio de 1998, se expropiaron los lotes de terreno No. s. 17-A y 35-B, superficies 469 y 97 m&#xB2;, respectivamente, roles de aval&#xFA;os en tr&#xE1;mite, comuna La Estrella, para la obra Camino L&#xED;mite Regional (Rapel) - Alcones I, Sector Litueche - La Rosa, se acord&#xF3; precio de las indemnizaciones con sus propietarios Luis Isidoro Y&#xE1;&#xF1;ez Atenas y Fernando Ren&#xE9; Herrera Huerta, ascendentes a las cantidades de $ 789.693.- para el lote No. 17-A y $ 566.721.- para el lote No. 35-B.</div><br></div>", "i": 6125771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6125772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "876", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-876"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LA ESTRELLA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-30", "doble_articulado": false, "id_norma": "123165", "numero_fuente": "36141", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-17", "vigencias": [{"desde": "1998-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-08-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_