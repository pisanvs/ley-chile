{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6285245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.723, de 28 de abril de 2000, se rectific&#xF3; el decreto MOP N&#xBA; 39 de 26 de enero de 2000 que orden&#xF3; la expropiaci&#xF3;n del lote N&#xBA; 11, en el sentido que la superficie de terreno es 8.733 m&#xB2; y que la Comisi&#xF3;n de Peritos fij&#xF3; con fecha 10 de abril de 2000, el valor provisional de la indemnizaci&#xF3;n en la cantidad de $31.748.500.-</div><br></div>", "i": 6285246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6285247}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1723", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1723"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "171835", "numero_fuente": "36702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-01", "vigencias": [{"desde": "2000-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CNB", "fecha_ingreso": "2000-07-03", "fecha_version": "2000-07-01", "fecha_actualizacion_texto": "2000-07-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estruc