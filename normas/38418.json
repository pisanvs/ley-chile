{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xBA; 138, DE 1992 </div><br></div>", "i": 6020945}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n exenta N&#xB0; 138 del 1&#xB0; de Diciembre de 1992, se adjudica a Servicios Oriente Soc. Ltda. la concesi&#xF3;n para operar, hasta el 14 de Febrero de 1995, un establecimiento ubicado en calle Bilbao 1070 comuna de Providencia, destinado a la revisi&#xF3;n t&#xE9;cnica de autom&#xF3;viles, station wagons, motocicletas, veh&#xED;culos de carga de menos de 1.750 kg. de capacidad de carga &#xFA;til y sus remolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6020946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Juan Fuentes Isla, Secretario Regional Ministerial Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana Subrogante.</div><br></div>", "i": 6020947}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "138 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-138 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "SANTIAGO", "REGION METROPOLITANA", "VEHICULOS MOTORIZADOS", "LIVIANOS", "SERVICIOS ORIENTE SOC. LTDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-01", "doble_articulado": false, "id_norma": "38418", "numero_fuente": "34497", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-02-20", "vigencias": [{"desde": "1993-02-20", "hasta": "