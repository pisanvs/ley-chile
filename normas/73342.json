{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6038607}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 429, de 30 de abril de 1997, se expropi&#xF3; el lote de terreno N&#xBA; 29, superficie 12.934 m&#xB2;, sin rol de aval&#xFA;o, comuna de Tom&#xE9;, para la obra Camino Acceso Norte a Concepci&#xF3;n, Ramal Colector, sector Rafael-Agua Amarilla, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Juana Mella Torres y otras, ascendente a la cantidad de $6.695.494.- </div></div>", "i": 6038608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6038609}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "429", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-429"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "TOME", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-30", "doble_articulado": false, "id_norma": "73342", "numero_fuente": "35779", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-02", "vigencias": [{"desde": "1997-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMR", "fecha_ingreso": "1997-06-18", "fecha_version": "1997-06-02", "fecha_actualizacion_texto": "1997-06-02", "tipo_tratado": ""}, "alertas": [], "alerta_global":