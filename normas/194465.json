{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.082 EXENTO, DE 2001 </div></div>", "i": 6368654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.082 de fecha 12 de diciembre de 2001 del Ministerio de Educaci&#xF3;n, se autoriza a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Nacional de Estudios Param&#xE9;dicos y Agropecuarios Propam, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 2002:</div><br><div class=\"p\">Sede N&#xBA; 2 - Iquique</div><br><br><div class=\"p\">Carrera&nbsp; : T&#xE9;cnico en Enfermer&#xED;a de Nivel Superior.</div><div class=\"p\">T&#xED;tulo&nbsp;  : T&#xE9;cnico en Enfermer&#xED;a de Nivel Superior.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (Dec. Ex. N&#xBA; 409 de 16.04.01)</div><br></div>", "i": 6368655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de enero de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6368656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1082 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1082 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.082 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-12", "doble_articulado": false, "id_norma": "194465", "numero_fuente": "37181", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-08", "vigencias": [{"desde": "2002-02-08", "hasta": "", "ti