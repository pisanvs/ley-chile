{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.125, de 19 de junio de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; decl&#xE1;rase la caducidad de las Resoluciones N&#xB0; 129, de 1985, N&#xB0; 939, de 1988 y N&#xB0; 473, de 1992, todas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autorizaron a PESQUERA LOA SUR S.A., para desarrollar actividades pesqueras extractivas con las naves &quot;Loa 6&quot; y &quot;Loa 8&quot;, por haberse configurado la causal de caducidad prevista en el art&#xED;culo 143 letra b) de la Ley N&#xB0; 18.892 y sus modificaciones, citada en Visto. </div></div>", "i": 8295871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 19 de junio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1125", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1125"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA LOA SUR S.A", "CADUCIDAD", "AUTORIZACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-19", "doble_articulado": false, "id_norma": "36297", "numero_fuente": "35499", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-06-24", "vigencias": [{"desde": "1996-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-06-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci