{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,834.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6191337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Ab&#xF3;nase, por gracia, al Ministro de la Corte de Apelaciones de Santiago, don Juan Guillermo MacKai, para los efectos de su jubilacion, el tiempo que sirvi&#xF3; como secretario del Juzgado de Letras de Nacimiento. </div></div>", "i": 6191338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiuno de enero de mil novecientos veintidos.- Arturo Alessandri.- Roberto S&#xE1;nchez. </div></div>", "i": 6191339}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3834", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3834"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1922-01-21", "doble_articulado": false, "id_norma": "143448", "numero_fuente": "13184", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1922-01-25", "vigencias": [{"desde": "1922-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1922-01-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1922-01-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingres