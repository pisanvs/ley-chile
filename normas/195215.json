{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7289896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;475, de 26 de febrero de 2002, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 835 de 1992, de esta Subsecretar&#xED;a, s&#xF3;lo</div><div class=\"p\">en cuanto autoriz&#xF3; a PESQUERA EL GOLFO S.A. para</div><div class=\"p\">realizar actividades con la nave Crist&#xF3;bal Col&#xF3;n, sobre</div><div class=\"p\">el recurso Raya, en el &#xE1;rea mar&#xED;tima comprendida entre</div><div class=\"p\">la VII y IX Regiones, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7289897}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de febrero de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7289898}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "475", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-475"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-26", "doble_articulado": false, "id_norma": "195215", "numero_fuente": "37202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-05", "vigencias": [{"desde": "2002-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen