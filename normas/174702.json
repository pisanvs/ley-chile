{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA </div></div>", "i": 7276244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero, mediante resoluci&#xF3;n exenta N&#xBA; 63 de 25 de Enero de 1988, rectific&#xF3; resoluci&#xF3;n exenta N&#xBA; 875 de fecha 25 de Junio de 1987, que aprob&#xF3; Estudio T&#xE9;cnico de Distribuci&#xF3;n de Derechos de Aprovechamiento de Aguas del Proyecto de Parcelaci&#xF3;n &quot;Los Aromos&quot;, de la comuna de San Nicol&#xE1;s, en el sentido de dejar constancia que al Bien Com&#xFA;n General N&#xBA; 2 corresponden derecho de agua del Canal Arancibia derivado del R&#xED;o &#xD1;uble y no al Bien Com&#xFA;n General N&#xBA; 1 como expresaba dicha resoluci&#xF3;n. Publicaci&#xF3;n hecha conforme Art. 13 Ley 18.377.-</div><br></div>", "i": 7276245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 7276246}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "63 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-63 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-25", "doble_articulado": false, "id_norma": "174702", "numero_fuente": "32984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-01", "vigencias": [{"desde": "1988-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-01", "fin_vigencia": ""}, "vigencias_version_norm