{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA; 91, DE 1985 </div></div>", "i": 6258129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 91, de 10 de Junio de 1985, se ha procedido a aprobar un plan de estudio especial para educaci&#xF3;n media human&#xED;stico cient&#xED;fica al Liceo A N&#xBA; 33, de Concepci&#xF3;n, que se aplicar&#xE1; a contar de 1985 en 1&#xBA; 2&#xBA; y 3er. a&#xF1;o y en 1986 hasta 4&#xBA; a&#xF1;o y que consiste en que se aprueban tres planes diferenciados: human&#xED;stico, biol&#xF3;gico y matem&#xE1;tico para 3&#xBA; y 4&#xBA; a&#xF1;o medio.</div><br></div>", "i": 6258130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de Junio de 1985.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6258131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "91 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-91 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº 91, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-10", "doble_articulado": false, "id_norma": "163342", "numero_fuente": "32206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-26", "vigencias": [{"desde": "1985-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "