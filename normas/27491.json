{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA EL NOMBRE DE LA AVENIDA QUE INDICA, POR EL QUE SE&#xD1;ALA, EN LA CIUDAD DE ANGOL</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8280928}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Denom&#xED;nase &quot;Jos&#xE9; Luis Osorio Navarrete&quot;, a la actual &quot;Avenida Agricultura&quot;, de la ciudad de Angol.&quot; </div></div>", "i": 8280929}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintinueve de septiembre de mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 8280930}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13546", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13546"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA EL NOMBRE DE LA AVENIDA QUE INDICA, POR EL\nQUE SEÑALA, EN LA CIUDAD DE ANGOL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMBIO NOMBRE", "AVENIDA JOSE LUIS OSORIO NAVARRETE", "ANGOL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-09-29", "doble_articulado": false, "id_norma": "27491", "numero_fuente": "24464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-10-10", "vigencias": [{"desde": "1959-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1959-10-10", "fin_vig