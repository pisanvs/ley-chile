{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ESTABLECE QUE EL LICEO DE HOMBRES DE CURICO SE DENOMINARA &quot;LICEO LUIS CRUZ MARTINEZ&quot;</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5973528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. El Liceo de Hombres de Curic&#xF3; se denominar&#xE1;, en lo sucesivo, &quot;Liceo Luis Cruz Mart&#xED;nez&quot;. </div></div>", "i": 5973529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dos de julio de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Francisco Cereceda. </div></div>", "i": 5973530}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13962", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13962"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "ESTABLECE QUE EL LICEO DE HOMBRES DE CURICO SE DENOMINARA LICEO LUIS CRUZ MARTINEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "LICEO LUIS CRUZ MARTINEZ", "CURICO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-07-02", "doble_articulado": false, "id_norma": "27596", "numero_fuente": "24717", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-08-12", "vigencias": [{"desde": "1960-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":