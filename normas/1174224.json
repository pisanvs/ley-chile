{"html": [{"t": "<div><div class=\"p\">AUTORIZA A ORGANISMO P&#xDA;BLICO EN LO QUE INDICA</div></div>", "i": 10321342}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. del Servicio de Impuestos Internos N&#xB0; 29, de 24-03-2022, establece que:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Autoriza como receptor electr&#xF3;nico, a contar del mes de marzo de 2022, al siguiente Organismo P&#xFA;blico:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Servicio Nacional de Migraciones, RUT 62.000.920-2.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Debiendo ajustarse a las instrucciones dispuestas en la <a href=\"https://www.leychile.cl/Navegar?idNorma=227838&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 63, de 2004</a>, modificada por la resoluci&#xF3;n exenta N&#xB0; 91, de 2017.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div><br></div>", "i": 10321343}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "29 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-29 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A ORGANISMO PÚBLICO EN LO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2107265", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-03-24", "doble_articulado": false, "id_norma": "1174224", "numero_fuente": "43217", "tipo_vers