{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;45, DE 2000</div><br><br></div>", "i": 6277959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA;45, de 2 de mayo del a&#xF1;o 2000, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la Cooperativa de Trabajo Desarrollo Productivo de Chilo&#xE9;, de nombre de fantas&#xED;a Isla Grande Limitada, de la ciudad de Ancud, en los t&#xE9;rminos que da testimonio el acta constitutiva protocolizada con fecha 2 de marzo de 2000, bajo el N&#xBA;282, y el acta complementaria protocolizada con fecha 7 de abril del mismo a&#xF1;o, bajo el N&#xBA;507, al final de los registros del Notario de Ancud, do&#xF1;a Martita W&#xF6;rner Tapia. </div></div>", "i": 6277960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6277961}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "45", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-45"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº45, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-02", "doble_articulado": false, "id_norma": "169519", "numero_fuente": "36673", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-26", "vigencias": [{"desde": "2000-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s"