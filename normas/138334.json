{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACIONES QUE INDICA</div><br><br></div>", "i": 6175097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 70, de fecha 14 de mayo de 1999, de Serviu Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiaci&#xF3;n, conforme art. 51 ley 16.391 y D.L. 2.186 de 1978, de parte del inmueble ubicado en calle Independencia N&#xBA; 414 presunto rol aval&#xFA;o 111-33 comuna de Vicu&#xF1;a, de aparentemente dominio de Sucesi&#xF3;n Maximiliano Ortiz Rivera, de una superficie aproximada de 30,40 metros cuadrados. Comisi&#xF3;n Peritos integrada por el ingeniero agr&#xF3;nomo don H&#xE9;ctor Baeza Morales, el contador auditor don Alfredo Ba&#xF1;ados Moreno y el arquitecto don Oscar Lara Vel&#xE1;squez, seg&#xFA;n informe de 15 de febrero de 1999, fij&#xF3; monto provisional indemnizaci&#xF3;n en $639.716, debidamente reajustada, pagadera al contado.- </div></div>", "i": 6175098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Coquimbo.</div><br></div>", "i": 6175099}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "70", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-70"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-14", "doble_articulado": false, "id_norma": "138334", "numero_fuente": "36401", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-01", "vigencias": [{"desde": "1999-07-01", "hasta": "", "tipo_version": "3", "tipo_version