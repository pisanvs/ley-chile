{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7353752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA;728 de 30 de julio de 2007 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n total, conforme D.L. N&#xBA; 2.186 de 1978, del inmueble ubicado en V. Mackenna N&#xBA;10720 Lote E, presunto Rol de Aval&#xFA;o N&#xBA;3.500-65, comuna de La Florida, de aparente dominio de Berta Luisa Cort&#xE9;s Vergara; correspondiente al Lote N&#xBA;12, del Proyecto Vial &quot;Corredor de Transporte P&#xFA;blico Av. Vicu&#xF1;a Mackenna&quot;. Comisi&#xF3;n integrada por Ver&#xF3;nica Olivier Valdebenito, Arquitecto, Miguel Fern&#xE1;ndez C&#xE1;diz, Constructor Civil e Ingrid Von Osten, Ingeniero Civil, seg&#xFA;n informe de 20 de septiembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $35.147.400.- pagadera al contado.</div><br></div>", "i": 7353753}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7353754}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "728", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-728"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-30", "doble_articulado": false, "id_norma": "264808", "numero_fuente": "38865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-15", "vigencias": [{"desde": "2007-09-15", "hasta": "", "tipo_version": "3", "tip