{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6523760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 194 de fecha 29 de marzo de 2005, se expropi&#xF3; el lote de terreno N&#xBA; 61, superficie 440,4 m2, rol en tr&#xE1;mite, comuna de Linares, para la obra &quot;Camino Ruta L-45, Sector Linares - Llepo, Tramo Km. 2,750.2 a Km. 13,147&quot;, VII Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Ilustre Municipalidad de Linares, ascendente a la cantidad de $13.335.878.</div><br></div>", "i": 6523761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6523762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "194", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-194"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-29", "doble_articulado": false, "id_norma": "237503", "numero_fuente": "38150", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-02", "vigencias": [{"desde": "2005-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-05-02", "fecha_version": "2005-05-02", "fecha_actualizacion_texto": "2005-05-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Enc