{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Instituto de Hijiene.- Fondos para proseguir su reconstruccion</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1698.- Santiago, a 22 de Setiembre de 1904.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional, ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 8274634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de veintisiete mil trescientos ochenta i nueve pesos ocho centavos, en proseguir los trabajos de construccion del edificio del Instituto de Hijiene.</div><br></div>", "i": 8274635}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp; JERMAN RIESCO.- M. E. Ballesteros.</div><br></div>", "i": 8274636}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1698", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1698"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "INSTITUTO DE HIJIENE.- FONDOS PARA PROSEGUIR SU RECONSTRUCCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO HIGIENE", "PRESIDENTE REPUBLICA", "INVERSION", "AUTORIZACION", "RECONSTRUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-09-22", "doble_articulado": false, "id_norma": "22857", "numero_fuente": "8012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-09-22", "vigencias": [{"desde": "1904-09-22", "hasta": "", "tipo_versi