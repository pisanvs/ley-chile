{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 2.396, DE 1989 </div></div>", "i": 7221074}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 2.396 de fecha 01 de septiembre de 1989 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se insert&#xF3; en la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 2.346 de 1987 y No.</div><div class=\"p\">3.431 de 1988 del Centro de Formaci&#xF3;n T&#xE9;cnica Fundaci&#xF3;n EPSON de Santiago, las adecuaciones introducidas en la carrera de Administraci&#xF3;n de Empresas menci&#xF3;n en Inform&#xE1;tica, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1989. </div></div>", "i": 7221075}, {"t": "<div><div class=\"p\">Santiago 26 de Octubre de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7221076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2396 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2396 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 2.396, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-09-01", "doble_articulado": false, "id_norma": "86319", "numero_fuente": "33598", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-16", "vigencias": [{"desde": "1990-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe