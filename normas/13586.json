{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5913781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto MOP. N&#xB0; 462, de 7 de octubre de 1994 y en base a la facultad otorgada por el art&#xED;culo 105 del Decreto MOP. N&#xB0; 294, de 1984, que fij&#xF3; el texto actualizado de la Ley N&#xB0; 15.840, se expropi&#xF3; el lote de terreno N&#xB0; 1, para obra Camino Longitudinal Sur, Ruta 5, sector Panguilemo- San Javier, que figura a nombre de H&#xE9;ctor M. Ortiz Berr&#xED;os, rol de aval&#xFA;o 152-37, comuna de Maule, VII Regi&#xF3;n, superficie 36 M2. Posteriormente, por Decreto MOP. N&#xB0; 78, de 28 de febrero de 1995, se autoriz&#xF3; el Convenio Directo de Precio, acord&#xE1;ndose el valor de indemnizaci&#xF3;n con dicho propietario, en la cantidad de $190.820.</div><br></div>", "i": 5913782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5913783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "462", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-462"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "MAULE", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-10-07", "doble_articulado": false, "id_norma": "13586", "numero_fuente": "35182-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-01", "vigencias": [{"desde": "1995-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-06-01", "fin_vi