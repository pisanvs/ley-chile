{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO ALCALDICIO N&#xBA; 1.171 DE 2004 </div></div>", "i": 6482262}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante decreto alcaldicio N&#xBA; 1.171 de fecha 26.05.04 se aprob&#xF3; la modificaci&#xF3;n a la Ordenanza de Subvenciones Municipales, aprobada por decreto alcaldicio N&#xBA; 2.588 de fecha 24.12.2003, elimin&#xE1;ndose el &#xFA;ltimo inciso del art&#xED;culo 12&#xBA;.</div><div class=\"p\">Se deja constancia que la dictaci&#xF3;n de la referida Ordenanza fue informada a la comunidad mediante publicaci&#xF3;n de fecha 29.12.2003 en el diario &quot;Cr&#xF3;nica&quot; de Concepci&#xF3;n.</div><br></div>", "i": 6482263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Renato A. Gal&#xE1;n Or&#xF3;stica, Alcalde.- Oscar M. San Mart&#xED;n Alvarez, Secretario Municipal.</div><br></div>", "i": 6482264}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1171", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1171"}], "organismos": ["MUNICIPALIDAD DE HUALQUI"], "titulo_norma": "EXTRACTO DECRETO ALCALDICIO Nº 1.171 DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-26", "doble_articulado": false, "id_norma": "226061", "numero_fuente": "37877", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-04", "vigencias": [{"desde": "2004-06-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingres