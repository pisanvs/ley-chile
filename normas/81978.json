{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 222, DE 1990 </div></div>", "i": 7216942}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 222 de 3 de septiembre de 1990 se ha complementado, a contar de la fecha de su vigencia, el decreto supremo exento de Educaci&#xF3;n No. 190, de 1989, que aprob&#xF3; planes y programas de estudio para 7&#xB0; y 8&#xB0; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica y para Educaci&#xF3;n Media, al Instituto de Humanidades Luis Campino, de Santiago, en el sentido de declarar la asignatura de franc&#xE9;s optativa con incidencia en la promoci&#xF3;n, en 7&#xB0; y 8&#xB0; a&#xF1;o b&#xE1;sico.</div><br></div>", "i": 7216943}, {"t": "<div><div class=\"p\">Santiago, 13 de Septiembre de 1990.- Gast&#xF3;n Gilbert Baettig, Subsecretario de Educaci&#xF3;n subrogante.</div><br></div>", "i": 7216944}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "222 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-222 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 222, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-09-03", "doble_articulado": false, "id_norma": "81978", "numero_fuente": "33791", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-10-11", "vigencias": [{"desde": "1990-10-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-10-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-10-11", "fin_vigencia": "", "tipo_version": "3"}]