{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.802 EXENTA, DE 20.08.2015</div></div>", "i": 9632678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por la presenta resoluci&#xF3;n exenta se han derogado las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=169589&amp;idParte=&amp;idVersion=\">Nos 12.880, de 1999</a>; <a href=\"https://www.leychile.cl/Navegar?idNorma=184779&amp;idParte=&amp;idVersion=\">5.114, de 2001</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=217688&amp;idParte=&amp;idVersion=\">5.629, de 2003</a>, todas del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Academia de Humanidades (Padres Dominicos), comuna de Recoleta, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><br><br><br></div>", "i": 9632679, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de agosto de 2015.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9632680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5802 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5802 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.802 EXENTA, DE 20.08.2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 940015"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-08-20", "doble_articulado": false, "id_norma": "1080968", "numero_fuente": "41246", "tipo_version": "3", "tip