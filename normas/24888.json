{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a do&#xF1;a Catalina El&#xED;as viuda de Guti&#xE9;rrez.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional a dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 9042227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dece, por gracia y por el plazo de diez a&#xF1;os, a do&#xF1;a Catalina El&#xED;as viuda de Guti&#xE9;rrez, el goce de una pensi&#xF3;n de setenta y cinco pesos mensuales, la cual disfrutar&#xE1; con arreglo a lo dispuesto en la ley de montep&#xED;o militar, y a contar desde el 1.o de Enero de 1930.</div><br></div>", "i": 9042228}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta y uno de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Carlos O. Frodden.</div><br></div>", "i": 9042229}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4755", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4755"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "CONCEDE PENSIÓN DE GRACIA A DOÑA CATALINA ELIAS VIUDA DE GUTIÉRREZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CATALINA ELIAS VIUDA DE GUTIERREZ", "PENSION POR", "GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-31", "doble_articulado": false, "id_norma": "24888", "numero_fuente": "15579", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-01-23", "vigencias": [{"