{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9268494}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.635, de 14 de junio de 2012, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n exenta N&#xBA; 1.586, de 2012, que autoriz&#xF3; a EDIC INGENIEROS S.A. para desarrollar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Pesca de investigaci&#xF3;n de la flora y fauna acu&#xE1;tica en cursos y cuerpos de aguas continentales e insulares de Chile&quot;, en el sentido de reemplazar el numeral 13.-, por el indicado en la resoluci&#xF3;n extractada.</div></div>", "i": 9268495}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de junio de 2012.- Felipe Palacio Rives, Subsecretario de Pesca (S).</div></div>", "i": 9268496}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1635 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1635 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-14", "doble_articulado": false, "id_norma": "1041226", "numero_fuente": "40294", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-22", "vigencias": [{"desde": "2012-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi