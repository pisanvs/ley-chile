{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 117, DE 1980 </div></div>", "i": 8460242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 207 de 05 de Marzo de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 117, de 25 de Marzo de 1980, de la misma Subsecretar&#xED;a que autoriz&#xF3; a Algas Marinas S.A., para sembrar, cultivar y explotar praderas artificiales de alga Gracilaria en Estero del Dique, y R&#xED;o Pudeto, de la Comuna de Ancud, en orden a fijar nuevas&nbsp; reas y exigencias para el desarrollo de dicha actividad, conforme a lo dispuesto en el Decreto 175, de 1980, de la Subsecretar&#xED;a de Estado mencionada.</div><br></div>", "i": 8460243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 05 de Marzo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 8460244}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "207", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-207"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 117, DE 1980", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-03-05", "doble_articulado": false, "id_norma": "158329", "numero_fuente": "32424", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-17", "vigencias": [{"desde": "1986-03-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici