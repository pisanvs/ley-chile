{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6226983}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 490 de 03 de junio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Edison Gallardo Ruiz, Jos&#xE9; Peralta Barrientos y Julia del C. Pereira y Otro para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 1 &quot;Centro-Poblaci&#xF3;n Los Canales&quot; de Puerto Varas, cuyo trazado fue autorizado por resoluci&#xF3;n No. 118 de 28 de Junio de 1984, de esta Secretaria Regional.- </div></div>", "i": 6226984}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones, X Regi&#xF3;n.</div><br></div>", "i": 6226985}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "490 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-490 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-03", "doble_articulado": false, "id_norma": "153775", "numero_fuente": "32871", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-15", "vigencias": [{"desde": "1987-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-15", "fin_vigencia": "", "ti