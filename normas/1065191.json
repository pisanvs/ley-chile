{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9494249}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.991, de 30 de julio de 2014, de esta Subsecretar&#xED;a, <a href=\"https://www.leychile.cl/Navegar?idNorma=1064098&amp;idParte=0&amp;idVersion=\">modifica resoluci&#xF3;n N&#xBA; 1.692, de 2014</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 18B, cambiando la clasificaci&#xF3;n de bioseguridad a Baja 1, las densidades de cultivo y el n&#xFA;mero de ejemplares a ingresar, en la forma se&#xF1;alada en la resoluci&#xF3;n extractada.</div></div>", "i": 9494250}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de julio de 2014.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9494251}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1991 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1991 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-07-30", "doble_articulado": false, "id_norma": "1065191", "numero_fuente": "40926", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-08-06", "vigencias": [{"desde": "2014-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-08-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-08-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci