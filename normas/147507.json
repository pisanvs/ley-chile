{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA QUELLON LTDA. PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 8353354}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 357, de 23 de Abril de 1987, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se amplia la resoluci&#xF3;n No. 325, de 1986, en el sentido de autorizar a Pesquera Quell&#xF3;n Ltda., domiciliada en Santiago, para procesar en la l&#xED;nea de congelado, adem&#xE1;s de los recursos hidrobiol&#xF3;gicos que en dicha resoluci&#xF3;n se se&#xF1;alan, la especie erizo.</div><br></div>", "i": 8353355}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Abril de 1987.- Roberto Cabezas Bello,, Subsecretario de Pesca.</div><br></div>", "i": 8353356}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "357", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-357"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA QUELLON LTDA. PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-04-23", "fecha_derogacion": "1989-08-17", "doble_articulado": false, "id_norma": "147507", "numero_fuente": "32760", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-05-02", "vigencias": [{"desde": "1989-08-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-05-02", "hasta": "1989-08-16", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1989-08-1