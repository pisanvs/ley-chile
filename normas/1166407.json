{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10276077}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 926, de 7 septiembre 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos que indica en condiciones que se&#xF1;ala, relativas a Obra de Conexi&#xF3;n de Uni&#xF3;n Domiciliaria de Alcantarillado en calle Los Maquis de Coyhaique, y autoriz&#xF3; a empresa contratista Mario Jaramillo Gallardo para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte parcial de calle Los Maquis, frente al n&#xFA;mero 896 (entre Los Canelos y Los Cipreses), desde el d&#xED;a 20-09-2021 hasta el d&#xED;a 10-10-2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10276078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10276079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "926 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-926 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2024039", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-07", "doble_articulado": false, "id_norma": "1166407", "numero_fuente": "43077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-14", "vigencias": [{"des