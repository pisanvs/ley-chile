{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6366052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.987, de fecha 30 de noviembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;16-A, superficie 6.723 m2, rol de aval&#xFA;o 75-1, comuna de Teno, VII Regi&#xF3;n, para la obra &quot;Camino ruta J-25, Sector Cruce Longitudinal-La Monta&#xF1;a, Km. 0,22000 al 25,00000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario don Jos&#xE9; del Carmen Aliaga Castro, ascendente a la cantidad de $8.852.705.</div><br></div>", "i": 6366053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6366054}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1987", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1987"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "193828", "numero_fuente": "37160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-15", "vigencias": [{"desde": "2002-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-01-16", "fecha_version": "2002-01-15", "fecha_actualizacion_texto": "2002-01-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "