{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 3.427 EXENTO, DE 2008 </div></div>", "i": 6951116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 3.427, de fecha 14 de noviembre de 2008, de Educaci&#xF3;n, decl&#xE1;rase aprobada en jornada diurna, al Instituto Profesional Projazz, la modificaci&#xF3;n mayor al plan y los programas de estudios de la carrera Profesional que se indica:</div><div class=\"p\">Carrera&nbsp;  :&nbsp; &nbsp; Composici&#xF3;n Musical con menci&#xF3;n en</div><div class=\"p\">Interpretaci&#xF3;n Musical y en M&#xFA;sica para Cine y Medios Audiovisuales.</div><br><div class=\"p\">T&#xED;tulo Profesional&nbsp;  :&nbsp; &nbsp; Compositor Musical.</div><br><br></div>", "i": 6951117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Dicha modificaci&#xF3;n podr&#xE1; ser implementada en jornada diurna a partir del primer semestre de 2009, en la ciudad de Santiago.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6951118}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3427 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3427 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 3.427 EXENTO, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-14", "doble_articulado": false, "id_norma": "285474", "numero_fuente": "39266", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-20", "vigencias": [{"desde": "2009-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-01-20", "f