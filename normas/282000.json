{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7381043}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.947, de 11 de noviembre de&nbsp; 2008, de esta Subsecretar&#xED;a, modif&#xED;canse los numerales&nbsp; 4&#xBA; y 5&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 442, modificada mediante resoluciones exentas N&#xBA; 910 y N&#xBA; 2.762, todas&nbsp; de 2008, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca&nbsp; de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Monitoreo de Anchoveta y Sardina en aguas interiores de la X Regi&#xF3;n de Los Lagos-Sur, 2008&quot;, en el sentido de reemplazar a la embarcaci&#xF3;n artesanal &quot;Oceani I&quot; por la embarcaci&#xF3;n &quot;Oceani III&quot;.</div><br></div>", "i": 7381044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de noviembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 7381045}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2947 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2947 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-11", "doble_articulado": false, "id_norma": "282000", "numero_fuente": "39218", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-21", "vigencias": [{"desde": "2008-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}