{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9148852}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.500, de 3 de junio de 2011, de esta Subsecretar&#xED;a, rech&#xE1;zanse las solicitudes de concesi&#xF3;n de acuicultura n&#xFA;meros 206031002, 206103122, 97110008, 205031037 y 205031036, se&#xF1;aladas en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl, en virtud del art&#xED;culo 78, de la Ley General de Pesca y Acuicultura y art&#xED;culo 14, del DS N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div></div>", "i": 9148853}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de junio de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9148854}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1500 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1500 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-06-03", "doble_articulado": false, "id_norma": "1026366", "numero_fuente": "39982", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-06-10", "vigencias": [{"desde": "2011-06-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-06-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-06-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po