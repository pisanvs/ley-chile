{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.342, de 18 de julio de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a RICO FOOD S.A.,</div><div class=\"p\">para iniciar actividades pesqueras de transformaci&#xF3;n, en</div><div class=\"p\">orden a instalar y operar una planta ubicada en Parque</div><div class=\"p\">Industrial Coronel, Manzana 24, Coronel, donde podr&#xE1;</div><div class=\"p\">procesar en la l&#xED;nea de elaboraci&#xF3;n de Deshidratado</div><div class=\"p\">artificial, los siguientes recursos: Cochayuyo, Chicorea de mar, Luga-Luga y Pelillo.</div><div class=\"p\">&nbsp; &nbsp; Cad&#xFA;case la Resoluci&#xF3;n N&#xB0; 462, de 1996, de esta Subsecretar&#xED;a, conforme lo dispuesto en el art&#xED;culo 6&#xB0;, del D.S. N&#xB0; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8296954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de julio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296955}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1342", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1342"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RICO FOOD S.A.", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07-18", "doble_articulado": false, "id_norma": "36751", "numero_fuente