{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9293101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. (Exento) N&#xBA;1467, de fecha 31 de julio de 2012, y de conformidad a lo dispuesto en el art&#xED;culo 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;48, superficie 162 m2., rol N&#xBA;41-177, para la obra &quot;MEJORAMIENTO RUTA I-70-J, SECTOR LOLOL - RANGUIL, KM. 0,00000 A KM. 19,38878&quot;, comuna de Lolol, Provincia de Colchagua, VI Regi&#xF3;n. La comisi&#xF3;n de peritos, integrada por Manuel D&#xED;az Farfan, Patricio Casagrande Ulloa y Orlando Fari&#xF1;a V&#xE1;squez, fij&#xF3; el valor de tasaci&#xF3;n con fecha 20 de mayo de 2009, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietaria ELSA DEL CARMEN MU&#xD1;OZ CASTRO, en la cantidad de $727.357, suma que se pagar&#xE1; al contado. </div></div>", "i": 9293102}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9293103}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1467 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1467 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-31", "doble_articulado": false, "id_norma": "1043421", "numero_fuente": "40352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-01", "vigencias": [{"desde": "2012-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-01", "fin_vigencia": ""}, "vigencias_ver