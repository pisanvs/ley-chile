{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6193040}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1400 de 19 de Diciembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza. a don Juan Jos&#xE9; S&#xE1;nchez Espinoza, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6193041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Diciembre de 1986.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6193042}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1400 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1400 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-19", "doble_articulado": false, "id_norma": "144042", "numero_fuente": "32687", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-02", "vigencias": [{"desde": "1987-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-02", "fin_vigencia": ""