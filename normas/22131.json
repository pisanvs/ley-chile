{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LEI DE CONTRIBUCIONES.-MODIFICACIONES Lei n&#xFA;m. 278.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947403}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Supr&#xED;mise el inciso 2&#xB0; del n&#xFA;mero 1&#xB0; del art&#xED;culo 2&#xB0; de la lei de 21 de Enero de 1895 que autoriza el cobro de las contribuciones.</div><div class=\"p\">&nbsp; &nbsp; Supr&#xED;mise tambien la segunda parte del n&#xFA;mero 2&#xB0; del mismo art&#xED;culo, que dice: &quot;no debiendo pagarlo los establecimientos que esten gravados con el impuesto que establece el n&#xFA;mero 1&#xB0; de este mismo art&#xED;culo&quot;.</div><br><br></div>", "i": 5947404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 11 de Febrero de 1895.-Jorje Montt.-M.</div><div class=\"p\">S. Fern&#xE1;ndez.</div><br></div>", "i": 5947405}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "278", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-278"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI DE CONTRIBUCIONES.-MODIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["IMPUESTOS", "CONTRIBUCIONES", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-02-11", "doble_articulado": false, "id_norma": "22131", "numero_fuente": "5037", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-02-11", "vigencias": [