{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6455725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.231, de 4 de diciembre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a CULTIVOS MARINOS DEL SUR S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Canal Quihua s/n, Sector San Rafael, Calbuco, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n Fresco-Enfriado, Fresco-Refrigerado, Congelado, Ahumado, Alga Seca, Deshidratado y Cocido, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada. </div></div>", "i": 6455726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de diciembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6455727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3231 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3231 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-04", "doble_articulado": false, "id_norma": "219361", "numero_fuente": "37743", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-24", "vigencias": [{"desde": "2003-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":