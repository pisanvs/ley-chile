{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6511707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.480, de 6 de diciembre de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 3.382, de 2004, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a MARES CHILE LIMITADA para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Control y monitoreo de la pesquer&#xED;a de Merluza del sur (Merluccius australis) en aguas interiores de la XII Regi&#xF3;n&quot;, en el sentido de incrementar en 35,926 toneladas la cuota autorizada para el mes de diciembre.</div><br></div>", "i": 6511708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6511709}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3480 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3480 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-06", "doble_articulado": false, "id_norma": "234317", "numero_fuente": "38052", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-05", "vigencias": [{"desde": "2005-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-01-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-01-05", "fin