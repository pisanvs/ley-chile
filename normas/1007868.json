{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8798219}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.515, de 20 de octubre de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a JOS&#xC9; MARIANO MONTEALEGRE ANDRADE para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar planta ubicada en Lote dos del Lote A, Predio Santa Gema, camino Chill&#xE1;n a Yungay, Km. 10, Chill&#xE1;n Viejo, Chill&#xE1;n, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea Alga seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div></div>", "i": 8798220}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de octubre de 2009.- Germ&#xE1;n Loyola Bast&#xED;as, Subsecretario de Pesca (S).</div></div>", "i": 8798221}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3515 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3515 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-20", "doble_articulado": false, "id_norma": "1007868", "numero_fuente": "39506", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-11-09", "vigencias": [{"desde": "2009-11-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-11-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-11-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingre