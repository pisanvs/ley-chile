{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO CIRCULAR N&#xB0; 20, DE 1995</div><br><br><br></div>", "i": 7104605}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Imparte nuevas instrucciones sobre verificaci&#xF3;n de actividades</div><div class=\"p\">&nbsp; &nbsp; Esta circular dicta normas y fija procedimientos para efectuar la verificaci&#xF3;n de Actividades a los contribuyentes, y espec&#xED;ficamente, se define en qu&#xE9; consiste, a qui&#xE9;nes debe realizarla, cu&#xE1;ndo realizarla, y c&#xF3;mo y qui&#xE9;n debe hacerla.</div><div class=\"p\">&nbsp; &nbsp; Al respecto se imparten las siguientes normas e instrucciones:</div><div class=\"p\">&nbsp; &nbsp; 1. Normas y disposiciones.</div><div class=\"p\">&nbsp; &nbsp; 2. Verificaci&#xF3;n Interna de Antecedentes.</div><div class=\"p\">&nbsp; &nbsp; 3. Procedimiento.</div><div class=\"p\">&nbsp; &nbsp; La presente Circular ser&#xE1; publicada in extenso en el Bolet&#xED;n del Servicio del mes de Mayo.</div><br></div>", "i": 7104606}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 12 de Mayo de 1995.- Javier Etcheberry Celhay, Director.</div><br></div>", "i": 7104607}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "20", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "CIR-20"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO CIRCULAR N° 20, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTRUCCIONES", "SERVICIO IMPUESTOS INTERNOS", "CONTRIBUYENTE", "VERIFICACION ACTIVIDADES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-05-12", "fecha_derogacion": "1998-01-26", "doble_articulado": false, "id_norma": "1914"