{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MUNICIPALIDAD DE PARRAL Lei n&#xFA;m. 157.-Santiago, a 10 de Enero de 1894.-Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase a la Municipalidad de Parral para contratar en cuenta corriente un empr&#xE9;stito de diez mil pesos, que se destinar&#xE1; a pagar los gastos ordinarios fijados en su presupuesto.</div><div class=\"p\">&nbsp; &nbsp; Al formar su presupuesto para el a&#xF1;o 1894, la Municipalidad de Parral consultar&#xE1; en &#xE9;l, de preferencia, las sumas necesarias para la cancelacion total de la deuda.</div><br><br></div>", "i": 8273780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.- Pedro Montt.</div><br></div>", "i": 8273781}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "157", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-157"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MUNICIPALIDAD DE PARRAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARRAL", "MUNICIPALIDAD", "EMPRESTITO", "CONTRATACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-10", "doble_articulado": false, "id_norma": "22018", "numero_fuente": "4714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-01-11", "vigencias": [{"desde": "1894-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc