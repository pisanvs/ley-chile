{"html": [{"t": "<div><br><div class=\"p\">&#xFEFF;ACLARA EL DECRETO CON FUERZA DE LEY NUMERO 132 DE 1960</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 341.- Santiago, 5 de Abril de 1960.- Vistas, las facultades que me confiere la ley N.o 13,305, de 6 de Abril de 1958, vengo en&nbsp; dictar el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto con fuerza de ley:</div></div>", "i": 10131980}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Acl&#xE1;rase que, el nombre del funcionario grado 11.o, H&#xE9;ctor Smith Vergara, del Servicio de Explotaci&#xF3;n de Puertos, suprimido en el art&#xED;culo 2.o del decreto con fuerza de ley N.o 132 es H&#xE9;ctor Smith Vargas.</div><br></div>", "i": 10131981}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- J. ALESSANDRI R.- Roberto Vergara Herrera.</div><br></div>", "i": 10131982}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "341", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "Decreto con Fuerza de Ley-341"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ACLARA EL DECRETO CON FUERZA DE LEY NUMERO 132 DE 1960", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-04-05", "doble_articulado": false, "id_norma": "1145384", "numero_fuente": "24613", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-04-06", "vigencias": [{"desde": "1960-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1960-04-06", "fin_v