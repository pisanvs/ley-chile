{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 296, DE 1986</div><br><br></div>", "i": 8548859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 20, de 06 de Enero de 1987, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, pronunci&#xE1;ndose sobre solicitudes de fechas 18 de Noviembre de 1985 y 27 de Octubre de 1986, se modifica la resoluci&#xF3;n No. 296, de 1986, de esa Subsecretaria que autoriz&#xF3; a la Sociedad Humberto Aguirre Gamboa e Hijos y Compa&#xF1;&#xED;a Limitada &quot;Mar Jordan Limitada&quot;, domiciliada en Arica, para operar la embarcaci&#xF3;n &quot;Don Enrique&quot; en el litoral de las Regiones III y IV, en el siguiente sentido: en el numeral 4&#xB0;, ampl&#xED;ase la zona de operaci&#xF3;n de dicha embarcaci&#xF3;n, adem&#xE1;s, al litoral de la I y II Regi&#xF3;n.</div><br></div>", "i": 8548860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 06 de Enero de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8548861}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "20", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-20"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 296, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-01-06", "fecha_derogacion": "1988-05-20", "doble_articulado": false, "id_norma": "140981", "numero_fuente": "33074", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-05-18", "vigencias": [{"desde": "1988-05-20", "