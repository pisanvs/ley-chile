{"html": [{"t": "<div><div class=\"p\">PRORROGA RESOLUCION QUE INDICA </div></div>", "i": 8321920}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 502 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o a contar del 04 de febrero de 1989, la autorizaci&#xF3;n otorgada a Sociedad Pesquera, Comercial y Profesional Aquacultivos Limitada, R.U.T. No. 87.829.000-3, domiciliada en Puerto Montt, para empezar a operar el establecimiento de cultivo en los t&#xE9;rminos y condiciones establecidos en la Resoluci&#xF3;n No. 101, de 1988 de esta Subsecretar&#xED;a en raz&#xF3;n de haberse acreditado la ocurrencia de un caso fortuito.</div><br></div>", "i": 8321921}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 05 de Mayo de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8321922}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "502", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-502"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-05", "doble_articulado": false, "id_norma": "92516", "numero_fuente": "33382", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-05-27", "vigencias": [{"desde": "1989-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-05-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-05-27", "fin_vigencia": "", "tipo_version": "3"}],