{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6329466}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por R.M. (Ex.) N&#xBA; 59, de 15 de marzo de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ac&#xF3;gese parcialmente el recurso de reclamaci&#xF3;n interpuesto por&nbsp; PESQUERA AURO S.A. Consid&#xE9;rese en la determinaci&#xF3;n de su l&#xED;mite m&#xE1;ximo de captura, en las unidades de pesquer&#xED;as que se indican, las siguientes capturas totales de la nave Albimer: a) Jurel, V a IX Regiones: enero 1998: 555 t.; b) Anchoveta, V a X Regiones: octubre 1998: 227 t.; noviembre 1998: 497 t.; marzo 2000: 1512 t.</div><br></div>", "i": 6329467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; de Gregorio Rebeco, Ministro de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6329468}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "59 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-59 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-15", "doble_articulado": false, "id_norma": "183721", "numero_fuente": "36933", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-07", "vigencias": [{"desde": "2001-04-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "