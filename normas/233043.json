{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6506889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 604, de fecha 25 de octubre de 2004, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA; 2.186, de 1978, del Lote N&#xBA;47 correspondiente al inmueble ubicado en calle Hermanos Carrera N&#xBA; 4991, Rol de aval&#xFA;o N&#xBA;1784-9, comuna de Estaci&#xF3;n Central, de dominio de Ren&#xE9; Eugenio Campos Valdivia. Comisi&#xF3;n integrada por peritos Sergio Rojas Ib&#xE1;&#xF1;ez, ingeniero civil; Douglas Herrera Flores, constructor civil, y Ver&#xF3;nica Olivier Valdebenito, arquitecta. Seg&#xFA;n informe de fecha 25 de marzo de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $13.011.970, pagadera al contado, acord&#xE1;ndose monto de indemnizaci&#xF3;n definitiva con propietario en $16.011.970.</div><br></div>", "i": 6506890}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6506891}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "604", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-604"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-25", "doble_articulado": false, "id_norma": "233043", "numero_fuente": "38025", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-01", "vigencias": [{"desde": "2