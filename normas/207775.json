{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A VERONICA ALISTE ROLDAN</div><br><br></div>", "i": 6414823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Santiago Poniente del SII, por resoluci&#xF3;n N&#xBA; Ex. de 69, de 23.01.2003 y N&#xBA;104 de 10 de febrero de 2003 concede la calidad de agente retenedor del Impuesto al Valor Agregado en las compras de Especies Hidrobiol&#xF3;gicas a do&#xF1;a Ver&#xF3;nica de las Mercedes Aliste Rold&#xE1;n, RUT 8.113.810-9, con vigencia a contar del d&#xED;a 1&#xBA; del mes siguiente al de su publicaci&#xF3;n en el Diario Oficial, y en forma indefinida, mientras se mantenga el fiel cumplimiento de la resoluci&#xF3;n N&#xBA; Ex.</div><div class=\"p\">3.311, de 30.06.2000 (D.O. 03.07.2000).-</div><br></div>", "i": 6414824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 6414825}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "69 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-69 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A VERONICA ALISTE ROLDAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-23", "doble_articulado": false, "id_norma": "207775", "numero_fuente": "37486", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-02-15", "vigencias": [{"desde": "2003-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc