{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6438792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.076, de fecha 22 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; de la resoluci&#xF3;n N&#xBA; 1.860, de 2003, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto FIP N&#xBA; 2003-09 denominado &quot;Evaluaci&#xF3;n del stock desovante de Merluza del sur y Merluza de cola en la zona sur austral, a&#xF1;o 2003&quot;, en el sentido de incrementar la cuota de investigaci&#xF3;n de Merluza de cola en 500 toneladas, las que se imputar&#xE1;n a la fracci&#xF3;n de la cuota global anual de captura de dicha especie reservada para fines de investigaci&#xF3;n. </div></div>", "i": 6438793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6438794}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2076 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2076 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-22", "doble_articulado": false, "id_norma": "214454", "numero_fuente": "37653", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-05", "vigencias": [{"desde": "2003-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia