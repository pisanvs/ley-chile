{"html": [{"t": "<div><br><div class=\"p\">Liberacion de derechos para la esportacion de sombreros</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 4 de 1822</div></div>", "i": 10216254}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  De acuerdo con la Excma. Suprema Corte de Representantes, se concede a don Tomas Appleby libertad de derechos de estraccion de los sombreros finos de la f&#xE1;brica que ha establecido en esta capital con tal que mantenga en ella operarios ind&#xED;jenas.</div></div>", "i": 10216255}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon en la Inspeccion Jeneral de aduanas e impr&#xED;mase. - O&apos;Higgins. - Rodr&#xED;guez.</div></div>", "i": 10216256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Liberacion de derechos para la esportacion de sombreros", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-12-04", "doble_articulado": false, "id_norma": "1152138", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "", "vigencias": [{"desde": "1822-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-12-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-04-14", "fecha_version": "1822-12-04", "fecha_actualizacion_texto": "2021-04-14", "tipo_tratado": ""}, "ale