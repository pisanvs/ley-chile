{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; FIJA VIGENCIA DEL DECRETO 211, DE 1995</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 525 exenta.- Santiago, 12 de diciembre de 1995.- Visto: Lo dispuesto en el art&#xED;culo 10&#xB0; del Decreto Supremo N&#xB0; 211/95, del Ministerio de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; R e s u e l v o :</div><br></div>", "i": 7201601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; F&#xED;jase el 02 de enero de 1996 para que entre en vigencia el Decreto Supremo N&#xB0; 211/95, del Ministerio de Transportes y Telecomunicaciones, que establece el Reglamento de Transporte P&#xFA;blico de Pasajeros desde y hacia aer&#xF3;dromos y aeropuertos en la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 7201602}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese y publ&#xED;quese.- Antonio Dourthe Castrill&#xF3;n, Secretario Regional Ministerial Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento, atte.- Jefe Administrativo Seremitt Metropolitana.</div><br></div>", "i": 7201603}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "525 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-525 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "FIJA VIGENCIA DEL DECRETO 211, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TRANSPORTE PUBLICO PASAJEROS", "AERODROMOS", "AEROPUERTOS", "REGION METROPOLITANA", "VIGENCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-12", "doble_articulado": false, "id_norma": "39088