{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUMENTO DE PENSION DE INVALIDEZ Lei num. 244.-Santiago, a 7 de Enero de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Aum&#xE9;ntase, por gracia, a veinticinco pesos mensuales la pension de invalidez de que actualmente disfruta don Antonio El&#xED;as Poblete </div><br></div>", "i": 5947264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-C&#xE1;rlos Rivera Jofr&#xE9;. </div></div>", "i": 5947265}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "244", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-244"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "AUMENTO DE PENSION DE INVALIDEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ANTONIO ELIAS POBLETE", "PENSION INVALIDEZ", "MODIFICACION."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-01-07", "doble_articulado": false, "id_norma": "22098", "numero_fuente": "5015", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-01-16", "vigencias": [{"desde": "1895-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-01-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM"