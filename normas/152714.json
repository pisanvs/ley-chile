{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6223955}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 245, del 30 de Junio de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo, se autoriza a don Juan Bautista Castillo para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6223956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, Junio de 1986.- Jorge Vargas Borcosky, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6223957}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "245 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-245 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-30", "doble_articulado": false, "id_norma": "152714", "numero_fuente": "32523", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-16", "vigencias": [{"desde": "1986-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc