{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308368}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA;654 de 16 de Julio de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar del 1&#xBA; de octubre de 1991 el plazo otorgado a INDUSTRIA PESQUERA POSEIDON S.A., RUT N&#xBA;96.148.000-0, domiciliada en Morris N&#xBA;721, Valpara&#xED;so, para operar la nave &quot;Vi&#xF1;a del Mar&quot; autorizada por resoluciones N&#xBA;599, de 1986 y N&#xBA;930, de 1989, ambas de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8308369}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 16 de Julio de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8308370}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "654", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-654"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-07-16", "doble_articulado": false, "id_norma": "77943", "numero_fuente": "34336", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-07", "vigencias": [{"desde": "1992-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-08-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text":