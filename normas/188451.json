{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 5.926 EXENTA, DE 2001 </div><br></div>", "i": 7285004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.926 de 24 de mayo del a&#xF1;o 2001, se ha aprobado al Colegio Hispanoamericano, comuna de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para segundo y tercer a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de Formaci&#xF3;n Diferenciada para tercer a&#xF1;o de ense&#xF1;anza media, que se se&#xF1;alan en la presente resoluci&#xF3;n.</div><br></div>", "i": 7285005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de junio de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General</div><br><br></div>", "i": 7285006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5926 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5926 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.926 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-24", "doble_articulado": false, "id_norma": "188451", "numero_fuente": "37035", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-11", "vigencias": [{"desde": "2001-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-08-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient