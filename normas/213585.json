{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7302674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.783, de 6 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 2&#xBA; de las resoluciones N&#xBA; 145 de 1990 y N&#xBA; 1.444 de 1997 y el numeral 1&#xBA; de las resoluciones N&#xBA; 1.475 de 1990 y N&#xBA; 1.703 de 1999, ambas de esta Subsecretar&#xED;a, que autorizaron a Sociedad Pesquera B&#xED;o B&#xED;o Limitada, hoy PESQUERA BIO BIO S.A., para realizar actividades pesqueras extractivas con la nave &quot;Biomar III&quot;, en el sentido de actualizar e incorporar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de esta:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 41,71 m.</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp;  374,21 m3.</div><br></div>", "i": 7302675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de agosto de 2003.- Felipe&nbsp; Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7302676}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1783 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1783 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-08-06", "fecha_derogacion": "2014-01-04", "doble_articulado": false, "id_norma": "213585", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-08-18", "vigencias": [{"desde": "2014-01-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Últi