{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10357935}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;532, de 13 de julio de 2022, se modific&#xF3; y desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xBA;8, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1139961&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xBA;1475, de 29 de noviembre de 2019</a>, reduci&#xE9;ndose la superficie expropiada a 569 m2. y modificando el numeral primero y segundo de dicho Decreto, se&#xF1;alando como nuevo rol de aval&#xFA;o 1405-39 y kilometraje t&#xE9;rmino, debe decir: Km. 1,06271, de la comuna de Rancagua, expropiado para la ejecuci&#xF3;n de obra &quot;Ampliaci&#xF3;n Ruta H-27 Carretera El Cobre Rancagua - Machal&#xED;, Comuna de Machal&#xED;, Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xBA; del Decreto Ley N&#xBA;2186, de 1978. </div><br></div>", "i": 10357936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10357937}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "532 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-532 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2169980", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-07-13", "doble_articulado": false, "id_norma": "1180030", "nume