{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.918, DE 1987 </div><br></div>", "i": 6269511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.918 de fecha 27 de</div><div class=\"p\">Agosto de 1987 del Subsecretario de Educaci&#xF3;n P&#xFA;blica,</div><div class=\"p\">se modific&#xF3; el art. 1&#xB0; de la Resoluci&#xF3;n Exenta de</div><div class=\"p\">Educaci&#xF3;n No. 1.960 de 1982, del Centro de Formaci&#xF3;n</div><div class=\"p\">T&#xE9;cnica Escuela de Ciencias Tur&#xED;sticas e Idiomas EDECTI</div><div class=\"p\">de Santiago, en el sentido de insertar nueva red</div><div class=\"p\">secuencial y nueva distribuci&#xF3;n de plan de estudio de la</div><div class=\"p\">carrera Turismo, a contar del a&#xF1;o 1985.</div><div class=\"p\">&nbsp; &nbsp;  Por esta misma Resoluci&#xF3;n Exenta se modific&#xF3; el</div><div class=\"p\">art. 1&#xB0; de la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 2.852 de 1986 del Centro de Formaci&#xF3;n T&#xE9;cnica EDECTI en el sentido que las modificaciones introducidas al plan y programas de estudio de la carrera de Turismo rigen a contar del a&#xF1;o 1986.</div><br></div>", "i": 6269512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6269513}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1918 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1918 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.918, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogad