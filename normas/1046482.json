{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 1, DE 2009</div><br></div>", "i": 9316115}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1, de 24 de septiembre de 2009, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n del Biob&#xED;o, se declar&#xF3; extinguida la Pr&#xF3;rroga del Contrato de Concesi&#xF3;n, de la Planta de Revisi&#xF3;n T&#xE9;cnica Clase AB, del concesionario &quot;Juan Luis Ben&#xED;tez Almeida&quot;, que practica revisi&#xF3;n t&#xE9;cnica de veh&#xED;culos Clase A y B, en la comuna de Curanilahue, dispuesta y aprobada mediante la <a href=\"https://www.leychile.cl/Navegar?idNorma=75891&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 62, de 25 de agosto de 1997</a>, de la mencionada Secretar&#xED;a Regional, estableci&#xE9;ndose la siguiente fecha de cierre, 30 de noviembre de 2012.- </div></div>", "i": 9316116}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Claudio Silva Gonz&#xE1;lez, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Biob&#xED;o.</div></div>", "i": 9316117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 1, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-09-24", "doble_articulado": false, "id_norma": "1046482", "numero_fuente": "40425", "t