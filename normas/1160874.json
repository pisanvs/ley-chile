{"html": [{"t": "<div><div class=\"p\">MUELLE.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 22 de 1831.</div><br><div class=\"p\">&nbsp; &nbsp;  El Presidente de la Rep&#xFA;blica, con el fin de excitar a los due&#xF1;os o apoderados de los buques que estuviesen anclados en el puerto de Valparaiso, a hacer uso del nuevo muelle para la carena de sus respectivas embarcaciones, ha acordado y decreta:</div></div>", "i": 10262744}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.&#xB0;&nbsp; Cualquier buque nacional o extranjero que por primera vez atraque al muelle para carenarse, queda libre del pago de los derechos fijados por el reglamento.</div><br><br></div>", "i": 10262745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0;&nbsp; T&#xF3;mese razon en la Comision de cuentas, trascr&#xED;base al gobernador de Valparaiso para su cumplimiento y arch&#xED;vese.</div><br><br></div>", "i": 10262746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PRIETO.&nbsp; &nbsp;  Rengifo.</div></div>", "i": 10262747}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MUELLE.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1831-11-22", "doble_articulado": false, "id_norma": "1160874", "numero_fuente": "1831", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1831-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1831-11-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1831-11-22"