{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,832.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6175313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Mar&#xED;a Mercedes i do&#xF1;a Jertrudis Astorga Ocampo, nietas del coronel de Ej&#xE9;rcito, servidor de la Independencia, don Manuel Jos&#xE9; Astorga, el goce de una pensi&#xF3;n mensual de ochenta pesos ($ 80), de que gozar&#xE1;n, en comun, con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6175314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintidos de diciembre de mil novecientos trece.- Ramon Barros Luco.- Ramon Corbalan Melgarejo. </div></div>", "i": 6175315}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2832", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2832"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-12-22", "doble_articulado": false, "id_norma": "138424", "numero_fuente": "10802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-02-18", "vigencias": [{"desde": "1914-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-02-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1914-