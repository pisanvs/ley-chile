{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,146.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 8346519}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a los hijos de don Marcial Rivera A., una pension anual de tres mil seiscientos pesos ($ 3,600), que gozar&#xE1;n por iguales partes, los hombres hasta la edad de veintiun a&#xF1;os y las mujeres hasta que contraigan matrimonio.</div><br></div>", "i": 8346520}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a once de diciembre de mil novecientos dieciseis.- Juan Luis Sanfuentes.- Enrique Za&#xF1;artu P. </div></div>", "i": 8346521}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3146", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3146"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-12-11", "doble_articulado": false, "id_norma": "138971", "numero_fuente": "11653", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-12-20", "vigencias": [{"desde": "1916-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-12-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci