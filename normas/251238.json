{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6575630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.671, de 20 de junio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a CULTIVOS MARINOS SAN CRISTOBAL S.A., para realizar actividades experimentales de acuicultura sobre la especie Macrocystis sp.</div><div class=\"p\">&nbsp; &nbsp;  El objetivo general consiste en evaluar el desarrollo del cultivo de Macrocystis sp. en laboratorio.</div><div class=\"p\">La interesada podr&#xE1; ejecutar las actividades experimentales en la concesi&#xF3;n otorgada por resoluci&#xF3;n N&#xBA; 175 de 1998, de la Subsecretar&#xED;a de Marina, ubicada en Caleta Los Patos, sector Punta Fr&#xF6;dden, III Regi&#xF3;n. </div></div>", "i": 6575631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de junio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6575632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1671", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1671"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-20", "doble_articulado": false, "id_norma": "251238", "numero_fuente": "38515", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-17", "vigencias": [{"desde": "2006-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-07-17", "fin_vi