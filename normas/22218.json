{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; VICTOR W. CASTRO Lei n&#xFA;m. 368.- Santiago, a 29 de Julio de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a don V&#xED;ctor W. Castro derecho para percibir los sueldos i gratificaciones que le habrian correspondido durante el tiempo que sirvi&#xF3; en el Ej&#xE9;rcito Constitucional, si el empleo de sarjento mayor que desempe&#xF1;&#xF3; le hubiera sido conferido por la Junta de Gobierno.</div><br><br></div>", "i": 5947747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i ll&#xE9;ve a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Luis Barros Borgo&#xF1;o.</div><br></div>", "i": 5947748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "368", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-368"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "VICTOR W. CASTRO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VICTOR CASTRO", "BENEFICIOS POR GRACIA", "SUELDOS", "GRATIFICACIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-07-29", "doble_articulado": false, "id_norma": "22218", "numero_fuente": "5477", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-08-08", "vigencias": [{"desde": "1896-08-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-08-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-08-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-26", "fecha_version": "1896-08-08", "fecha_actualizacion_texto": "1896-08-08", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5947746}, {"n": "Artículo UNICO", "i": 5947747, "t": 6}, {"n": "Promulgación", "i": 5947748}]}