{"html": [{"t": "<div><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A ELENA CAMPO L.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6441481}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Elena Campo Lynch, una pensi&#xF3;n de $ 35.000 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6441482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiuno de Noviembre de mil novecientos cincuenta y ocho.- JORGE ALESSANDRI RODRIGUEZ. - Roberto Vergara H.</div><br><br></div>", "i": 6441483}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13272", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13272"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA ELENA CAMPO L.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-11-21", "doble_articulado": false, "id_norma": "215196", "numero_fuente": "24208", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-12-01", "vigencias": [{"desde": "1958-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1958-12-01", "fin_vigencia": ""}, "vigencias_ve