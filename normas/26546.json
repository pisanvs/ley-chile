{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 9,998, RELACIONADA CON UN EMPRESTITO PARA LA MUNICIPALIDAD DE VALDIVIA.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279210}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Modif&#xED;case la letra b) del art&#xED;culo 4.o de la ley 9,998, de 20 de Octubre de 1951, por la</div><div class=\"p\"> siguiente:</div><div class=\"p\"> &quot;b) 5.000.000 de $ 1.-</div><div class=\"p\">&nbsp; &nbsp;  1.000.000 de&nbsp;  2.-</div><div class=\"p\">&nbsp; &nbsp; &nbsp;  500.000 de&nbsp;  3.-</div><div class=\"p\">&nbsp; &nbsp; &nbsp;  300.000 de&nbsp;  5.-</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; 75.000 de&nbsp; 10.-&quot;</div><div class=\"p\">&nbsp; &nbsp; -------------------</div><br></div>", "i": 8279211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a trece de Noviembre de mil novecientos cincuenta y dos.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Guillermo del Pedregal H.</div><br></div>", "i": 8279212}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11113", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11113"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY N.o 9,998, RELACIONADA CON UN\nEMPRESTITO PARA LA MUNICIPALIDAD DE VALDIVIA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 9998", "MUNICIPALIDAD VALDIVIA", "CONTRATACION", "CREDITO", "PRESTAMO."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "