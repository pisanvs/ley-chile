{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6332100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 23, del 20 de marzo del a&#xF1;o 2001, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la Cooperativa de Servicios de Eventos y Veraneo Las Cruces Veracoop Limitada, de nombres de fantas&#xED;a Centro de Eventos y Veraneo Las Cruces Veracoop Limitada, y Veracoop Ltda., de la ciudad de Santiago; en los t&#xE9;rminos que da testimonio el acta constitutiva reducida a escritura p&#xFA;blica con fecha 5 de enero de 2001, ante la Notario de Santiago do&#xF1;a Elba Sanhueza Mu&#xF1;oz.</div><br></div>", "i": 6332101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario.- Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6332102}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "23", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-23"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-20", "doble_articulado": false, "id_norma": "184552", "numero_fuente": "36945", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-24", "vigencias": [{"desde": "2001-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v