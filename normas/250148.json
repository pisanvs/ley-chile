{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 14,772</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, AL SE&#xD1;OR HUGO WAGNER RADTKE </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6571654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, al se&#xF1;or Hugo Wagner Radtke, un pensi&#xF3;n de E&#xB0; 40 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6571655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a siete de Diciembre de mil novecientos sesenta y uno.- JORGE ALESSANDRI RODRIGUEZ.- Luis Meckenna S.</div><br></div>", "i": 6571656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14772", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14772"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, AL SEÑOR HUGO WAGNER RADTKE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1961-12-07", "doble_articulado": false, "id_norma": "250148", "numero_fuente": "25130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1961-12-28", "vigencias": [{"desde": "1961-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci