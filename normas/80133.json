{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO EXENTO No. 234, DE 1991 </div></div>", "i": 6056648}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 234 de fecha 05 de Agosto de 1991 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; el plan y programas de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Osorno, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 1991.</div><div class=\"p\">Carrera: Turismo con menci&#xF3;n en Hoteler&#xED;a o Marketing Tur&#xED;stico.</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Turismo con menci&#xF3;n en Hoteler&#xED;a o Marketing Tur&#xED;stico.</div><br></div>", "i": 6056649}, {"t": "<div><div class=\"p\">Santiago, 08 de Noviembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6056650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "234 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-234 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DECRETO EXENTO No. 234, DE 1991", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-08-05", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "80133", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-12-17", "vigencias": [{"desde": "2015-06-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-12-17", "hasta": "2015-06-24", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2015-06-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"in