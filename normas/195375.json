{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7290065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 522, de 5 de marzo de 2002, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA;, de la resoluci&#xF3;n N&#xBA; 2.333, de 2001, de esta Subsecretar&#xED;a, que declar&#xF3; la caducidad de resoluciones que autorizaban a operar a diversas plantas de transformaci&#xF3;n, en el sentido de eliminar su punto 7). Como consecuencia recobran vigencia resoluciones N&#xBA; 305 de 1994, N&#xBA; 138 y N&#xBA; 1.035 de 1997, que autorizaron a do&#xF1;a CONSUELO DEL CARMEN FREIRE SAAVEDRA, a operar una planta de transformaci&#xF3;n ubicada en calle Atacama N&#xBA; 2822, Taltal, II Regi&#xF3;n.</div><br></div>", "i": 7290066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de marzo de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7290067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "522", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-522"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-05", "doble_articulado": false, "id_norma": "195375", "numero_fuente": "37208", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-12", "vigencias": [{"desde": "2002-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-03-12", "fin_vigencia": "", "ti