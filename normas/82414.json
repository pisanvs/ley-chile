{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA</div><br><br></div>", "i": 8313632}, {"t": "<div><br><div class=\"p\">Por resoluci&#xF3;n No. 1.015, de 17 de Agosto de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por seis meses a contar del 02.09.90, el plazo otorgado a Pesquera Santa Ana S.A., R.U.T. No. 96.546.690-8, domiciliada en la ciudad de Santiago, para empezar a operar la nave &quot;Area Milla&quot;, autorizada por resoluci&#xF3;n No. 981, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8313633}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 17 de Agosto de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313634}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1015", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1015"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-08-17", "fecha_derogacion": "1993-06-22", "doble_articulado": false, "id_norma": "82414", "numero_fuente": "33757", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1990-08-29", "vigencias": [{"desde": "1993-06-22", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1990-08-29", "hasta": "1993-06-21", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1993-06-22", "fin_vigenc