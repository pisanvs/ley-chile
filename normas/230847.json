{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6499012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.525, de 6 de septiembre</div><div class=\"p\">de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a</div><div class=\"p\">SALMOCONCESIONES S.A., para ampliar actividades</div><div class=\"p\">pesqueras extractivas con la nave &quot;Rafael&quot;, en &#xE1;rea</div><div class=\"p\">mar&#xED;tima de las Regiones V, VI, VII, IX y X, donde podr&#xE1;</div><div class=\"p\">capturar, por fuera del &#xE1;rea de reserva artesanal, con</div><div class=\"p\">arte de cerco, los siguientes recursos hidrobiol&#xF3;gicos: Agujilla, Bacaladillo o mote, Bonito, Cojinoba del norte, Cojinoba del sur, Cojinoba moteada, Dorado, Machuelo, Palometa, Sardina espa&#xF1;ola, Jurel fino, Anchoa blanca o samasa, Sardina redonda, Vinciguerria, Pota del Atl&#xE1;ntico, Calamar, Pulpo y Jibia.</div><br></div>", "i": 6499013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6499014}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2525 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2525 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-06", "fecha_derogacion": "2006-11-22", "doble_articulado": false, "id_norma": "230847", "numero_fuente": "37975", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-10-01", "vi