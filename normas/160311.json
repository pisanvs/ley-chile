{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 12.867 EXENTA, DE 1999 </div></div>", "i": 6248328}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 12.867 de 29 de diciembre de 1999, se ha aprobado, al Colegio &apos;&apos;Nuestra Se&#xF1;ora del Huerto&apos;&apos;, comuna de San Joaqu&#xED;n, de Santiago, un plan de estudio para segundo a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000, de acuerdo a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 220 de 1998 y sus modificaciones.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 6248329}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de enero de 2000.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6248330}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12867 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12867 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 12.867 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "160311", "numero_fuente": "36610", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-10", "vigencias": [{"desde": "2000-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-10", "fin_vigencia": ""}, "vig