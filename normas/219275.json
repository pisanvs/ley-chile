{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 1101 </div></div>", "i": 6455430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1101, celebrada el 18 de diciembre de 2003, adopt&#xF3; el siguiente Acuerdo:</div><div class=\"p\">1101-01-031218 - Tasa de inter&#xE9;s para pago diferido de derechos de Aduana.</div><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del Art&#xED;culo N&#xBA; 10 de la Ley N&#xBA; 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que expira el 30 de junio de 2004, ser&#xE1; de 5,5% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 6455431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de diciembre de 2003.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6455432}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1101", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1101"}, {"tipo": "5", "numero": "1101-01-031218", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1101-01-031218"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1101", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-18", "doble_articulado": false, "id_norma": "219275", "numero_fuente": "37741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-22", "vigencias": [{"desde": "2003-12-22", "hasta": "", "tipo_version": "3",