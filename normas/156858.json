{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 249, de 4 de febrero de 2000, de</div><div class=\"p\">esta Subsecretar&#xED;a, autor&#xED;zase al SINDICATO DE</div><div class=\"p\">PESCADORES ARTESANALES INDEPENDIENTES EMBARCADERO DE</div><div class=\"p\">QUINTERO para iniciar actividades pesqueras de</div><div class=\"p\">transformaci&#xF3;n y operar una planta ubicada en 21 de Mayo</div><div class=\"p\">N&#xBA; 1187, comuna de Quintero, V Regi&#xF3;n, donde podr&#xE1;</div><div class=\"p\">procesar en la l&#xED;nea de Congelado los siguientes</div><div class=\"p\">recursos hidrobiol&#xF3;gicos: Sardina espa&#xF1;ola y Raya.</div><div class=\"p\">&nbsp; &nbsp;  La materia prima deber&#xE1; provenir de pescadores</div><div class=\"p\">artesanales e industriales, debidamente autorizados. </div></div>", "i": 6236918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de febrero de 2000.- Edith Saa Collantes, Subsecretario(S) de Pesca.</div><br></div>", "i": 6236919}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "249", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-249"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-04", "doble_articulado": false, "id_norma": "156858", "numero_fuente": "36594", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-21", "vigencias": [{"desde": "2000-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],