{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6277433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 396, de 10.11.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XII Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a Mar&#xED;a Teresa Izquierdo Echeverr&#xED;a y Aurora Toro Maldonado para efectuar todo tipo de servicios de transporte terrestre de pasajeros, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbana de pasajeros.</div><br></div>", "i": 6277434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Urbano Peralta, Secretario Regional Ministerial XII Regi&#xF3;n.</div><br></div>", "i": 6277435}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "396 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-396 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-10", "doble_articulado": false, "id_norma": "169354", "numero_fuente": "32923", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-18", "vigencias": [{"desde": "1987-11-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-18", "fin_vigencia": "", "tipo_version": "3"}], "e