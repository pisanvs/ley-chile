{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUTORIZA LA ERECCION, EN LA CIUDAD DE LOS ANDES, DE UN MONUMENTO A LA MEMORIA DE MARCELINO CHAMPAGNAT.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5974781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Autor&#xED;zase la erecci&#xF3;n en la Avenida Argentina de la ciudad de los Andes, de un monumento al fundador de la Congregaci&#xF3;n de los Hermanos Maristas, Beato Marcelino Champagnat&quot;.</div><br></div>", "i": 5974782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintiuno de febrero de mil novecientos sesenta y dos.-</div><div class=\"p\">&nbsp; &nbsp; JORGE ALESSANDRI RODRIGUEZ.- Patricio Barros. </div></div>", "i": 5974783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14845", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14845"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "AUTORIZA LA ERECCION, EN LA CIUDAD DE LOS ANDES, DE\nUN MONUMENTO A LA MEMORIA DE MARCELINO CHAMPAGNAT.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ERECCION", "CONSTRUCCION", "MONUMENTO", "BEATO MARCELINO CHAMPAGNAT", "AVENIDA ARGENTINA", "ANDES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1962-02-21", "doble_articulado": false, "id_norma": "27923", "numero_fuente": "25364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1962-10-10", "