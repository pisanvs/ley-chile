{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESION N&#xBA; 773 </div><br></div>", "i": 6181670}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 773, celebrada el 5 de agosto de 1999, adopt&#xF3; los siguientes Acuerdos:</div><br><div class=\"p\">&nbsp; &nbsp;  773-01-990805 - Fija Tasa de Inter&#xE9;s de la L&#xED;nea de Cr&#xE9;dito del Programa de Financiamiento Industrial.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; establecer las siguientes Tasas de Inter&#xE9;s para Pr&#xE9;stamos Subsidiarios de la L&#xED;nea de Cr&#xE9;dito del Programa de Financiamiento Industrial, para el per&#xED;odo que se indica:</div><br><div class=\"p\">Per&#xED;odo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Tasa de inter&#xE9;s para Pr&#xE9;stamos Subsidiarios</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; expresados en Unidades de Fomento.</div><div class=\"p\">1&#xBA; de agosto de</div><div class=\"p\">1999 y el</div><div class=\"p\">31 de enero del 2000&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 6,50%</div><br></div>", "i": 6181671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de agosto de 1999.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6181672}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "773", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-773"}, {"tipo": "5", "numero": "773-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-773-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESION Nº 773", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun