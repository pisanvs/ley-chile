{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCION (M) N&#xBA; 2.153, DE 2001 </div></div>", "i": 6454322}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante (M) 1.688, de 1 de octubre de 2003, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se rectific&#xF3; la resoluci&#xF3;n (M) N&#xBA; 2.153, de 18 de diciembre de 2001, en el sentido que se reemplaza en el p&#xE1;rrafo 2 de la parte resolutiva lo siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Donde dice:&nbsp;  &quot;V&#xE9;rtice D Lat. 48&#xB0;48&apos;20,82&quot; W.&quot; Debe decir:&nbsp;  &quot;V&#xE9;rtice D Lat. 41&#xB0;48&apos;20,82&quot; W.&quot; </div></div>", "i": 6454323}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de noviembre de 2003.- Por el Subsecretario, Carlos de la Maza Urrutia, Subjefe Subsecretar&#xED;a de Marina.</div><br></div>", "i": 6454324}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1688", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1688"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "RECTIFICA RESOLUCION (M) Nº 2.153, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-01", "doble_articulado": false, "id_norma": "218949", "numero_fuente": "37736", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-16", "vigencias": [{"desde": "2003-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-12-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes