{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6267795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;3436, de 29 de octubre de 1999, se expropiaron los lotes de terreno N&#xBA;2, 3-A, 3-B, 3-C y 3-D, superficies 186,6 m&#xB2;, 142.089,7 m&#xB2;, 2.772,1 m&#xB2;, 5.691,3 m&#xB2; y 512,0 m&#xB2;, rol de aval&#xFA;o 8-458, comuna de Colb&#xFA;n, obra Camino Ruta 115-Ch, sector Puente Armerillo-L&#xED;mite Paso Pehuenche y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietario Empresa El&#xE9;ctrica Pehuenche S.A., ascendente a la cantidad de $2.004.362.366.</div><br></div>", "i": 6267796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6267797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3436", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3436"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-29", "doble_articulado": false, "id_norma": "166375", "numero_fuente": "36641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-15", "vigencias": [{"desde": "2000-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-04-19", "fecha_version": "2000-04-15", "fecha_actualizacion_texto": "2000-04-15", "tipo_tratado": ""