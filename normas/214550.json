{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6439129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.053, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; COMPA&#xD1;IA PESQUERA QUINTERO S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Eversen&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : 2108 Valpara&#xED;so</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : CB-2583</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : 21,97 m</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : 6,40 m</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : 2,44 m</div><div class=\"p\">T.R.G. (nacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : 79,21</div><div class=\"p\">Potencia motor principal&nbsp;  : 400,00 HP</div><div class=\"p\">Potencia motores auxiliares: 6,00 HP.</div><br></div>", "i": 6439130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6439131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2053", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2053"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-08-