{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304415}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 877, de 26 de junio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA CAZADOR S.A., para continuar desarrollando las actividades pesqueras autorizadas a Pacific Fisheries S.A., en Resoluciones N&#xBA; 80 de 1994 y N&#xBA; 173 de 1995, de esta Subsecretar&#xED;a, respecto de la nave&nbsp; &quot;Vestliner&quot;, en virtud de la escritura p&#xFA;blica y disposiciones legales.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 87 de 1997, de esta Subsecretar&#xED;a, en virtud de lo se&#xF1;alado en la presente Resoluci&#xF3;n.</div><br><br></div>", "i": 8304416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de junio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304417}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "877", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-877"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESQUERA CAZADOR S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-06-26", "fecha_derogacion": "1998-02-12", "doble_articulado": false, "id_norma": "74104", "numero_fuente": "35810", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-07-08", "vigencias": [{"desde": "1998-02-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Ve