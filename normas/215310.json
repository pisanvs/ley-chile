{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6441892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.152, de 3 de septiembre de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA;817 de 2001, de esta Subsecretar&#xED;a, que autoriz&#xF3; a EMPRESA PESQUERA BRAVAMAR Y CIA. LTDA. para sustituir la nave &quot;Denise&quot; por una embarcaci&#xF3;n en construcci&#xF3;n, en el sentido de se&#xF1;alar que las caracter&#xED;sticas n&#xE1;uticas de la nave en construcci&#xF3;n son las siguientes:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  21,40 m</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 84,00</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp; &nbsp;  365,00 Hp</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 4,50 Hp</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Arrastre</div><br></div>", "i": 6441893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de septiembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6441894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2152 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2152 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-09-03", "fecha_derogacion": "2003-12-20", "doble_articulado"