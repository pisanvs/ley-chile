{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,078.- Santiago, 7 de setiembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161520}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Elena Vicencio i Cabrera, hermana de los oficiales don Federico i don Enrique Vicencio, muerto este &#xFA;ltimo a consecuencia de las heridas recibidas en la batalla de Miraflores, la pension que corresponde en conformidad al art&#xED;culo 12 de la lei de 22 de diciembre de 1881 a la madre-viuda de un teniente.</div><br></div>", "i": 6161521}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- V. Blanco.</div><br></div>", "i": 6161522}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1078", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1078"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-09-07", "doble_articulado": false, "id_norma": "134165", "numero_fuente": "6099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-09-12", "vigencias": [{"desde": "1898-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-09-12", "fin_vigencia": "", "tipo_ver