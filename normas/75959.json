{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6046241}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 721, de 31 de julio de 1997, se expropiaron los lotes de terreno N&#xBA;s. 12-A, 96-A y 96-B, superficies 540, 200 y 112 m&#xB2;, respectivamente, roles de aval&#xFA;os 12095-2, 655-24 y 655-29, comuna de Rancagua, obra Mejoramiento Ruta 5 Sur, sector Pasada por Rancagua, Camino Ruta 5 Sur y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Domingo Sep&#xFA;lveda Lagos, Jos&#xE9; Monje Venegas y Alberto Rodr&#xED;guez Est&#xE9;vez, ascendente a las cantidades de: $15.567.700, $8.005.250 y $4.550.590.</div><br></div>", "i": 6046242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6046243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "721", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-721"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "RANCAGUA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-31", "doble_articulado": false, "id_norma": "75959", "numero_fuente": "35867", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-09-15", "vigencias": [{"desde": "1997-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAV", "fecha_ing