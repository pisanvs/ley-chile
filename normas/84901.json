{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 4, DE 1990 </div></div>", "i": 6069090}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 4 de 09 de enero de 1990 se han declarado v&#xE1;lidos los estudios cursados en el Liceo B No. 2 de la comuna de Diego de Almagro, provincia de Cha&#xF1;aral, III Regi&#xF3;n de Atacama, durante el a&#xF1;o 1989, en Primer y Segundo Ciclo de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica para Adultos, aprobados por decreto supremo exento de Educaci&#xF3;n No. 12, de 1987, suprimiendo la asignatura de Idioma Extranjero.</div><br></div>", "i": 6069091}, {"t": "<div><div class=\"p\">Santiago, 16 de Enero de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6069092}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 4, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-09", "doble_articulado": false, "id_norma": "84901", "numero_fuente": "33600", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-19", "vigencias": [{"desde": "1990-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr