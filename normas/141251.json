{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO N&#xB0; 1.130, DE 1986, QUE APRUEBA MODIFICACION CONVENIO DE TRASPASOS DE LA ESCUELA BASICA F-625 DE PUENTE ALTO </div></div>", "i": 6184775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto N&#xB0; 1.130, de 1986, se aprob&#xF3; una modificaci&#xF3;n al convenio de traspaso de la Escuela B&#xE1;sica F-625, de Puente Alto, aprobado por Decreto N&#xB0; 9.356, de 1981, que incide en la cl&#xE1;usula sexta, relativa al bien ra&#xED;z.</div><br></div>", "i": 6184776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Enero de 1987.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica, subrogante. </div></div>", "i": 6184777}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1130", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1130"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DECRETO N° 1.130, DE 1986, QUE APRUEBA\nMODIFICACION CONVENIO DE TRASPASOS DE LA ESCUELA BASICA\nF-625 DE PUENTE ALTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-28", "doble_articulado": false, "id_norma": "141251", "numero_fuente": "32700", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-17", "vigencias": [{"desde": "1987-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1999-