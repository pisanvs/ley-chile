{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9127792}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 569, de 4 de marzo de 2011, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1022693&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 190, de 2011</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la Universidad de Antofagasta para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Distribuci&#xF3;n espacio - temporal de las agregaciones de Jurel (Trachurus murphyi) en la III Regi&#xF3;n, temporada 2011&quot;, en el sentido de agregar en el numeral 4.- la embarcaci&#xF3;n artesanal Lonquimay 2 (RPA 955248).</div><br><br></div>", "i": 9127793}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de marzo de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9127794}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "569 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-569 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-03-04", "doble_articulado": false, "id_norma": "1023979", "numero_fuente": "39919", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-03-25", "vigencias": [{"desde": "2011-03-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-03-25", "fin_vigencia