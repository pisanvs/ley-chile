{"html": [{"t": "<div><br><div class=\"p\">DECRETO N&#xB0; 2.271, DE 04 DE SEPTIEMBRE DE 1920</div><br><div class=\"p\">DECLARA MODELO OFICIAL DEL ESCUDO NACIONAL DE LA REPUBLICA.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Vistos estos antecedentes,</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado i decreto:</div></div>", "i": 8964846}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se declara como modelo oficial para la confecci&#xF3;n del <a href=\"https://www.leychile.cl/Navegar?idNorma=229390&amp;idParte=&amp;idVersion=\">Escudo Nacional de la Rep&#xFA;blica</a>, el presentado por el Estado Mayor Jeneral, cuyo orijinal quedar&#xE1; archivado en el Archivo Jeneral del Ej&#xE9;rcito.</div><div class=\"p\">&nbsp; &nbsp; <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/12646.jpg\"></div><br></div>", "i": 8964847}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n i comun&#xED;quese.- Sanfuentes.- Ladislao Err&#xE1;zuriz.</div><br></div>", "i": 8964848}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2271", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2271"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "DECLARA MODELO OFICIAL DEL ESCUDO NACIONAL DE LA REPUBLICA", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1920-09-04", "doble_articulado": false, "id_norma": "1016221", "numero_fuente": "738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1920-09-08", "vigencias": [{"desde": "1920-09-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1920-09-08", "fin_vigencia": ""}, "vig