{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;AUGUSTO TECHNER YUKLE&quot; AL HOSPITAL DE CONTULMO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente,</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5982783}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Denom&#xED;nase &quot;Augusto Techner Yukle&quot;, al Hospital de Contulmo.</div><br></div>", "i": 5982784}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, once de Septiembre de mil novecientos setenta y dos.- SALVADOR ALLENDE GOSSENS.- Juan Carlos Concha G.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a U. para su conocimiento.- Saluda a U.- Carlos Molina Bustos, Subsecretario de Salud P&#xFA;blica.</div><br></div>", "i": 5982785}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17719", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17719"}], "organismos": ["MINISTERIO DE SALUD PÚBLICA"], "titulo_norma": "DENOMINA \"AUGUSTO TECHNER YUKLE\" AL HOSPITAL DE\nCONTULMO", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Hospital Augusto Techner Yukle de Contulmo"], "terminos_libres": ["HOSPITAL AUGUSTO TECHNER YURLE", "CONTULMO", "NOMBRE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1972-09-11", "doble_articulado": false, "id_norma": "29240", "numero_fuente": "28361", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1972-09-25", "vigencias": [{"desde": "1972-09-25", "hasta": "", "tipo_version": "3", "tipo_version