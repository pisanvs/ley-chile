{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION DE INMUEBLES QUE INDICA</div><br><div class=\"p\">NOTIFICACION </div></div>", "i": 6483243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 285 de 31 de mayo de 2004 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL N&#xBA; 2.186 de 1978, del Lote N&#xBA; 39 correspondiente al inmueble ubicado en Pje. 55 2168, presunto rol de aval&#xFA;o N&#xBA; 1787-8, comuna de Estaci&#xF3;n Central, aparente dominio de Cuevas Cubillos Benedicto. Comisi&#xF3;n integrada por peritos Sergio Rojas Ib&#xE1;&#xF1;ez, Ingeniero Civil; Douglas Herrera Flores, Constructor Civil; y Ver&#xF3;nica Olivier Valdebenito, Arquitecto. Seg&#xFA;n informe de 25 de marzo de 2004, fij&#xF3; monto provisional indemnizaci&#xF3;n en $16.557.102 pagadera al contado.</div><br></div>", "i": 6483244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6483245}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "285", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-285"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-31", "doble_articulado": false, "id_norma": "226384", "numero_fuente": "37885", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-15", "vigencias": [{"desde": "2004-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio