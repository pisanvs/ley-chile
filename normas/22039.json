{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 179.-Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947043}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese por gracia a do&#xF1;a Clorinda Araya, viuda de Clauder, el goce de la pension que se&#xF1;ala el art&#xED;culo 11 de la lei de 22 de Diciembre de 1881, correspondiente al empleo de injeniero segundo muerto en accion de guerra.</div><br><br></div>", "i": 5947044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 17 de Enero de 1894.-JORGE MONTT.-Juan Antonio Orrego.</div><br></div>", "i": 5947045}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "179", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-179"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CLORINDA ARAYA VDA. DE CLAUDER", "MONTEPIO MILITAR", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-17", "doble_articulado": false, "id_norma": "22039", "numero_fuente": "4736", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-02-08", "vigencias": [{"desde": "1894-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-02-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-02-08", "fin_vigencia": "", "tipo_version": "3"}], "event