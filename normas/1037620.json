{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9239840}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 278, de 3 de febrero de 2012, de esta Subsecretar&#xED;a, autor&#xED;zase a ESPECT&#xC1;CULOS MUNDOMAR LTDA. para capturar, en el &#xE1;rea mar&#xED;tima de la II Regi&#xF3;n, en el plazo de 1 a&#xF1;o contado desde la fecha de la presente resoluci&#xF3;n, la cantidad total de 92 ejemplares juveniles de la especie Lobo marino com&#xFA;n, en la forma y condiciones se&#xF1;aladas en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  El solicitante designa como persona responsable de esta autorizaci&#xF3;n a don Guillermo Rodr&#xED;guez Ban.</div></div>", "i": 9239841}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de febrero de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9239842}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "278", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-278"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-02-03", "doble_articulado": false, "id_norma": "1037620", "numero_fuente": "40202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-03-02", "vigencias": [{"desde": "2012-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-03-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-03-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi