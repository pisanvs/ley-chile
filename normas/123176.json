{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8333239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.169, de 12 de agosto de 1998, de esta Subsecretar&#xED;a, deni&#xE9;gase la solicitud presentada por SOCIEDAD PESQUERA COLOSO S.A., para ampliar el plazo de iniciaci&#xF3;n de operaciones indicado en la resoluci&#xF3;n N&#xBA; 892 de 1998 de esta Subsecretar&#xED;a, con una nave en construcci&#xF3;n sobre los recursos Anchoveta, Sardina espa&#xF1;ola y Jurel, en el litoral de la III y IV Regiones, por no configurarse una causal de fuerza mayor.</div><br></div>", "i": 8333240}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8333241}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1169", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1169"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "SOCIEDAD PESQUERA COLOSO S.A.", "AMPLIACION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-12", "doble_articulado": false, "id_norma": "123176", "numero_fuente": "36143", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-19", "vigencias": [{"desde": "1998-08-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-08-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i