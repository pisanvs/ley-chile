{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a do&#xF1;a Palmira Menares viuda de Ram&#xED;rez</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277667}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia y por el plazo de diez a&#xF1;os, a do&#xF1;a Palmira Menares, viuda del inspector de polic&#xED;a de Valpara&#xED;so, don Emilio Ram&#xED;rez, el goce de una pensi&#xF3;n mensual de cincuenta pesos, de la que disfrutar&#xE1; con las restricciones establecidas por la Ley de Montep&#xED;o Militar.</div><br></div>", "i": 8277668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como ley la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, trece de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Enrique Berm&#xFA;dez. </div></div>", "i": 8277669}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4720", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4720"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE PENSIÓN DE GRACIA A DOÑA PALMIRA MENARES VIUDA DE RAMÍREZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PALMIRA MENARES DE RAMIREZ", "MONTEPIO MILITAR", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-13", "doble_articulado": false, "id_norma": "24858", "numero_fuente": "15551", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-12-18", "vigencias": [{"desde": "1929-12-18", "