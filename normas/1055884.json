{"html": [{"t": "<div><br><div class=\"p\">MODIFICA ORDENANZA LOCAL N&#xBA; 22, DE 2001, SOBRE DERECHOS MUNICIPALES</div></div>", "i": 9382830}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por ordenanza N&#xBA; 124, de 29 de octubre de 2013, se modifica la ordenanza N&#xBA; 22, de 28 de diciembre de 2001, &quot;Ordenanza Local sobre Derechos Municipales&quot;, que rige para el a&#xF1;o 2013, cuyo texto refundido y sistematizado fue aprobado por <a href=\"https://www.leychile.cl/Navegar?idNorma=1045866&amp;idParte=0&amp;idVersion=\">decreto alcaldicio Ex. N&#xBA; 2.304, de 9 de noviembre de 2012</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo se encuentra en la p&#xE1;gina web Municipal, Transparencia Activa en Carpeta Marco Normativo Aplicable/Ordenanzas/Derechos/Sobre Derechos Municipales.- </div></div>", "i": 9382831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  La Alcaldesa.</div></div>", "i": 9382832}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "124", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "Ordenanza-124"}], "organismos": ["MUNICIPALIDAD DE PROVIDENCIA"], "titulo_norma": "MODIFICA ORDENANZA LOCAL Nº 22, DE 2001, SOBRE DERECHOS MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-10-29", "doble_articulado": false, "id_norma": "1055884", "numero_fuente": "40699", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-11-06", "vigencias": [{"desde": "2013-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-11-06", "fin_vigenci