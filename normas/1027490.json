{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9156516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.474, de 2 de junio de 2011, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1025305&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 976 de 2011</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto 2010-04 denominado &quot;Evaluaci&#xF3;n hidroac&#xFA;stica de reclutamiento de Anchoveta y Sardina com&#xFA;n entre la V-X Regiones, a&#xF1;o 2011&quot; Fase II, en el sentido de extender el per&#xED;odo de operaci&#xF3;n de las embarcaciones artesanales en el &#xE1;rea mar&#xED;tima de la XIV Regi&#xF3;n hasta el 15 de junio de 2011, inclusive.</div></div>", "i": 9156517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de junio de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9156518}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1474 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1474 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-06-02", "doble_articulado": false, "id_norma": "1027490", "numero_fuente": "40003", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-07-06", "vigencias": [{"desde": "2011-07-06", "hasta": "", "