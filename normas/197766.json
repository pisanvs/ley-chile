{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.296 EXENTA, DE 2002 </div></div>", "i": 6380375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.296, de 8 de abril de 2002, se ha aprobado un plan de estudio para los cursos de primero, segundo, tercero y cuarto a&#xF1;o de ense&#xF1;anza media, Human&#xED;stico-Cient&#xED;fica al Instituto Chacabuco (Hermanos Maristas) de Los Andes, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de los Subsectores que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6380376}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6380377}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4296 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4296 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.296 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-08", "doble_articulado": false, "id_norma": "197766", "numero_fuente": "37251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-06", "vigencias": [{"desde": "2002-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fe