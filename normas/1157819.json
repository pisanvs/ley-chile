{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10213863}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 489, de 23 de marzo de 2021, aprueba nuevo procedimiento de tramitaci&#xF3;n de proyectos para el fomento y desarrollo de la investigaci&#xF3;n cient&#xED;fica del Instituto de Salud P&#xFA;blica y deja sin efecto la resoluci&#xF3;n exenta N&#xB0; 1.761, de fecha 4 de julio de 2019.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10213864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10213865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "489 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-489 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1921523", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-03-23", "doble_articulado": false, "id_norma": "1157819", "numero_fuente": "42922", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-04-06", "vigencias": [{"desde": "2021-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-04-06", "fin_vigencia": "", "tipo_version": "3"}], "event