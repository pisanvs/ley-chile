{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,285.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170537}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; Conc&#xE9;dese, por gracia, a do&#xF1;a Eduvijis Carrasco v. de Soto Salas la cantidad de dos mil cuatrocientos pesos ($ 2,400), correspondiente al sueldo de dos a&#xF1;os de que disfrutaba su esposo, don Manuel Soto Salas, conductor de trenes de los Ferrocarriles del Estado. </div></div>", "i": 6170538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de marzo de mil novecientos diez.- Pedro Montt.-&nbsp; Eduardo D&#xE9;lano.</div><br></div>", "i": 6170539}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2285", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2285"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-03-05", "doble_articulado": false, "id_norma": "136996", "numero_fuente": "9635", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-03-08", "vigencias": [{"desde": "1910-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-03-08", "fin_vigencia": "", "tipo