{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303793}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 784, de 4 de junio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las Resoluciones N&#xBA; 1.741, de 1989 y N&#xBA; 220, de 1990, ambas de esta Subsecretar&#xED;a, que autorizaron a SOCIEDAD PESQUERA SANTOS DEL MAR LTDA., para iniciar actividades pesqueras extractivas con la nave &quot;Caicaven&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143 letras b) de la Ley N&#xBA; 18.892 y sus modificaciones. </div></div>", "i": 8303794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de junio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303795}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "784", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-784"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "SOCIEDAD PESQUERA SANTOS DEL MAR LTDA.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-04", "doble_articulado": false, "id_norma": "73551", "numero_fuente": "35789", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-13", "vigencias": [{"desde": "1997-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-13", "fin_vigencia": "", "tipo_version": "