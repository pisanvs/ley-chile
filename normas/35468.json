{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 742, de 22 de junio de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por ROSSANA DEL CARMEN PEREIRA FLORES, R.U.T. N&#xB0; 8.915.936-9, para un centro de cultivo ubicado en Bah&#xED;a de Tongoy, Comuna de Coquimbo, Provincia de Elqui, IV Regi&#xF3;n, por no dar cumplimiento el respectivo proyecto t&#xE9;cnico al art&#xED;culo 67&#xB0;, inciso 5&#xB0; de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8293951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de junio de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293952}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "742", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-742"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION ACUICULTURA", "ROSSANA PEREIRA FLORES", "DENEGACION", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-06-22", "doble_articulado": false, "id_norma": "35468", "numero_fuente": "35204", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-28", "vigencias": [{"desde": "1995-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-06-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi