{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 26, DE 1985</div><br><br></div>", "i": 7260114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 388 de 08 de Mayo de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. se modifica la Resoluci&#xF3;n 26, de 1985. de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la Sociedad Industrial Pesquera Me Hugh y Compa&#xF1;&#xED;a Ltda., domiciliada en Iquique, para operar en faenas extractivas de recursos hidrobiol&#xF3;gicos, la embarcaci&#xF3;n denominada &quot;Tarapac &quot;, en orden a ampliar la zona de operaci&#xF3;n de dicha embarcaci&#xF3;n al litoral de las Regiones III y IV.</div><br></div>", "i": 7260115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 08 de Mayo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7260116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "388", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-388"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 26, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-05-08", "fecha_derogacion": "1987-07-23", "doble_articulado": false, "id_norma": "153607", "numero_fuente": "32490", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-06-07", "vigencias": [{"desde": "1987-07-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-06-07", "hasta": "1987-07-22", "tipo_version": "0", "tipo_versi