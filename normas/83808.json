{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 487, DE 1989 </div></div>", "i": 6066324}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 487 de fecha 28.12.89, la Secretar&#xED;a Ministerial de Educaci&#xF3;n de la Regi&#xF3;n de Antofagasta ha aprobado Planes y Programas de Estudio de 1&#xB0; a 4&#xB0; A&#xF1;o de la Educaci&#xF3;n Media T&#xE9;cnico Profesional, para el Liceo Polit&#xE9;cnico B - 9 &quot;Ces&#xE1;reo Goyenechea&quot; de Calama. En las Especialidades de:</div><br><div class=\"p\">- Contabilidad</div><div class=\"p\">- Secretariado Administrativo y Digitaci&#xF3;n Computacional</div><div class=\"p\">- Ventas y Publicidad</div><div class=\"p\">- Alimentaci&#xF3;n</div><div class=\"p\">- Vestuario.</div><br><div class=\"p\">Los Planes y Programas aprobados tendr&#xE1;n vigencia a contar del a&#xF1;o escolar 1990 y hasta el a&#xF1;o 1997.-</div><br></div>", "i": 6066325}, {"t": "<div><div class=\"p\">Mar&#xED;a Moscopulos Arismendi, Secretaria Ministerial de Educaci&#xF3;n, Regi&#xF3;n de Antofagasta.- Roberto Silva Pimentel, Director Ejecutivo.</div><br></div>", "i": 6066326}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "487 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-487 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SECRETARIA MINISTERIAL DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 487, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-28", "doble_articulado": false, "id_norma": "83808", "numero_fuente": "33621", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-15", "vigenc