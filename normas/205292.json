{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A GACM S.A. </div></div>", "i": 6405017}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por resoluci&#xF3;n exenta N&#xBA; 153 del 8 de octubre de 2002. Concede la calidad de Agente Retenedor del IVA a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, a GACM S.A. RUT. 96.989.170-0, en las operaciones de faenamiento de ganado y en la venta de carnes, conforme a lo establecido en la resoluci&#xF3;n Ex.</div><div class=\"p\">N&#xBA; 3.722 del 28-07-2000, la cual entr&#xF3; en vigencia el 1 de agosto del 2000.-</div><br></div>", "i": 6405018}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Erica Morales Lartiga, Director Regional (S). </div></div>", "i": 6405019}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "153 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-153 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A GACM S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-08", "doble_articulado": false, "id_norma": "205292", "numero_fuente": "37425", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-04", "vigencias": [{"desde": "2002-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-04", "fin_vigencia": "", "tipo_version": "3"}], "even