{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 1.425, de 3 de julio de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8783803}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;case <a href=\"https://www.leychile.cl/Navegar?idNorma=215632&amp;idParte=0&amp;idVersion=\">la resoluci&#xF3;n 1.298, de 23 de junio de 2003, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>, en el sentido de reemplazar el p&#xE1;rrafo 4.- por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;4.- El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n 1.015, de 20 de mayo de 2003, y modificada por la resoluci&#xF3;n exenta 3.245, de 13 de noviembre de 2007, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;</div><br></div>", "i": 8783804, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de septiembre de 2009.- Por la Sra. Subsecretaria, Humberto Ram&#xED;rez Navarro, Subjefe Subsecretar&#xED;a de Marina.</div><br></div>", "i": 8783805}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1425", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1425"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-07-03", "doble_articulado": false, "id_norma": "10063