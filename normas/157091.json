{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6237614}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 143, de 14 de febrero de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a la Sociedad Gonz&#xE1;lez y Compa&#xF1;&#xED;a Limitada, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6237615}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de Febrero de 1985.- Carlos Osb&#xE9;n Mu&#xF1;oz, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, subrogante. </div></div>", "i": 6237616}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "143 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-143 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-14", "doble_articulado": false, "id_norma": "157091", "numero_fuente": "32114", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-06", "vigencias": [{"desde": "1985-03-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-06", "