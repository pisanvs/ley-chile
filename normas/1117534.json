{"html": [{"t": "<div><div class=\"p\">Instalacion del Supremo Tribunal de Justicia</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 22 de 1822.</div></div>", "i": 9914536}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mientras se reune la Convencion preparatoria i se concluyen las salas del Supremo Tribunal de Justicia, susp&#xE9;ndese la instalacion decretada de &#xE9;ste para el 31 del corriente i enc&#xE1;rguese a los majistrados nombrados formen un reglamento de sus atribuciones i gobierno interior para presentarlo a la Convencion.</div></div>", "i": 9914537}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese e impr&#xED;mase.-O&apos;Higgins.-Echeverr&#xED;a.</div></div>", "i": 9914538}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Instalacion del Supremo Tribunal de Justicia", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-05-22", "doble_articulado": false, "id_norma": "1117534", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-05-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-05-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2018-05-17", "fecha_version": "1822-05-22", "fecha_actualizacion_texto": "2018-05-17", "tipo_tratado": ""}, "alertas": [], "ale