{"html": [{"t": "<div><div class=\"p\">ORDENA ESTUDIO DE EXPROPIACION QUE INDICA</div><br><br></div>", "i": 6213610}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.000 de fecha 9 de diciembre de 1999 de Serviu IV Regi&#xF3;n de Coquimbo, se orden&#xF3; el estudio de la expropiaci&#xF3;n, conforme al art&#xED;culo 2 del D.L. N&#xBA; 2.186/78, del inmueble ubicado en la comuna de Ovalle, provincia de Limar&#xED;, IV Regi&#xF3;n de Coquimbo, rol de aval&#xFA;o 553-4 de la comuna de Ovalle, aparente dominio de la Comunidad Agr&#xED;cola Lagunillas Galleguillos del Valle. Dicha resoluci&#xF3;n fij&#xF3; plazo de 60 d&#xED;as para la realizaci&#xF3;n del estudio.</div><br></div>", "i": 6213611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu IV Regi&#xF3;n.</div><br></div>", "i": 6213612}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1000", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1000"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "ORDENA ESTUDIO DE EXPROPIACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-09", "doble_articulado": false, "id_norma": "149750", "numero_fuente": "36545", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-22", "vigencias": [{"desde": "1999-12-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-12-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes