{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 339 EXENTO, DE 1996</div><br><br><br></div>", "i": 7161642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento N&#xB0; 339, de fecha 18 de junio de 1996, del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Navieros Concepci&#xF3;n, las adecuaciones al plan y programas de estudios de la carrera de T&#xE9;cnico en Navegaci&#xF3;n y Extracci&#xF3;n Pesquera, modific&#xE1;ndose, en consecuencia, el decreto exento de Educaci&#xF3;n N&#xB0; 131 de 1994. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996.- </div></div>", "i": 7161643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de Julio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "339 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-339 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 339 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "CENTRO ESTUDIOS NAVIEROS", "CONCEPCION", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-06-18", "fecha_derogacion": "2004-04-13", "doble_articulado": false, "id_norma": "21028", "numero_fuente": "35525", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-07-25", "vigencias": [{"desde": "2004-04-13", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-07-25", "hasta": "2004-04-12", "tipo_version"