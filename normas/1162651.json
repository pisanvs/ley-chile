{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10252402}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 296, de 26 de mayo de 2021, se desisti&#xF3; de la expropiaci&#xF3;n del lote N&#xBA;489, expropiado mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=1152560&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xBA; 1001</a>, de 22 de octubre de 2020, para la obra: &quot;Reposici&#xF3;n Pavimento Ruta L-111-11, Sector Colbun-Panimavida-Linares&quot;, Comuna de Linares, Regi&#xF3;n del Maule&quot;, por cuanto, dicho lote fue eliminado por Resoluci&#xF3;n S.R.M. Regi&#xF3;n del Maule (Exenta) N&#xBA;1210, de 15 de diciembre de 2020. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xBA; del Decreto Ley N&#xBA;2186, de 1978. </div></div>", "i": 10252403}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10252404}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "296 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-296 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1975748", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-05-26", "doble_articulado": false, "id_norma": "1162651", "numero_fuente": "43003", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-07-15", "vigencias": [{"desde": "2021-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci