{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6257451}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 631 de fecha 23 de Septiembre de 1985, de la Secretaria Regional Ministerial de Transportes de la Regi&#xF3;n Metropolitana, se autoriza a don Carlos Ch&#xE1;vez Cuevas, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6257452}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Septiembre de 1985.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6257453}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "631 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-631 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-09-23", "doble_articulado": false, "id_norma": "163120", "numero_fuente": "32315", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-07", "vigencias": [{"desde": "1985-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-11-07", "fin_vigencia": "", "tipo_version": "3"}], "event