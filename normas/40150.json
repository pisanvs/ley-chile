{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION </div></div>", "i": 6026005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n N&#xB0; Ex. 2.302 de 31 de Octubre de 1994, la suscrita deleg&#xF3; en el Jefe de la Oficina Jur&#xED;dica Regional las funciones descritas en los n&#xFA;meros 1 al 8 del dispositivo Primero de la Resoluci&#xF3;n N&#xB0; Ex. 2482, de la Direcci&#xF3;n Nacional, de 3 de Junio de 1994, publicada en extracto en el Diario Oficial del d&#xED;a 6 del mismo mes y a&#xF1;o, revoc&#xE1;ndose, adem&#xE1;s la Resoluci&#xF3;n N&#xB0; 496 de 31.08.81, en lo pertinente.-</div><br></div>", "i": 6026006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julia Altamirano Santib&#xE1;&#xF1;ez, Directora Regional. </div></div>", "i": 6026007}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2302", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2302"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "SERVICIO IMPUESTOS INTERNOS", "JEFE", "DIRECCION REGIONAL", "DECIMOSEGUNDA REGION", "OFICINA JURIDICA REGIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-10-31", "doble_articulado": false, "id_norma": "40150", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-11-14", "vigencias": [{"desde": "2009-07-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-11-14", "hasta": "2009-07-09", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2009-07-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci