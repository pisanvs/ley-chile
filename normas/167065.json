{"html": [{"t": "<div><div class=\"p\">AUTORIZA A VASQUEZ Y COMPA&#xD1;IA LIMITADA PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 7268369}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.060, de 09 de Septiembre de 1987, de esta Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a V&#xE1;squez y Compa&#xF1;&#xED;a Limitada, domiciliada en Talcahuano, para ampliar actividades pesqueras autorizadas por resoluci&#xF3;n No. 204, de 1985, de esta Subsecretaria, en orden a facultarle para extraer con la embarcaci&#xF3;n &quot;Lincoy&#xE1;n&quot;, adem&#xE1;s de los recursos hidrobiol&#xF3;gicos ya autorizados, Langostino colorado y Langostino amarillo en las regiones IV a VIII.</div><br></div>", "i": 7268370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 09 de Septiembre de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7268371}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1060", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1060"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A VASQUEZ Y COMPAÑIA LIMITADA PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-09-09", "fecha_derogacion": "1990-10-29", "doble_articulado": false, "id_norma": "167065", "numero_fuente": "32889", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-10-08", "vigencias": [{"desde": "1990-10-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde"