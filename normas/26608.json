{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;AVENIDA DOCTOR LUIS EBERHARD R.&quot; LA ACTUAL AVENIDA ESTACION DE COLLIPULLI.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279396}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. La actual Avenida Estaci&#xF3;n de la ciudad de Collipulli se denominar&#xE1; en lo sucesivo &quot;Avenida Doctor Luis Eberhard R.&quot;.</div><br></div>", "i": 8279397}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, cinco de Septiembre de mil novecientos cincuenta y tres.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Osvaldo Koch.</div><br></div>", "i": 8279398}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11229", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11229"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DENOMINA \"AVENIDA DOCTOR LUIS EBERHARD R.\" LA ACTUAL\nAVENIDA ESTACION DE COLLIPULLI.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "AVENIDA DOCTOR LUIS EBERHARD R.", "COLLIPULLI"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1953-09-05", "doble_articulado": false, "id_norma": "26608", "numero_fuente": "22655", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1953-09-24", "vigencias": [{"desde": "1953-09-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1953-09-24", "fin_vigencia": "