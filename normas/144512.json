{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES </div></div>", "i": 6194443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 351, de 16 de agosto de 1999, modificada por resoluci&#xF3;n N&#xBA; 385 de 1&#xBA; de septiembre de 1999, ambas de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, parte inmueble ubicado en calle Diagonal Sur Oriente N&#xBA; 0540, presunto rol de aval&#xFA;os N&#xBA; 3647-11 comuna de La Granja, de aparente dominio de don Arturo Catrileo Sandoval. Comisi&#xF3;n integrada por peritos Sres. Luis Rojas Quezada, constructor civil, Juan Pagola Idiart y Ren&#xE9; Ureta Koster, arquitectos, seg&#xFA;n informe de 28 de mayo de 1999 fij&#xF3; monto provisional de indemnizaci&#xF3;n en $13.647.000.- pagadera al contado.-</div><br></div>", "i": 6194444}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6194445}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "351", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-351"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-16", "doble_articulado": false, "id_norma": "144512", "numero_fuente": "36478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-01", "vigencias": [{"desde": "1999-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-10-01", "fin