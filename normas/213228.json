{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6434117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.687, de 23 de julio de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; ALIMENTOS MARINOS S.A. ALIMAR, para ampliar actividades pesqueras extractivas con la nave &quot;Panilonco&quot;, en las &#xE1;reas mar&#xED;timas que en cada caso se indican, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: a) En la III Regi&#xF3;n, con arrastre de media agua, por fuera del &#xE1;rea de reserva artesanal: Merluza de cola; b) En la IV Regi&#xF3;n, con arrastre de media agua, por fuera de las 60 millas n&#xE1;uticas: Merluza de cola.</div><br></div>", "i": 6434118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de julio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6434119}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1687 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1687 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-07-23", "fecha_derogacion": "2020-12-30", "doble_articulado": false, "id_norma": "213228", "numero_fuente": "37626", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-08-04", "vigencias": [{"desde": "2020-12-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-08-04", "hasta": "2020-12-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia"