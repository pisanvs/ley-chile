{"html": [{"t": "<div><div class=\"p\">AUTORIZA A ALGAS SALINAS S.A. PARA DESARROLAR ACTIVIDADES PESQUERAS Y DENIEGA PERMISO QUE INDICA </div><br></div>", "i": 7261209}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 122, de 06 de Febrero de 1986, la</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, se autoriza a Algas Salinas</div><div class=\"p\">S.A., domiciliada en Puerto Montt, para instalar y</div><div class=\"p\">operar un establecimiento de cultivo de algas Gracilaria</div><div class=\"p\">en un sector de 30.000 m2., ubicado en Piedra Azul</div><div class=\"p\">comuna de Puerto Montt, provincia de Llanquihue y se le</div><div class=\"p\">deniega permiso para operar en la X Regi&#xF3;n un secador</div><div class=\"p\">artificial de algas, atendida la sobrecapacidad instalada de secadores existentes en la Regi&#xF3;n. </div></div>", "i": 7261210}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 06 de Febrero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7261211}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "122", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-122"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A ALGAS SALINAS S.A. PARA DESARROLAR\nACTIVIDADES PESQUERAS Y DENIEGA PERMISO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-02-06", "fecha_derogacion": "1995-01-09", "doble_articulado": false, "id_norma": "155581", "numero_fuente": "32402", "ti