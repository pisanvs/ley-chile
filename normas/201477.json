{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6392542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;978, de 3 de junio de 2002, se dej&#xF3;</div><div class=\"p\">sin efecto el decreto MOP N&#xBA;4.809, de 31 de octubre de 2000,</div><div class=\"p\">que orden&#xF3; la expropiaci&#xF3;n v&#xED;a judicial y aprob&#xF3; el plano y</div><div class=\"p\">cuadro de expropiaci&#xF3;n del lote de terreno N&#xBA;2, para la</div><div class=\"p\">ejecuci&#xF3;n de la obra: &apos;&apos;Mejoramiento Ruta 5 Sur, Sector</div><div class=\"p\">Pasada por Temuco, Camino Ruta 5, Sector Km. 667,6529 a Km.</div><div class=\"p\">673,551 y Km. 0,117 a Km. 0,133 (Eje 8)&apos;&apos;, por cambio de</div><div class=\"p\">trazado del proyecto de la obra que elimin&#xF3; dicho lote. La</div><div class=\"p\">publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el</div><div class=\"p\">art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.- </div></div>", "i": 6392543}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6392544}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "978", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-978"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-03", "doble_articulado": false, "id_norma": "201477", "numero_fuente": "37335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-16", "vigencias": [{"desde": "2002-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic