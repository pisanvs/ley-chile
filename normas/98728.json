{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329786}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;569, de 24 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, dej&#xE1;se sin efecto la resoluci&#xF3;n N&#xBA;138 de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a LUIS OMERO PAREDES CONTRERAS, para instalar y operar el centro de cultivo ubicado en la localidad de Chuyaqu&#xE9;n, R&#xED;o Maull&#xED;n, comuna de Maull&#xED;n, X Regi&#xF3;n, por haberse derogado el respectivo decreto de concesi&#xF3;n de acuicultura. </div></div>", "i": 8329787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329788}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "569", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-569"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "MAULLIN", "LUIS OMERO PAREDES CONTRERAS", "DECIMA REGION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-24", "doble_articulado": false, "id_norma": "98728", "numero_fuente": "36054", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-02", "vigencias": [{"desde": "1998-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-05-02", "fin_vigencia": "", "tip