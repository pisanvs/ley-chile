{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9305569}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;2210, de 28 de septiembre de 2012, y de conformidad a lo dispuesto en el art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;27, superficie 1.196 m2., Rol N&#xBA;524-89, para la obra &quot;MEJORAMIENTO CAMINO COSTERO S: TIR&#xDA;A &#x2013; L&#xCD;MITE REGIONAL&quot;, Comuna de Tir&#xFA;a, Regi&#xF3;n de B&#xED;o B&#xED;o. La comisi&#xF3;n de peritos, integrada por Alejandra Figueroa Giralt, Claudio Castro Guti&#xE9;rrez y Juan Tepper Lavanderos, fij&#xF3; el valor de tasaci&#xF3;n con fecha 10 de septiembre de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario HILARIO LINCOPI YAUPI, en la cantidad de $1.987.141, suma que se pagar&#xE1; al contado.- </div></div>", "i": 9305570}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9305571}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2210 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2210 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-28", "doble_articulado": false, "id_norma": "1044878", "numero_fuente": "40386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-16", "vigencias": [{"desde": "2012-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini