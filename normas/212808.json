{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6432746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 1.571, de 9 de julio de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ITATA S.A. para sustituir la nave &quot;Porvenir II&quot;, por una nave en construcci&#xF3;n, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Eslora total&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  24,00 m</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; 125,50 t</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; 127,60 m3</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Cerco</div><br><div class=\"p\">&nbsp; &nbsp;  F&#xED;jase como zona de operaci&#xF3;n de la nave reemplazante individualizada precedentemente, el &#xE1;rea mar&#xED;tima de la VII y VIII Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con red de cerco, el recurso hidrobiol&#xF3;gico Jurel.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.774, de 2002, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6432747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de julio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6432748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1571 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1571 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-09",