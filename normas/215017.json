{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6440875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.055, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de las resoluciones N&#xBA; 1.522 de 1998 y N&#xBA; 2.357 de 2000, ambas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA QUINTERO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Don Stefan&quot;, en el sentido de incorporar a esta &#xFA;ltima las siguientes caracter&#xED;sticas n&#xE1;uticas:</div><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp;  18.84 m.</div><div class=\"p\">Potencia principal&nbsp; &nbsp;  525.00 Hp.</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp; &nbsp; 8.50 Hp.</div><br></div>", "i": 6440876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6440877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2055 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2055 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-21", "doble_articulado": false, "id_norma": "215017", "numero_fuente": "37668", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-25", "vigencias": [{"desde": "2003-09-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-25", "fin_vigencia": ""}, "vigencias_versi