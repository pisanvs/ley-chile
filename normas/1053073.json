{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.201 EXENTA, DE 2013</div></div>", "i": 9366278}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 5.201, de 9 de julio de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Centro de Formaci&#xF3;n T&#xE9;cnica Ireland Ltda. (C.F.T. Ireland)&quot;, RUT 77.168.390-8, contenida en la resoluci&#xF3;n exenta N&#xBA; 2.599, de 29 de septiembre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9366279}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9366280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5201 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5201 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.201 EXENTA, DE 2013", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-07-09", "fecha_derogacion": "2013-08-06", "doble_articulado": false, "id_norma": "1053073", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-07-23", "vigencias": [{"desde": "2013-08-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2013-07-23", "hasta": "2013-08-05", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2013-08-06", "fin_vigencia": ""}, "vigencias_ve