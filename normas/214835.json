{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303798}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.058, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 132, de 1986, y N&#xBA; 1.066, de 1987, ambas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA QUINTERO S.A. para operar la nave &quot;Crusoe I&quot; en el &#xE1;rea mar&#xED;tima comprendida entre la III a VII Regiones, sobre los recursos Jurel, Sardina espa&#xF1;ola, Sardina com&#xFA;n, Anchoveta y Caballa, en virtud de lo dispuesto en el articulo 143 letra b) de la Ley General de Pesca&nbsp; y&nbsp; Acuicultura. </div></div>", "i": 7303799}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7303800}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2058 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2058 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-21", "doble_articulado": false, "id_norma": "214835", "numero_fuente": "37662", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-16", "vigencias": [{"desde": "2003-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-16", "fin_vigencia": "", "tipo_version": "3"}], "e