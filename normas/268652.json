{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6746676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 93, de 8 de enero de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a SALAZONES Y AHUMADOS PATAGONIA S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, para operar planta ubicada en Avenida Brasil N&#xBA; 95, Calbuco, para elaborar en l&#xED;neas de proceso de fresco-enfriado, congelado y seco salado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;janse sin efecto las resoluciones N&#xBA; 92 de 1998 y N&#xBA;1.689 de 2003, ambas de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6746677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de enero de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6746678}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "93 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-93 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-01-08", "doble_articulado": false, "id_norma": "268652", "numero_fuente": "38966", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-01-21", "vigencias": [{"desde": "2008-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-01-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen