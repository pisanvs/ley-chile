{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;772 EXENTO, DE 2004 </div></div>", "i": 6501281}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA;772 de 15 de septiembre de 2004, se ha aprobado programa de Religi&#xF3;n de la Iglesia Ej&#xE9;rcito de Salvaci&#xF3;n de Chile para todos los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica y de 1&#xBA; a 4&#xBA; a&#xF1;o de ense&#xF1;anza media de los Colegios Salvacionistas de Chile, los que se aplicar&#xE1;n simult&#xE1;neamente en todos los cursos a partir del a&#xF1;o escolar 2004 y seg&#xFA;n lo establecido en el decreto supremo de Educaci&#xF3;n N&#xBA;924 de 1983.</div><br></div>", "i": 6501282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de octubre de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6501283}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "772 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-772 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº772 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-15", "doble_articulado": false, "id_norma": "231466", "numero_fuente": "37988", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-18", "vigencias": [{"desde": "2004-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_