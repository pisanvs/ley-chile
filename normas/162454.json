{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 307 DE 16 DE SEPTIEMBRE DE 1985 </div></div>", "i": 6255392}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 307 de 16 de septiembre de 1985 se declara v lida la ense&#xF1;anza de un solo idioma extranjero impartida por el Colegio De La Salle de Santiago, en 3&#xB0; y 4&#xB0; a&#xF1;o de ense&#xF1;anza media human&#xED;stico cient&#xED;fica, durante los a&#xF1;os 1984 y 1985, para los cursos que se rigieron por el plan de estudio aprobado por el decreto supremo de Educaci&#xF3;n No. 11.201, de 1967.</div><br></div>", "i": 6255393}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Septiembre de 1985.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6255394}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "307 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-307 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 307\nDE 16 DE SEPTIEMBRE DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "162454", "numero_fuente": "32283", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-28", "vigencias": [{"desde": "1985-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-09-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-09-28", "fin_vigencia": ""