{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 233, DE 1991 </div></div>", "i": 8954217}, {"t": "<div><div class=\"p\">Por decreto Exento No. 233 de fecha 05 de Agosto de 1991<div class=\"n rnp\" id=\"rnp0\"><a href=\"#np0\">NOTA:</a></div> del Ministerio de Educaci&#xF3;n, se insert&#xF3; en las respectivas Resoluciones Exentas de Educaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Sim&#xF3;n Bol&#xED;var de Santiago, las adecuaciones introducidas a las carreras de Turismo y Hoteler&#xED;a; Secretario Ejecutivo Biling&#xFC;e y Control Industrial.</div><br><div class=\"np\" id=\"np0\"><a href=\"#rnp0\">NOTA:</a> <br>&nbsp; &nbsp;  El DTO 366 exento, Educaci&#xF3;n, publicado el 17.04.1998, aprob&#xF3; adecuaciones al programa de estudio de la carrera de Turismo y Hoteler&#xED;a.<br></div></div>", "i": 8954218}, {"t": "<div><div class=\"p\">Santiago, 08 de Noviembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8954219}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "2", "numero": "233 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-233 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "IA DE EDUCACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-05", "doble_articulado": false, "id_norma": "79926", "numero_fuente": "34125", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-11-25", "vigencias": [{"desde": "1998-04-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-11-25", "hasta": "1998-04-16", "tipo_version": "0", "tipo_ve