{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8912935}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.352, de 15 de abril de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ITATA S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Don Alfonso&quot;, en las &#xE1;reas mar&#xED;timas se&#xF1;aladas a continuaci&#xF3;n, donde podr&#xE1; extraer los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima comprendida entre la VI a VII y IX a X Regiones, por fuera del &#xE1;rea reservada a la pesca artesanal, con cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima comprendida entre la VI a VII y IX a X Regiones, por fuera de las 60 millas marinas, con arrastre de media agua: Jibia.</div></div>", "i": 8912936}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de abril de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 8912937}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1352 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1352 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-04-15", "fecha_derogacion": "2011-12-13", "doble_articulado": false, "id_norma": "1012694", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2010-04-24", "vigencias": [{"desde": "2011-12-13", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2010-04-24", "hasta": "2011-12-12", "tipo_version": "0", "tipo_version_s": "Texto Ori