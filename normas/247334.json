{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD AGRICOLA SAN FRANCISCO LTDA.</div><br><br></div>", "i": 6561455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del Servicio de Impuestos Internos, por resoluci&#xF3;n ex. N&#xBA; 26, de fecha 6 de febrero de 2006 otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n y en forma indefinida, a Sociedad Agr&#xED;cola San Francisco Ltda., RUT N&#xBA; 77.317.590-K, la calidad de Agente Retenedor del Impuesto al Valor Agregado, en las ventas de Ganado que realice, seg&#xFA;n lo establecido en la res. ex. 3.721 de 28.07.2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6561456}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Luis Mu&#xF1;oz Arratia, Director Regional. </div></div>", "i": 6561457}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "26 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-26 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD\nAGRICOLA SAN FRANCISCO LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD AGRICOLA SAN FRANCISCO LTDA", "AGENTE RETENEDOR DEL IVA", "VENTAS DE GANADO", "OTORGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-06", "doble_articulado": false, "id_norma": "247334", "numero_fuente": "38391", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-02-16", "vigencias": [{"desde": "2006-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig