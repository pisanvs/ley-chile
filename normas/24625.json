{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n al ex-barredor de patios del Palacio de la Moneda, F&#xE9;lix Ca&#xF1;a Vial.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, al ex-barredor de patios del Palacio de la Moneda, F&#xE9;lix Ca&#xF1;a Vial, una pensi&#xF3;n de mil doscientos pesos anuales ($ 1,200).</div><br></div>", "i": 8277368}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, primero de Febrero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Enrique Balmaceda. </div></div>", "i": 8277369}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4278", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4278"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE PENSION AL EX-BARREDOR DE PATIOS DEL PALACIO DE LA MONEDA, FELIX CAÑA VIAL..", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FELIX CA A VIAL", "PENSION", "BENEFICIO", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-01", "doble_articulado": false, "id_norma": "24625", "numero_fuente": "14992", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-06", "vigencias": [{"desde": "1928-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-02-06", "fin_vigenci