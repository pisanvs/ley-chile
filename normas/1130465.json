{"html": [{"t": "<div><br><div class=\"p\">AMPL&#xCD;A PLAZO QUE INDICA</div></div>", "i": 10014708}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.277, de 29 de marzo de 2019, de esta Subsecretar&#xED;a, ampl&#xED;ese por doce meses, a contar del 1 de enero de 2019 el plazo otorgado a Blumar S.A., para realizar actividades pesqueras extractivas con la nave &quot;Don Edmundo&quot; respecto del recurso hidrobiol&#xF3;gico Jibia, en el &#xE1;rea mar&#xED;tima comprendida entre las Regiones de Atacama al Maule y de la Araucan&#xED;a a Los Lagos, en virtud de haberse acreditado una circunstancia de fuerza mayor. </div></div>", "i": 10014709}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de marzo de 2019.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura (S). </div></div>", "i": 10014710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1277 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1277 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "AMPLÍA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1574473", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-03-29", "doble_articulado": false, "id_norma": "1130465", "numero_fuente": "42329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-04-12", "vigencias": [{"desde": "2019-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-04-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-04-12", "fin_vigencia": "", "