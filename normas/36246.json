{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.107, de 12 de junio de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase a AQUICULTURA</div><div class=\"p\">MIRAMAR CHILE, una autorizaci&#xF3;n de acuicultura para</div><div class=\"p\">instalar y operar una piscicultura, ubicada en la ribera</div><div class=\"p\">sur del Lago Lanalhue, Comuna de Ca&#xF1;ete, Provincia de</div><div class=\"p\">Arauco, VIII Regi&#xF3;n, conforme a lo dispuesto en los</div><div class=\"p\">art&#xED;culos 71, 78 y 87 de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14, del D.S. N&#xB0; 290, de 1993, modificado por el D.S. N&#xB0; 604, de 1994, ambos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8295736}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de junio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295737}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1107", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1107"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "AQUICULTURA MIRAMAR CHILE", "CA ETE", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-12", "doble_articulado": false, "id_norma": "36246", "numero_fuente": "35495", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-