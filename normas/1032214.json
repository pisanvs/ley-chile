{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 9.808 EXENTA, DE 2011</div><br></div>", "i": 9202564}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo se&#xF1;alado en el art&#xED;culo 48 de la Ley N&#xBA; 19.880, el Servicio Nacional de Capacitaci&#xF3;n y Empleo cumple con informar que mediante resoluci&#xF3;n exenta N&#xBA; 9.808, de 14 de octubre de 2011, se aprobaron las Instrucciones Generales para Beneficiarios del Programa de Capacitaci&#xF3;n en Oficios.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto completo de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio, www.sence.cl.- </div></div>", "i": 9202565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Ag&#xFC;ero Larrondo, Director Nacional Subrogante.</div></div>", "i": 9202566}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9808 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-9808 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 9.808 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-14", "doble_articulado": false, "id_norma": "1032214", "numero_fuente": "40108", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-12", "vigencias": [{"desde": "2011-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-11-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-11-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in