{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON GERMAN MOYA GARCIA, PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 7260972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 167 de 17 de Abril de 1984 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Germ&#xE1;n Moya Garc&#xED;a, RUT. 6.648.889-6, domiciliado en calle Luis Silva Lezaeta 0563, Gran V&#xED;a, Antofagasta, para operar una embarcaci&#xF3;n actualmente en construcci&#xF3;n, en labores extractivas de las especies que se indican, en el litoral comprendido entre la I y la II Regi&#xF3;n: Sardina espa&#xF1;ola, jurel, caballa, anchoa y bonito.</div><br></div>", "i": 7260973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de Abril de 1984.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7260974}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "167", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-167"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A DON GERMAN MOYA GARCIA, PARA DESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-04-17", "doble_articulado": false, "id_norma": "155109", "numero_fuente": "31871", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1984-05-15", "vigencias": [{"desde": "2003-08-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1984-05-15", "hasta": "2003-08-11", "tipo_version": "0", "tipo_version_s": "Te