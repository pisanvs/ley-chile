{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 991 EXENTA, DE 2006 </div></div>", "i": 6580040}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 991, de 1 de junio de 2006, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xBA; 5 de la resoluci&#xF3;n N&#xBA; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza, para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo como combustible.</div><br><br><div class=\"p\">Empresa&nbsp; &nbsp; &nbsp;  Nombre del&nbsp; &nbsp; &nbsp; Direcci&#xF3;n del</div><div class=\"p\">Habilitada&nbsp; &nbsp; &nbsp;  Taller&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Taller&nbsp; &nbsp; &nbsp; Ciudad</div><div class=\"p\">GLP Motor&nbsp; &nbsp; &nbsp; Marticorena</div><div class=\"p\">Ltda.&nbsp; &nbsp; &nbsp; &nbsp; Comercial Ltda.&nbsp; Chacabuco</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; N&#xBA; 2047&nbsp; &nbsp; &nbsp; &nbsp; Valpara&#xED;so</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.</div><br><br></div>", "i": 6580041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Danilo N&#xFA;&#xF1;ez Izquierdo, Subsecretario de Transportes.</div><br></div>", "i": 6580042}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "991 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-991 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 991 EXENTA, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [