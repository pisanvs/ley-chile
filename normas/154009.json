{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6227622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 544, de 14 de Agosto de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a don V&#xED;ctor Sebasti n Godoy Causa, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6227623}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6227624}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "544 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-544 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-14", "doble_articulado": false, "id_norma": "154009", "numero_fuente": "32553", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-21", "vigencias": [{"desde": "1986-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-08-21", "fin_vigencia": "", "tipo_versio