{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA LOCAL SOBRE DERECHOS MUNICIPALES </div></div>", "i": 6460570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Ilustre Municipalidad de Til Til, seg&#xFA;n acuerdo tomado por su honorable Concejo Municipal en Sesi&#xF3;n Extraordinaria N&#xBA; 41, de fecha 09 de diciembre de 2003, ha procedido a modificar su Ordenanza Local sobre Derechos Municipales. Dichas modificaciones comenzar&#xE1;n a regir a contar del 01 de enero del a&#xF1;o 2004 y su nuevo texto podr&#xE1; ser adquirido en Secretar&#xED;a Municipal de la I. Municipalidad de Til Til.</div><br></div>", "i": 6460571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Dar&#xED;o Ovalle Lecaros, Alcalde.- Demetrio Protopsaltis Palma, Secretario Municipal.</div><br></div>", "i": 6460572}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "S/N", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-S/N"}], "organismos": ["MUNICIPALIDAD DE TIL TIL"], "titulo_norma": "MODIFICA ORDENANZA LOCAL SOBRE DERECHOS MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-09", "doble_articulado": false, "id_norma": "220419", "numero_fuente": "37767", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-23", "vigencias": [{"desde": "2004-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-01-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-01-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":