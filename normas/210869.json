{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 111 EXENTA, DE 2003 </div></div>", "i": 6425639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;111, de 22 de mayo de 2003, se establece en $70 la tarifa escolar a cobrar por los servicios urbanos de locomoci&#xF3;n colectiva en la ciudad de Curic&#xF3; para los estudiantes de ense&#xF1;anza media, t&#xE9;cnica y universitaria; lo antes resuelto no excluye la posibilidad de cobrar una tarifa inferior si as&#xED; lo dispusieren los empresarios de los servicios urbanos de buses.</div><br></div>", "i": 6425640}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese en extracto.- Pedro Orozco L&#xF3;pez, Secretario Regional Ministerial de Transportes y Telecomunicaciones (S) Regi&#xF3;n del Maule.</div><br></div>", "i": 6425641}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "111 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-111 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 111 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-22", "doble_articulado": false, "id_norma": "210869", "numero_fuente": "37574", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-03", "vigencias": [{"desde": "2003-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "