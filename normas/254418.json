{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,910</div><br><div class=\"p\">ABONA EL TIEMPO QUE INDICA EN LA HOJA DE SERVICIOS DE DON TOMAS RIVERA MU&#xD1;OZ</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6586838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Ab&#xF3;nanse, por gracia y para todos los efectos legales, en la hoja de servicios de don Tom&#xE1;s Rivera Mu&#xF1;oz, los ocho a&#xF1;os que fue oficial de secretar&#xED;a del Juzgado de Letras de Yumbel.</div><br></div>", "i": 6586839}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintid&#xF3;s de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 6586840}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10910", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10910"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ABONA EL TIEMPO QUE INDICA EN LA HOJA DE SERVICIOS DE\nDON TOMAS RIVERA MUÑOZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-22", "doble_articulado": false, "id_norma": "254418", "numero_fuente": "22407", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-24", "vigencias": [{"desde": "1952-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia