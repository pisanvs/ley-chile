{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6534316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.989, de 29 de junio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a CARLOS HERNAN RODRIGUEZ MANNS, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Camino Caica&#xE9;n Km. 3, comuna de Calbuco, provincia de Llanquihue, X Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n congelado, fresco - refrigerado, conserva y ahumado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.801 de 2003, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6534317}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de junio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6534318}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1989 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1989 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-29", "doble_articulado": false, "id_norma": "240446", "numero_fuente": "38220", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-26", "vigencias": [{"desde": "2005-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "20