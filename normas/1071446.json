{"html": [{"t": "<div><br><div class=\"p\">POSTERGACI&#xD3;N DEL IMPUESTO AL VALOR AGREGADO</div></div>", "i": 9536581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 110 de 2 de diciembre de 2014, que se&#xF1;ala:</div><div class=\"p\">&nbsp; &nbsp;  Establece la forma y procedimiento en que se har&#xE1; efectiva la postergaci&#xF3;n del Impuesto al Valor Agregado, establecida en el inciso tercero del <a href=\"https://www.leychile.cl/Navegar?idNorma=6369&amp;idParte=8675389&amp;idVersion=\">art&#xED;culo 64</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=6369&amp;idParte=0&amp;idVersion=\">DL N&#xBA; 825</a>, incorporado por la <a href=\"https://www.leychile.cl/Navegar?idNorma=1067194&amp;idParte=0&amp;idVersion=\">ley N&#xBA; 20.780</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2014.</div></div>", "i": 9536582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "110 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-110 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "POSTERGACIÓN DEL IMPUESTO AL VALOR AGREGADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-12-02", "fecha_derogacion": "2022-05-07", "doble_articulado": false, "id_norma": "1071446", "numero_fuente": "41025", "t