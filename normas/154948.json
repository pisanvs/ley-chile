{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6230569}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 587, de 29 de Agosto de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n, se autoriza a don Luis L. Mu&#xF1;oz Sep&#xFA;lveda para efectuar todo tipo de servicios de transporte de pasajeros, por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6230570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o. </div></div>", "i": 6230571}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "587 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-587 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-29", "doble_articulado": false, "id_norma": "154948", "numero_fuente": "32.571", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-09-12", "vigencias": [{"desde": "1986-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-09-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien