{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOLICITA CONSTITUCION LEGAL DEL PARTIDO &quot;RENOVACION NACIONAL&quot; EN LA VI REGION </div></div>", "i": 6016673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Andr&#xE9;s Allamand Zavala y Rodrigo Ubilla Mackenney, Presidente y Secretario General, respectivamente, en representaci&#xF3;n del partido &quot;Renovaci&#xF3;n Nacional&quot;, han solicitado con fecha 27 de Noviembre de 1995, la constituci&#xF3;n legal del partido en la VI Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins. Expresan acompa&#xF1;ar 2.280 fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0; 1431 de fecha 30 de Noviembre de 1995.- </div></div>", "i": 6016674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6016675}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1431", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1431"}, {"tipo": "3", "numero": "O-1431", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1431"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION LEGAL DEL PARTIDO RENOVACION NACIONAL EN LA VI REGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "RENOVACION NACIONAL", "SEXTA", "REGION", "INSCRIPCION", "REGISTRO PARTIDOS POLITICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-30", "doble_articulado": false, "id_norma": "36957", "numero_fuente": "35337", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicac