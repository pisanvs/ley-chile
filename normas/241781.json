{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6539293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.815, de 26 de agosto de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIAL H y M S.A., para ampliar actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en Regimiento Coquimbo N&#xBA; 230, Coquimbo, IV Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado, Congelado, Seco salado, Ahumado, Conserva, Harina y Deshidratado los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6539294}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de agosto de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6539295}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2815 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2815 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-08-26", "fecha_derogacion": "2006-07-28", "doble_articulado": false, "id_norma": "241781", "numero_fuente": "38258", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-09-09", "vigencias": [{"desde": "2006-07-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-09-09", "hasta": "2006-07-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2006-07-28", "fin_vigencia": ""}, "vigencias_version