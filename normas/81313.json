{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8929877}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0;. 1.001 de 26 de agosto de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 30 d&#xED;as a contar de esta fecha, el plazo otorgado a PESQUERA IBER CHILE S.A. N&#xB0;. 96.535.870-6, domiciliada en Santiago, para empezar a operar las embarcaciones &quot;Iber II&quot; e &quot;Iber III&quot;, autorizadas por Resoluci&#xF3;n N&#xB0;. 393, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br><br></div>", "i": 8929878}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de Agosto de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br><br></div>", "i": 8929879}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1001", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1001"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-08-26", "fecha_derogacion": "1993-09-13", "doble_articulado": false, "id_norma": "81313", "numero_fuente": "34071", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-09-22", "vigencias": [{"desde": "1993-09-13", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-09-22", "hasta": "1993-09-12", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1993-09-13", "fin_vigencia": ""}