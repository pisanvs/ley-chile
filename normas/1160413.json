{"html": [{"t": "<div><br><div class=\"p\">NOMBRAMIENTO DE LA JUNTA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 20 de 1832.</div></div>", "i": 10248100}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Satisfecho de la ilustracion y patriotismo de los ciudadanos don Juan de Dios Vial del R&#xED;o, don Diego Jos&#xE9; Benavente, don Andres Bello, don Jos&#xE9; Miguel Irarr&#xE1;zaval y don Diego Arriaran; vengo la junta directora de estudios, cuyas atribuciones he designado por decreto de esta fecha, y a los dos &#xFA;ltimo para que los subroguen en sus ausencias y enfermedades. Comun&#xED;quese a quienes corresponda y publ&#xED;quese.</div></div>", "i": 10248101}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.</div><div class=\"p\">&nbsp; &nbsp;  Err&#xE1;zuriz.</div></div>", "i": 10248102}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "NOMBRAMIENTO DE LA JUNTA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-03-20", "doble_articulado": false, "id_norma": "1160413", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-03-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-07-05", "fecha_version": "1832-03-20", "fecha_actual