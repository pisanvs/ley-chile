{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Nombramiento de can&#xF3;nigo</div></div>", "i": 10197254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Los talentos i distinguidos servicios del antiguo Cura de Talca Don Jos&#xE9; Ignacio Cienfuegos le han acreditado en benem&#xE9;rito de la Patria cuyas altas confianzas acaba de desempe&#xF1;ar dignamente en el Gobierno. La justicia i el honor reclaman el premio correspondiente a su virtud. Por tanto se le confiere la Canonj&#xED;a vacante por muerte del Doctor Don Vicente Larrain. Transcr&#xED;basele al interesado, al Venerable Dean i Cabildo, i t&#xF3;mese razon.</div></div>", "i": 10197255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Dado en el Palacio de Chile, a 9 de Marzo de 1814.</div></div>", "i": 10197256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Nombramiento de canónigo", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-03-09", "doble_articulado": false, "id_norma": "1154704", "numero_fuente": "1814", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "17616", "fecha_ingreso": "2021-01-29", "fecha_version": "1814-03-09", "fecha_actualizacion_texto": "2021-01-29", "tipo_tratado": ""},