{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6461373}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.534, de 30 de diciembre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a SINDICATO DE TRABAJADORES INDEPENDIENTES DE LA PESCA ARTESANAL, BUZOS MARISCADORES Y ACTIVIDADES CONEXAS CALETA CERRO VERDE, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en calle El Faro, Pasaje N&#xBA; 2 s/n, Cerro Verde Bajo, comuna de Penco, VIII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Cocido, fresco-enfriado, fresco-refrigerado, conserva, alga seca y alga fresca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6461374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6461375}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3534 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3534 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-12-30", "fecha_derogacion": "2005-04-16", "doble_articulado": false, "id_norma": "220629", "numero_fuente": "37772", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-01-29", "vigencias": [{"desde": "2005-04-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-01-29", "hasta": "2005-04-15", "tipo_version": "0", "tipo_ve