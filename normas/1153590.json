{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10185350}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xBA; 1.193, de fecha 23/11/2020, conforme al art&#xED;culo 51 ley 16.391, DL 2.186/1978 y DS 1.128/2012, de Vivienda y Urbanismo, para destinarlo al Proyecto &quot;Construcci&#xF3;n Soluci&#xF3;n AA.LL. acceso Las Mariposas, Temuco&quot;, Serviu Regi&#xF3;n de la Araucan&#xED;a orden&#xF3; la expropiaci&#xF3;n parcial del bien ra&#xED;z denominado Inmueble consistente en la parcela n&#xFA;mero 1 del Fundo La Esperanza, Rol de aval&#xFA;o 3203-31, comuna de Temuco. La superficie a expropiar aproximada es de 117,83 metros cuadrados, de aparente dominio de Miriam Elisabeth Stockebrand Lorca. Comisi&#xF3;n de Peritos integrada por don &#xCD;talo Cort&#xE9;s Rocco, Eduardo Ya&#xF1;ez Inzunza y Claudio Pezo Mu&#xF1;oz, fij&#xF3; monto de Indemnizaci&#xF3;n Provisional en $7.840.000.- seg&#xFA;n Informe N&#xBA; 02-0 de fecha 16/11/2020, pagadero contado.- </div></div>", "i": 10185351}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de la Araucan&#xED;a.</div><br></div>", "i": 10185352}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1193 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1193 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1857597", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-11-23", "doble_articulado": fal