{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO DEL CONSEJO DE ESTADO</div><br><div class=\"p\">&nbsp; &nbsp;  Concepcion, Febrero 2 de 1824.</div></div>", "i": 10064870}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Con arreglo a lo prevenido en el art. 28 de la Constitucion, y a la facultad que me concede el S. 11 del art. 18 nombro para Consejeros de Estado a D. Jos&#xE9; Gregorio Argomedo, a D. Francisco Antonio P&#xE9;rez, a D. Jos&#xE9; Ignacio Cienfuegos, a D. Manuel Blanco Encalada y a D. Agustin Vial. Los nombrados ser&#xE1;n puestos inmediatamente en posesion de este cargo, para lo cual se les comunicar&#xE1; el presente decreto, que se insertar&#xE1; en el Boletin.</div></div>", "i": 10064871}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Fern&#xE1;ndez.</div></div>", "i": 10064872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "NOMBRAMIENTO DEL CONSEJO DE ESTADO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-02-02", "doble_articulado": false, "id_norma": "1137401", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-02-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": 