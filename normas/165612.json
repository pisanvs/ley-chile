{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 271 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6265165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Cielo de la Educaci&#xF3;n Media T&#xE9;cnico-Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo Comercial &quot;A&quot; No. 6, de Iquique.</div><br><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES: Jornada Diurna</div><br><div class=\"p\">&nbsp; &nbsp; 1.- Contabilidad.</div><div class=\"p\">&nbsp; &nbsp; 2..- Ventas y Publicidad.</div><div class=\"p\">&nbsp; &nbsp; 3.- Secretariado Ejecutivo.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Jornada Nocturna:</div><br><div class=\"p\">&nbsp; &nbsp; 1.- Contabilidad.</div><div class=\"p\">&nbsp; &nbsp; 2.- Ventas y Publicidad. 3.- Secretariado</div><div class=\"p\">Ejecutivo.</div><br></div>", "i": 6265166}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  28 de junio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica, subrogante.</div><br></div>", "i": 6265167}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "271 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-271 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 271\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "165612", "numero_fue