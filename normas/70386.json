{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 270 EXENTO, DE 1997 </div></div>", "i": 6033732}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Supremo exento de Educaci&#xF3;n N&#xBA; 270 de 13 de marzo de 1997, se ha autorizado al Colegio Nido de Aguilas de Santiago, para que, a partir del a&#xF1;o escolar 1997, imparta la ense&#xF1;anza en car&#xE1;cter de biling&#xFC;e, en todos los cursos de ense&#xF1;anza b&#xE1;sica, salvo las asignaturas (subsector de aprendizaje) Castellano e Historia y Geograf&#xED;a de Chile.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para la asignatura (subsector de aprendizaje) Ingl&#xE9;s, para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica. </div></div>", "i": 6033733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de marzo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6033734}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "270 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-270 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 270 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROGRAMAS ESTUDIO", "ENSE ANZA BILINGUE", "COLEGIO NIDO DE AGUILAS", "SANTIAGO", "ENSE ANZA BASICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-13", "doble_articulado": false, "id_norma": "70386", "numero_fuente": "35734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-07", "vigencias": [{"desde": "1997-04-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}