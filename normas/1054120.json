{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">ESTABLECE AGRUPACIONES DE CONCESIONES DE ACUICULTURA DE SALM&#xD3;NIDOS EN LAS REGIONES X, XI Y XII</div></div>", "i": 9373893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.473, de 3 de septiembre de 2013, de esta Subsecretar&#xED;a, se establecen las agrupaciones de concesiones de acuicultura de salm&#xF3;nidos en las Regiones X, XI y XII, reemplaz&#xE1;ndose las existentes a la fecha, individualizadas &#xED;ntegramente en la resoluci&#xF3;n extractada y publicada &#xED;ntegramente en www.subpesca.cl y www.sernapesca.cl.</div></div>", "i": 9373894}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de septiembre de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9373895}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2473 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2473 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "ESTABLECE AGRUPACIONES DE CONCESIONES DE ACUICULTURA DE SALMÓNIDOS EN LAS REGIONES X, XI Y XII", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-09-03", "doble_articulado": false, "id_norma": "1054120", "numero_fuente": "40657", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-09-11", "vigencias": [{"desde": "2013-09-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig