{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO N&#xBA; 25 EXENTO DE 2000</div><br></div>", "i": 6318408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 25 de fecha 18 de enero de 2000 del Ministerio de Educaci&#xF3;n, se declara aprobada al Instituto Profesional Santo Tom&#xE1;s, la carrera de Servicio Social conducente al t&#xED;tulo profesional de Asistente Social, para ser impartida en jornada diurna en su sede de la ciudad de Concepci&#xF3;n, de conformidad al Acuerdo adoptado por el Consejo Superior de Educaci&#xF3;n, quien llevar&#xE1; a efecto la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6318409}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6318410}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "25 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-25 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 25 EXENTO DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-18", "doble_articulado": false, "id_norma": "180755", "numero_fuente": "36873", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-27", "vigencias": [{"desde": "2001-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"