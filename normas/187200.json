{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6341022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 3.247, de 29 de octubre de 1999, se orden&#xF3; la expropiaci&#xF3;n y aprob&#xF3; el plano y cuadro de expropiaci&#xF3;n del lote de terreno N&#xBA; 1-K, y por decreto MOP N&#xBA; 712, de 30 de abril de 2001, se autoriz&#xF3; el valor de la consignaci&#xF3;n provisional de la expropiaci&#xF3;n por la v&#xED;a judicial, en la cantidad de $744.000.- necesario para la ejecuci&#xF3;n de la obra &apos;&apos;Camino Quinta de Tilcoco-Co&#xED;nco, Sector Quinta de Tilcoco-Co&#xED;nco, Km.</div><div class=\"p\">0.000,000 a Km. 12.732,500&apos;&apos; el pago de la indemnizaci&#xF3;n se efectuar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2186, de 1978.</div><br></div>", "i": 6341023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6341024}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3247", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3247"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-29", "doble_articulado": false, "id_norma": "187200", "numero_fuente": "37001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-03", "vigencias": [{"desde": "2001-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-03", "fin_vigencia": ""}, "vigencias_version_no