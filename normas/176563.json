{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE&nbsp; DECRETO&nbsp; N&#xBA;271 EXENTO, DE&nbsp; 2000</div><br></div>", "i": 7277032}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 271 de fecha 20 de julio de 2000 del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas de estudios de la carrera de Asistente de Educador de P&#xE1;rvulos del Centro de Formaci&#xF3;n T&#xE9;cnica Juan Bohon, que se encuentran anexas y forman parte del decreto, modific&#xE1;ndose en consecuencia, la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;64 del 12 de enero de 1983, en el sentido de incorporar las actuales adecuaciones. Las adecuaciones que se aprueban, podr&#xE1;n aplicarse a contar del a&#xF1;o 2000.</div><br></div>", "i": 7277033}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de agosto de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7277034}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "271 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-271 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº271 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-20", "doble_articulado": false, "id_norma": "176563", "numero_fuente": "36784", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-11", "vigencias": [{"desde": "2000-10-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-11", "fin_vi