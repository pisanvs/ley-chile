{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6460609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 124, de 14 de enero de 2004, de</div><div class=\"p\">esta Subsecretar&#xED;a, recon&#xF3;cese la participaci&#xF3;n conjunta</div><div class=\"p\">de los armadores que a continuaci&#xF3;n se indican, en la</div><div class=\"p\">unidad de pesquer&#xED;a Merluza com&#xFA;n, individualizada en el</div><div class=\"p\">art&#xED;culo 2&#xBA; letra m) de la ley 19.713, para ejercer el l&#xED;mite m&#xE1;ximo de captura establecido por decreto exento N&#xBA; 845 de 2003, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, a partir de la fecha de la presente resoluci&#xF3;n y hasta el 31 de diciembre del 2004:</div><br><div class=\"p\">ALVAREZ ARMIJO, JAIME; GONZALEZ RIVERA, MARCELINO; NORDIO LTDA. SOC.</div><br><div class=\"p\">&nbsp; &nbsp;  La opci&#xF3;n ejercida por el grupo de armadores antes indicados es irrevocable durante el presente a&#xF1;o calendario.</div><br></div>", "i": 6460610}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6460611}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "124", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-124"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-14", "doble_articulado": false, "id_norma": "220432", "numero_fuente": "37767", "tipo_version": "3", "tipo_version_s": "Única", "fe