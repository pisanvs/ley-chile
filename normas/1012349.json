{"html": [{"t": "<div><br><div class=\"p\">DELEGA FACULTAD QUE INDICA</div></div>", "i": 8907267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. N&#xBA;19, de 1 de abril de 2010, de la Direcci&#xF3;n Regional de Copiap&#xF3; del Servicio de Impuestos Internos, del&#xE9;gase en los funcionarios individualizados nominativamente la facultad de autorizar a los contribuyentes que lo soliciten, el pago diferido de los impuestos de la Ley de la Renta.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta Resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl)</div></div>", "i": 8907268}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "19 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-19 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL DE COPIAPÓ"], "titulo_norma": "DELEGA FACULTAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-04-01", "doble_articulado": false, "id_norma": "1012349", "numero_fuente": "39632", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-04-10", "vigencias": [{"desde": "2010-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-04-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-04-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2010-04-12", "fecha_version": "2010-04-10", "actualizado_por": "98", "fecha_actu