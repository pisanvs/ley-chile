{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;QUILLAY&quot; A LA ACTUAL CALLE &quot;GATH Y CHAVES&quot;, DE LA COMUNA DE PROVIDENCIA.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La calle &quot;Gath y Chaves&quot;, de la comuna de Providencia, se denominar&#xE1; calle &quot;Quillay&quot;. </div></div>", "i": 8279409}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, quince de Septiembre de mil novecientos cincuenta y tres.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Osvaldo Koch.</div><br></div>", "i": 8279410}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11251", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11251"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DENOMINA QUILLAY A LA ACTUAL CALLE \"GATH Y CHAVES\", DE LA COMUNA DE PROVIDENCIA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE QUILLAY", "PROVIDENCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1953-09-15", "doble_articulado": false, "id_norma": "26618", "numero_fuente": "22663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1953-10-03", "vigencias": [{"desde": "1953-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1953-10-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"