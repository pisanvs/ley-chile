{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5895888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto MOP. N&#xB0; 137, de fecha 29 de Abril de 1994, se expropiaron los lotes de terrenos N&#xB0;s. 12 y 13 superficies ambas 375, roles de aval&#xFA;o 336-2 y 336-3, Comuna de Penco, para la obra Ampliaci&#xF3;n y Reposici&#xF3;n Ruta 150 Concepci&#xF3;n - Lirqu&#xE9;n, y se aprob&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Luz E. Villanueva Vallejos y Cristian J. Guerrero Villanueva, ascendente a las cantidades de $7.970.270 y $4.490.750.-</div><br></div>", "i": 5895889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas </div></div>", "i": 5895890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "137", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-137"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN RAIZ", "BIEN INMUEBLE", "DECRETO EXPROPIATORIO", "PENCO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-04-29", "doble_articulado": false, "id_norma": "9864", "numero_fuente": "34879-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-01", "vigencias": [{"desde": "1994-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1994-06-01", "fecha_actualizacion_texto": "1994-06-01", "tipo_tratado": ""}, "alerta