{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6272871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 9, de 11 de abril de 1985, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a Dn. Leopoldo Gonz&#xE1;lez Rodr&#xED;guez para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios pdblicas urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6272872}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 6272873}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-9 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-11", "doble_articulado": false, "id_norma": "167902", "numero_fuente": "32169", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-05-13", "vigencias": [{"desde": "1985-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-05-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen