{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 140 EXENTO, DE 1994 </div></div>", "i": 7160760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 140 de fecha 29 de marzo de 1994 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica ITESA, las adecuaciones introducidas a los Planes y Programas de Estudios de las Carreras que se se&#xF1;alan, las que se entienden incorporadas en los documentos que en cada caso se indican. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1994:</div><div class=\"p\"> Carrera&nbsp;  :&nbsp; Administraci&#xF3;n de Empresas con menci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; en personal o finanzas o comercializaci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Resoluci&#xF3;n Exenta N&#xB0; 893/86)</div><div class=\"p\"> Carrera&nbsp;  :&nbsp; Comercio exterior (Resoluci&#xF3;n Exenta</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; N&#xB0; 893/86)</div><div class=\"p\"> Carrera&nbsp;  :&nbsp; Publicidad (Resoluci&#xF3;n Exenta N&#xB0; 599/83)</div><div class=\"p\">Carrera&nbsp;  :&nbsp; Dise&#xF1;o gr&#xE1;fico publicitario (Resoluci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Exenta N&#xB0; 599/83).</div><br></div>", "i": 7160761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 20 de Mayo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "140 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-140 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 140 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "termino