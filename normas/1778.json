{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8922411}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Subsecretario de Educaci&#xF3;n quien suscribe, certifica que el Instituto Profesional DUOC, autorizado a funcionar por Decreto Exento N&#xB0; 3 de 1983, ha presentado los programas de estudios de la carrera Ingenier&#xED;a de Ejecuci&#xF3;n en Inform&#xE1;tica conducente al t&#xED;tulo profesional de Ingeniero de Ejecuci&#xF3;n en Inform&#xE1;tica, a la Universidad T&#xE9;cnica Federico Santa Mar&#xED;a como entidad examinadora y revisados por &#xE9;sta, han sido aprobados en tiempo y forma, de acuerdo a convenio de examinaci&#xF3;n suscrito por ambas instituciones.</div><div class=\"p\">&nbsp; &nbsp; La carrera profesional mencionada podr&#xE1; ser impartida por el Instituto Profesional DUOC, a contar del a&#xF1;o 1994 en las ciudades de Santiago, Vi&#xF1;a del Mar y Concepci&#xF3;n.</div><br></div>", "i": 8922412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  JULIO VALLADARES MU&#xD1;OZ</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Subsecretario de Educaci&#xF3;n</div><br></div>", "i": 8922413}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL DUOC", "PROGRAMAS ESTUDIOS", "INGENIERIA EJECUCION INFORMATICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1778", "numero_fuente": "34822", "tipo_version": "3", "tipo_version_s": "Única", "f