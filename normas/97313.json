{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 263, de 19 de febrero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 427 y N&#xBA; 536 de 1997, ambas de esta Subsecretar&#xED;a, que autorizaron a don Roberto Fermandois Gatica, para operar la nave &quot;Tonyn&quot;, matr&#xED;cula 2646, por no haber dado cumplimiento al pago de la patente &#xFA;nica pesquera correspondiente al a&#xF1;o 1997, en virtud de lo dispuesto en Art. 143 letra d), del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8328593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de febrero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8328594}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "263", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-263"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ROBERTO FERNANDOIS GATICA", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-19", "doble_articulado": false, "id_norma": "97313", "numero_fuente": "36001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-26", "vigencias": [{"desde": "1998-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-02-26", "fin_vigencia": ""}, "vigencias_version_no