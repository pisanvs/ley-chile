{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,309.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por el teniente-coronel graduado de la &#xE9;poca de la Independencia, don Ignacio D&#xED;az Valdes, aum&#xE9;ntase a sesenta pesos mensuales el montep&#xED;o de que disfrutan sus hijas do&#xF1;a Mariana i do&#xF1;a Quiteria D&#xED;az Valdes&quot;. </div></div>", "i": 6171507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de junio de mil novecientos diez- Pedro Montt.- C&#xE1;rlos Larrain Claro.</div><br></div>", "i": 6171508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2309", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2309"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-06-28", "doble_articulado": false, "id_norma": "137303", "numero_fuente": "9738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-07-09", "vigencias": [{"desde": "1910-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-07-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-07-09", "fin_vigencia": "", "tipo_version": "3"}