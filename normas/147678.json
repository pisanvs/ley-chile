{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8353556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.238, de 29 de octubre de 1999,</div><div class=\"p\">de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; PESQUERA EL GOLFO</div><div class=\"p\">S.A., para ampliar las actividades pesqueras autorizadas</div><div class=\"p\">con la nave &apos;&apos;Polaris II&apos;&apos;, en el litoral de la IV</div><div class=\"p\">Regi&#xF3;n y el paralelo 41&#xB0;28,6&apos; L.S., sobre el recurso</div><div class=\"p\">hidrobiol&#xF3;gico Merluza de tres aletas.</div><div class=\"p\">&nbsp; &nbsp;  Deni&#xE9;gase la autorizaci&#xF3;n solicitada respecto de</div><div class=\"p\">los recursos y &#xE1;reas no contemplados en la presente</div><div class=\"p\">resoluci&#xF3;n, en virtud de los informes t&#xE9;cnicos y los</div><div class=\"p\">art&#xED;culos 47 y 19 letras c) y e) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8353557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8353558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2238", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2238"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-10-29", "fecha_derogacion": "2016-11-21", "doble_articulado": false, "id_norma": "147678", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-11-13", "vigencias": [{"desde": "2016-11-