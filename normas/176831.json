{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6305637}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 2.240, de 17 de octubre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA FRIOSUR S.A., para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Friosur X&apos;&apos;, en el &#xE1;rea mar&#xED;tima que se indica, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con arrastre los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima de I Regi&#xF3;n: Alfonsino; b) En el &#xE1;rea mar&#xED;tima de la Isla de Pascua, Archipi&#xE9;lago Juan Fern&#xE1;ndez, Isla Sala y G&#xF3;mez e Islas Desventuradas: Alfonsino.</div><br></div>", "i": 6305638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de octubre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6305639}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2240", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2240"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-17", "doble_articulado": false, "id_norma": "176831", "numero_fuente": "36792", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-20", "vigencias": [{"desde": "2000-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-20", "fin_vigencia": "",