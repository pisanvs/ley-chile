{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8345217}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 928, de 20 de mayo de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 1.060 de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don OLEGARIO ERNESTO DELGADO DIAZ, para operar la nave &apos;&apos;Alborada&apos;&apos;, por haber suspendido actividades extractivas por m&#xE1;s de 12 meses sucesivos, respecto de los recursos Anchoveta, Sardina espa&#xF1;ola, Jurel y otros pel&#xE1;gicos no declarados en plena explotaci&#xF3;n de la I a la III Regiones, configur&#xE1;ndose la causal prevista en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8345218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de mayo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8345219}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "928", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-928"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-20", "doble_articulado": false, "id_norma": "137029", "numero_fuente": "36374", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-28", "vigencias": [{"desde": "1999-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-