{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6198387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1283 de fecha 28.11.86, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones, de la Regi&#xF3;n Metropolitana, se autoriza a do&#xF1;a Eliana de las Mercedes Mart&#xED;nez N&#xFA;&#xF1;ez, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6198388}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 04.12.86.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6198389}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1283 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1283 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-11-28", "doble_articulado": false, "id_norma": "145731", "numero_fuente": "32715", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-06", "vigencias": [{"desde": "1987-03-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-03-06", "fin_vigencia":