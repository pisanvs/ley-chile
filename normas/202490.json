{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7294123}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.810, de 27 de agosto de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a do&#xF1;a MARIA BAYCIC BAYCIC, para ampliar actividades pesqueras extractivas con la nave &quot;Ulises 2&quot;, autorizada por las resoluciones N&#xBA; 287 de 1983, N&#xBA; 198 de 1985, N&#xBA; 460 de 1987, N&#xBA; 154 de 1994, N&#xBA; 1.764 de 1996, N&#xBA; 896, N&#xBA; 1.207 y N&#xBA; 2.251, todas de 2001, todas de esta Subsecretar&#xED;a, en orden a realizar actividades pesqueras con la nave individualizada precedentemente, en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 24&#xB0; Latitud Sur y Cha&#xF1;aral, por fuera del &#xE1;rea de reserva artesanal, con arrastre, donde podr&#xE1; capturar el recurso hidrobiol&#xF3;gico Gamba Hymenopenaeus diomedae.</div><br></div>", "i": 7294124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de agosto de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7294125}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1810", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1810"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-08-27", "fecha_derogacion": "2014-03-14", "doble_articulado": false, "id_norma": "202490", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-09-13", "vigencias": [{"desde": "2014-03-14", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Ve