{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6300561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.854, de 18 de agosto de 2000,</div><div class=\"p\">de esta Subsecretar&#xED;a, autor&#xED;zase&nbsp; a&nbsp; ALIMENTOS MARINOS</div><div class=\"p\">S.A., para ampliar las actividades pesqueras extractivas</div><div class=\"p\">con la nave &apos;&apos;Don Mauro&apos;&apos;, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, en las &#xE1;reas y con el arte de pesca que se indica: litoral de la V a VII y IX Regi&#xF3;n, con cerco: Cojinoba del sur, Sardina espa&#xF1;ola; litoral de la X Regi&#xF3;n, con cerco: Bonito, Cojinoba del sur, Sardina com&#xFA;n, Sardina espa&#xF1;ola.</div><div class=\"p\">&nbsp; &nbsp;  Deni&#xE9;gase la autorizaci&#xF3;n solicitada por la peticionaria en el litoral y respecto de los recursos no incluidos en la presente resoluci&#xF3;n.</div><br></div>", "i": 6300562}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de agosto de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6300563}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1854", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1854"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-08-18", "fecha_derogacion": "2013-01-19", "doble_articulado": false, "id_norma": "175444", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-09-16", "vigencias": [{"desde": "2013-01-19", "hasta": "",