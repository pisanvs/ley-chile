{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8343065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 441, de 25 de marzo de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n 541 de 1995, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA DEL ESTRECHO S.A., para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Curaco&apos;&apos;, respecto de los recursos At&#xFA;n aleta azul, At&#xFA;n aleta larga, At&#xFA;n ojos grandes, At&#xFA;n mariposa, Azulejo, Cachurreta, Merlines, Marrajo o tibur&#xF3;n, Tibur&#xF3;n sardinero y Pejezorro, en las &#xE1;reas de pesca autorizadas en dicha resoluci&#xF3;n.</div><br></div>", "i": 8343066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de marzo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8343067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "441", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-441"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-25", "doble_articulado": false, "id_norma": "134356", "numero_fuente": "36329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-01", "vigencias": [{"desde": "1999-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi