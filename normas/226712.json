{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6484442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.537, de 4 de junio de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a MARIA ISABEL CORTES CORTES para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Las Industrias s/n, Barrio Industrial Norte, Caldera, III Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n de Cocido, Fresco-Enfriado, Fresco-Refrigerado, Congelado, Seco Salado, Ahumado, Alga Seca y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6484443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6484444}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1537 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1537 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-04", "doble_articulado": false, "id_norma": "226712", "numero_fuente": "37893", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-24", "vigencias": [{"desde": "2004-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend