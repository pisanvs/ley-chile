{"html": [{"t": "<div><div class=\"p\">AUTORIZA COMO EMISOR ELECTR&#xD3;NICO </div></div>", "i": 6658785}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 97, de 28 de agosto de 2008, que autoriza a contribuyente como emisor electr&#xF3;nico.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de documentos tributarios a contribuyente RUT 77.261.280-K, a contar del mes de agosto de 2008. En la Oficina Virtual del SII, en internet, se podr&#xE1;n consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2008.</div><br></div>", "i": 6658786}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "97 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-97 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA COMO EMISOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-08-28", "doble_articulado": false, "id_norma": "277361", "numero_fuente": "39153", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-09-02", "vigencias": [{"desde": "2008-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-09-02", "fin_vigencia": ""}, "vigencias_version_n