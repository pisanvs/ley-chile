{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9425889}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 45, de 03 de marzo de 2014, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1050661&amp;idParte=0&amp;idVersion=\">Decreto MOP. (Exento) N&#xBA;467, de 28 de marzo de 2013</a>, a fin de individualizar correctamente el lote de terreno N&#xBA;6, ubicado en la comuna de Punta Arenas, que figura a nombre de LEIVA TRONCOSO CECILIA DEL CARMEN, rol de aval&#xFA;o 5054-06, superficie 218 m2., complementando el informe de tasaci&#xF3;n referido al lote N&#xBA;6, emitido por la Comisi&#xF3;n de Peritos el 31 de julio de 2012, mediante acta emanada de la misma comisi&#xF3;n el 06 de julio de 2013, expropiado con motivo de la obra: &quot;Mejoramiento Ruta Y-565 Acceso R&#xED;o Seco, Km. 0,00000 al Km. 9,00000&quot;, Comuna de Punta Arenas, XII Regi&#xF3;n de Magallanes y la Ant&#xE1;rtica Chilena.</div></div>", "i": 9425890}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9425891}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "45 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-45 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-03-03", "doble_articulado": false, "id_norma": "1060690", "numero_fuente": "40822", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-04-01", "vigencias": [{"desde": "2014-04-01", "hasta": "", "tipo_version": "3