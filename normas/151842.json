{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6220937}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 304, de 29 de Julio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XIIa. Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a Carlos Ren&#xE9; Silva Puratic, para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbana de pasajeros.-</div><br></div>", "i": 6220938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Urbano Peralta, Secretario Regional Ministerial XIIa. Regi&#xF3;n.</div><br></div>", "i": 6220939}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "304 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-304 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-29", "doble_articulado": false, "id_norma": "151842", "numero_fuente": "32840", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-07", "vigencias": [{"desde": "1987-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen