{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8312299}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.278 de 26 de Octubre de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 1628, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a VITAMAR S.A., R.U.T.</div><div class=\"p\">No. 96.548.570-8, domiciliada en la ciudad de Santiago, para desarrollar actividades de cultivo, en orden a sustituir en su numeral 2&#xB0; la expresi&#xF3;n &quot;422.130 m2&quot; por &quot;375.577 m2&quot;. </div></div>", "i": 8312300}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 26 de Octubre de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8312301}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1278", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1278"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-26", "doble_articulado": false, "id_norma": "81390", "numero_fuente": "33824", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-11-21", "vigencias": [{"desde": "1990-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-11-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-11-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MNV", "fech