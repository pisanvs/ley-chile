{"html": [{"t": "<div><br><div class=\"p\">AMPL&#xCD;A PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA</div><br></div>", "i": 8955039}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n N&#xBA; 2.463, de fecha 28 de diciembre de 2009, Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, se resolvi&#xF3;:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- Ampl&#xED;ase por cuatro a&#xF1;os, a contar del 20 de abril de 2006, d&#xED;a siguiente de cumplido el primer a&#xF1;o desde la fecha de entrega material de la concesi&#xF3;n de acuicultura, el plazo para inicar actividades de acuicultura autorizadas mediante resoluci&#xF3;n 1.653, de fecha 20 de octubre de 2006, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina.</div><br></div>", "i": 8955040}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de julio de 2010.- Por el Sr. Subsecretario, Felipe Garc&#xED;a-Huidobro Correa, Subjefe (M).</div><br></div>", "i": 8955041}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2463", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2463"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "AMPLÍA PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-28", "doble_articulado": false, "id_norma": "1015802", "numero_fuente": "39724", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-31", "vigencias": [{"desde": "2010-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07-31", "fin_vigencia": ""},