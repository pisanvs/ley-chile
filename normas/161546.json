{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6252487}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 500, de 3 de marzo de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; PESQUERA LA PENINSULA S.A., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Loa 1&apos;&apos;, en el &#xE1;rea mar&#xED;tima de la I y II regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con red de cerco los recursos hidrobiol&#xF3;gicos: Jurel fino Decapterus spp., Sardina redonda Etrumeus teres y Vinciguerria Vinciguerria lucetia pacifis.</div><br></div>", "i": 6252488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de marzo de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 6252489}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "500", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-500"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA LA PENINSULA S.A.", "ACTIVIDADES PESQUERAS", "NAVE LOA 1", "RECURSOS HIDROBIOLOGICOS", "PESCA RED DE CERCO", "AUTORIZA AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-03-03", "fecha_derogacion": "2002-11-07", "doble_articulado": false, "id_norma": "161546", "numero_fuente": "36617", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-03-18", "vigencias": [{"desde": "2002-11-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-03-18", "hasta": "2002-11-06", "tipo_version": "0", "