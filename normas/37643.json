{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298801}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 2.017, de 2 de diciembre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura para un sector ubicado en Punta Cuello, Canal Queil&#xE9;n, Comuna de Queil&#xE9;n, Provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los art&#xED;culos 78&#xB0; y 87, de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0;, del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8298802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 2 de diciembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298803}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2017", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2017"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION DE ACUICULTURA", "QUEILEN", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-02", "doble_articulado": false, "id_norma": "37643", "numero_fuente": "35638", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-11", "vigencias": [{"desde": "1996-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-12-11", "fin_vigen