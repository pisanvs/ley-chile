{"html": [{"t": "<div><div class=\"p\">ESTABLECIMIENTOS PIADOSOS Y DE EDUCACION.</div><br><div class=\"p\">&nbsp; &nbsp;  72 Por cuanto el Congreso nacional con fecha 5 del presente ha sancionado lo siguiente:</div></div>", "i": 10246404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico. Los recursos que tuviesen necesidad de instaurar los administradores de cualquiera establecimiento piadoso o de educacion, se har&#xE1;n en papel comun, y ser&#xE1;n considerados en la secuela de ellos como de pobres.</div></div>", "i": 10246405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se cumpla, tome razon en las oficinas que corresponda y se publique insert&#xE1;ndose en el Boletin. Dado en la Sala de Gobierno en Santiago de Chile a 6 de diciembre de 1828.</div><br><div class=\"p\">&nbsp; &nbsp;  PINTO</div><div class=\"p\">&nbsp; &nbsp;  Ruiz Tagle.</div></div>", "i": 10246406}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ESTABLECIMIENTOS PIADOSOS Y DE EDUCACION.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-12-06", "doble_articulado": false, "id_norma": "1158870", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-12-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":