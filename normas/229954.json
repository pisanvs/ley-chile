{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CERTIFICADO</div><br></div>", "i": 6495664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 0,22% anual durante el mes de agosto de 2004.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de agosto de 2004, fue de 0,07% anual.</div><br><br></div>", "i": 6495665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago, 1 de septiembre de 2004.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6495666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-01", "doble_articulado": false, "id_norma": "229954", "numero_fuente": "37954", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-04", "vigencias": [{"desde": "2004-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-09-04", "fin_vigencia": "", "tipo_version": "3"}], "ev