{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6272031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 901, de 05.11.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Gerardo Herrera L&#xF3;pez y Luis Carvajal Ampuero para efectuar el servicio de taxi colectivo de la L&#xED;nea No. 20 &quot;Las Animas Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n No. 35, de 16 de Enero de 1986, y modificado por resoluci&#xF3;n No. 644, de 03.08.87, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6272032}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6272033}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "901 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-901 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-05", "doble_articulado": false, "id_norma": "167678", "numero_fuente": "32943", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-12", "vigencias": [{"desde": "1987-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-12", "fin_vigencia": "", "tipo_ve