{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 473 EXENTO, DE 1996 </div></div>", "i": 7161919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 473 de fecha 26 de agosto de 1996 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica CREP, las adecuaciones al plan y programas de estudios de la carrera de Programaci&#xF3;n de Computadores, modific&#xE1;ndose, en consecuencia, el Decreto Exento del Ministerio de Educaci&#xF3;n N&#xB0; 272 de 1990. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996.</div><br></div>", "i": 7161920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 13 de octubre de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161921}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "473 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-473 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 473 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "CENTRO DE", "FORMACION TECNICA CREP", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-10-13", "doble_articulado": false, "id_norma": "21317", "numero_fuente": "35595", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-10-21", "vigencias": [{"desde": "1996-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-10-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-10-21", "fin_vigencia": "", "tipo_version": "3"}], "event