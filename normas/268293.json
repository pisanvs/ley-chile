{"html": [{"t": "<div><div class=\"p\">ESTABLECE OBLIGACI&#xD3;N PARA SOCIEDADES Y COMUNIDADES QUE INDICAN </div></div>", "i": 6635963}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 4, del 7 de enero de 2008, que establece obligaci&#xF3;n para las sociedades y comunidades que se indican de informar al Servicio de Impuestos Internos sobre los Cr&#xE9;ditos y Pagos Previsionales Mensuales puestos a disposici&#xF3;n de los socios.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, se publicar&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2008.</div><br></div>", "i": 6635964}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE OBLIGACIÓN PARA SOCIEDADES Y COMUNIDADES QUE INDICAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-01-07", "doble_articulado": false, "id_norma": "268293", "numero_fuente": "38958", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-01-11", "vigencias": [{"desde": "2008-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-01-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []