{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6325641}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 8, de fecha 31 de enero del a&#xF1;o 2001, se autoriz&#xF3; la existencia y se aprobaron los estatutos de la Cooperativa de Trabajo San Juan, de nombre de fantas&#xED;a Cooperativa San Juan, de la comuna de Corral, D&#xE9;cima Regi&#xF3;n, en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica suscrita con fecha 14 de diciembre del a&#xF1;o 2000, ante el Notario de Valdivia don Conrado Z&#xFC;lch Herrmann, suplente de la titular, do&#xF1;a Carmen Podlech Michaud, bajo el repertorio 5570-2000. </div></div>", "i": 6325642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Cecilia Gonz&#xE1;lez Mart&#xED;nez, Jefe Departamento de Cooperativas (S). </div></div>", "i": 6325643}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-31", "doble_articulado": false, "id_norma": "182664", "numero_fuente": "36907", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-08", "vigencias": [{"desde": "2001-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-08", "fin_vigencia": "",