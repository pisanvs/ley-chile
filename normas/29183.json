{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LEY NUM. 17.647 ESTABLECE IMPUESTOS A PRIMERA TRANSFERENCIA DE VEHICULOS MOTORIZADOS</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8845432}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; DEROGADO<span class=\"n\" id=\"n_0\">DL 292, HACIENDA<br>Art. 29 N&#xBA; 2<br>D.O. 30.01.1974</span></div><br></div>", "i": 8845433, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticinco de Abril de mil novecientos setenta y dos.- SALVADOR ALLENDE GOSSENS.- Am&#xE9;rico Zorrilla R.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Patricio Morales Salinas, Subsecretario del Hacienda.</div><br></div>", "i": 8845434}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "1", "numero": "17647", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17647"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEY NUM. 17.647\nESTABLECE IMPUESTOS A PRIMERA TRANSFERENCIA DE\nVEHICULOS MOTORIZADOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VEHICULOS MOTORIZADOS", "DISTRIBUIDORES", "PRIMERA TRANSFERENCIA", "IMPUESTO", "PAGO", "IMPORTADORES", "DIRECCION DEPORTES RECREACION", "APORTE", "AUTOMOVILISMO DEPORTIVO", "FEDERACION CHILENA AUTOMOVILISMO DEPORTIVO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1972-04-25", "doble_articu