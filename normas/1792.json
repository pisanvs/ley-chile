{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Ministro de Fe de las actuaciones del Consejo y del Banco Central de Chile que suscribe, conforme lo dispone el N&#xB0; 6 del Art&#xED;culo 18 de la Ley N&#xB0; 18.840, certifica que de conformidad con lo establecido en el Cap&#xED;tulo III.F.5. del Compendio de Normas Financieras, la clasificaci&#xF3;n de riesgo de los estados soberanos y las entidades bancarias extranjeras que se indican a continuaci&#xF3;n es, para los efectos previstos en dicho Cap&#xED;tulo, la siguiente:</div><div class=\"p\">&nbsp; _____________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 34.902 DEL DIA JUEVES&nbsp;  |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  30 DE JUNIO DE 1994, PAGINA 2.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; |</div><div class=\"p\"> |_____________________________________________________|</div><br></div>", "i": 5845150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, junio 24 de 1994.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe.</div><br></div>", "i": 5845151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CLASIFICACION RIESGO", "ENTIDADES BANCARIAS EXTRANJERAS", "ESTADOS SOBERANOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-24", "doble_articulado": false, "id_norma": "1792", "numero_fuente": "34902", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-30", "vigenc