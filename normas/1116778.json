{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE INDICA</div></div>", "i": 9902843}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.085, de 28 de marzo de 2018, de esta Subsecretar&#xED;a, modif&#xED;case <a href=\"https://www.leychile.cl/Navegar?idNorma=1101582&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.131, de 2017</a>, modificada por resoluci&#xF3;n N&#xBA; 3.104, de 2017, ambas de esta Subsecretar&#xED;a, que estableci&#xF3; agrupaciones de concesiones de acuicultura de salm&#xF3;nidos en X, XI y XII Regi&#xF3;n, adecuando las agrupaciones de concesiones en la forma indicada en la resoluci&#xF3;n extractada y publicada &#xED;ntegramente en www.subpesca.cl y www.sernapesca.cl.</div></div>", "i": 9902844}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de marzo de 2018.- Eduardo Riquelme Portilla, Subsecretario de Pesca y Acuicultura.</div><br></div>", "i": 9902845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1085 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1085 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1376404", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-03-28", "doble_articulado": false, "id_norma": "1116778", "numero_fuente": "42024", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-04-05", "vigencias": [{"desde": "2018-04-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig