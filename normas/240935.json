{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 3.107 EXENTA, DE 2005 </div></div>", "i": 6535938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.107, de fecha 21 de julio de 2005, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se modifican resoluciones exentas N&#xBA;s. 632 y 633, ambas de 27 de julio de 2000, resoluci&#xF3;n exenta N&#xBA; 37, de 31 de enero de 2001, y resoluci&#xF3;n exenta N&#xBA; 159, de 16 de enero de 2002, todas de la misma Secretar&#xED;a Regional Ministerial, en el sentido de eliminar en la parte resolutiva de las mismas, la expresi&#xF3;n &quot;A1&quot;.</div><br></div>", "i": 6535939}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Silvio Albarr&#xE1;n Alb&#xE1;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6535940}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3107 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3107 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 3.107 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-21", "doble_articulado": false, "id_norma": "240935", "numero_fuente": "38235", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-12", "vigencias": [{"desde": "2005-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic