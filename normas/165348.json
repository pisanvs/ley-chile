{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION No. 125, DE 1981, DE LA SUBSECRETARIA DE PESCA </div></div>", "i": 6264405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 803, de 2 de Diciembre de 1985, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga a petici&#xF3;n de la Universidad del Norte, Sede Antofagasta, la Resoluci&#xF3;n No. 125, de 13 de Abril de 1981, de la misma Subsecretaria que la autoriz&#xF3; para operar la embarcaci&#xF3;n Stella Maris, en faenas extractivas de recursos hidrobiol&#xF3;gicos, en el litoral de la I a la IV Regi&#xF3;n. </div></div>", "i": 6264406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 02 de Diciembre de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6264407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "803", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-803"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION No. 125, DE 1981, DE LA SUBSECRETARIA\nDE PESCA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-02", "doble_articulado": false, "id_norma": "165348", "numero_fuente": "32343", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-10", "vigencias": [{"desde": "1985-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend