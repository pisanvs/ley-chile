{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6294618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.459 de fecha 31 de mayo del 2000, se expropi&#xF3; los lotes de terreno N&#xBA;s. 9, 18 y 19, superficie 3.854, 1.655 y 1.792 m&#xB2; respectivamente, rol de aval&#xFA;o 519-33 y 519-158, comuna de Carahue, para la obra &apos;&apos;Camino Costero Tir&#xFA;a-Carahue, Tramo Tir&#xFA;a-Bajo Yupehue, Km. 19.000,00 al Km. 23.413,36&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Pedro Enrique S&#xE1;ez D&#xED;az y Antonio Paill&#xE1;n Caniull&#xE1;n, ascendente a la cantidad de $754.875.- para el lote N&#xBA;9 y $8.648.041.- para los lotes N&#xBA;s. 18 y 19.</div><br></div>", "i": 6294619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6294620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2459", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2459"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-31", "doble_articulado": false, "id_norma": "173720", "numero_fuente": "36728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-01", "vigencias": [{"desde": "2000-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CA