{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA AMBIENTAL DE ANIMALES DOMESTICOS </div></div>", "i": 6400690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Av&#xED;sase a la comunidad que la Ilustre Municipalidad de Osorno con fecha 24 de septiembre de 2002, aprob&#xF3; la Ordenanza Ambiental de Animales Dom&#xE9;sticos, N&#xBA; 71, dictada con acuerdo de Concejo N&#xBA; 557, adoptado en sesi&#xF3;n ordinaria N&#xBA; 37, de fecha 24 de septiembre de 2002.</div><div class=\"p\">&nbsp; &nbsp;  Cualquier persona podr&#xE1; adquirir en la Oficina de Partes, un ejemplar de la Ordenanza indicada, pagando los correspondientes derechos municipales.</div><br></div>", "i": 6400691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Yamil Uarac Rojas, Secretario.</div><br></div>", "i": 6400692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "71", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-71"}], "organismos": ["MUNICIPALIDAD DE OSORNO"], "titulo_norma": "APRUEBA ORDENANZA AMBIENTAL DE ANIMALES DOMESTICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-09-24", "doble_articulado": false, "id_norma": "203869", "numero_fuente": "37391", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-24", "vigencias": [{"desde": "2002-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-10-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2002-10-24", "fecha_version": "2002-10-24", "fec