{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 189 EXENTO, DE 2003</div><br><br></div>", "i": 6421118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 189, de fecha 26 de marzo de 2003, de Educaci&#xF3;n, se autoriza el traslado del Instituto Profesional Instituto de Estudios Bancarios Guillermo Subercaseaux a su nuevo domicilio ubicado en Anwandter N&#xBA; 10, de la ciudad de Vi&#xF1;a del Mar, y elim&#xED;nase el domicilio anterior ubicado en calle Prat N&#xBA; 732, de Valpara&#xED;so.</div><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y reglamentarios.</div><br></div>", "i": 6421119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de abril de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6421120}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "189 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-189 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 189 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-26", "doble_articulado": false, "id_norma": "209450", "numero_fuente": "37538", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-04-17", "vigencias": [{"desde": "2003-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-04-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-04-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CN