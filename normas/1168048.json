{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10282907}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional de Ays&#xE9;n, por Res. Ex. N&#xB0; 1.060, de 1 octubre de 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos por Actividad Cultural y Social &quot;Primavera Fest 2021&quot; en Puerto Ays&#xE9;n, y autoriz&#xF3; a Direcci&#xF3;n de Desarrollo Comunitario de la I. Municipalidad de Ays&#xE9;n para realizar intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  -corte total de v&#xED;a en calle Esmeralda, entre calles Bernardo O&apos;Higgins y Arturo Prat, entre las 08:00 hrs. del d&#xED;a viernes 1 y las 11:59 hrs. del d&#xED;a s&#xE1;bado 2 de octubre de 2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10282908}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &#xD3;scar del Solar Navarrete, Gobernador Regional (S), Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10282909}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1060 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1060 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2038041", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-10-01", "doble_articulado": false, "id_norma": "1168048", "numero_fuente": "43099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-11-10", "vigencias": [{"desde":