{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 99, DE 1989 </div></div>", "i": 6099919}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 99 de 12 de mayo de 1989 se ha aprobado a la Escuela Especial E No. 13 de Copiap&#xF3;, III Regi&#xF3;n de Atacama, un plan de estudio especial de orientaci&#xF3;n laboral para alumnos discapacitados, que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de cuatro a&#xF1;os, a contar desde el a&#xF1;o escolar 1990. </div></div>", "i": 6099920}, {"t": "<div><div class=\"p\">- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6099921}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "99", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-99"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 99, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-12", "doble_articulado": false, "id_norma": "95414", "numero_fuente": "33404", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-22", "vigencias": [{"desde": "1989-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-03-13", "fecha_version": "1989-06-22", "fecha_actualizacion_texto": "1989-06-22", "tipo_