{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6659779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP N&#xBA; 682 de fecha 31 de julio del 2008, se expropi&#xF3; el lote de terreno N&#xBA; 45, superficie 3.020 m2, Rol N&#xBA; 172-6, comuna de Arauco, VIII Regi&#xF3;n para la obra &quot;Camino Ruta P-40, sector Arauco - Quiapo, Km. 0,00000 a Km. 15,96000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria IRMA LUISA GONZALEZ MU&#xD1;OZ Y OTRAS, ascendente a la cantidad de $2.597.658.- para el lote N&#xBA; 45. </div></div>", "i": 6659780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6659781}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "682 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-682 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-31", "doble_articulado": false, "id_norma": "277999", "numero_fuente": "39164", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-09-15", "vigencias": [{"desde": "2008-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2008-09-16", "fecha_version": "2008-09-15", "fecha_actualizacion_texto": "2008-09-15", "tipo_tratado": ""}, "alertas": [], "alert