{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.695</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo d&#xE9; este Banco Central de Chile en su Sesi&#xF3;n No. 1.695, celebrada el 11 de diciembre de 1985, adopt&#xF3; los siguientes acuerdos: </div></div>", "i": 6266234}, {"t": "<div><div class=\"p\">1695-19-851211- Modifica Cap&#xED;tulo IV.B.7 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar la cifra &quot;20&quot; establecida en el n&#xFA;mero 2 del Cap&#xED;tulo IV.B.7 &quot;Pagar&#xE9;s Reajustables del Banco Central de Chile&quot; del Compendio de Normas Financieras, por &quot;30&quot;.</div><br></div>", "i": 6266235}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de diciembre de 1985.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6266236}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "19", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-19"}, {"tipo": "5", "numero": "1965-19", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1965-19"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO\nCENTRAL DE CHILE EN SU SESION No. 1.695", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-04", "doble_articulado": false, "id_norma": "165957", "numero_fuente": "32346", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-13", "vigencias": [{"desde": "1985-12-13", "hasta": "", "tipo_version": "3", "tipo