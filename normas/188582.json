{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6346171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.065, de 29 de junio de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 1-A, superficie 14.158 m2., rol de aval&#xFA;o 3501-87, comuna de Quilpu&#xE9;, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar. Troncal Sur. Enlace Quilpu&#xE9; Oriente, Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Cooperativa de Viviendas y Servicios Habitacionales Sol del Pac&#xED;fico Limitada de Valpara&#xED;so, ascendente a la cantidad de $103.949.772.-.</div><br></div>", "i": 6346172}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6346173}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1065", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1065"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-06-29", "doble_articulado": false, "id_norma": "188582", "numero_fuente": "37038", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-16", "vigencias": [{"desde": "2001-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-08-16", "fecha_version"