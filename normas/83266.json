{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0;. 131, DE 1990 </div></div>", "i": 6064845}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 131 de 12 de abril de 1990 se ha autorizado al Liceo Industrial &quot;Vanguardia&quot; de Quinta Normal aplicar, durante los per&#xED;odos lectivos que se indican, los planes y programas de estudio aprobados por decreto supremo exento de Educaci&#xF3;n No. 162, de 1985.</div><div class=\"p\">Estos planes y programas se aplicar&#xE1;n en 3&#xB0;, 4&#xB0; y 5&#xB0; a&#xF1;o en el a&#xF1;o escolar 1990; en 4&#xB0; y 5&#xB0; a&#xF1;o en 1991 y, en 5&#xB0; a&#xF1;o en 1992.</div><br></div>", "i": 6064846}, {"t": "<div><div class=\"p\">Santiago, 27 de Abril de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6064847}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "131 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-131 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°. 131, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-12", "doble_articulado": false, "id_norma": "83266", "numero_fuente": "33662", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-05", "vigencias": [{"desde": "1990-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula