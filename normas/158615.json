{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 532, DE 1985</div><br><br></div>", "i": 8561571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 166 de 20 de Febrero de 1986 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n 532, de 28 de Agosto de 1985, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a Sociedad Industrial y Comercial Humboldt Limitada, para operar en calle Lautaro No. 099, de la Comuna de Los Vilos, una planta procesadora de recursos hidrobiol&#xF3;gicos en las l&#xED;neas de fresco, congelado y conservas, en orden a incluir en el numeral 3&#xB0;, entre las especies que dicha empresa puede emplear como materia prima en la elaboraci&#xF3;n de los productos se&#xF1;alados los siguientes: At&#xFA;n, albacora y camar&#xF3;n nailon.</div><br></div>", "i": 8561572}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de Febrero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 8561573}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "166", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-166"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 532, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-02-20", "fecha_derogacion": "1996-03-07", "doble_articulado": false, "id_norma": "158615", "numero_fuente": "32426", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-03-19", "vigencias": [{"desde": "1996-03-07", "hast