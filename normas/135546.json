{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,889.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165758}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Se declaran de utilidad p&#xFA;blica los terrenos necesarios para la via, estaciones i demas dependencias del ferrocarril de San Bernardo a San Jos&#xE9; de Maipo, en conformidad a los planos aprobados por el Consejo de Obras P&#xFA;blicas i el Ministerio del ramo. </div></div>", "i": 6165759}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a 5 de diciembre de 1906.- Pedro Montt.-</div><div class=\"p\">C&#xE1;rlos G. Avalos.</div><br></div>", "i": 6165760}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1889", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1889"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-12-05", "doble_articulado": false, "id_norma": "135546", "numero_fuente": "8671", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-12-10", "vigencias": [{"desde": "1906-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1906-12-10", "fin_vigencia": "", "tipo_ve