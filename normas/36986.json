{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOLICITA CONSTITUCION LEGAL DEL PARTIDO POR LA DEMOCRACIA, EN LA II REGION </div></div>", "i": 6016751}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jorge Schaulsohn Brodsky, Presidente del &quot;Partido por la Democracia&quot;, ha solicitado la constituci&#xF3;n legal del partido en la II Regi&#xF3;n de Antofagasta, acompa&#xF1;ando 1.227 fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0; 1.445, de fecha 27 de diciembre de 1995. </div></div>", "i": 6016752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de diciembre de 1995.- Andr&#xE9;s Merino Espi&#xF1;eira, Director Subrogante.</div><br></div>", "i": 6016753}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1445", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1445"}, {"tipo": "3", "numero": "0-1445", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-0-1445"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION LEGAL DEL PARTIDO POR LA\nDEMOCRACIA, EN LA II REGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONSTITUCION LEGAL", "PARTIDO POR LA DEMOCRACIA", "ANTOFAGASTA", "SEGUNDA REGION", "SOLICITUD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-27", "doble_articulado": false, "id_norma": "36986", "numero_fuente": "35359", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-01-06", "vigencias": [{"desde": "1996-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1