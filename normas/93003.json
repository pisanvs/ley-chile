{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 213, DE 1988</div><br><br></div>", "i": 6093069}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 213 de 30 de diciembre de 1988, se ha procedido a aprobar planes y programas especiales de estudio para 5&#xB0;, 6&#xB0;, 7&#xB0; y 8&#xB0; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica de la Escuela Subvencionada Particular No. 72 &quot;Los Solares&quot; de la Comuna de Lautaro, IX Regi&#xF3;n de La Araucan&#xED;a.</div><div class=\"p\">Los planes y programas aprobados se aplicar&#xE1;n a contar del a&#xF1;o escolar 1989, en todos los cursos indicados simult&#xE1;neamente.</div><br></div>", "i": 6093070}, {"t": "<div><div class=\"p\">Santiago 06 de Febrero de 1989.- Adelchi Colombo Breschi, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6093071}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "213 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-213 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 213, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-02-06", "doble_articulado": false, "id_norma": "93003", "numero_fuente": "33342", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-08", "vigencias": [{"desde": "1989-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-04-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie