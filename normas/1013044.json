{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8915754}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.476, de 28 de abril de 2010, de esta Subsecretar&#xED;a, rectif&#xED;quense los numerales 1.- y 11.- y el extracto de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1012556&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.333, de 2010</a>, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a PESCA CHILE S.A. para sustituir dos naves f&#xE1;bricas por la nave f&#xE1;brica &quot;Saint Pierre&quot;, en el sentido de se&#xF1;alar que el nombre de la segunda de las naves reemplazadas es &quot;Magallanes III&quot; y no como all&#xED; se indica.</div></div>", "i": 8915755}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de abril de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 8915756}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1476 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1476 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-04-28", "fecha_derogacion": "2012-01-19", "doble_articulado": false, "id_norma": "1013044", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2010-05-05", "vigencias": [{"desde": "2012-01-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2010-05-05", "hasta": "2012-01-18", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2012-01-19", "f