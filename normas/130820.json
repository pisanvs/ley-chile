{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO No. 129, DE 1988 </div></div>", "i": 6151188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por DS exento de Educaci&#xF3;n No. 129 de 20.07.88 se ha aprobado para el Liceo Municipal de San Ram&#xF3;n (Ex - Escuela D No. 535), Regi&#xF3;n Metropolitana, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar de 1989 y hasta el a&#xF1;o escolar de 1992, en las Ramas y Especialidades que se indican:</div><br><div class=\"p\">Rama: Industrial.</div><div class=\"p\">Especialidades: * Electricidad Industrial.</div><div class=\"p\">* Instalaciones Sanitarias.</div><div class=\"p\">Rama: T&#xE9;cnica.</div><div class=\"p\">Especialidad: Sastrer&#xED;a Var&#xF3;n </div></div>", "i": 6151189}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26.08.88.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6151190}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "129 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-129 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 129, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-07-20", "doble_articulado": false, "id_norma": "130820", "numero_fuente": "33164", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-05", "vigencias": [{"desde": "1988-09-05", "hasta": "", "tipo_version": "3", "tipo_v