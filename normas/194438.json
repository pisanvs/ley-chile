{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 16.279 EXENTA, DE 2001 </div><br></div>", "i": 6368540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 16.279 de 28 de diciembre del a&#xF1;o 2001, se ha aprobado al Liceo Experimental Art&#xED;stico de Santiago, comuna y provincia de Santiago, administrado por la Corporaci&#xF3;n Educacional de Desarrollo Art&#xED;stico, planes de estudio de las especialidades que se se&#xF1;alan en la presente resoluci&#xF3;n, los que ser&#xE1;n aplicados en 4&#xBA; a&#xF1;o medio t&#xE9;cnico - profesional, a contar del a&#xF1;o escolar 2002.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6368541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6368542}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16279 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-16279 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 16.279 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-28", "doble_articulado": false, "id_norma": "194438", "numero_fuente": "37180", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-07", "vigencias": [{"desde": "2002-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici