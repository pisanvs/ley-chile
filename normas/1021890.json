{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div></div>", "i": 9096259}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as fue de 3,56% anual durante el mes de diciembre de 2010.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, de conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de diciembre de 2010, fue de 3,93% anual.</div></div>", "i": 9096260}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de enero de 2011.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9096261}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-06", "doble_articulado": false, "id_norma": "1021890", "numero_fuente": "39854", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-08", "vigencias": [{"desde": "2011-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-01-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-01-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":