{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 627, de 2 de mayo de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a MARIO ALBERTO GALLARDO GAYTAN, en orden a instalar y operar una planta ubicada en Playa Caramucho, Iquique, I Regi&#xF3;n, donde podr&#xE1; procesar, en la l&#xED;nea de elaboraci&#xF3;n de Secado natural y Molienda de Algas, los siguientes recursos hidrobiol&#xF3;gicos: Chasc&#xF3;n y Huiro.</div><div class=\"p\">&nbsp; &nbsp;  La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales y reglamentarias vigentes o que se establezcan.</div><br></div>", "i": 8303116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de mayo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "627", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-627"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "MARIO ALBERTO GALLARDO GAYTAN", "IQUIQUE", "PRIMERA REGION", "PLANTA DE PROCESAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-05-02", "doble_articulado": false, "id_norma": "71486", "numero_fuente": "35770", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-20", "vigencias": [{"desde": "1997-05-20", "hasta": "", "tipo_version": "3", "tipo_ver