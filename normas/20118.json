{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 92, DE 1994 </div><br><br><br></div>", "i": 5940983}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 92 de fecha 4 de marzo de 1994 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica &quot;Chileno Brit&#xE1;nico de Cultura&quot; el plan y programa de estudio de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en la Casa Central de Vi&#xF1;a del Mar y Sede N&#xB0; 3 de Quillota, a contar de agosto de 1993:</div><div class=\"p\">&nbsp; &nbsp; Carrera: Secretariado Ejecutivo con conocimientos en Aplicaciones Computacionales.</div><div class=\"p\">&nbsp; &nbsp; T&#xED;tulo: Secretario (a) Ejecutivo (a) con conocimientos en Aplicaciones Computacionales. </div></div>", "i": 5940984}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5940985}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "92 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-92 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 92, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA CHILENO BRITANICO CULTURA", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "SECRETARIADO", "EJECUTIVO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-03-04", "fecha_derogacion": "2001-05-29", "doble_articulado": false, "id_norma": "20118", "numero_fuente": "34865", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-05-14", "vigencias": [{"de