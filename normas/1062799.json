{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO&nbsp; N&#xBA; 1 EXENTO, DE 2014</div></div>", "i": 9476639}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante decreto exento N&#xBA; 357, de 8 de mayo de 2014, del Ministerio de Bienes Nacionales, se autoriz&#xF3; la modificaci&#xF3;n del <a href=\"https://www.leychile.cl/Navegar?idNorma=1059217&amp;idParte=&amp;idVersion=\">decreto exento N&#xBA; 1, de 2 de enero de 2014</a>, que otorg&#xF3; la Concesi&#xF3;n Onerosa directa por un plazo de 30 a&#xF1;os, a la sociedad Almeyda Solar SpA, en la comuna de Diego de Almagro, provincia de Cha&#xF1;aral, Regi&#xF3;n de Atacama, en el sentido de otorgar un nuevo plazo de 30 d&#xED;as h&#xE1;biles, para la suscripci&#xF3;n del contrato de concesi&#xF3;n, a contar de la fecha de publicaci&#xF3;n del presente extracto. Los decretos mencionados con sus textos &#xED;ntegros se encuentran disponibles en el sitio web del Ministerio de Bienes Nacionales.</div></div>", "i": 9476640}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Autoriza extracto.- Nivia Palma Manr&#xED;quez, Jefa de Divisi&#xF3;n Jur&#xED;dica.</div></div>", "i": 9476641}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "357 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-357 EXENTO"}], "organismos": ["MINISTERIO DE BIENES NACIONALES"], "titulo_norma": "MODIFICA DECRETO Nº 1 EXENTO, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-05-08", "doble_articulado": false, "id_norma": "1062799", "numero_fuente": "40868", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "