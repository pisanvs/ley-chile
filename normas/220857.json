{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 22 EXENTA, DE 2004 </div></div>", "i": 6462260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 22 del 29 de enero de 2004, que dispone presentaci&#xF3;n de Declaraciones Juradas, Formularios 1811, 1812, 1823, 1850, 1879, 1884, 1885 y 1887 que indica mediante transmisi&#xF3;n electr&#xF3;nica de datos, establece procedimiento alternativo que indica y deroga resoluci&#xF3;n Ex. N&#xBA; 78 del 23.12.2003.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio Web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el bolet&#xED;n del SII en enero, de 2004.</div><br></div>", "i": 6462261}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "22 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-22 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 22 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "DECLARACION JURADA", "TRANSMISION ELECTRONICA DE DATOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-29", "doble_articulado": false, "id_norma": "220857", "numero_fuente": "37777", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-04", "vigencias": [{"desde": "2004-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci