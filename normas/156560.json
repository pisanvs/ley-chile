{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 16, DE 1985 </div></div>", "i": 7261882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 102, 06 de Febrero de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 16, de 09 de Enero de 1985, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a Sociedad Armadores Alfa Limitada para operar una embarcaci&#xF3;n en construcci&#xF3;n, en orden a incluir en el numeral 5&#xB0;, entre las especies que la Sociedad podra extraer con la embarcaci&#xF3;n, los recursos bonito, cojinova y dorado, que debera destinar a su industrializaci&#xF3;n para consumo humano. La embarcaci&#xF3;n debera contar con sistemas adecuados de preservaci&#xF3;n de la materia prima.</div><br></div>", "i": 7261883}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 06 de Febrero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7261884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "102", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-102"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 16, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-06", "doble_articulado": false, "id_norma": "156560", "numero_fuente": "32412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-03", "vigencias": [{"desde": "1986-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia