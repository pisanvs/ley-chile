{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 276 EXENTO, DE 1995 </div></div>", "i": 7161456}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 276 de fecha 2 de mayo de 1995 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica INACAP, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en todas las sedes que contaban con su aprobaci&#xF3;n, a contar del a&#xF1;o 1994, con la siguiente denominaci&#xF3;n:</div><div class=\"p\"> Carrera : Electr&#xF3;nica; cambia por:</div><div class=\"p\"> Carrera : Electr&#xF3;nica Industrial</div><div class=\"p\"> T&#xED;tulo&nbsp; : T&#xE9;cnico en Electr&#xF3;nica Industrial. </div></div>", "i": 7161457}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161458}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "276", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-276"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 276 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INACAP", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-02", "doble_articulado": false, "id_norma": "20869", "numero_fuente": "35201", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-24", "vigencias": [{"desde": "1995-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "