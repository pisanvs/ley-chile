{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xB0; 1.575 EXENTA, DE 2020, DEL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES</div></div>", "i": 10149763}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.575, de 10 de agosto de 2020, se modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1147025&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.243, de 24 de junio de 2020</a>, del Ministerio de Transportes y Telecomunicaciones, que implementa rebaja tarifaria para el adulto mayor en servicios de transporte p&#xFA;blico remunerado de pasajeros, establecida en la Ley N&#xB0; 21.192, aprueba metodolog&#xED;a para ello y deja sin efecto resoluci&#xF3;n que indica. Texto &#xED;ntegro de la resoluci&#xF3;n exenta de modificaci&#xF3;n referida, estar&#xE1; disponible para ser consultada en la p&#xE1;gina web http://www.dtpr.gob.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10149764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Luis Dom&#xED;nguez Covarrubias, Ministro de Transportes y Telecomunicaciones (S).</div><div class=\"p\"> </div><br></div>", "i": 10149765}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1575 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1575 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO RESOLUCIÓN N° 1.575 EXENTA, DE 2020, DEL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1800083", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-24", "doble_artic