{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;AMELIA BARAHONA DE MUJICA&quot; A ESCUELA QUE SE&#xD1;ALA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente:</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5982919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Denom&#xED;nase a la Escuela N.&#xB0; 21, de Gualliguaica, del departamento de Elqui, con el nombre de &quot;Amelia Barahona de M&#xFA;jica.</div><br></div>", "i": 5982920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, trece de Octubre de mil novecientos setenta y dos.- SALVADOR ALLENDE GOSSENS.- An&#xED;bal Palma Fourcade, Ministro de Educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Waldo Su&#xE1;rez Zambont, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5982921}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17788", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17788"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DENOMINA \"AMELIA BARAHONA DE MUJICA\" A ESCUELA QUE\nSEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "ELQUI", "GUALLIHUAICA", "ESCUELA AMELIA BARAHONA MUJICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1972-10-13", "doble_articulado": false, "id_norma": "29281", "numero_fuente": "28384", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1972-10-23", "vigencia