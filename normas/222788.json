{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 2.096 EXENTA, DE 2004 </div></div>", "i": 6470264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xBA; 2096 de 30 de enero de 2004, complem&#xE9;ntase por el a&#xF1;o escolar 2003 la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 14.117, de 2002, que aprob&#xF3; planes y programas especiales de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Colegio del Sagrado Coraz&#xF3;n, Apoquindo, de la comuna de Las Condes, de Santiago, en el sentido de agregar el siguiente plan de Formaci&#xF3;n Diferenciada al plan de estudio de 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media.</div><br></div>", "i": 6470265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de febrero de 2004.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6470266}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2096 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2096 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 2.096 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-30", "doble_articulado": false, "id_norma": "222788", "numero_fuente": "37817", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-22", "vigencias": [{"desde": "2004-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-22", "fin_vigencia": "", "tipo_version": "3