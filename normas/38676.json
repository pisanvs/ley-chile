{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 857 EXENTA DE 1991 N&#xFA;m. 262 exenta.- Valpara&#xED;so, 3 de Febrero de 1993.- Visto: Lo dispuesto en el Art. N&#xB0; 28 del D.F.L. N&#xB0; 5, de 1983; el Art. N&#xB0; 19, letra c) del decreto N&#xB0; 175, de 1989, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, la resoluci&#xF3;n exenta N&#xB0; 857, de 1991, del Servicio Nacional de Pesca.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 8299398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1&#xB0;.- Modif&#xED;case el numeral 8&#xB0; de la resoluci&#xF3;n exenta N&#xB0; 857, de 1991, del Servicio Nacional de Pesca, en el sentido de sustituirse por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;8.- La transgresi&#xF3;n a lo dispuesto en la presente resoluci&#xF3;n, ser&#xE1; sancionada conforme a lo dispuesto en el D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.&quot; </div></div>", "i": 8299399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Ren&#xE9; Maturana Contreras, Director Nacional de Pesca (S).</div><br></div>", "i": 8299400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "262 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-262 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA", "SERVICIO NACIONAL DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 857 EXENTA DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NAVE PESQUERA", "AGUAS EXTRA JURISDICCIONALES", "REQUISITOS", "ANTECEDENTES", "DOCUMENTOS", "AUTORIZACION", "PESCA", "SANCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacio