{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xB0; 1.336 EXENTO, DE 2012</div></div>", "i": 9361288}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xB0; 579, de 19 de junio de 2013, de este Ministerio, modif&#xED;case la letra a) del art&#xED;culo 2&#xB0; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1047817&amp;idParte=&amp;idVersion=\">decreto exento N&#xB0; 1.336 de 2012</a>, modificado mediante los decretos exentos N&#xB0; 195 y N&#xB0; 427, ambos de 2013, todos del Ministerio de Econom&#xED;a, Fomento y Turismo, en el sentido de reemplazar la tabla ah&#xED; indicada por la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/33391.jpg\"> </div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9361289}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de junio de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9361290}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "579 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-579 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO N° 1.336 EXENTO, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-06-19", "doble_articulado": false, "id_norma": "1052187", "numero_fuente": "40593", "tipo_versio