{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6512405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.676, de 28 de diciembre</div><div class=\"p\">de 2004, de esta Subsecretar&#xED;a, ampl&#xED;ase por 11 meses</div><div class=\"p\">respecto del recurso Alfonsino y por 6 meses respecto</div><div class=\"p\">del recurso Besugo, a contar del 23 de agosto de 2004,</div><div class=\"p\">el plazo otorgado a PESQUERA SAN JOSE S.A., para iniciar</div><div class=\"p\">actividades pesqueras extractivas con la nave</div><div class=\"p\">&quot;Alejandr&#xED;a I&quot;, respecto de cada uno de los recursos</div><div class=\"p\">reci&#xE9;n indicados, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, en el &#xE1;rea mar&#xED;tima correspondiente a la Isla de Pascua, Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Islas Sala y G&#xF3;mez e Islas Desventuradas, con arrastre y palangre, en virtud de haberse acreditado la circunstancia de fuerza mayor invocada por la peticionaria.</div><br></div>", "i": 6512406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6512407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3676 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3676 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-28", "doble_articulado": false, "id_norma": "234442", "numero_fuente": "38054", "tipo_version"