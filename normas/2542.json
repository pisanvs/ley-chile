{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE EXPROPIACIONES PARCIALES QUE SE&#xD1;ALA </div></div>", "i": 5853080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Decreto 600, 26 abril 1996, Alcalde Municipalidad Puc&#xF3;n, dispone expropiaci&#xF3;n parcial conforme D.F.L. 458 de 1976, Ley 18.695 y D.L. 2.186 de 1978, inmueble dominio aparente de Luis Alberto Colipe Aburto, inscrito fojas 924 vta. N&#xB0; 772 Registro Propiedad Puc&#xF3;n 1995, Rol 114-8, superficie aproximada 1.638 m2. Deslindes: Norte: en 78 metros con el mismo propietario; Sur: el mismo propietario en 78 metros; Oriente: en 21 metros con propiedad de Rafael Aburto Paillalef; Poniente: en 21 metros con faja camino internacional alternativo. Indemnizaci&#xF3;n provisional $3.112.200.- Pagadera contado. </div></div>", "i": 5853081}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Carlos Barra Matamala, Alcalde de Puc&#xF3;n. </div></div>", "i": 5853082}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "600", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-600"}], "organismos": ["MUNICIPALIDAD DE PUCÓN"], "titulo_norma": "DISPONE EXPROPIACIONES PARCIALES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "PUCON", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-26", "doble_articulado": false, "id_norma": "2542", "numero_fuente": "35481-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-06-01", "vigencias": [{"desde": "1996-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "