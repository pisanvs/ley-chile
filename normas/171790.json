{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6285134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.668, de 28 de abril del 2000, se expropi&#xF3; el lote de terreno N&#xBA; 4-A, superficie 992 m&#xB2;, rol de aval&#xFA;o en tr&#xE1;mite, comuna de Constituci&#xF3;n, para la obra Camino M-24-K Quivolgo - Puente Lautaro, Sector C, Putu - Quivolgo, Km. 30.000 a Km. 49.815,494 y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietario Juan Mario Urbina Urbina, ascendente a la cantidad de $1.688.370 para el lote N&#xBA; 4-A.</div><br></div>", "i": 6285135}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6285136}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1668", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1668"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "171790", "numero_fuente": "36702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-01", "vigencias": [{"desde": "2000-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-07-03", "fecha_version": "2000-07-01", "fecha_actualizacion_texto": "2000-07-01", "tipo_tratado": ""}, "alertas": [], "alerta_glo