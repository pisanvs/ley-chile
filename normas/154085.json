{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6227845}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 452, del 14 de Agosto de 1986 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n, se autoriza al Sr. Arnaldo Iturriaga Cuevas, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del Territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br><br></div>", "i": 6227846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6227847}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "452 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-452 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-14", "doble_articulado": false, "id_norma": "154085", "numero_fuente": "32559", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-28", "vigencias": [{"desde": "1986-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-08-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu