{"html": [{"t": "<div><div class=\"p\">FIJA ANTIGUEDAD MAXIMA PARA INGRESO&nbsp; DE&nbsp; BUSES&nbsp; A</div><div class=\"p\">SERVICIOS&nbsp; URBANOS&nbsp; DE LOCOMOCION COLECTIVA EN OVALLE</div><br><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 154 exenta.- La Serena, 6 de septiembre de 2000.- Visto: El art&#xED;culo 1&#xBA; del D.S. N&#xBA; 1 de 1994, del MTT, Subsecretar&#xED;a de Transportes; la carta de fecha 17/08/2000 de la Asociaci&#xF3;n Gremial de Transporte de Pasajeros Urbanos de Ovalle y; el informe t&#xE9;cnico que se adjunta:</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6304292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Establ&#xE9;cese a contar del 15 de octubre de 2000, en 12 <span class=\"n\" id=\"n_0\"><a href=\"navegar?idNorma=1053568&amp;idParte=9370032&amp;idVersion=2013-08-13\">Resoluci&#xF3;n 290 EXENTA,<br>TRANSPORTES<br>D.O. 13.08.2013</a></span>a&#xF1;os la antig&#xFC;edad m&#xE1;xima que deber&#xE1;n tener los buses para incorporarse a los servicios de locomoci&#xF3;n colectiva urbana en la ciudad de Ovalle.</div><br><br></div>", "i": 6304293, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese.- Claudio M&#xE9;ndez Olave, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6304294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "154 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-154 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "FIJA ANTIGUEDAD MAXIMA PARA INGRESO DE BUSES A SERVICIOS URBANOS DE LOCOMOCION COLECTIVA EN OVALLE", "fuente": "Diario Oficial", "resumenes": [], "mat