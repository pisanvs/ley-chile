{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION&nbsp; N&#xBA; 835&nbsp; EXENTA, DE 2001</div><br></div>", "i": 6322212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 835 de 7 de febrero del a&#xF1;o 2001, se ha aprobado al Colegio Sagrados Corazones del Arzobispado de Santiago, un plan de estudio para&nbsp; 3er. a&#xF1;o de ense&#xF1;anza media human&#xED;stico-cient&#xED;fica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores de &apos;&apos;Teor&#xED;a y Pr&#xE1;ctica de la Comunicaci&#xF3;n&apos;&apos; y de &apos;&apos;Desarrollo del Pensamiento Occidental&apos;&apos;, que se se&#xF1;alan en la presente resoluci&#xF3;n.</div><br></div>", "i": 6322213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de febrero de 2001.- Javier San Miguel Beltr&#xE1;n, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 6322214}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "835 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-835 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 835 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-07", "doble_articulado": false, "id_norma": "181732", "numero_fuente": "36888", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-14", "vigencias": [{"desde": "2001-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-14", "fin_vig