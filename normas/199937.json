{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 72 EXENTO, DE 2002 </div></div>", "i": 6387272}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 25, de fecha 25 de enero de 2002, del Ministerio de Educaci&#xF3;n, se autoriza a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura Cidec, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 2002:</div><br><div class=\"p\">Sede N&#xBA; 2-La Serena</div><br><br><div class=\"p\">Carrera&nbsp; : Topograf&#xED;a</div><div class=\"p\">T&#xED;tulo&nbsp;  : T&#xE9;cnico de Nivel Superior en Topograf&#xED;a</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Decreto exento N&#xBA; 423 del 10.12.99)</div><br></div>", "i": 6387273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de abril de 2002.- Patricio Vilaplana Barberis, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6387274}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "25 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-25 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 72 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-25", "doble_articulado": false, "id_norma": "199937", "numero_fuente": "37297", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-02", "vigencias": [{"desde": "2002-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen