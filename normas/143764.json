{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION&nbsp; N&#xBA; 788E </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 788E, celebrada el 16 de septiembre de 1999, adopt&#xF3; el siguiente Acuerdo:</div><br><br></div>", "i": 6192267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  788E-01-990916 - Modifica Cap&#xED;tulo III.F.4 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el Cap&#xED;tulo III.F.4 del Compendio de Normas Financieras, reemplazando en la letra a) del N&#xBA; 1 del T&#xED;tulo II, el guarismo &apos;&apos;0,7&apos;&apos; por &apos;&apos;1,0&apos;&apos;.</div><br></div>", "i": 6192268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de septiembre de 1999.-&nbsp; Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6192269}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "788", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-788"}, {"tipo": "5", "numero": "788-E-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-788-E-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 788E", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-16", "doble_articulado": false, "id_norma": "143764", "numero_fuente": "36470", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-22", "vigencias": [{"desde": "1999-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-22", "fin_vigencia": ""}, "v