{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6203025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1, de fecha 02 de Enero de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a do&#xF1;a Sandra Marta Stoicheff Herdoscio para efectuar todo tipo de servicios de transporte de pasajeros por callas y caminas, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6203026}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 09.01.86.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6203027}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-02", "doble_articulado": false, "id_norma": "147064", "numero_fuente": "32753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-23", "vigencias": [{"desde": "1987-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-23", "fin_vigencia": "", "tipo_version"