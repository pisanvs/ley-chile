{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6522214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 715, de 16 de marzo de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SINDICATO DE TRABAJADORES INDEPENDIENTES DE LA PESCA ARTESANAL, BUZOS MARISCADORES Y ACTIVIDADES CONEXAS CALETA CERRO VERDE, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en calle El Faro, pasaje N&#xBA; 2 s/n, Cerro Verde Bajo, comuna de Penco, VIII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Cocido, Fresco-enfriado, Fresco-refrigerado, Conserva, Alga seca y Alga fresca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 3.534 de 2003, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6522215}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de marzo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6522216}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "715 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-715 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-16", "doble_articulado": false, "id_norma": "237117", "numero_fuente": "38137", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-16", "vigencias": [{"desde": "2005-04-16", "hasta": "", "t