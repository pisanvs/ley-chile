{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6565226}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 832, de 10 de marzo de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.997, de 2003, modificada por resoluci&#xF3;n N&#xBA; 3.641, de 2004, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA SAN JOSE S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Don Tel&#xE9;sforo&quot; sobre el recurso Alfonsino, en el &#xE1;rea mar&#xED;tima correspondiente a la Isla de Pascua, Islas Sala y G&#xF3;mez, Islas Desventuradas y Archipi&#xE9;lago de Juan Fern&#xE1;ndez, con arrastre y palangre, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y los dem&#xE1;s antecedentes citados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6565227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de marzo de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6565228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "832 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-832 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-10", "doble_articulado": false, "id_norma": "248387", "numero_fuente": "38423", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-25", "vigencias": [{"desde": "2006-03-25", "hasta": "", "tipo_version": "3"