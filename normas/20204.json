{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 109 EXENTO, DE 1995 </div></div>", "i": 7160566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 109 de 1&#xB0;</div><div class=\"p\">de Febrero de 1995, se ha modificado el decreto supremo</div><div class=\"p\">exento de Educaci&#xF3;n N&#xB0; 51 de 1994, que aprob&#xF3; plan</div><div class=\"p\">especial de estudio al Liceo &quot;Carmela Carvajal de Prat&quot;,</div><div class=\"p\">de la comuna de Providencia, Regi&#xF3;n Metropolitana, en el</div><div class=\"p\">sentido de sustituir el plan de estudio aprobado en su</div><div class=\"p\">art&#xED;culo 1&#xB0;, por el que se indica en el presente decreto.</div><br><br></div>", "i": 7160567, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de Febrero de 1995.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 7160568}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "109 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-109 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 109 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO CARMELA CARVAJAL PRAT", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-01", "doble_articulado": false, "id_norma": "20204", "numero_fuente": "35096", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-02-17", "vigencias": [{"desde": "1995-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v