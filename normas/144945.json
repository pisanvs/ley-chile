{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6195945}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta No. 417, de 04.03.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n, se autoriza a don H&#xE9;ctor Homero Retamal Miranda de la Asociaci&#xF3;n de Buses Interb&#xFA;s, para efectuar todo tipo de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6195946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regional del Maule. </div></div>", "i": 6195947}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "417 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-417 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-04", "doble_articulado": false, "id_norma": "144945", "numero_fuente": "32724", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-17", "vigencias": [{"desde": "1987-03-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-03-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen