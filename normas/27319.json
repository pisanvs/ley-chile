{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REEMPLAZA EN EL ITEM QUE INDICA LA GLOSA QUE SE&#xD1;ALA Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5972360}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase en el &#xED;tem 12/01/07 &quot;Cuotas fiscales a fondos y servicios especiales&quot;, letra e) del Presupuesto vigente, la glosa: &quot;Cruz Roja de Traigu&#xE9;n, $ 3.500.000&quot;, por la siguiente: &quot;Aporte a la Cruz Roja de Traigu&#xE9;n para compra de un edificio, $ 3.500.000.&quot;.&quot; </div></div>", "i": 5972361}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a dos de Septiembre de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Eduardo Urz&#xFA;a M.</div><br></div>", "i": 5972362}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12977", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12977"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "REEMPLAZA EN EL ITEM QUE INDICA LA GLOSA QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O 1958", "MODIFICA", "CRUZ ROJA", "TRAIGUEN", "EDIFICIO", "ADQUISICION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-09-02", "doble_articulado": false, "id_norma": "27319", "numero_fuente": "24147", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-09-16", "vigencias": [{"desde": "1958-09-16", "hasta":