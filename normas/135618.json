{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,616.- Santiago, 30 de setiembre de 1903.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6166013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais durante la guerra de la independencia por el coronel don Domingo de Torres, conc&#xE9;dese a sus nietas do&#xF1;a Cristobalina i do&#xF1;a Rosa Amelia Torres Labarca derecho a disfrutar de la pension de montep&#xED;o correspondiente al empleo de coronel.</div><br></div>", "i": 6166014}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- C&#xE1;rlos Besa.</div><br></div>", "i": 6166015}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1616", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1616"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-09-30", "doble_articulado": false, "id_norma": "135618", "numero_fuente": "7718", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-10-03", "vigencias": [{"desde": "1903-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-10-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1903-10-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in