{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EN LA FORMA QUE INDICA LA LEY 10,043 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zanse en el art&#xED;culo 1.o de la ley N.o 10,043, en su inciso tercero la cifra &quot;10 o&#xF3;&quot; por &quot;12%&quot; y en su inciso cuarto la cifra &quot;8 o&#xF3;&quot; por &quot;10 o&#xF3;&quot;, </div></div>", "i": 8278972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a trece de Agosto de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- C. Torres H. </div></div>", "i": 8278973}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10401", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10401"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA EN LA FORMA QUE INDICA LA LEY 10,043", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 10.043"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-08-13", "doble_articulado": false, "id_norma": "26396", "numero_fuente": "22348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-09-11", "vigencias": [{"desde": "1952-09-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-09-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1952-09-11", "fin_vigencia": "", "tipo_