{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION No. 1.738, DE 1988 </div></div>", "i": 6134389}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.738 de 11 de Octubre de 1988, de este Servicio Nacional, se revoc&#xF3; la autorizaci&#xF3;n otorgada a la Sociedad de Capacitaci&#xF3;n Empresarial Limitada, para actuar como organismo t&#xE9;cnico de ejecuci&#xF3;n al amparo del decreto ley 1.446, de 1976, y su Reglamento. Santiago, 14 de Octubre de 1988.- </div></div>", "i": 6134390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco L&#xF3;pez Villanueva, Jefe Depto. Administrativo y Secretar&#xED;a General.</div><br></div>", "i": 6134391}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1738", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1738"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARIA DE PREVISION SOCIAL", "SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION No. 1.738, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-10-11", "doble_articulado": false, "id_norma": "125692", "numero_fuente": "33203", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-10-24", "vigencias": [{"desde": "1988-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-10-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "1998-10-08", "fecha_version": "1988-10-24", "fecha_actu