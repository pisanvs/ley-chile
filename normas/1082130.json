{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE SE&#xD1;ALA</div></div>", "i": 9638488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.443, de 4 de septiembre de 2015, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; inciso 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1080922&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.193 de 2015</a>, que autoriz&#xF3; a Gonz&#xE1;lez, Koper y Mart&#xED;nez Limitada, para continuar desarrollando actividades pesqueras extractivas con la nave &quot;Maori&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 24&#xBA; L.S. y la VIII Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar, con arrastre, el recurso hidrobiol&#xF3;gico Jibia, en el sentido de se&#xF1;alar que la nave tendr&#xE1; plazo para comenzar operar hasta el mes de abril de 2016.</div></div>", "i": 9638489}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de septiembre de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9638490}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2443 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2443 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2015-09-04", "fecha_derogacion": "2023-01-18", "doble_articulado": false, "id_norma": "1082130", "numero_fuen