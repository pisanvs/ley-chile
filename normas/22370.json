{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Instituto Aleman de la Union Lei n&#xFA;m. 1,044.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese al Instituto Aleman de la Union el permiso requerido por el art. 556 del C&#xF3;digo Civil para conservar, durante treinta a&#xF1;os, la propiedad del bien raiz que posee en dicha ciudad.</div><br><br></div>", "i": 7162847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 5 de Julio de 1898.- FEDERICO ERRAZURIZ.- C&#xE1;rlos A. Palacios Z.</div><br></div>", "i": 7162848}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1044", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1044"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "INSTITUTO ALEMÁN DE LA UNIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO ALEMAN", "LA UNION", "BIEN RAIZ", "POSESION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-07-05", "doble_articulado": false, "id_norma": "22370", "numero_fuente": "6042", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-07-06", "vigencias": [{"desde": "1898-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-07-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-07-06