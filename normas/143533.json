{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8350203}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.643, de 31 de agosto de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a ADOLFO DEL CARMEN MICHEA MICHEA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en sector La Pi&#xF1;a, comuna de Caldera, provincia de Copiap&#xF3;, III Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas que se indican los siguientes recursos hidrobiol&#xF3;gicos: Secado y Picado: Cochayuyo, Chasc&#xF3;n, Huiro y Pelillo.</div><br></div>", "i": 8350204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de agosto de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8350205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1643", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1643"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-31", "doble_articulado": false, "id_norma": "143533", "numero_fuente": "36468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-20", "vigencias": [{"desde": "1999-09-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-09-20