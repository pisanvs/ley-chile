{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,109.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6177103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Conc&#xE9;dese, por gracia, a do&#xF1;a Esperanza Espina, viuda del capitan de Ej&#xE9;rcito don Manuel Ramon Ar&#xED;stegui, i a sus hijos menores el derecho de disfrutar de la pension de montep&#xED;o militar correspondiente al empleo de capitan. </div></div>", "i": 6177104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a dos de setiembre de mil novecientos dieciseis.- Juan Luis Sanfuentes.- J. Boonen Rivera. </div></div>", "i": 6177105}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3109", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3109"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-09-02", "doble_articulado": false, "id_norma": "138961", "numero_fuente": "11569", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-09-08", "vigencias": [{"desde": "1916-09-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-09-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-09-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JA