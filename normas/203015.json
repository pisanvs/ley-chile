{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 769 EXENTO, DE 2002 </div></div>", "i": 6397813}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 769 de fecha 27 de agosto de 2002, de Educaci&#xF3;n, se declara aprobada a la Universidad Iberoamericana de Ciencias y Tecnolog&#xED;a la modificaci&#xF3;n al Plan y a los Programas de estudio de la carrera de Ingenier&#xED;a Civil Electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, dicha carrera se imparte en jornada diurna en su sede de la ciudad Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Las modificaciones se har&#xE1;n efectivas a contar del segundo semestre del a&#xF1;o 2002.</div><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br><br></div>", "i": 6397814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de septiembre de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6397815}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "769 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-769 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 769 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-27", "doble_articulado": false, "id_norma": "203015", "numero_fuente": "37370", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-28", "vigencias": [{"desde": "2002-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-28", "fin_vigencia": ""}, "vigencias_v