{"html": [{"t": "<div><div class=\"p\">AMPLIA PLAZO DEL ARTICULO 4&#xBA; DEL DECRETO 420, DE 1971 </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Abril de 1971.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 845.- Visto, lo dispuesto en la ley N&#xBA; 17.328, y la facultad que me confiere el N&#xBA; 2 del Art. 72&#xBA; de la Constituci&#xF3;n Pol&#xED;tica del Estado,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6182119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ampl&#xED;ase hasta el 30 de Junio de 1971 el plazo se&#xF1;alado en el primer inciso del Art. 4&#xBA; del decreto reglamentario de este Ministerio N&#xBA; 420, de 22 de Febrero de 1971.</div><br></div>", "i": 6182120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- S. ALLENDE G.- Am&#xE9;rico Zorrilla Rojas.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud. Patricio Morales Salinas, Subsecretario de Hacienda.</div><br></div>", "i": 6182121}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "845", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-845"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "AMPLIA PLAZO DEL ARTICULO 4º DEL DECRETO 420, DE 1971", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1971-04-26", "doble_articulado": false, "id_norma": "140452", "numero_fuente": "27951", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1971-05-20", "vigencias": [{"desde": "1971-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi