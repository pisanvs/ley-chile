{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 200, DE 1988 </div></div>", "i": 6095797}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 200 de 26 de diciembre de 1988 se ha aprobado a la Escuela Diferencial E N&#xB0; 527 de Temuco, IX Regi&#xF3;n de La Araucan&#xED;a, un plan de estudio especial de orientaci&#xF3;n laboral, que se desarrollar&#xE1; con car&#xE1;cter experimental, por un per&#xED;odo de cuatro a&#xF1;os, a contar desde 1989.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio correspondiente al plan que aprueba el presente decreto.</div><br></div>", "i": 6095798}, {"t": "<div><div class=\"p\">Santiago, 6 de Enero de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6095799}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "200 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-200 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 200, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-26", "doble_articulado": false, "id_norma": "93974", "numero_fuente": "33288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-02", "vigencias": [{"desde": "1989-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por