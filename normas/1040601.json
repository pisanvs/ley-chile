{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9262200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;796 de 30 de abril de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;5, superficie 79 m2, rol de Aval&#xFA;o N&#xBA;2593-31, comuna de Yumbel, para la obra &quot;CONSERVACI&#xD3;N RED VIAL VIII REGI&#xD3;N A&#xD1;OS 2009-2011, SECTOR PUENTE QUINQUIHUENO&quot;, VIII Regi&#xF3;n. La Comisi&#xF3;n de peritos, integrada por ADRIANA FASCE CASANUEVA, VALESKA CAROLINA AL&#xC9; GO&#xD1;I Y SUSANA CONEJEROS RUDLOFF, fij&#xF3; el valor de tasaci&#xF3;n con fecha 28 de octubre de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario ROBERTO ALEJANDRO CAMPOS BASCU&#xD1;AN, en la cantidad de $183.961.-, suma que se pagar&#xE1; al contado.</div></div>", "i": 9262201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9262202}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "796 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-796 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-04-30", "doble_articulado": false, "id_norma": "1040601", "numero_fuente": "40276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-01", "vigencias": [{"desde": "2012-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-01", "fin_vigencia": ""}, "vigencias_version_norma