{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA DECRETO&nbsp; N&#xBA; 1.410 EXENTO, DE 2013</div></div>", "i": 9403039}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 17, de 22 enero de 2014, de este Ministerio, rectif&#xED;case el art&#xED;culo 6&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1057670&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 1.410, de 2013, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, en el sentido de se&#xF1;alar que la cuota anual de captura de la unidad de pesquer&#xED;a de Merluza de tres aletas comprendida desde el paralelo 41&#xBA;28,6&apos; L.S. al Sur, ascender&#xE1; a 14.440 toneladas, distribuidas de la siguiente manera:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/37130.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9403040}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de enero de 2014.-&nbsp; Edith Saa Collantes, Subsecretaria de Pesca y Acuicultura (S).</div></div>", "i": 9403041}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "17 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-17 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA DECRETO Nº 1.410 EXENTO, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "