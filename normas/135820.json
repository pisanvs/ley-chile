{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,051.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6166718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados, durante la guerra contra el Per&#xFA; i Bolivia por el sarjento mayor graduado don Antonio A. Cervantes, conc&#xE9;dese, por gracia, a su viuda do&#xF1;a Filomena Ram&#xED;rez, derecho a disfrutar de la pension de montep&#xED;o militar que corresponde al empleo de sarjento mayor en vez de la pension de capitan, que actualmente percibe.</div><br></div>", "i": 6166719}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, dieciseis de setiembre de mil novecientos siete.- Pedro Montt.- Alejandro Lira.</div><br></div>", "i": 6166720}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2051", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2051"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-09-16", "doble_articulado": false, "id_norma": "135820", "numero_fuente": "8914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-10-03", "vigencias": [{"desde": "1907-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-10-03", "fin_vigencia": ""}, "vigencias_v