{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6451999}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.029, de 21 de noviembre</div><div class=\"p\">de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">parcial de la resoluci&#xF3;n N&#xBA; 1.840 de 1997, de esta</div><div class=\"p\">Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a MARCELO RODRIGO</div><div class=\"p\">GRA&#xD1;AS SILVA, para operar la nave &quot;Coru&#xF1;a&quot;, respecto de</div><div class=\"p\">los recursos hidrobiol&#xF3;gicos Besugo, en el litoral de la</div><div class=\"p\">VIII Regi&#xF3;n, con arrastre, y Bacalao de profundidad, en</div><div class=\"p\">el litoral comprendido entre Punta Liles y el paralelo</div><div class=\"p\">47&#xBA; L.S., con espinel, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6452000}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6452001}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3029 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3029 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-21", "doble_articulado": false, "id_norma": "218240", "numero_fuente": "37727", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-04", "vigencias": [{"d