{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;378 EXENTO, DE 2007 </div></div>", "i": 6609752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA;378, de 22 de enero de 2007, se ha aprobado al Colegio &quot;The International Preparatory School&quot;, comuna de Lo Barnechea, de Santiago, un plan de estudio especial biling&#xFC;e para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; a contar del a&#xF1;o escolar 2007.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los Subsectores de Aprendizaje que se indican en el presente decreto.</div><br></div>", "i": 6609753}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de mayo de 2007.- Juan Cavada Artigues, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6609754}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "378 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-378 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº378 EXENTO, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-01-22", "doble_articulado": false, "id_norma": "260711", "numero_fuente": "38760", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-11", "vigencias": [{"desde": "2007-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-05-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresa