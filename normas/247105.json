{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6560394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 248, de 24 de enero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA OMEGA LIMITADA, para realizar actividades extractivas en aguas internacionales, con la nave &quot;Tami&apos;s&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Puerto de matr&#xED;cula:&nbsp; &nbsp;  Valpara&#xED;so</div><div class=\"p\">Matr&#xED;cula:&nbsp; &nbsp;  2770</div><div class=\"p\">Se&#xF1;al de llamada:&nbsp; &nbsp;  CB-2678</div><div class=\"p\">Eslora de arqueo:&nbsp; &nbsp;  42,24 m.</div><div class=\"p\">Manga:&nbsp; &nbsp;  8,50 m.</div><div class=\"p\">Puntal:&nbsp; &nbsp;  3,63 m.</div><div class=\"p\">T.R.G. (internacional):&nbsp; &nbsp;  478,00</div><br><div class=\"p\">&nbsp; &nbsp;  Previo al inicio de operaciones de la nave, la solicitante deber&#xE1; inscribirla en el Registro Nacional Pesquero Industrial que lleva el Servicio Nacional de Pesca.</div><br></div>", "i": 6560395}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6560396}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "248 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-248 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-24", "doble_articulado": false, "id_norma": "247105", "numero_fuente": "38383", "