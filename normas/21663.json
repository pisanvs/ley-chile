{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 668 EXENTO, DE 1995</div><br><br></div>", "i": 5945794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 668 de 13 de diciembre de 1995, se ha aprobado al Colegio &quot;Saint Mary Joseph School&quot; de Macul, un plan y programas especiales de estudio para los cursos de ense&#xF1;anza b&#xE1;sica y media human&#xED;stico-cient&#xED;fica, que se aplicar&#xE1;n a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Computaci&#xF3;n.</div><br></div>", "i": 5945795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de Diciembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "668 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-668 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 668 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO SAINT MARY JOSEPH SCHOOL", "MACUL", "PLANES", "ESTUDIO", "PROGRAMA ESTUDIO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-13", "doble_articulado": false, "id_norma": "21663", "numero_fuente": "35363", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-01-11", "vigencias": [{"desde": "1996-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-01-11", "fin_