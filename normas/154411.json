{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6228907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.143, de fecha 01.09.87, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se renueva la concesi&#xF3;n otorgada a la Empresa Alfredo Becerra Dur&#xE1;n por resoluci&#xF3;n No. 417/82, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, para efectuar transporte terrestre de pasajeros entre Valdivia (Chile) y San Mart&#xED;n de los Andes (Argentina), por Paso Mamuil Malal o Hua Hum efectuando dos (2) frecuencias semanales.-</div><br></div>", "i": 6228908}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Claudio Guzm&#xE1;n P&#xE9;rez, Brigadier, Subsecretario de Transportes.</div><br></div>", "i": 6228909}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1143", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1143"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-01", "doble_articulado": false, "id_norma": "154411", "numero_fuente": "32881", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-29", "vigencias": [{"desde": "1987-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ing