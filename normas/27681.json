{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA DEL ARTICULO 1&#xB0; DE LA LEY NUMERO 12,240, DE 1956,</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5973887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Agr&#xE9;gase en la n&#xF3;mina de predios</div><div class=\"p\">fiscales que se transfieren a la Caja de Previsi&#xF3;n de</div><div class=\"p\">Empleados P&#xFA;blicos y Peridostas por el n&#xFA;mero 1&#xB0; del</div><div class=\"p\">art&#xED;culo 1&#xB0; de la ley N&#xB0; 12,240, el siguiente: ocupante Carmen Rosa Pulgar viuda de don Pedro Solar Leiva, direcci&#xF3;n calle General Iba&#xF1;ez N&#xB0; 1736 y n&#xFA;mero del rol 2,627/11&quot;.</div><br></div>", "i": 5973888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintiocho de Septiembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Enrique Bahamonde R.</div><br></div>", "i": 5973889}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14107", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14107"}], "organismos": ["MINISTERIO DE TIERRAS Y COLONIZACIÓN"], "titulo_norma": "MODIFICA DEL ARTICULO 1° DE LA LEY NUMERO 12,240, DE\n1956,", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 12.240", "PREDIO FISCAL", "TRANSFERENCIA", "BIEN RAIZ FISCAL", "INMUEBLE FISCAL", "CAJA PREVISION EMPLEADOS PARTICULARES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_