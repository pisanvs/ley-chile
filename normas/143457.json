{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,861.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8350105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, y por el t&#xE9;rmino de diez a&#xF1;os, a do&#xF1;a Rosa Vera, viuda del guarda-hilos del Tel&#xE9;grafo del Estado, don Liborio Reyes, y a sus menores hijos, una pension anual de ochocientos pesos ($ 800).</div><br></div>", "i": 8350106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, nueve de junio de mil novecientos veintidos.- Arturo Alessandri.- Armando Jaramillo V.</div><br></div>", "i": 8350107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3861", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3861"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1922-06-09", "doble_articulado": false, "id_norma": "143457", "numero_fuente": "13315", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1922-06-28", "vigencias": [{"desde": "1922-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1922-06-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1922-06-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac