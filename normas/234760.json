{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE PICHIDEGUA </div></div>", "i": 6513471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA; 16 del 5 de enero de 2005, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, aprob&#xF3; el Proyecto de Distribuci&#xF3;n de Aguas para atender el riego de las parcelas y sitios que integran el Proyecto de Parcelaci&#xF3;n la Cooperativa de Reforma Agraria Asignataria &quot;La Uni&#xF3;n Limitada&quot;, ubicado en la comuna de Pichidegua, VI Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Los derechos de aguas son de la Asociaci&#xF3;n del Canal Almahue, que son captadas en la Tercera Secci&#xF3;n del r&#xED;o Cachapoal.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; de la ley N&#xBA; 18.377.</div><br></div>", "i": 6513472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Nacional.</div><br></div>", "i": 6513473}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-16 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE PICHIDEGUA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS DE APROVECHAMIENTO DE AGUAS", "PICHIDEGUA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-01-05", "doble_articulado": false, "id_norma": "234760", "numero_fuente": "38061", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-15", "vigencias": [{"desde": "2005-01-15", "hasta": "", "