{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;1.067 EXENTO, DE 1998</div><br><br></div>", "i": 6172465}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;1.067 de 1&#xBA; de diciembre de 1998, se ha aprobado, a partir del a&#xF1;o escolar 1999, un programa de Religi&#xF3;n de la Convenci&#xF3;n Evang&#xE9;lica Bautista de Chile para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica y 1&#xBA; a&#xF1;o de ense&#xF1;anza media, los que podr&#xE1;n aplicarse conforme a la gradualidad establecida en los decretos supremos de Educaci&#xF3;n N&#xBA;s. 40 de 1996 y 220 de 1998.</div><br></div>", "i": 6172466}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de diciembre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6172467}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1067 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1067 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº1.067 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-01", "doble_articulado": false, "id_norma": "137574", "numero_fuente": "36385", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-11", "vigencias": [{"desde": "1999-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-06-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text":