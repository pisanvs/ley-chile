{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DERECHOS DE AGUAS EN COMUNA DE PE&#xD1;AFLOR </div></div>", "i": 6026670}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n</div><div class=\"p\">Exenta N&#xB0; 3.663 del 20 de Diciembre de 1995, conforme</div><div class=\"p\">art&#xED;culo 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento de Aguas proporcionales que corresponden a Reservas fundos &quot;Santa M&#xF3;nica&quot; y &quot;El Array&#xE1;n&quot;, de la comuna de Pe&#xF1;aflor, Regi&#xF3;n Metropolitana y Derechos Aprovechamiento de Aguas que corresponden a las parcelas N&#xB0;s. 1 a 30 y sitios N&#xB0;s. 1 a 32 del Proyecto de Divisi&#xF3;n de los Terrenos de la Cooperativa de Reforma Agraria Asignataria &quot;Santa M&#xF3;nica Limitada&quot;, formado por predios se&#xF1;alados.</div><div class=\"p\">&nbsp; &nbsp; Los derechos de aguas se extraen de los canales Bajo de la Esperanza y Alto de la Esperanza.-</div><br></div>", "i": 6026671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 6026672}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3663", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3663"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUAS EN COMUNA DE PEÑAFLOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO APROVECHAMIENTO AGUAS", "PE AFLOR", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-20", "doble_articulado": false, "id_norma": "40378", "numero_fuente": "35366-1", "tipo_version": "3", "tipo_v