{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8676806}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.923, de 1 de junio de 2009, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 7&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 1.607, de 2009, de esta Subsecretar&#xED;a de Pesca que autoriz&#xF3; a la CORPORACI&#xD3;N DE EDUCACI&#xD3;N LA ARAUCANA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Bacalao de profundidad -Captura de peces vivos para proyecto de cultivo experimental&quot;, en el sentido de prorrogar el plazo de entrega del informe final al 7 de octubre de 2009.</div></div>", "i": 8676807}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de junio de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8676808}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1923 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1923 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-01", "doble_articulado": false, "id_norma": "1003174", "numero_fuente": "39380", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-06-06", "vigencias": [{"desde": "2009-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-06-06", "fin