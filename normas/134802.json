{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,413.- Santiago, 28 de diciembre de 1900.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163487}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese por gracia a la viuda e hijos del jeneral de division don Manuel B&#xFA;lnes Pinto, una pension de dos mil cuatrocientos pesos anuales, que disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar i con esclusion de toda otra pension fiscal.</div><br></div>", "i": 6163488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Arturo Besa.</div><br></div>", "i": 6163489}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1413", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1413"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-12-28", "doble_articulado": false, "id_norma": "134802", "numero_fuente": "6783", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-04", "vigencias": [{"desde": "1901-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-01-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-