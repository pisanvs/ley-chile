{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Declara libre de derechos de internacion el cloruro de platino</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,468.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se declara libre de derechos de internacion el cloruro de platino que se importe al pais para usos industriales.</div><br></div>", "i": 5953498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 1.&#xB0; de Febrero de 1911.- RAMON BARROS LUCO.- Roberto S&#xE1;nchez.</div><br></div>", "i": 5953499}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2468", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2468"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DECLARA LIBRE DE DERECHOS DE INTERNACION EL CLORURO DE PLATINO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CLORURO PLATINO", "DERECHOS INTERNACION", "EXENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-02-01", "doble_articulado": false, "id_norma": "23328", "numero_fuente": "9903", "tipo_version": "3", "tipo_version_s": "Única", "fech