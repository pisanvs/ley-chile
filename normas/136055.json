{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 83, DE 1988 </div></div>", "i": 7248432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 83 de 20 de abril de 1988 se ha complementado el decreto supremo exento de Educaci&#xF3;n No. 275 de 1985, que aprob&#xF3; planes y programas de estudio experimentales para la capacitaci&#xF3;n laboral de educandos discapacitados atendidos por la Escuela &quot;Taller de Formaci&#xF3;n Laboral&quot; de Osorno, en el sentido de incorporar en el Plan B, de Formaci&#xF3;n Espec&#xED;fica, el Taller de Muebler&#xED;a, Tapicer&#xED;a y Torner&#xED;a.</div><br></div>", "i": 7248433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de abril de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7248434}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "83 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-83 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 83, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-20", "doble_articulado": false, "id_norma": "136055", "numero_fuente": "33068", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-11", "vigencias": [{"desde": "1988-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-05-11", "fin_vigencia": "", "tipo_version": "3"}],