{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300891}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA;&nbsp; 92, de 20 de enero de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la Resoluci&#xF3;n N&#xBA; 371 de 1982, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA COLOSO S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Colo Colo&quot; en lo relativo a las especies Sardina espa&#xF1;ola, Jurel, Caballa, Roncacho y Machuelo, en el litoral de la V Regi&#xF3;n, en virtud de no haber operado sobre esta Unidad de Pesquer&#xED;a conforme lo dispuesto en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 de 1989.</div><br></div>", "i": 8300892}, {"t": "<div><br><div class=\"p\">Valpara&#xED;so, 20 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8300893}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "92", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-92"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA COLOSO S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-20", "doble_articulado": false, "id_norma": "60472", "numero_fuente": "35676", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-27", "vigencias": [{"desde": "1997-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-27", "fin_vigencia": ""}