{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 16.281 EXENTA, DE 2001 </div></div>", "i": 6383369}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 16.281, de 28 de diciembre del a&#xF1;o 2001, se ha aprobado al Colegio &quot;St. Margaret&apos;s British School&quot;, comuna de Vi&#xF1;a del Mar, V Regi&#xF3;n de Valpara&#xED;so, un plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n.-</div><br><br></div>", "i": 6383370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6383371}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16281 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-16281 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 16.281 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-28", "doble_articulado": false, "id_norma": "198671", "numero_fuente": "37271", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-31", "vigencias": [{"desde": "2002-05-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODI