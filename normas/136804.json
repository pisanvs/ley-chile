{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de Septiembre de 1892.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6169909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Mientras el General de Divisi&#xF3;n don Estanislao del Canto permanece en el extranjero en comisi&#xF3;n del servicio, gozar&#xE1; de una gratificaci&#xF3;n anual de dos mil pesos oro.</div><br></div>", "i": 6169910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, o&#xED;do el Consejo de Estado, he tenido &#xE1; bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese &#xE1; efecto como ley de la Rep&#xFA;blica.- JORGE MONTT.- Luis Arteaga.</div><br></div>", "i": 6169911}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-S/N"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1892-09-15", "doble_articulado": false, "id_norma": "136804", "numero_fuente": "4429", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-01-21", "vigencias": [{"desde": "1893-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-01-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-01-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-05-20", "fecha_version": "1893-01-21", "fecha_actualizacion_texto": "1893-01-21", "t