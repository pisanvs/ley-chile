{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8164691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 3.226, de 11 de diciembre de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a LUNA Y GALAZ LIMITADA para capturar, en el &#xE1;rea mar&#xED;tima de la X Regi&#xF3;n de Los Lagos, en el plazo de 1 a&#xF1;o contado desde la fecha de la presente resoluci&#xF3;n, la cantidad total de 200 ejemplares de la especie Lobo marino com&#xFA;n Otaria flavescens, en la forma y bajo las condiciones se&#xF1;aladas en la resoluci&#xF3;n extractada. El solicitante designa como persona responsable de esta pesca de investigaci&#xF3;n a don Claudio Galaz Guerra.</div><br></div>", "i": 8164692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8164693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3226", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3226"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-11", "doble_articulado": false, "id_norma": "283657", "numero_fuente": "39239", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-17", "vigencias": [{"desde": "2008-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-17", "fin_vigencia": "", "tipo_version": "3"}], "evento