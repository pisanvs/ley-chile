{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.208 EXENTA, DE 2007 </div></div>", "i": 7347439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.208, de fecha 28 de junio de 2007, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se aprueba el programa de ense&#xF1;anza para la obtenci&#xF3;n de licencia de conductor Clase B, a la Escuela de Conductores No Profesionales o Clase B &quot;Escuela de Conductores Condutec&quot;, cuyo propietario y director es el se&#xF1;or Francisco Harold Salazar Z&#xFA;&#xF1;iga, la que tendr&#xE1; su lugar de funcionamiento en el local ubicado en Mar&#xED;a Ester Garay N&#xBA; 014, comuna de Pe&#xF1;aflor.-</div><br></div>", "i": 7347440}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Pablo Rodr&#xED;guez Olivares, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 7347441}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1208 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1208 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.208 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-28", "doble_articulado": false, "id_norma": "262603", "numero_fuente": "38810", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-11", "vigencias": [{"desde": "2007-07-11", "hasta": "", "tipo_vers