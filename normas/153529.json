{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6226266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1455, de fecha 31 de Agosto de 1987 de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n, se autoriza a Hidroel&#xE9;ctrica Guardia Vieja S.A., para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6226267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de Agosto de 1987.- Hern&#xE1;n V&#xE1;squez Wacquez, Capit&#xE1;n de Navio, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n. </div></div>", "i": 6226268}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1455 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1455 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-31", "doble_articulado": false, "id_norma": "153529", "numero_fuente": "32867", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-09", "vigencias": [{"desde": "1987-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-09", "fin_vige