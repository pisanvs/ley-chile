{"html": [{"t": "<div><div class=\"p\">COMUNICA NUEVA CODIFICACI&#xD3;N DE LAS ACTIVIDADES ECON&#xD3;MICAS</div></div>", "i": 9931194}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 56, de 9 de julio de 2018, que se&#xF1;ala:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Comunica nueva codificaci&#xF3;n de las actividades econ&#xF3;micas, la que se ajusta al <a href=\"https://www.leychile.cl/Navegar?idNorma=1070772&amp;idParte=&amp;idVersion=\">decreto N&#xB0; 187, de 2014, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes julio de 2018.</div></div>", "i": 9931195}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "56 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-56 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "COMUNICA NUEVA CODIFICACIÓN DE LAS ACTIVIDADES ECONÓMICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1428208", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-07-09", "doble_articulado": false, "id_norma": "1120608", "numero_fuente": "42105", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-07-12", "vigencias": [{"desde": "2018-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia