{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8325978}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No.1.151 de 25 de Agosto de 1989 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No.503, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Sociedad Pesquera Comercial y Profesional Aqua Cultivos Limitada, R.U.T.</div><div class=\"p\">No.87.829.000-3, domiciliada en Puerto Montt, para desarrollar actividades pesqueras de cultivo, en el sentido de sustituir en su numeral 2&#xBA; la expresi&#xF3;n &quot;Haliotis rufescens&quot; por &quot;Crassostrea gigas&quot;.</div><br></div>", "i": 8325979}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 25 de agosto de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8325980}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1151", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1151"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-25", "doble_articulado": false, "id_norma": "95340", "numero_fuente": "33467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-06", "vigencias": [{"desde": "1989-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-06", "fin_vigencia": "", "tipo_version": "3"}], "event