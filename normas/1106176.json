{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 1</div></div>", "i": 9822045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.453, de 27 de julio de 2017, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1101826&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.200, de 2017</a>, modificada por resoluci&#xF3;n N&#xB0; 1.964, de 2017, ambas de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 1, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div><br></div>", "i": 9822046}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de julio de 2017.- Pablo Berazaluce Maturana, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9822047}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2453 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2453 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 1", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; CVE 1251577"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-07-27", "doble_articulado": false, "id_norma": "1106176", "numero_fuente": "41826", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-08-04", "vigencias": [{"desde": "2017-08-04", "hasta": "", "ti