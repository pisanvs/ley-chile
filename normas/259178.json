{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6604513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 745, de 28 de febrero de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA PACIFIC FARMER LIMITADA para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por las resoluciones citadas precedentemente, en orden a incorporar a la planta ubicada en Avenida Brasil N&#xBA; 710, Calbuco, X Regi&#xF3;n, en la l&#xED;nea de proceso de Liofilizado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6604514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de febrero de 2007.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 6604515}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "745 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-745 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-02-28", "doble_articulado": false, "id_norma": "259178", "numero_fuente": "38715", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-16", "vigencias": [{"desde": "2007-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-03-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2