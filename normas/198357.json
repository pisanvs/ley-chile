{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIALIZADORA CAMPOSUR S.A.</div><br></div>", "i": 6382219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex- 605, de fecha 30 de abril de 2002, revoca a Comercializadora Camposur S.A., RUT N&#xBA; 96.816.080-K, a contar de la fecha de esta publicaci&#xF3;n la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las adquisiciones de Carne, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 16 de la resoluci&#xF3;n Ex. N&#xBA; 3722/2000, de la Direcci&#xF3;n Nacional. </div></div>", "i": 6382220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 30 de abril de 2002.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6382221}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "605 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-605 EXENTA"}, {"tipo": "3", "numero": "DRE-08-605 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-605 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A COMERCIALIZADORA CAMPOSUR S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-30", "doble_articulado": false, "id_norma": "198357", "numero_fuente": "37262", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-18", "vigencias": [{"desde": "2002-05-18", "hasta": "", "tipo_v