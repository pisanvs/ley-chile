{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA</div><br><br></div>", "i": 8561394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 674, de 05 de Julio de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 1 a&#xF1;o a contar de 02 de junio de 1988, el plazo otorgado a don Dagoberto Vera Alvarado, para empezar a operar el establecimiento de cultivo autorizado por la Resoluci&#xF3;n No. 452, de 1987, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8561395}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 05 de Julio de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8561396}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "674", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-674"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-07-05", "fecha_derogacion": "1994-01-10", "doble_articulado": false, "id_norma": "130431", "numero_fuente": "33127", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-07-22", "vigencias": [{"desde": "1994-01-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1988-07-22", "hasta": "1994-01-09", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1994-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici