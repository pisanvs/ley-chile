{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9101518}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 36, de 7 de enero de 2011, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1012185&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.130, de 2010</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a LUNA Y GALAZ LIMITADA para capturar 120 ejemplares de la especie Lobo marino com&#xFA;n en la X Regi&#xF3;n de Los Lagos, en el sentido de extender el plazo de la citada autorizaci&#xF3;n hasta el d&#xED;a 25 de marzo de 2012, inclusive.</div></div>", "i": 9101519}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de enero de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9101520}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "36", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-36"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-07", "doble_articulado": false, "id_norma": "1022163", "numero_fuente": "39862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-18", "vigencias": [{"desde": "2011-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-01-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-01-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFIC