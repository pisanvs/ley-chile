{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">SE APRUEBA &quot;INSTRUCTIVO REEVALUACI&#xD3;N INVALIDEZ PARCIAL SISTEMA DE PENSIONES SOLIDARIAS&quot;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9656017}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 605, de 6 de noviembre de 2015, se aprueba para el Instituto de Previsi&#xF3;n Social, el &quot;Instructivo Reevaluaci&#xF3;n Invalidez Parcial Sistema de Pensiones Solidarias&quot;, que describe el procedimiento administrativo para ejecutar de manera eficiente, oportuna y segura, las labores que involucra dicho proceso de reevaluaci&#xF3;n.</div><br></div>", "i": 9656018}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de diciembre de 2015.- Patricio Coronado Rojo, Director Nacional.</div></div>", "i": 9656019}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "605 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-605 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE APRUEBA \"INSTRUCTIVO REEVALUACIÓN INVALIDEZ PARCIAL SISTEMA DE PENSIONES SOLIDARIAS\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 975282; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-11-06", "doble_articulado": false, "id_norma": "1085109", "numero_fuente": "41329", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-12-11", "vigencias": [{"desde": "2015-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio