{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 37, DE 1984 </div></div>", "i": 6293241}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Oficio Circular N&#xBA; 37, de fecha 16 de Enero de 1984 el se&#xF1;or Director Nacional de Aduanas ha instruido a los se&#xF1;ores Directores Regionales y Administradores de Aduanas a objeto de que procedan a denunciar como infracci&#xF3;n al art&#xED;culo 183 de la Ordenanza de Aduanas, los errores en la indicaci&#xF3;n de las series num&#xE9;ricas de los contenedores, a excepci&#xF3;n del &#xFA;ltimo d&#xED;gito, contenidos en los conocimientos de embarque que sirven de base para la confecci&#xF3;n de los documentos de destinaci&#xF3;n aduanera.</div><div class=\"p\">&nbsp; &nbsp;  La denuncia se dirigir&#xE1; contra quien suscribi&#xF3; el documento de destinaci&#xF3;n aduanera, de la persona que resulte responsable del error o del emisor de los documentos, seg&#xFA;n los casos.-</div><br></div>", "i": 6293242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Patricio Cort&#xE9;s Chadwick, Director Nacional de Aduanas.</div><br></div>", "i": 6293243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "37", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-37"}], "organismos": ["MINISTERIO DE HACIENDA", "DIRECCIÓN NACIONAL DE ADUANAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 37, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-01-16", "doble_articulado": false, "id_norma": "173338", "numero_fuente": "32978", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-25", "vigencias": [{"desde": "1988-01-25", "hasta": "", "tipo_versio