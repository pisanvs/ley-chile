{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6583859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.676, de 14 de septiembre de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.051, de 1989, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a LUIS ALEJANDRO SEPULVEDA CRUZ para desarrollar actividades pesqueras extractivas con la nave &quot;Maribel II&quot;, sobre el recurso Bacalao de profundidad, en el &#xE1;rea mar&#xED;tima comprendida entre la III a VII Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado en Informes T&#xE9;cnicos citados en Visto.</div><br></div>", "i": 6583860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de septiembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6583861}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2676 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2676 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-14", "doble_articulado": false, "id_norma": "253550", "numero_fuente": "38573", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-26", "vigencias": [{"desde": "2006-09-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-09-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2