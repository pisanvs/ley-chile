{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.728 EXENTA, DE 2008 </div></div>", "i": 7383926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 8.728, de 10 de diciembre de 2008, se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 7.132, de 2004, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Colegio Dunalastair, comuna de Las Condes, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los Subsectores de Historia Moderna y Contempor&#xE1;nea (2&#xBA; a 4&#xBA;), Filosof&#xED;a (2&#xBA; a 4&#xBA;), Econom&#xED;a (2&#xBA; a 4&#xBA;), Historia de Chile (2&#xBA;), Biolog&#xED;a, Qu&#xED;mica y F&#xED;sica (1&#xBA; a 4&#xBA;), Ciencias Naturales (2&#xBA;) y Artes Teatrales (2&#xBA; a 4&#xBA;). </div></div>", "i": 7383927}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de diciembre de 2008.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 7383928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8728 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8728 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.728 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-10", "doble_articulado": false, "id_norma": "284986", "numero_fuente": "39261", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-14", "vigencias":