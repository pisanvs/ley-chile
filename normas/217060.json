{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6447886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.578, de 28 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a FAENADORA SAN VICENTE&nbsp; LIMITADA&nbsp; para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Km. 19,2, de la Ruta H-66-G, San Vicente de Tagua Tagua, VI Regi&#xF3;n, donde podr&#xE1; procesar, en la l&#xED;nea de proceso de&nbsp; Empanizados, los recursos hidrobiol&#xF3;gicos Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n plateado y Trucha arcoiris.</div><br></div>", "i": 6447887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6447888}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2578 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2578 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-28", "doble_articulado": false, "id_norma": "217060", "numero_fuente": "37708", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-12", "vigencias": [{"desde": "2003-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":