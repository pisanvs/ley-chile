{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.058, de 18 de julio de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las Resoluciones N&#xBA; 934 y N&#xBA; 1.383, ambas de 1989, de esta Subsecretar&#xED;a, que autorizaron a&nbsp;  PESQUERA MONTEMAR S.A., para operar y ampliar actividades pesqueras extractivas, respectivamente, con las naves &quot;Bucalemu I&quot; y &quot;Bucalemu II&quot;; en virtud de&nbsp; no haberse publicado oportunamente la primera Resoluci&#xF3;n, y la segunda por configurar la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones. </div></div>", "i": 8304902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304903}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1058", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1058"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MONTEMAR S.A.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-18", "doble_articulado": false, "id_norma": "74507", "numero_fuente": "35826", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-07-26", "vigencias": [{"desde": "1997-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-07-26", "fin_