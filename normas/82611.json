{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUAS EN COMUNA DE GRANEROS </div></div>", "i": 7094259}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No.</div><div class=\"p\">1.074 de 23 de Julio de 1990, conforme art&#xED;culo 5&#xB0; Transitorio C&#xF3;digo de Aguas, complement&#xF3; Resoluci&#xF3;n Exenta No. 1.989 de 1&#xB0; de Septiembre de 1981, en el sentido de determinar derechos aprovechamiento aguas proporcionales que corresponden a Sector Expropiado y Sector Excluido del predio &quot;Resto del Fundo Santa Rosa de Tuniche&quot; de la comuna de Graneros, VI Regi&#xF3;n.</div><div class=\"p\">Los derechos de aguas se extraen de la Asociaci&#xF3;n Canales de la Compa&#xF1;&#xED;a por los Canales Cerpa y Estero La Cadena. Publicaci&#xF3;n hecha conforme art&#xED;culo 13 Ley No. 18.377.- </div></div>", "i": 7094260}, {"t": "<div><div class=\"p\">Director Nacional.</div><br></div>", "i": 7094261}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1074 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1074 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE AGUAS EN COMUNA DE GRANEROS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-23", "doble_articulado": false, "id_norma": "82611", "numero_fuente": "33734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-01", "vigencias": [{"desde": "1990-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-01", "fin_vigencia": ""}, "vigencias_version_n