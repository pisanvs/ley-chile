{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 186 EXENTO, DE 1999</div><br><br></div>", "i": 6184494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 186 de fecha 9 de julio de 1999 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; el funcionamiento de la carrera modificada que se indica y el otorgamiento de los t&#xED;tulos que se se&#xF1;alan, la que podr&#xE1; impartirse en el Instituto Profesional Alpes, a contar del a&#xF1;o 1999:</div><div class=\"p\">Carrera: Comunicaci&#xF3;n Gr&#xE1;fica, conducente al t&#xED;tulo profesional de Comunicador Gr&#xE1;fico y t&#xED;tulo intermedio de T&#xE9;cnico de Nivel Superior en Dise&#xF1;o Gr&#xE1;fico (Certificado N&#xBA; 1222 del 19 de octubre de 1990). Liberada por decreto supremo de Educaci&#xF3;n N&#xBA; 972, de 1987.</div><br></div>", "i": 6184495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de agosto de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6184496}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "186 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-186 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 186 EXENTO, DE 1999", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-07-09", "fecha_derogacion": "2012-10-19", "doble_articulado": false, "id_norma": "141160", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-08-24", "vigencias": [{"desde": "2012-10-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-08-24", "hasta": "2012-10-18", "tipo_version