{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,874.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Rita Aguilera, viuda de Maza, el derecho a gozar del montep&#xED;o correspondiente, como hija del teniente coronel don Pedro Aguilera, que habia perdido por haber contraido matrimonio y que no pudo recuperar cuando enviud&#xF3;, por encontrarse en posesion del montep&#xED;o otra persona con mejor derecho.</div><br></div>", "i": 6165974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, treinta y uno de julio de mil novecientos seis.- Jerman Riesco.- Salvador Vergara A.</div><br></div>", "i": 6165975}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1874", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1874"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-07-31", "doble_articulado": false, "id_norma": "135605", "numero_fuente": "8850", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-07-16", "vigencias": [{"desde": "1907-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{