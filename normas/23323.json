{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede una asignacion de $ 1,500 a don Benigno Cruzat</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,459.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275281}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- En atencion a los servicios prestados por don Benigno Cruzat en las polic&#xED;as municipales de la Victoria, Santiago i Puente Alto, conc&#xE9;desele por gracia, i por una sola vez, mil quinientos pesos ($ 1,500).</div><br></div>", "i": 8275282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 1.&#xB0; de Febrero de 1911.- RAMON BARROS LUCO.- Rafael Orrego.</div><br></div>", "i": 8275283}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2459", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2459"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE UNA ASIGNACION DE $ 1,500 A DON BENIGNO CRUZAT", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BENIGNO CRUZAT", "POLICIA MUNICIPAL", "ASIGNACION POR", "GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-02-01", "doble_articulado": false, "id_norma": "23323", "numero_fuente": "9905", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-02-11", "vigencias": [{"desde": "1911-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc