{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 1.104 EXENTA, DE 2015</div></div>", "i": 9612936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.545, de 10 de junio de 2015, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1077174&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.104 de 2015</a>, que autoriz&#xF3; al Instituto de Fomento Pesquero para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Evaluaci&#xF3;n hidroac&#xFA;stica de los stocks de anchoveta y sardina com&#xFA;n entre la V y X Regiones, a&#xF1;o 2014 (Crucero de Oto&#xF1;o 2015) (Crucero de Oto&#xF1;o 2015)&quot;, en el sentido de se&#xF1;alar que el plazo del estudio se extender&#xE1; hasta el 20 de junio de 2015, inclusive.</div></div>", "i": 9612937}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de junio de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9612938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1545 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1545 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 1.104 EXENTA, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-06-10", "doble_articulado": false, "id_norma": "1078707", "numer