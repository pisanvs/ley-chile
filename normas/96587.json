{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;. 363, DE 1990</div><br><br><br><br></div>", "i": 6103497}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 363 de 27 de Diciembre de 1990, se han aprobado planes especiales de estudio al Liceo A No. 33 de Conchal&#xED;, Regi&#xF3;n Metropolitana, para que sean aplicados en 7&#xB0; y 8&#xB0; A&#xF1;o de Ense&#xF1;anza B&#xE1;sica y en todos los cursos de Ense&#xF1;anza Media Human&#xED;stico - Cient&#xED;fica.</div><div class=\"p\">Las nuevos planes aprobados se aplicar&#xE1;n en el a&#xF1;o escalar 1991 en 7&#xB0; y 8&#xB0; A&#xF1;o de Ense&#xF1;anza B&#xE1;sica y en los cursas 1&#xB0; a 3&#xB0; A&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico - Cient&#xED;fica y las correspondientes a 4&#xB0; A&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico - Cient&#xED;fica se aplicar&#xE1;n a partir del a&#xF1;o escalar 1992. </div></div>", "i": 6103498}, {"t": "<div><div class=\"p\">Santiago, 12 de Febrero de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6103499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "363 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-363 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº. 363, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-12-27", "fecha_derogacion": "1995-03-25", "doble_articulado": false, "id_norma": "96587", "numero_fuente": "33899", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-02-20", "vigen