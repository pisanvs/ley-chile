{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6233175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 124, de 18 de Septiembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XII Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a Mar&#xED;a Teresa Leal Espinoza, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6233176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mario Salgado Jim&#xE9;nez, Secretario Regional Ministerial de Transportes y Telecomunicaciones XII Regi&#xF3;n Subrogante:</div><br></div>", "i": 6233177}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "124 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-124 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-16", "doble_articulado": false, "id_norma": "155770", "numero_fuente": "32630", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-11-24", "vigencias": [{"desde": "1986-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-11-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-11-24", "fin_vigencia