{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,687, que suplementa el Presupuesto de Guerra.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,687.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7167104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de treinta i siete mil pesos ($ 37,000) al &#xED;tem 137 de la partida 7a. del Presupuesto de Guerra vijente.</div><div class=\"p\">&nbsp; &nbsp; El gasto se deducir&#xE1; de la mayor entrada de los derechos de esportacion del salitre.</div><br></div>", "i": 7167105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo, por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticuatro de Noviembre de mil novecientos veinte.- JUAN LUIS SANFUENTES.- Ladislao Err&#xE1;zuriz.</div><br></div>", "i": 7167106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3687", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3687"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NUM. 3,687, QUE SUPLEMENTA EL PRESUPUESTO DE GUERRA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1920", "MODIFICACION", "MINISTERIO", "GUERRA", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1920-11-24", "doble_articulado": false, "id_norma": "24173", "numero_fuente": "12832", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1920-11-26", "vigencias": [{"desde": "1920-11-26", "hasta": 