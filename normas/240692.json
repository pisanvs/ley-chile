{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6535057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 633 de 30 de junio de 2005, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP exento N&#xBA; 612 de 27 de abril de 2004, en la parte que se refiere al Convenio Directo de Precio Ad- Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote N&#xBA;630. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 630, fijada por la Comisi&#xF3;n de Peritos, con fecha 6 de mayo de 2002, en la cantidad de $280.500.- para el lote N&#xBA; 630. </div></div>", "i": 6535058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6535059}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "633 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-633 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-30", "doble_articulado": false, "id_norma": "240692", "numero_fuente": "38225", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-01", "vigencias": [{"desde": "2005-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MOD