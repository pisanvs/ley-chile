{"html": [{"t": "<div><br><div class=\"p\">COMPLEMENTA RESOLUCI&#xD3;N N&#xBA; 11 EXENTA, DE 2003</div></div>", "i": 9360648}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 61, de 17 de junio de 2013, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Complementa <a href=\"https://www.leychile.cl/Navegar?idNorma=207808&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 11, de 14.02.2003</a>, fijando procedimiento sobre entrega de boletas electr&#xF3;nicas en servicios de recarga telef&#xF3;nica m&#xF3;vil a trav&#xE9;s de internet.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio de 2013.</div></div>", "i": 9360649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-61 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "COMPLEMENTA RESOLUCIÓN Nº 11 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-06-17", "doble_articulado": false, "id_norma": "1052092", "numero_fuente": "40590", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-21", "vigencias": [{"desde": "2013-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-06-21", "fin_vigencia": ""}, "vigen