{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298657}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.937 de 11 de noviembre de 1996</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la</div><div class=\"p\">solicitud de concesi&#xF3;n de acuicultura presentada por</div><div class=\"p\">DIEGO MANCILLA VARGAS, para un sector ubicado en Canal</div><div class=\"p\">Quihua, Comuna de Calbuco, Provincia de Llanquihue, X</div><div class=\"p\">Regi&#xF3;n, en virtud de lo dispuesto en los art&#xED;culos 76&#xB0;,</div><div class=\"p\">77&#xB0; y 78&#xB0;, de la Ley General de Pesca y Acuicultura y el</div><div class=\"p\">art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8298658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 11 de noviembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298659}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1937", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1937"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION DE ACUICULTURA", "DIEGO MANCILLA VARGAS", "CALBUCO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-11-11", "doble_articulado": false, "id_norma": "37583", "numero_fuente": "35622", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-11-22", "vigenci