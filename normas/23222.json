{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei 2,240, que fija en $ 0.20 por kilo de peso bruto el derecho de internacion de los f&#xF3;sforos de madera Lei n&#xFA;m. 2,240.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Desde el 1.&#xB0; de Enero de 1910, f&#xED;jase en veinte centavos por kilo de peso bruto el derecho de internacion de los f&#xF3;sforos de madera que se introduzcan al pais.</div><br></div>", "i": 5953141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 15 de Enero de 1910.- PEDRO MONTT.- Manuel Salinas.</div><br></div>", "i": 5953142}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2240", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2240"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Lei 2,240, que fija en $ 0.20 por kilo de peso bruto;el derecho de internacion de los fósforos de madera", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FOSFOROS MADERA", "DERECHOS INTERNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-01-15", "doble_articulado": false, "id_norma": "2322