{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.406 EXENTA,DE 2007 </div></div>", "i": 6620890}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.406, de fecha 23 de mayo de 2007 del Ministerio de Educaci&#xF3;n, se ampl&#xED;a el per&#xED;odo de acreditaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica SOEDUC Aconcagua, por un a&#xF1;o, a contar de diciembre de 2006.</div><div class=\"p\">&nbsp; &nbsp;  Requi&#xE9;rase del Centro de Formaci&#xF3;n T&#xE9;cnica SOEDUC Aconcagua el cumplimiento de algunas acciones dentro del plazo se&#xF1;alado, lo que ser&#xE1; verificado por la Divisi&#xF3;n de Educaci&#xF3;n Superior, como condici&#xF3;n previa para la obtenci&#xF3;n de la Plena Autonom&#xED;a, correspondiendo al Ministerio de Educaci&#xF3;n la verificaci&#xF3;n de su desarrollo.</div><br></div>", "i": 6620891}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de agosto de 2007.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6620892}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4406 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4406 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.406 EXENTO, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2007-05-23", "fecha_derogacion": "2022-03-17", "doble_articulado": false, "id_norma": "263931", "numero_fuente": "38840", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2007-08-17", "vigencias": [{"desde": "2022-03-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Ve