{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9912285}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Punta Arenas del SII, por resoluci&#xF3;n N&#xB0; Ex. 106, de 23 de abril de 2018, otorga, a contar del 1&#xB0; del mes siguiente al de esta publicaci&#xF3;n y se mantendr&#xE1; vigente siempre que d&#xE9; cabal cumplimiento a las obligaciones se&#xF1;aladas en la resoluci&#xF3;n N&#xB0; Ex. 3.722, de 2000, a Ganadera Carne Sur Limitada, RUT N&#xB0; 76.058.633-1, la calidad de Agente Retenedor del Impuesto al Valor Agregado en el 5% anticipo de la carne, establecido en la Res. N&#xB0; Ex. 3.722, del 2000, de la Direcci&#xF3;n Nacional.</div></div>", "i": 9912286}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Punta Arenas, 23 de abril de 2018.- Ana Mar&#xED;a Vargas C&#xE1;rdenas, Directora Regional.</div></div>", "i": 9912287}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "106 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-106 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL PUNTA ARENAS"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1395618", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-04-23", "doble_articulado": false, "id_norma": "1118385", "numero_fuente": "42054", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-05-11", "vigencias": [{"desde": "2018-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-06-01", "fin_vigencia": ""}, "vigen