{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6182510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. No. 353, de 28 de noviembre de 1986, se expropi&#xF3; el lote de terreno No. 11, cuya superficie es 4.440 m2., rol de aval&#xFA;o 4922-6, comuna San Antonio, para la obra Camino nuevo acceso al Puerto de San Antonio, sector bajada a Barrancas y se acord&#xF3; el precio de indemnizaci&#xF3;n con su propietaria Sociedad Constructora de Viviendas Econ&#xF3;micas Puyaral Limitada, ascendente a $ 3.797.403.</div><br></div>", "i": 6182511}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas.</div><div class=\"p\">(2) </div></div>", "i": 6182512}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "353", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-353"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-11-28", "doble_articulado": false, "id_norma": "140555", "numero_fuente": "32661", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-02", "vigencias": [{"desde": "1987-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1999-08-17", "fecha_version": "1987-01-02", "fecha_actualizacion_texto": "1987-01-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "