{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON RENE CUPERTINO BOLADOS CONTRERAS PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br><br></div>", "i": 7260445}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.004 de 31 de Agosto de 1987 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Ren&#xE9; Cupertino Bolados Contreras, domiciliado en Serrano No. 142, Iquique, I Regi&#xF3;n, para ampliar las actividades pesqueras autorizadas per resoluci&#xF3;n No. 99, de 1986, de esta Subsecretar&#xED;a, en orden a extender la zona del litoral en que puede operar la embarcaci&#xF3;n &quot;Do&#xF1;a Sara&quot; al comprendido entre las regiones III a VI.</div><br></div>", "i": 7260446}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de Agosto de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7260447}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1004", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1004"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A DON RENE CUPERTINO BOLADOS CONTRERAS PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-08-31", "fecha_derogacion": "2003-06-09", "doble_articulado": false, "id_norma": "154384", "numero_fuente": "32880", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-09-28", "vigencias": [{"desde": "2003-06-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-09-