{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6238591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 4, de 13 de Enero de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a la Sra. Rosario Mu&#xF1;oz Navarro para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6238592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 6238593}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-13", "doble_articulado": false, "id_norma": "157472", "numero_fuente": "32381", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-25", "vigencias": [{"desde": "1986-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-01-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-01-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes