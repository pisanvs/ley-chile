{"html": [{"t": "<div><div class=\"p\">AUTORIZA A LA SOCIEDAD PESQUERA COQUIMBO DOS LTDA. PARA AMPLIAR SUS ACTIVIDADES PESQUERAS </div></div>", "i": 7260978}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 265, de 1&#xBA; de Junio de 1984 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la Sociedad Pesquera Coquimbo Dos Ltda., domiciliada en Santiago, para operar la embarcaci&#xF3;n denominada &quot;St. Irene&quot;, en el litoral comprendido entre la III y la V Regi&#xF3;n, en labores extractivas de los siguientes recursos: jurel, sardina espa&#xF1;ola, caballa y anchoa.</div><br></div>", "i": 7260979}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1&#xBA; de Junio de 1984.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7260980}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "265", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-265"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A LA SOCIEDAD PESQUERA COQUIMBO DOS LTDA. PARA AMPLIAR SUS ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-06-01", "doble_articulado": false, "id_norma": "155113", "numero_fuente": "31890", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1984-06-07", "vigencias": [{"desde": "1984-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1984-06-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1984-06-07", "fin_vigencia