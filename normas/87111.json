{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 79, DE 1992</div><br><br></div>", "i": 7221857}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 79 de 31 de marzo de 1992 se ha modificado, a partir del a&#xF1;o escolar 1992, el decreto supremo exento de Educaci&#xF3;n No. 170 de 1983, que aprob&#xF3; un plan especial de estudio para 7&#xB0; y 8&#xB0; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica y 1&#xB0; a 4&#xB0; a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico - Cient&#xED;fica, para el Instituto Nacional &quot;Jos&#xE9; Miguel Carrera&quot;, de Santiago.</div><br></div>", "i": 7221858, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">Santiago, 25 de mayo de 1992.- Ra&#xFA;l Allard Neumann. Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7221859}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "79 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-79 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 79, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-31", "doble_articulado": false, "id_norma": "87111", "numero_fuente": "34282", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-06-03", "vigencias": [{"desde": "1992-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-06-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_