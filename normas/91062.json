{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8319844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 101, de 21 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xBA; 164, de 1990, de esta Subsecretar&#xED;a que autoriz&#xF3; a EXPORTADORA Y COMERCIAL DESHIDRO LIMITADA, para operar la nave &quot;Berta&quot;, en el litoral comprendido entre los paralelos 41&#xB0;28,6&apos; L.S. y 43&#xB0; L.S., en la captura de Merluza com&#xFA;n y Pejegallo, en virtud de lo se&#xF1;alado en el art&#xED;culo 143 letra b) del D.S. N&#xBA; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8319845}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8319846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "101", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-101"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "EXPORTADORA Y COMERCIAL DESHIDRO LIMITADA", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-21", "doble_articulado": false, "id_norma": "91062", "numero_fuente": "35978", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-30", "vigencias": [{"desde": "1998-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-30", "fin_vige