{"html": [{"t": "<div><div class=\"p\">\\ufeffSuspension de diversiones p&#xFA;blicas</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 20 de 1822.</div></div>", "i": 10214978}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Toda diversion p&#xFA;blica debe cesar mientras duran los movimientos de la tierra que han hecho grandes estragos, i en los pueblos de los partidos mayores que en esta capital. Es justo que todos los habitantes no tengan un embarazo que les distraiga de el objeto de elevar sus s&#xFA;plicas para aplacar la ira divina. En consecuencia, ordeno que las representaciones teatrales i toda otra diversion p&#xFA;blica se suspenda hasta nueva providencia. - </div></div>", "i": 10214979}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Echeverr&#xED;a. -Torres, sub-secretario.</div></div>", "i": 10214980}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Suspension de diversiones públicas", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-11-20", "doble_articulado": false, "id_norma": "1152084", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-11-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-11-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-04-08", "fecha_version": "1822-1