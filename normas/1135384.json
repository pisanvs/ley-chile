{"html": [{"t": "<div><div class=\"p\">FIJA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESI&#xD3;N DE SALM&#xD3;NIDOS 12A REGI&#xD3;N DE LOS LAGOS</div></div>", "i": 10048887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.856, de 16 de agosto de 2019, de esta Subsecretar&#xED;a, f&#xED;janse las densidades para agrupaci&#xF3;n 12A:</div><div class=\"p\"> </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/96780.jpg\">.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Except&#xFA;anse los centros que se acojan al porcentaje de reducci&#xF3;n de siembra, que tendr&#xE1;n la densidad establecida por <a href=\"https://www.leychile.cl/Navegar?idNorma=1003741&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.449, de 2009</a>, del Servicio Nacional de Pesca y Acuicultura, de conformidad con el art&#xED;culo 62 del DS N&#xBA; 319, de 2001, de este Ministerio.</div></div>", "i": 10048888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de agosto de 2019.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 10048889}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2856 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2856 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "FIJA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIÓN DE SALMÓNIDOS 12A REGIÓN DE LOS LAGOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1642290", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-08-16", "doble_articulado": false, "id_norma": "11353