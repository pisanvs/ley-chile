{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;378, de 18 de marzo de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto el numeral 1 de la resoluci&#xF3;n N&#xBA;168 de 1998, que declar&#xF3; la caducidad de la resoluci&#xF3;n N&#xBA;924 de 1989, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a COMPA&#xD1;IA PESQUERA MEDITERRANEO LTDA., para operar la nave &apos;&apos;Terranova&apos;&apos;, en virtud de los nuevos antecedentes tenidos a la vista.</div><br></div>", "i": 8328996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de marzo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><div class=\"p\">Ministerio de Hacienda </div></div>", "i": 8328997}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "378", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-378"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "COMPA IA PESQUERA MEDITERRANEO LTDA.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-18", "doble_articulado": false, "id_norma": "97708", "numero_fuente": "36031", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-04-02", "vigencias": [{"desde": "1998-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-04-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-04-02", "fin_vigencia": "", "ti