{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; OTORGA NOMBRE DE &quot;FERNANDO SANTIVAN&quot; A LICEO QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente,</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5982915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.- Ot&#xF3;rgase al Liceo Coeducacional de Panguipulli el nombre de &quot;Fernando Santiv&#xE1;n&quot;. </div></div>", "i": 5982916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.- Denom&#xED;nase &quot;Liceo Julio Asmussen Urrutia&quot; al Liceo N.&#xB0; 2 Coeducacional de la ciudad de Antofagasta.</div><br></div>", "i": 5982917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, trece de Octubre de mil novecientos setenta y dos.- SALVADOR ALLENDE GOSSENS.- An&#xED;bal Palma Fourcade, Ministro de Educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Waldo Su&#xE1;rez Zambont, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 5982918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17787", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17787"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "OTORGA NOMBRE DE FERNANDO SANTIVAN A LICEO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO COEDUCACIONAL FERNANDO SANTIVAN", "NOMBRE", "PANGUIPULLI", "LICEO JULIO ASMUSSEN URRUTIA", "ANTOFAGASTA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1972