{"html": [{"t": "<div><div class=\"p\">MODIFICA EL DECRETO NUMERO 1,505, DE 1935</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 230.- Santiago, 16 de Mayo de 1956.- Visto lo dispuesto en el art&#xED;culo 57 del DFL. 287, de 25 de Julio de 1953, y la facultad que me confiere el art&#xED;culo 72 de la Constituci&#xF3;n Pol&#xED;tica del Estado,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7353212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase el texto de la letra f) del art&#xED;culo 161 del decreto N.o 1,505, de 4 de Diciembre de 1935, por el siguiente: &quot;Las sumas autorizadas en uso de la facultad que confiere al Ministerio, el art&#xED;culo 57 del DFL. 287.&quot;.</div><br></div>", "i": 7353213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- C. IBA&#xD1;EZ C.- Enrique Barbosa B. </div></div>", "i": 7353214}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "230", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-230"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "MODIFICA EL DECRETO NUMERO 1,505, DE 1935", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-05-16", "doble_articulado": false, "id_norma": "264625", "numero_fuente": "23481", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-06-23", "vigencias": [{"desde": "1956-06-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1956-06-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1956-06-23", "fin_vigencia": "", "tipo_v