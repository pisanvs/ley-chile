{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO </div></div>", "i": 6000290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n de la Fiscal&#xED;a del Ministerio de Obras P&#xFA;blicas F. N&#xB0; 17, de 12 Abril de 1991, se ha ordenado pagar la cantidad de $ 2.597.639.- a la Sucesi&#xF3;n Juan Manuel P&#xE9;rez Hurtado, o a quienes acrediten derecho como valor del 100% del aval&#xFA;o fijado por la Comisi&#xF3;n de Hombres Buenos m&#xE1;s su reajuste, para el Lote N&#xB0; 23, superficie 380 m2., Comuna de Renca, para la obra Trazados R&#xED;o Mapocho, Avenidas Costanera Norte y Sur, sector Walker Mart&#xED;nez calle Los Aromos. Se deja constancia que el plazo para reclamar judicialmente del aval&#xFA;o es de 30 d&#xED;as contados desde la fecha de la 2&#xB0; publicaci&#xF3;n.-</div><br></div>", "i": 6000291}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6000292}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "17", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-17"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RENCA", "EXPROPIACION", "INMUEBLE", "INDEMNIZACION", "SUCESION JUAN MANUEL PEREZ HURTADO", "PAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-04-12", "doble_articulado": false, "id_norma": "31235", "numero_fuente": "33993", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-15", "vigencias": [{"desde": "1991-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-06-15", "fin_vigencia": ""}, "vigencia