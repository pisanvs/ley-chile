{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8934622}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.775, de 4 de junio de 2010 de esta Subsecretar&#xED;a, autor&#xED;zase a EL&#xCD;AS JUAN REYES GONZ&#xC1;LEZ para iniciar actividades pesqueras de transformaci&#xF3;n, instalar y operar planta en ex Cancha de Huasos N&#xBA; 90, Sitio Dos, Colonia Pudeto, Ruta 5 Ancud a Chacao, Ancud, Chilo&#xE9;, X Regi&#xF3;n, para elaborar en l&#xED;neas de Cocido, Fresco-Enfriado, Fresco-Refrigerado, Congelado, Seco Salado, Ahumado, Conservas, Aceite, Alga Seca y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div></div>", "i": 8934623}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de junio de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 8934624}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1775 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1775 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-06-04", "doble_articulado": false, "id_norma": "1014665", "numero_fuente": "39690", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-19", "vigencias": [{"desde": "2010-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-06-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-06-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p