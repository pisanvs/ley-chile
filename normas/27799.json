{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ESTABLECE QUE EL LICEO FISCAL DE LAUTARO SE DENOMINARA LICEO &quot;DOMINGO DURAN MORALES&quot;.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congeso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5974316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. El Liceo Fiscal de Lautaro se denominar&#xE1; Liceo &quot;Domingo Dur&#xE1;n Morales&quot;.&quot; </div></div>", "i": 5974317}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diez de agosto de mil novecientos sesenta y uno.-</div><div class=\"p\">&nbsp; &nbsp; JORGE ALESSANDRI RODRIGUEZ.- Eduardo Moore. </div></div>", "i": 5974318}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14606", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14606"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "ESTABLECE QUE EL LICEO FISCAL DE LAUTARO SE DENOMINARA LICEO DOMINGO DURAN MORALES.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "LICEO DOMINGO DURAN MORALES", "LAUTARO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1961-08-10", "doble_articulado": false, "id_norma": "27799", "numero_fuente": "25027", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1961-08-23", "vigencias": [{"desde": "1961-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1961-08-23", "fin_vigencia": ""}, "vigencias_version_