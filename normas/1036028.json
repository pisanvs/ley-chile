{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE APLICACI&#xD3;N WEB PARA SOLICITAR BENEFICIO QUE INDICA</div></div>", "i": 9226165}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xBA; 2 de fecha 6 de enero de 2012, que establece una aplicaci&#xF3;n en internet para facilitar a los contribuyentes solicitar el beneficio correspondiente a la exenci&#xF3;n del Impuesto Territorial establecida en el DFL N&#xBA; 2, de 1959, sobre Plan Habitacional.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en el mes de enero de 2012.</div></div>", "i": 9226166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "2", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-2"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE APLICACIÓN WEB PARA SOLICITAR BENEFICIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-06", "doble_articulado": false, "id_norma": "1036028", "numero_fuente": "40159", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-01-12", "vigencias": [{"desde": "2012-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-01-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones