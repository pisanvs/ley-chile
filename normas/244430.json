{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8868767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.045, de 23 de noviembre de 2005, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.502 de 1997, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA POLAR S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Polar Mist&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a la X Regi&#xF3;n, sobre el recurso Caballa Scomber peruanus, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y lo informado por la Divisi&#xF3;n de Administraci&#xF3;n Pesquera de la Subsecretar&#xED;a de Pesca.</div><br></div>", "i": 8868768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 8868769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4045 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4045 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-23", "doble_articulado": false, "id_norma": "244430", "numero_fuente": "38325", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-30", "vigencias": [{"desde": "2005-11-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-30