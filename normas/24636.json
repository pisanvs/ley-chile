{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente,</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 7168474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Apru&#xE9;base el traspaso de la suma de $ 10,000, del &#xED;tem 184, del Cap&#xED;tulo VII, al &#xED;tem 412, Cap&#xED;tulo XV, de Presupuesto de Marina correspondente al a&#xF1;o 1927.</div><br></div>", "i": 7168475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a ocho de Febrero de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez del Campo.- Carlos O. Frodden.</div><br></div>", "i": 7168476}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4295", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4295"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1927", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-08", "doble_articulado": false, "id_norma": "24636", "numero_fuente": "15001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-16", "vigencias": [{"desde": "1928-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-02-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-02-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION",