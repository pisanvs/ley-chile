{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISORES DE BOLETAS ELECTRONICAS</div><br><br><br></div>", "i": 6542431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 95 de 28/09/2005, que autoriza a contribuyentes como emisores de boletas electr&#xF3;nicas.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de boletas electr&#xF3;nicas a los contribuyentes RUT N&#xBA; 97.041.000-7 y RUT N&#xBA; 97.008.000-7, a contar del mes de septiembre de 2005.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2005. </div></div>", "i": 6542432}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "95 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-95 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES DE BOLETAS ELECTRONICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "EMISORES", "BOLETAS ELECTRONICAS", "AUTORIZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-28", "doble_articulado": false, "id_norma": "242611", "numero_fuente": "38278", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-04", "vigencias": [{"desde": "2005-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-04", "fin_vigencia": ""}, "vigencias_version_norma":