{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 20, DE 1989 </div></div>", "i": 6097345}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 20 de 31 de enero de 1989 se ha aprobado a la Escuela Especial E No. 66 de Vallenar, III Regi&#xF3;n de Atacama, un plan de estudio especial de orientaci&#xF3;n laboral para alumnos con deficiencia mental, que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de 4 a&#xF1;os, a contar desde 1989.-</div><br></div>", "i": 6097346}, {"t": "<div><div class=\"p\">Adelchi Colombo Breschi, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6097347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "20 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-20 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No.20, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-31", "doble_articulado": false, "id_norma": "94532", "numero_fuente": "33316", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-07", "vigencias": [{"desde": "1989-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1998-03-06", "fecha_version": "1989-03-07", "fecha_actualizacion_texto": "1989-03-07", "tipo_tratado": ""}, "alertas":