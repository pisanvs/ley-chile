{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10384356}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 813, de fecha 24 de mayo de 2022, de esta Secretar&#xED;a Regional, modific&#xF3; las resoluciones exentas N&#xB0;s. <a href=\"https://www.leychile.cl/Navegar?idNorma=1128018&amp;idParte=&amp;idVersion=\">143</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1128019&amp;idParte=&amp;idVersion=\">144</a>, ambas de 9 de septiembre de 2019, de la Secretar&#xED;a Regional de Transportes y Telecomunicaciones de Valpara&#xED;so, ampli&#xF3; el Reconocimiento Oficial a Escuela de Conductores Profesional denominada Olivares, para impartir cursos conducentes a la obtenci&#xF3;n de licencias de conductor profesional Clase A3, incorporando la autorizaci&#xF3;n para la sede ubicada en calle 5 Norte N&#xB0; 971, comuna de Vi&#xF1;a del Mar.- </div><div class=\"p\">&nbsp; </div></div>", "i": 10384357}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Maritza del Carmen Robledo Fern&#xE1;ndez, Secretaria Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Valpara&#xED;so (S).</div><br></div>", "i": 10384358}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "813 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-813 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2226503", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-05-24", "doble_articulado": false, "id_norma": "1185624", "numero_fu