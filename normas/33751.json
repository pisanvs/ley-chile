{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7195343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 207 de 12 de septiembre de 1994, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se adjudic&#xF3; a don Felipe Eduardo Alc&#xE1;ntara Perojinowski, la concesi&#xF3;n para operar, hasta el d&#xED;a 2 de diciembre de 1998 a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en camino a Los Lagos, Kil&#xF3;metro 3, de la comuna de Panguipulli, X Regi&#xF3;n, Rol de Propiedad N&#xB0; 182-2 54, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.- </div></div>", "i": 7195344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Oscar Silva Ortiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 7195345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "207", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-207"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REVISION TECNICA", "PLANTA REVISION TECNICA", "VEHICULOS MOTORIZADOS", "PANGUIPULLI", "DECIMA REGION", "FELIPE EDUARDO ALCANTARA PEROJINOWSKI", "CONCESION REVISION TECNICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-12", "doble_articulado": false, "id_norma": "33751", "numero_fuente": "35029", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-11-30", "vi