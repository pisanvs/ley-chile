{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6275261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;647, de 29 de febrero del 2000, se expropiaron los lotes de terreno N&#xBA;10 y 54, superficies 578 y 76 m&#xB2;, roles de aval&#xFA;o 231-35 y 232-6, comuna de Villa Alegre, para la obra Camino Mejoramiento Ruta L-19, sector Cruce Long. (Villa Alegre) Esperanza y se acord&#xF3; precio de las indemnizaciones con sus propietarios, Arosto Antonio Sep&#xFA;lveda y Olivia Mercedes Ilufi Vald&#xE9;s, ascendentes a las cantidades de $1.224.348, lote N&#xBA;10 y $295.036, lote N&#xBA;54. </div></div>", "i": 6275262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6275263}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "647", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-647"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-29", "doble_articulado": false, "id_norma": "168649", "numero_fuente": "36663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-15", "vigencias": [{"desde": "2000-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-05-15", "fecha_version": "2000-05-15", "fecha_actualizacion_texto": "2000-05-15", "tipo