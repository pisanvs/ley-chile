{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10276022}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 978 de 16 septiembre 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos que indica en condiciones que se&#xF1;ala, relativas a Actividad Dieciochera Escuela Poetisa Gabriela Mistral Puerto Ays&#xE9;n, y autoriz&#xF3; a Direcci&#xF3;n del establecimiento para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - corte total de v&#xED;a en calle Manuel Rodr&#xED;guez, frente a la Escuela Poetisa Gabriela Mistral, entre calles Eusebio Ibar y Mayer, el d&#xED;a martes 14 de septiembre desde las 10:30 hrs. hasta las 12:00 hrs. </div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10276023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10276024}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "978 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-978 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2024049", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-16", "doble_articulado": false, "id_norma": "1166417", "numero_fuente": "43077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-1