{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8342510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 371, de 11 de marzo de 1999, de esta Subsecretar&#xED;a, deni&#xE9;gase la autorizaci&#xF3;n solicitada por SOCIEDAD PESQUERA COLOSO S.A., para incluir a la nave &apos;&apos;Aventurero&apos;&apos;, autorizada por resoluciones N&#xBA; 636 de 1985, N&#xBA; 357 de 1989, N&#xBA; 845 de 1993, N&#xBA; 1.153 de 1996 y N&#xBA; 370 de 1999, todas de esta Subsecretar&#xED;a, en la n&#xF3;mina de naves autorizadas para operar en la pesquer&#xED;a de Jurel, en la III y IV Regiones, se&#xF1;alados en la resoluci&#xF3;n N&#xBA; 1.133 de 1998, de esta Subsecretar&#xED;a, de conformidad con lo establecido en los informes, reglamentos y normas legales.</div><br></div>", "i": 8342511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de marzo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8342512}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "371", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-371"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-11", "doble_articulado": false, "id_norma": "133841", "numero_fuente": "36317", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-18", "vigencias": [{"desde": "1999-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"in