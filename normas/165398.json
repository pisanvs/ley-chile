{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 534, DE 1985 </div></div>", "i": 6264540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 742, de 14 de Noviembre de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 534, de 1985, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a Conservera San Francisco Ltda., para instalar y operar una planta de conserva en Limache, en orden a incluir en el numeral 3&#xB0;, entre los recursos que esa sociedad puede Utilizar como materia prima en dicha planta, los siguientes: lapa, jaiba, caracol, sardina, sardina espa&#xF1;ola y chocha.</div><br></div>", "i": 6264541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de Noviembre de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6264542}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "742", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-742"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 534, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-14", "doble_articulado": false, "id_norma": "165398", "numero_fuente": "32347", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-14", "vigencias": [{"desde": "1985-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-14", "fin_vigencia": "",