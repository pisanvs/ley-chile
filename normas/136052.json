{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 80, DE 1988 </div></div>", "i": 6167488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 80 de 19 de abril de 1988 se ha aprobado, a contar del a&#xF1;o escolar 1988, al Liceo A - 119 de la Corporaci&#xF3;n Municipal de Educaci&#xF3;n de Talagante, provincia de Talagante, Region Metropolitana, un plan de estudio especial para 3&#xB0; y 4&#xB0; a&#xF1;o medio human&#xED;stico - cient&#xED;fico de Adultos.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para la asignatura de Computaci&#xF3;n e Inform&#xE1;tica.</div><br></div>", "i": 6167489}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago 28 de abril de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6167490}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "80 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-80 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 80, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-19", "doble_articulado": false, "id_norma": "136052", "numero_fuente": "33068", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-11", "vigencias": [{"desde": "1988-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-05-11", "fin_vigencia": "", "tipo_versi