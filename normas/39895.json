{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION EXENTA N&#xB0; O-1647, DE 1991 N&#xFA;m. O-1657 exenta.- Santiago, 15 de Octubre de 1991.-</div><div class=\"p\">&nbsp; &nbsp; Visto:</div><div class=\"p\">&nbsp; &nbsp; a) La Resoluci&#xF3;n Exenta N&#xB0; O-1647, de este Servicio; y</div><div class=\"p\">&nbsp; &nbsp; Lo dispuesto en los art&#xED;culos 5, 7, 8, 10 y 93 letra i) de la Ley N&#xB0; 18.556.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6025286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1. Modif&#xED;case el numeral 4&#xB0; de la Resoluci&#xF3;n N&#xB0; O-1647/91, en el sentido que la Junta Electoral de Curic&#xF3; mantendr&#xE1; jurisdicci&#xF3;n sobre las Circunscripciones Electorales de Curic&#xF3;, Romeral, Rauco y Teno.</div><br></div>", "i": 6025287}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Andr&#xE9;s Merino Espi&#xF1;eira, Director Subrogante.</div><br></div>", "i": 6025288}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1657 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1657 EXENTA"}, {"tipo": "3", "numero": "O-1647 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1647 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "MODIFICA RESOLUCION EXENTA N° O-1647, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUNTA ELECTORAL CURICO", "CIRCUNSCRIPCION ELECTORAL", "CURICO", "CIRCUNSCRIPCION ELECTORAL ROMERAL", "CIRCUNSCRIPCION ELECTORAL RAUCO", "CIRCUNSCRIPCION", "ELECTORAL TENO", "TERRITORIO JURISDICCIONAL", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-15", "d