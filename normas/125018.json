{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA</div><br><br></div>", "i": 8335116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.186 de 31 de Octubre de 1988, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga en un a&#xF1;o, a contar del 03 de julio de 1988, el plazo fijado en el numeral 6&#xB0; de la resoluci&#xF3;n No. 613, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; para desarrollar actividades pesqueras de cultivo a Sociedad Gracilaria Quenuir Limitada. R.U.T. No.</div><div class=\"p\">79.601.430-k, domiciliada en Santiago, en raz&#xF3;n de haberse acreditado la ocurrencia de un caso fortuito. </div></div>", "i": 8335117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de Octubre de 1988.- Roberto Cabezas Bello Subsecretario de Pesca.</div><br></div>", "i": 8335118}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1186", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1186"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-10-31", "fecha_derogacion": "1995-07-29", "doble_articulado": false, "id_norma": "125018", "numero_fuente": "33224", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-11-18", "vigencias": [{"desde": "1995-07-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1988-11-18", "hasta": "1995-07-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}]