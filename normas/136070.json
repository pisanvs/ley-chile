{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 97, DE 1988 </div></div>", "i": 6167536}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 97 de 29 de abril de 1988 se ha aprobado con car&#xE1;cter experimental, a contar del a&#xF1;o escolar 1988 y por 4 a&#xF1;os, un plan de estudio de Capacitaci&#xF3;n Laboral para educandos con d&#xE9;ficit intelectual, para ser aplicados por la Escuela Especial &quot;Padre Luis Guanella&quot; de Batuco, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban los programas de estudio correspondientes y se dan normas de evaluaci&#xF3;n. </div></div>", "i": 6167537}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de Mayo de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6167538}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "97 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-97 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 97, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-29", "doble_articulado": false, "id_norma": "136070", "numero_fuente": "33072", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-16", "vigencias": [{"desde": "1988-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-05-16", "fin_vigencia": "", "t