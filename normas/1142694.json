{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xB0; 4.012 EXENTA, DE 2019</div></div>", "i": 10103345}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 322, de 7 de febrero de 2020, de esta Subsecretar&#xED;a, rectif&#xED;quese el resuelvo 1&#xB0; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1140981&amp;idVersion=2020-02-25\">resoluci&#xF3;n exenta N&#xB0; 4.012, de 2019</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; las toneladas que podr&#xE1;n capturar durante el a&#xF1;o 2020 los titulares de licencias transables de pesca clase A, en el sentido de reemplazar la tabla del recurso Merluza com&#xFA;n en su unidad pesquer&#xED;a de la Regi&#xF3;n de Coquimbo al paralelo 41&#xB0; 28, 6&apos; L.S., por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/105422.jpg\"></div><br></div>", "i": 10103346, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de febrero de 2020.- Jos&#xE9; Pedro N&#xFA;&#xF1;ez Barruel, Subsecretario de Pesca y Acuicultura (S).</div><br></div>", "i": 10103347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "322 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-322 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA RESOLUCIÓN N° 4.012 EXENTA, DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1730631", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-02-07", "doble_articulad