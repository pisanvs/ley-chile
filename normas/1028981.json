{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xBA; 6.996 EXENTA, DE 2011</div></div>", "i": 9173483}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo se&#xF1;alado en el art&#xED;culo 48 de la ley N&#xBA; 19.880, el Servicio Nacional de Capacitaci&#xF3;n y Empleo cumple con informar que mediante resoluci&#xF3;n exenta N&#xBA; 6.996, de 8 de agosto de 2011, se aprobaron las Instrucciones para la Ejecuci&#xF3;n del &quot;Programa de Capacitaci&#xF3;n para trabajadores de Flota de la Industria Pesquera de la Regi&#xF3;n de Tarapac&#xE1;, a&#xF1;o 2011&quot;. El texto completo de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio, www.sence.cl.- </div><br></div>", "i": 9173484}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Miguel Bergu&#xF1;o Ca&#xF1;as, Director Nacional.</div></div>", "i": 9173485}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6996 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6996 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO RESOLUCIÓN Nº 6.996 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-08-08", "doble_articulado": false, "id_norma": "1028981", "numero_fuente": "40048", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-08-30", "vigencias": [{"desde": "2011-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-08-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-08-30", "fin_vigencia": "", "tipo_version": "3