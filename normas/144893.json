{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6195758}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 530, del 24 de Diciembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo, se autoriza a don Nazareno Carvajal Abbett de la Torre para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6195759}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 24 de Diciembre de 1987.- Jorge Vargas Borcosky, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6195760}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "530 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-530 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-24", "doble_articulado": false, "id_norma": "144893", "numero_fuente": "32708", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-26", "vigencias": [{"desde": "1987-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-26", "fin_vigencia": "", "t