{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 971 de 24 de Octubre de 1994 de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la</div><div class=\"p\">Resoluci&#xF3;n N&#xB0; 808 de 1994, de esta Subsecretar&#xED;a, s&#xF3;lo</div><div class=\"p\">en cuanto se caduc&#xF3; el permiso extraordinario de pesca</div><div class=\"p\">otorgado a la SOCIEDAD PESCA MARINA LIMITADA, R.U.T. N&#xB0;</div><div class=\"p\">89.389.200-1, mediante Resoluci&#xF3;n N&#xB0; 1338, de 1992, de</div><div class=\"p\">esta Subsecretar&#xED;a, por haberse acreditado el pago de la</div><div class=\"p\">cuota anual, correspondiente a 1993, a que se refiere el</div><div class=\"p\">art&#xED;culo 46 de la Ley antes citada.</div><br></div>", "i": 8295031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 24 de Octubre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "971", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-971"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "SOCIEDAD PESCA", "MARINA LIMITADA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-10-24", "doble_articulado": false, "id_norma": "35948", "numero_fuente": "35008", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-11-05", "vigencias": [{"desde": "1994-11