{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xBA; 2.112, de 18 de diciembre de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; modif&#xED;case la Resoluci&#xF3;n N&#xBA; 1.965, de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD COMERCIAL MUNDO MARINO LIMITADA, para realizar faenas de captura de 8 ejemplares juveniles vivos de Lobo marino com&#xFA;n, en el litoral de la V Regi&#xF3;n, en el sentido que indica: Prorr&#xF3;gase el plazo se&#xF1;alado en el Numeral Primero de la Resoluci&#xF3;n citada precedentemente hasta el 31 de diciembre de 1996, plazo que comenzar&#xE1; a regir a contar de la fecha de la presente Resoluci&#xF3;n.</div><br></div>", "i": 8298880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de diciembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2112", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2112"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "SOCIEDAD COMERCIAL MUNDO", "MARINO LIMITADA", "CAPTURA", "LOBO MARINO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-18", "doble_articulado": false, "id_norma": "37673", "numero_fuente": "35650", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-26", "vigencias": [{"desde": "1996-12-26", "hasta": "", "tipo_version": "