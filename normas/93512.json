{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 3.434, DE 1988 </div></div>", "i": 7227875}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 3.434, de fecha 21 de diciembre de 1988, de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Altos Estudios de la Comunicaci&#xF3;n y Educaci&#xF3;n EACE de Santiago, aprobadas por resoluci&#xF3;n exenta de educaci&#xF3;n No. 2.377 de 1985, las que podr&#xE1;n aplicarse a contar del segundo semestre 1988.</div><br></div>", "i": 7227876}, {"t": "<div><div class=\"p\">Santiago, 15 de Febrero de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7227877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3434 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3434 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 3.434, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-21", "doble_articulado": false, "id_norma": "93512", "numero_fuente": "33312", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-02", "vigencias": [{"desde": "1989-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MOD