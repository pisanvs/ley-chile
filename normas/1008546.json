{"html": [{"t": "<div><br><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE CURACAV&#xCD;</div></div>", "i": 8811610}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA; 6.316, del 16 de octubre de 2009, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, rectific&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1003546&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.968, de 9 de junio de 2009</a>, que aclar&#xF3; y complement&#xF3; la resoluci&#xF3;n exenta del Servicio Agr&#xED;cola y Ganadero N&#xBA; 2.331, de 9 de noviembre de 1987, que aprob&#xF3; el Estudio T&#xE9;cnico de Divisi&#xF3;n de los Derechos de Aprovechamiento de Aguas del predio &quot;Fundo Alhu&#xE9;&quot; y del Proyecto de Parcelaci&#xF3;n &quot;Alhu&#xE9;&quot;, ubicado en la Comuna de Curacav&#xED;, Regi&#xF3;n Metropolitana, en el sentido de establecer las reales coordenadas de la elevaci&#xF3;n N&#xBA; 3.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; ley N&#xBA; 18.377.</div><br></div>", "i": 8811611}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div><br></div>", "i": 8811612}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6316 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6316 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE CURACAVÍ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-16", "doble_articulado