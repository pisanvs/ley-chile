{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Fija la fecha en que comenzar&#xE1;n a elegir las modificaciones introducidas a la Lei de Elecciones.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1836.- Santiago, a 13 de Febrero de 1906.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente:</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Las modificaciones a la Lei de Elecciones a que se refiere la lei n&#xFA;mero 1806, de fecha del 7 del corriente mes. comenzar&#xE1;n a rejir desde su publicacion en el Diario Oficial.</div><br></div>", "i": 8274776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Miguel Cruchaga.</div><br></div>", "i": 8274777}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1836", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1836"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "FIJA FECHA EN QUE COMENZARAN A ELEGIR LAS MODIFICACIONES INTRODUCIDAS A LA LEI DE ELECCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELECCIONES", "LEY DE ELECCIONES", "VIGENCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-02-13", "doble_articulado": false, "id_norma": "22948", "numero_fuente": "8429", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-02-13", "vigencias": [{"desde": "1906-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1