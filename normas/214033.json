{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P No. 254 de 10 de octubre de 1991, se expropiaron los lotes N&#xBA;s. 1,2,3,4, 5-A, 5-B y 6, superficies 1.003 m2., 1.657 m2. 688 m2., 918 m2., 919 m2., 225 m2. y 242 m2., roles de aval&#xFA;o 166-155, 166-165, 166-166, 166-169, 166-170 y 166-171, respectivamente, Comuna de Lanco, para la obra Camino Lanco Panguipulli, sector Lanco Puente Salto de Agua, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Enrique Nahuelp&#xE1;n Caniulaf, Julio L&#xF3;pez Nahuelp&#xE1;n, Egidia Pononcura Nahuelp&#xE1;n, Juana Nahuelp&#xE1;n Huichalaf y Silvia Z. Nahuelp&#xE1;n Rivas, ascendente a $ 174.898.- $ 195.662.-, $ 145.766.-, $ 139.039.-, $ 139.071.-, $ 124.822.- y $ 125.916.</div><br></div>", "i": 7303103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7303104}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "254", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-254"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-10", "doble_articulado": false, "id_norma": "214033", "numero_fuente": "34117", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-15", "vigencias": [{"desde": "1991-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-15", "fin_vigencia": "", "t