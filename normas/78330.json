{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308718}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 649, de 15 de Julio de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n No. 765, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a EXPORTADORA DE PRODUCTOS DEL MAR LIMITADA, R.U.T. No. 79.624.640-5, domiciliada en Gran Avenida No. 7321, Antofagasta, para operar tres establecimientos de cultivo en tres sectores, que en dicha resoluci&#xF3;n se indican, ubicados en Caleta Err&#xE1;zuriz, Comuna y Provincia de Antofagasta, II Regi&#xF3;n, por renuncia total de su titular.</div><br></div>", "i": 8308719}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 15 de Julio de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8308720}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "649", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-649"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-07-15", "doble_articulado": false, "id_norma": "78330", "numero_fuente": "34323", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-23", "vigencias": [{"desde": "1992-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin