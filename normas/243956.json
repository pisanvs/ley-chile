{"html": [{"t": "<div><div class=\"p\">LEY NUM. 14.983</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A ADRIANA MORA BRIONES </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6548343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Adriana Mora Briones una pensi&#xF3;n mensual de E&#xBA; 15.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que importe el cumplimiento de esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Ministerio de Hacienda.</div><br></div>", "i": 6548344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintinueve de Octubre de mil novecientos sesenta y dos.- JORGE ALESSANDRI RODRIGUEZ.- Luis Mackenna S.</div><br></div>", "i": 6548345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14983", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14983"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA ADRIANA MORA BRIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1962-10-29", "doble_articulado": false, "id_norma": "243956", "numero_fuente": "25390", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1962-11-12", "vigencias": [{"desde": "1962-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia"