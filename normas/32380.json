{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 7194250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 31, de 19 de Abril de 1995, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se adjudic&#xF3; a &quot;Fernando Moreno S&#xE1;nchez&quot; la concesi&#xF3;n para operar, por un plazo de cuatro meses, a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en Avenida Ferm&#xED;n Vivaceta N&#xB0; 798, de la comuna de Independencia, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de veh&#xED;culos a que se refiere el inciso segundo del art&#xED;culo 7&#xB0; del Decreto Supremo N&#xB0; 156/90 del Ministerio de Transportes y Telecomunicaciones, en la forma, modo y condiciones que se se&#xF1;alan en el contrato que se aprueba.- </div></div>", "i": 7194251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Antonio Dourthe Castrill&#xF3;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 7194252}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "31", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-31"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "SANTIAGO", "PLANTA REVISION TECNICA", "REGION METROPOLITANA", "FERNANDO MORENO SANCHEZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-19", "doble_articulado": false, "id_norma": "32380", "numero_fuente": "35191"