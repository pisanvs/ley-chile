{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6302988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 89 de 8 septiembre 2000, Serviu Regi&#xF3;n de Tarapac&#xE1;, conforme a decretos leyes N&#xBA;1.523 de 1976 y N&#xBA;2.186 de 1978 y decretos supremos N&#xBA;355 de 1976, 63 de 1996 y decreto N&#xBA;120 de 2000, todos de Vivienda y Urbanismo, dispuso expropiaci&#xF3;n total del inmueble ubicado en Iquique, calle Luis Jaspard N&#xBA;2595, Rol de Aval&#xFA;o N&#xBA;139-04, de presunto dominio de don Juan Carlos Ram&#xF3;n Barra Rivera. Comisi&#xF3;n integrada por peritos se&#xF1;ores Jorge Romero Ossio, Ricardo Muixi Decona, Constructores Civiles y Santiago Vallejos Medic, Arquitecto, seg&#xFA;n Informe de Tasaci&#xF3;n de 6 de agosto 2000, fij&#xF3; monto provisional de indemnizaci&#xF3;n en $16.162.491.- pagadera al contado.</div><br></div>", "i": 6302989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Iv&#xE1;n Figueroa Llona, Director Serviu Regi&#xF3;n de Tarapac&#xE1;.</div><br></div>", "i": 6302990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "89", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-89"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE TARAPACÁ"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-08", "doble_articulado": false, "id_norma": "176219", "numero_fuente": "36777", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-02", "vigencias": [{"desde": "2000-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio