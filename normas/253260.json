{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6582815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 461, de fecha 31 de julio de 2006, se expropiaron los lotes de terrenos N&#xBA;s.</div><div class=\"p\">50-A y 51-A, superficies 435 y 315 m2, respectivamente, rol N&#xBA; 411-37, comuna de Los Muermos, X Regi&#xF3;n, para la obra &quot;Camino Ruta V-60, Sector El Tepual-Las Quemas-Los Muermos, Km. 0,00000 al Km. 32,27442&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario &#xD3;scar Ernesto Harvez Garc&#xED;a, ascendente a la cantidad de $626.830. </div></div>", "i": 6582816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6582817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "461 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-461 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-31", "doble_articulado": false, "id_norma": "253260", "numero_fuente": "38566", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-15", "vigencias": [{"desde": "2006-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-09-15", "fecha_version": "2006-09-15", "fecha_actualizacion_texto": "2006-