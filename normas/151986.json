{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;97, DE 1999</div><br><br></div>", "i": 8357105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA;97, de fecha 17 de diciembre de 1999, se aprob&#xF3; la Disoluci&#xF3;n Voluntaria de la Cooperativa de Vivienda y Servicios Habitacionales Villa Malalhue Ltda., de San Bernardo, que consta en la escritura p&#xFA;blica suscrita con fecha 11 de noviembre de 1999, ante el Notario P&#xFA;blico de San Bernardo do&#xF1;a Lylian Jacques Parraguez. </div></div>", "i": 8357106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8357107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "97", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-97"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº97, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-17", "doble_articulado": false, "id_norma": "151986", "numero_fuente": "36569", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-22", "vigencias": [{"desde": "2000-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-22", "fin_vigencia": "", "tipo_ver