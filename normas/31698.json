{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8289054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 995, de 21 de Octubre de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o a contar del 30 de septiembre de 1992, el plazo otorgado a do&#xF1;a ANDREA XIMENA JARA ITURRA, R.U.T. N&#xB0; 8.327.154-K, para instalar y operar un establecimiento de cultivo en un sector del Lago Tepuhueico, comuna de Chonchi, Provincia de Chilo&#xE9;, X Regi&#xF3;n, autorizada por la resoluci&#xF3;n N&#xB0; 1126, de 1991, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 8289055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 21 de Octubre de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8289056}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "995", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-995"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMPLIACION", "PLAZO", "PESCA", "CHILOE", "DECIMA REGION", "ANDREA XIMENA JARA ITURRA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-21", "doble_articulado": false, "id_norma": "31698", "numero_fuente": "34418", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-17", "vigencias": [{"desde": "1992-11-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-17", "fin_vigencia": ""}, "vigencias_version_n