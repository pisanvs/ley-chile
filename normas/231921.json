{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6502950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.854, de 14 de octubre de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIAL H Y M S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Camino al Fuerte N&#xBA; 78, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-Enfriado, Fresco-Refrigerado, Congelado, Seco-Salado, Ahumado, Conserva, Harina y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extactada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 168 de 1990, de esta Subsecretar&#xED;a, en virtud de la carta renuncia citada en Visto, y del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6502951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de octubre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6502952}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2854 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2854 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-14", "doble_articulado": false, "id_norma": "231921", "numero_fuente": "37998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-29", "vigencias": [{"desde": "2004-10-29", "hasta": "", "tipo_version": "3", "tipo_version_s"