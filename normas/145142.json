{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6196540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta No. 150, de 12 de Febrero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Arnoldo Mart&#xED;nez Ch&#xE1;vez, Luis Rubi Aparicio y Candelar&#xED;a Monsalve Jaramillo para efectuar el servicio de taxi colectivo urbano de la l&#xED;nea No. 10 &quot;Corvi Regional - Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n exenta No. 12, de 04 de Enero de 1985 y modificado por resoluci&#xF3;n exenta No. 486, de 04 de Noviembre de 1985, de esta Secretar&#xED;a Regional. </div></div>", "i": 6196541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6196542}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "150 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-150 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-12", "doble_articulado": false, "id_norma": "145142", "numero_fuente": "32714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-05", "vigencias": [{"desde": "1987-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-05", "fin_