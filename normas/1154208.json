{"html": [{"t": "<div><div class=\"p\">AMPL&#xCD;A FACULTADES DELEGADAS AL GOBERNADOR MAR&#xCD;TIMO DE ANTOFAGASTA</div></div>", "i": 10190103}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n D.G.T.M. y M.M. exenta N&#xB0; 12.240/3 Vrs., del 18 de diciembre de 2020, ampl&#xED;a facultades delegadas al Gobernador Mar&#xED;timo de Antofagasta para los efectos que se indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10190104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de diciembre de 2020.- Paul Miguras Silva, Teniente 2&#xB0; AB, Jefe Depto. Abastecimiento.</div><div class=\"p\"> </div><br></div>", "i": 10190105}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3 EXENTA"}, {"tipo": "3", "numero": "12240/3 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-12240/3 EXENTA"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "AMPLÍA FACULTADES DELEGADAS AL GOBERNADOR MARÍTIMO DE ANTOFAGASTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1874013", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-18", "doble_articulado": false, "id_norma": "1154208", "numero_fuente": "42846", "tipo_version": "3", "tipo_version_s": "Única