{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 11,331</div><br><div class=\"p\">ABONA, POR GRACIA, A DON JOSE MARIA MELO MERA EL TIEMPO QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6931137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Ab&#xF3;nanse, por gracia y para todos los efectos legales, a don Jos&#xE9; Mar&#xED;a Melo Mera, los 9 a&#xF1;os y 4 meses servidos en la ense&#xF1;anza privada. </div></div>", "i": 6931138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diez de Octubre de mil novecientos cincuenta y tres.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Felipe Herrera L.</div><br></div>", "i": 6931139}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11331", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11331"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ABONA, POR GRACIA, A DON JOSE MARIA MELO MERA EL TIEMPO\nQUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1953-10-10", "doble_articulado": false, "id_norma": "285620", "numero_fuente": "22691", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1953-11-06", "vigencias": [{"desde": "1953-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1953-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v