{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la ereccion en Melipilla de un monumento a Ignacio Serrano</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,638.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275429}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase la ereccion en la plaza de la ciudad de Melipilla, de un monumento, costeado por suscricion popular, i destinado a honrar la memoria del h&#xE9;roe Ignacio Serrano.</div><br></div>", "i": 8275430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 12 de Febrero de 1912.- RAMON BARROS LUCO.- Ismael Tocornal.</div><br></div>", "i": 8275431}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2638", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2638"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA ERECCION EN MELIPILLA DE UN MONUMENTO A IGNACIO SERRANO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["IGNACIO SERRANO", "MELIPILLA", "MONUMENTO", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-02-12", "doble_articulado": false, "id_norma": "23399", "numero_fuente": "10208", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-02-17", "vigencias": [{"desde": "1912-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc