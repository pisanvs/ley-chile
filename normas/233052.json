{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6506916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;620 de 29 de octubre de 2004 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA;2.186 de 1978, del Lote N&#xBA;244 correspondiente al inmueble ubicado en Avenida Santa Rosa N&#xBA;5299, presunto Rol de Aval&#xFA;o N&#xBA;5040-43, comuna de San Miguel, aparente dominio de Marta del Carmen Belmar Morales. Comisi&#xF3;n integrada por peritos Mufida Abuawad El&#xED;as, Arquitecto; Alfredo Irizarri Valderrama, Arquitecto, y Carmen P.</div><div class=\"p\">R&#xED;os Marcuello, Ingeniero Civil. Seg&#xFA;n informe de fecha 20 de septiembre de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $24.217.300.- pagadera al contado. </div></div>", "i": 6506917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6506918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "620", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-620"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-29", "doble_articulado": false, "id_norma": "233052", "numero_fuente": "38025", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-01", "vigencias": [{"desde": "2004-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"