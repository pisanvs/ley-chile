{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;94, DE 1999</div><br><br></div>", "i": 6224191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA;94, de fecha 9 de diciembre de 1999, se aprob&#xF3; la reforma parcial al estatuto de la Cooperativa de Vivienda y Servicios Habitacionales Petrohu&#xE9; Limitada, de la ciudad de Santiago, en los t&#xE9;rminos de que da testimonio la escritura p&#xFA;blica suscrita con fecha 13 de octubre de 1999, ante el notario p&#xFA;blico de la ciudad de Valpara&#xED;so, Sonia Ravanal Toro.</div><br></div>", "i": 6224192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6224193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "94", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-94"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº94, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-09", "doble_articulado": false, "id_norma": "152789", "numero_fuente": "36574", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-28", "vigencias": [{"desde": "2000-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici