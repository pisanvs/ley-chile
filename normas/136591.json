{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 37, DE 1988 </div></div>", "i": 6169273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 37, de 15 de Marzo de 1988, se ha aprobado para el Liceo Polit&#xE9;cnico &quot;Mar&#xED;a Ward&quot;, de la comuna de San Ignacio, provincia de &#xD1;uble, VIII Regi&#xF3;n del B&#xED;o B&#xED;o, un plan y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico-Profesional, que se aplicar n gradualmente a contar del a&#xF1;o escolar de 1988 y hasta el a&#xF1;o escolar de 1989, en la Rama y Especialidad que se indica:</div><br><div class=\"p\">Rama&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Agr&#xED;cola.</div><div class=\"p\">Especialidad&nbsp; : Pecuario.</div><br></div>", "i": 6169274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Marzo de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6169275}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "37 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-37 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 37, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-15", "doble_articulado": false, "id_norma": "136591", "numero_fuente": "33034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-30", "vigencias": [{"desde": "1988-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-30", "fin_vige