{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 82, DE 1987</div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 108.- Santiago, 19 de Agosto de 1987.- Vistos: Lo dispuesto en el Art. 4&#xB0; del Decreto Ley No. 2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7254951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n No. 82 de fecha 21 de Julio de 1987, en el sentido que se indica:</div><div class=\"p\">&nbsp; &nbsp;  - Donde dice &quot;Receptores Judiciales&quot;, debe decir &quot;Ministros de Fe&quot;.</div><br><div class=\"p\">&nbsp; &nbsp;  En lo dem&#xE1;s, mant&#xE9;ngase lo resuelto.</div><br></div>", "i": 7254952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Sergio Retamal Iglesias, Vicepresidente Ejecutivo.</div><br></div>", "i": 7254953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "108", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-108"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA RESOLUCION No. 82, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-19", "doble_articulado": false, "id_norma": "145801", "numero_fuente": "32880", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-28", "vigencias": [{"desde": "1987-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"in