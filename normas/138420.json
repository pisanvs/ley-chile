{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,851.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6175301}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados a la instrucci&#xF3;n p&#xFA;blica por don M&#xE1;ximo Torres Guti&#xE9;rrez, conc&#xE9;dese, por gracia, a su viuda do&#xF1;a Nieves Ram&#xED;rez, una pensi&#xF3;n mensual de veinticinco pesos ($ 25). </div></div>", "i": 6175302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiocho de enero de mil novecientos catorce.- Ramon Barros Luco.- Enrique A. Rodr&#xED;guez. </div></div>", "i": 6175303}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2851", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2851"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-01-28", "doble_articulado": false, "id_norma": "138420", "numero_fuente": "10790", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-02-04", "vigencias": [{"desde": "1914-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1914-02-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi