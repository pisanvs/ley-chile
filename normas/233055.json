{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6506925}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 633, de 3 de noviembre de 2004, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA; 2.186, de 1978, del Lote 103 correspondiente a parte del inmueble ubicado en Santa Rosa N&#xBA;4588, presunto Rol de aval&#xFA;o N&#xBA;4538-4, comuna de San Joaqu&#xED;n, aparente dominio de Soc. Indust. y Comercial Noucamp S.A. Comisi&#xF3;n integrada por peritos Luisa Aracena Hern&#xE1;ndez, constructor civil; Norman Calder&#xF3;n Pontiggia, ingeniero agr&#xF3;nomo, y Mar&#xED;a Isabel R&#xED;os Marcuello, arquitecta. Seg&#xFA;n informe de fecha 21 de septiembre de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $3.682.120, pagadera al contado.</div><br></div>", "i": 6506926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6506927}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "633", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-633"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-03", "doble_articulado": false, "id_norma": "233055", "numero_fuente": "38025", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-01", "vigencias": [{"desde": "2004-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ún