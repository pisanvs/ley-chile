{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298429}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.851, de 29 de octubre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las Resoluciones N&#xB0; 493, de 1992, N&#xB0; 728, de 1994, N&#xB0; 1741 y N&#xB0; 1893, ambas de 1995, todas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA COLOMBA S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Colomba IV&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xB0; 18.892 y sus modificaciones.</div><br></div>", "i": 8298430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 29 de octubre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298431}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1851", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1851"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "PESQUERA COLOMBA S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-10-29", "fecha_derogacion": "1998-01-05", "doble_articulado": false, "id_norma": "37494", "numero_fuente": "35604", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-10-31", "vigencias": [{"desde": "1998-01-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-10-31", "hasta": "1998-01-04", "tipo_version": "0", "tipo_vers