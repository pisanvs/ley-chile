{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION EXENTA </div></div>", "i": 7344888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 69 de 8 de junio de 2007, deroga resoluci&#xF3;n exenta.</div><div class=\"p\">&nbsp; &nbsp;  Der&#xF3;gase resoluci&#xF3;n exenta N&#xBA; 6.145, del 26 de diciembre de 1995, de esta Direcci&#xF3;n Nacional.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio de 2007.</div><br></div>", "i": 7344889}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "69 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-69 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA RESOLUCION EXENTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-08", "doble_articulado": false, "id_norma": "261706", "numero_fuente": "38788", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-06-14", "vigencias": [{"desde": "2007-06-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-06-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-06-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CMV", "fecha_ingres