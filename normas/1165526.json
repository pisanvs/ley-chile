{"html": [{"t": "<div><div class=\"p\">NOMBRA ALCALDE DE MAR AD-HON&#xD3;REM A LA PERSONA QUE SE INDICA</div></div>", "i": 10271429}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n D.G.T.M. y M.M. ordinario N&#xB0; 1120/95 Vrs., del 9 de septiembre de 2021, nombra Alcalde de Mar Ad-Hon&#xF3;rem a la persona que se indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10271430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de septiembre de 2021.- Por orden del Sr. Director General, Francisco Garc&#xED;a-Huidobro Correa, Capit&#xE1;n de Nav&#xED;o, Subdirector.- Cristi&#xE1;n Pfeifer Rojas, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.</div><div class=\"p\"> </div><br></div>", "i": 10271431}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "95", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-95"}, {"tipo": "3", "numero": "1120/95", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1120/95"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "NOMBRA ALCALDE DE MAR AD-HONÓREM A LA PERSONA QUE SE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2013593", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-09", "doble_articulado": false, "id_norma": "1165526", "numero_fuente": "4306