{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 368, DE 1992 </div></div>", "i": 7161736}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 368 de 28 de Octubre de 1992, se ha complementado el plan especial de estudio que aplica el Colegio Saint Margaret&apos;s de Vi&#xF1;a del Mar, para 3&#xB0; y 4&#xB0; de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, aprobado por decreto supremo exento de Educaci&#xF3;n N&#xB0; 133, de 1990, con el siguiente Plan Electivo que se aplicar&#xE1; progresivamente en los a&#xF1;os escolares 1992 y 1993, en los cursos antes indicados.</div><br><br></div>", "i": 7161737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 10 Marzo 1993.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161738}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "368 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-368 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 368, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO SAINT MARGARET'S", "VI A DEL MAR", "PLANES", "ESTUDIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-28", "doble_articulado": false, "id_norma": "21085", "numero_fuente": "34537", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-08", "vigencias": [{"desde": "1993-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-04-08", "fin_vigencia": "", "tipo_version": "