{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6035634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto&nbsp; MOP. N&#xBA; 295, de 31 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s. 27-D, 28-A, 47-A, 47-B y 47-C, superficies 637 m&#xB2;., 1.200 m&#xB2;., 237 m&#xB2;., 1.620 m&#xB2;. y 2.364 m&#xB2;., roles de aval&#xFA;o 602-5 y 618-15, comuna de Tom&#xE9;, para la obra Camino Acceso Norte a Concepci&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Roberto Salas Salas y Juan Inzunza Bahamondes, ascendente a las cantidades de $767.976.- para los lotes 27-D y 28-A; $29.037.- para el lote 47-A y $517.920.- para los lotes 47-B y 47-C.-</div><br></div>", "i": 6035635}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6035636}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "295", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-295"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "INDEMNIZACION", "TOME", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "71174", "numero_fuente": "45755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-02", "vigencias": [{"desde": "1997-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [