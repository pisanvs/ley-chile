{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,961, que concede derecho a jubilar a don Alberto Roman</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,961.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5957587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, al Director i Profesor del Instituto Comercial de Talcahuano, don Alberto Roman A., el derecho a jubilar con una pension de $ 12,000 anuales.</div><br></div>", "i": 5957588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de Julio de 1923.- ARTURO ALESSANDRI.- Alcib&#xED;ades Rold&#xE1;n.</div><br></div>", "i": 5957589}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3961", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3961"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "LEI NUM. 3,961, QUE CONCEDE DERECHO A JUBILAR A DON ALBERTO ROMAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ALBERTO ROMAN", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-07-09", "doble_articulado": false, "id_norma": "24367", "numero_fuente": "13623", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-07-11", "vigencias": [{"desde": "1923-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1923-07-11", "fi