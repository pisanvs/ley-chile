{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5844173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de diciembre de 1996, fue de 6,83% anual.</div><br></div>", "i": 5844174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, diciembre 20 de 1996.- Jorge Court Larenas, Ministro de Fe Subrogante.</div><br></div>", "i": 5844175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA DE INTERES PROMEDIO", "CAPTACIONES", "OPERACIONES CREDITO DE DINERO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-20", "doble_articulado": false, "id_norma": "1446", "numero_fuente": "35651", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-27", "vigencias": [{"desde": "1996-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-12-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1996-12-27", "fecha_actualizacion_texto": "1996-12-27", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5844173}, {"n": "Artículo 1"