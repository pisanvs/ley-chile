{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 690, DE 1997</div><br><br></div>", "i": 6074168}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Supremo de Educaci&#xF3;n N&#xBA; 690 de 18 de noviembre de 1997 se ha aprobado Convenio de fecha 15 de octubre de 1997, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Molina, que rectifica el Convenio de Traspaso de la Escuela B&#xE1;sica F N&#xBA; 295 de Molina, traspasada a dicha Corporaci&#xF3;n, por Convenio aprobado por Decreto Supremo de Educaci&#xF3;n N&#xBA; 8.520, de 16 de noviembre de 1981.</div><br></div>", "i": 6074169}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de diciembre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6074170}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "690", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-690"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 690, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONVENIO DE TRASPASO", "MINISTERIO DE EDUCACION", "MUNICIPALIDAD DE MOLINA", "ESCUELA BASICA F N 295", "RECTIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-18", "doble_articulado": false, "id_norma": "86762", "numero_fuente": "35955", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-03", "vigencias": [{"desde": "1998-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos