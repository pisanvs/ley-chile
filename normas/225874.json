{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6481560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 219 de 30 de abril de 2004 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, del lote N&#xBA; 187 correspondiente a parte del inmueble ubicado en Santa Rosa 3050, presunto rol de aval&#xFA;o N&#xBA; 1720-114, comuna de San Joaqu&#xED;n, aparente dominio de Esc. Ind. Part. Jos&#xE9; S. Ossa. Comisi&#xF3;n integrada por peritos Ram&#xF3;n Rovira Baro, Constructor Civil; Alejandro R&#xED;os Salas, Arquitecto y Roberto Mu&#xF1;oz Ordenes, Ingeniero Civil. Seg&#xFA;n informe de 22 de septiembre de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $75.558.890 pagadera al contado. </div></div>", "i": 6481561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6481562}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "219", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-219"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE SEÑALA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-30", "doble_articulado": false, "id_norma": "225874", "numero_fuente": "37874", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-01", "vigencias": [{"desde": "2004-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia