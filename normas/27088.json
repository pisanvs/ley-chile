{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL DECRETO CON FUERZA DE LEY N&#xB0; 222, DE 1953</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5971412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase el inciso tercero del decreto con fuerza de ley n&#xFA;mero 222, de 30 de Julio de 1953, por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;Los Subsecretarios de Guerra, Marina y Aviaci&#xF3;n&quot;. </div></div>", "i": 5971413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, catorce de Diciembre de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- B. Videla V.</div><br></div>", "i": 5971414}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12402", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12402"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "MODIFICA EL DECRETO CON FUERZA DE LEY N° 222, DE\n1953", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "DFL 222-1953-M HACIENDA", "COMPOSICION", "CONSEJO", "CAJA DEFENSA NACIONAL", "CAPREDENA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-12-14", "doble_articulado": false, "id_norma": "27088", "numero_fuente": "23631", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-12-24", "vigencias": [{"desde": "1956-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni