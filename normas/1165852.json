{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10273237}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xB0; 815, de 10 de septiembre de 2021, se rectific&#xF3; el numeral 2&#xB0; del <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1161468&amp;idVersion=2021-10-01\">Decreto MOP Exento N&#xB0; 343, de 26 de mayo de 2021</a>, en lo relativo a la superficie del lote de terreno N&#xB0; 27, en la forma que a continuaci&#xF3;n se indica, Donde dice: 3.829 m2., Debe decir: 3.839 m2. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xB0; 2.186, de 1978. </div><div class=\"p\"> </div><br></div>", "i": 10273238, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10273239}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "815 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-815 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2015959", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-10", "doble_articulado": false, "id_norma": "1165852", "numero_fuente": "43067", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-01", "vigencias": [{"desde": "2021-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-