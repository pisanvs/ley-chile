{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,392.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 9050966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- El&#xE9;vese, por gracia, a treinta y dos pesos ($ 32), la pension mensual de que actualmente disfruta, como inv&#xE1;lido relativo, el teniente 2.o de la Armada, don Horacio Urmeneta Prieto&quot;.</div><br></div>", "i": 9050967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiseis de julio de mil novecientos dieciocho.- Juan Luis Sanfuentes.- Jorje Valdivieso Blanco. </div></div>", "i": 9050968}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3392", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3392"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-07-26", "doble_articulado": false, "id_norma": "141108", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-08-02", "vigencias": [{"desde": "1918-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-08-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-08-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "