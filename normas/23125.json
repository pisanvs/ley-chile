{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,108, que concede derecho de jubilar al Secretario del Senado don Francisco Carvallo Elizalde Lei n&#xFA;m. 2,108.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, al Secretario del Senado, don Francisco Carvallo Elizalde, el derecho de jubilar con el sueldo &#xED;ntegro asignado a dicho empleo.</div><br></div>", "i": 8274989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 10 de Julio de 1908.- PEDRO MONTT.- Rafael Sotomayor.</div><br></div>", "i": 8274990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2108", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2108"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Lei núm. 2,108, que concede derecho de jubilar al;Secretario del Senado don Francisco Carvallo Elizalde", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FRANCISCO CARVALLO ELIZALDE", "SENADO", "SECRETARIO", "JUBILACION POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-07-10", "doble_articulado": false, "id_norma": "23125", "numero_fuente": "9132", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-07-11", "vigencias": [{"desde": "1908-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {