{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7287815}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1006 de 9 de Agosto de 1995 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar de la fecha de la presente resoluci&#xF3;n el plazo otorgado a EXOSUR S.A., R.U.T. N&#xBA; 96.539.360-9, en orden a iniciar actividades pesqueras con la nave &quot;Le Crabe Tambour&quot;, autorizadas mediante Resoluci&#xF3;n N&#xBA; 935, de 1989, modificada por Resoluciones N&#xBA; 1866, de 1989 y N&#xBA; 382, de 1990, todas de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 7287816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de Agosto de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 7287817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1006", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1006"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-08-09", "doble_articulado": false, "id_norma": "192055", "numero_fuente": "35259", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-09-02", "vigencias": [{"desde": "1995-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-09-02", "f