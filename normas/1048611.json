{"html": [{"t": "<div><br><div class=\"p\">APRUEBA MODIFICACI&#xD3;N DEL PLAN REGULADOR</div></div>", "i": 9331529}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Decreto n&#xFA;mero 239 exento.- Curic&#xF3;, 25 de enero de 2013.- Habi&#xE9;ndose cumplido con la tramitaci&#xF3;n administrativa, ordenada realizar en el punto segundo de la parte resolutiva del decreto exento N&#xBA; 1.865, de fecha 23 de julio de 2012 de la Municipalidad de Curic&#xF3; y en consideraci&#xF3;n al Acuerdo N&#xBA; 11 del Concejo Municipal de Curic&#xF3;, de fecha 15 de enero de 2013, apru&#xE9;base, en forma definitiva, la modificaci&#xF3;n del Plan Regulador de Curic&#xF3;, v&#xED;a Enmienda N&#xBA; 1, que cambia la Ordenanza Local del Plan Regulador Vigente, de la comuna de Curic&#xF3;.</div><div class=\"p\">&nbsp; &nbsp;  La enmienda se encuentra publicada en su totalidad en la p&#xE1;gina web de la Municipalidad de Curic&#xF3;, de acuerdo a las disposiciones legales vigentes.</div></div>", "i": 9331530}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Javier Mu&#xF1;oz Riquelme, Alcalde.</div></div>", "i": 9331531}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "239 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-239 EXENTO"}], "organismos": ["MUNICIPALIDAD DE CURICÓ"], "titulo_norma": "APRUEBA MODIFICACIÓN DEL PLAN REGULADOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-01-25", "doble_articulado": false, "id_norma": "1048611", "numero_fuente": "40477", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-05", "vigencias": [{"desde"