{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,790.- Santiago, 18 de enero de 1906.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Josefa Arancibia, viuda del cabo primero de Ej&#xE9;rcito, don Wenceslao Barrios, una pension mensual de diez pesos, que disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar&quot;.</div><br></div>", "i": 6165747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Manuel F&#xF3;ster R.</div><br></div>", "i": 6165748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1790", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1790"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-01-18", "doble_articulado": false, "id_norma": "135542", "numero_fuente": "8410", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-01-22", "vigencias": [{"desde": "1906-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1906-01-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-27"