{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065974}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 38 de 12 de Enero de 1990, se adjudica a &quot;Josefa Alvarez Paredes&quot;, la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar del 15 de Febrero de 1990, un establecimiento ubicado en calle Independencia No. 3380 destinado a la Revisi&#xF3;n T&#xE9;cnica y Verificaci&#xF3;n de Emisi&#xF3;n de Contaminantes de Autom&#xF3;viles, Station Wagons. Motocicletas, Veh&#xED;culos de Carga de menos de 1.750 Kg de capacidad de carga util y sus Remolques de la Regi&#xF3;n Metropolitana, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6065975}, {"t": "<div><div class=\"p\">Carlos Silva Echiburu, Ministro de Transportes y Telecomunicaciones.</div><br></div>", "i": 6065976}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "38", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-38"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "83674", "numero_fuente": "33586", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-02", "vigencias": [{"desde": "1990-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":