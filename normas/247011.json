{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 14,413</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DON ELEUTERIO ALARCON ALARCON</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6560035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a don Eleuterio Alarc&#xF3;n Alarc&#xF3;n, una pensi&#xF3;n de E&#xBA; 40 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6560036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticinco de Noviembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Figueroa G.</div><br></div>", "i": 6560037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14413", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14413"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DON ELEUTERIO ALARCON\nALARCON", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-11-25", "doble_articulado": false, "id_norma": "247011", "numero_fuente": "24821", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-12-17", "vigencias": [{"desde": "1960-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"