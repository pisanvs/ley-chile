{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 50 EXENTO, DE 2003 </div></div>", "i": 6416654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 50 de fecha 23 de enero de 2003, de Educaci&#xF3;n, se autoriza al Instituto Profesional Agrario Adolfo Matthei para impartir la siguiente carrera y t&#xED;tulo t&#xE9;cnico de Nivel Superior que se indica a contar del a&#xF1;o 2003:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; : T&#xE9;cnico Hort&#xED;cola</div><div class=\"p\">T&#xED;tulo T&#xE9;cnico : T&#xE9;cnico Hort&#xED;cola, menci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Horticultura o menci&#xF3;n Fruticultura.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6416655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de febrero de 2003.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6416656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "50 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-50 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 50 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-23", "doble_articulado": false, "id_norma": "208262", "numero_fuente": "37503", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-07", "vigencias": [{"desde": "2003-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-07", "fin_v