{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7259745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;147, de 19 de enero de 2000 de esta Subsecretar&#xED;a, autor&#xED;zase a Pesquera Grimar S.A., para ampliar las actividades pesqueras de transformaci&#xF3;n que tiene autorizadas por resoluciones N&#xBA;285 de 1990, N&#xBA;1.751 de 1998 y N&#xBA;789 de 1999, todas de esta Subsecretar&#xED;a, en orden a operar una planta ubicada en Parque Industrial I Etapa camino a Coronel, VIII Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n de Congelado, Fresco-refrigerado, Salado, Ahumado, Embutido, Cocido, Apanado y Seco-salado el recurso hidrobiol&#xF3;gico Orange roughy.</div><br></div>", "i": 7259746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 7259747}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "147", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-147"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-19", "doble_articulado": false, "id_norma": "153088", "numero_fuente": "36575", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-29", "vigencias": [{"desde": "2000-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-29", "fin_vigencia":