{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Rehabilitacion del Sarjento-Mayor don Diego Miller Almeida</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,177.- Santiago, a 19 Enero de 1899.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948502}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Rehabil&#xED;tase al sarjento-mayor retirado, don Diego Miller Almeida, para que pueda tramitar su espediente de invalidez relativa, en conformidad al art&#xED;culo 3.&#xB0; de la lei de 22 de Diciembre de 1881.</div><br><br></div>", "i": 5948503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 5948504}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1177", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1177"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Rehabilitacion del Sarjento-Mayor don Diego Miller;Almeida", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIEGO MILLER ALMEIDA", "REHABILITACION", "EXPEDIENTE", "TRAMITACION INVALIDEZ RELATIVA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-19", "doble_articulado": false, "id_norma": "22448", "numero_fuente": "6205", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-19", "vigencias": [{"desde": "1899-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-01-19", "fin_vigencia": ""}, "vigen