{"html": [{"t": "<div><div class=\"p\">EXTRACTO </div></div>", "i": 6298241}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 73, del 2 de agosto del a&#xF1;o 2000, se autoriz&#xF3; existencia y aprob&#xF3; el estatuto de la Cooperativa de Trabajo Transmatur, de sigla Transmatur, que se contiene en los documentos protocolizados al final de los Registros de do&#xF1;a Martita W&#xF6;rner Tapia, Notario de la ciudad de Ancud, bajo los n&#xFA;meros 351 y 352, ambos de fecha 13 de marzo del 2000, rectificada por acta complementaria protocolizada bajo el N&#xBA; 969, con fecha 6 de julio del 2000, en los mismos Registros, actuando como suplente do&#xF1;a Mar&#xED;a Teresa S&#xE1;nchez Puente.</div><br></div>", "i": 6298242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas.</div><br></div>", "i": 6298243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "73", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-73"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-02", "doble_articulado": false, "id_norma": "174760", "numero_fuente": "36753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-31", "vigencias": [{"desde": "2000-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-31", "fin_vigencia": ""}, "vigencias_version_norma"