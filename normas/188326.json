{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6345163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.612, de 1 de agosto de 2001, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las</div><div class=\"p\">resoluciones que a continuaci&#xF3;n se indican, todas de</div><div class=\"p\">esta Subsecretar&#xED;a, conforme a lo dispuesto en el</div><div class=\"p\">art&#xED;culo 7&#xBA; del D.S. N&#xBA;175 de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n: N&#xBA; 844 de 1988, N&#xBA; 306 de 1989, N&#xBA; 582 de 1989, N&#xBA; 1.663 de 1989, N&#xBA; 13 de 1988, N&#xBA; 157 de 1994, N&#xBA; 705 y N&#xBA; 810 ambas de 1994, N&#xBA; 275 de 1996, que autorizaron a realizar actividades pesqueras de transformaci&#xF3;n.</div><br></div>", "i": 6345164}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de agosto de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6345165}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1612", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1612"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-08-01", "doble_articulado": false, "id_norma": "188326", "numero_fuente": "37032", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-08", "vigencias": [{"desde": "2001-08-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-08", "fin_vigencia