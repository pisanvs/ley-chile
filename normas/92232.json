{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA</div><br><br></div>", "i": 8321445}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 413, de 07.04.89, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, der&#xF3;gase la Resoluci&#xF3;n No. 154, de 1989, de esta Subsecretar&#xED;a que autoriz&#xF3; a Sociedad Pesquera Comercial y Profesional Aquacultivos Limitada, R.U.T. No.</div><div class=\"p\">87.829.000-3, domiciliada Puerto Montt, para desarrollar actividades pesqueras de cultivo, en un sector situado en la ribera del R&#xED;o Blanco, Comuna de Puerto Varas, Provincia de Llanquihue, X Regi&#xF3;n, por renuncia de su titular. </div></div>", "i": 8321446}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 07.04.89;- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8321447}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "413", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-413"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-04-07", "doble_articulado": false, "id_norma": "92232", "numero_fuente": "33348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-15", "vigencias": [{"desde": "1989-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente