{"html": [{"t": "<div><div class=\"p\">Donativos patri&#xF3;ticos</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Diciembre 15 de 1817</div></div>", "i": 10228136}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;nse las m&#xE1;s espresivas gracias oficiales a nombre del Gobierno por el Ministerio de Hacienda al ciudadano de las Provincias Unidas don Estanislao Lynch por su donativo de 300 pesos con el ofrecimiento de su benem&#xE9;rita persona en defensa de la causa jeneral, i de un pais aliado e &#xED;ntimamente unido al de aquellas: imprimase en la Gazeta su memorial con este decreto de que se tomar&#xE1; razon.-</div></div>", "i": 10228137}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Cruz. - Astorga. - Dr. Villegas. </div></div>", "i": 10228138}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Donativos patrióticos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-12-15", "doble_articulado": false, "id_norma": "1159372", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ingreso": "2021-05-19", "fecha_version": "1817-12-15", "fecha_actualizacion_texto": "2021-05-19", "tipo_tratado": ""}, "ale