{"html": [{"t": "<div><div class=\"p\">REASUME MANDO DEL ESTADO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de julio de 2001.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 783. Visto: Lo dispuesto en los art&#xED;culos 29&#xBA; y 32&#xBA;, N&#xBA; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o :</div><br><br></div>", "i": 8366622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con ocasi&#xF3;n de mi regreso al pa&#xED;s a contar de esta fecha reasumo el mando del Estado.</div><br></div>", "i": 8366623}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese, raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- RICARDO LAGOS ESCOBAR, Presidente de la Rep&#xFA;blica.- Jos&#xE9; Miguel Insulza Salinas, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda Atte. a Ud., Jorge Correa Sutil, Subsecretario del Interior.</div><br></div>", "i": 8366624}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "783", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-783"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE DE LA REPUBLICA", "RICARDO LAGOS ESCOBAR", "MANDO DE LA NACION", "REASUNCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-31", "doble_articulado": false, "id_norma": "189020", "numero_fuente": "37051", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-31", "vigencias": [{"desde": "2001-08-31", "hasta": "", "tipo_versi