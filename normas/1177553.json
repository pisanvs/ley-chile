{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10342383}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0;1.132, de 24 de mayo de 2022, modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1175330&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0;356, de fecha 1 de marzo de 2022</a>, que derog&#xF3; la resoluci&#xF3;n exenta N&#xB0;988, de 2021, y sus modificaciones posteriores, las que determinaron el listado de prestaciones del Instituto de Salud P&#xFA;blica de Chile que se mantendr&#xED;an suspendidas mientras durase la alerta sanitaria decretada por la pandemia del virus SARS-CoV-2.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div><br></div>", "i": 10342384}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10342385}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1132 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1132 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2144098", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-05-24", "doble_articulado": false, "id_norma": "1177553", "numero_fuente": "43280", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-06-16", "vigencias": [{"desde": "2022-