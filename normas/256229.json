{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br><br><br></div>", "i": 6593072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 853, de 14 de noviembre de 2006, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 1-A, correspondiente a parte del inmueble ubicado en R. Freire N&#xBA; 77, Rol de Aval&#xFA;o N&#xBA; 151-2, comuna de Maip&#xFA;, aparente dominio de Jos&#xE9; Campos Sep&#xFA;lveda. Comisi&#xF3;n integrada por peritos se&#xF1;ores Carmen P. R&#xED;os Marcuello, Ingeniero Civil; Carmen G. Gatica Villarroel, Arquitecto, y Ram&#xF3;n Rovira Baro, Constructor Civil. Seg&#xFA;n informe de 12 de septiembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $51.539.000, pagadera al contado.</div><br></div>", "i": 6593073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6593074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "853", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-853"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL Y TOTAL DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-14", "doble_articulado": false, "id_norma": "256229", "numero_fuente": "38639", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-15", "vigencias": [{"desde": "2006-12-15", "hasta": "", "tipo_version": "3", "tipo_ve