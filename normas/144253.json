{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,969.-&nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6193655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a la se&#xF1;ora Sara Fern&#xE1;ndez de Arriagada, una pension anual de seis mil pesos ($ 6,000), la que ser&#xE1; pagada con fondos de la Empresa de los Ferrocarriles del Estado.</div><br></div>", "i": 6193656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticinco de julio de mil novecientos veintitres.-&nbsp; Arturo Alessandri.-&nbsp; F. Mard&#xF3;nes.</div><br></div>", "i": 6193657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3969", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3969"}], "organismos": ["MINISTERIO DE FERROCARRILES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-07-25", "doble_articulado": false, "id_norma": "144253", "numero_fuente": "13664", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-08-29", "vigencias": [{"desde": "1923-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1923-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1923-08-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc