{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7276325}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n n&#xFA;mero 1.852, de 18 de agosto de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n&nbsp; N&#xBA; 1.239, de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA BIO BIO LIMITADA, para operar la nave &apos;&apos;Lascar&apos;&apos;, para operar sobre los recursos Anchoveta y Sardina espa&#xF1;ola en el litoral de la III y IV Regi&#xF3;n, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7276326}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de agosto de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7276327}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1852", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1852"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-18", "doble_articulado": false, "id_norma": "174764", "numero_fuente": "36753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-31", "vigencias": [{"desde": "2000-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION