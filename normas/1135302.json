{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xB0; 1.970, DEL 23 DE ABRIL DE 2019</div></div>", "i": 10048127}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 3.349, de fecha 10 julio 2019, rectificada por la resoluci&#xF3;n N&#xB0; 3.632, del 31 de julio de 2019, ambas del Director Nacional de Aduanas, se modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1131242&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 1.970, del 23 de abril de 2019</a>, que contiene las normas actualizadas sobre las operaciones de &quot;alije&quot; para las descargas de petr&#xF3;leo y/o sus derivados.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\"> </div></div>", "i": 10048128}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de agosto de 2019.- Jos&#xE9; Ignacio Sotomayor, Director Nacional de Aduanas.</div></div>", "i": 10048129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3349 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3349 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN N° 1.970, DEL 23 DE ABRIL DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1640162; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-07-10", "doble_articulado": false, "id_norma": "1135302", "numero_fuente": "42436", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-08-23", "vi