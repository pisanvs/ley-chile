{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO DE EDUCACION N. 186, DE 1989 </div><br></div>", "i": 7224056}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 186. de 24 de noviembre de 1989 se ha aprobado. a contar del a&#xF1;o escolar 1990. al Colegio Santa Catalina de Siena. de Santiago. un programa especial de estudio de la asignatura de Idioma Extranjero 2 Lat&#xED;n con una carga horaria de dos clases semanales. para los cursos de 7&#xB0; y 8&#xB0; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica. el que deber&#xE1; cumplir con los Objetivos Generales y Espec&#xED;ficos que se indican en este decreto.- </div></div>", "i": 7224057}, {"t": "<div><div class=\"p\">Mar&#xED;a Sixtina Barriga Guzm&#xE1;n. Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7224058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "186 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-186 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°. 186, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-24", "doble_articulado": false, "id_norma": "89367", "numero_fuente": "33551", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-21", "vigencias": [{"desde": "1989-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text