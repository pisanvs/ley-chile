{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA; 1.768</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1,768, celebrada el 03 de diciembre de 1986, adopt&#xF3; los siguientes acuerdos: </div></div>", "i": 6203546}, {"t": "<div><div class=\"p\">1768-09-861203 - Casa de Cambios &quot;Financiera Mediterr&#xE1;neo S.A.&quot;.- Revoca autorizaci&#xF3;n para operar como tal.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, a petici&#xF3;n de los interesados, revocar la autorizaci&#xF3;n N&#xBA; 73 concedida a Casa de Cambios Financiera Mediterr&#xE1;neo S.A., para operar como tal en su local de Ahumada N&#xBA; 77, Santiago.</div><br></div>", "i": 6203547}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 04 de diciembre de 1986.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6203548}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1768", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1768"}, {"tipo": "5", "numero": "1768-09", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1768-09"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION Nº 1.768", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-04", "doble_articulado": false, "id_norma": "147210", "numero_fuente": "32640", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-12-05", "vigencia