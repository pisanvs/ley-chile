{"html": [{"t": "<div><br><br><br><br><br><br><div class=\"p\">&nbsp; &nbsp;  Servicio de correos</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 24 de 1822.</div></div>", "i": 10099791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese &#xF3;rden a la Administracion Jeneral de Correos para que por motivo alguno sufran demora los correos ordinarios, que deben jirar en los dias prefijados para su salida con arreglo a sus instrucciones, cuyo exacto cumplimiento se le reencarga.</div></div>", "i": 10099792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ins&#xE9;rtese en la Gaceta Ministerial este decreto.- O&apos;Higgins.- Echeverr&#xED;a.</div><br></div>", "i": 10099793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "17", "numero": "S/N", "abreviacion": "LEI", "descripcion": "Norma Antigua", "compuesto": "Norma Antigua-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Servicio de correos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-05-24", "doble_articulado": false, "id_norma": "1141921", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-05-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-05-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-05-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2020-02-11", "fecha_version": "1822-05-24", "fecha_actualizacion_texto": "2020-02-11", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado