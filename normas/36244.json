{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295732}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.106, de 12 de Junio de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por RENE ADALBERTO</div><div class=\"p\">HERZBERG CORDONES, para un centro de cultivo ubicado en</div><div class=\"p\">Punta Tasca, Isla Laitec, Comuna de Quell&#xF3;n, Provincia</div><div class=\"p\">de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en el</div><div class=\"p\">art&#xED;culo 67&#xB0;, inciso 5&#xB0;, de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8295733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de Junio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295734}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1106", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1106"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "RENE ADALBERTO HERZBERG CORDONES", "QUELLON", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-06-12", "doble_articulado": false, "id_norma": "36244", "numero_fuente": "35495", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-06-19", "vigencias": [{"desde": "1996-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci