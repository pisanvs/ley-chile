{"html": [{"t": "<div><div class=\"p\">NOTIFICACION </div></div>", "i": 6126869}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En Pe&#xF1;aflor, a 25 de Noviembre de 1983 por los decretos alcaldicios N&#xBA; 325 - 326 y 327 se aprobaron las Ordenanzas Municipales sobre &quot;Aseo&quot;, &quot;Mantenci&#xF3;n de Areas Verdes y Especies Vegetales en la V&#xED;a P&#xFA;blica&quot; y &quot;Prevenci&#xF3;n y Control de Ruidos Molestos en la Comuna&quot;. Estas Ordenanzas se encuentran a disposici&#xF3;n de los interesados a contar de la fecha de esta publicaci&#xF3;n, en la Direcci&#xF3;n de Obras Direcci&#xF3;n de Aseo y Jardines de la I. Municipalidad de Pe&#xF1;aflor, ubicada en calle Balmaceda N&#xBA; 1215 de Pe&#xF1;aflor.</div><br></div>", "i": 6126870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - El Alcalde.</div><br></div>", "i": 6126871}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "327", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-327"}], "organismos": ["MUNICIPALIDAD DE PEÑAFLOR"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1983-11-25", "doble_articulado": false, "id_norma": "123449", "numero_fuente": "31743", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1983-12-13", "vigencias": [{"desde": "1983-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1983-12-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1983-12-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-08-27", "fecha_ver