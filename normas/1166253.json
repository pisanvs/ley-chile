{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10275127}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 1.586, de 17 de agosto de 2021, establece criterios para evaluar las solicitudes voluntarias de verificaci&#xF3;n de conformidad de los kits de diagn&#xF3;stico de SARS-COV-2.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10275128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10275129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1586 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1586 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS COVID-19", "CORONAVIRUS", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2021910", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-08-17", "doble_articulado": false, "id_norma": "1166253", "numero_fuente": "43073", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-08", "vigencias": [{"desde": "2021-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-10-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],