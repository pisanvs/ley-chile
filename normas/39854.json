{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6025168}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 1.588 de 14 de Diciembre de 1994, se autoriz&#xF3; a la sociedad Transportes V&#xED;a G&#xE9;minis Limitada (V&#xED;a G&#xE9;minis Ltda.), para efectuar transporte internacional terrestre de pasajeros entre Iquique (Chile) y Salta (Argentina) por los pasos fronterizos de Sico o Jama con dos frecuencias semanales de ida y vuelta.-</div><br></div>", "i": 6025169}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Claudio Hohmann Barrientos, Subsecretario de Transportes.</div><br></div>", "i": 6025170}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1588 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1588 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TRANSPORTES VIA GEMINIS LIMITADA", "TRANSPORTE", "INTERNACIONAL", "TRANSPORTE PASAJEROS", "IQUIQUE", "SALTA", "CHILE", "ARGENTINA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-14", "doble_articulado": false, "id_norma": "39854", "numero_fuente": "35104", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-02-27", "vigencias": [{"desde": "1995-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-02-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1995-02-27", "fecha_actualizacion_texto": "1995-02-27",