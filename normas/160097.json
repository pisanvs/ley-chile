{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6247492}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decretos MOP No. 76 y 81, de fechas 16 y 18 de marzo de 1992, se expropiaron los lotes de terrenos No.</div><div class=\"p\">s. 1-A, 1-B, 9 y 20, superficies 3.920 m&#xB2;., 1.490 m&#xB2;, 1.340 m&#xB2; y 4.251 m&#xB2;, respectivamente, roles de aval&#xFA;os 224-24, 225-3 y 225-09, Comuna Santa B&#xE1;rbara, para la obra Camino de Acceso y de la Red Vial interna de la Central Pangue, Tramo A y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios sucesi&#xF3;n Eugenio Mu&#xF1;oz Pal, sucesi&#xF3;n Benicio Espinoza Castillo y sucesi&#xF3;n Jos&#xE9; Policarpo Vargas Sanhueza, ascendente a las cantidades de $1.579.667, $657.185 y $2.004.214.- </div></div>", "i": 6247493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de obras P&#xFA;blicas. </div></div>", "i": 6247494}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "81", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-81"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-18", "doble_articulado": false, "id_norma": "160097", "numero_fuente": "34256", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-05-02", "vigencias": [{"desde": "1992-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v