{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de Ley:</div><br></div>", "i": 7299765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Except&#xFA;anse el trigo y el cemento de los productos a que se refiere la ley n&#xFA;mero 3,915, de 9 de Febrero de 1923, y f&#xED;jase en ochenta y seis kilos el peso m&#xE1;ximo de los sacos en que se envasen estos art&#xED;culos.</div><br></div>", "i": 7299766, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a diez de Febrero de mil novecientos veintiocho.- Carlos Iba&#xF1;ez del Campo.- Adolfo Ib&#xE1;&#xF1;ez B. </div></div>", "i": 7299767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4290", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4290"}], "organismos": ["MINISTERIO DE FOMENTO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-10", "doble_articulado": false, "id_norma": "210653", "numero_fuente": "14998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-13", "vigencias": [{"desde": "1928-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-02-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [