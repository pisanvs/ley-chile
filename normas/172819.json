{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6288438}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.349, de 30 de mayo del 2000, se expropi&#xF3; el lote de terreno N&#xBA;1, superficie 3.376 m&#xB2;, rol de aval&#xFA;o 24-88, comuna de R&#xED;o Claro, para la obra Concesi&#xF3;n Internacional Ruta 5, Tramo: Talca - Chill&#xE1;n, S&#xE9;ptima Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Mar&#xED;a Ang&#xE9;lica del Carmen Olave Villagra, ascendente a la cantidad de $7.265.382.</div><br></div>", "i": 6288439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6288440}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2349", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2349"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-30", "doble_articulado": false, "id_norma": "172819", "numero_fuente": "36714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-15", "vigencias": [{"desde": "2000-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-07-18", "fecha_version": "2000-07-15", "fecha_actualizacion_texto": "2000-07-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructu