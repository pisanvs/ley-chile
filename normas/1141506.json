{"html": [{"t": "<div><br><div class=\"p\">TEMPORALIDADES DE REGULARES.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 16 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto:</div></div>", "i": 10101013}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Todas las temporalidades de los Regulares, quedan incorporadas a la Hacienda p&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Los Directores de la Caja nacional de descuentos, comisionados para el arreglo y liquidacion de dichas temporalidades, se entenderan directamente en todas sus jestiones con el Ministerio de Hacienda. T&#xF3;mese razon, comun&#xED;quese e ins&#xE9;rtese en el Boletin.</div><br></div>", "i": 10101014}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  F. A. Pinto.</div><br></div>", "i": 10101015}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "TEMPORALIDADES DE REGULARES.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-10-16", "doble_articulado": false, "id_norma": "1141506", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-10-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "conco