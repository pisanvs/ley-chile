{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6264562}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 328 de 04 de Diciembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n se autoriza a Mar&#xED;a Ibarra Cornejo, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6264563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan W. Flaquer Hern&#xE1;ndez, Secretario Regional Ministerial, Transportes y Telecomunicaciones, I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6264564}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "328", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-328"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-18", "doble_articulado": false, "id_norma": "165405", "numero_fuente": "32347", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-14", "vigencias": [{"desde": "1985-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingres