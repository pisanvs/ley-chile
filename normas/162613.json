{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 183, DE 1980</div><br><div class=\"p\">&nbsp; &nbsp;  No. 41.- Santiago, 09 de Abril de 1985.- Visto: Lo dispuesto en el Art. 11 del decreto ley No. 2.974, y lo informado por el Director de la VIII Regi&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7266170}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n No., 183, de 18 de Abril de 1980, sobre designaci&#xF3;n de Receptores Judiciales en lo referente a la VIII Regi&#xF3;n, en la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp;  Se elimina a don Marcial Ram&#xED;rez Palacios. </div></div>", "i": 7266171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Arturo Venegas Palacios, Vicepresidente Ejecutivo.</div><br></div>", "i": 7266172}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-41"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA RESOLUCION No. 183, DE 1980", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-09", "doble_articulado": false, "id_norma": "162613", "numero_fuente": "32157", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-27", "vigencias": [{"desde": "1985-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-27", "fin_vigencia": "", "tipo_vers