{"html": [{"t": "<div><div class=\"p\">RECTIFICACION </div></div>", "i": 7233808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En el Diario Oficial de 26 de abril de 1989, se public&#xF3; el autoacordado del Tribunal Constitucional relativo al r&#xE9;gimen previsional de sus Ministros, con la omisi&#xF3;n que se salva a continuaci&#xF3;n:</div><div class=\"p\">&nbsp; &nbsp;  En su art&#xED;culo 1&#xB0; se omiti&#xF3; la letra e) del siguiente tenor, la que debe entenderse incorporada al referido autoacordado:</div><div class=\"p\">&quot;e) El art&#xED;culo 2&#xB0; de la ley 18.263, de 1983.&quot;, debiendo sustituirse la conjunci&#xF3;n &quot;y&quot; que aparece en su letra c) por un punto y coma (;), y el punto final de su letra d) por la expresi&#xF3;n &quot;, y&quot;.</div><br></div>", "i": 7233809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de mayo de 1989.- Rafael Larra&#xED;n Cruz, Secretario.</div><br></div>", "i": 7233810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "4", "numero": "S/N", "abreviacion": "AA", "descripcion": "Auto Acordado", "compuesto": "AA-S/N"}], "organismos": ["TRIBUNAL CONSTITUCIONAL"], "titulo_norma": "RECTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-04-26", "doble_articulado": false, "id_norma": "101041", "numero_fuente": "33376", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-05-19", "vigencias": [{"desde": "1989-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-05-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos