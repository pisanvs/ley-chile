{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES</div><br><br></div>", "i": 8288772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 631 de 6 de Junio de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por un a&#xF1;o a contar del 23 de diciembre de 1990, el plazo otorgado a don ROLANDO GARAY CIFUENTES, R.U.T. N&#xB0; 1.424.987-7, domiciliado en calle Puerto Caldera N&#xB0; 6868, Las Condes, Santiago, en el n&#xFA;mero 5&#xB0; de la resoluci&#xF3;n N&#xB0; 1847, de 1989, de esta Subsecretar&#xED;a, por haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8288773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288774}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "631", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-631"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ROLANDO GARAY CIFUENTES", "PESCA", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-06-06", "fecha_derogacion": "1993-11-23", "doble_articulado": false, "id_norma": "31569", "numero_fuente": "34003", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-06-27", "vigencias": [{"desde": "1993-11-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-06-27", "hasta": "1993-11-22", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia":