{"html": [{"t": "<div><br><div class=\"p\">SE CONCEDE A EXONERADOS POL&#xCD;TICOS EL BONO EXTRAORDINARIO DEL ART&#xCD;CULO 1&#xB0; DE LA LEY 20.134, POR EL MONTO &#xDA;NICO Y TOTAL QUE SE CONSIGNA</div></div>", "i": 9779961}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 78, de 3 de febrero de 2017, del Director Nacional del Instituto de Previsi&#xF3;n Social, se concede por el Instituto de Previsi&#xF3;n Social y por una sola vez, el Bono Extraordinario del <a href=\"https://www.leychile.cl/Navegar?idNorma=255414&amp;idParte=8374907&amp;idVersion=\">art&#xED;culo 1&#xB0;</a>, de la <a href=\"https://www.leychile.cl/Navegar?idNorma=255414&amp;idParte=&amp;idVersion=\">ley N&#xB0; 20.134</a>, a las 829 personas que se individualiza en n&#xF3;mina adjunta, por el monto &#xFA;nico que se se&#xF1;ala en cada caso.</div><div class=\"p\"> </div><br></div>", "i": 9779962}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de marzo de 2017.- Patricio Coronado Rojo, Director Nacional.</div></div>", "i": 9779963}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "78 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-78 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DE PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE CONCEDE A EXONERADOS POLÍTICOS EL BONO EXTRAORDINARIO DEL ARTÍCULO 1° DE LA LEY 20.134, POR EL MONTO ÚNICO Y TOTAL QUE SE CONSIGNA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1192540; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-02-03", "doble_articulado": false, "id_norma": "1100967", "numero_fuente": "41708", "tipo_ve