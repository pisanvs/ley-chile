{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL 5% ANTICIPO IVA EN LAS VENTAS DE CARNE A JAMA S.A.</div><br></div>", "i": 6466601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2.- Certifico que la empresa Jama S.A., RUT N&#xB0; 96.963.670-0 cumple los requisitos establecidos en la resoluci&#xF3;n exenta N&#xB0; 3.722 de 28 de julio de 2000 y que, en consecuencia, se le ha otorgado la calidad de Agente Retenedor del anticipo del 5% del impuesto al valor agregado, en las ventas de carnes, a contar del 1&#xB0; del mes siguiente al de la publicaci&#xF3;n de este certificado en el Diario Oficial.</div><br></div>", "i": 6466602}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Providencia, 23 de febrero de 2004.- Patricio Espinoza Llanos, Director Regional (S).</div><br></div>", "i": 6466603}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "2", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-2"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "XV DIRECCIÓN REGIONAL METROPOLITANA", "SANTIAGO ORIENTE"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL 5% ANTICIPO IVA EN LAS VENTAS DE CARNE A JAMA S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-23", "doble_articulado": false, "id_norma": "221778", "numero_fuente": "37797", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-27", "vigencias": [{"desde": "2004-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-27