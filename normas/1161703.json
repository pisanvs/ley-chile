{"html": [{"t": "<div><br><div class=\"p\">COMANDANTE DE ARMAS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 7 de 1833.</div></div>", "i": 10255651}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por justas y poderosas consideraciones queda separado del mando de la Comandancia jeneral de armas e Inspeccion jeneral del ej&#xE9;rcito el Jeneral de brigada don Jos&#xE9; Ignacio Zenteno, y en su lugar se nombra para que desempe&#xF1;e interinamente ambos destinos al Coronel de infanter&#xED;a de ej&#xE9;rcito don Jos&#xE9; Antonio Vidaurre.</div></div>", "i": 10255652}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon y comuniquese.</div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Ramon Cavareda.</div></div>", "i": 10255653}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE LA GUERRA"], "titulo_norma": "COMANDANTE DE ARMAS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1833-03-07", "doble_articulado": false, "id_norma": "1161703", "numero_fuente": "1833", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1833-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1833-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1833-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-07-29", "fecha_version": "1833-03-07", "fecha_actualizacion_texto": "1833-0