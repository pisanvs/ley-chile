{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DECLARA FERIADO EL DIA EN QUE SE VERIFICA LA ELECCION DE ELECTORES DEL PRESIDENTE DE LA REPUBLICA.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1752.-Santiago, a 31 de Agosto de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274661}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.-Se declara feriado el dia en que se verifica la eleccion de Electores de Presidente de la Rep&#xFA;blica.</div><br></div>", "i": 8274662}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JERMAN RIESCO.-Juan Antonio Orrego.</div><br></div>", "i": 8274663}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1752", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1752"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DECLARA FERIADO EL DIA EN QUE SE VERIFICA LA ELECCION DE ELECTORES DEL PRESIDENTE DE LA REPUBLICA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "ELECCION", "FERIADO LEGAL", "DECLARACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-08-31", "doble_articulado": false, "id_norma": "22892", "numero_fuente": "8299", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-09-02", "vigencias": [{"desde": "1905-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-09-02", "fin_vigencia": ""}, "vigencias_version_norm