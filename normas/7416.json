{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7132139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto MOP. N&#xB0; 9, de 9 de enero de 1995, se orden&#xF3; la consignaci&#xF3;n judicial de la indemnizaci&#xF3;n provisional del lote N&#xB0; 3, ascendente a $43.760, destinado a la ejecuci&#xF3;n de la obra Camino Lanco-Panguipulli, sector Lanco Puente Salto de Agua Km.</div><div class=\"p\">9.600 al 12.200, expropiado por Decreto MOP. N&#xB0; 254, de 10 de octubre de 1991, que figura a nombre de Egidia Pononcura Nahuelp&#xE1;n, rol de aval&#xFA;o 166-166, comuna de Lanco, X Regi&#xF3;n.</div><br></div>", "i": 7132140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7132141}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "9", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-9"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INDEMNIZACION", "EXPROPIACION", "BIEN INMUEBLE", "LANCO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-09", "doble_articulado": false, "id_norma": "7416", "numero_fuente": "35118-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-15", "vigencias": [{"desde": "1995-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1995-03-15",