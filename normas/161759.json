{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6253189}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 91, de 16 de Abril de 1984, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza al se&#xF1;or Ra&#xFA;l Antonio Espinoza Gonz&#xE1;lez, para efectuar todo tipo de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n del servicio urbano de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6253190}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomun&#xED;caciones, Regi&#xF3;n del Maule.</div><br></div>", "i": 6253191}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "91", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-91"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-04-16", "doble_articulado": false, "id_norma": "161759", "numero_fuente": "32191", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-08", "vigencias": [{"desde": "1985-06-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_in