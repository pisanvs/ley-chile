{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,791.- Santiago, 18 de enero de 1906.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados durante la &#xE9;poca de la Independencia por el teniente coronel graduado, don Manuel Gregorio Quiroga, conc&#xE9;dese, por gracia, a su nieta do&#xF1;a Camila Aravena Quiroga derecho a disfrutar de la pension de montep&#xED;o militar que corresponde a la viuda de un capitan de Ej&#xE9;rcito.&quot; </div></div>", "i": 6165750}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Manuel F&#xF3;ster R.</div><br></div>", "i": 6165751}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1791", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1791"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-01-18", "doble_articulado": false, "id_norma": "135543", "numero_fuente": "8410", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-01-22", "vigencias": [{"desde": "1906-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1906-01-22", "fin_vigencia": "", "tipo_version": "