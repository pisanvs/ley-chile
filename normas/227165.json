{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 7.132 EXENTA, DE 2004 </div><br></div>", "i": 7312794}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 7.132 de 17 de mayo de 2004, se ha aprobado al &quot;Colegio Dunalastair&quot;, de la Comuna de Las Condes de Santiago, un plan especial de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2004 en 1&#xBA;, 2&#xBA; y 3er. a&#xF1;o medio y desde el a&#xF1;o escolar 2005 en 4&#xBA; a&#xF1;o medio.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban los programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 7312795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de junio de 2004.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 7312796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7132 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7132 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 7.132 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-17", "doble_articulado": false, "id_norma": "227165", "numero_fuente": "37900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-03", "vigencias": [{"desde": "2004-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07-03",