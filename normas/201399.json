{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7293496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.659, de 6 de agosto de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a SOUTHPACIFIC KORP S.A., para ampliar las actividades pesqueras extractivas con la nave &quot;Vinga&quot;, autorizada por resoluciones N&#xBA; 830 y N&#xBA; 1.919, ambas de 2001, de esta Subsecretar&#xED;a, en orden a realizar actividades pesqueras con la nave se&#xF1;alada precedentemente, en el &#xE1;rea mar&#xED;tima comprendida entre la VI y X Regiones, por fuera del &#xE1;rea de reserva artesanal, con cerco, sobre los siguientes recursos hidrobiol&#xF3;gicos: Jurel fino, Anchoa blanca o samasa, Sardina redonda, Vinciguerria.</div><br></div>", "i": 7293497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de agosto de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7293498}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1659", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1659"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-08-06", "fecha_derogacion": "2007-12-21", "doble_articulado": false, "id_norma": "201399", "numero_fuente": "37334", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-08-14", "vigencias": [{"desde": "2007-12-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-08-14", "hasta": "2007-12-20", "tipo_version": "0", "tipo_version_s"