{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;736 EXENTO, DE 2006 </div></div>", "i": 6589648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA;736 de 6 de junio de 2006, se ha aprobado plan y programas especiales de estudio biling&#xFC;e para 1&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica a la Escuela B&#xE1;sica Particular &quot;Trapa Trapa Butalelbum&quot;, de la comuna de Alto B&#xED;o B&#xED;o, Regi&#xF3;n del B&#xED;o B&#xED;o, el que se aplicar&#xE1; a contar del a&#xF1;o escolar 2006.</div><div class=\"p\">Adem&#xE1;s se aprueban programas de estudio para los Subsectores correspondientes a los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o (NB.1, NB.2, NB.3, NB.4, NB.5 y NB.6) de Ense&#xF1;anza B&#xE1;sica.</div><br></div>", "i": 6589649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de agosto de 2006.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6589650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "736 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-736 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº736 EXENTO, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-06", "doble_articulado": false, "id_norma": "255274", "numero_fuente": "38615", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-16", "vigencias": [{"desde": "2006-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen