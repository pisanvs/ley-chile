{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7348945}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 590 de 26 de junio de 2007, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme DL N&#xBA; 2.186 de 1978, del inmueble ubicado en calle Sierra Bella N&#xBA; 2728, presunto rol de aval&#xFA;o N&#xBA; 614-43, comuna de San Joaqu&#xED;n, aparente dominio de Suc. Gonz&#xE1;lez Devia Olga; correspondiente al Lote N&#xBA; 154, del Proyecto Vial &quot;Habilitaci&#xF3;n Corredor de Transporte P&#xFA;blico Avda. Las Industrias&quot;. Comisi&#xF3;n integrada por peritos Joaqu&#xED;n Eyzaguirre Edwards, arquitecto; Patricia Zavala Contreras, constructor civil; y Miguel Fern&#xE1;ndez C&#xE1;diz, constructor civil, seg&#xFA;n informe de 15 de noviembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $21.585.000, pagadera al contado.-</div><br></div>", "i": 7348946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 7348947}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "590", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-590"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-26", "doble_articulado": false, "id_norma": "263144", "numero_fuente": "38827", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-01", "vigencias": [{"desde": "2007-08-01", "hasta": "", "tipo_v