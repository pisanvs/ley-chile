{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.121, DE 1985 </div></div>", "i": 6240173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.121 de fecha 22 de Mayo de 1985 del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 1.762, de 1982, en su art&#xED;culo 2&#xB0;, sobre normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica &quot;DE ENAC&quot;, a partir del a&#xF1;o 1985.</div><div class=\"p\">&nbsp; &nbsp;  Para optar al t&#xED;tulo correspondiente, los alumnos deber&#xE1;n aprobar todas las asignaturas del plan de estudio y cumplir con las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n estipuladas en la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 1.121, de 1985.-</div><br></div>", "i": 6240174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6240175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1121 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1121 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.121, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-22", "doble_articulado": false, "id_norma": "157971", "numero_fuente": "32221", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-13", "vigencias": [{"desde": "1985-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]