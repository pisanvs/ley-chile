{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9270790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;1016, de 15 de junio de 2012, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1024590&amp;idParte=0&amp;idVersion=\">Decreto Exento MOP. N&#xBA;446, de 28 de marzo de 2011</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xBA;13, expropiado con motivo de la obra &quot;Conservaci&#xF3;n Global de Varios Caminos, Sector Norte de la Provincia de Osorno II Etapa&quot;, Comuna de San Juan de la Costa, Provincia de Osorno. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijado mediante tasaci&#xF3;n de 25 de octubre de 2007, en la suma de $145.800.-</div></div>", "i": 9270791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9270792}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1016 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1016 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-15", "doble_articulado": false, "id_norma": "1041499", "numero_fuente": "40302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-03", "vigencias": [{"desde": "2012-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic