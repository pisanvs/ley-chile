{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9370535}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.817, de 18 de julio de 2013, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1030930&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.461 de 2011</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a COMERCIAL PANAMERICANA S.A., a realizar actividades de acuicultura experimental sobre la especie Abal&#xF3;n rojo, en el sentido de extender el plazo para desarrollar las actividades de 48 a 60 meses.</div></div>", "i": 9370536}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9370537}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1817 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1817 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-07-18", "doble_articulado": false, "id_norma": "1053680", "numero_fuente": "40638", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-08-20", "vigencias": [{"desde": "2013-08-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-08-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-08-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACIO