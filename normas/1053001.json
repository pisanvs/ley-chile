{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N LEGAL DEL PARTIDO HUMANISTA EN LA XI REGI&#xD3;N DE AYS&#xC9;N</div></div>", "i": 9365789}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Don Danilo Monteverde Reyes y do&#xF1;a Mercedes Bravo Valenzuela, Presidente y Secretaria General de la Directiva Central del Partido Humanista, ha solicitado la constituci&#xF3;n legal del partido en la XI Regi&#xF3;n de Ays&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 56 fichas de afiliaci&#xF3;n con 288 afiliados.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la ley N&#xB0; 18.603, por resoluci&#xF3;n O-N&#xB0; 10.521, de fecha 11 de julio de 2013.- </div></div>", "i": 9365790}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9365791}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10521", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-10521"}, {"tipo": "3", "numero": "O-10521", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-10521"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN LEGAL DEL PARTIDO HUMANISTA EN LA XI REGIÓN DE AYSÉN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-07-11", "doble_articulado": false, "id_norma": "1053001", "numero_fuente": "40612", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-07-19", "vigencias": [{"desde": "2013-07-19", "hasta": "", "tipo_version": "3", "tipo_v