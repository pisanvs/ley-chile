{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.990, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;canse el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 541, de 1997, y el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 390, de 2001, ambas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA BIO BIO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Oceanic II&quot;, en el sentido de actualizar la siguiente caracter&#xED;stica n&#xE1;utica de &#xE9;sta:</div><br><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; 140,06 m3</div><br></div>", "i": 7303796}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7303797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1990 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1990 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-08-21", "fecha_derogacion": "2004-12-07", "doble_articulado": false, "id_norma": "214834", "numero_fuente": "37662", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-09-16", "vigencias": [{"desde": "2004-12-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-09-16", "hasta": "2004-12-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2004