{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LEY NUM. 17.466 DENOMINA &quot;OBISPO MANUEL LARRAIN&quot; A LA POBLACION QUE SE&#xD1;ALA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8284279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Denom&#xED;nase &quot;Obispo Manuel Larra&#xED;n&quot; a la Poblaci&#xF3;n Mataquito de Curic&#xF3;&quot;.</div><br></div>", "i": 8284280}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, seis de Agosto de mil novecientos setenta y uno.- SALVADOR ALLENDE GOSSENS.- Jos&#xE9; Toh&#xE1; G.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Daniel Vergara Bustos, Subsecretario del Interior.</div><br></div>", "i": 8284281}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17466", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17466"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEY NUM. 17.466 DENOMINA OBISPO MANUEL LARRAIN A LA POBLACION QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["POBLACION MATAQUITO", "CURICO", "DENOMINACION", "OBISPO MANUEL LARRAIN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1971-08-06", "doble_articulado": false, "id_norma": "29038", "numero_fuente": "28029", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1971-08-18", "vigencias": [{"desde": "1971-08-18", "h