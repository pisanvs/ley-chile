{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 14,308</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A ROSA AURELIA OROSTICA GAJARDO</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6576487}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Rosa Aurelia Or&#xF3;stica Gajardo una pensi&#xF3;n de cincuenta escudos mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande la aplicaci&#xF3;n de esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.</div><br></div>", "i": 6576488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a quince de Noviembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Figueroa G.</div><br></div>", "i": 6576489}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14308", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14308"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA ROSA AURELIA\nOROSTICA GAJARDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-11-15", "doble_articulado": false, "id_norma": "251467", "numero_fuente": "24808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-12-01", "vigencias": [{"desde": "1960-12-01", "hasta": "", "tipo_version": "3