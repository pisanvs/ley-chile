{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6489343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.729, de 30 de junio de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA PORTALES VALPARAISO S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Espa&#xF1;a s/n, Caleta Diego Portales, Valpara&#xED;so, V Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n de Congelado, Fresco-Enfriado, Fresco-Refrigerado, Ahumado, Seco Salado, Cocido, Deshidratado y Seco-Salado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6489344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6489345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1729 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1729 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-30", "doble_articulado": false, "id_norma": "228175", "numero_fuente": "37921", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-28", "vigencias": [{"desde": "2004-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07-28", "fin_vigencia": "", "tipo_version