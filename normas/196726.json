{"html": [{"t": "<div><div class=\"p\">DESIGNA A DON WILLIAM JOHNNY GALVEZ NU&#xD1;EZ COMO RECEPTOR JUDICIAL</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 150.- Santiago, 22 de marzo de 2002.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974, de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6376987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, Regi&#xF3;n Metropolitana, al siguiente funcionario:</div><br><div class=\"p\">&nbsp; &nbsp;  William Johnny G&#xE1;lvez N&#xFA;&#xF1;ez </div></div>", "i": 6376988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Halabi Caffena, Director Nacional.</div><br></div>", "i": 6376989}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "150", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-150"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA A DON WILLIAM JOHNNY GALVEZ NUÑEZ COMO RECEPTOR\nJUDICIAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-22", "doble_articulado": false, "id_norma": "196726", "numero_fuente": "37236", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-16", "vigencias": [{"desde": "2002-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":