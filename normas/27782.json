{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA EL NOMBRE DE LA CALLE QUE INDICA DE LA COMUNA DE LAS CONDES</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281517}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Des&#xED;gnase con el nombre de Avenida &quot;Alejandro Alvarez&quot;, la actual calle denominada &quot;Don Carlos&quot;, situada en la comuna de Las Condes, de esta capital.&quot; </div></div>", "i": 8281518}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, seis de julio de mil novecientos sesenta y uno.-</div><div class=\"p\">&nbsp; &nbsp; JORGE ALESSANDRI RODRIGUEZ .- S&#xF3;tero del R&#xED;o. </div></div>", "i": 8281519}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14588", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14588"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA EL NOMBRE DE LA CALLE QUE INDICA DE LA COMUNA\nDE LAS CONDES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "AVENIDA ALEJANDRO ALVAREZ", "CONDES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1961-07-06", "doble_articulado": false, "id_norma": "27782", "numero_fuente": "24995", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1961-07-15", "vigencias": [{"desde": "1961-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1961-0