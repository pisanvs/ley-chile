{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6384114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 982, de 22 de mayo de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a SOUTHPACIFIC KORP S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 821 y N&#xBA; 1.919, ambas de 2001, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Avenida Pedro Aguirre Cerda N&#xBA; 989, Lo Rojas, Coronel, VIII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Harina y Aceite, los siguientes recursos hidrobiol&#xF3;gicos: Bacaladillo o mote, Jurel fino, Machuelo o tritre, Anchoveta blanca, Sardina redonda, Vinciguerria.</div><br></div>", "i": 6384115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de mayo de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6384116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "982", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-982"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-22", "doble_articulado": false, "id_norma": "198921", "numero_fuente": "37276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-06", "vigencias": [{"desde": "2002-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-06", "fin_vigencia": "", "tipo_version"