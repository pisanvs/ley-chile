{"html": [{"t": "<div><div class=\"p\">Extracto </div></div>", "i": 6368475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA;110, de 30 de noviembre del a&#xF1;o 2001, se autoriz&#xF3; existencia y aprob&#xF3; el estatuto de la Cooperativa de Trabajo Producci&#xF3;n y Transformaci&#xF3;n Coopemar Trumao Ltda., de sigla Coopemar Trumao Ltda., de Osorno, en los t&#xE9;rminos que da testimonio documento protocolizado ante el Notario de la ciudad de Osorno don Marco Anuch Hayal suplente del titular Cristi&#xE1;n Sanhueza Pimentel, con fecha 26 de octubre de 2001 bajo el N&#xBA;2119-2001.</div><br></div>", "i": 6368476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas.</div><br></div>", "i": 6368477}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "110", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-110"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "Extracto", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "194415", "numero_fuente": "37179", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-06", "vigencias": [{"desde": "2002-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-02-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-02-06", "fin