{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 442 EXENTA, DE 6 DE MAYO DE 2016</div></div>", "i": 9815763}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento a la <a href=\"https://www.leychile.cl/Navegar?idNorma=39435&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 968 del 11 de marzo de 1992</a> del Director del Servicio de Impuestos Internos, la suscrita ha dictado la resoluci&#xF3;n exenta N&#xB0; 442, de 6 de mayo de 2016, que delega en las Jefaturas de las Unidades de Puerto Natales y Porvenir para autorizar individualmente el empleo de m&#xE1;quinas registradoras o electr&#xF3;nicas de modelos o marcas previamente aprobadas por la Direcci&#xF3;n del Servicio para la emisi&#xF3;n de vales en reemplazo de boletas de ventas y servicios, seg&#xFA;n el Art. 56 del DL 825.-</div></div>", "i": 9815764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ana Mar&#xED;a Vargas C&#xE1;rdenas, Directora Regional XII D.R. Punta Arenas, Servicio de Impuestos Internos.</div></div>", "i": 9815765}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "442 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-442 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL PUNTA ARENAS"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 442 EXENTA, DE 6 DE MAYO DE 2016", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; CVE 1244132"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-05-06", "doble_articulado": false, "id_norma": "1105579", "numero_fuente": "41814", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-07-21", "vigencias": [{"desde": "2017-07-