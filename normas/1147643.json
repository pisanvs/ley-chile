{"html": [{"t": "<div><div class=\"p\">ESTABLECE FORMULARIO PARA FINES QUE INDICA</div></div>", "i": 10137586}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 80, del 14 de julio de 2020, donde se establece formulario para declarar y pagar el impuesto sustitutivo de los impuestos finales, aplicable sobre utilidades tributables acumuladas y utilidades reinvertidas que permanezcan en el fondo de utilidades reinvertidas (FUR), que establece el art&#xED;culo vig&#xE9;simo quinto transitorio de la ley N&#xBA; 21.210. Modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=287641&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta SII N&#xBA; 27, del 25 de febrero de 2009</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10137587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Javier Barraza Luengo, Director Nacional.</div><div class=\"p\"> </div><br></div>", "i": 10137588}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "80 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-80 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE FORMULARIO PARA FINES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1786955; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-07-14", "doble_articulado": false, "id_norma": "1147643", "numero_fuente": "42710", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacio