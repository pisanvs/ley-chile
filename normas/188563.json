{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6346114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;850 de fecha 31 de mayo del 2001, se expropi&#xF3; el lote de terreno N&#xBA;15, superficie 9.463,46 m2, rol de aval&#xFA;o N&#xBA;387-55, comuna de Pitrufqu&#xE9;n, para la obra &apos;&apos;Dise&#xF1;o Definitivo Regad&#xED;o Faja Maisan, Expropiaciones Red primaria 4/5, Derivado Mahuidanche&apos;&apos;, sector Km. 2.009,85 al Km. 7.790,94, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario, Gunther Karl Lohr y Otro, ascendente a la cantidad de $5.038.207.- </div></div>", "i": 6346115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6346116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "850", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-850"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-31", "doble_articulado": false, "id_norma": "188563", "numero_fuente": "37038", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-16", "vigencias": [{"desde": "2001-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-08-16", "fecha_version": "2001-08-16", "fecha_actualizacion_texto": "2001-08-16", "tipo_tratad