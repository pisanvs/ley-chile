{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 952 EXENTO, DE 2014</div></div>", "i": 9594727}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 332, de 7 de mayo de 2015, de este Ministerio, modif&#xED;case el art&#xED;culo 4&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1072932&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 952, de 2014</a>, que estableci&#xF3; la cuota global de captura para el a&#xF1;o 2015 para las unidades de pesquer&#xED;as de peque&#xF1;os pel&#xE1;gicos, sometidas a licencias transables de pesca, en el sentido de reemplazar la tabla indicada para el recurso sardina com&#xFA;n, en la unidad de pesquer&#xED;a de la V a X Regiones, por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/48984.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9594728, "v": ["MODIFICACION"]}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de mayo de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9594729}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "332 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-332 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 952 EXENTO, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organis