{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 240 EXENTO, DE 2004 </div></div>", "i": 6478618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 240 de fecha 15 de abril de 2004, de Educaci&#xF3;n, se autoriza al Instituto Profesional Andali&#xE9;n, a contar del presente a&#xF1;o acad&#xE9;mico, la creaci&#xF3;n de la Sede de Villarrica.</div><div class=\"p\">Asimismo, se autoriza para impartir en dicha sede la carrera de Relaciones P&#xFA;blicas, conducente al T&#xED;tulo Profesional de Relacionador P&#xFA;blico.</div><div class=\"p\">Santiago, 28 de abril de 2004.-</div><br></div>", "i": 6478619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6478620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "240 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-240 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 240 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-15", "doble_articulado": false, "id_norma": "225065", "numero_fuente": "37859", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-13", "vigencias": [{"desde": "2004-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-05-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-05-13", "fecha_version": "200