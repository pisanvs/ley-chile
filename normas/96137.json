{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6102083}, {"t": "<div><div class=\"p\">Derechos de Aprovechamiento de Aguas de la Comuna de Peralillo. Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 80 de 22 de Enero de 1992 conforme art&#xED;culo 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; la Divisi&#xF3;n de Derechos de Aprovechamiento de Aguas proporcionales que corresponden al Sector Expropiado y al Sector de la Reserva del predio denominado &quot;Fundo Santa Amelia de Poblaci&#xF3;n ubicado en la Comuna de Peralillo, Provincia de Colchagua VIa. Regi&#xF3;n.</div><div class=\"p\">Los Derechos de Agua se captan con bombas del Estero Las Cadenas.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xAA; 18.377.- </div></div>", "i": 6102084}, {"t": "<div><div class=\"p\">Director Nacional.</div><br></div>", "i": 6102085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "80 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-80 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-22", "doble_articulado": false, "id_norma": "96137", "numero_fuente": "34194", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-02-15", "vigencias": [{"desde": "1992-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-02-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-02-15", "fin_vigencia": "", "tipo_version": "3"}], "ev