{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9696234}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA; 1.017 de 21/12/15. Exp. N&#xBA;1501754. Vistos: Ley N&#xBA;18.755; Ley N&#xBA;18.575, resoluci&#xF3;n N&#xBA;1.600/2008 de la CGR considerando: ADC N&#xB0; 097041, que se&#xF1;ala que al revisar el equipaje de la infractora se intercepta 1 Unidad de Naranja que no fue declarada; 2.- Que, la infractora no formula descargos. 3.- Que, la infractora no registra denuncias anteriores. Resuelvo: Absu&#xE9;lvase por esta &#xFA;nica vez a do&#xF1;a Margarita Villca Rueda, C&#xE9;dula de Identidad N&#xBA;5672187, Nacionalidad Boliviana, domicilio indeterminado.</div></div>", "i": 9696235}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Firma: C&#xE9;sar Cardozo Rojas, Director Regional Regi&#xF3;n de Tarapac&#xE1; Servicio Agr&#xED;cola y Ganadero.</div></div>", "i": 9696236}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1017 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1017 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO REGIÓN DE TARAPACÁ"], "titulo_norma": "NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1012408; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-21", "doble_articulado": false, "id_norma": "1089421", "numero_fuente": "41433", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-04-15", "vigencias": [{"desde": "2016-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen