{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA, MODIFICA Y DICTA ORDENANZAS QUE INDICA </div></div>", "i": 5853580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.- Por Decreto Alcaldicio N&#xB0; 1.084 del 16 de mayo de 1996, se deroga la Ordenanza Local sobre Derechos Municipales por Concesiones, Permisos y Servicios otorgados por la Ilustre Municipalidad de Vicu&#xF1;a, aprobada por Decreto Alcaldicio N&#xB0; 3 de fecha 3 de febrero de 1981 y se dicta la nueva Ordenanza relativa al mismo tema.</div><br></div>", "i": 5853581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 7.- El texto de las se&#xF1;aladas Ordenanzas y sus modificaciones, se encuentra a disposici&#xF3;n del p&#xFA;blico en la Oficina de Secretar&#xED;a Municipal.</div><div class=\"p\">&nbsp; &nbsp; Saluda atentamente a Ud., Edmanuel J. Ferreira Mondaca, Alcalde.</div><br></div>", "i": 5853582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1084", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1084"}], "organismos": ["MUNICIPALIDAD DE VICUÑA"], "titulo_norma": "DEROGA, MODIFICA Y DICTA ORDENANZAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ORDENANZA MUNICIPAL", "MUNICIPALIDAD VICUÑA", "DERECHOS", "MUNICIPALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-16", "doble_articulado": false, "id_norma": "2687", "numero_fuente": "35479", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-30", "vigencias": [{"desde": "1996-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-05-30", "fin_vigencia": "", "tipo_v