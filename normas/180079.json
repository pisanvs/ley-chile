{"html": [{"t": "<div><div class=\"p\">RECTIFICA DECRETO ALCALDICIO N&#xBA; 1.435, DE 2000 </div></div>", "i": 6316053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto N&#xBA; 1.598, 26 diciembre 2000, decreto N&#xBA; 39, 12 enero 2001, Alcalde Municipalidad &#xD1;u&#xF1;oa, rectifica decreto alcaldicio N&#xBA; 1.435, 25 octubre 2000, sentido reemplazar &apos;&apos;art. 3&apos;&apos; por &apos;&apos;punto 3 del presente decreto&apos;&apos;. Deja constancia que inmueble referido punto 1 decreto alcaldicio rectificado, se encuentra inscrito a nombre nudos propietarios expropiados fs. 45.854 N&#xBA; 53.964 a&#xF1;o 1982 y fs. 17.959, N&#xBA; 21.405 a&#xF1;o 1983, y usufructuario vitalicios expropiados fs. 30.630 N&#xBA; 38.025 a&#xF1;o 1982 y fs. 10.350 N&#xBA; 13.098 a&#xF1;o 1983. Registro Propiedad e Hipotecas y Grav&#xE1;menes Conservador Bienes Ra&#xED;ces Santiago.</div><br></div>", "i": 6316054}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1598", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1598"}], "organismos": ["MUNICIPALIDAD DE ÑUÑOA"], "titulo_norma": "RECTIFICA DECRETO ALCALDICIO Nº 1.435, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-26", "doble_articulado": false, "id_norma": "180079", "numero_fuente": "36862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-15", "vigencias": [{"desde": "2001-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-15", "fin_vigencia": "", "tipo_versio