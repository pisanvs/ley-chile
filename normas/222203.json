{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7309721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 776, de 3 de marzo de</div><div class=\"p\">2004, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">parcial de la resoluci&#xF3;n N&#xBA; 444, de 1993, de esta</div><div class=\"p\">Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a MARIA ANA</div><div class=\"p\">MOROZIN BAYCIC para operar la nave &quot;Samoa&quot; entre el</div><div class=\"p\">paralelo 29&#xB0; L.S. y el l&#xED;mite sur de la III Regi&#xF3;n,</div><div class=\"p\">sobre el recurso Besugo, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7309722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de marzo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7309723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "776 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-776 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-03", "doble_articulado": false, "id_norma": "222203", "numero_fuente": "37807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-10", "vigencias": [{"desde": "2004-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen