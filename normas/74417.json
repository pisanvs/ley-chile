{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 871, de 26 de junio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PROSMOLT S.A., para continuar desarrollando las actividades pesqueras autorizadas por Resoluciones N&#xBA; 350, de 1986 y N&#xBA; 976, de 1989, ambas de esta Subsecretar&#xED;a, a Chisal S.A., en virtud de la Escritura P&#xFA;blica de fecha 29 de noviembre de 1996, otorgada ante la Notario P&#xFA;blico do&#xF1;a Edith Cabello Arroyo, suplente del titular de la Trig&#xE9;sima Tercera Notar&#xED;a de Santiago don Iv&#xE1;n Torrealba Acevedo, que dividi&#xF3; la sociedad &quot;Chisal S.A.&quot;.</div><br></div>", "i": 8304749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de junio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304750}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "871", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-871"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PROSMOLT S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-26", "doble_articulado": false, "id_norma": "74417", "numero_fuente": "35822", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-07-22", "vigencias": [{"desde": "1997-07-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-07-22", "fin_vigencia