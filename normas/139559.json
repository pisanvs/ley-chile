{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 18, DE 1988 </div></div>", "i": 6178933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 18 de 03 de febrero de 1988 se ha aprobado, a contar del a&#xF1;o escolar 1988 y por un per&#xED;odo de cuatro a&#xF1;os con car&#xE1;cter experimental, planes de estudio de capacitaci&#xF3;n laboral, para ser aplicados por la Escuela Especial F No. 218 de Nu&#xF1;oa, provincia de Santiago, Regi&#xF3;n Metropolitana. Adem&#xE1;s, se aprueban programas de estudio para los planes aprobados en el art&#xED;culo 1&#xB0; del presente decreto. </div></div>", "i": 6178934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 08 de Febrero de 1988.- Ra&#xFA;l Mohr Aray, Subsecretario de Educacion P&#xFA;blica subrogante. </div></div>", "i": 6178935}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "18 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-18 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 18, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-03", "doble_articulado": false, "id_norma": "139559", "numero_fuente": "33007", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-27", "vigencias": [{"desde": "1988-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac