{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6473730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 133 de fecha 27 de febrero del 2004, se expropi&#xF3; el lote de terreno N&#xBA; 511-A, superficie 689 m2, Rol en tr&#xE1;mite, comuna de Pichidegua, VI Regi&#xF3;n para la obra &quot;Camino Conexi&#xF3;n Vial Pichidegua - Las Cabras, sector San Roberto - El Toco - Ruta 66, Tramo Km. 0,00000 al Km. 12,70000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Yolanda de las Mercedes Carroza Molina, ascendente a la cantidad de $3.883.677.- para el lote N&#xBA; 511-A.</div><br></div>", "i": 6473731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6473732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "133", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-133"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-27", "doble_articulado": false, "id_norma": "223760", "numero_fuente": "37836", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-15", "vigencias": [{"desde": "2004-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-04-15", "fecha_version": "2004-04-15", "fecha_actualizacion_texto": "2004-04-1