{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6664129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 3,49% anual durante el mes de octubre de 2008.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de octubre de 2008, fue de 3,62% anual.</div><br></div>", "i": 6664130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de noviembre de 2008.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6664131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-04", "doble_articulado": false, "id_norma": "281044", "numero_fuente": "39206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-07", "vigencias": [{"desde": "2008-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-11-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p