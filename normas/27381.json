{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AMPLIA PLAZO SE&#xD1;ALADO EN LA LEY N.o 12,437 Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5972665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Ampl&#xED;ase a tres a&#xF1;os el plazo fijado en el art&#xED;culo 8.o de la ley N.o 12,437, de 21 de Febrero de 1957&quot;.</div><br></div>", "i": 5972666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintinueve de Octubre de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Abel Vald&#xE9;s A.- Alberto Sep&#xFA;lveda C.- Eduardo Urz&#xFA;a M.- Eduardo Ya&#xF1;ez Z.- Oscar Acevedo V.</div><br></div>", "i": 5972667}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13197", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13197"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "AMPLIA PLAZO SEÑALADO EN LA LEY N.o 12,437", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD SANTIAGO", "TERRENOS", "TRANSFERENCIA GRATUITA", "FISCO", "EMPRESA AGUA POTABLE", "LAS CONDES", "INMUEBLE", "PRESIDENTE REPUBLICA", "ORGANIZACION NACIONES UNIDAS", "AUTORIZACION TRABAJOS", "INICIACION", "PLAZO", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-10-29", "doble_articulado": false, "id_norma": "27381", "numero_fuente": "24190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-11-10", "vigencia