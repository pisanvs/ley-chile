{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N&#xB0; 11,519, DE 29 DE ABRIL DE 1954 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5970771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zase en el inciso primero del art&#xED;culo &#xFA;nico de la ley N&#xB0; 11,519, de 29 de Abril de 1954, por una coma (,) la conjunci&#xF3;n &quot;y&quot; que precede a la expresi&#xF3;n &quot;a la Universidad T&#xE9;cnica Santa Mar&#xED;a&quot; y agr&#xE9;gase a continuaci&#xF3;n de la citada expresi&#xF3;n, la siguiente: &quot;y a la Universidad Austral de Chile.&quot; </div></div>", "i": 5970772, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, ocho de Junio de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Oscar Herrera Palacios.</div><br></div>", "i": 5970773}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12032", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12032"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY N° 11,519, DE 29 DE ABRIL DE 1954", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FRANQUICIA TRIBUTARIA", "FRANQUICIA ADUANERA", "IMPORTACION", "DERECHO INTERNACION", "UNIVERSIDAD AUSTRAL", "RESPONSABILIDAD SOLIDARIA", "PROHIBICION ENAJENAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-06-08", "doble_articulado": false, "id_norma": "26994", "numero_fuente