{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10164071}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA; 548, de 15 de julio de 2020, se rectific&#xF3; el <a href=\"https://www.leychile.cl/Navegar?idNorma=1144321&amp;idParte=&amp;idVersion=\">Decreto MOP. Exento N&#xBA; 60, de 23 de marzo de 2020</a>, que orden&#xF3; la expropiaci&#xF3;n de los lotes 49-A y 49-B, en lo que respecta al kilometraje inicial del lote N&#xBA; 49-B; donde dice: N&#xBA; 49-B, Km. 1,79900 a Km. 3,80300, debe decir: N&#xBA; 49-B, Km. 3,79900 a Km. 3,80300, en lo no modificado permanece plenamente vigente el Decreto MOP. Exento N&#xBA; 60, de 23 de marzo de 2020. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7 del Decreto Ley N&#xBA; 2186, de 1978. </div></div>", "i": 10164072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10164073}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "548 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-548 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1818968", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-07-15", "doble_articulado": false, "id_norma": "1149941", "numero_fuente": "42769", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-10-01", "vigencias": [{"desde": "2020-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-10-01", "fin_vigenc