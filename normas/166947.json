{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.927, DE 1987 </div></div>", "i": 6269655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.927 de fecha 28 de Agosto de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el art. 1&#xB0; de la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 738 de 1983, del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Luis Alberto Vera de Illapel, en el sentido de modificar la denominaci&#xF3;n de la carrera T&#xE9;cnico en Contabilidad por la siguiente:</div><br><div class=\"p\">Carrera: Contabilidad</div><div class=\"p\">T&#xED;tulo: Contador General</div><br><div class=\"p\">&nbsp; &nbsp;  La presente modificaci&#xF3;n rige a contar del a&#xF1;o 1983 para la sede Central - Illapel y a contar del a&#xF1;o 1985 para la sede No. 1 de Quillota del Centro de Formaci&#xF3;n T&#xE9;cnica Luis Alberto Vera.</div><br></div>", "i": 6269656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salame Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6269657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1927 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1927 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.927, DE 1987", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-08-28", "fecha_derogacion": "2020-07-31", "doble_articulado": false, "id_norma": "166947", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-10-14", "vigencias": [{"desde": "2020-07-31", "hasta": "", "tipo