{"html": [{"t": "<div><div class=\"p\">PARTIDO SOCIALISTA DE CHILE </div></div>", "i": 6434192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos Tapia Sieglitz y Luz Mar&#xED;a Guti&#xE9;rrez Zelada, Presidente y Secretaria del Tribunal Supremo del Partido, y Gonzalo Martner Fanta y Arturo Barrios Ote&#xED;za, Presidente y Secretario General de la Directiva Central del Partido Socialista de Chile, respectivamente, han informado la nueva composici&#xF3;n de la Directiva Central de dicho Partido:</div><br><div class=\"p\">Directiva Central:</div><br><div class=\"p\">Presidente&nbsp; &nbsp; &nbsp; &nbsp; : Gonzalo Martner Fanta</div><div class=\"p\">Secretario General: Arturo Barrios Ote&#xED;za</div><div class=\"p\">Tesorero&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Jaime Gazmuri Mujica</div><br><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O N&#xBA;&nbsp; 887 de fecha 25 de julio de 2003.</div><br></div>", "i": 6434193}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 6434194}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "887", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-887"}, {"tipo": "3", "numero": "O-887", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-887"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO SOCIALISTA DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO SOCIALISTA DE CHILE", "DIRECTIVA CENTRAL", "PRESIDENTE", "GONZALO MARTNER FANTA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion