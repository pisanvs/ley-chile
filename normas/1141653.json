{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 4.559 EXENTA, DE 31 DE DICIEMBRE DE 2019</div></div>", "i": 10096208}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 4.559, de 31 de diciembre de 2019, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, establece beneficiarios elegibles por las empresas para el periodo comprendido entre el 1 de enero y 31 de diciembre de 2020, para efectos de celebrar contratos de capacitaci&#xF3;n en conformidad a lo establecido en el inciso sexto del <a href=\"https://www.leychile.cl/Navegar?idNorma=76201&amp;idParte=8717096&amp;idVersion=\">art&#xED;culo N&#xB0; 33</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=76201&amp;idParte=&amp;idVersion=\">ley 19.518</a>.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10096209, "v": ["CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de diciembre de 2019.- Orlando Mancilla V&#xE1;squez, Director Nacional Subrogante, Servicio Nacional de Capacitaci&#xF3;n y Empleo.</div><br></div>", "i": 10096210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4559 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4559 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DEL TRABAJO", "SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 4.559 EXENTA, DE 31 DE DICIEMBRE DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1717500", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-31", "doble_articulado": false, "id_norma": "1141653", "numero_fuente": "42564