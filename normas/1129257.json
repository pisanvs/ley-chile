{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 1.077 EXENTA, DE 15 DE FEBRERO DE 2019</div><div class=\"p\"> </div></div>", "i": 10003238}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=141056&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 4.096, de 1999, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; plan y programas especiales de estudio de 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Tabancura, comuna de Vitacura, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para las asignaturas de Lengua y Literatura; Matem&#xE1;tica; Historia, Geograf&#xED;a y Ciencias Sociales; Ciencias Naturales: Biolog&#xED;a; Qu&#xED;mica; F&#xED;sica; Filosof&#xED;a; M&#xFA;sica; Educaci&#xF3;n F&#xED;sica y Salud y Ciencia Teol&#xF3;gica y &#xC9;tica para 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media.- </div><br></div>", "i": 10003239}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Raimundo Larra&#xED;n Hurtado, Subsecretario de Educaci&#xF3;n (S).</div></div>", "i": 10003240}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1077 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1077 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 1.077 EXENTA, DE 15 DE FEBRERO DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1551736; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-02-15", "doble_articulado": false, "id_norma": "1129257", "numero_f