{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 2.984, DE 1986 </div></div>", "i": 6191158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 2.984 de fecha 05 de Noviembre de 1986, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas al siguiente plan y programas de estudio, al Centro de Formaci&#xF3;n T&#xE9;cnica Centro Nacional de Capacitaci&#xF3;n Ocupacional, CENCO Ltda., de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1986: Carrera: Programaci&#xF3;n de Aplicaciones Computacionales T&#xED;tulo: Programador de Aplicaciones Computacionales. </div></div>", "i": 6191159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6191160}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2984 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2984 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 2.984, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-11-05", "doble_articulado": false, "id_norma": "143386", "numero_fuente": "32686", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-31", "vigencias": [{"desde": "1987-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-01-31", "fin_vigencia": "", "tipo_version": "3"}], "even