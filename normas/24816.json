{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Eleva a $ 200 mensuales la pensi&#xF3;n de que disfruta don Manuel de la Cruz C&#xE1;ceres.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960415}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. El&#xE9;vase, por gracia, a la cantidad de doscientos pesos mensuales, la pensi&#xF3;n de que actualmente disfruta don Manuel de la Cruz C&#xE1;ceres. </div></div>", "i": 5960416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de Septiembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Carlos O. Frodden. </div></div>", "i": 5960417}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4663", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4663"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "Eleva a $ 200 mensuales la pensión de que disfruta;don Manuel de la Cruz Cáceres.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANUEL DE LA CRUZ CACERES", "PENSION POR GRACIA", "REAJUSTE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-09-30", "doble_articulado": false, "id_norma": "24816", "numero_fuente": "15494", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-10-10", "vigencias": [{"desde": "1929-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-10-10", "fin_vigencia": ""}, "vigencias_