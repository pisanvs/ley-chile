{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6356248}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.134, de 10 de octubre de</div><div class=\"p\">2001, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; SOCIEDAD</div><div class=\"p\">PROCESADORA DE ALIMENTOS SOCOVEL LIMITADA para ampliar</div><div class=\"p\">actividades pesqueras extractivas con la nave &quot;Oficina</div><div class=\"p\">California&quot;, matr&#xED;cula 1891, en el &#xE1;rea mar&#xED;tima de</div><div class=\"p\">la I a la IV Regiones, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, con arte de arrastre, sobre los siguientes recursos hidrobiol&#xF3;gicos: Besugo, Congrio dorado, Pejerrata y Raya.</div><br></div>", "i": 6356249}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de octubre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6356250}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2134", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2134"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-10", "doble_articulado": false, "id_norma": "191369", "numero_fuente": "37106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-09", "vigencias": [{"desde": "2001-11-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-09", "fin_vigencia": "