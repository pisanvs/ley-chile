{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9286073}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;1179 de fecha 29 de junio de 2012, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;14, superficie 611 m2, rol N&#xBA;84-79, comuna de Do&#xF1;ihue, para la obra &quot;Reposici&#xF3;n Puente Coinco, Comunas de Coinco y Do&#xF1;ihue&quot;, VI Regi&#xF3;n. La Comisi&#xF3;n de Peritos integrada por Norman Calder&#xF3;n Pontiggia, Oscar Navea Mu&#xF1;oz y Mar&#xED;a Isabel de Jes&#xFA;s R&#xED;os Marcuello, fij&#xF3; valor de tasaci&#xF3;n con fecha 01 de agosto de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario ALEJANDRO DANIEL FERN&#xC1;NDEZ SOTO, en la cantidad de $4.846.935, suma que se pagar&#xE1; al contado. </div></div>", "i": 9286074}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9286075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1179 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1179 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-29", "doble_articulado": false, "id_norma": "1042439", "numero_fuente": "40326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-01", "vigencias": [{"desde": "2012-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-01", "fin_vigencia": ""}, "vigencias_version_norma":