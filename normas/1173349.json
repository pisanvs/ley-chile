{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 31B</div></div>", "i": 10315373}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 487, de 25 de febrero de 2022, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1172525&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 328 de 2022</a>, y de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 31B, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que se indica en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10315374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de febrero de 2022.- M&#xF3;nica Orellana Vald&#xE9;s, Subsecretaria de Pesca y Acuicultura (S).</div><div class=\"p\"> </div><br></div>", "i": 10315375}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "487 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-487 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 31B", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2094934", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-02-25", "doble_articulado": false, "id_norma": "1173349", "numero_fuente": "43194", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-03-04", "vigenci