{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,358, que declara feriado el dia 5 de Abril de 1918.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,358.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276228}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se declara feriado el dia 5 de Abril de 1918.</div><div class=\"p\">&nbsp; &nbsp; La presente lei rejir&#xE1; desde la fecha de su publicacion en el Diario Oficial.</div><br></div>", "i": 8276229}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a tres de Abril de mil novecientos dieciocho.- JUAN LUIS SANFUENTES.- Domingo Amun&#xE1;tegui. </div></div>", "i": 8276230}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3358", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3358"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,358, QUE DECLARA FERIADO EL 5 DE ABRIL DE 1918.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FERIADO NACIONAL", "DECLARACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-04-03", "doble_articulado": false, "id_norma": "23922", "numero_fuente": "12036", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-04-03", "vigencias": [{"desde": "1918-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-04-03", "fin_vigencia": ""}, "vigencias_version_norm