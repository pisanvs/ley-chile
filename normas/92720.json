{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 61, DE 1989</div><br><br></div>", "i": 6092262}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 61 de 31 de marzo de 1989, se ha aprobado a contar del a&#xF1;o 1989, el aumento de una clase a la semana en la asignatura de Ciencias Naturales en los cursos de 1&#xB0; y 2&#xB0; a&#xF1;o medio human&#xED;stico - cient&#xED;fica con las condiciones que se indican, en los establecimientos educacionales que se se&#xF1;alan, dependientes de la Corporaci&#xF3;n de Dollo Social de la I. Municipalidad de Providencia:</div><br><div class=\"p\">- Liceo A No. 12 &quot;Arturo Alessandri Palma&quot;;</div><div class=\"p\">- Liceo B No. 42 &quot;Tajamar&quot;;</div><div class=\"p\">- Liceo A No. 43 &quot;Luisa Saavedra de Gonz&#xE1;lez&quot;;</div><div class=\"p\">- Liceo A No. 44 &quot;Carmela Carvajal de Prat&quot;; y</div><div class=\"p\">- Liceo A No. 45 &quot;Jos&#xE9; Victorino Lastarria&quot;.</div><br></div>", "i": 6092263}, {"t": "<div><div class=\"p\">Santiago, 24 de Abril de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6092264}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "61 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-61 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 61, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-04-24", "fecha_derogacion": "1992-04-24", "doble_articulado": false, "id_norma": "92720", "numero_fuente": "33361", "tipo_version": "2",