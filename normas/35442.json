{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293878}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 727, de 12 de abril de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., para un centro de cultivo ubicado en Punta Terao, comuna de Chonchi, provincia de Chilo&#xE9;, X Regi&#xF3;n, por no dar cumplimiento el respectivo proyecto t&#xE9;cnico a lo dispuesto en los art&#xED;culos 78&#xB0; y 87&#xB0; de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8293879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293880}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "727", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-727"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPA IA PESQUERA CAMANCHACA S.A", "CHONCHI", "DECIMA REGION", "CONCESION ACUICULTURA", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-12", "doble_articulado": false, "id_norma": "35442", "numero_fuente": "35449", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-23", "vigencias": [{"desde": "1996-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-04-23", "fin_vigencia": "", "t