{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA CONCESION DE RADIODIFUSION SONORA</div><div class=\"p\">&nbsp; &nbsp; Santiago, 18 de Julio de 1986.- Con esta fecha se ha decretado lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 126.-</div><div class=\"p\"> _______________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 34.944 DEL DIA VIERNES&nbsp; |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  19 DE AGOSTO DE 1994, PAGINA 14&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  |</div><div class=\"p\"> |_____________________________________________________|</div><br></div>", "i": 7138631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, reg&#xED;strese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese en el Diario Oficial. Por orden del Presidente de la Rep&#xFA;blica, Enrique Escobar Rodr&#xED;guez, General de Aviaci&#xF3;n, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda atentamente a Ud., Gustavo Arenas Corral, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 7138632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "126", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-126"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "MODIFICA CONCESION DE RADIODIFUSION SONORA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "CONCESION RADIODIFUSION SONORA", "ONDA MEDIA", "RED AUSTRAL RADIODIFUSION LIMITADA", "PUNTA ARENAS", "DECIMOSEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-18", "doble_articulado": false, "id_norma": "