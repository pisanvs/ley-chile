{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 8324773}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 97 de fecha 05.07.89 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la Asociaci&#xF3;n Gremial Educere Per Labor, inscrita bajo el n&#xFA;mero 27-5, del registro que lleva este Ministerio, por haberse configurado de ella la causal de cancelaci&#xF3;n contemplada en el Art&#xED;culo 18 No. 2 letra d) del DL 2.757 de 1979.</div><br></div>", "i": 8324774}, {"t": "<div><div class=\"p\">Norman Bull de la Jara, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8324775}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "97", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-97"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA", "FOMENTO"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-05", "doble_articulado": false, "id_norma": "94348", "numero_fuente": "33448", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-14", "vigencias": [{"desde": "1989-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-03-06", "fecha_version": "1