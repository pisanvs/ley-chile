{"html": [{"t": "<div><div class=\"p\">FIJA TRAZADOS DE CIRCULACION DE VEHICULOS DE LOCOMOCION COLECTIVA</div><br><br></div>", "i": 7246754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta No. 626 de fecha 29 de Marzo de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule, se fijaron los trazados urbanos por los cuales podr&#xE1;n circular los veh&#xED;culos que efect&#xFA;an servicio de locomoci&#xF3;n colectiva no urbana, en tr&#xE1;nsito hacia o desde el Terminal de Buses de la Comuna de Parral, ubicado en Alameda Las Delicias, entre las calles Arturo Prat e Igualdad.-</div><br></div>", "i": 7246755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alfonso Rodr&#xED;guez del R&#xED;o, Alcalde de Parral.- Juan Carlos Alvarez Maigret, Secretario Municipal. </div></div>", "i": 7246756}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "626 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-626 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "FIJA TRAZADOS DE CIRCULACION DE VEHICULOS DE LOCOMOCION;COLECTIVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-03-29", "fecha_derogacion": "1989-07-21", "doble_articulado": false, "id_norma": "133488", "numero_fuente": "33053", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-04-23", "vigencias": [{"desde": "1989-07-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1988-04-23", "hasta": "19