{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6222151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1482 de 12 de Agosto de 1987, conforme art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden al Proyecto de Parcelaci&#xF3;n &quot;Las Casas de Pile&quot;, de la comuna de Mulch&#xE9;n, VIII Regi&#xF3;n, formado por las Parcelas N&#xB0;s. 1 a la 4, 10 y 11, y Reservas CORA N&#xB0;s. 1 y 2 del Predio &quot;Las Casas de Pil&#xE9;&quot;. Los derechos de agua se extraen de derrames del Estero Pile.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme art. 13 Ley No. 18.377.- </div></div>", "i": 6222152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6222153}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1482 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1482 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-12", "doble_articulado": false, "id_norma": "152115", "numero_fuente": "32847", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-17", "vigencias": [{"desde": "1987-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-17", "fin_vigencia": "", "ti