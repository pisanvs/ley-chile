{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 379, DE 1986 </div></div>", "i": 8356837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 797, de 27 de Julio de 1987, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 379, de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; la operaci&#xF3;n de las embarcaciones &quot;Coray I&quot; y &quot;Coray II&quot; a Sociedad Pesquera del Sur S.A., domiciliada en Santiago, en orden a: a) Incluir entre los artes de pesca que puede utilizar una red de cerco de 280 brazas de largo; 40 brazas de alto y 0,5 pulgadas de tama&#xF1;o de malla, y b) Ampliar el destino de los recursos que se le autorizaron en el numeral 5&#xB0; de la citada resoluci&#xF3;n, a consumo humano.</div><br></div>", "i": 8356838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de Julio de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8356839}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "797", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-797"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 379, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-27", "doble_articulado": false, "id_norma": "151549", "numero_fuente": "32835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-01", "vigencias": [{"desde": "1987-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige