{"html": [{"t": "<div><div class=\"p\"> EXTRACTO DE RESOLUCION&#xA0;</div></div>", "i": 7417638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n exenta N&#xB0; 193 de Febrero 23 de 1983, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, se autoriza a la Asociaci&#xF3;n Gremial de Transportes de Pasajeros San Bernardo, para efectuar el servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros en el recorrido de la Sub-Variante N&#xB0; 107-B-1 &quot;La Granja Mapocho Juan A. R&#xED;os&quot;, de la L&#xED;nea de Buses N&#xB0; 107, cuyo trazado fue autorizado por <a href=\"https://www.leychile.cl/Navegar?idNorma=284161&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 1406 </a>de Diciembre 29 de 1980, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 10137954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 25 de 1983.- Mauricio Mena Cruzat, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana. </div><br><br></div>", "i": 10137955}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "193 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-193 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": " EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["PF"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1983-02-23", "doble_articulado": false, "id_norma": "284181", "numero_fuente": "31522", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1983-03-21", "vigencias": [{"desde": "1983-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic