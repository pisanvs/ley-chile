{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6415193}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 234, de 28 de enero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SAN JOSE S.A., para realizar actividades extractivas en aguas internacionales con la nave &quot;Conquistador&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><div class=\"p\"> Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2763-Valpara&#xED;so</div><div class=\"p\">&nbsp; &nbsp;  Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-4843</div><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  50,75 m</div><div class=\"p\">&nbsp; &nbsp;  T.R.G. (Internacional)&nbsp; &nbsp; &nbsp;  913,00</div><div class=\"p\">&nbsp; &nbsp;  Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 999,56 m3</div><div class=\"p\">&nbsp; &nbsp;  Potencia motor principal&nbsp; &nbsp;  2.700,00 Hp</div><div class=\"p\">&nbsp; &nbsp;  Potencia motor auxiliar&nbsp; &nbsp; &nbsp; 1.117,00 Hp</div><br></div>", "i": 6415194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de enero de 2003.-&nbsp; Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6415195}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "234", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-234"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-28", "doble_articulado": false, "i