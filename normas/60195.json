{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300537}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 2.144, de 26 de diciembre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2 de la Resoluci&#xF3;n N&#xBA; 463 de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Salmones Puntra S.A. hoy SOCIEDAD PESQUERA TREMAR S.A., para realizar actividades pesqueras extractivas con una nave en construcci&#xF3;n, denominada &quot;Don Mauro&quot;, en el sentido de se&#xF1;alar que las actuales caracter&#xED;sticas n&#xE1;uticas de dicha nave son las siguientes:</div><br><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Don Mauro</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2792</div><div class=\"p\">Eslora de Arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 46,00 m</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  10,40 m</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  6,40 m</div><div class=\"p\">T.R.G.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  799,80</div><div class=\"p\">T.R.N.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  300,00</div><div class=\"p\">Capacidad de Bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 1.066,03 m3</div><div class=\"p\">Arte de Pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Cerco</div><br></div>", "i": 8300538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de diciembre de 1996.-</div><br><div class=\"p\">&nbsp; &nbsp;  Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca. </div></div>", "i": 8300539}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2144", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2144"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "SALMONES PUNTRA S.A.", "SOCIEDAD PESQUERA TREMAR S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["extracto"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-26", "doble_articulado": false, "id_norma": "60195", "numero_fuente": "35669", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-18", "vigencias": [{"desde": "1997-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-01-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CAV", "fecha_ingreso": "1997-02-03", "fecha_version": "1997-01-18", "fecha_actualizacion_texto": "1997-01-18", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8300537}, {"n": "Artículo", "i": 8300538, "t": 6}, {"n": "Promulgación", "i":