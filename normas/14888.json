{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA DECRETO N&#xB0; 500, DE 1993</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 653.- Santiago, 09 de Junio de 1993.- Vistos: La Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica y el art&#xED;culo N&#xB0; 22 de la Ley N&#xB0; 18.575; el Decreto N&#xB0; 500 de 1993, del Ministerio de Relaciones Exteriores.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7152001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1. Modif&#xED;case el Decreto N&#xB0; 500 de 1993, que designa Ministro de Relaciones Exteriores en calidad de subrogante a don Patricio Enrique Rojas Saavedra, en el sentido que dicha subrogaci&#xF3;n se realiz&#xF3; hasta el 05 de Junio de 1993, y no como se indica en el Decreto que se modifica.</div><br></div>", "i": 7152002, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Enrique Silva Cimma, Ministro de Relaciones Exteriores.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a US para su conocimiento.- Cristi&#xE1;n Barros Melet, Director General Administrativo. </div></div>", "i": 7152003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "653", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-653"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "MODIFICA DECRETO N° 500, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUBROGACION", "MINISTERIO RELACIONES EXTERIORES", "PATRICIO ENRIQUE ROJAS SAAVEDRA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-09", "doble_articulado": false, "id_norma"