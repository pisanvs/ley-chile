{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9088385}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;3.640, de 2 de diciembre de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL MELINKA Y COMPA&#xD1;&#xCD;A LIMITADA para capturar, en loberas ubicadas en la XII Regi&#xF3;n, en el plazo de 1 a&#xF1;o contado desde la fecha de la presente resoluci&#xF3;n, la cantidad total de 30 ejemplares juveniles de la especie Lobo marino com&#xFA;n, en la forma y condiciones se&#xF1;aladas en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  El solicitante designa como persona responsable de esta autorizaci&#xF3;n a do&#xF1;a Teresa Saldivia Moraga.</div></div>", "i": 9088386}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de diciembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9088387}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3640", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3640"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-02", "doble_articulado": false, "id_norma": "1021599", "numero_fuente": "39846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-29", "vigencias": [{"desde": "2010-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-12-29", "fin_vigencia": "", "tipo_version"