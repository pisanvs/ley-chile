{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY 9,741, RELACIONADA CON OBREROS DE LOS SERVICIOS DE EXPLOTACION DE PUERTOS</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7172841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Supr&#xED;mese en el art&#xED;culo transitorio de la ley N.o 9,741, de 9 de Noviembre de 1950, la siguiente frase que figura al final del inciso primero:</div><div class=\"p\">&quot;a su vigencia&quot;.</div><br></div>", "i": 7172842, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinte de Octubre de mil novecientos cincuenta y uno.- GABRIEL GONZALEZ VIDELA.- Jorge Mardones Restat.</div><br></div>", "i": 7172843}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10022", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10022"}], "organismos": ["MINISTERIO DE SALUBRIDAD, PREVISIÓN Y ASISTENCIA SOCIAL"], "titulo_norma": "MODIFICA LA LEY 9,741, RELACIONADA CON OBREROS DE\nLOS SERVICIOS DE EXPLOTACION DE PUERTOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERVICIO EXPLOTACION", "PUERTOS", "OBREROS", "REGIMEN PREVISIONAL", "PREVISION", "CAJA NACIONAL EMPLEADOS PUBLICOS PERIODISTAS", "INCORPORACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1951-10-20", "doble_articulado": false, "id_norma": "26290", "numero_fuente": "22089", "tipo_version": "3", "tipo_versi