{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7380398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. (exento) N&#xBA; 1.017 de 30 de septiembre de 2008, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP. (exento) N&#xBA; 1.155 de 30 de septiembre de 2003, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote N&#xB0; 52-A. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 52-A, fijada por la Comisi&#xF3;n de Peritos, con fecha 1 de octubre de 2002, ascendente a la cantidad de $1.897.200.</div><br></div>", "i": 7380399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7380400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1017 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1017 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-09-30", "doble_articulado": false, "id_norma": "280883", "numero_fuente": "39202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-03", "vigencias": [{"desde": "2008-11-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-11-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-11-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":