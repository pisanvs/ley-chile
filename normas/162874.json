{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6256741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 594, de 23 de marzo de 2000, modif&#xED;case la resoluci&#xF3;n N&#xBA; 99 del 2000, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Anchoveta Engraulis ringens y Sardina espa&#xF1;ola Sardinops sagax, declaradas en estado de plena explotaci&#xF3;n y sometidas a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral de la III y IV Regiones, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, al 30 de junio de 1999, en el sentido de incluir lo siguiente:</div><br><br><div class=\"p\">Armador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Nave</div><br><div class=\"p\">Sociedad Inmobiliaria&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Isla Orcas</div><div class=\"p\">Comercial e Industrial Bremen</div><br></div>", "i": 6256742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de marzo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6256743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "594", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-594"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-03-23", "fecha_derogacion": "2000-08-02", "doble_articulado": false, "id_norma": "162874", "num