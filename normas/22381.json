{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Club Jimn&#xE1;stico Aleman Lei n&#xFA;m. 1.056.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la Sociedad Club Jimn&#xE1;stico Aleman el permiso requerido por el art&#xED;culo 556 del C&#xF3;digo Civil para que pueda conservar hasta por treinta a&#xF1;os la posesion de un bien raiz situado en la calle de San Martin, n&#xFA;mero 841 de esta capital.</div><br><br></div>", "i": 5948287}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 11 de Agosto de 1898.- FEDERICO ERRAZURIZ.- C&#xE1;rlos A. Palacios Z.</div><br></div>", "i": 5948288}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1056", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1056"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "Club Jimnástico Aleman", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD CLUB GIMNASTICO ALEMAN", "BIEN RAIZ", "POSESION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-08-11", "doble_articulado": false, "id_norma": "22381", "numero_fuente": "6078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-08-17", "vigencias": [{"desde": "1898-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-08-17", "fin_vig