{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.189 EXENTA, DE 2014</div></div>", "i": 9499405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta, se han modificado las resoluciones exentas Nos <a href=\"https://www.leychile.cl/Navegar?idNorma=140121&amp;idParte=0&amp;idVersion=\">4.084</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=159501&amp;idParte=0&amp;idVersion=\">12.866</a>, ambas de 1999, del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 1&#xBA; y 2&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al colegio The Angel&apos;s School, comuna de &#xD1;u&#xF1;oa, provincia de Santiago, Regi&#xF3;n Metropolitana, en el sentido de sustituir sus planes de estudio de 1&#xBA; y 2&#xBA; a&#xF1;o medio, por el que se indica en la presente resoluci&#xF3;n exenta.</div></div>", "i": 9499406}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de agosto de 2014.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9499407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5189 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5189 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.189 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-08-13", "doble_articulado": false, "id_norma": "1065701", "numero_fuente": "40939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-08-22", "vigencias": [{"desde": "2014-08-22", "