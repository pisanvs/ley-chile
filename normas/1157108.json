{"html": [{"t": "<div><div class=\"p\">ERRAZURIZ (D. RAMON) ES SUSPENDIDO DE LA CIUDADAN&#xCD;A POR EL TERMINO DE DOS A&#xD1;OS.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional con fecha 13 de este mes ha sancionado lo siguiente:</div></div>", "i": 10237386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. &#xFA;nico. Se declara a D. Ramon Err&#xE1;zuriz incurso en la pena de la lei de 1.&#xB0; de mayo.</div></div>", "i": 10237387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se guarde y cumpla, comunicandose a quienes corresponda e insert&#xE1;ndose en el Bolet&#xED;n. Dado en la Sala de Gobierno en Santiago de Chile a 16 de junio de 1828.</div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><div class=\"p\">&nbsp; &nbsp;  Rodr&#xED;guez.</div></div>", "i": 10237388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "ERRAZURIZ (D. RAMON) ES SUSPENDIDO DE LA CIUDADANÍA POR EL TERMINO DE DOS AÑOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-06-16", "doble_articulado": false, "id_norma": "1157108", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-06-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-06-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-06-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "17616", "fecha_ingreso": "2021-06-03