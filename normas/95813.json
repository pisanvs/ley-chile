{"html": [{"t": "<div><div class=\"p\">NOMBRA MINISTRO DE ESTADO EN CARTERA QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de enero de 1998.- Hoy se decret&#xF3; lo que sigue:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 68.- Visto: Lo dispuesto en el art&#xED;culo 32 N&#xBA; 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile.</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o :</div><br></div>", "i": 8326715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico: N&#xF3;mbrase a contar de esta fecha, como Ministro de Defensa Nacional a don Ra&#xFA;l Troncoso Castillo.</div><br></div>", "i": 8326716}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Carlos Figueroa Serrano, Ministro del Interior.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8326717}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "68", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-68"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "NOMBRA MINISTRO DE ESTADO EN CARTERA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTRO DE ESTADO", "MINISTERIO DE DEFENSA NACIONAL", "RAUL TRONCOSO CASTILLO", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-16", "doble_articulado": false, "id_norma": "95813", "numero_fuente": "35986", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-09", "