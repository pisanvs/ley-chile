{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6499846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.655, de 16 de septiembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA LOTA VEDDE LIMITADA ARIES Y COMPA&#xD1;IA COMANDITA POR ACCIONES para ampliar actividades pesqueras extractivas con la nave &quot;La Ni&#xF1;a I&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la V a VII Regiones, y en la IX y X Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con cerco los recursos hidrobiol&#xF3;gicos Calamar y Pota del Atl&#xE1;ntico.</div><br></div>", "i": 6499847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6499848}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2655 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2655 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-16", "fecha_derogacion": "2005-02-21", "doble_articulado": false, "id_norma": "231081", "numero_fuente": "37978", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-10-05", "vigencias": [{"desde": "2005-02-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-10-05", "hasta": "2005-02-20", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2005-02-21", "fin_vigencia": ""}, "vigencia