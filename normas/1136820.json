{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 54 A</div></div>", "i": 10057045}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.119, de 17 de septiembre de 2019, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1133747&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.430 de 2019</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 54 A, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para los centros de cultivo que se indican en la resoluci&#xF3;n extractada.</div><br></div>", "i": 10057046}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de septiembre de 2019.- Jos&#xE9; Pedro N&#xFA;&#xF1;ez Barruel, Subsecretario de Pesca y Acuicultura (S).</div><br></div>", "i": 10057047}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3119 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3119 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 54 A", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1660001", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-09-17", "doble_articulado": false, "id_norma": "1136820", "numero_fuente": "42464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-09-28", "vigencias": [{"desde": "2019-09-28", "h