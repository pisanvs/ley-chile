{"html": [{"t": "<div><div class=\"p\">ESTABLECE DEROGACI&#xD3;N DE RESOLUCI&#xD3;N N&#xBA; 26 EXENTA, DE 2004 </div></div>", "i": 6635961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 3, del 7 de enero de 2008, que establece la derogaci&#xF3;n de la resoluci&#xF3;n Ex. N&#xBA; 26, de 06.02.2004, que establece obligaci&#xF3;n de presentar Declaraci&#xF3;n Jurada sobre rentas del Art. 42, N&#xBA; 1, de la Ley de la Renta (Sueldos), Retenciones del Impuesto &#xDA;nico y capacitados por Sence.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, se publicar&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2008.</div><br></div>", "i": 6635962}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE DEROGACIÓN DE RESOLUCIÓN Nº 26 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-01-07", "doble_articulado": false, "id_norma": "268292", "numero_fuente": "38958", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-01-11", "vigencias": [{"desde": "2008-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-01-11", "fin_vig