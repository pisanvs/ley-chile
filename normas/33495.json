{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIOS QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 156.- Santiago, 8 de septiembre de 1994.- Vistos: Lo dispuesto en el Art. 11 del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6007074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley citado, en la I Regi&#xF3;n a los se&#xF1;ores:</div><div class=\"p\">&nbsp; &nbsp; - Mario Alejandro Concha Sanhueza - Ricardo Agust&#xED;n Sossa V&#xE1;squez </div></div>", "i": 6007075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Luis Marambio Canales, Director Nacional.</div><br></div>", "i": 6007076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "156", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-156"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIOS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECEPTOR JUDICIAL", "NOMBRAMIENTO", "PRIMERA REGION", "JUICIOS", "CREDITO AGRICOLA", "MARIO ALEJANDRO CONCHA SANHUEZA", "RICARDO AGUSTIN SOSSA VASQUEZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-08", "doble_articulado": false, "id_norma": "33495", "numero_fuente": "34981", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-10-03", "vigencias