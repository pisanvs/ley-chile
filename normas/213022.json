{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CERTIFICADO</div><br></div>", "i": 6433512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Ministro de Fe de las actuaciones del Consejo y del Banco Central de Chile que suscribe, conforme lo dispone el N&#xBA; 6 del art&#xED;culo 18 de la ley N&#xBA; 18.840, certifica que de conformidad con lo establecido en el Cap&#xED;tulo III.F.5. del Compendio de Normas Financieras, las Clasificaciones de Riesgo de los estados soberanos y las entidades bancarias extranjeras contenidas en el Anexo de la citada norma permanecen, para los efectos previstos en dicho Cap&#xED;tulo, sin variaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Se deja constancia que las Clasificaciones de Riesgo corresponden a la informaci&#xF3;n disponible en el Banco Central de Chile hasta el 27 de julio del 2003. </div></div>", "i": 6433513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de julio del 2003.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6433514}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-28", "doble_articulado": false, "id_norma": "213022", "numero_fuente": "37623", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-31", "vigencias": [{"desde": "2003-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-31", "fin_vigencia": ""}, "v