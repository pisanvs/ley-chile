{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 3.431, DE 1986 </div></div>", "i": 6202381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 3.431 de fecha 18 de Diciembre de 1986, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 97 de 1983 del Centro de Formaci&#xF3;n T&#xE9;cnica Academia Universo, en el sentido de modificar las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n aprobadas para el centro y de agregar a las carreras Mec&#xE1;nica General Automotriz y Electricidad Industrial el perfil profesional del t&#xE9;cnico deseado y nueva red secuencial de asignaturas.</div><br></div>", "i": 6202382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6202383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3431 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3431 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 3.431, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-18", "doble_articulado": false, "id_norma": "146844", "numero_fuente": "32740", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-06", "vigencias": [{"desde": "1987-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-06", "fin_vigencia": "", "t