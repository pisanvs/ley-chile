{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,029.- Santiago, 25 de enero de 1898.- Por cuanto el Congreso Nacional ha tenido a bien aprobar el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a dos mil cuatrocientos pesos ($ 2,400) al a&#xF1;o la pension que la lei de 12 de setiembre de 1884 asigna a do&#xF1;a Josefa Carrera de Lira i a su hija soltera do&#xF1;a C&#xE1;rmen Lira i Carrera.</div><br></div>", "i": 6161464}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Patricio Larrain A.</div><br></div>", "i": 6161465}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1029", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1029"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-25", "doble_articulado": false, "id_norma": "134144", "numero_fuente": "5914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-28", "vigencias": [{"desde": "1898-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-01-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-03-30", "