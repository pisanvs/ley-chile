{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 976, de 4 de julio de 1997, de esta Subsecretar&#xED;a de Pesca; del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; modif&#xED;case el numeral 1&#xBA; de la Resoluci&#xF3;n N&#xBA; 923, de 1995, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; SOCIEDAD PESQUERA MAR XENARA S.A., para sustituir la nave &quot;Pur&#xE9;n&quot;, en el sentido de actualizar las caracter&#xED;sticas n&#xE1;uticas de esta &#xFA;ltima, en los t&#xE9;rminos que se indica:</div><br><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;Pur&#xE9;n&quot;</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 1910</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp;  22,1&nbsp; m.</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; &nbsp; 76,6&nbsp; t.</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp;  118,9 m3.</div><div class=\"p\">Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Cerco</div><br></div>", "i": 8305067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305068}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "976", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-976"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "SOCIEDAD PESQUERA MAR XENARA S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derog