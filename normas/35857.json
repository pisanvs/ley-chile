{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 915, de 26 de Julio de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 282, de 1993, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a PESQUERA PLAYA BLANCA S.A., R.U.T.: N&#xB0; 88.875.700-7, para ampliar actividades pesqueras, en el sentido de reemplazar la nave que la interesada pod&#xED;a operar por otra, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><div class=\"p\"> Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;Inger Hildur&quot;</div><div class=\"p\"> Eslora total&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 46,0 m</div><div class=\"p\"> T.R.G.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  548,7</div><div class=\"p\"> Capacidad de bodega&nbsp; &nbsp; 603,2 m3</div><div class=\"p\"> Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Cerco y Trampas</div><br></div>", "i": 8294824, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Julio de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294825}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "915", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-915"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA PLAYA BLANCA S.A.", "PESCA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-07-26", "fecha_derogacion": "2001-01-04",