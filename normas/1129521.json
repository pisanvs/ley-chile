{"html": [{"t": "<div><div class=\"p\">FIJA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESI&#xD3;N DE SALM&#xD3;NIDOS 50A REGI&#xD3;N DE MAGALLANES Y DE LA ANT&#xC1;RTICA CHILENA</div></div>", "i": 10005076}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 763, de 27 de febrero de 2019, de esta Subsecretar&#xED;a, f&#xED;janse las densidades para agrupaci&#xF3;n 50A:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/90403.jpg\">.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Except&#xFA;anse los centros que se acojan al porcentaje de reducci&#xF3;n de siembra, que tendr&#xE1;n la densidad establecida por <a href=\"https://www.leychile.cl/Navegar?idNorma=1003741&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.449, de 2009</a>, del Servicio Nacional de Pesca y Acuicultura, de conformidad con el art&#xED;culo 62 del DS N&#xB0; 319, de 2001, de este Ministerio.</div></div>", "i": 10005077}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de febrero de 2019.- Eduardo Riquelme Portilla, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 10005078}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "763 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-763 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "FIJA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIÓN DE SALMÓNIDOS 50A REGIÓN DE MAGALLANES Y DE LA ANTÁRTICA CHILENA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1556471", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fe