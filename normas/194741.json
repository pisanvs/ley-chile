{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6369808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 388 de 14 de febrero de 2002 de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 630 de 1997 de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA FRANCO LIMITADA, para ampliar actividades pesqueras extractivas con la nave &quot;Jofrani&quot;, por haberse configurado las causales previstas en el art&#xED;culo 143 letras b) y d) de la ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 6369809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de febrero de 2002.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6369810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "388", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-388"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-14", "doble_articulado": false, "id_norma": "194741", "numero_fuente": "37191", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-20", "vigencias": [{"desde": "2002-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-02-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_ingreso": "2002-02