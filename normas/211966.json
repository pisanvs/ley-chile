{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6429762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.297, de 18 de junio de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a FAENADORA SUPER LTDA. para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en el kil&#xF3;metro 18 Ruta H-30 S/N, localidad de Lo Miranda, comuna de Do&#xF1;ihue, VI Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Hamburguesas, Empanizados y Marinados: Salm&#xF3;n del Pac&#xED;fico, Salm&#xF3;n del Atl&#xE1;ntico y Trucha arcoiris.</div><br></div>", "i": 6429763}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de junio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6429764}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1297", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1297"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-18", "doble_articulado": false, "id_norma": "211966", "numero_fuente": "37598", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-02", "vigencias": [{"desde": "2003-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "