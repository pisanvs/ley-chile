{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6028232}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 930, de 31 de octubre de 1996, se expropiaron los lotes de terrenos N&#xBA;s. 7 y 11, superficies 215 y 70 m2 respectivamente, roles de aval&#xFA;o 179-412 y 172-11, comuna de Nogales, para la obra Paso Superior y acceso a El Mel&#xF3;n, Camino Ruta 5 Norte y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios, Eliana Villegas Urrutia y orden de los Carmelitas Descalzos, ascendentes a las cantidades de $728.460 para el lote N&#xBA; 7 y $487.123 para el lote N&#xBA; 11.- </div></div>", "i": 6028233}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6028234}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "930", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-930"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "NOGALES", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-10-31", "doble_articulado": false, "id_norma": "60044", "numero_fuente": "35666", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-15", "vigencias": [{"desde": "1997-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMR", "fecha_ingreso": "1997-01-28", "fe