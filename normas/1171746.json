{"html": [{"t": "<div><div class=\"p\">REVOCA RESOLUCI&#xD3;N N&#xB0; 4 EXENTA, DE 2022, DE ESTA SUBSECRETAR&#xCD;A</div></div>", "i": 10304910}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 141, de&nbsp; 19 de enero de 2022, de esta Subsecretar&#xED;a, rev&#xF3;case la <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1164986&amp;idVersion=2022-01-26\">resoluci&#xF3;n exenta N&#xB0; 4 de 2022</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; l&#xED;mites de captura en actividades de pesca recreativa y submarina en las aguas marinas del territorio nacional.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la presente resoluci&#xF3;n se encuentra publicado en www.subpesca.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br><br></div>", "i": 10304911, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2022.- Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><br></div>", "i": 10304912}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "141 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-141 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "REVOCA RESOLUCIÓN N° 4 EXENTA, DE 2022, DE ESTA SUBSECRETARÍA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2076854", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-19", "doble_articulado": false, "id_norma": "1171746", "numero_fuente": "43162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-01-26", "vigencias": [{"desde": "2022-01-26", "hasta": "", "tipo_version"