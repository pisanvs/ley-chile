{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br></div>", "i": 8322514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.775, de 14 de Noviembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 3&#xB0; de la resoluci&#xF3;n No. 970, de 1989, de esta Subsecretaria, que autoriz&#xF3; a don Ricardo Augusto Born Lunecke, R.U.T. No. 5.185.352-0, domiciliado en Vi&#xF1;a del Mar, para iniciar actividades pesqueras, en el sentido de autorizar al solicitante para extraer el recurso Albacora o pez espada, (Xiphias gladius), en el litoral de las Regiones III a X, no obstante lo se&#xF1;alado en dicha resoluci&#xF3;n, respecto de las zonas a operar.</div><br><br><br></div>", "i": 8322515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de Noviembre de 1989. Roberto Cabezas Bello, Subsecretario de Pesca.</div><br><br><br></div>", "i": 8322516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1775", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1775"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-11-14", "fecha_derogacion": "1999-02-11", "doble_articulado": false, "id_norma": "92951", "numero_fuente": "33534", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-11-29", "vigencias": [{"desde": "1999-02-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1