{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7353737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 721, de 30 de julio de 2007, de</div><div class=\"p\">Serviu Metropolitano, se rectific&#xF3; Resoluci&#xF3;n N&#xBA; 904, de</div><div class=\"p\">28 de noviembre de 2006, en cuanto se elimin&#xF3;, en el</div><div class=\"p\">Art&#xED;culo 2&#xBA; de su parte resolutiva, el guarismo &quot;$242.003.935&quot;, reemplaz&#xE1;ndolo por la cifra</div><div class=\"p\">&quot;$49.625.500&quot;, que corresponde al monto de la indemnizaci&#xF3;n provisional por la expropiaci&#xF3;n ordenada por la Resoluci&#xF3;n rectificada, determinada por la Comisi&#xF3;n de Peritos designada conforme D.L. N&#xBA; 2.186 de 1978 en Informe de 13 de noviembre de 2006. La expropiaci&#xF3;n se encuentra referida al Lote N&#xBA; 36, constituido por parte del inmueble ubicado en Avenida Larra&#xED;n N&#xBA; 8511, Rol de Aval&#xFA;o N&#xBA; 5515-1, Comuna de La Reina, aparente dominio de Inversiones Tobalaba Limitada, necesario para la ejecuci&#xF3;n del Proyecto Vial &quot;Mejoramiento Eje Larra&#xED;n&quot;, de la mencionada Comuna. </div></div>", "i": 7353738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7353739}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "721", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-721"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "d