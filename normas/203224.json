{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 569 EXENTO, DE 2000 </div></div>", "i": 6398504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 569 de fecha 28 de diciembre de 2000 se aprobaron las modificaciones introducidas a los planes y programas de estudios de la carrera de Dise&#xF1;o Gr&#xE1;fico Publicitario que imparte el Instituto Profesional Incacea y se autoriza el cambio de denominaci&#xF3;n de dicha carrera por &quot;Dise&#xF1;o y Comunicaci&#xF3;n Gr&#xE1;fica y Publicitaria Digital&quot;, conducente al t&#xED;tulo profesional de Dise&#xF1;ador y Comunicador Gr&#xE1;fico y Publicitario Digital. Dichas modificaciones regir&#xE1;n a contar del a&#xF1;o 2001. </div></div>", "i": 6398505}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de diciembre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6398506}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "569 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-569 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 569 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-12-28", "fecha_derogacion": "2020-07-11", "doble_articulado": false, "id_norma": "203224", "numero_fuente": "37376", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-10-05", "vigencias": [{"desde": "2020-07-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-10-05", "hasta": "2020-07-10", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"ini