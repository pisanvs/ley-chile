{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N&#xB0; 233 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6237899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo Polit&#xE9;cnico A N&#xB0; 4, de San Carlos.</div><br><div class=\"p\">ESPECIALIDADES:</div><div class=\"p\">1. Contabilidad.</div><div class=\"p\">2. Ventas y Publicidad.</div><div class=\"p\">3. Secretariado Administrativo.</div><div class=\"p\">4. Alimentaci&#xF3;n.</div><div class=\"p\">5. Atenci&#xF3;n de P&#xE1;rvulos.</div><div class=\"p\">6. Vestuario.</div><div class=\"p\">7. Mec&#xE1;nica de M quinas Herramientas.</div><div class=\"p\">8. Electromec&#xE1;nica.</div><div class=\"p\">9. Electr&#xF3;nica.</div><div class=\"p\">10. Construcci&#xF3;n Habitacional.</div><br></div>", "i": 6237900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Junio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6237901}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "233 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-233 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N° 233\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "15