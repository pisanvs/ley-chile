{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8815087}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;2158, de 30 de noviembre de 2009, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del Decreto Exento N&#xBA;650, de 31 de julio de 2008, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n, del lote de terreno N&#xBA;32, con motivo de la obra: &quot;Mejoramiento Ruta 7, sector Quillaipe La Arena, tramo Km. 15,84700 a Km. 40,41746&quot;, Provincia de Llanquihue, Comuna de Puerto Montt. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n, fijada por la Comisi&#xF3;n de Peritos, con fecha 18 de agosto de 2004, complementada por acta de fecha 25 de marzo de 2008, ascendente a la cantidad de $310.800. </div><br></div>", "i": 8815088, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 8815089}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2158 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2158 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-11-30", "doble_articulado": false, "id_norma": "1009308", "numero_fuente": "39536", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-12-15", "vigencias": [{"desde": "2009-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s":