{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 56</div></div>", "i": 9862064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 4.018, de 29 de noviembre de 2017, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1098909&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 4.209, de 2016</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 56, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 9862065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de noviembre de 2017.- Pablo Berazaluce Maturana, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9862066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4018 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4018 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 56", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1314207; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-11-29", "doble_articulado": false, "id_norma": "1112080", "numero_fuente": "41926", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-12-06", "vigencias": [{"desde": "2017-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen