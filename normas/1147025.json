{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 1.243 EXENTA, DE 2020, DEL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES</div></div>", "i": 10132334}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.243, de 24 de junio de 2020, del Ministerio de Transportes y Telecomunicaciones, se implementa rebaja tarifaria para el adulto mayor en servicios de transporte p&#xFA;blico remunerado de pasajeros establecida en la <a href=\"https://www.leychile.cl/Navegar?idNorma=1140200&amp;idParte=&amp;idVersion=\">ley N&#xB0; 21.192</a>, aprueba metodolog&#xED;a para ello y deja sin efecto resoluci&#xF3;n que indica. Texto &#xED;ntegro de la resoluci&#xF3;n exenta referida, estar&#xE1; disponible para ser consultada en la p&#xE1;gina web http://www.dtpr.gob.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10132335}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gloria Hutt Hesse, Ministra de Transportes y Telecomunicaciones.</div><br></div>", "i": 10132336}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1243 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1243 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 1.243 EXENTA, DE 2020, DEL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1779559", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-06-24", "doble_articulado": false, "id_norma": "1147025", "numero_fuente": "42692", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicaci