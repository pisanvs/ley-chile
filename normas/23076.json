{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2.028 que deroga el inciso final del art.</div><div class=\"p\">1.&#xB0; de la lei n&#xFA;m. 1,839.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,028.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se deroga el inciso final del art.</div><div class=\"p\">1.&#xB0; de la lei n&#xFA;m. 1,839, de 13 de febrero de 1906. </div></div>", "i": 8274936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 9 de setiembre de 1907.- PEDRO MONTT.- Luis A. Vergara.</div><br></div>", "i": 8274937}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2028", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2028"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 2.028 QUE DEROGA EL INCISO FINAL DEL ART 1.° DE LA LEI NUM. 1,839.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTERIOS", "FUNCIONARIOS", "EMPLEOS", "INCOMPATIBILIDAD", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-09-09", "doble_articulado": false, "id_norma": "23076", "numero_fuente": "8900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-09-13", "vigencias": [{"desde": "1907-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-09-13", "fin_vige