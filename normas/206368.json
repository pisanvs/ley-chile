{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6408757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 2.884, de&nbsp; 18 de diciembre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESCA MARINA LIMITADA para ampliar las actividades pesqueras extractivas con la nave &quot;Polux&quot; en el litoral comprendido entre la III y VI Regiones y entre la VIII Regi&#xF3;n y el paralelo 41&#xBA; 28,6&apos; L.S., con arrastre, por fuera del &#xE1;rea de reserva artesanal, sobre los siguientes recursos hidrobiol&#xF3;gicos: Gamba y Besugo. </div></div>", "i": 6408758}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6408759}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2884", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2884"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-12-18", "fecha_derogacion": "2005-03-04", "doble_articulado": false, "id_norma": "206368", "numero_fuente": "37449", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-01-03", "vigencias": [{"desde": "2005-03-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-01-03", "hasta": "2005-03-03", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2005-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-03", "fin_vigencia": "2005-