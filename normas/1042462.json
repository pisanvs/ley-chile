{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9286094}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;1203 de 29 de junio de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;1, superficie 53 m2, rol de Aval&#xFA;o N&#xBA;189-2, comuna de Hualqui, para la obra &quot;REPOSICI&#xD3;N INFRAESTRUCTURA VIAL RUTA 0-60, CHIGUAYANTE - HUALQUI PROV. DE CONCEPCI&#xD3;N&quot;, VIII Regi&#xF3;n. La Comisi&#xF3;n de peritos, integrada por Mar&#xED;a Pamela Mac-Guire Acevedo, Roxana Cecilia Abarz&#xFA;a Gajardo y Consuelo Loreto Zuloaga Sanhueza, fij&#xF3; el valor de tasaci&#xF3;n con fecha 1 diciembre de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario don FERNANDO LAGOS RODR&#xCD;GUEZ, en la cantidad de $2.479.292.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9286095}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9286096}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1203 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1203 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-29", "doble_articulado": false, "id_norma": "1042462", "numero_fuente": "40326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-01", "vigencias": [{"desde": "2012-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-01", "fin_vigencia": ""}, "vi