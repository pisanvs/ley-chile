{"html": [{"t": "<div><div class=\"p\">AUTORIZA A EMPACADORA SEA LAND LIMITADA PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 7260357}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 420 de 15 de Mayo de 1986 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Empacadora Sea Land Limitada, domiciliada en Santiago, para elaborar la l&#xED;nea de ahumado en filo y caliente, en las instalaciones de Frigor&#xED;fico Santiago Limitada, ubicada en calle Ram&#xF3;n Freire 6470, Maip&#xFA;, empleando como materia prima los recursos hidrobiol&#xF3;gicos se&#xF1;alados en el numeral 3&#xB0; de la Resoluci&#xF3;n 810, de 04 de Diciembre de 1985, de la Subsecretar&#xED;a de Pesca.</div><br></div>", "i": 7260358}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de Mayo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7260359}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "420", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-420"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A EMPACADORA SEA LAND LIMITADA PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-05-15", "fecha_derogacion": "1989-05-04", "doble_articulado": false, "id_norma": "154207", "numero_fuente": "32496", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-06-14", "vigencias": [{"desde": "1989-05-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Vers