{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,286.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados al pais por don Benjamin Videla, conc&#xE9;dese a cada una de sus hijas do&#xF1;a Jertr&#xFA;dis i do&#xF1;a C&#xE1;rmen Rosa Videla, mi&#xE9;ntras permanezcan solteras, una pension anual de seiscientos pesos.</div><br></div>", "i": 6162853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a 29 de noviembre de 1899.- FEDERICO ERRAZURIZ.- Jos&#xE9; F. Valdes C.</div><br></div>", "i": 6162854}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1286", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1286"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-11-29", "doble_articulado": false, "id_norma": "134591", "numero_fuente": "6461", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-11-30", "vigencias": [{"desde": "1899-11-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-11-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-11-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], 