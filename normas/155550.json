{"html": [{"t": "<div><div class=\"p\">AUTORIZA A LA SOCIEDAD SALMOSUR S.A. PARA AMPLIAR SUS ACTIVIDADES PESQUERAS.</div><br></div>", "i": 7261191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 108, de 06 de Febrero de 1986 de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la Sociedad Salmosur S.A.,- domiciliada en la comuna de Santiago, para destinar el establecimiento de cultivo que tiene autorizado por la Resoluci&#xF3;n 237, de 1984, de la Subsecretar&#xED;a de Pesca, en el Estero Quilquito Bajo, sector Punta Atal Comuna de Castro, Chilo&#xE9; Xa Regi&#xF3;n, adem&#xE1;s al cultivo de trucha arco iris.</div><br></div>", "i": 7261192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 06 de Febrero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7261193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "108", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-108"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A LA SOCIEDAD SALMOSUR S.A. PARA AMPLIAR SUS\nACTIVIDADES PESQUERAS.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-06", "doble_articulado": false, "id_norma": "155550", "numero_fuente": "32400", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-02-17", "vigencias": [{"desde": "1986-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "19