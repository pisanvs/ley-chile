{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6233137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 728, de Julio 22 de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Tecomunicaciones, Regi&#xF3;n Metropolitana, se autoriza a don Orlando Rocco Santiago, para efectuar el servicio de Taxi Colectivo urbano que se indica a continuaci&#xF3;n:</div><br><div class=\"p\">LINEA N&#xBA; 174 &quot;LAS PERDICES - BLEST GANA&quot;</div><br><div class=\"p\">&nbsp; &nbsp;  Circunvalaci&#xF3;n: Las Perdices con Mar&#xED;a Monvel - Mar&#xED;a Monvel - Av. Larra&#xED;n - Paula Jaraquemada - Blest Gana - Av. Ega&#xF1;a - Av. Larra&#xED;n - Los Maitenes - Pepe Vila - Av. Larra&#xED;n - Parque Industrial (Villa La Reina) - Av. Larra&#xED;n - Mar&#xED;a Monvel hasta Las Perdices. </div></div>", "i": 6233138}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 29 de 1986. Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6233139}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "728 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-728 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-29", "doble_articulado": false, "id_norma": "155762", "numero_fuente": "32629", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-11-