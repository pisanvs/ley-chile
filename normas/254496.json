{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,956</div><br><div class=\"p\">ABONA EL TIEMPO QUE INDICA EN LA HOJA DE SERVICIOS DE DO&#xD1;A BLANCA EMILIA LADRON DE GUEVARA ROMERO</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6587117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Ab&#xF3;nanse, por gracia y para todos los efecto legales, 8 a&#xF1;os y 4 meses en la hoja de servicios de do&#xF1;a Blanca Emilia Ladr&#xF3;n de Guevara Romero&quot;.</div><br></div>", "i": 6587118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintitr&#xE9;s de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 6587119}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10956", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10956"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ABONA EL TIEMPO QUE INDICA EN LA HOJA DE SERVICIOS DE\nDOÑA BLANCA EMILIA LADRON DE GUEVARA ROMERO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-23", "doble_articulado": false, "id_norma": "254496", "numero_fuente": "22408", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-25", "vigencias": [{"desde": "1952-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen