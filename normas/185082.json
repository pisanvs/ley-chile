{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6334204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;197, de fecha 30 de marzo de 2001, se expropi&#xF3; el lote de terreno N&#xBA;71-A, superficie 1.530 m&#xB2;, rol de aval&#xFA;o 155-14, comuna de Portezuelo, para la obra &apos;&apos;Camino Ruta N-60-O, Sector R&#xED;o &#xD1;uble - Portezuelo, Tramo: Km. 6,900.00 a Km.</div><div class=\"p\">28,833.35&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Manuel Jes&#xFA;s Riquelme Palma, ascendente a la cantidad de $1.556.010.-.</div><br></div>", "i": 6334205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6334206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "197 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-197 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "185082", "numero_fuente": "36962", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-15", "vigencias": [{"desde": "2001-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-05-15", "fecha_version": "2001-05-15", "fecha_actualizacion_texto": "2001-05-15", "tipo_tra