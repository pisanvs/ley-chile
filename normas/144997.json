{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6196089}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta No. 364, de fecha 17 de Marzo de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n, se autoriza a Juan Enrique Herrera C&#xE1;riz, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6196090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 17 de Marzo de 1987.- Hern&#xE1;n V&#xE1;squez Wacquez, Capit&#xE1;n de Nav&#xED;o, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n. </div></div>", "i": 6196091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "364 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-364 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 48, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-17", "doble_articulado": false, "id_norma": "144997", "numero_fuente": "32730", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-24", "vigencias": [{"desde": "1987-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig