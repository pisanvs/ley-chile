{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 205, DE 1993</div><br><br><br></div>", "i": 7161109}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 205 de fecha 03 de Mayo de 1993 del Ministerio de Educaci&#xF3;n, se ampli&#xF3; la autorizaci&#xF3;n de funcionamiento del Instituto Profesional Escuela Superior de Comercio Exterior ESCE, otorgada por decreto Exento de Educaci&#xF3;n N&#xB0; 50 de 1989, a la sede que los organizadores mantienen en calle Guillermo Munnich N&#xB0; 338 de Valpara&#xED;so, a efecto de mejorar la capacidad de atenci&#xF3;n de los alumnos de la citada instituci&#xF3;n. En dicha Sede se impartir&#xE1; la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n Agronom&#xED;a menciones en Producci&#xF3;n Agropecuaria y Administraci&#xF3;n Agr&#xED;cola.</div><br></div>", "i": 7161110}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago 5 de Julio de 1993. Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161111}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "205 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-205 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "ASIGNA VEHICULO QUE INDICA Y EXIME DE USO DISCO FISCAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL ESCUELA SUPERIOR COMERCIO", "EXTERIOR ESCE", "INGENIERIA EJECUCION AGRONOMIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-05-03", "fecha_derogacion": "1998-12-14", "doble_articulado": false, "id_norma": "20649", "numero_fuente": "34638", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-08-11", "vigencias": [{