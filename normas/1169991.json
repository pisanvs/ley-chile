{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10292887}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta 2.237, 1 de diciembre 2021, Serviu Regi&#xF3;n del Biob&#xED;o orden&#xF3; expropiaci&#xF3;n parcial de un inmueble, ubicado en Maip&#xFA; N&#xB0; 2314, Rol de Aval&#xFA;o N&#xB0; 271-6, comuna de Concepci&#xF3;n, de aparente dominio de Ej&#xE9;rcito de Chile, superficie de 19,63 m2 de terreno, dentro de pol&#xED;gono y linderos se&#xF1;alados plano de expropiaci&#xF3;n S8R-41.419-1, para la ejecuci&#xF3;n de las obras del proyecto &quot;Mejoramiento Par Vial Collao / General Novoa&quot; comuna de Concepci&#xF3;n, conforme art&#xED;culo 51 ley N&#xB0; 16.391 y D.L. N&#xB0; 2.186. Comisi&#xF3;n Peritos integrada por ingeniero civil Orlando Javier Paredes V&#xE1;squez, constructor civil &#xCD;talo Renzo Zerga Arancibia y arquitecto Guillermo Orlando Villafa&#xF1;e Feres, seg&#xFA;n informe de fecha 29.10.2021, fij&#xF3; monto provisional indemnizaci&#xF3;n en $12.256.345.- </div></div>", "i": 10292888}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n del Biob&#xED;o.</div><br></div>", "i": 10292889}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2237 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2237 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL BIOBÍO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2053345", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-01", "doble_articulado