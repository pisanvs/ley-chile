{"html": [{"t": "<div><div class=\"p\">NOMBRA EN EL CARGO DE DIRECTOR DE LA VII DIRECCION REGIONAL AL FUNCIONARIO QUE INDICA </div></div>", "i": 6070829}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n N&#xBA;444, de 9 de Junio de 1992, el suscrito, Director del Servicio de Impuestos Internos, en uso de sus atribuciones legales, nombr&#xF3; en el cargo de Director Regional, al Sr. Eladio Esteban Soza Hern&#xE1;ndez a contar del 6 de Julio de 1992, asign&#xE1;ndole a partir de la misma fecha las funciones de Director Regional de la VII Direcci&#xF3;n Regional, Talca.-</div><br></div>", "i": 6070830}, {"t": "<div><div class=\"p\">Javier Etcheberry Celhay, Director.</div><br></div>", "i": 6070831}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "444", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-444"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "NOMBRA EN EL CARGO DE DIRECTOR DE LA VII DIRECCION REGIONAL AL FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-09", "doble_articulado": false, "id_norma": "85630", "numero_fuente": "34308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-06", "vigencias": [{"desde": "1992-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-01-20", "fecha_version": "1992-07