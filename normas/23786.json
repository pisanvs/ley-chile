{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Modifica el art&#xED;culo 57 de la Lei de Alcoholes Lei n&#xFA;m. 3,175.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7166405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.-Se reemplaza el art&#xED;culo 57 de la lei n&#xFA;mero 3,087, de 13 de Abril de 1916, por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 57.-Para los efectos del pago del impuesto por produccion de vinos i chichas se considerar&#xE1; como &quot;hect&#xE1;rea&quot; la fraccion que exeda de media hect&#xE1;rea i como &quot;media hect&#xE1;rea&quot; la fraccion que no alcance a esta superficie&quot; </div></div>", "i": 7166406, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien probarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Diciembre de 1916.-JUAN LUIS SANFUENTES.- Arturo Prat.</div><br></div>", "i": 7166407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3175", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3175"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA EL ARTICULO 57 DE LA LEI DE ALCOHOLES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["IMPUESTO ALCOHOLES", "MODIFICACION", "PRODUCCION VINOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-12-29", "doble_articulado": false, "id_norma": "23786", "numero_fuente": "11664", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-01-04", "vigencias": [{"desde": "1917-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1917-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1917-01-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JAM", "fecha_ingreso": "1999-02-23", "fecha_version": "1917-01-04", "fecha_actualizacion_texto": "1917-01-04", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7166405}, {"n": "Artículo UNICO", "i": 7166406, "t": 6}, {"n": "Promulgación", "i": 7166407}]}