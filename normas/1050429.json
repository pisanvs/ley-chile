{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9347954}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.001, de 19 de abril de 2013, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la <a href=\"https://www.leychile.cl/Navegar?idNorma=230465&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.551, de 2004</a>, que autoriz&#xF3; a PESCA CHILE S.A. para realizar actividades pesqueras extractivas con la nave denominada &quot;Puerto Ballena&quot; en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 44&#xB0;30&apos; L.S. y 57&#xB0; L.S., sobre el recurso hidrobiol&#xF3;gico Jibia, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum t&#xE9;cnico citado en Visto.</div><br></div>", "i": 9347955, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de abril de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9347956}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1001 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1001 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-04-19", "fecha_derogacion": "2013-06-11", "doble_articulado": false, "id_norma": "1050429", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-04-26", "vigencias": [{"desde": "2013-06-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"