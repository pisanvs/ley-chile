{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;12.872 EXENTA, DE 1999 </div><br></div>", "i": 6254185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;12.872 de 29 de diciembre de 1999, se ha aprobado al Colegio Alem&#xE1;n de Valpara&#xED;so y a los Colegios Alemanes de Chile, Programas de Estudio de Lat&#xED;n y Franc&#xE9;s para el 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media, los que podr&#xE1;n ser aplicados voluntariamente por cualesquiera de estos colegios que desee impartir dichos idiomas en el Sector Idioma Extranjero.</div><br></div>", "i": 6254186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de febrero de 2000.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6254187}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12872 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12872 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº12.872 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "162064", "numero_fuente": "36620", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-22", "vigencias": [{"desde": "2000-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingr