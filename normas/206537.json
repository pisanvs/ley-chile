{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA LOCAL SOBRE DERECHOS MUNICIPALES </div><br></div>", "i": 6695254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se comunica que la I. Municipalidad de Til Til, seg&#xFA;n Acuerdo tomado por su Honorable Consejo Municipal en su sesi&#xF3;n ordinaria N&#xBA; 44 de 11 de diciembre del a&#xF1;o 2002, ha procedido a modificar su Ordenanza Local sobre Derechos Municipales, dichas modificaciones empezar&#xE1;n a regir a contar del 1 de enero del a&#xF1;o 2003 y su nuevo texto podr&#xE1; ser adquirido en Secretar&#xED;a Municipal de la I. Municipalidad de Til Til.</div><br></div>", "i": 6695255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Dar&#xED;o Ovalle Lecaros, Alcalde.- Pedro Pizarro Tapia, Secretario Municipal.</div><br></div>", "i": 6695256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MUNICIPALIDAD DE TIL TIL"], "titulo_norma": "MODIFICA ORDENANZA LOCAL SOBRE DERECHOS MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "206537", "numero_fuente": "37447", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-31", "vigencias": [{"desde": "2002-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"