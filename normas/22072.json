{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; RESIDENCIA DEL EJERCITO EN EL LUGAR DE LAS SESIONES DEL CONGRESO</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 215.- Santiago, a 26 de Noviembre de 1894.- Por cuanto el Congreso Nacional ha aprobado el siguiente PROYECTO DE LEI:</div><br></div>", "i": 5947180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Perm&#xED;tese, por el t&#xE9;rmino de un a&#xF1;o, la residencia de cuerpos del Ej&#xE9;rcito permanente en el lugar de las sesiones del Congreso Nacional i diez leguas a su circunferencia.</div><br><br></div>", "i": 5947181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-Santiago Aldunate B.</div><br></div>", "i": 5947182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "215", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-215"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "RESIDENCIA DEL EJERCITO EN EL LUGAR DE LAS SESIONES DEL CONGRESO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO CHILE", "CUERPOS", "RESIDENCIA", "FIJACION", "SESIONES DEL CONGRESO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-11-26", "doble_articulado": false, "id_norma": "22072", "numero_fuente": "4974", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-11-26", "vigencias": [{"desde": "1894-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-11-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-11-26", "fin_vigencia"