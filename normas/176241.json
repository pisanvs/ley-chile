{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 9.090 EXENTA, DE 2000 </div></div>", "i": 6303063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 9.090, de 8</div><div class=\"p\">de septiembre del a&#xF1;o 2000, se ha aprobado al Colegio de</div><div class=\"p\">La Salle, comuna de La Reina, de Santiago, un plan de</div><div class=\"p\">estudio para 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se</div><div class=\"p\">aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los</div><div class=\"p\">subsectores que se indican, del plan aprobado en el</div><div class=\"p\">art&#xED;culo anterior.</div><br></div>", "i": 6303064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de septiembre de 2000.- Juan Ruz R., Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6303065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9090 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-9090 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 9.090 EXENTA, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-08", "doble_articulado": false, "id_norma": "176241", "numero_fuente": "36776", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-30", "vigencias": [{"desde": "2000-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":