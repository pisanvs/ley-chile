{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aprueba cuentas inversi&#xF3;n Ferrocarriles a&#xF1;os 1915 y 1916.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 5958350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Apru&#xE9;banse las Cuentas de Inversi&#xF3;n de los Ferrocarriles del Estado correspondientes a los a&#xF1;os 1915 y 1916.</div><br></div>", "i": 5958351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintiocho de Octubre de mil novecientos veintis&#xE9;is.- Emiliano Figueroa.- Angel Guarello. </div></div>", "i": 5958352}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4102", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4102"}], "organismos": ["MINISTERIO DE OBRAS PUBLICAS COMERCIO Y VIAS DE COMUNICACION"], "titulo_norma": "APRUEBA CUENTAS INVERSION FERROCARRILES AÑOS 1915 y 1916.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FERROCARRILES ESTADO", "CUENTAS INVERSION", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1926-10-28", "doble_articulado": false, "id_norma": "24472", "numero_fuente": "14634", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1926-11-29", "vigencias": [{"desde": "1926-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1926-11-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "