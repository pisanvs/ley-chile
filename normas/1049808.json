{"html": [{"t": "<div><br><div class=\"p\">REGULA ARTES DE PESCA DE ARRASTRE PARA PESQUER&#xCD;AS DE CRUST&#xC1;CEOS DEMERSALES</div></div>", "i": 9341376}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 762, de 21 de marzo de 2013, de esta Subsecretar&#xED;a, se regulan los artes de pesca de arrastre para crust&#xE1;ceos demersales, fij&#xE1;ndose las dimensiones y caracter&#xED;sticas de las redes relativas a: Malletas, est&#xE1;ndares, pa&#xF1;os de telas, material no boyante, di&#xE1;metro de los hilos, cabos en la red, flotabilidad m&#xED;nima de las Relinga superior, protecci&#xF3;n contra el roce, cabos restrictores, dispositivo de escape de fauna acompa&#xF1;ante y tama&#xF1;o m&#xED;nimo de claro de malla.</div><br></div>", "i": 9341377}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de marzo de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9341378}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "762 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-762 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-21", "doble_articulado": false, "id_norma": "1049808", "numero_fuente": "40523", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-02", "vigencias": [{"desde": "2013-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-04-02", "fin_vigencia": ""}, "vigencias_version_norma":