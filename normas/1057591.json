{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO ALCALDICIO N&#xBA; 2.590 EXENTO, DE 2013</div></div>", "i": 9394288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto alcaldicio Ex. N&#xBA; 2.590, de 17 de diciembre de 2013, se fija el texto refundido y sistematizado de la ordenanza N&#xBA;22 de 28 de diciembre de 2001, y sus modificaciones &quot;Ordenanza local sobre derechos municipales&quot; que regir&#xE1; en el a&#xF1;o 2014.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo se encuentra en la p&#xE1;gina web municipal, Transparencia Activa en Carpeta Marco Normativo Aplicable/Ordenanzas/Derecho/Sobre Derechos Municipales.</div></div>", "i": 9394289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Alcaldesa.</div></div>", "i": 9394290}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2590 EXENTA", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2590 EXENTA"}], "organismos": ["MUNICIPALIDAD DE PROVIDENCIA"], "titulo_norma": "EXTRACTO DE DECRETO ALCALDICIO Nº 2.590 EXENTO, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-17", "doble_articulado": false, "id_norma": "1057591", "numero_fuente": "40741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-12-26", "vigencias": [{"desde": "2013-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-12-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "162