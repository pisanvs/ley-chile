{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO No. 147, DE 1988 </div></div>", "i": 7244926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 147 de 31 de agosto de 1988 se ha aprobado, a la Escuela Especial Diferencial E No. 77 de Antofagasta, II Regi&#xF3;n de Antofagasta, un plan de estudio especial de Orientaci&#xF3;n Laboral que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de 4 a&#xF1;os, a contar desde 1989.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio correspondientes a las etapas y asignaturas de las &#xE1;reas que contempla el plan aprobado por el presente decreto. </div></div>", "i": 7244927}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de Septiembre de 1988.- Ren&#xE9; Salame Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7244928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "147 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-147 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 147, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-31", "doble_articulado": false, "id_norma": "130891", "numero_fuente": "33177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-21", "vigencias": [{"desde": "1988-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"