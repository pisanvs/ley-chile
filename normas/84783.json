{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 8316670}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n 212 de fecha 20.12.89 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la Asociaci&#xF3;n Gremial de Due&#xF1;os de Taxis Colectivos de Talcahuano &quot;ASOTRACO&quot; A.G. inscrita bajo el No. 745 del Registro que para tal efecto lleva este Ministerio, por haberse configurado respecto de ella, la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18 No. 2 letra c) del DL 2.757 de 1979.-</div><br></div>", "i": 8316671}, {"t": "<div><div class=\"p\">Norman Bull de la Jara, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8316672}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "212", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-212"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-20", "doble_articulado": false, "id_norma": "84783", "numero_fuente": "33578", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-24", "vigencias": [{"desde": "1990-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-01-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion