{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8356740}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.689, de 30 de diciembre de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a la EMPRESA DE DESARROLLO PESQUERO DE CHILE S.A., para realizar operaciones pesqueras a contar del 1 de enero y hasta el 31 de diciembre del a&#xF1;o 2000, ambas fechas inclusive con los barcos f&#xE1;bricas denominados &apos;&apos;Unzen&apos;&apos; y</div><div class=\"p\">&apos;&apos;Unionsur&apos;&apos;, en aguas exteriores, por fuera de las l&#xED;neas de base recta, al sur del paralelo 44&#xB0;30&apos; de latitud sur, respecto de las &#xE1;reas y recursos y con las obligaciones establecidas en las respectivas resoluciones.</div><br></div>", "i": 8356741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8356742}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2689", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2689"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMPRESA DE DESARROLLO PESQUERO DE CHILE S.A.", "ACTIVIDADES PESQUERAS", "BARCOS FABRICAS", "AGUAS EXTERIORES", "AUTORIZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-30", "doble_articulado": false, "id_norma": "151480", "numero_fuente": "36565", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-18", "vigencias": [{"desde": "2000-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v