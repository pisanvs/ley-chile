{"html": [{"t": "<div><div class=\"p\">DESIGNA ALCALDE DE PAIHUANO </div></div>", "i": 9049532}, {"t": "<div><br><div class=\"p\">En conformidad a lo dispuesto en la ley org&#xE1;nica N&#xB0; 18.685,</div><div class=\"p\">art&#xED;culo 48 y ley N&#xB0; 18.883, Estatuto Administrativo para funcionarios municipales, art&#xED;culo 12, y al Acuerdo N&#xB0; 003 del 01 de Agosto de 1990 del Consejo de Desarrollo Comunal de Paihuano donde propone terna definitiva para alcalde de esa comuna.</div><div class=\"p\">El Consejo Regional de Desarrollo - COREDE - IV REGION a acordado, en su Sesi&#xF3;n Ordinaria N&#xB0; 33 de fecha 14 de Septiembre de 1990, designar alcalde de la comuna de Paihuano al se&#xF1;or:</div><div class=\"p\">FRANCISCO JAVIER HERNANDEZ SOLIS RUT: 6.648.619-2 </div></div>", "i": 9049533}, {"t": "<div><div class=\"p\">RODRIGO SUGG PIERRY Secretario Ejecutivo - COREDE IV Regi&#xF3;n MINISTRO DE FE </div></div>", "i": 9049534}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "039", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-039"}], "organismos": ["CONSEJO REGIONAL DE DESARROLLO IV REGIÓN DE COQUIMBO"], "titulo_norma": "DESIGNA ALCALDE DE PAIHUANO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-09-14", "doble_articulado": false, "id_norma": "88441", "numero_fuente": "33782", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-01", "vigencias": [{"desde": "1990-01-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-01-01", "fin_vigencia": "", "tip