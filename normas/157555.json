{"html": [{"t": "<div><div class=\"p\">CANCELA PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL </div></div>", "i": 6238836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 148, de 30 de Diciembre de 1985,</div><div class=\"p\">del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se</div><div class=\"p\">cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Federaci&#xF3;n</div><div class=\"p\">Gremial Agr&#xED;cola Norte Chico&quot;, inscrita bajo el n&#xFA;mero</div><div class=\"p\">11-4 del Registro de Asociaciones Gremiales, por haberse</div><div class=\"p\">configurado respecto de ella la causal establecida en el</div><div class=\"p\">art&#xED;culo 18&#xB0; N&#xB0; 2, letra a), del DL 2.757. Los bienes quedados una vez practicada la liquidaci&#xF3;n de la Federaci&#xF3;n Gremial sancionada tendr&#xE1;n el destino que determine el Presidente de la Rep&#xFA;blica.</div><br></div>", "i": 6238837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ximena del Pozo Parada, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n Subrogante. </div></div>", "i": 6238838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "148", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-148"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "CANCELA PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-30", "doble_articulado": false, "id_norma": "157555", "numero_fuente": "32386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-31", "v