{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6254021}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 372 de 30 de Agosto de 1985 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a Alejandro Denham y C&#xED;a. Ltda., para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m s de nueve (9) asientos, incluido el del conductor; de los veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en calle Collao No. 1866 de la ciudad de Concepci&#xF3;n.</div><br></div>", "i": 6254022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Francisco Navarro Ruiz, Secretario Regional Ministerial, Transportes y Telecomunicaciones, VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6254023}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "372 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-372 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-30", "doble_articulado": false, "id_norma": "162008", "numero_fuente": "32264", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-03", "vigencias": [{"desde": "1985-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen