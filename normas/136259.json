{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,182.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atencion a los especiales servicios prestados por el teniente-coronel don Aurelio Bergu&#xF1;o, el&#xE9;vase a dos mil cuatrocientos pesos ($ 2,400) la pension anual que disfrutan su viuda e hijos.</div><div class=\"p\">&nbsp; &nbsp;  Este aumento rejir&#xE1; desde la fecha del fallecimiento del espresado se&#xF1;or Bergu&#xF1;o&quot;.</div><br></div>", "i": 6168114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintinueve de marzo de mil novecientos nueve.- Pedro Montt.- D. Za&#xF1;artu.</div><br></div>", "i": 6168115}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2182", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2182"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-03-29", "doble_articulado": false, "id_norma": "136259", "numero_fuente": "9367", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-04-21", "vigencias": [{"desde": "1909-04-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1909-04-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc