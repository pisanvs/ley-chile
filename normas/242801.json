{"html": [{"t": "<div><div class=\"p\">RESOLUCION N&#xBA; 115 (A), DE 2005</div><br><br></div>", "i": 8149487}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo dispuesto por los decretos N&#xBA;s. 291, de 11 de junio y 668, de 16 de noviembre, ambos de 1999, del Ministerio de Econom&#xED;a, certifico que por resoluci&#xF3;n (A) N&#xBA; 115 de 29 de agosto de 2005, del Sr. Vicepresidente Ejecutivo de la Corporaci&#xF3;n de Fomento de la Producci&#xF3;n, se dejaron sin efecto las resoluciones (A) N&#xBA; 163, de 2000 y N&#xBA; 97, de 2002, y se aprob&#xF3; el nuevo texto del &quot;Reglamento de los Programas Territoriales Integrados&quot;, PTI.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la resoluci&#xF3;n N&#xBA; 115 (A), antes citada, est&#xE1; a disposici&#xF3;n de los usuarios en la Secretar&#xED;a General de la Corporaci&#xF3;n y en las Direcciones Regionales.</div><br></div>", "i": 8149488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de octubre de 2005.- Yerko Koscina Peralta, Secretario General.</div><br></div>", "i": 8149489}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "115", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-115"}, {"tipo": "3", "numero": "115-A", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-115-A"}], "organismos": ["CORPORACIÓN DE FOMENTO DE LA PRODUCCIÓN"], "titulo_norma": "RESOLUCION Nº 115 (A), DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REGLAMENTO PROGRAMAS TERRITORIALES INTEGRADOS", "PTI."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-29", "doble_articulado": false, "id_norma": "242801", "numero_fuente": "38284", "tipo_version": "3", "t