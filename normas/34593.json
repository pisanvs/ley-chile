{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 395, de 1&#xB0; de Junio de 1993 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SALMONES PACIFIC STAR LIMITADA, R.U.T. N&#xB0; 79.559.220-2, para continuar desarrollando las actividades pesqueras autorizadas mediante las Resoluciones vigentes otorgadas a Pacific Star S.A., R.U.T. N&#xB0; 79.559.220-2, en virtud de la Escritura P&#xFA;blica de 4 de Febrero de 1993, otorgada ante la Quinta Notar&#xED;a de Santiago, que transform&#xF3; a Pacific Star S.A., en Salmones Pacific Star Limitada. </div></div>", "i": 8292223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 1&#xB0; de Junio de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8292224}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "395", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-395"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SALMONES PACIFIC STAR LIMITADA", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-01", "doble_articulado": false, "id_norma": "34593", "numero_fuente": "34592", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-06-17", "vigencias": [{"desde": "1993-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-06-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-06-17", "fin_vigencia": "", "tipo_version"