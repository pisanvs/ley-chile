{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO NUMERO 498 EXENTO, DE 1993 </div><br></div>", "i": 7161989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 498 de fecha 23 de Septiembre de 1993 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Pit&#xE1;goras las adecuaciones introducidas al plan y programas de estudio de la carrera de Secretariado de Gerencia, las que se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 368 de 1983 y N&#xB0; 1.403 de 1989. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1993.</div><br><br><br></div>", "i": 7161990}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Marzo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161991}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "498 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-498 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 498 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA PITAGORAS", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "SECRETARIADO GERENCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-09-23", "fecha_derogacion": "2021-12-31", "doble_articulado": false, "id_norma": "21367", "numero_fuente": "34856", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-05-04", "vigencias": [{"desde": "2021-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-05-04", "hasta": "2021-12-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vig