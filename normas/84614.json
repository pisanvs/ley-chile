{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 27, DE 1990 </div></div>", "i": 6068302}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 27 de 19 de enero de 1990 se ha modificado, a contar del a&#xF1;o 1990, el decreto supremo exento de Educaci&#xF3;n No. 159 de 1988, que aprob&#xF3; un plan especial de estudio de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica para Adultos al Instituto Luisa Cardijn, de Santiago, en la forma que se indica en el presente decreto.-</div><br></div>", "i": 6068303}, {"t": "<div><div class=\"p\">Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6068304}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "27 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-27 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 27, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-19", "doble_articulado": false, "id_norma": "84614", "numero_fuente": "33631", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-27", "vigencias": [{"desde": "1990-03-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-01-13", "fecha_version": "1990-03-27", "fecha_actualizacion_texto": "19