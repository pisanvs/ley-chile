{"html": [{"t": "<div><div class=\"p\">CONCEDE PLAZO QUE INDICA </div></div>", "i": 8314556}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 664, de 24 de Mayo de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se concede un plazo de 30 d&#xED;as a contar de la fecha de esta Resoluci&#xF3;n, a don Arnoldo del Carmen Opazo C&#xE1;ceres, R.U.T. No. 6.356.477-k, domiciliado en Constituci&#xF3;n, calle Balmaceda No. 339, para publicar el extracto de la resoluci&#xF3;n No. 195, de 1990, de esta Subsecretar&#xED;a, por haberse acreditado la ocurrencia de fuerza mayor.</div><br></div>", "i": 8314557}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 24 de mayo de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "664", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-664"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "CONCEDE PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-24", "doble_articulado": false, "id_norma": "82994", "numero_fuente": "33689", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-07", "vigencias": [{"desde": "1990-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "