{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6337110}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 596, de fecha 30 de marzo del 2001, se expropi&#xF3; el lote de terreno N&#xBA; 44, superficie 12.415,8 m&#xB2;, rol de aval&#xFA;o 178-30, comuna de Chonchi, para la obra &quot;Camino Ruta 5, Sector Chonchi-Tara, Km.</div><div class=\"p\">1.205,160 a Km. 1.215,004&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Zulema Cristina P&#xE9;rez B&#xF3;rquez, ascendente a la cantidad de $4.832.335.- </div></div>", "i": 6337111}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6337112}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "596", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-596"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "186017", "numero_fuente": "36976", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-01", "vigencias": [{"desde": "2001-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-06-01", "fecha_version": "2001-06-01", "fecha_actualizacion_texto": "2001-06-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura"