{"html": [{"t": "<div><div class=\"p\">MODIFICA EL ANEXO 51-15, RELATIVO A &quot;ALMACENISTAS&quot;, DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10259424}, {"t": "<div><br><div class=\"p\"> </div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.860, de 05.08.2021, del Director Nacional de Aduanas, se modific&#xF3; el Anexo 51-15, relativo a &quot;Almacenistas&quot;, en el siguiente sentido:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Cr&#xE9;ase e incorp&#xF3;rase el c&#xF3;digo A-49 a la tabla de almacenista asociado a la empresa Muelles de Penco S.A. Asimismo, deshabil&#xED;tase el c&#xF3;digo A-23 correspondiente a la empresa Cosaf S.A.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10259425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de agosto de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10259426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1860 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1860 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL ANEXO 51-15, RELATIVO A \"ALMACENISTAS\", DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1992022", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-08-05", "doble_