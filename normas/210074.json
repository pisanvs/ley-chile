{"html": [{"t": "<div><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DON HOMERO VALDES GUTIERREZ</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6423166}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a don Homero Vald&#xE9;s Guti&#xE9;rrez, una pensi&#xF3;n de $ 40.000 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones de Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6423167}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiuno de noviembre de mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- Roberto Vergara Herrera.</div><br></div>", "i": 6423168}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13859", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13859"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DON HOMERO VALDES\nGUTIERREZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-11-21", "doble_articulado": false, "id_norma": "210074", "numero_fuente": "24514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-12-10", "vigencias": [{"desde": "1959-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1959-12-10", "fin_vigenc