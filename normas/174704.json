{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA </div></div>", "i": 6298053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero, mediante resoluci&#xF3;n exenta N&#xBA; 66 de 25 de Enero de 1988, conforme Art. 5&#xBA; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas que corresponden a parcela N&#xBA; 1, parte de la N&#xBA; 48 y sitio N&#xBA; 47 de la parte del Proyecto de Parcelaci&#xF3;n &quot;Los Quillayes&quot; de la comuna de Pelarco, S&#xE9;ptima Regi&#xF3;n, formada por los predios Hijuela Huencuecho Norte y Los Quillayes. Los Derechos de Agua que se distribuyen se extraen del estero Las Chilcas. Publicaci&#xF3;n hecha conforme Art. 13 Ley 18.377.- </div></div>", "i": 6298054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6298055}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "66 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-66 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-25", "doble_articulado": false, "id_norma": "174704", "numero_fuente": "32984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-01", "vigencias": [{"desde": "1988-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-01", "fin_vigencia": "", "tipo