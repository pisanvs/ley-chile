{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9875083}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xB0;1762 de 15 de diciembre de 2017, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1068124&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xB0;806 de 30 de septiembre de 2014</a>, que orden&#xF3; la expropiaci&#xF3;n, entre otros, del Lote N&#xB0;26, en la parte que se refiere al nombre del propietario y rol de aval&#xFA;o, seg&#xFA;n certificado de aval&#xFA;o emitido por el Servicio de Impuestos Internos, quedando como a continuaci&#xF3;n se indica: LOTE 26, ARCE RUIZ SALVADOR Y OTRO, superficie 258 m2., rol de aval&#xFA;o 614-39, Comuna de MOLINA. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xB0; 2186, de 1978. </div></div>", "i": 9875084}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1762 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1762 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1332401", "NORMA SIN PROMULGACIÓN", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-12-15", "doble_articulado": false, "id_norma": "1113574", "numero_fuente": "41957", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-01-15", "vigencias": [{"desde": "2018-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-01-15", "fin_vigencia": ""}, "vig