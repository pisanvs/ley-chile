{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A FORESTAL Y PAPELERA CONCEPCION S.A.</div><br></div>", "i": 6336268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/ Ex. N&#xBA; 913, de fecha 30 de abril de 2001, revoca a Forestal y Papelera Concepci&#xF3;n S.A., RUT. N&#xBA; 96.771.800-9, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las adquisiciones de madera, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 18 de la resoluci&#xF3;n Ex. N&#xBA; 4.916/2000, de la Direcci&#xF3;n Nacional. </div></div>", "i": 6336269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 30 de abril de 2001.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6336270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "913 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-913 EXENTA"}, {"tipo": "3", "numero": "DRE-08-913 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-913 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A FORESTAL Y PAPELERA CONCEPCION S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-30", "doble_articulado": false, "id_norma": "185698", "numero_fuente": "36971", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-26", "vi