{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6196456}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta No. 168, de fecha 09.02.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Luis Ferm&#xED;n Urz&#xFA;a Vidal para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6196457}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago, 12.02.87.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6196458}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "168 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-168 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-09", "doble_articulado": false, "id_norma": "145111", "numero_fuente": "32713", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-04", "vigencias": [{"desde": "1987-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-03-04", "fin_vigencia": "", "tipo_version": "3"}], "even