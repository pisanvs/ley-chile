{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065528}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 174 de 09 de marzo de 1990 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; a la Sociedad Gonz&#xE1;lez y Compa&#xF1;&#xED;a Limitada (Transporte Aconcagua Santiago T.A.S. Choapa Limitada o T.A.S. Choapa Limitada) para efectuar servicio internacional de transporte terrestre de pasajeros entre San tiago (Chile) y San Luis - C&#xF3;rdoba (Argentina) por Paso Caracoles (T&#xFA;nel Cristo Redentor) con tres frecuencias semanales, de ida y vuelta.- </div></div>", "i": 6065529}, {"t": "<div><div class=\"p\">Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 6065530}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "174 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-174 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-09", "doble_articulado": false, "id_norma": "83507", "numero_fuente": "33640", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-06", "vigencias": [{"desde": "1990-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-04-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1998-01-08", "fecha_version": "