{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6410121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 37, de 8 de enero de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.264 de 2000, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA GENMAR LIMITADA, para operar la nave &quot;Don Chelo I&quot;, con red de arrastre, en relaci&#xF3;n con el recurso hidrobiol&#xF3;gico Raya volant&#xED;n, en el &#xE1;rea mar&#xED;tima correspondiente a la VIII Regi&#xF3;n, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6410122}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6410123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "37", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-37"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-08", "doble_articulado": false, "id_norma": "206676", "numero_fuente": "37458", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-14", "vigencias": [{"desde": "2003-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text":