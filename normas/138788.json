{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8346365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 127, de 11 de Febrero de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 1.058, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Salazar y Cerna Limitada, domiciliada en Quell&#xF3;n, para instalar y operar una planta industrial ubicada en la X Regi&#xF3;n, Miramar No. 153, Quell&#xF3;n, Provincia de Chilo&#xE9;, en las l&#xED;neas de elaboraci&#xF3;n de conserva, congelado, deshidratado, seco-salado y ahumado, en orden a se&#xF1;alar que se incluye, entre los recursos hidrobiol&#xF3;gicos ya autorizados el Erizo. </div></div>", "i": 8346366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de Febrero de 1988.- Roberto Cabezas Bello Subsecretario de Pesca.</div><br></div>", "i": 8346367}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "127", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-127"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-11", "doble_articulado": false, "id_norma": "138788", "numero_fuente": "33003", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-23", "vigencias": [{"desde": "1988-02-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-23", "fin_vigencia": ""}, "vigencias_ver