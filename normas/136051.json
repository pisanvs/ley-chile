{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 78, DE 1988 </div></div>", "i": 6167485}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 78 de 15 de abril de 1988 se ha aprobado a la Escuela Diferencial F No. 69 de San Felipe, provincia de San Felipe de Aconcagua, V Regi&#xF3;n de Valpara&#xED;so, un plan de estudio especial de orientaci&#xF3;n laboral para alumnos discapacitados, que se desarrollar&#xE1; con car&#xE1;cter experimental, por un per&#xED;odo de 4 a&#xF1;os, a contar desde 1988.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio correspondientes al plan que aprueba el presente decreto.</div><br></div>", "i": 6167486}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de abril de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6167487}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "78 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-78 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 78, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-15", "doble_articulado": false, "id_norma": "136051", "numero_fuente": "33068", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-11", "vigencias": [{"desde": "1988-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "19