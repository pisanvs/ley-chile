{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6375068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 402, de fecha 25 de febrero de 2002, se expropiaron los lotes de terreno N&#xBA;s 15 y 16, superficie 99 y 432 m2, respectivamente, rol de aval&#xFA;o 7400-3 y 7404-13, comuna de Talcahuano, para la obra &quot;Mejoramiento Eje Gran Breta&#xF1;a, Sector Cuatro Esquinas-Rotonda CAP Km. 0,00000 a Km. 2,74400&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Edyce S.A., ascendente a la cantidad de $33.071.975. </div></div>", "i": 6375069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6375070}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "402", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-402"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-25", "doble_articulado": false, "id_norma": "196252", "numero_fuente": "37223", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-01", "vigencias": [{"desde": "2002-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-04-01", "fecha_version": "2002-04-01", "fecha_actualizacion_texto": "2002-04-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": ""