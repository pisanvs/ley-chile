{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  MODIFICA CONCESION DE RADIODIFUSION SONORA</div><div class=\"p\">&nbsp;  Santiago, 14 de Junio de 1994.- Con esta fecha se ha decretado lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 193.- Vistos:</div><div class=\"p\"> _______________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 34.943 DEL DIA JUEVES&nbsp;  |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  18 DE AGOSTO DE 1994, PAGINAS 7 a 8&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  |</div><div class=\"p\"> |_____________________________________________________|</div><br></div>", "i": 7140916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese, notif&#xED;quese al interesado y publ&#xED;quese en el Diario Oficial.- Por orden del Presidente de la Rep&#xFA;blica, Narciso Irureta Aburto, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda atentamente a Ud., Jorge Rosenblut Ratinoff, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 7140917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "193", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-193"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "MODIFICA CONCESION DE RADIODIFUSION SONORA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION RADIODIFUSION SONORA", "FRECUENCIA MODULADA", "PUNCON", "NOVENA REGION", "JORGE RAFAEL FIGUEROA MIRANDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-14", "doble_articulado": false, "id_norma": "10765", "numero_fuente": "34943", "tipo_version