{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9254760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0;1.143, de 26 de abril de 2012, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 1&#xB0; letra a) de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1039356&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 944, de 2012</a>, que modific&#xF3; la distribuci&#xF3;n para el a&#xF1;o 2012 de la fracci&#xF3;n artesanal de pesquer&#xED;a de Sardina com&#xFA;n en la VIII Regi&#xF3;n, sometida al R&#xE9;gimen Artesanal de Extracci&#xF3;n, en sentido de reemplazar la asignaci&#xF3;n efectuada a la organizaci&#xF3;n de pescadores artesanales que se individualiza, por la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/25946.jpg\"></div></div>", "i": 9254761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de abril de 2012.- Maximiliano Alarma Carrasco, Subsecretario de Pesca (S).</div></div>", "i": 9254762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1143 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1143 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-04-26", "doble_articulado": false, "id_norma": "1039703", "numero_fuente": "40255", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-07", "vigencias": [{"desde": "2012-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in