{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  ACUERDOS ADOPTADOS POR&nbsp; EL CONSEJO EN SU SESION N&#xBA; 691</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA;691, celebrada el 16 de julio de 1998, adopt&#xF3; los siguientes Acuerdos:</div><br><div class=\"p\">691-07-980716 - Designaci&#xF3;n de representantes ante la Comisi&#xF3;n Chilena del Cobre.</div><br><br><br></div>", "i": 6119596}, {"t": "<div><div class=\"p\">Se acord&#xF3; designar a contar del 23 de julio de 1998, por el per&#xED;odo de dos a&#xF1;os, como representantes del Banco Central de Chile ante el Consejo de la Comisi&#xF3;n Chilena del Cobre, a los se&#xF1;ores Ricardo Vicu&#xF1;a Poblete y Andr&#xE9;s Reinstein Alvarez, todo ello en conformidad con lo establecido en la ley N&#xBA;18.940.</div><br></div>", "i": 6119597}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 16 de julio de 1998.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6119598}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "691", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-691"}, {"tipo": "5", "numero": "691-07", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-691-07"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESION Nº 691, DESIGNACION DE REPRESENTANTES ANTE LA COMISION CHILENA DEL COBRE.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMISION CHILENA DEL COBRE", "RICARDO VICU A POBLETE", "ANDRES REINSTEIN ALVAREZ", "CONSEJERO", "DESIGNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-16", "doble_articulado": false, "id_norma": "12147