{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6224028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 924, de fecha 27 de Julio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Alberto Ram&#xF3;n D&#xED;az Parraguez para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios publicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6224029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de Agosto de 1987.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6224030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "924 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-924 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-27", "doble_articulado": false, "id_norma": "152739", "numero_fuente": "32860", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-01", "vigencias": [{"desde": "1987-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-01", "fin_vigencia": "", "tipo_v