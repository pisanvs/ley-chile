{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO N&#xBA; 10 EXENTO, DE 2004</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 153 exento.- Santiago, 16 de marzo de 2004. </div></div>", "i": 6474045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Modifica decreto ex. N&#xBA; 10 de 16 de enero de 2004, en el sentido que se otorga nuevo plazo para de 30 d&#xED;as para publicar extracto.</div><div class=\"p\">&nbsp; &nbsp;  2.- El presente decreto forma parte integrante del que se modifica.</div><br></div>", "i": 6474046}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, reg&#xED;strese en el Ministerio de Bienes Nacionales, comun&#xED;quese, publ&#xED;quese en extracto en el &quot;Diario Oficial&quot; y arch&#xED;vese.- Por orden del Presidente de la Rep&#xFA;blica, Jaime Ravinet de la Fuente, Ministro de Bienes Nacionales.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud., Jacqueline Weinstein Levy, Subsecretaria de Bienes Nacionales.</div><br></div>", "i": 6474047}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "153 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-153 EXENTO"}], "organismos": ["MINISTERIO DE BIENES NACIONALES"], "titulo_norma": "MODIFICA DECRETO Nº 10 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-16", "doble_articulado": false, "id_norma": "223872", "numero_fuente": "37837", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-16", "vigencias": [{"desde": "2004-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-1