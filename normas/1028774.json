{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 5.469.- Santiago, 27 de Noviembre de 1929.- Visto lo dispuesto en el Art. 81 del decreto N.o 4.807, de 4 del actual, que reglamenta la organizaci&#xF3;n de la Ense&#xF1;anza Universitaria, y en uso de las facultades que me confiere la ley N.o 4,659, de 17 de Setiembre &#xFA;ltimo,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div></div>", "i": 9168490}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se declara que las Universidades particulares existentes a que se refiere el Art. 81 del Estatuto de la Ense&#xF1;anza Universitaria, aprobado por <a href=\"https://www.leychile.cl/Navegar?idNorma=1028775&amp;idParte=0&amp;idVersion=\">decreto N.o 4,807</a>, de 4 del actual, son la Universidad Cat&#xF3;lica de Chile y la Universidad de Concepci&#xF3;n.</div><br></div>", "i": 9168491}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- C. Ib&#xE1;&#xF1;ez C.- M. Navarrete C.</div></div>", "i": 9168492}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5469", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-5469"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-11-27", "doble_articulado": false, "id_norma": "1028774", "numero_fuente": "15541", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-12-06", "vigencias": [{"desde": "1929-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini