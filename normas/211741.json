{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 1.071 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1.071, celebrada el 26 de junio de 2003, adopt&#xF3; el siguiente Acuerdo:</div><br><br></div>", "i": 6428938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1071-02-030626 - Tasa de inter&#xE9;s para pago diferido de derechos de aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del art&#xED;culo 10 de la ley N&#xBA; 18.634, publicada en el Diario Oficial del 5 de agosto de 1987, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que expira el 31 de diciembre de 2003, ser&#xE1; de 5,3% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica. </div></div>", "i": 6428939}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de junio de 2003.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (S).</div><br></div>", "i": 6428940}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1071", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1071"}, {"tipo": "5", "numero": "1071-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1071-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1.071", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BIENES DE CAPITAL", "DERECHOS ADUANEROS", "PAGO DIFERIDO", "TASA DE INTERES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-26", "doble_articulado": false, "id_norma": "211741", "numero_fuente": "37596", "tipo_version":