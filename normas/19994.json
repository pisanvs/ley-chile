{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 68 EXENTO, DE 1995 </div></div>", "i": 5940582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 68 de fecha 25 de Enero de 1995 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Osorno, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 1995:</div><div class=\"p\"> Carrera&nbsp; : Turismo con menci&#xF3;n en Hoteler&#xED;a o</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Marketing Tur&#xED;stico.</div><br><div class=\"p\"> T&#xED;tulo&nbsp;  : - T&#xE9;cnico en Turismo (4 semestres)</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; - T&#xE9;cnico en Turismo con menci&#xF3;n en Hoteler&#xED;a</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; o Marketing Tur&#xED;stico (2 semestres</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; adicionales)</div><br></div>", "i": 5940583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 7 de Febrero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5940584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "68", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-68"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 68 EXENTO, DE 1995", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA OSORNO", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-01-25", "fecha_derogacion": "20