{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO No. 159, DE 1982</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 241.- Santiago, 08 de Marzo de 1988.- Vistos: La facultad que me otorga el No. 8 del art&#xED;culo 32 de la Constituci&#xF3;n Pol&#xED;tica del Estado y lo dispuesto en el art&#xED;culo 54 del DFL No. 338, de 1960,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7271027}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Agr&#xE9;gase en el n&#xFA;mero 2 del decreto No. 159, de Hacienda, de 18 de Febrero de 1982, a la enumeraci&#xF3;n de los Servicios que se pagan el d&#xED;a 19 el siguiente:</div><div class=\"p\">&quot;Instituto de Normalizaci&#xF3;n Previsional&quot;.</div><br></div>", "i": 7271028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Hern&#xE1;n Buchi Buc, Ministro de Hacienda. Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Dante Santoni Compiano, Teniente Coronel, Subsecretario de Hacienda.</div><br></div>", "i": 7271029}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "241", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-241"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA"], "titulo_norma": "MODIFICA DECRETO No. 159, DE 1982", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-08", "doble_articulado": false, "id_norma": "171250", "numero_fuente": "33030", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-25", "vigencias": [{"desde": "1988-0