{"html": [{"t": "<div><div class=\"p\">DECLARA CADUCIDAD DE RESOLUCIONES QUE INDICA</div></div>", "i": 10187757}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.784, de 17 de diciembre de 2020, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de las resoluciones exentas <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=181660&amp;idVersion=2020-12-24\">N&#xBA; 136, de 2001</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=207026&amp;idVersion=2020-12-24\">N&#xBA; 39, de 2003</a>, <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=251244&amp;idVersion=2020-12-24\">N&#xBA; 1.918, de 2006</a> y <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1023148&amp;idVersion=2020-12-24\">N&#xBA; 130, de 2011</a>, que autorizaron a Sociedad Pesquera Leucot&#xF3;n Ltda. para realizar actividades pesqueras extractivas con la nave &quot;Leucot&#xF3;n&quot;, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura en relaci&#xF3;n al memor&#xE1;ndum t&#xE9;cnico citado en Visto de la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10187758, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de diciembre de 2020.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10187759}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2784 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2784 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DECLARA CADUCIDAD DE RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], 