{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA IQUIQUE S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS </div></div>", "i": 7262021}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 288 de 27 de Mayo de 1985 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a &quot;Pesquera Iquique S.A.&quot;, para operar la embarcaci&#xF3;n denominado &quot;Colorado I&quot; en el litoral comprendido entre la I y III Regi&#xF3;n, en labores extractivas de los siguientes recursos: agujilla, anchoa, caballa, jurel, sardina espa&#xF1;ola, bonito, at&#xFA;n y cachurreta. Se establece que la embarcaci&#xF3;n &quot;Colorado I&quot; fue adquirida por Pesquera Iquique S.A. en 1984.</div><br></div>", "i": 7262022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Mayo de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7262023}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "288", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-288"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA IQUIQUE S.A. PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-27", "doble_articulado": false, "id_norma": "156680", "numero_fuente": "32184", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-05-31", "vigencias": [{"desde": "1985-05-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-05-31", "fin_vigencia": ""}, "vigencias_version_norma"