{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6552434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.922, de 18 de noviembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SILVIA YANETT ARNALDI SANDOVAL para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Chesque Bajo Km. 15, camino Villarrica-Lican Ray, comuna de Villarrica, IX Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco-refrigerado y Ahumado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6552435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6552436}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3922 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3922 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-18", "doble_articulado": false, "id_norma": "244929", "numero_fuente": "38335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-13", "vigencias": [{"desde": "2005-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-12-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fech