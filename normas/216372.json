{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CERTIFICADO</div><br></div>", "i": 6445545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe,</div><div class=\"p\">certifica que la Universidad del Mar inscrita bajo el</div><div class=\"p\">n&#xFA;mero C-30 del Registro de Universidades del Ministerio</div><div class=\"p\">de Educaci&#xF3;n, ha presentado los programas de estudios de</div><div class=\"p\">la carrera de Pesca y Acuicultura conducente al T&#xED;tulo</div><div class=\"p\">de Ingeniero de Ejecuci&#xF3;n en Pesca a la Universidad</div><div class=\"p\">Arturo Prat, quien los ha aprobado y se ha constituido en entidad examinadora, de conformidad al convenio celebrado entre amabas instituciones con fecha 14 de Noviembre de 1990.</div><div class=\"p\">&nbsp; &nbsp;  La carrera mencionada podr&#xE1; impartirse a contar desde 1991, en la Sede Vi&#xF1;a del Mar de dicha Universidad.</div><br></div>", "i": 6445546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Julio de 1991.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; RAUL ALLARD NEUMANN</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  Subsecretario de Educaci&#xF3;n</div><br></div>", "i": 6445547}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-23", "doble_articulado": false, "id_norma": "216372", "numero_fuente": "