{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8337613}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.614, de 20 de noviembre de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a MARCOS HERACLIO PI&#xD1;A CABELLO para ampliar actividades pesqueras autorizadas por resoluciones N&#xBA;1.278, de 1991, y N&#xBA;479, de 1997, ambas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Avenida Mackenna N&#xBA;84, Calbuco, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican los siguientes recursos hidrobiol&#xF3;gicos: Seco-Salado: Anchoveta, Merluza del sur, Sardina espa&#xF1;ola y Sardina com&#xFA;n.</div><br></div>", "i": 8337614}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de noviembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8337615}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1614", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1614"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-20", "doble_articulado": false, "id_norma": "128584", "numero_fuente": "36243", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-19", "vigencias": [{"desde": "1998-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-12-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],