{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede a don Domingo Godoi derecho de jubilar Santiago, a 22 de Setiembre de 1903.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5950708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a don Domingo Godoi derecho de jubilar en el car&#xE1;cter de juez de letras de Santiago, que desempe&#xF1;aba en 1890, i con arreglo a la lei n&#xFA;m. 327, de 31 de Diciembre de 1895.</div><br></div>", "i": 5950709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Francisco J. Concha.</div><br></div>", "i": 5950710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1614", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1614"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE A DON DOMINGO GODOI DERECHO DE JUBILAR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DOMINGO GODOY", "DERECHO", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-09-22", "doble_articulado": false, "id_norma": "22793", "numero_fuente": "7714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-09-29", "vigencias": [{"desde": "1903-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-09-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1903-09-29", "fin_vigencia": "", "tipo_version":