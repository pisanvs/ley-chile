{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA PARTE DISPOSITIVA DE LA RESOLUCION N&#xB0; 1.309 EXENTA, DE 1992 </div></div>", "i": 7202264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Res. Ex. N&#xB0; 1453 de 22 de junio de 1995, se introducen las siguientes modificaciones en el dispositivo N&#xB0; 1 de la Res. Ex. N&#xB0; 1309 de 26.03.92 publicada en el Diario Oficial de 04.04.92.</div><div class=\"p\">&nbsp; &nbsp; 1.- Reempl&#xE1;zase en el inciso segundo de la letra A) la expresi&#xF3;n &quot;graves&quot; por la palabra &quot;complejas&quot;, y 2.- Supr&#xED;mese la letra D), pasando las letras F), G), y H) a ser D), F) y G), respectivamente.</div><br><br></div>", "i": 7202265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jorge Villablanca Echegoyen, Director Regional. + </div></div>", "i": 7202266}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1453 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1453 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA PARTE DISPOSITIVA DE LA RESOLUCION N° 1.309 EXENTA, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIRECCION REGIONAL", "SERVICIO IMPUESTOS INTERNOS", "DELEGACION", "FACULTAD", "MODIFICACION", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-06-22", "doble_articulado": false, "id_norma": "39782", "numero_fuente": "35208", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-07-04", "vigencias": [{"desde": "1995-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-07-04