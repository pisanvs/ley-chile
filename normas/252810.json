{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br><br></div>", "i": 6581331}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.145 de 18 de agosto de 2006 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n total, conforme D.L. N&#xBA; 2.186 de 1978, del inmueble ubicado en calle San Jorge, Sitio 268, MZ 8 Sector C, presunto Rol de aval&#xFA;o N&#xBA; 4.037-268, comuna de Quinta Normal, aparente dominio de Andr&#xE9;s Osorio Trivi&#xF1;o. Comisi&#xF3;n integrada por peritos Miguel Fern&#xE1;ndez C&#xE1;diz, constructor civil, In&#xE9;s Ot&#xE1;rola Castillo, arquitecto y Mario Zamorano Villablanca, arquitecto. Seg&#xFA;n informe de 15 de junio de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $2.116.400.- pagadera al contado. </div></div>", "i": 6581332}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6581333}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4145 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4145 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACION TOTAL DE INMUEBLES QUE SEÑALA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-08-18", "doble_articulado": false, "id_norma": "252810", "numero_fuente": "38554", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-01", "vigencias": [{"desde": "2006-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ún