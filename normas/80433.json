{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6057329}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No.60 de 15 de abril</div><div class=\"p\">de 1991 se han aprobado planes especiales de estudio de</div><div class=\"p\">Educaci&#xF3;n B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica, al</div><div class=\"p\">Washington Center College, de Santiago, para ser aplicados a</div><div class=\"p\">partir del a&#xF1;o escolar 1991, en todos los cursos</div><div class=\"p\">simult&#xE1;neamente.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio de las asignaturas</div><div class=\"p\">que se indican de los planes de estudio a que se refiere el</div><div class=\"p\">art&#xED;culo 1&#xBA; del presente decreto.</div><br></div>", "i": 6057330}, {"t": "<div><div class=\"p\">Santiago, 3 de Junio de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6057331}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "60 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-60 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-04-15", "doble_articulado": false, "id_norma": "80433", "numero_fuente": "34043", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-14", "vigencias": [{"desde": "1991-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-08-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-08-14", "fin_vigencia