{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Subvencion a la Sociedad Protectora de la Infancia en Santiago</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,409.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274317}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la Sociedad Protectora de la Infancia de Santiago una subvencion estraordinaria de sesenta mil pesos para continuar la construccion de los edificios destinados a la instalacion de sus servicios.</div><br></div>", "i": 8274318}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 16 de Enero de 1901.- FEDERICO ERRAZURIZ E.- Juan Antonio Orrego.</div><br></div>", "i": 8274319}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1409", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1409"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SUBVENCION A LA SOCIEDAD PROTECTORA DE LA INFANCIA EN SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD PROTECTORA INFANCIA SANTIAGO", "FONDOS", "DESTINACION", "CONSTRUCCION", "EDIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-16", "doble_articulado": false, "id_norma": "22628", "numero_fuente": "6793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-16", "vigencias": [{"desde": "1901-01-16", "hasta": "", "tipo_version": "3", "tipo_versi