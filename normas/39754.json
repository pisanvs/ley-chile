{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCION </div></div>", "i": 6024876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Res. Ex. N&#xB0; 1.403, de fecha 17 de Mayo de 1991, modifica Certificado de Subsidio habitacional Serie A-89 N&#xB0; 02-7088, extendido en favor de do&#xF1;a ramona del Carmen Torres Ayala, en el sentido de eliminar el monto de la rebaja que expresa y dispone la sustituci&#xF3;n de dicho Certificado de Subsidio habitacional, Como consecuencia de ello, queda en 1.284.170 Unidades de Fomento (U.F.), el monto de los recursos comprometidos para el financiamiento del subsidio directo para la atenci&#xF3;n de los postulantes seleccionados en el segundo llamado 1989 del Sistema General Unificado de Subsidio habitacional.- </div></div>", "i": 6024877}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Joan Mac Donald M., Subsecretaria de Vivienda y Urbanismo.</div><br></div>", "i": 6024878}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1403", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1403"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "EXTRACTOS DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RAMONA CARMEN TORRES AYALA", "CERTIFICADO", "SUBSIDIO HABITACIONAL", "SEGUNDO LLAMADO 1989"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-05-17", "doble_articulado": false, "id_norma": "39754", "numero_fuente": "33981", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-01", "vigencias": [{"desde": "1991-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-06-01", "fin_vigencia": ""}, "vigencias_version_nor