{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 12.862 EXENTA, DE 1999 </div><br></div>", "i": 7265544}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 12.862, de 29 de diciembre de 1999, se ha aprobado, al Colegio Hispanoamericano (PP. Escolapios), comuna de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para primer a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n exenta. </div></div>", "i": 7265545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de enero de 2000.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 7265546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12862 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12862 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 12.862 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "161547", "numero_fuente": "36617", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-18", "vigencias": [{"desde": "2000-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac