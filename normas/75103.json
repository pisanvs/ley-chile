{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO N&#xBA; 690, DE 1994</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 699.- Santiago, 18 de junio de 1997.- Vistos: lo dispuesto en el art&#xED;culo 4&#xBA; de la Ley N&#xBA; 19.288; en el art&#xED;culo 29 de la Ley N&#xBA; 19.420 y en la letra h) del art&#xED;culo 1&#xBA; de la Ley N&#xBA; 19.478,</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br></div>", "i": 6043785}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Supr&#xED;mese en el Decreto de Hacienda N&#xBA; 690, de 1994, la frase &quot;del Aeropuerto Arturo Merino Ben&#xED;tez de Santiago&quot;.</div><br></div>", "i": 6043786, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Eduardo Aninat Ureta, Ministro de Hacienda.</div><br><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud., Manuel Marf&#xE1;n Lewis, Subsecretario de Hacienda.</div><br></div>", "i": 6043787}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "699", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-699"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA DECRETO Nº 690, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ALMACENES DE VENTA LIBRE", "DUTY FREE SHOP", "AEROPUERTO ARTURO MERINO BENITEZ", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-18", "doble_articulado": false, "id_norma": "75103", "numero_fuente": "35848", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997