{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8321400}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.312 de 20 de Septiembre de 1989 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 6 meses a contar del 18 de julio de 1989, el plazo otorgado a Cultivos Marinos Chilo&#xE9; Limitada, R.U.T. No. 79.784.980-4, domiciliada en Santiago, para empezar a operar el establecimiento de cultivo autorizado por la Resoluci&#xF3;n No. 920, de 1988, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8321401}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 20 de Septiembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8321402}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1312", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1312"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-09-20", "doble_articulado": false, "id_norma": "92213", "numero_fuente": "33500", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-19", "vigencias": [{"desde": "1989-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-10-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-10-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones