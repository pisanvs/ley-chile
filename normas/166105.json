{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6266844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;501, de 28 de febrero del 2000, se expropi&#xF3; los lotes de terreno N&#xBA;s. 100 y 102, superficies 2.369,0 m&#xB2; y 2.784,0 m&#xB2;., rol de aval&#xFA;o 251-30, comuna de Lautaro, para la obra Concesi&#xF3;n Internacional Ruta 5, Tramo Collipulli-Temuco, Novena Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Gast&#xF3;n Carlos Caminondo Vidal y otros, ascendente a la cantidad total de $19.269.489.-</div><br></div>", "i": 6266845}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6266846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "501", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-501"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-28", "doble_articulado": false, "id_norma": "166105", "numero_fuente": "36641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-15", "vigencias": [{"desde": "2000-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "2000-04-19", "fecha_version": "2000-04-15", "fecha_actualizacion_texto": "2000-04-15", "tipo_tratado": ""}, "alertas": [], "alerta_glob