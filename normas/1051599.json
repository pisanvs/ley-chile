{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9356298}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.223, de 17 de mayo de 2013, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA B&#xCD;O B&#xCD;O S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Bonn&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la IV a IX Regiones, por fuera del &#xE1;rea de reserva artesanal, con arrastre, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: Mict&#xF3;fido Triphoturus mexicanus, Mict&#xF3;fido Diogenichthys sp., Mict&#xF3;fido Ceratoscopelus sp., Mict&#xF3;fido Diaphus sp., Mict&#xF3;fido Gonichthys sp., Mict&#xF3;fido Gymnoscopelus sp., Mict&#xF3;fido Hygophum sp., Mict&#xF3;fido Lampadena sp., Mict&#xF3;fido Lampanyctus sp. y Mict&#xF3;fido Myctophum sp.</div></div>", "i": 9356299}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de mayo de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9356300}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1223 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1223 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-05-17", "fecha_derogacion": "2016-10-21", "doble_articulado": false, "id_norma": "1051599", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-06-03", "vigencias": [{"desde": "2016-10-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Ver