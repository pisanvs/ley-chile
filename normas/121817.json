{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A MARIO FERNANDO LARROULET LAFONTAINE</div><br></div>", "i": 7235896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex. 0615, de fecha 8 de julio de 1998, otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n a don Mario Fernando Larroulet Lafontaine, Rut.</div><div class=\"p\">N&#xBA; 5.967.831-0, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las operaciones de ganado vivo, establecido en la resoluci&#xF3;n N&#xBA; Ex.</div><div class=\"p\">2.379/98, de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 24.04.98, modificada y complementada por resoluci&#xF3;n N&#xBA; Ex. 3.785/98, publicada en el Diario Oficial del d&#xED;a 30.06.98.-</div><br></div>", "i": 7235897}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 7235898}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "615 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-615 EXENTA"}, {"tipo": "3", "numero": "DRE-08-0615 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-0615 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A MARIO FERNANDO LARROULET LAFONTAINE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "MARIO FERNANDO LARROULET LAFONTAINE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "dero