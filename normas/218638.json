{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 656, de 31 de octubre de 1995, se expropiaron los lotes de terreno N&#xBA;s. 8, 8-A, 14, 16 y 97, superficies 1.019 m2., 529 m2., 6.720 m2., 320 m2. y 477 m2., roles de aval&#xFA;o 1093-8 y 162-12, comunas de Cartagena y Casablanca, para la obra Camino Malvilla-Orrego Abajo y se acord&#xF3; valor con sus propietarios Alfonso Romero Aguirre y Marta F. N&#xFA;&#xF1;ez Pacheco, ascendente a las cantidades de $9.578.832, para los lotes N&#xBA;s. 8, 8-A, 14 y 16 y $244.507, para el lote N&#xBA; 97.</div><br></div>", "i": 6743179}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743180}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "656", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-656"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-31", "doble_articulado": false, "id_norma": "218638", "numero_fuente": "35331", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-01", "vigencias": [{"desde": "1995-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-12-15", "fecha_version": "1995-12-01", "fecha_actualizacion_texto": "