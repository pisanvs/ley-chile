{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 280, DE 1986 </div></div>", "i": 6223701}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento de Educaci&#xF3;n N&#xB0; 280 de fecha 30 de Septiembre de 1986, se modific&#xF3; el Art&#xED;culo Unico del Decreto Exento de Educaci&#xF3;n N&#xB0; 159 de 1982, que autoriza el funcionamiento del Instituto Profesional Chileno Britanico de Cultura en el sentido de incorporar al Reglamento a que se refiere el Art&#xED;culo 6&#xB0; del DFL N&#xB0; 5 de 1981, nuevas condiciones para el otorgamiento de los t&#xED;tulos profesionales y t&#xE9;cnicos a contar del a&#xF1;o 1986.- </div></div>", "i": 6223702}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6223703}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "280 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-280 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 280, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-30", "doble_articulado": false, "id_norma": "152627", "numero_fuente": "32.601", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-20", "vigencias": [{"desde": "1986-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-10-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": []