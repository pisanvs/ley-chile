{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8890701}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 852, de 22 de febrero de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a GESAM CONSULTORES LTDA. para efectuar una liberaci&#xF3;n 3.000 alevines de Trucha caf&#xE9; Salmo trutta en sectores de R&#xED;o Juncal, V Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Los ejemplares deber&#xE1;n provenir de Piscicultura de R&#xED;o Blanco &quot;Federico Albert Taupp&quot;, ubicado en Los Andes, V Regi&#xF3;n, autorizado por resoluci&#xF3;n N&#xBA; 1.280 de 1982, de esta Subsecretar&#xED;a.</div></div>", "i": 8890702}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de febrero de 2010.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8890703}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "852 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-852 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRAQCTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-02-22", "doble_articulado": false, "id_norma": "1011477", "numero_fuente": "39602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-04", "vigencias": [{"desde": "2010-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-03-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "