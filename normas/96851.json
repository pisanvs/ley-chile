{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8327989}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No.1.363, de 4 de Noviembre de 1991 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a FINAMAR S.A., R.U.T.</div><div class=\"p\">No.96.532.690-1, domiciliada en Avda. General Bonilla No.9469, Pudahuel, para continuar desarrollando actividades pesqueras autorizadas a Elaboradora y Comercializadora de Alimentos Finamar S.A., en la forma y bajo las condiciones se&#xF1;aladas en las Resoluciones No.1124 y No.2018, ambas de 1989, de esta Subsecretar&#xED;a, en virtud del cambio de raz&#xF3;n social acordada en instrumento citado en Visto. </div></div>", "i": 8327990}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 4 de Noviembre de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br><br></div>", "i": 8327991}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1363", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1363"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-04", "doble_articulado": false, "id_norma": "96851", "numero_fuente": "34124", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-23", "vigencias": [{"desde": "1991-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-23", "fin_vigencia": "", "tipo_version": "3"}], "eve