{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6308770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 4.121, de 31 de agosto del 2000, se expropiaron los lotes de terreno N&#xBA;s. 205-A, 205-B y 205-C, superficies 52.756 m&#xB2;, 4.374 m&#xB2; y 17.637 m&#xB2;, rol de aval&#xFA;o 293-1, comuna de Los Vilos, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Samtiago - Los Vilos, Cuarta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Guillermo Lorca Ribbeck y Otras, ascendente a la cantidad total de $233.296.619.</div><br></div>", "i": 6308771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6308772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4121", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4121"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-31", "doble_articulado": false, "id_norma": "177867", "numero_fuente": "36813", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-15", "vigencias": [{"desde": "2000-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-11-16", "fecha_version": "2000-11-15", "fecha_actualizacion_texto": "2000-11-15", "tipo_tratado": ""}, "alert