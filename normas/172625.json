{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6288095}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.674, de 28 de abril de 2000, se expropi&#xF3; el lote de terreno N&#xBA;199-1, superficie 35 m&#xB2;, rol de aval&#xFA;o 53-2, comuna de Collipulli, para la obra &apos;&apos;Concesi&#xF3;n Internacional Ruta 5; Tramo:</div><div class=\"p\">Chill&#xE1;n-Collipuli, Novena Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Sonia del Carmen Acu&#xF1;a Salinas, ascendente a la cantidad de $9.913.080. </div></div>", "i": 6288096}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6288097}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1674", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1674"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "172625", "numero_fuente": "36714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-15", "vigencias": [{"desde": "2000-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-07-18", "fecha_version": "2000-07-15", "fecha_actualizacion_texto": "2000-07-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "es