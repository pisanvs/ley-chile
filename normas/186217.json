{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;214 EXENTO, DE 2001 </div></div>", "i": 6337970}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;214 de fecha 4 de mayo de 2001, del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Osorno, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 2001, en la Sede Central de Osorno y Sede N&#xBA;1 de Temuco, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; : Turismo con menci&#xF3;n en Hoteler&#xED;a o</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Marketing, cambia por:</div><div class=\"p\">Carrera&nbsp; &nbsp; : Turismo y Hoteler&#xED;a.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp;  : T&#xE9;cnico de Nivel Superior en Turismo</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  y Hoteler&#xED;a.</div><br></div>", "i": 6337971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de mayo de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6337972}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "214 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-214 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº214 EXENTO, DE 2001", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-05-04", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "186217", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicac