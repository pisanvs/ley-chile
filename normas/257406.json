{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 2.319 EXENTA, DE 2006 </div></div>", "i": 6597077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.319, de 18 de diciembre de 2006, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xBA; 5 de la resoluci&#xF3;n N&#xBA; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo como combustible:</div><br><div class=\"p\"> Empresa&nbsp; &nbsp; &nbsp; &nbsp; Nombre del&nbsp; &nbsp;  Direcci&#xF3;n</div><div class=\"p\">Habilitada&nbsp; &nbsp; &nbsp;  Taller&nbsp; &nbsp; &nbsp; &nbsp; del Taller&nbsp; &nbsp; &nbsp; Ciudad</div><br><div class=\"p\">Italgas S.A.&nbsp;  &quot;Comercial&nbsp; &nbsp; &nbsp; Santa Sof&#xED;a</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  R.T.I. Ltda.&quot;&nbsp;  N&#xBA; 92&nbsp; &nbsp; &nbsp; &nbsp;  Concepci&#xF3;n</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.</div><br></div>", "i": 6597078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Danilo N&#xFA;&#xF1;ez Izquierdo, Subsecretario de Transportes.</div><br></div>", "i": 6597079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2319 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2319 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 2.319 EXENTA, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "