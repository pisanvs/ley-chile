{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6288720}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.122 de fecha 29 de mayo de 2000, se expropi&#xF3; los lotes de terreno N&#xBA;s 36 y 41, superficie 860 y 258 m&#xB2; respectivamente, rol de aval&#xFA;o 311-21, comuna de Pe&#xF1;aflor, para la obra &apos;&apos;Camino Ruta G-380, Sector Santa Teresa - Puente Pelv&#xED;n, Tramo Km.</div><div class=\"p\">21.185 a Km. 35.351,88&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Mar&#xED;a del Pilar Jara Valenzuela, ascendente a la cantidad de $2.943.218. </div></div>", "i": 6288721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6288722}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2122", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2122"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-29", "doble_articulado": false, "id_norma": "172916", "numero_fuente": "36714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-15", "vigencias": [{"desde": "2000-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-07-18", "fecha_version": "2000-07-15", "fecha_actualizacion_texto": "2000-07-15", "t