{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xB0; 355 EXENTA, DE 2022</div></div>", "i": 10307303}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  La resoluci&#xF3;n exenta N&#xB0; 355, de 19 de enero de 2022, del Director Nacional del Servicio Nacional de Capacitaci&#xF3;n y Empleo, autoriz&#xF3; la presentaci&#xF3;n de documentos digitalizados y en formato electr&#xF3;nico que consten con firma electr&#xF3;nica de sus otorgantes, respecto de actividades de contrato de capacitaci&#xF3;n y declaraciones juradas de cursos bajo modalidad a distancia.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n exenta N&#xB0; 355 de 2022 de Capacitaci&#xF3;n y Empleo, www.sence.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10307304}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de enero de 2022.- Ricardo Enrique Ruiz de Vi&#xF1;aspre Rencoret, Director Nacional, Servicio Nacional de Capacitaci&#xF3;n y Empleo.</div><div class=\"p\"> </div><br></div>", "i": 10307305}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "355 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-355 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DEL TRABAJO", "SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO RESOLUCIÓN N° 355 EXENTA, DE 2022", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2080988", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2022-01-19", "fecha_derogacion": "2024-06-12", "doble_articulado": false, "id_norma": "1172257", "numero_fuente": "43169", "tipo_version": "2", "tipo_version_s": "Últim