{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,786.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede a la viuda e hijos del operario Manuel Caro, fallecido el 15 de diciembre de 1911 a consecuencia de una esplosion en el taller de artificios de la F&#xE1;brica i Maestranza del Ej&#xE9;rcito, una pension de seiscientos pesos ($ 600) anuales, de la que disfrutar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6173697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiseis de julio de mil novecientos trece.- Ramon Barros Luco.- Jorje Matte.</div><br></div>", "i": 6173698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2786", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2786"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-07-26", "doble_articulado": false, "id_norma": "137953", "numero_fuente": "10635", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-07-26", "vigencias": [{"desde": "1913-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1913-07-26",