{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6410469}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n que suscribe, certifica que la Universidad de Temuco, inscrita bajo el n&#xFA;mero C-36 del Registro del Ministerio de Educaci&#xF3;n, ha presentado los programas de estudio de la carrera de &quot;Arquitectura&quot; conducente al grado ACAD&#xC9;MICO de &quot;Licenciado en Arquitectura&quot; y al t&#xED;tulo de &quot;Arquitecto&quot;, a la Universidad Cat&#xF3;lica del Norte, como entidad examinadora y revisados por &#xE9;sta han sido aprobados.</div><div class=\"p\">&nbsp; &nbsp;  La carrera mencionada podr&#xE1; impartirse a contar de 1991.</div><br></div>", "i": 6410470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6410471}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "206801", "numero_fuente": "33898", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-19", "vigencias": [{"desde": "1991-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-02-19", "fin_vigencia": "", "tipo_version": "3