{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 18D</div></div>", "i": 9890746}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 664, de 20 de febrero de 2018, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1113473&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xB0; 4.528, de 2017</a>, de esta Subsecretaria, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 18D, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 9890747}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de febrero de 2018.- Pablo Berazaluce Maturana, Subsecretario de Pesca y Acuicultura. </div></div>", "i": 9890748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "664 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-664 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 18D", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1359066", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-02-20", "doble_articulado": false, "id_norma": "1115642", "numero_fuente": "41994", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-02-27", "vigencias": [{"desde": "2018-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "