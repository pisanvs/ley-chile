{"html": [{"t": "<div><div class=\"p\">TRASPASO DE UN ITEM</div><br><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 496. - Santiago, 25 de Agosto de 1932. - El Presidente Provisional de la Rep&#xFA;blica ha acordado y dicta el siguiente</div><br><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br><br></div>", "i": 8256262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.o Trasp&#xE1;sase la suma de veinte mil pesos ($20.000) del &#xED;tem 02/02/04/i-l) al &#xED;tem 04/01/04/v-2).</div><div class=\"p\">&nbsp; &nbsp;  2.o El presente decreto-ley comenzar&#xE1; a regir desde esta fecha.</div><br><br></div>", "i": 8256263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno. - CARLOS DAVILA.-Joaqu&#xED;n Fern&#xE1;ndez F.</div><br></div>", "i": 8256264}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "496", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-496"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "TRASPASO DE UN ITEM", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1932", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-08-25", "doble_articulado": false, "id_norma": "6138", "numero_fuente": "16366", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-09-03", "vigencias": [{"desde": "1932-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-09-03", "fin_vigencia": "", "tipo_version": "3"}], "event