{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6223626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 415, 01 de Julio de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n se autoriza a don Ar&#xED;stides Segundo Ortiz Charpentier, para efectuar servicio p&#xFA;blico de locomoci&#xF3;n colectiva de pasajeros que se indica a continuaci&#xF3;n:</div><br><div class=\"p\">LINEA: &quot;VILLA LAJA POBLACION NIVEQUETEN&quot;</div><br><div class=\"p\">Ida: Terminal en Villa Laja, Avda. Los Rios, Avda. Balmaceda, Bulnes, Rio Polcura, Antuco, Los Magnolios, Los Casta&#xF1;os, Nivequet&#xE9;n, Los Tilos.</div><br><div class=\"p\">Regreso: Circunvalaci&#xF3;n, poblaci&#xF3;n Nivequet&#xE9;n, Bulnes, Avda. Balmaceda, Avda. Los Rios, y Terminal Villa Laja. </div></div>", "i": 6223627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6223628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "415 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-415 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-01", "doble_articulado": false, "id_norma": "152598", "numero_fuente": "32517", "tipo_version": "3", "tipo_version_s": "Única", "fecha_p