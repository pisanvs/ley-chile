{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE SE&#xD1;ALA </div></div>", "i": 8341404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 592, de 15 de Junio de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga la resoluci&#xF3;n No. 111, de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; al Instituto de Fomento Pesquero, domiciliado en Santiago, para desarrollar actividades pesqueras de cultivo, en Contao, Comuna de Hualaihu&#xE9;, Provincia de Palena, X Regi&#xF3;n, por renuncia de su titular.</div><br></div>", "i": 8341405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de Junio de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8341406}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "592", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-592"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-15", "doble_articulado": false, "id_norma": "132272", "numero_fuente": "33101", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-21", "vigencias": [{"desde": "1988-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion