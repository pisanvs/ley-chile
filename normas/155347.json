{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 162, DE 1986 </div></div>", "i": 6231859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 162 de 11 de junio de 1986 se han aprobado para el Liceo Polit&#xE9;cnico A N&#xB0; 1, de Ays&#xE9;n, XI Regi&#xF3;n del General Carlos Ib&#xE1;&#xF1;ez del Campo, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1986 hasta el a&#xF1;o escolar de 1991, en las Especialidades de: Pesquer&#xED;a y Construcci&#xF3;n de Embarcaciones Menores y Mec&#xE1;nica y Mantenci&#xF3;n de Equipos Industriales.</div><br></div>", "i": 6231860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6231861}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "162 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-162 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 162, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-27", "doble_articulado": false, "id_norma": "155347", "numero_fuente": "32509", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-30", "vigencias": [{"desde": "1986-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig