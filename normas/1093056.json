{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9719311}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n Ex. N&#xBA; 77316060742, de fecha 18 de julio de 2016, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=122787&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 256 de fecha 26.06.1998</a>, que otorg&#xF3; la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de venta de ganado vivo, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Fernando L&#xE1;zaro Topali Bruckmoser, RUT N&#xBA; 2.729.657-2, conforme a lo establecido en la <a href=\"https://www.leychile.cl/Navegar?idNorma=173624&amp;idParte=&amp;idVersion=\">Res. Ex. N&#xBA; 3.721 de fecha 28.07.2000</a>, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial del d&#xED;a 01.08.2000.- </div><br><br></div>", "i": 9719312, "v": ["CONCORDANCIA", "MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lidia del Carmen Castillo Alarc&#xF3;n, Director Regional.</div></div>", "i": 9719313}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77316060742 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77316060742 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1047168"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-07-18", "doble_articulado": false, "id_norma": "1093