{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A NEOGEL S.A.</div><br><br></div>", "i": 6151051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Metropolitana Santiago Oriente, del Servicio de Impuestos Internos, por Res. N&#xBA;Ex. 195 de 20 de enero de 1999, certifica que a contar del 1 del mes siguiente al de esta publicaci&#xF3;n y hasta el 30 de junio de 1999, Neogel S.A., Rut. N&#xBA;96.821.230-3, tiene la calidad de agente retenedor del Impuesto al Valor Agregado, por las compras de especies hidrobiol&#xF3;gicas, por cuanto cumple con los requisitos establecidos en la resoluci&#xF3;n N&#xBA;Ex. 3.839, del 26 de junio de 1998.-</div><br></div>", "i": 6151052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Bernardo Seaman Gonz&#xE1;lez, Director Regional. </div></div>", "i": 6151053}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "195 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-195 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO ORIENTE"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A NEOGEL S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-01-20", "doble_articulado": false, "id_norma": "130768", "numero_fuente": "36274", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-27", "vigencias": [{"desde": "1999-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-01-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-01-27", "f