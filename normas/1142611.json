{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xB0; 505 EXENTA, DE 22.01.2020</div></div>", "i": 10102277}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=1061366&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 2.244, de 2014</a>, del Ministerio de Educaci&#xF3;n, que aprob&#xF3; planes y programas especiales de estudio de 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Colegio Alem&#xE1;n de Santiago, RBD 8979-6, comuna de Las Condes, Regi&#xF3;n Metropolitana, y a los establecimientos educacionales que se individualizan en este mismo acto administrativo, en el sentido de sustituir el plan de estudio de 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media.- </div><br></div>", "i": 10102278, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10102279}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "505 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-505 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO RESOLUCIÓN N° 505 EXENTA, DE 22.01.2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1729236", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-22", "doble_articulado": false, "id_norma": "1142611", "numero_fuente": "42585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-02-21", "vigencias": [{"desde": "2020-