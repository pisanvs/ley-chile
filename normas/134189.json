{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 1,126.- Santiago 24 de noviembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6161580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese derecho a do&#xF1;a Rafaela San Martin, hija del teniente-coronel don Juan Jos&#xE9; San Mart&#xED;n, para percibir la pensi&#xF3;n que el art&#xED;culo 18 de la lei de 22 de diciembre de 1881 acuerda a los hijos naturales de los militares muertos en acci&#xF3;n de guerra, la que gozar&#xE1; con arreglo a la lei citada.</div><br></div>", "i": 6161581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ventura Blanco.</div><br></div>", "i": 6161582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1126", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1126"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-11-24", "doble_articulado": false, "id_norma": "134189", "numero_fuente": "6161", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-11-26", "vigencias": [{"desde": "1898-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-11-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-11-26", "fin_vigencia": "", "tipo_version": "3"}], "even