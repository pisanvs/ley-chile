{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 968 EXENTA, DE 2011</div></div>", "i": 9108076}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 968, de 27 de enero de 2011, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la sociedad &quot;Riquelme y Villalobos Servicios de Capacitaci&#xF3;n Limitada&quot; (R &amp; V Capacitaci&#xF3;n Ltda.), RUT 76.010.401-9, contenida en la resoluci&#xF3;n exenta N&#xBA; 3.873, de 28 de mayo de 2008, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del art. 21 de la ley 19.518.</div></div>", "i": 9108077}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  - Jos&#xE9; Miguel Bergu&#xF1;o Ca&#xF1;as, Director Nacional.</div></div>", "i": 9108078}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "968 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-968 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 968 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-27", "doble_articulado": false, "id_norma": "1022819", "numero_fuente": "39879", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-07", "vigencias": [{"desde": "2011-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-02-07", "fin_vige