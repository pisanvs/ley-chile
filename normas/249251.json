{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6568662}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 134, de 30 de marzo de 2006, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 18, correspondiente a parte del inmueble ubicado en Avenida Larra&#xED;n N&#xBA; 7135, Rol de Aval&#xFA;o N&#xBA; 4700-7, comuna de La Reina, aparente dominio de do&#xF1;a Olga Ortiz Blanc y otros. Comisi&#xF3;n integrada por peritos se&#xF1;ores Juan Alfredo D&#xED;az Velasco, arquitecto; Miguel Ortiz Bobadilla, constructor civil; y Jaime Jurgens Bittner, ingeniero civil. Seg&#xFA;n informe de 6 de enero de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $55.093.000, pagadera al contado.</div><br></div>", "i": 6568663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6568664}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "134", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-134"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-30", "doble_articulado": false, "id_norma": "249251", "numero_fuente": "38452", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-02", "vigencias": [{"desde": "2006-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única