{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A&nbsp; SOC. HARAS DON ALBERTO LIMITADA</div><br><br><br></div>", "i": 6136823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex-0590, de fecha 6 de julio de 1998, otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n a Soc. Haras don Alberto Limitada, Rut.</div><div class=\"p\">N&#xBA; 78.652.530-6, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las operaciones de ganado vivo, establecido en la Resoluci&#xF3;n N&#xBA; Ex 2.379/98, de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 24-04-98, modificada y complementada por resoluci&#xF3;n N&#xBA; Ex. 3.785/98, publicada en el Diario Oficial del d&#xED;a 30-06-98.</div><br></div>", "i": 6136824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 6136825}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "590 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-590 EXENTA"}, {"tipo": "3", "numero": "DRE-08-0590 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-0590 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOC. HARAS\nDON ALBERTO LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "SOC. HARAS DON ALBERTO LIMITADA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgaci