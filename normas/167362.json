{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6270991}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 791, de 29 de febrero de 2000, se expropiaron los lotes de terreno N&#xBA;s. 9, 19, 23 y 45, roles de aval&#xFA;o 62-43, 59-51, 60-44 y 59-31, comuna de Ch&#xE9;pica, VI Regi&#xF3;n, para la obra Camino Ch&#xE9;pica-Bif. Teno, Sector Cuesta El Peral-Ch&#xE9;pica y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Juan Navarro Sep&#xFA;lveda, Isabel Fuentes Morales e Inelia Gonz&#xE1;lez Marchant y otros, ascendente a las cantidades que se indican en dicho decreto.</div><br></div>", "i": 6270992}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6270993}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "791", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-791"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-29", "doble_articulado": false, "id_norma": "167362", "numero_fuente": "36652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-02", "vigencias": [{"desde": "2000-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "2000-05-02", "fecha_version": "2000-05-02", "fecha_actualizacion_texto": "2000-05-02", "ti