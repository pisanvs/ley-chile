{"html": [{"t": "<div><div class=\"p\">FIJA NUEVO HORARIO DE ATENCION EN JUNTAS INSCRIPTORAS </div><br></div>", "i": 6342808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n O-N&#xBA; 389 de fecha 11 de julio de 2001, se ha dispuesto que las Juntas Inscriptoras de todo el pa&#xED;s funcionen a contar del d&#xED;a mi&#xE9;rcoles 01 de agosto y hasta el s&#xE1;bado 17 de agosto de 2001,<span class=\"n\" id=\"n_0\">RES S/N,<br>SERV. ELECTORAL<br>D.O. 30.07.2001</span> cierre del per&#xED;odo extraordinario de inscripciones electorales, en horario de 9:00 a 14:00 horas. Sin embargo, si al t&#xE9;rmino del horario de funcionamiento se encontraren a&#xFA;n presentes personas que requieran su inscripci&#xF3;n, se extender&#xE1; el funcionamiento pero no m&#xE1;s all&#xE1; de las 20:00 horas, salvo el d&#xED;a s&#xE1;bado en que no exceder&#xE1; de las 14:00 horas. </div></div>", "i": 6342809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de julio de 2001.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6342810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "389", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-389"}, {"tipo": "3", "numero": "O-389", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-389"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "FIJA NUEVO HORARIO DE ATENCION EN JUNTAS INSCRIPTORAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUNTAS INSCRIPTORAS", "HORARIO DE ATENCION", "FUNCIONAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-11", "doble_articulado": false, "id_norma": "187641", "numero_fuente": "37012", "tipo_version": "2", "tipo_versi