{"html": [{"t": "<div><div class=\"p\">CERTIFICADO</div><br><br></div>", "i": 6349450}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que por resoluci&#xF3;n N&#xBA; E-173-2001, de fecha 28 de agosto de 2001, se cancel&#xF3; la autorizaci&#xF3;n de existencia de la sociedad &quot;Habitat Servicios Internacionales S.A.&quot;, filial de Administradora de Fondos de Pensiones Habitat S.A., por haber concurrido a su respecto, la causal de disoluci&#xF3;n establecida en el n&#xFA;mero 2) del art&#xED;culo 103, de la ley N&#xBA; 18.046, sobre Sociedades An&#xF3;nimas, esto es, haberse reunido todas las acciones en manos de una sola persona.</div><br></div>", "i": 6349451}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de agosto de 2001.- Alejandro Ferreiro Yazigi, Superintendente de A.F.P.</div><br></div>", "i": 6349452}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "173", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-173"}, {"tipo": "3", "numero": "E-173-2001", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-E-173-2001"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARIA DE PREVISION SOCIAL", "SUPERINTENDENCIA DE ADMINISTRADORAS DE FONDOS DE PENSIONES"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-08-28", "doble_articulado": false, "id_norma": "189401", "numero_fuente": "37065", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-09-20", "vigencias": [{"desde": "2001-09-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-09-20", "fin