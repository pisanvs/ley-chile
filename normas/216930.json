{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6447248}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.448, de 10 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PRODUCTOS DEL MAR TENGLOFISH LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Pen&#xED;nsula Caullahuapi, Sector Panitao, Chinquihue, Puerto Montt, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Fresco-enfriado, Fresco-refrigerado y Congelado: Salm&#xF3;n del Atl&#xE1;ntico, Trucha arcoiris, Salm&#xF3;n plateado, Merluza del sur o austral, Congrio dorado y Pejerrey de mar.</div><br></div>", "i": 6447249}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6447250}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2448 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2448 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-10-10", "fecha_derogacion": "2010-02-19", "doble_articulado": false, "id_norma": "216930", "numero_fuente": "37704", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-11-07", "vigencias": [{"desde": "2010-02-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-11-07", "hasta": "2010-02-18", "tipo_version": "0", "tipo_version_s": "Texto Origi