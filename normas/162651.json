{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6255981}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xB0; 870 de 15 de Julio de 1985, conforme Art. 5&#xB0;, transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden al sector expropiado predios &quot;Hijuela Primera de la Subdivisi&#xF3;n del Fundo Chicauma&quot;, &quot;Hijuela Segunda del Fundo Chicauma&quot; de la comuna de Lampa, Regi&#xF3;n Metropolitana, y derechos aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s. 1 a la 20 del proyecto de parcelaci&#xF3;n &quot;Chicauma&quot; formado, por predios se&#xF1;alados.</div><div class=\"p\">&nbsp; &nbsp;  Los derechos de agua se extraen del Estero Lampa y de tres Pozos Profundos.- Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377.</div><br></div>", "i": 6255982}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6255983}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "870 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-870 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-15", "doble_articulado": false, "id_norma": "162651", "numero_fuente": "32237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-01", "vigencias": [{"desde": "1985-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08-01", "fin_vi