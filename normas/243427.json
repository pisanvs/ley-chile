{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6546264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 959 de fecha 29 de septiembre del 2005, se expropi&#xF3; el lote de terreno N&#xBA;2, superficie 626 m2, rol N&#xBA; 602-40, comuna de San Ignacio, VIII Regi&#xF3;n para la obra &quot;Proyecto Laja Diguill&#xED;n, Camino de acceso a Canal Matriz Diguill&#xED;n Larqui Km.</div><div class=\"p\">5,951&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Eugenia del Carmen Pedraza Herrera y Otra, ascendente a la cantidad de $1.461.718.- para el lote N&#xBA;2.</div><br></div>", "i": 6546265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6546266}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "959 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-959 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-29", "doble_articulado": false, "id_norma": "243427", "numero_fuente": "38301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-02", "vigencias": [{"desde": "2005-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2005-11-02", "fecha_version": "2005-11-02", "fecha_actualizacion_text