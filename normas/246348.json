{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6557490}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.374, de 20 de diciembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD DE INVERSIONES ALIZE CHILE LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, autorizada por la resoluci&#xF3;n citada en Visto, en orden a incorporar a su planta ubicada en ruta N&#xBA; 226, Km. 13,7, camino a Las Quemas, Puerto Montt, X Regi&#xF3;n, en las l&#xED;neas de procesos de Congelado y Fresco-Enfriado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6557491}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6557492}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4374 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4374 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-20", "doble_articulado": false, "id_norma": "246348", "numero_fuente": "38363", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-14", "vigencias": [{"desde": "2006-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-01-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ing