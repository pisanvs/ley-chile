{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que concede 30 000 pesos para combatir la epidemia de viruelas</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1647.- Valpara&#xED;so, a 12 de Febrero de 1904.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br></div>", "i": 8274546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de treinta mil pesos en atender a los gastos que ocasione la epidemia de viruelas.</div><br></div>", "i": 8274547}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Rafael Err&#xE1;zuriz Urmeneta.</div><br></div>", "i": 8274548}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1647", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1647"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Que concede 30 000 pesos para combatir la epidemia;de viruelas", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VIRUELA", "EPIDEMIA", "PREVENCION", "FONDOS", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-02-12", "doble_articulado": false, "id_norma": "22816", "numero_fuente": "7828", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-02-12", "vigencias": [{"desde": "1904-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-0