{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 635 EXENTO, DE 1995 </div><br></div>", "i": 7162155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto supremo exento de Educaci&#xF3;n N&#xB0; 635 de 20 de noviembre de 1995, se ha aprobado, a contar del presente a&#xF1;o escolar, un plan especial de estudio para educaci&#xF3;n media t&#xE9;cnico-profesional de adultos, en las especialidades de Contabilidad, Secretariado Ejecutivo y Ventas.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas para las asignaturas que se indican en el presente decreto.</div><br></div>", "i": 7162156}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de Noviembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162157}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "635 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-635 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 635 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EDUCACION DE ADULTOS", "PLANES ESTUDIO", "EDUCACION TECNICO PROFESIONAL", "CONTABILIDAD", "SECRETARIADO EJECUTIVO", "VENTAS", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-20", "doble_articulado": false, "id_norma": "21605", "numero_fuente": "35334", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-05", "vigencias": [{"desde": "1995-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-05", "fin_vigen