{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA CALLE HOSPITAL DE LA COMUNA DE SAN VICENTE</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5971309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La calle &quot;Hospital&quot; de la comuna de San Vicente se denominar&#xE1;, en lo sucesivo, &quot;Doctor Exequiel Gonz&#xE1;lez Cort&#xE9;s&quot;.</div><br></div>", "i": 5971310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, ocho de Octubre de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Roberto Mu&#xF1;oz Urrutia.</div><br></div>", "i": 5971311}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12185", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12185"}], "organismos": ["MINISTERIO DE SALUD PÚBLICA Y PREVISIÓN SOCIAL"], "titulo_norma": "CAMBIA NOMBRE A LA CALLE HOSPITAL DE LA COMUNA DE\nSAN VICENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Comuna de San Vicente", "Calle Hospital", "Camio de Nombre", "Dr. Exequiel González Cortés"], "terminos_libres": ["CAMBIO NOMBRE", "CALLE DOCTOR EXEQUIEL GONZALEZ CORTES", "SAN VICENTE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-10-08", "doble_articulado": false, "id_norma": "27063", "numero_fuente": "23577", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-10-19", "vigencias": [{"desde": "1956-10-19", "hasta": "", "tipo_version": "3", "