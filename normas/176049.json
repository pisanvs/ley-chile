{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6302446}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.075, de 15 de septiembre de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA;1.006 de 1993, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA PUNTA ARENAS S.A., para operar la nave &quot;Arbumasa XIV&quot;, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;1.998 de 1996, en virtud de lo dispuesto en la resoluci&#xF3;n N&#xBA;128 de 1999, ambas de esta Subsecretar&#xED;a.</div><br></div>", "i": 6302447}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de septiembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6302448}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2075", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2075"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-15", "doble_articulado": false, "id_norma": "176049", "numero_fuente": "36771", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-25", "vigencias": [{"desde": "2000-09-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-25", "fin_vigencia": "", "tipo_version":