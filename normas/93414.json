{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 194, DE 1988 </div></div>", "i": 6094218}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 194, de 15 de diciembre de 1988, se ha aprobado a la Escuela Especial F N&#xB0; 207 de Chill&#xE1;n, VIII Regi&#xF3;n del B&#xED;o-Bio, un plan de estudio especial de orientaci&#xF3;n laboral que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de cuatro a&#xF1;os a contar desde el a&#xF1;o escolar 1989.</div><br></div>", "i": 6094219}, {"t": "<div><div class=\"p\">Santiago, 03 de Enero de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6094220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "194 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-194 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 194, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-15", "doble_articulado": false, "id_norma": "93414", "numero_fuente": "33273", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-01-16", "vigencias": [{"desde": "1989-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-01-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-03-04", "fecha_version": "1989-01-16", "fecha_actualizacion_texto": "1989-01-16", "tipo_trata