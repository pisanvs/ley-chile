{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ESTABLECE QUE EL LICEO COEDUCACIONAL DE QUIRIHUE SE DENOMINARA EN LA FORMA QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 5976434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. El Liceo Coeducacional de Quirihue, se denominar&#xE1; en lo sucesivo &quot;Liceo Coeducacional Carlos Montan&#xE9; Castro&quot;.&quot;.</div><br></div>", "i": 5976435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, ventinueve de agosto de mil novecientos sesenta y cuatro.- JORGE ALESSANDRI RODRIGUEZ.- Alejandro Garret&#xF3;n.</div><br></div>", "i": 5976436}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15678", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15678"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "ESTABLECE QUE EL LICEO COEDUCACIONAL DE QUIRIHUE SE\nDENOMINARA EN LA FORMA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "LICEO COEDUCACIONAL CARLOS MONTANE CASTRO", "QUIRIHUE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1964-08-29", "doble_articulado": false, "id_norma": "28254", "numero_fuente": "25936", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1964-09-09", "vigencias": [{"desde": "1964-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1964-09-0