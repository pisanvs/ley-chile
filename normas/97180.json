{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.218 EXENTO, DE 1997 </div></div>", "i": 7231719}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.218, de fecha 26 de diciembre de 1997, del Ministerio de Educaci&#xF3;n, se reemplazaron a contar del a&#xF1;o 1998 las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto AIEP, que fueran aprobadas por decreto exento de Educaci&#xF3;n N&#xBA; 576 de fecha 9 de octubre de 1996.</div><br></div>", "i": 7231720}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de enero de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7231721}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1218 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1218 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.218 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA INSTITUTO AIEP", "EVALUACION", "PROMOCION", "TITULACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-26", "doble_articulado": false, "id_norma": "97180", "numero_fuente": "36014", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-13", "vigencias": [{"desde": "1998-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-03-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-03-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modifi