{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES </div></div>", "i": 6467753}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Ilustre Municipalidad de Curaco de V&#xE9;lez pone en conocimiento de la comunidad que por decreto alcaldicio N&#xBA; 1.038, de fecha 31 de diciembre de 2003, fue aprobada la Ordenanza que norma sobre el procedimiento a observar para el otorgamiento de las subvenciones municipales.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada Ordenanza est&#xE1; a disposici&#xF3;n de quien lo solicite en la Secretar&#xED;a Municipal, cuya oficina se ubica en Gabriela Mistral N&#xBA; 10, Curaco de V&#xE9;lez.</div><br></div>", "i": 6467754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Curaco de V&#xE9;lez, 19 de febrero de 2004.- Luis Curumilla Sotomayor, Alcalde.</div><br></div>", "i": 6467755}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1038", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1038"}], "organismos": ["MUNICIPALIDAD DE CURACO DE VELEZ"], "titulo_norma": "APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-31", "doble_articulado": false, "id_norma": "222080", "numero_fuente": "37804", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-06", "vigencias": [{"desde": "2004-03-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], 