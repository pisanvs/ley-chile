{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7291560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n n&#xFA;mero 781, de 22 de abril de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SAN JOSE S.A. para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 14 de 1989, N&#xBA; 239, N&#xBA; 330, N&#xBA; 1.076, N&#xBA; 1.352, todas de 1992, N&#xBA; 1.343 de 1996, N&#xBA; 1.913 de 1998 y N&#xBA; 2.498 de 2000, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Avenida Pedro Montt N&#xBA; 405, San Vicente, Talcahuano, VIII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Harina y Aceite, los siguientes recursos hidrobiol&#xF3;gicos: Bacaladillo o mote, Jurel fino, Machuelo o tritre, Anchoveta blanca, Sardina redonda y Vinciguerria.</div><br></div>", "i": 7291561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7291562}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "781", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-781"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-22", "doble_articulado": false, "id_norma": "197812", "numero_fuente": "37253", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-08", "vigencias": [{"desde": "2002-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "200