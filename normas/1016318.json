{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8966067}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n (E) N&#xB0; 1.654, del 11 de agosto de 2010, del Gobierno Regional del Maule, se invalid&#xF3; el concurso para proveer el cargo de tercer nivel jer&#xE1;rquico, jefe de departamento grado 5&#xB0; EUS del Servicio Administrativo del Gobierno Regional del Maule, convocado mediante Resoluci&#xF3;n (E) N&#xB0; 3.486, del 16 de noviembre de 2009, en raz&#xF3;n de que el aviso publicado en el Diario Oficial del 15 de dicembre de 2009 no cumpli&#xF3; la normativa vigente en relaci&#xF3;n al plazo que debe mediar legalmente entre dicha publicaci&#xF3;n y la fecha de cierre para recepcionar los antecedentes de los postulantes. </div></div>", "i": 8966068}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese. </div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; RODRIGO GALILEA VIAL</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; Intendente Regi&#xF3;n del Maule</div></div>", "i": 8966069}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1654 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1654 EXENTA"}], "organismos": ["GOBIERNO REGIONAL VII REGIÓN DEL MAULE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-08-11", "doble_articulado": false, "id_norma": "1016318", "numero_fuente": "39737", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-08-16", "vigencias": [{"desde": "2010-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2