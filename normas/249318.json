{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  EXTRACTO</div><br></div>", "i": 6568847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 223, de 14 de marzo de 2006, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n de Los Lagos, se declar&#xF3; extinguida la pr&#xF3;rroga del contrato de concesi&#xF3;n, de la Planta de Revisi&#xF3;n T&#xE9;cnica Clase AB 1009, que practica revisi&#xF3;n t&#xE9;cnica de veh&#xED;culos Clase AB, en la comuna de Ancud, dispuesta y aprobada mediante la resoluci&#xF3;n N&#xBA; 146, de 2 de diciembre de 1998, del mismo origen, estableci&#xE9;ndose el 22 de marzo de 2006 como fecha de cierre.</div><br></div>", "i": 6568848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Iv&#xE1;n Leonhardt C&#xE1;rdenas, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n de Los Lagos.</div><br></div>", "i": 6568849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "223 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-223 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-14", "doble_articulado": false, "id_norma": "249318", "numero_fuente": "38453", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-03", "vigencias": [{"desde": "2006-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v