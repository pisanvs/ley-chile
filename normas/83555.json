{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8315265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.687, de 12 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xBA; 341 de 1995 de esta Subsecretar&#xED;a, que autoriz&#xF3; a EMPRESA PESQUERA ZONA CENTRAL S.A., hoy Pesquera Tarapac&#xE1; S.A., para ampliar las actividades pesqueras extractivas con la nave &quot;Zonace I&quot;, por haber paralizado actividades pesqueras extractivas por m&#xE1;s de 12 meses sucesivos, a partir del mes de julio de 1996, configur&#xE1;ndose la causal prevista en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8315266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8315267}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1687", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1687"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "EMPRESA PESQUERA ZONA CENTRAL S.A.", "PESQUERA TARAPACA S.A.", "AMPLIACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-12", "doble_articulado": false, "id_norma": "83555", "numero_fuente": "35944", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-19", "vigencias": [{"desde": "1997-12-19", "hasta": "", "tipo_version": "3", "tipo_