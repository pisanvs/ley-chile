{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6432573}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.575 de 9 de julio de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a la SOCIEDAD PESQUERA LANGEVELD LIMITADA, para realizar actividades extractivas en aguas internacionales, con la nave &quot;Islas Orcas&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes: Matr&#xED;cula: 1868-Valpara&#xED;so; Se&#xF1;al distintiva: CB-3387; Eslora arqueo: 21,95 m.; Manga:</div><div class=\"p\">6,63 m.; T.R.G. (nacional): 84,09; Capacidad de bodega: 138,18 m3; Potencia principal: 425,00 Hp.; Potencia auxiliar: 15,00 Hp.; Arte de pesca: cerco, arrastre de media agua, espinel, l&#xED;nea de mano, trampas, enmalle. </div></div>", "i": 6432574}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de julio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6432575}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1575", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1575"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-09", "doble_articulado": false, "id_norma": "212730", "numero_fuente": "37614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-21", "vigencias": [{"desde": "2003-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-21