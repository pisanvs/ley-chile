{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 318, DE 1986 </div></div>", "i": 7253135}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 318 de 11 de diciembre de 1986 se ha aprobado al Colegio Craighouse, de Santiago, un plan de estudio especial que se aplicar&#xE1; desde 1987, de 7&#xB0; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica a 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica, y a partir de 1988 en 3&#xB0; y 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media, inclusive.</div><br></div>", "i": 7253136}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de Abril de, 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7253137}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "318 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-318 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 318, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-11", "doble_articulado": false, "id_norma": "142586", "numero_fuente": "32758", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-29", "vigencias": [{"desde": "1987-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingr