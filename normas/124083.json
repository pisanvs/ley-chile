{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8334363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.244, de 25 de agosto de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA QUINTERO S.A., para ampliar actividades pesqueras autorizadas por resoluciones N&#xBA; 128, de 1983, N&#xBA; 132, de 1986, N&#xBA; 431, de 1987 y N&#xBA; 636, de 1991, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Avenida 21 de Mayo N&#xBA; 1057, Quintero, V Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n de Congelado el recurso Gamba.</div><br></div>", "i": 8334364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8334365}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1244", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1244"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA QUINTERO S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-25", "doble_articulado": false, "id_norma": "124083", "numero_fuente": "36162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-10", "vigencias": [{"desde": "1998-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-09-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFIC