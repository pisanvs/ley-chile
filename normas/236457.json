{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7318966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 649 exenta, de 8 de marzo de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a BRACPESCA S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Punta Talca&quot;, en el &#xE1;rea mar&#xED;tima que se indica, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar el recurso hidrobiol&#xF3;gico que a continuaci&#xF3;n se se&#xF1;ala: a) En el &#xE1;rea mar&#xED;tima comprendida entre la I y XII Regiones, con potera: Jibia.</div><br></div>", "i": 7318967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 08 de marzo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7318968}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "649 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-649 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-03-08", "fecha_derogacion": "2005-07-29", "doble_articulado": false, "id_norma": "236457", "numero_fuente": "38115", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-03-19", "vigencias": [{"desde": "2005-07-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-03-19", "hasta": "2005-07-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2005-07-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "200