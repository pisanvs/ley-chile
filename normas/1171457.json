{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 25A</div></div>", "i": 10302399}, {"t": "<div><br><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 45, de 12 de enero de 2022, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1161997&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1852</a>, modificada por las N&#xB0; 2.497 y N&#xB0; 3.166, todas de 2021, y de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 25A, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que se indica en la resoluci&#xF3;n extractada.&nbsp; &nbsp; </div></div>", "i": 10302400}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de enero de 2022.-&nbsp; Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10302401}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "45 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-45 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 25A", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2072295", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-12", "doble_articulado": false, "id_norma": "1171457", "numero_fuente": "43154", "tipo_version": "3", "tipo_version_s": "Única", "fec