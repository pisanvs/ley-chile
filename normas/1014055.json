{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8926410}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP N&#xBA; 616 de fecha 30 de abril del 2010, se expropi&#xF3; el lote de terreno N&#xBA; 2, superficie 3.286,8 m2, Rol N&#xBA;323-41, comuna de Rio Negro, X Regi&#xF3;n de Los Lagos para la obra &quot;Reposici&#xF3;n Puente Chapaco&quot;, Camino R&#xED;o Negro Riachuelo, Rol U-588&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria SOCIEDAD AGRICOLA TRES ESTEROS LIMITADA, ascendente a la cantidad de $2.984.246.- para el lote N&#xBA;2. </div><br></div>", "i": 8926411}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 8926412}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "616 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-616 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-04-30", "doble_articulado": false, "id_norma": "1014055", "numero_fuente": "39674", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-01", "vigencias": [{"desde": "2010-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ingreso": "2010-06-01", "fecha_version": "2010-06-01", "actualizado_por": "2932", "fecha_actu