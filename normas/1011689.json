{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 8892268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La XIII Direcci&#xF3;n Regional Metropolitana Santiago Centro del Servicio de Impuestos Internos, por resoluci&#xF3;n Ex. N&#xBA; 1044/69, de 3 de marzo de 2010, otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n en el Diario Oficial, y duraci&#xF3;n indefinida, a RUT N&#xBA; 76.045.738-8 la calidad de Agente Retenedor del Impuesto al Valor Agregado en las Ventas de Chatarra, de acuerdo a lo establecido en la resoluci&#xF3;n N&#xBA; 7, de fecha 28.01.2003, y publicada en el Diario Oficial el 03.02.2003.- </div></div>", "i": 8892269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  V&#xED;ctor Villa Lezana, Director Regional (S).</div></div>", "i": 8892270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1044 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1044 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "XIII DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO CENTRO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-03-03", "doble_articulado": false, "id_norma": "1011689", "numero_fuente": "39610", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-13", "vigencias": [{"desde": "2010-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-03-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-03-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie