{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306046}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.153, de 8 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por cuatro meses, a contar del 30 de abril de 1997, el plazo otorgado a PESQUERA EL GOLFO S.A., para continuar las actividades pesqueras con la nave &quot;Ballestas&quot;, autorizada por Resoluci&#xF3;n N&#xBA; 72, de 1997, de esta Subsecretar&#xED;a, por haberse acreditado la existencia de una fuerza mayor. </div></div>", "i": 8306047}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306048}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1153", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1153"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA EL GOLFO S.A.", "PESCA", "PLAZO", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-08-08", "fecha_derogacion": "1997-08-28", "doble_articulado": false, "id_norma": "75367", "numero_fuente": "35852", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-08-27", "vigencias": [{"desde": "1997-08-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-08-27", "hasta": "1997-08-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1997-08-28", "fin_vigencia": ""}, "vigencias_