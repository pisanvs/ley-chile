{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6564125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 1.285, de 30 de noviembre de 2005, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xB0;, 5&#xB0; y 6&#xB0; del decreto MOP exento N&#xBA; 1.525, de 28 de noviembre de 2003, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xB0; 113, fijada por la Comisi&#xF3;n de Peritos, con fecha 15 de enero de 2002, ascendente a la cantidad de $17.700.-</div><br></div>", "i": 6564126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6564127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1285 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1285 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-30", "doble_articulado": false, "id_norma": "248057", "numero_fuente": "38414", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-15", "vigencias": [{"desde": "2006-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_pa