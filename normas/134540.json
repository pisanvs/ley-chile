{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,179.- Santiago, 27 de enero de 1899.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 8343275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Aum&#xE9;ntase a cincuenta pesos mensuales la pension de que disfruta do&#xF1;a Felicia Toledo v. de Castro, en conformidad a lo dispuesto en la lei de 30 de agosto de 1850.</div><br></div>", "i": 8343276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8343277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1179", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1179"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-27", "doble_articulado": false, "id_norma": "134540", "numero_fuente": "6212", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-27", "vigencias": [{"desde": "1899-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-01-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-01-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-08", "fecha_version": "1899-01-27", "fecha_actualizacion_texto": "189