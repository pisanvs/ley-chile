{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; RECTIFICA DECRETO N&#xB0; 183 EXENTO, DE 1994 N&#xFA;m. 551 exenta.- Santiago, 19 de Diciembre de 1994.- Visto: Lo dispuesto en la letra i) del art&#xED;culo 1&#xB0; del Decreto Ley N&#xB0; 1.028, de 1975, y en la Resoluci&#xF3;n N&#xB0; 55, de 1992, de la Contralor&#xED;a General de la Rep&#xFA;blica, dicto la siguiente,</div><div class=\"p\">&nbsp; &nbsp; Resoluci&#xF3;n:</div><br></div>", "i": 7201607}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Rectif&#xED;case el Decreto de Hacienda Exento N&#xB0; 183, de 1994, publicado en Diario Oficial con fecha 19 de Diciembre de 1994, en el sentido que en el Visto de dicho Decreto debe decir &quot;Oficio Reservado N&#xB0; 1021&quot; y no &quot;Oficio Reservado N&#xB0; 1201&quot;, como se expres&#xF3;. </div></div>", "i": 7201608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Manuel Marf&#xE1;n Lewis, Subsecretario de Hacienda</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud., Manuel Marf&#xE1;n Lewis, Subsecretario de Hacienda.</div><br></div>", "i": 7201609}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "551 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-551 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "RECTIFICA DECRETO N° 183 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO RECTIFICATORIO", "DERECHO ANTIDUMPING", "IMPORTACION", "HARINA TRIGO", "ARGENTINA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-19", "doble_articulado": false, "id_norma": "39106", "numero_fuente": "35047", "tipo_version": "3", "tipo_v