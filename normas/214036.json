{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. No. 261, de 15 de Octubre de 1991, se expropi&#xF3; los lotes de terreno N&#xBA;s. 18, 34-B y 35, superficies 5.395 m2., 396 m2. y 308 m2., Roles de Aval&#xFA;o 565-1, 595-12 y 595-010, respectivamente, Comuna de Copiap6, para la obra Ruta 31-CH, sector Copiap&#xF3; Paipote, Tramo Doble Calzada y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios don Manfredo Pellegrini V., Albina Rojas Abarcia y Juana R. Rojas Olivares. ascendente a las cantidades de $ 40.024.076 para el Lote 18, $ 6.523.631 para el Lote 34-B. y $ 5.863.508 para el Lote 35, respectivamente.</div><br></div>", "i": 6437209}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6437210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "261", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-261"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-15", "doble_articulado": false, "id_norma": "214036", "numero_fuente": "34117", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-15", "vigencias": [{"desde": "1991-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "