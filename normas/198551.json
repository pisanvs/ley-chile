{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 347 EXENTO, DE 2002 </div></div>", "i": 6382910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;347 de fecha 29 de abril de 2002 se declara aprobada al Instituto Profesional Carlos Casanueva la carrera y t&#xED;tulo profesional que se indica:</div><br><div class=\"p\">Carrera: Asistente de Educador de P&#xE1;rvulos con especializaci&#xF3;n en Montessori.</div><br><div class=\"p\">T&#xED;tulo: T&#xE9;cnico de Nivel Superior de Asistente de Educador de P&#xE1;rvulos con especializaci&#xF3;n en Montessori.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera podr&#xE1; ser impartida en jornada diurna en su sede de la ciudad de Santiago, a contar del primer semestre del a&#xF1;o 2002, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6382911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de mayo de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6382912}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "347 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-347 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 347 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-04-29", "fecha_derogacion": "2021-12-31", "doble_articulado": false, "id_norma": "198551", "numero_fuente": "37269", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-05-29", "vigencias": [{"desde": "2021-12-31", "hasta": "", "tipo_version": "2",