{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6504393}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.001, de esta Subsecretar&#xED;a, autor&#xED;zase a la ASOCIACION GREMIAL DE PESCADORES ARTESANALES Y GREMIOS AFINES X REGION, para ampliar las actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en Caica&#xE9;n s/n, kil&#xF3;metro 2,5, Calbuco, X Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Fresco Enfriado, Fresco Refrigerado, Congelado y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6504394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de octubre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6504395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3001 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3001 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-20", "doble_articulado": false, "id_norma": "232326", "numero_fuente": "38008", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-11", "vigencias": [{"desde": "2004-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-11-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-11-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "