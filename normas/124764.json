{"html": [{"t": "<div><div class=\"p\">DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE SAN FERNANDO </div></div>", "i": 6131653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1.683 de 06 de Octubre de 1988, conforme Art.</div><div class=\"p\">5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas No. s. 1 a la 17 y sitios No. s. 1 al 13 del Proyecto de Parcelaci&#xF3;n &quot;Bellavista&quot; de la comuna de San Fernando, Sexta Regi&#xF3;n, formado por predio Bellavista. Los derechos de agua se extraen de los canales Vicentino y Lo Maturana, derivados del r&#xED;o Tinguiririca.Publicaci&#xF3;n hecha conforme Art. 13 Ley No.</div><div class=\"p\">18.377.</div><br></div>", "i": 6131654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6131655}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1683 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1683 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE APROVECHAMIENTO DE AGUAS EN COMUNA DE SAN FERNANDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-10-06", "doble_articulado": false, "id_norma": "124764", "numero_fuente": "33196", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-10-15", "vigencias": [{"desde": "1988-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v