{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 909 EXENTA, DE 22.05.2012</div></div>", "i": 9261828}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  F&#xED;jense las siguientes agrupaciones de comunas con m&#xE1;s de 5.000 habitantes urbanos, en la Regi&#xF3;n Metropolitana, para la aplicaci&#xF3;n del subsidio diferenciado a la localizaci&#xF3;n para los proyectos habitacionales postulados al programa &quot;Fondo Solidario de Elecci&#xF3;n de Vivienda&quot; durante el a&#xF1;o 2012, de acuerdo a lo establecido en el &#xFA;ltimo inciso del art&#xED;culo 5&#xBA; del DS N&#xBA; 49 (V. y U.), de 2011.</div><br><div class=\"p\"> <span class=\"n\" id=\"n_0\"><a href=\"navegar?idNorma=1040814&amp;idParte=9263760&amp;idVersion=2012-06-07\">Resoluci&#xF3;n 1013 EXENTA,<br>VIVIENDA<br>D.O. 07.06.2012</a></span>&nbsp; &nbsp; <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/26475.jpg\"></div><br><br></div>", "i": 9261829, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Marisol Rojas Schwemmer, Secretaria Ministerial Metropolitana de Vivienda y Urbanismo.</div></div>", "i": 9261830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "909 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-909 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 909 EXENTA, DE 22.05.2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-22", "doble_articulado": false, "id_norma": "1040483", "numero_fuent