{"html": [{"t": "<div><br><div class=\"p\">OTRO</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 10 de 1825</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto:</div></div>", "i": 10191839}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La Caja nacional de descuentos encargada de la administracion de bienes de Regulares, pagar&#xE1; de estos fondos la cantidad de cuatrocientos pesos anuales R. P. Fr. Justo Oro durante el tiempo que permaneciese fuera del territorio de la Rep&#xFA;blica en virtud de lo dispuesto por decreto de 8 del pr&#xF3;ximo pasado octubre. Esta asignacion se satisfar&#xE1; por mesadas, que empezar&#xE1;n a correr desde el 1.&#xB0; del presente noviembre. Refr&#xE9;ndese por el Ministerio de Hacienda, t&#xF3;mese razon, comun&#xED;quese.</div></div>", "i": 10191840}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Campino.</div></div>", "i": 10191841}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE INTERIOR"], "titulo_norma": "OTRO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-11-10", "doble_articulado": false, "id_norma": "1151790", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-11-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-11-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": 