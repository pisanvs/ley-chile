{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A ACU&#xD1;A E HIJOS S.A.</div></div>", "i": 9323511}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del S.I.I., por resoluci&#xF3;n Ex. N&#xBA; 6.165 de fecha 03.12.2012, otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en los contratos de instalaci&#xF3;n o confecci&#xF3;n de especialidades, a la Sociedad Acu&#xF1;a e Hijos S.A., RUT N&#xB0; 76.871.900-4. Dicho acto de autoridad regir&#xE1; a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido en la resoluci&#xF3;n exenta SII N&#xB0; 142 del 26.12.2005, de la Direcci&#xF3;n Nacional.</div></div>", "i": 9323512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Aguirre P&#xE9;rez, Director Regional.</div></div>", "i": 9323513}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6165 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6165 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A ACUÑA E HIJOS S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-03", "doble_articulado": false, "id_norma": "1047541", "numero_fuente": "40446", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-12-29", "vigencias": [{"desde": "2012-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen