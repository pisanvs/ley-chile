{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9204834}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;3255, de 18 de octubre de 2011, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1014573&amp;idParte=0&amp;idVersion=\">Decreto Exento MOP. N&#xBA;735, de 31 de mayo de 2010</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xBA;60-E, expropiado con motivo de la obra &quot;Mejoramiento Ruta D-37, Sector Limahuida - Canelillo&quot;. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n, fijado el 02 de mayo de 2009, por la Comisi&#xF3;n de Peritos Tasadores en la suma de $150.890.</div></div>", "i": 9204835}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9204836}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3255 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3255 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-18", "doble_articulado": false, "id_norma": "1032691", "numero_fuente": "40110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-15", "vigencias": [{"desde": "2011-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-11-15", "fin_vigencia