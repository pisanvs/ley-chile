{"html": [{"t": "<div><div class=\"p\">DESIGNA INTEGRANTE DE COMISION&nbsp; RESOLUTIVA A PERSONA QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 136 exento.- Santiago, 6 de mayo de 1998.- Vistos: Lo dispuesto en la letra c) del art&#xED;culo 16&#xBA;, del decreto ley N&#xBA;211, de 1973; y el decreto exento de Hacienda N&#xBA;52, de 1996, dicto el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br><br><br></div>", "i": 6110680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase, por un nuevo per&#xED;odo de dos a&#xF1;os, a contar de la fecha del presente decreto, a don Enrique Fanta Ivanovic, Director del Servicio Nacional de Aduanas, como integrante de la Comisi&#xF3;n Resolutiva creada por el decreto ley N&#xBA;211, de 1973.</div><br></div>", "i": 6110681}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Manuel Marf&#xE1;n Lewis, Ministro de Hacienda Subrogante.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud., Manuel Marf&#xE1;n Lewis, Subsecretario de Hacienda. </div></div>", "i": 6110682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "136 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-136 EXENTO"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DESIGNA INTEGRANTE DE COMISION RESOLUTIVA A PERSONA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMISION RESOLUTIVA", "ENRIQUE FANTA IVANOVIC", "INTEGRANTE", "DESIGNACION", "DEFENSA DE LA LIBRE COMPETENCIA", "LEY ANTIMONOPOLIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-05-06", "fecha_derogacion": "2000-04-27", "doble_articulado"