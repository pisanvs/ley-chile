{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 1.336 EXENTO, DE 2012</div></div>", "i": 9377602}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.058, de 8 de octubre de 2013, de este Ministerio, modif&#xED;canse los art&#xED;culos 6&#xBA;, 7&#xBA; y 8&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1047817&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 1.336, de 2012</a>, modificado mediante decreto exento N&#xBA; 195, de 2013, ambos del Ministerio de Econom&#xED;a, Fomento y Turismo, en el sentido de reemplazar las distribuciones de las cuotas globales de captura de los recursos que se indican, por las siguientes:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/35112.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9377603}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de octubre de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9377604}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1058 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1058 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 1.336 EXENTO, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados"