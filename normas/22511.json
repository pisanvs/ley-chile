{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Retiro del Contra-Almirante don Luis Uribe O.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,258.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 9042101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. El contra-almirante de la Armada don Luis Uribe Orrego podr&#xE1; retirarse con el rango, prerogativas i sueldo correspondientes al empleo de vice-almirante en servicio activo, sin perjuicio de las gratificaciones que le conceden las leyes de 22 de Setiembre de 1890.</div><br><br></div>", "i": 9042102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 23 de Agosto de 1899.- FEDERICO ERRAZURIZ.- J. A. Figueroa.</div><br></div>", "i": 9042103}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1258", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1258"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "RETIRO DEL CONTRA-ALMIRANTE DON LUIS URIBE O.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LUIS URIBE ORREGO", "RETIRO", "VICE-ALMIRANTE", "SERVICIO", "ACTIVO", "GRATIFICACIONES", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-08-23", "doble_articulado": false, "id_norma": "22511", "numero_fuente": "6381", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-08-23", "vigencias": [{"desde": "1898-08-23", "hasta": "", "tipo_version