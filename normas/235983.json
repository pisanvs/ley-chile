{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6517657}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 334, de 9 de febrero de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL IMPORTADORA Y EXPORTADORA ROXANA LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en&nbsp; Cardonal Bajo kil&#xF3;metro 2,7, Puerto Montt, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n Cocido, fresco, enfriado, fresco refrigerado, congelado, seco salado, ahumado, conserva, harina, aceite y deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6517658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de febrero de 2005.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6517659}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "334 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-334 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-02-09", "doble_articulado": false, "id_norma": "235983", "numero_fuente": "38100", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-02", "vigencias": [{"desde": "2005-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-03-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-03-02", "fin_vigencia": "", "tipo_version": "3"}], "evento