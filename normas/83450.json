{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065381}, {"t": "<div><div class=\"p\">Por Decreto MOP No. 60 de 08 de Marzo de 1990, se expropi&#xF3; el Lote No. 2 y se constituy&#xF3; Servidumbre sobre los lotes No. s. 11-A y 11-B, superficies 2.870 m2., 350 m2. y 150 m2 roles de aval&#xFA;os 109-55 y 108-24, comuna de Quilicura, para Avenida Am&#xE9;rico Vespucio, sector Recoleta Panamericana Norte y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Aislantes Bepolit Ltda. y Aislantes Nacionales S.A., ascendente a 2.945 UF y 175 UF.</div><br></div>", "i": 6065382}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6065383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "60", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-60"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-08", "doble_articulado": false, "id_norma": "83450", "numero_fuente": "33646", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-16", "vigencias": [{"desde": "1990-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-04-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1998-01-08", "fecha_version": "1990-04-16", "fecha_actualizacion_texto": "1990-04-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura