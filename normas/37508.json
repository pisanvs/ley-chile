{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298456}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.878, de 8 de noviembre de 1996, de esta Subsecretar&#xED;a de Pesca; del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n rectif&#xED;quese la Resoluci&#xF3;n N&#xB0; 1318, de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA COLOSO S.A., para sustituir las naves &quot;Bandurria&quot;, &quot;Don Mateo&quot;, y &quot;El Conquistador&quot;, en el sentido de se&#xF1;alar que el nombre correcto de esta &#xFA;ltima nave corresponde al de &quot;Conquistador&quot; y no al se&#xF1;alado en dicha Resoluci&#xF3;n.</div><br></div>", "i": 8298457}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de noviembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298458}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1878", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1878"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PESQUERA COLOSO S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-11-08", "doble_articulado": false, "id_norma": "37508", "numero_fuente": "35618", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-11-18", "vigencias": [{"desde": "1996-11-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-11-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-11-18", "fin_vigencia": "", "tipo_version": "3"}