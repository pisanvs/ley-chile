{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6292047}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.544, de 14 de julio de 2000, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA;1.222 de 1997, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a PESQUERA VASQUEZ Y CIA. LTDA. para operar la</div><div class=\"p\">nave &apos;&apos;Porvenir II&apos;&apos;, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra d) de la Ley General de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;842 de 1995, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6292048}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de julio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6292049}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1544", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1544"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-07-14", "fecha_derogacion": "2000-10-04", "doble_articulado": false, "id_norma": "172994", "numero_fuente": "36717", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-07-19", "vigencias": [{"desde": "2000-10-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-07-19", "hasta": "2000-10-03", "tipo_version": "0", "tipo_version_