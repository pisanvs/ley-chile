{"html": [{"t": "<div><br><div class=\"p\">AMPL&#xCD;A PLAZO PARA POSTULACI&#xD3;N A COMIT&#xC9; DE MANEJO</div></div>", "i": 9507100}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.436, de 15 de septiembre de 2014, de esta Subsecretar&#xED;a, ampl&#xED;ese plazo para postular a Comit&#xE9;s de Manejo de recursos bent&#xF3;nicos de Bah&#xED;a Ancud, iniciado por <a href=\"https://www.leychile.cl/Navegar?idNorma=1065584&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.136, de 2014</a>, de esta Subsecretar&#xED;a, hasta las 14:00 horas del 29 de septiembre de 2014.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9507101}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de septiembre de 2014.- Alejandro Gertosio Ram&#xED;rez, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9507102}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2436 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2436 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "AMPLÍA PLAZO PARA POSTULACIÓN A COMITÉ DE MANEJO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-09-15", "doble_articulado": false, "id_norma": "1066878", "numero_fuente": "40962", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-09-20", "vigencias": [{"desde