{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Fondos para Agua Potable Lei n&#xFA;m. 1,002.- Santiago, a 22 de Enero de 1898.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274043}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir durante el presente a&#xF1;o hasta la cantidad de quinientos mil pesos en atender a los servicios del agua potable de las diversas ciudades de la Rep&#xFA;blica.</div><br><br></div>", "i": 8274044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Antonio Valdes C.</div><br></div>", "i": 8274045}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1002", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1002"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "FONDOS PARA AGUA POTABLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGUA POTABLE", "FONDOS", "INVERSION", "PRESIDENTE", "REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-22", "doble_articulado": false, "id_norma": "22337", "numero_fuente": "5909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-22", "vigencias": [{"desde": "1898-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-01-22", "fin_vigencia": "", "tipo_version