{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6303471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;3.455 de fecha 31 de julio del 2000, se expropi&#xF3; el lote de terreno N&#xBA;1, superficie 3.306.050m2., rol de aval&#xFA;o 250-3, comuna de Salamanca, para la obra &apos;&apos;Proyecto Embalse Corrales, sector Camisas, Zona de Inundaci&#xF3;n&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Sociedad Agr&#xED;cola y Ganadera Camisas y Compa&#xF1;&#xED;a, ascendente a la cantidad de $427.941.247.</div><br></div>", "i": 6303472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6303473}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3455", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3455"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-31", "doble_articulado": false, "id_norma": "176378", "numero_fuente": "36777", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-02", "vigencias": [{"desde": "2000-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAL", "fecha_ingreso": "2000-10-03", "fecha_version": "2000-10-02", "fecha_actualizacion_texto": "2000-10-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "