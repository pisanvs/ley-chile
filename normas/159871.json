{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6246822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. No. 269, de 29 de noviembre de 1990, se expropiaron los lotes Nos. 1-a, 1-c, 2 y 1-b, superficies 5.714 m2., 750 m2., 2.493 m2. y 3.840 m2., respectivamente, rol de aval&#xFA;o 506-23, Comuna Los Andes, para la obra Los Andes - T&#xFA;nel Cristo Redentor Ruta 60Ch,variante R&#xED;o Blanco - Guardia Vieja, y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Sres. Carlos Docmac Brito y Juan Jim&#xE9;nez Guzm&#xE1;n, ascendente a las cantidades de $ 2.649.999, y $ 1.045.344. </div></div>", "i": 6246823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas.</div><div class=\"p\">(2) </div></div>", "i": 6246824}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "269", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-269"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-11-29", "doble_articulado": false, "id_norma": "159871", "numero_fuente": "33857", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-02", "vigencias": [{"desde": "1991-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-03-07", "fecha_version": "1991-01-02", "fecha_actualiz