{"html": [{"t": "<div><div class=\"p\">PARTIDO RADICAL SOCIALDEMOCRATA </div></div>", "i": 6460952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Silvia Moreno Gonz&#xE1;lez, Secretaria General de la Directiva Central del Partido Radical Socialdem&#xF3;crata y Jean Pierre Warnier, Presidente del Tribunal Supremo de la colectividad, dan cuenta de la modificaci&#xF3;n de la Directiva Central del partido por la elecci&#xF3;n de don Augusto Parra Mu&#xF1;oz como Primer Vicepresidente por renuncia de don Carlos Gonz&#xE1;lez M&#xE1;rquez, y de don Mario Papi Beyer, como Tercer Vicepresidente, cargo que se encontraba vacante.</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O-N&#xBA; 0004 de fecha 16 de enero de 2004.-</div><br></div>", "i": 6460953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6460954}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-4"}, {"tipo": "3", "numero": "O-4", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-4"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO RADICAL SOCIALDEMOCRATA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO RADICAL SOCIALDEMOCRATA", "DIRECTIVA CENTRAL", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-27", "doble_articulado": false, "id_norma": "220502", "numero_fuente": "37768", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-24",