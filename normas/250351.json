{"html": [{"t": "<div><div class=\"p\">Ley N&#xFA;m. 14,228</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A HORTENSIA DE LA CAVAREDA ALMARZA</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6572372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Hortensia de la Cavareda Almarza, una pensi&#xF3;n de E&#xBA; 50 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6572373}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticinco de Octubre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Figueroa G.</div><br></div>", "i": 6572374}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14228", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14228"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA HORTENSIA DE LA\nCAVAREDA ALMARZA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-10-25", "doble_articulado": false, "id_norma": "250351", "numero_fuente": "24800", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-11-22", "vigencias": [{"desde": "1960-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-11-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1960-11-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-06-13", "fecha_version": "1960-11-22", "fecha_actualizacion_texto": "1960-11-22", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6572372}, {"n": "Artículo UNICO", "i": 6572373, "t": 6}, {"n": "Promulgación", "i": 6572374}]}