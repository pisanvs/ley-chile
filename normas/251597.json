{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6576996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.021, de 18 de julio de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;2.001 de 2003, modificada por la resoluci&#xF3;n N&#xBA;3.675 de 2004, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA SAN JOSE S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Surmar I&quot;, en el Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Isla de Pascua, Islas Sala y G&#xF3;mez e Islas Desventuradas, con red de arrastre, sobre el recurso Alfonsino, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado en informe t&#xE9;cnico citado en Visto. </div></div>", "i": 6576997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6576998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2021 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2021 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-18", "doble_articulado": false, "id_norma": "251597", "numero_fuente": "38522", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-25", "vigencias": [{"desde": "2006-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-0