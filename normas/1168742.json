{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N</div></div>", "i": 10287122}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 299, de 10 de noviembre de 2021, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, aprueba Contrato Ad-Refer&#xE9;ndum de Concesi&#xF3;n 3 para operar una Planta Revisora Clase AB en la comuna de Copiap&#xF3; y una Planta Revisora Clase AB en la comuna de Cha&#xF1;aral, Regi&#xF3;n de Atacama, celebrado entre el Ministerio de Transportes y Telecomunicaciones, a trav&#xE9;s de la referida Secretar&#xED;a Regional Ministerial y &quot;Revisiones T&#xE9;cnicas R&#xED;o San Pedro S.A.&quot;, con vigencia de diez a&#xF1;os contados desde la publicaci&#xF3;n del presente extracto en el Diario Oficial.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10287123}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Vittorio Ghiglino Bianchi, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 10287124}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "299 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-299 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2047145", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-10", "doble_articulado": false, "id_norma": "1168742", "numero_fuente": "43113", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion