{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 167, DE 1991</div><br><div class=\"p\">N&#xFA;m. 245.- Santiago, 30 de Septiembre de 1991.- Vistos: Lo dispuesto en el Art. 4&#xB0; del decreto ley No. 2.974 de 1979 </div><div class=\"p\">Resuelvo:</div><br></div>", "i": 7221992}, {"t": "<div><div class=\"p\">Modif&#xED;case la Resoluci&#xF3;n No. 167 de 2 de Julio de 1991, que designa ministros de fe, en la forma siguiente: Se eliminan a los siguientes funcionarios: Rodrigo Eugenio Saini Ar&#xE9;valo y Gricerio Bastidas San Mart&#xED;n. Rectif&#xED;case el nombre de Rub&#xE9;n Enrique Alarc&#xF3;n Cartes por el de Ra&#xFA;l Enrique Alarc&#xF3;n Cartes.</div><br></div>", "i": 7221993}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional. </div></div>", "i": 7221994}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "245", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-245"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA RESOLUCION No. 167, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-09-30", "doble_articulado": false, "id_norma": "87271", "numero_fuente": "34101", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-26", "vigencias": [{"desde": "1991-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-26", "fin_vigencia": "", "tipo_version": "3"}], "e