{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8318254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.793, de 30 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de sustituci&#xF3;n presentada por PESQUERA QUINTERO UNO S.A., para sustituir la nave &quot;Plavnik&quot; por una nave en construcci&#xF3;n, por haberse enajenado la nave a sustituir, vulner&#xE1;ndose lo dispuesto en el art&#xED;culo 32 de la ley N&#xBA; 18.892 y sus modificaciones, citada en visto, y en el D.S. N&#xBA; 64, de 1992 y su modificaci&#xF3;n contenida en el D.S. N&#xBA; 500, de 1994, ambos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8318255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8318256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1793", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1793"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "SOLICITUD DE SUSTITUCION", "PESQUERA QUINTERO UNO S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-30", "doble_articulado": false, "id_norma": "86920", "numero_fuente": "35961", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-10", "vigencias": [{"desde": "1998-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci