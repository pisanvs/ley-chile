{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; HOSPITAL DE LA LIGUA Lei n&#xFA;m 154.-Santiago, a 10 de Enero de 1894.-Por cuanto el Congreso Nacional ha aprobado el siguiente PROYECTO DE LEI:</div><br><br></div>", "i": 8273770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir la cantidad de cinco mil trescientos noventa i seis pesos treinta centavos, en cancelar a los contratistas para la construccion del hospital de la Ligua la suma que se les adeuda por los trabajos ejecutados en dicho edificio.</div><br><br></div>", "i": 8273771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.-Pedro Montt.</div><br></div>", "i": 8273772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "154", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-154"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "HOSPITAL DE LA LIGUA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LIGUA", "HOSPITAL", "FONDOS", "DESTINACION", "PRESIDENTE", "REPUBLICA", "AUTORIZACION", "CONSTRUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-10", "doble_articulado": false, "id_norma": "22015", "numero_fuente": "4714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-01-11", "vigencias": [{"desde": "1894-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-01-11", "fin_vigencia": "", "