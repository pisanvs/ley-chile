{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6242049}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 240 del 21 de Abril de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la 1ra. Regi&#xF3;n se autoriza a Gast&#xF3;n Pedro Julio Sippa y Alen del Carmen Tello Vega, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6242050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones, 1ra. Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6242051}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "240 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-240 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-21", "doble_articulado": false, "id_norma": "158505", "numero_fuente": "32468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-12", "vigencias": [{"desde": "1986-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-05-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p