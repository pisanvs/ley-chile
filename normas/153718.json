{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 73, DE 1986 </div></div>", "i": 6226829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 73 de 15 de mayo de 1986 se han aprobado para la Escuela T&#xE9;cnica Femenina Teresa Brown de Arizt&#xED;a, de La Calera, planes y programas especiales de estudio parala Educaci&#xF3;n Media, Modalidad T&#xE9;cnico-Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar de 1991, en las Especialidades de: Atenci&#xF3;n de P&#xE1;rvulos con menci&#xF3;n en Educaci&#xF3;n Diferencial, Atenci&#xF3;n Social Administrativa, Peluquer&#xED;a y Belleza, Tejido Industrial y Vestuario Industrial.</div><br></div>", "i": 6226830}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Mayo de 1986.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6226831}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "73 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-73 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 73, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-15", "doble_articulado": false, "id_norma": "153718", "numero_fuente": "32492", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-10", "vigencias": [{"desde": "1986-06-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-10", "fin_vigencia": ""}, "vigencias_versi