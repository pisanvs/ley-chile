{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A INDUSTRIAL SANTA MARIA S.A.</div><br><br></div>", "i": 7237742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex-0830, de 05-08-98, corregida por resoluci&#xF3;n DRE08/Ex-N&#xBA; 0863 de fecha 13 de agosto de 1998, otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n a Industrial Santa Mar&#xED;a S.A., Rut.</div><div class=\"p\">N&#xBA;96.766.590-8, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de especies hidrobiol&#xF3;gicas, establecido en la resoluci&#xF3;n N&#xBA; Ex-3.839/98, de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 01-07-98. </div></div>", "i": 7237743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 7237744}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "830 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-830 EXENTA"}, {"tipo": "3", "numero": "DRE-08-0830 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-0830 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A;INDUSTRIAL SANTA MARIA S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "INDUSTRIAL SANTA MARIA S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-21", "doble_articulado": false, "id_norma": "123473", "n