{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A FORESTAL RIO VERGARA S.A.</div><br></div>", "i": 6112275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por resoluci&#xF3;n DRE08/N&#xB0; Ex-0361 de fecha 7 de mayo de 1998, ha procedido a Revocar a solicitud de la empresa Forestal R&#xED;o Vergara S.A., Rut.</div><div class=\"p\">N&#xB0; 93.679.000-3, su calidad de Agente Retenedor del Impuesto al Valor Agregado por la Compra de Madera, de acuerdo a lo dispuesto en el dispositivo N&#xB0; 15, de la resoluci&#xF3;n N&#xB0; Ex-5362/97, de la Direcci&#xF3;n Nacional, la que regir&#xE1; a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n.</div><br></div>", "i": 6112276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se adjunta resoluci&#xF3;n en cuesti&#xF3;n.- Saluda a Ud., Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6112277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "361 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-361 EXENTA"}, {"tipo": "3", "numero": "DRE-08-0361 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-0361 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A FORESTAL\nRIO VERGARA S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "FORESTAL RIO VERGARA S.A.", "MADERA", "REVOCACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-07", "doble_articulado": false, "id