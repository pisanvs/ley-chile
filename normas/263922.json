{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6620863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.246, de 27 de julio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a SEA GARDEN S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en parcela N&#xBA; 26, La Laja, Puerto Varas, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de cocido, fresco-enfriado, fresco-refrigerado, congelado, seco salado, ahumado y conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6620864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de julio de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6620865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2246 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2246 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-27", "doble_articulado": false, "id_norma": "263922", "numero_fuente": "38840", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-17", "vigencias": [{"desde": "2007-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-08-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad