{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6260943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 624, de 16 Septiembre de 1985, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza en forma complementaria a la Empresa de origen argentino Ram&#xF3;n Delv s (Turismo Lanin), para efectuar servicio internacional de transporte terrestre de pasajeros entre San Carlos de Bariloche (Argentina) y Osorno - Puerto Montt (Chile), por paso Puyehue, efectuando dos (2) frecuencias semanales </div></div>", "i": 6260944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Y&#xE1;var Martin, Coronel de Ej&#xE9;rcito, Subsecretario de Transportes.</div><br></div>", "i": 6260945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "624", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-624"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-09-16", "doble_articulado": false, "id_norma": "164246", "numero_fuente": "32292", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-09", "vigencias": [{"desde": "1985-10-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-10-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-10-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "2000-04-05", "fecha_ver