{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8335499}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.359, de 28 de septiembre de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA DEL CABO S.A., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Don Pedro&apos;&apos; con la cual podr&#xE1; operar en el litoral de la V a IX Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con red de cerco los siguientes recursos hidrobiol&#xF3;gicos: Anchoveta, Bonito, Caballa, Merluza de cola, Sardina Espa&#xF1;ola y Sardina Com&#xFA;n.</div><div class=\"p\">&nbsp; &nbsp;  Deni&#xE9;gase la autorizaci&#xF3;n solicitada respecto de los recursos y &#xE1;reas no mencionados en la presente resoluci&#xF3;n. </div></div>", "i": 8335500}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de septiembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8335501}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1359", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1359"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA DEL CABO S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-09-28", "fecha_derogacion": "2004-04-20", "doble_articulado": false, "id_norma": "125615", "numero_fuente": "36183", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-10-08", "vigencias": [{"desde": "2004-04-20", "hasta": "", "tipo_version": "2", "tipo_version_s"