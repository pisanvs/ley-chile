{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6284775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 630, de fecha 29 de febrero del 2000, se expropi&#xF3; los lotes de terreno N&#xBA;s. 10-A y 13-A, superficie 219,27 y 1.340,20 m&#xB2; respectivamente, sin rol de aval&#xFA;o, comuna de Vicu&#xF1;a, para la obra &apos;&apos;Embalse Puclaro II Etapa Sector La Polvada, Complementaria &apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Juan Antonio Flores C&#xE1;ceres y Silvia Vigorena C&#xE1;ceres y otros, ascendente a la cantidad de $3.426.480.- por el lote N&#xBA; 10-A y $4.074.441.- por el N&#xBA; 13-A.- </div></div>", "i": 6284776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6284777}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "630", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-630"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-29", "doble_articulado": false, "id_norma": "171726", "numero_fuente": "36702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-01", "vigencias": [{"desde": "2000-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-07-03", "fecha_version": "2000