{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.073, de 31 de julio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2 de la Resoluci&#xF3;n N&#xBA; 95 de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESQUERA IQUIQUE GUANAYE S.A., para operar por sustituci&#xF3;n la nave &quot;Guanaye 4&quot;, en el sentido de agregar lo siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;d) Litoral de la I a la IV Regiones, por fuera del &#xE1;rea de reserva artesanal, con red de cerco: Bacaladillo o mote.</div><br></div>", "i": 8305743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305744}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1073", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1073"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA IQUIQUE GUANAYE S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-07-31", "fecha_derogacion": "2001-05-05", "doble_articulado": false, "id_norma": "75067", "numero_fuente": "35845", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-08-19", "vigencias": [{"desde": "2001-05-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-08-19", "hasta": "2001-05-04", "tipo_version": "0", "tipo_vers