{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL QUE INDICA </div></div>", "i": 6226416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 90, de 16 de Julio de 1986, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n Gremial de Due&#xF1;os de Taxibuses de la Regi&#xF3;n Metropolitana&quot;, inscrita bajo el No. 77, del Registro de Asociaciones Gremiales que lleva este Ministerio, por haberse configurado a su respecto la causal contenida en el art&#xED;culo 18&#xB0; No. 2, letra d) del Decreto Ley 2.757. </div></div>", "i": 6226417}, {"t": "<div><div class=\"p\"> - Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito. </div></div>", "i": 6226418}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "90", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-90"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE\nASOCIACION GREMIAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-16", "doble_articulado": false, "id_norma": "153579", "numero_fuente": "32548", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-14", "vigencias": [{"desde": "1986-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-08-14", "fin_vigencia": "", "tipo_ve