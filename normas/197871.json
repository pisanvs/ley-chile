{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO N&#xB0; 1.150, DE 1988</div><br><div class=\"p\">&nbsp; &nbsp; Santiago, 08 de Febrero de 1989.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 184.- Visto la facultad que me confiere el art&#xED;culo 32, N&#xB0; 8, de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7291579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico: Introd&#xFA;cense las siguientes modificaciones al Decreto Supremo N&#xB0; 1.150, de 31 de octubre de 1988, publicado en el Diario Oficial de 18 de enero de 1989:</div><div class=\"p\">&nbsp; &nbsp;  1.- Der&#xF3;gase su art&#xED;culo 1&#xB0; transitorio, y 2.- En su art&#xED;culo 2&#xB0; transitorio, sustit&#xFA;yese el a&#xF1;o &quot;1988&quot; que all&#xED; figura, por &quot;1989&quot;.</div><br></div>", "i": 7291580, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Luis Manr&#xED;quez Reyes, Ministro de Justicia subrogante.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Le saluda atentamente.- Daniel Munizaga Munita, Subsecretario de Justicia subrogante.</div><br></div>", "i": 7291581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "184", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-184"}], "organismos": ["MINISTERIO DE JUSTICIA", "SUBSECRETARIA DE JUSTICIA"], "titulo_norma": "MODIFICA DECRETO N° 1.150, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-02-08", "doble_articulado": false, "id_norma": "197871", "numero_fuente": "33320", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-11", "vigencias": [{"desde": "1989-03-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PSO", "fecha_ingreso": "2002-05-09", "fecha_version": "1989-03-11", "fecha_actualizacion_texto": "1989-03-11", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7291579}, {"n": "Artículo UNICO", "i": 7291580, "t": 6}, {"n": "Promulgación", "i": 7291581}]}