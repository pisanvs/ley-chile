{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACIONES PARCIALES DE INMUEBLES </div></div>", "i": 6351550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 142 de 24 agosto 2001, Serviu V</div><div class=\"p\">Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme</div><div class=\"p\">art&#xED;culo 87 Ley 8946 y decreto ley 2.186, de 1978, de inmueble ubicado en calle 1 Norte 3041, rol aval&#xFA;o 410-8, comuna Vi&#xF1;a del Mar, de presunto dominio de Mirtha Mery Ormaz&#xE1;bal. Comisi&#xF3;n tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, Alvaro Verdejo Vidal, ingeniero constructor, y Pablo Caria Giurici, constructor civil, seg&#xFA;n informe de fecha 15 de mayo 2001, fij&#xF3; monto provisional indemnizaci&#xF3;n en $4.192.000.- que ser&#xE1; pagada al contado.-</div><br></div>", "i": 6351551}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu V Regi&#xF3;n.</div><br></div>", "i": 6351552}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "142", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-142"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "DISPONE EXPROPIACIONES PARCIALES DE INMUEBLES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-08-24", "doble_articulado": false, "id_norma": "190083", "numero_fuente": "37074", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-01", "vigencias": [{"desde": "2001-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "20