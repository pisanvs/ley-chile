{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Juana L&#xF3;pez, ex-cantinera del Ej&#xE9;rcito Lei n&#xFA;m. 996.- Santiago, a 14 de Enero de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese por gracia, a do&#xF1;a Juana L&#xF3;pez, ex-cantinera del Ej&#xE9;rcito, una pension vitalicia de quince pesos mensuales.</div><br><br></div>", "i": 5948116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Patricio Larrain A.</div><br></div>", "i": 5948117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "996", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-996"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION DE JUANA LOPEZ, EX-CANTINERA DEL EJERCITO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUANA LOPEZ", "PENSION VITALICIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-14", "doble_articulado": false, "id_norma": "22332", "numero_fuente": "5906", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-19", "vigencias": [{"desde": "1898-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por