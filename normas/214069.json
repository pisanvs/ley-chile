{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 65 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rech&#xE1;zase el recurso de reclamaci&#xF3;n interpuesto por&nbsp; CIDEF S.A. en contra de la resoluci&#xF3;n N&#xBA; 369 de 2002 de la Subsecretar&#xED;a de Pesca, en virtud de haber sido dictadas sentencias definitivas que rechazaron las acciones judiciales destinadas a obtener la declaraci&#xF3;n de la nulidad del acto administrativo citado, ello de conformidad con lo dispuesto en los art&#xED;culos 6&#xBA; y 74 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica. </div></div>", "i": 6437338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6437339}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "65 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-65 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-19", "doble_articulado": false, "id_norma": "214069", "numero_fuente": "37647", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-29", "vigencias": [{"desde": "2003-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-08-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen