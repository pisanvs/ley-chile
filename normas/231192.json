{"html": [{"t": "<div><div class=\"p\">MODIFICA REGLAMENTO DE CARRERAS DE CHILE </div></div>", "i": 8925647}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Consejo Superior de la H&#xED;pica Nacional, en uso de la facultad establecida en la letra c) del art&#xED;culo 3&#xBA; del DS del Ministerio de Hacienda N&#xBA; 1.588, del a&#xF1;o 1943, y de conformidad con lo dispuesto en el DS N&#xBA; 211 del Ministerio de Hacienda, de 13 de marzo de 2003, acord&#xF3; en su sesi&#xF3;n N&#xBA; 928 de fecha 21 de septiembre de 2004, introducir al Reglamento de Carreras de Chile, la siguiente modificaci&#xF3;n:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Agregar la letra g) al art&#xED;culo 130&quot;.</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;g) Aprobar un examen de aptitud psicol&#xF3;gica para el ejercicio de la profesi&#xF3;n, practicado por un especialista calificado por el Consejo&quot;.</div><br></div>", "i": 8925648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Domingo Romero Cort&#xE9;s, Presidente.</div><br></div>", "i": 8925649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "23", "numero": "928", "abreviacion": "SES", "descripcion": "Sesion", "compuesto": "SES-928"}], "organismos": ["CONSEJO SUPERIOR DE LA HÍPICA NACIONAL"], "titulo_norma": "MODIFICA REGLAMENTO DE CARRERAS DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REGLAMENTO DE CARRERAS DE CHILE", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-21", "doble_articulado": false, "id_norma": "231192", "numero_fuente": "37981", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-08", "vigencias": [{"desde": "2004-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],