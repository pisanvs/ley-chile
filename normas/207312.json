{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div><br><br></div>", "i": 6412593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 120, de fecha 20 de diciembre del a&#xF1;o 2002, se aprob&#xF3; la Disoluci&#xF3;n Voluntaria de la Cooperativa de Vivienda y Servicios Habitacionales &quot;Proa al Sol&quot; Limitada, que consta en la escritura p&#xFA;blica suscrita con fecha 25 de octubre del a&#xF1;o 2002, ante el Notario P&#xFA;blico de Valpara&#xED;so don Luis Enrique Fischer Y&#xE1;var.</div><br></div>", "i": 6412594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Ra&#xFA;l Oliva Camadro, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6412595}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "120", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-120"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-20", "doble_articulado": false, "id_norma": "207312", "numero_fuente": "37476", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-02-04", "vigencias": [{"desde": "2003-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-02-04", "fin_vigencia": "", "tipo_version":