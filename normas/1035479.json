{"html": [{"t": "<div><br><div class=\"p\">CREA DEPARTAMENTO DE DELITOS TRIBUTARIOS</div></div>", "i": 9221702}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 153 de 23 de diciembre de 2011, que:</div><div class=\"p\">&nbsp; &nbsp;  Modifica la organizaci&#xF3;n del Departamento Subdirecci&#xF3;n Jur&#xED;dica, creando un Departamento que asuma parte de las funciones que se han asignado al Departamento de Defensa Judicial y Delitos Tributarios.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2011.</div></div>", "i": 9221703}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "153 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-153 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CREA DEPARTAMENTO DE DELITOS TRIBUTARIOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO, NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-23", "doble_articulado": false, "id_norma": "1035479", "numero_fuente": "40147", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-29", "vigencias": [{"desde": "2011-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-12-29", "fin_vigencia": "", "tipo_version": "3"}], "