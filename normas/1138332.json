{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO INTERINO DE CONSEJERO DE ESTADO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 15 da 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  He adordado y decreto:</div></div>", "i": 10074406}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Durante la enfermedad del Ministro de la Suprema Corte de Justicia D. Francisco Antonio Perez, nombrado Consejero de Estado por Supremo decreto de 2 de Febrero &#xFA;ltimo, nombro para que le subrogue interinamente en este cargo, al Ministro de la misma Corte D. Jos&#xE9; Gaspar Mar&#xED;n. Comun&#xED;quesele este decreto que se insertar&#xE1; en el Bolet&#xED;n.</div></div>", "i": 10074407}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Err&#xE1;zuriz.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Ega&#xF1;a.</div></div>", "i": 10074408}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "NOMBRAMIENTO INTERINO DE CONSEJERO DE ESTADO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-03-15", "doble_articulado": false, "id_norma": "1138332", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingres