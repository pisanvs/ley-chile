{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6364447}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.552, de 20 de diciembre de 2001, de esta Subsecretar&#xED;a, decl&#xE1;rase que con fecha 29 de octubre de 2001 han quedado sin efecto las resoluciones N&#xBA;1.457 de 1996, N&#xBA;255 de 1997, N&#xBA;109 de 2000, N&#xBA;1.298, N&#xBA;1.895 y N&#xBA;1.947, todas de 2001, de esta Subsecretar&#xED;a, que autorizaron a PESQUERA PLAYA BLANCA S.A. para desarrollar actividad extractiva con la nave Hoddevick, en conformidad con lo dispuesto en el art&#xED;culo 9&#xBA; de la Ley N&#xBA;19.713. Dicha nave queda permanente e irrevocablemente excluida de la actividad pesquera extractiva.</div><br></div>", "i": 6364448}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6364449}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2552", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2552"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-20", "doble_articulado": false, "id_norma": "193322", "numero_fuente": "37151", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-04", "vigencias": [{"desde": "2002-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-04", "fin_vigencia": "", "tipo_ve