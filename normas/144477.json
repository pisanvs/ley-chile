{"html": [{"t": "<div><div class=\"p\">AUTORIZA A. DON JORGE ORLANDO CARDENAS MERCADO PARA INICIAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 8350809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 76, de 26 de Enero de 1987, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Jorge Orlando C&#xE1;rdenas Mercado, - R.U.T. N&#xB0; 2.955.589-3, domiciliado en San Mart&#xED;n N&#xB0; 0751, Temuco, IX Regi&#xF3;n, para iniciar actividades de cultivo de alga del g&#xE9;nero Gracilaria, en un sector del fondo del r&#xED;o Queule, Comuna Tolt&#xE9;n, IX Regi&#xF3;n, en un &#xE1;rea de 6.000 m2. </div></div>", "i": 8350810}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de Enero de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8350811}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "76", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-76"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A. DON JORGE ORLANDO CARDENAS MERCADO PARA INICIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-01-26", "fecha_derogacion": "1989-05-26", "doble_articulado": false, "id_norma": "144477", "numero_fuente": "32699", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-02-16", "vigencias": [{"desde": "1989-05-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-02-16", "hasta": "1989-05-25", "tipo_version": "0", "tipo_version_s":