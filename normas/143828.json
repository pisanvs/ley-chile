{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8350322}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.706, de 2 de septiembre de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a CONGELADOS DEL PACIFICO LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 702, de 1988, N&#xBA; 231 y N&#xBA; 1.033, ambas de 1998, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Avenida Gran Breta&#xF1;a N&#xBA; 955, comuna de Talcahuano, provincia de Concepci&#xF3;n, VIII Regi&#xF3;n, en las l&#xED;neas de proceso de Congelado&nbsp; y Fresco-refrigerado, el recurso hidrobiol&#xF3;gico Orange roughy.</div><br></div>", "i": 8350323}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de septiembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8350324}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1706", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1706"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-02", "doble_articulado": false, "id_norma": "143828", "numero_fuente": "36470", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-22", "vigencias": [{"desde": "1999-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-22", "fin_vigencia": "", "tipo_version":