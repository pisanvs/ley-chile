{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que fija en 5,500 pesos el sueldo del Secretario de Comisiones de la C&#xE1;mara de Diputados.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 31 de Diciembre de 1901.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8274393}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. F&#xED;jase en cinco mil quinientos pesos ($ 5,500) el sueldo del secretario de comisiones de la C&#xE1;mara de Diputados, con la obligacion de atender a la Comision Mista de Presupuestos.</div><br></div>", "i": 8274394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Ismael Tocornal.</div><br></div>", "i": 8274395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1508", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1508"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Que fija en 5,500 pesos el sueldo del Secretario de;Comisiones de la Cámara de Diputados.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMARA DIPUTADOS", "SECRETARIO", "REMUNERACION", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-31", "doble_articulado": false, "id_norma": "22704", "numero_fuente": "7110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-31", "vigencias": [{"desde": "1901-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "19