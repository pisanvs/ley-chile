{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 10.355 EXENTA, DE 2011</div></div>", "i": 9205939}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 10.355, de 3 de noviembre de 2011, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Meldar Capacitaci&#xF3;n Limitada (Meldar Ltda.)&quot;, RUT 76.168.900-2, contenida en la resoluci&#xF3;n exenta N&#xBA; 2.207, de 2 de noviembre de 2005, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.- </div></div>", "i": 9205940}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Francisco Ag&#xFC;ero Larrondo, Director Nacional (Subrogante).</div></div>", "i": 9205941}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10355 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-10355 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 10.355 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-03", "doble_articulado": false, "id_norma": "1032967", "numero_fuente": "40115", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-21", "vigencias": [{"desde": "2011-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-11-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-11-21", "fin_vigencia": "", "tipo_version": "3"}], "evento