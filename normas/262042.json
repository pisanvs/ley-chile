{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7346051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.796, de 14 de junio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A., para realizar actividades extractivas en alta mar con la nave &quot;Galletu&#xE9;&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; CB-2052</div><div class=\"p\">Puerto de matr&#xED;cula&nbsp; &nbsp;  Valpara&#xED;so</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2515</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; 40,22 m</div><div class=\"p\">TRG (Internacional)&nbsp; &nbsp;  464,70</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  8,60 m</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 6,80 m.</div><br></div>", "i": 7346052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de junio de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7346053}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1796 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1796 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2007-06-14", "fecha_derogacion": "2011-05-23", "doble_articulado": false, "id_norma": "262042", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2007-06