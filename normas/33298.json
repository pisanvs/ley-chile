{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290464}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 125 de 17 de Enero de 1996 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SOCIEDAD DE MATARIFES ARICA LIMITADA, R.U.T. N&#xB0; 79.785.080-2, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a procesar en la planta ubicada en Azolas N&#xB0; 2176, Arica, en la l&#xED;nea de elaboraci&#xF3;n de Fresco-refrigerado, el recurso hidrobiol&#xF3;gico Lobo marino com&#xFA;n Otaria Flavescens.</div><div class=\"p\">&nbsp; &nbsp; La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales y reglamentarias vigentes o que se establezcan.</div><br></div>", "i": 8290465}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 17 de Enero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8290466}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "125", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-125"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "AUTORIZACION", "SOCIEDAD DE MATARIFES ARICA LIMITADA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-01-17", "fecha_derogacion": "2000-01-24", "doble_articulado": false, "id_norma": "33298", "numero_fuente": "35397", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-02-20", "vigencias": [{"desde": "2000-01-24", "hasta": "", "tipo_vers