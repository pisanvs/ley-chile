{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,097.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de veinte mil pesos ($ 20,000) oro de dieciocho peniques, para atender a los gastos imprevistos de las legaciones i consulados de la Rep&#xFA;blica </div></div>", "i": 6168058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, dieciseis de marzo de mil novecientos ocho.- Pedro Montt.- F. Puga Borne.</div><br></div>", "i": 6168059}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2097", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2097"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-03-16", "doble_articulado": false, "id_norma": "136243", "numero_fuente": "9049", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-03-16", "vigencias": [{"desde": "1908-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1908-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1908-03-16", "fin_vigencia": "", "tipo_version": "3"}], "even