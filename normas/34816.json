{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 443, de 13 de marzo de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por CULTIVOS YADRAN S.A., para un centro de cultivo ubicado en Sector Trincao, Comuna de Quell&#xF3;n, Provincia de Chilo&#xE9;, X Regi&#xF3;n, por no ser factible el respectivo proyecto t&#xE9;cnico en virtud de lo dispuesto en el art&#xED;culo 14 inciso 2&#xB0; del D.S. N&#xB0; 290, de 1993, modificado por el D.S. N&#xB0; 604 de 1994, ambos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8292505}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 13 de marzo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292506}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "443", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-443"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "CULTIVOS YADRAN S.A.", "QUELLON", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-13", "doble_articulado": false, "id_norma": "34816", "numero_fuente": "35422", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-20", "vigencias": [{"desde": "1996-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-20", "fin_vigencia": ""