{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,282.- Santiago, 22 de noviembre de 1899.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Aum&#xE9;ntase, por gracia, la pensi&#xF3;n de montep&#xED;o que corresponde a la viuda e hijas solteras del se&#xF1;or jeneral de division&nbsp; de la Rep&#xFA;blica, don Jos&#xE9; Antonio Villagran, a la suma de dos mil pesos anuales. </div></div>", "i": 6162847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 6162848}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1282", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1282"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-11-22", "doble_articulado": false, "id_norma": "134589", "numero_fuente": "6456", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-11-24", "vigencias": [{"desde": "1899-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-11-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-11-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-04-08", "fe