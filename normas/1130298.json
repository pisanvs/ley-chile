{"html": [{"t": "<div><br><div class=\"p\">RENUNCIA DEL GOBERNADOR INTENDENTE</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 3 de 1823.</div></div>", "i": 10014115}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Cont&#xE9;stese al Gobernador Intendente que la Junta no puede admitir la renuncia que hace porque la Patria se privar&#xED;a en tal caso de un buen funcionario que la sirve con honor, con celo, y tan a satisfaccion p&#xFA;blica, que la misma confianza que el Gobierno y el pueblo le manifiestan, son el testimonio mas honroso de su conducta, y sobre que debe descansar.- </div></div>", "i": 10014116}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Eyzaguirre.- Infante.- Err&#xE1;zuriz.- Ega&#xF1;a.</div></div>", "i": 10014117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES"], "titulo_norma": "RENUNCIA DEL GOBERNADOR INTENDENTE", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-02-03", "doble_articulado": false, "id_norma": "1130298", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-02-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2019-04-10", "fecha_version": "1823-02-03", "fecha_actualizacion_texto": "2019-04-10",