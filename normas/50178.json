{"html": [{"t": "<div><div class=\"p\">REFORMA ESTATUTOS DEL BANCO DEL DESARROLLO </div></div>", "i": 6027524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que por Resoluci&#xF3;n N&#xBA; 179 de 27 de diciembre de 1996, se aprob&#xF3; la reforma introducida a los estatutos del Banco del Desarrollo en la Junta Extraordinaria de Accionistas celebrada en Santiago el 21 de noviembre de 1996, cuya acta fue reducida a escritura p&#xFA;blica el 10 de diciembre de 1996 en la Notar&#xED;a de Santiago de do&#xF1;a Gloria Cort&#xE9;s Escaida.</div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de la reforma:</div><br><div class=\"p\">&nbsp; &nbsp;  Se aument&#xF3; el n&#xFA;mero de directores titulares a once.</div><br><br></div>", "i": 6027525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de diciembre de 1996.- Jos&#xE9; Florencio Guzm&#xE1;n C., Superintendente de Bancos e Instituciones Financieras. </div></div>", "i": 6027526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "179", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-179"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE BANCOS E INSTITUCIONES FINANCIERAS"], "titulo_norma": "REFORMA ESTATUTOS DEL BANCO DEL DESARROLLO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REFORMA ESTATUTARIA", "ESTATUTOS", "BANCO DEL DESARROLLO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-27", "doble_articulado": false, "id_norma": "50178", "numero_fuente": "35657", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-04", "vigencias": [{"desde": "1997-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1