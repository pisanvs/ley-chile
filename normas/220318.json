{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6460175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 94, de 9 de enero de 2004,</div><div class=\"p\">de esta Subsecretar&#xED;a, modif&#xED;case el literal b) del</div><div class=\"p\">numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 57 de 2004, de esta</div><div class=\"p\">Subsecretar&#xED;a, que constituy&#xF3; la Comisi&#xF3;n Evaluadora</div><div class=\"p\">asesora del Subsecretario de Pesca establecida en el</div><div class=\"p\">art&#xED;culo 24 del D.S. N&#xBA; 85 de 2003, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el sentido de designar a don Juan Germ&#xE1;n Loyola Bast&#xED;as, R.U.T. N&#xBA; 10.041.434-1, como integrante de la citada Comisi&#xF3;n en reemplazo de don Leonardo Angelo Sasso Barros, R.U.T. N&#xBA; 7.564.538-4.</div><br></div>", "i": 6460176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6460177}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "94 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-94 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-09", "doble_articulado": false, "id_norma": "220318", "numero_fuente": "37764", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-20", "vigencias": [{"desde": "2004-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"