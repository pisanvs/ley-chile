{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8740771}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.123, 17 de junio de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a JORGE PABLO ANDR&#xC9;S BELMAR RUSSELL para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar planta ubicada en kil&#xF3;metro 6 de camino a Queilen, Pucatu&#xE9;, Chonchi, Chilo&#xE9;, X Regi&#xF3;n, en las l&#xED;neas de procesos Cocido, Fresco enfriado, Congelado, Seco salado, Salado h&#xFA;medo, Ahumado y Conserva.</div></div>", "i": 8740772}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de junio de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8740773}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2123 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2123 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-17", "doble_articulado": false, "id_norma": "1004169", "numero_fuente": "39409", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-07-11", "vigencias": [{"desde": "2009-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-07-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-07-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2009-07-13", "fecha_vers