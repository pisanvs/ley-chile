{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6287285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.148, de 29 de mayo del 2000, se expropiaron los lotes de terreno N&#xBA;s. 27, 45, 46 y 47, superficies 10.874, 504, 871 y 332 m&#xB2; respectivamente, roles de aval&#xFA;os 1441-8 y 2190-83, comunas de Puerto Varas y Puerto Montt, para la obra Camino Ruta V-505, sector Pto. Varas - Los Alerces - Pto. Montt, Kms. 0,000 al 16,340 y se acord&#xF3; precio de las indemnizaciones con sus propietarios Eduardo Jerman Schnettler Droppelmann y Georg Grothusen Gesche, ascendentes a las cantidades de $14.302.344 para el lote N&#xBA;27 y $2.105.912 para los lotes N&#xBA;s. 45, 46 y 47.</div><br></div>", "i": 6287286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6287287}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2148", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2148"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-29", "doble_articulado": false, "id_norma": "172362", "numero_fuente": "36714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-15", "vigencias": [{"desde": "2000-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha