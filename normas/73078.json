{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 464 EXENTO, DE 1997 </div></div>", "i": 6037854}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 464 de fecha 21 de abril de 1997 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto AIEP, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a contar del a&#xF1;o 1997:</div><br><div class=\"p\">Sede N&#xBA; 7 - Calama</div><br><br><div class=\"p\">Carrera&nbsp; &nbsp;  :&nbsp; Comercio Internacional</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp; :&nbsp; T&#xE9;cnico en Comercio Internacional</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (Decreto exento N&#xBA; 273 del 02.05.95)</div><br></div>", "i": 6037855}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de mayo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6037856}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "464 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-464 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 464 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA INSTITUTO AIEP", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-21", "doble_articulado": false, "id_norma": "73078", "numero_fuente": "35778", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-