{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n, por gracia, a don Jos&#xE9; Miguel Aguilera</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 7168826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, y por el t&#xE9;rmino de diez a&#xF1;os, a don Jos&#xE9; Miguel Aguilera, ex trabajador inv&#xE1;lido del Dique de Carena de Talcahuano, una pensi&#xF3;n de seiscientos pesos ($ 600.00), anuales, de la que disfrutar&#xE1; a contar desde el d&#xED;a 1.o de Enero de 1929.</div><br></div>", "i": 7168827}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, catorce de Septiembre de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- C. O. Froedden. </div></div>", "i": 7168828}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4420", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4420"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DON JOSÉ MIGUEL AGUILERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE MIGUEL AGUILERA", "PENSION GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-09-14", "doble_articulado": false, "id_norma": "24725", "numero_fuente": "15192", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-10-06", "vigencias": [{"desde": "1928-10-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi