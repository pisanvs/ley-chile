{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6462364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 241 de 21 de enero de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a INVERSIONES PESCA MAR LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Brice&#xF1;o N&#xBA; 2278, Concepci&#xF3;n VIII Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n cocido, fresco-enfriado, fresco-refrigerado y congelado, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.218 de 2003, de esta Subsecretar&#xED;a, en virtud de la carta renuncia presentada por Juan Pablo Bustos Contreras y del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6462365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6462366}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "241 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-241 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-21", "doble_articulado": false, "id_norma": "220878", "numero_fuente": "37777", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-04", "vigencias": [{"desde": "2004-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v