{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6354551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.206, de 17 de octubre de 2001, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA; 2.017, de 2001, de esta Subsecretar&#xED;a que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Distribuci&#xF3;n espacio temporal de las capturas de jurel en la I y II Regi&#xF3;n (Cuarta etapa)&quot;, en el sentido de reemplazar la nave &quot;Eperva 57&quot; por la nave &quot;Bandurria&quot;, ambas de propiedad de Corpesca S.A., de la n&#xF3;mina de naves participantes en la se&#xF1;alada pesca de investigaci&#xF3;n.</div><br></div>", "i": 6354552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de octubre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6354553}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2206", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2206"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-17", "doble_articulado": false, "id_norma": "190913", "numero_fuente": "37094", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-25", "vigencias": [{"desde": "2001-10-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-25", "fin_vige