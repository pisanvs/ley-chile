{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6500141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.712, de 21 de septiembre</div><div class=\"p\">de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA</div><div class=\"p\">LOTA VEDDE S.A. SANTA MARIA Y COMPA&#xD1;IA COMANDITA POR</div><div class=\"p\">ACCIONES para ampliar actividades pesqueras extractivas</div><div class=\"p\">con la nave &quot;Santa Mar&#xED;a II&quot;, entre la V a VII Regiones,</div><div class=\"p\">y en la IX y X Regiones, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar, con cerco, el recurso hidrobiol&#xF3;gico Pota del Atl&#xE1;ntico.</div><br></div>", "i": 6500142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6500143}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2712 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2712 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-21", "doble_articulado": false, "id_norma": "231159", "numero_fuente": "37981", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-08", "vigencias": [{"desde": "2004-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-08", "fin_vigencia": "