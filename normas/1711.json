{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CERTIFICADO </div></div>", "i": 5844932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 4,51% anual durante el mes de enero de 1992.</div><div class=\"p\">&nbsp; &nbsp; Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de enero de 1992, fue de 4,56% anual. </div></div>", "i": 5844933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de febrero de 1992.- Isaac Telias Ergas, Ministro de Fe subrogante.</div><br></div>", "i": 5844934}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "OPERACIONES", "CREDITO DINERO", "CAPTACION", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-02-06", "doble_articulado": false, "id_norma": "1711", "numero_fuente": "34187", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-02-07", "vigencias": [{"desde": "1992-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-02-07", "fin_vigencia": "", "tipo_