{"html": [{"t": "<div><div class=\"p\">CASA BLANCA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 14 de 1827.</div><div class=\"p\">&nbsp; &nbsp;  El Vice-Presidente de la Rep&#xFA;blica atendiendo a la solicitud del Procurador de la Villa de Casa-Blanca, y de acuerdo con la Comision Nacional, ha acordado y decreta: </div></div>", "i": 10245697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico. Costeando los vecinos del departamento de Casa-Blanca, casa capitular y carcel, quedan autorizados para elejir municipalidad con arreglo a las leyes vijentes. </div></div>", "i": 10245698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><div class=\"p\">&nbsp; &nbsp;  Ramos. Pro-Secret.</div></div>", "i": 10245699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CASA BLANCA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-12-14", "doble_articulado": false, "id_norma": "1156524", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-12-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1827-12-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-06-23", "fecha_version": "1827-12-14", "fecha_actualizacion_texto": "2021-06-23", "tipo_tratado": ""}, "alertas": [], "alerta_global