{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328248}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 255 de 18 de febrero de 1998 de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 262 de 1988, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a don BOLIVAR GUZMAN ACU&#xD1;A, para operar la nave</div><div class=\"p\">&quot;Santa Isabel I&quot;, en virtud de lo se&#xF1;alado en el</div><div class=\"p\">art&#xED;culo 143 letra b), del D.S. N&#xBA; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, por no haber operado en las pesquer&#xED;as autorizadas por m&#xE1;s de un a&#xF1;o.</div><br></div>", "i": 8328249}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de febrero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8328250}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "255", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-255"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "BOLIVAR GUZMAN ACU A", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-18", "doble_articulado": false, "id_norma": "97056", "numero_fuente": "36000", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-25", "vigencias": [{"desde": "1998-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única