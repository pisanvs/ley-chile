{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL INCISO 2&#xB0; DEL ARTICULO 1&#xB0; DE LA LEY N&#xB0; 7,593, DE 1946,</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5973712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Modif&#xED;case el inciso 2&#xB0; del</div><div class=\"p\">art&#xED;culo 1&#xB0; de la ley n&#xFA;mero 7,593, de 19 de Octubre de 1946, debiendo quedar en la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp; &quot;Dicho terreno ser&#xE1; destinado &#xFA;nicamente a campos deportivos denominados &quot;Estadio Municipal&quot; y para la construcci&#xF3;n de un edificio escolar&quot;.</div><br></div>", "i": 5973713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintis&#xE9;is de Agosto de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Francisco Cereceda.</div><br></div>", "i": 5973714}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14007", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14007"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "MODIFICA EL INCISO 2° DEL ARTICULO 1° DE LA LEY N°\n7,593, DE 1946,", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 7593"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-08-26", "doble_articulado": false, "id_norma": "27634", "numero_fuente": "24737", "tipo_version": "3", "tipo_version_s": "Única", "fech