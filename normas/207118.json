{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 5.499 EXENTA, DE 2001 </div></div>", "i": 6411895}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.499 de 8 de mayo del a&#xF1;o 2001, se ha aprobado al Colegio &quot;Cambridge College&quot; de Santiago, el siguiente plan de estudio para 1&#xBA;, 2&#xBA;, 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban los siguientes programas de estudio para los Subsectores que a continuaci&#xF3;n se se&#xF1;alan, de la Formaci&#xF3;n Diferenciada de 3&#xBA; y 4&#xBA; a&#xF1;o, cuyos programas ser&#xE1;n los oficiales aprobados por el Ministerio de Educaci&#xF3;n.</div><br></div>", "i": 6411896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de mayo de 2001- Juan Ruz Ruz, Jefe Divisi&#xF3;n Educaci&#xF3;n General.</div><br></div>", "i": 6411897}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5499 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5499 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.499 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-08", "doble_articulado": false, "id_norma": "207118", "numero_fuente": "37471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-29", "vigencias": [{"desde": "2003-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-29", "fin_vigencia": ""}, "vigencias_vers