{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6099618}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No.694, de 27 de Julio de 1989 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. 2186 de 1978, parte inmueble- ubicado en calle San Francisco No.485, presunto rol aval&#xFA;os No.597-7, comuna de Santiago, aparentemente dominio de don Jos&#xE9; Chanes Hern&#xE1;ndez. Comisi&#xF3;n integrada por peritos Sres. Gabriel Urrutia Benavente y Mario Vergara Navarrete, arquitectos y Walter Soto Silva, ingeniero civil, seg&#xFA;n informe de 24 de Noviembre de 1988, fij&#xF3; monto provisional indemnizaci&#xF3;n en $1.287.020.-, pagadera al contado.</div><br></div>", "i": 6099619}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6099620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "694", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-694"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-27", "doble_articulado": false, "id_norma": "95306", "numero_fuente": "33463", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-01", "vigencias": [{"desde": "1989-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1998-03-12", "fecha_version": "1989-09-01", "