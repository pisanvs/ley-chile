{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.844, de 28 de octubre de 1996, de esta Subsecretar&#xED;a de Pesca de Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0;, de la Resoluci&#xF3;n N&#xB0; 1.494, de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a CONSERVERA LEYMO S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a las l&#xED;neas de elaboraci&#xF3;n autorizadas, esto es, Conserva, Congelado, Deshidratado y Seco-salado, el recurso hidrobiol&#xF3;gico Caracol gigante.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la autorizaci&#xF3;n para procesar el recurso Jibia, contenida en el numeral 2&#xB0;, de la Resoluci&#xF3;n N&#xB0; 1.494, de 1996, de esta Subsecretar&#xED;a. </div></div>", "i": 8298406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de octubre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1844", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1844"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "CONSERVERA LEYMO S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-10-28", "fecha_derogacion": "1998-01-15", "doble_articulado": false, "id_norma": "37485", "numero_fuente": "35607", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-11-05"