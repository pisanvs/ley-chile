{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA</div><br><div class=\"p\">(Extracto)</div><br><br></div>", "i": 8314105}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n N&#xB0;. 1.024 de 21 de Agosto de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio del Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 30 d&#xED;as a contar de la fecha de la presente Resoluci&#xF3;n, el plazo para publicar el extracto en el Diario Oficial de la Resoluci&#xF3;n N&#xB0;. 410, de 05 de marzo de 1990, de esta Subsecretar&#xED;a, que autoriza a don Juan Ruiz. RUT N&#xB0;. 3.012.685-8, domiciliado en calle Juan Ch&#xE1;vez N&#xB0;. 82, Talcahuano, para iniciar actividades pesqueras, en raz&#xF3;n de haberse acreditado la existencia de fuerza mayor.</div><br></div>", "i": 8314106}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 21 de Agosto de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1024", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1024"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-21", "doble_articulado": false, "id_norma": "82747", "numero_fuente": "33770", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-09-14", "vigencias": [{"desde": "1990-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-09-14", "fin_vigencia": ""}, "vigencias_version_norma"