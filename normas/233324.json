{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A RED-SUR GANADEROS S.A.</div><br></div>", "i": 6508136}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n Ex. N&#xBA; 430, de 22 de noviembre de 2004, otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en las operaciones de venta de ganado vivo, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n al contribuyente Red-Sur Ganaderos S.A., RUT N&#xBA; 99.539.730-7, conforme a lo establecido en la Res. Ex.</div><div class=\"p\">N&#xBA; 3.721 de fecha 28.07.2000, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial del d&#xED;a 01.08.2000.</div><br></div>", "i": 6508137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 6508138}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "430 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-430 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A RED-SUR\nGANADEROS S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-22", "doble_articulado": false, "id_norma": "233324", "numero_fuente": "38034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-13", "vigencias": [{"desde": "2004-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v