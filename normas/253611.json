{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7332692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.623, de 13 de septiembre de 2006, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 2.- de la resoluci&#xF3;n N&#xBA;1.908 de 1989, modificada mediante las resoluciones N&#xBA; 249 de 1993 y N&#xBA;891 de 2002, todas de esta Subsecretar&#xED;a, que autorizaron a SOCIEDAD PESQUERA LANDES S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Huachinango&quot;, en el sentido de actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas de la nave:</div><br><div class=\"p\">Potencia principal&nbsp;  1876,00 Hp.</div><div class=\"p\">Capacidad de bodega&nbsp;  789,50 mt3 </div></div>", "i": 7332693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de septiembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7332694}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2623 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2623 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-09-13", "fecha_derogacion": "2011-12-03", "doble_articulado": false, "id_norma": "253611", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2006-09-28", "vigencias": [{"desde": "2011-12-03", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2006-09-28", "hasta": "2011-12-02", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia"