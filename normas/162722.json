{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6256205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;565, de 15 de marzo de 2000, de esta Subsecretar&#xED;a, ot&#xF3;rgase al INSTITUTO DE FOMENTO PESQUERO, Direcci&#xF3;n Zonal XII Regi&#xF3;n de Magallanes y Ant&#xE1;rtica Chilena, Punta Arenas, el plazo de 15 d&#xED;as contado desde la fecha en que la presente resoluci&#xF3;n le sea transcrita, para completar las actividades comprendidas en la pesca de investigaci&#xF3;n autorizada por resoluci&#xF3;n N&#xBA;103, del 2000, de esta Subsecretar&#xED;a, de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto &apos;&apos;Pesca de investigaci&#xF3;n del Osti&#xF3;n del Sur Chlamys vitrea en Bah&#xED;a Parry, Seno Almirantazgo, XII Regi&#xF3;n&apos;&apos;.</div><br></div>", "i": 6256206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de marzo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6256207}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "565", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-565"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-15", "doble_articulado": false, "id_norma": "162722", "numero_fuente": "36622", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-24", "vigencias": [{"desde": "2000-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-24", "fin_vige