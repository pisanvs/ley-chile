{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6097357}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 535 de 29 de mayo 1989 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186 de 1978, -parte inmueble- ubicado en calle Lira No. 485, presunto rol aval&#xFA;os No. 589-6, comuna de Santiago, aparentemente dominio de don Eugenio Figueroa Galecic. Comisi&#xF3;n integrada por peritos srs. Humberto Mattas Mendoza y Patricio Rojas Troncoso, ingenieros civiles y Jorge Searle Jouanne, arquitecto, seg&#xFA;n informe de 17 de noviembre 1988, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 4.888.740.-, pagadera al contado.</div><br></div>", "i": 6097358}, {"t": "<div><div class=\"p\">- Director SERVIU Metropolitano.</div><br></div>", "i": 6097359}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "535", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-535"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-29", "doble_articulado": false, "id_norma": "94537", "numero_fuente": "33398", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-15", "vigencias": [{"desde": "1989-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-03-06", "fecha_ver