{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8349925}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.639, de 31 de agosto de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; PATAGONIA SALMON FARMING S.A. para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 873, de 1995, N&#xBA; 33 y N&#xBA; 1.790, ambas de 1998, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Bah&#xED;a Ilque s/n, comuna de Puerto Montt, provincia de Llanquihue, X Regi&#xF3;n, en las l&#xED;neas de procesamiento de Fresco-Refrigerado y Congelado el recurso hidrobiol&#xF3;gico Bacalao de profundidad.</div><br></div>", "i": 8349926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de agosto de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8349927}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1639", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1639"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-31", "doble_articulado": false, "id_norma": "143278", "numero_fuente": "36464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-14", "vigencias": [{"desde": "1999-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient