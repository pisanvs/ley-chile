{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 385, DE 1990 </div></div>", "i": 6057027}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 385 de 28 de diciembre de 1990 se ha aprobado al Colegio Art&#xED;stico Salvador de Santiago, un plan especial de estudio para ser aplicado a partir del a&#xF1;o escolar 1991 en Ense&#xF1;anza B&#xE1;sica y hasta 3er. a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico - Cient&#xED;fica y a partir del a&#xF1;o escolar 1992 en 4&#xB0; a&#xF1;o medio. </div></div>", "i": 6057028}, {"t": "<div><div class=\"p\">Santiago, 16 de Septiembre 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br><br></div>", "i": 6057029}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "385 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-385 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 385, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "80326", "numero_fuente": "34118", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-16", "vigencias": [{"desde": "1991-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1997-12-19", "fecha_version": "1991-11-16", "fecha_actualizacion_texto"