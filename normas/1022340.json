{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9102938}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.948, de 30 de diciembre de 2010, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1010298&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 4.434 de 2009</a>, modificada por resoluci&#xF3;n exenta N&#xBA; 2.139 de 2010, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a UNIVERSIDAD CAT&#xD3;LICA DEL NORTE para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Seguimiento de la Pesquer&#xED;a de las Algas Pardas en la IV Regi&#xF3;n de Coquimbo&quot;, en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la citada pesca de investigaci&#xF3;n hasta el 31 de diciembre de 2011, inclusive.</div><br></div>", "i": 9102939}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9102940}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3948 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3948 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-30", "doble_articulado": false, "id_norma": "1022340", "numero_fuente": "39867", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-24", "vigencias": [{"desde": "2011-01-24", "hasta": ""