{"html": [{"t": "<div><div class=\"p\">MODIFICA EL DECRETO CON FUERZA DE LEY N.o 118, DE 1960 </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 167.- Santiago, 17 de Marzo de 1960.- Vistas las facultades que me confieren los art&#xED;culos 202 y siguientes de la ley N.o 13,305, vengo en dictar el siguiente,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto con fuerza de ley:</div><br></div>", "i": 7322867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase en el art&#xED;culo 1.o del decreto con fuerza de ley N.o 118, de 2 de marzo de 1960, el &quot;Grado 4.o&quot; que se le asigna a los Tenientes de los Servicios de Orden y Seguridad, Administrativo y de Veterinaria, por el &quot;Grado 3.o&quot;.</div><br></div>", "i": 7322868, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- J. ALESSANDRI R.- S. del R&#xED;o.- R. Vergara H.</div><br></div>", "i": 7322869}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "167", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-167"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA EL DECRETO CON FUERZA DE LEY N.o 118, DE 1960", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-03-17", "doble_articulado": false, "id_norma": "241849", "numero_fuente": "24605", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-03-28", "vigencias": [{"desde": "1960-03-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-03-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1960-03