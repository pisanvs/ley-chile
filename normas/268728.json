{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 2.057 EXENTO, DE 2007 </div></div>", "i": 7362554}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 2.057, de fecha 24 de octubre de 2007, del Ministerio de Educaci&#xF3;n, se deja sin efecto la aprobaci&#xF3;n del plan y programas de estudio de la carrera que se indica para el Centro de Formaci&#xF3;n T&#xE9;cnica CEDEP, aprobado por el acto administrativo correspondiente, a petici&#xF3;n de la propia entidad, dado que no registra matr&#xED;cula de alumnos en los &#xFA;ltimos seis a&#xF1;os:</div><br><div class=\"p\">&nbsp; &nbsp;  Carrera: T&#xE9;cnico en Desarrollo de Sistemas Computacionales</div><br><div class=\"p\">(D. Ex. N&#xBA; 421 del 9 de diciembre de 1999) </div></div>", "i": 7362555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de enero de 2008.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 7362556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2057 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2057 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 2.057 EXENTO, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-24", "doble_articulado": false, "id_norma": "268728", "numero_fuente": "38967", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-01-22", "vigencias": [{"desde": "2008-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-01-2