{"html": [{"t": "<div><div class=\"p\">AUTORIZA DISOLUCION DE &quot;DCV Registros S.A.&quot; </div></div>", "i": 6335825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por junta extraordinaria de accionistas de la sociedad DCV Registros S.A. celebrada con fecha 26 de marzo de 2001, cuya acta fue reducida a escritura p&#xFA;blica con fecha 2 de abril de 2001, ante el Titular de la 45&#xAA; Notar&#xED;a de Santiago, se&#xF1;or Ren&#xE9; Benavente Cash, domiciliado en Hu&#xE9;rfanos N&#xBA; 979, piso 7, se acord&#xF3; la disoluci&#xF3;n anticipada de la sociedad.</div><div class=\"p\">&nbsp; &nbsp;  Que por resoluci&#xF3;n N&#xBA; 176, de fecha 10 de mayo de 2001, esta Superintendencia de Valores y&nbsp; Seguros autoriz&#xF3; la disoluci&#xF3;n anticipada de la sociedad &quot;DCV Registros S.A.&quot;.</div><br></div>", "i": 6335826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de mayo de 2001.- Carmen Undurraga Mart&#xED;nez, Secretario General.</div><br></div>", "i": 6335827}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "176", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-176"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "AUTORIZA DISOLUCION DE DCV REGISTROS S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-10", "doble_articulado": false, "id_norma": "185580", "numero_fuente": "36968", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-23", "vigencias": [{"desde": "2001-05-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-23", "fin_vigenc