{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 193 EXENTO, DE 1999</div><br><br></div>", "i": 6198024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;193 de 14 de julio de 1999, se ha aprobado, a partir del a&#xF1;o escolar 1999, un programa de Religi&#xF3;n de la Iglesia Cat&#xF3;lica Apost&#xF3;lica Ortodoxa de Chile para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o de ense&#xF1;anza media, el que podr&#xE1; aplicarse conforme a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA;220 de 1998.</div><br></div>", "i": 6198025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de julio de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6198026}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "193", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-193"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 193 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-14", "doble_articulado": false, "id_norma": "145594", "numero_fuente": "36492", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-19", "vigencias": [{"desde": "1999-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-10-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-10-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-10-19", "fecha_version": "1999-10-19", "fecha