{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6371837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo dispuesto en el decreto del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, N&#xBA;291, de 11 de junio de 1999, publicado en el Diario Oficial de fecha 13 de agosto de 1999 y N&#xBA;668, de 16 de noviembre de 1999, certifico que por resoluci&#xF3;n (exenta) N&#xBA;55, de 18 de enero de 2002, del se&#xF1;or Vicepresidente Ejecutivo, totalmente tramitada, se puso en vigencia el nuevo Reglamento del Registro Nacional de Consultores en programas de cofinanciamiento de Corfo.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la antes referida resoluci&#xF3;n, estar&#xE1; a disposici&#xF3;n de los usuarios en la Secretar&#xED;a General de la Corporaci&#xF3;n y en las Direcciones Regionales.</div><br></div>", "i": 6371838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de febrero de 2002.- Yerko Koscina Peralta, Secretario General.</div><br></div>", "i": 6371839}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "55 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-55 EXENTA"}], "organismos": ["CORPORACIÓN DE FOMENTO DE LA PRODUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-01-18", "fecha_derogacion": "2003-06-24", "doble_articulado": false, "id_norma": "195291", "numero_fuente": "37204", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-03-07", "vigencias": [{"desde": "2003-06-24", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-03-07", "