{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,973.-&nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6193664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a la viuda del juez letrado de Coquimbo don Juan Ramon Pomar, do&#xF1;a Virjinia Mard&#xF3;nes viuda de Pomar, y a sus hijos menores, una pension de doscientos pesos ($ 200) mensuales, de que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.&quot; </div></div>", "i": 6193665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintinueve de agosto de mil novecientos veintitres.-&nbsp; Arturo Alessandri.-&nbsp; Alcib&#xED;ades Roldan.</div><br></div>", "i": 6193666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3973", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3973"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-08-29", "doble_articulado": false, "id_norma": "144257", "numero_fuente": "13697", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-10-09", "vigencias": [{"desde": "1923-10-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1923-10-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1923-10-09",