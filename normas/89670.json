{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTORES JUDICIALES A FUNCIONARIOS QUE INDICA (Resoluci&#xF3;n)</div><br><div class=\"p\">N&#xFA;m. 167.- Santiago, 22 de Octubre de 1990.- Vistos: Lo dispuesto en el Art. No. 11 del Decreto Ley No. 2.974.-</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 7224350}, {"t": "<div><div class=\"p\">Des&#xED;gnanse como Receptores Judiciales para que permanentemente practiquen las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley No. 2.974, en las Regiones I y II, a los se&#xF1;ores:</div><div class=\"p\">- Jos&#xE9; Luis Rivas Deville</div><div class=\"p\">- Gustavo Osvaldo Bravo Castillo</div><div class=\"p\">- Orlando Marcelo Miranda Ortega</div><div class=\"p\">- Nelson Herrera Tejas</div><br></div>", "i": 7224351}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese v publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional. </div></div>", "i": 7224352}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "167", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-167"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTORES JUDICIALES A FUNCIONARIOS QUE INDICA", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-10-22", "fecha_derogacion": "2011-02-17", "doble_articulado": false, "id_norma": "89670", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1990-11-15", "vigencias": [{"desde": "2011-02-17", "has