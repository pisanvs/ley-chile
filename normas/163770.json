{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6259423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 37, de fecha 28 de marzo de 2000, de Serviu Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiaci&#xF3;n, conforme art. 51 ley 16.391 y D.L. 2.186 de 1978, del inmueble denominado Lote 3 ubicado en localidad de Lagunillas de la comuna de Ovalle, presunto rol aval&#xFA;o 553-4 comuna de Ovalle, de aparentemente dominio de Comunidad Agr&#xED;cola Lagunillas Galleguillos del Valle, de una superficie aproximada de 9.382 metros cuadrados. Comisi&#xF3;n Peritos integrada por arquitectos do&#xF1;a Iris Marcich Moller, Alfredo Prieto Parra y Francisco Broquedis Marcich, seg&#xFA;n informe de 27 de marzo de 2000, fij&#xF3; monto provisional indemnizaci&#xF3;n en $1.876.400, pagadera al contado.-</div><br></div>", "i": 6259424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Regi&#xF3;n Coquimbo.</div><br></div>", "i": 6259425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "37", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-37"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-28", "doble_articulado": false, "id_norma": "163770", "numero_fuente": "36629", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-01", "vigencias": [{"desde": "2000-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-01", "fin_vigencia": ""}, "vigencias_ve