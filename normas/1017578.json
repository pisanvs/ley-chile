{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 1.320 EXENTO, DE 03.09.2010</div></div>", "i": 9013831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento que se indica del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas de estudio de la carrera Asistente Jur&#xED;dico del Centro de Formaci&#xF3;n T&#xE9;cnica Osorno, que se encuentran anexas y forman parte del presente decreto. Modif&#xED;case, en consecuencia, el <a href=\"https://www.leychile.cl/Navegar?idNorma=20781&amp;idParte=0&amp;idVersion=\">decreto exento de Educaci&#xF3;n N&#xBA; 242 del 25 de mayo de 1993</a>, en el sentido de incorporar dichas adecuaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones que se aprueban mediante este decreto, podr&#xE1;n aplicarse a contar del a&#xF1;o 2010.</div></div>", "i": 9013832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de septiembre de 2010.- Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9013833}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1320 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1320 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 1.320 EXENTO, DE 03.09.2010", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-09-03", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "1017578", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2010-10-05", "vigencias": [{"desde": "2015-06-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2010-10-05", "hasta": "201