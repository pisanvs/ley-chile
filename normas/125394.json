{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6133609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. No. 1.110, de 30 de julio de 1998, se expropiaron los lotes de terreno No. s. 6-A y 21, superficies 523,5 y 138 M2. respectivamente, roles de aval&#xFA;o 1404-7 y 1402-3, comuna de Puerto Varas, para la obra Camino Ampliaci&#xF3;n Ruta 5 Sur, Sector Puerto Varas-Puerto Montt y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Fredy Emig Droppelmann y Sociedad Gunther y Compa&#xF1;&#xED;a Limitada, ascendente a las cantidades de $ 1.767.77.- para el lote 6-A y $ 1.034.268.- para el lote 21.</div><br></div>", "i": 6133610}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6133611}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1110", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1110"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "PUERTO VARAS", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-30", "doble_articulado": false, "id_norma": "125394", "numero_fuente": "36177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-01", "vigencias": [{"desde": "1998-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificaci