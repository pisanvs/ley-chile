{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 2.424, DE 1989 </div><br><br></div>", "i": 7226238}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 2.424 de fecha 05 de septiembre de 1989 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se insert&#xF3; en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 1580 de 1985 del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Chileno Brit&#xE1;nico de Cultura de Vi&#xF1;a del Mar, las adecuaciones introducidas a la carrera de Traductolog&#xED;a y Traducci&#xF3;n e Interpretaci&#xF3;n, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1989. </div></div>", "i": 7226239}, {"t": "<div><div class=\"p\">Santiago, 26 de Octubre de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7226240}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2424 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2424 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 2.424, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-09-05", "fecha_derogacion": "2001-05-29", "doble_articulado": false, "id_norma": "91675", "numero_fuente": "33524", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-11-17", "vigencias": [{"desde": "2001-05-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-11-17", "hasta": "2001-05-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2001-05-29", "fin_v