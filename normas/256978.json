{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6595524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 899, de 14 de diciembre de 2006, se modific&#xF3; el numeral 6&#xBA; del decreto MOP exento N&#xBA; 271 de fecha 31 de mayo de 2006, en relaci&#xF3;n a la suma correspondiente a la imputaci&#xF3;n del gasto, siendo &#xE9;sta ascendente a la cantidad de ochocientos sesenta y dos mil cuatrocientos ochenta pesos ($862.480.-) y no como se expresa en el decreto modificado.</div><br></div>", "i": 6595525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6595526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "899 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-899 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-14", "doble_articulado": false, "id_norma": "256978", "numero_fuente": "38652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-02", "vigencias": [{"desde": "2007-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "2007-01-02", "fecha_version": "2007-01-02", "fecha_actualizacion_texto": "2007-01-02", "tipo_tratado": ""}, "alertas": [], "aler