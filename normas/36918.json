{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8949381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 1.416, de 31 de Diciembre de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., R.U.T. N&#xB0; 93.711.000-6, para ampliar actividades pesqueras que tiene autorizadas por resoluci&#xF3;n N&#xB0; 709, de 1985, de esta Subsecretar&#xED;a, en orden a operar la nave &quot;Lingueral&quot; en el Litoral de las Regiones VII a IX, donde podr&#xE1; extraer con cerco, el recurso Merluza de cola.</div><div class=\"p\">&nbsp; &nbsp; La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales o reglamentarias vigentes o que se establezcan.</div><br></div>", "i": 8949382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 31 de Diciembre de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8949383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1416", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1416"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "AUTORIZACION", "COMPAÑIA PESQUERA CAMANCHACA S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-12-31", "fecha_derogacion": "1996-08-14", "doble_articulado": false, "id_norma": "36918", "numero_fuente": "34478", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-01-29", "vigencias": [{"desde": "1996