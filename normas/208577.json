{"html": [{"t": "<div><div class=\"p\">CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A TRANSPORTE&nbsp; AGRICOLA Y FORESTAL EL ALAMO LIMITADA </div></div>", "i": 6417795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 14.- Certifico que Transporte Agr&#xED;cola y Forestal El Alamo Limitada, RUT N&#xBA; 78.640.950-0, cumple los requisitos establecidos en la resoluci&#xF3;n Ex.</div><div class=\"p\">N&#xBA;3.722/2002, y que en consecuencia tiene la calidad de agente retenedor del Impuesto al Valor Agregado en los Servicios de Faenamiento de Ganado que efect&#xFA;e a contar del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n del presente certificado en el Diario Oficial.</div><br></div>", "i": 6417796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 27 de febrero de 2003.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6417797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "14", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-14"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A\nTRANSPORTE AGRICOLA Y FORESTAL EL ALAMO LIMITADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-02-27", "doble_articulado": false, "id_norma": "208577", "numero_fuente": "37512", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-18", "vigencias": [{"desde": "2003-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-18", "fin_vigencia": ""}, "vigencias_vers