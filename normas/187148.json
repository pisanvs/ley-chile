{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6340866}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 698, de 30 de abril de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 16-A, superficie 4.560 m2., rol de aval&#xFA;o 141-150, comuna de Codegua, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Santiago - Talca y Acceso Sur a Santiago. By Pass Rancagua, Sexta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Sociedad Frut&#xED;cola Callejones Limitada, ascendente a la cantidad de $26.177.423.-.</div><br></div>", "i": 6340867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6340868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "698", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-698"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-30", "doble_articulado": false, "id_norma": "187148", "numero_fuente": "37001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-03", "vigencias": [{"desde": "2001-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-07-03", "fecha_version": "2001-07-03", "fecha_actualizacion_texto": "2001-07-03", "tipo_tratado": ""}, "alertas": [], "alerta_glob