{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8787835}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.228, de 24 de septiembre de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA PESSUR LIMITADA para ampliar actividades pesqueras extractivas con la nave &quot;Pesur I&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 33&#xBA; L.S. a la VIII Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con red de arrastre, sobre los siguientes recursos hidrobiol&#xF3;gicos: Besugo y Alfonsino.</div></div>", "i": 8787836}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de septiembre de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8787837}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3228 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3228 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSCRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-09-24", "doble_articulado": false, "id_norma": "1006933", "numero_fuente": "39478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-10-05", "vigencias": [{"desde": "2009-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-10-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-10-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part"