{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6400875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.285, de 21 de octubre de 2002, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 1.453 de 2002, de esta Subsecretar&#xED;a, que estableci&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Camar&#xF3;n nailon Heterocarpus reedi, declarada en estado de plena explotaci&#xF3;n y sometida a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral de la II a la VIII Regiones, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, al 31 de diciembre de 2001, en el sentido de incorporar el siguiente armador y nave:</div><br><div class=\"p\">Armador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Nave</div><div class=\"p\">Gonz&#xE1;lez Rivera, Marcelino&nbsp; &nbsp; &nbsp;  Walrus</div><br></div>", "i": 6400876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de octubre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6400877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2285", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2285"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-10-21", "fecha_derogacion": "2002-12-31", "doble_articulado": false, "id_norma": "203938", "numero_fuente": "37393", "tipo_version": "2", "tipo_vers