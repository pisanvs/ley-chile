{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6562828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 1.282, de 30 de noviembre de 2005, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP exento N&#xBA; 1.076, de 31 de julio de 2001, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote N&#xBA; 37-A. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 37-A, fijada por la Comisi&#xF3;n de Peritos, con fecha 10 de julio de 2000, en la cantidad de $415.000.</div><br></div>", "i": 6562829}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6562830}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1282 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1282 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-30", "doble_articulado": false, "id_norma": "247680", "numero_fuente": "38402", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-01", "vigencias": [{"desde": "2006-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACIO