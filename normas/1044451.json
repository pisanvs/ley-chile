{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 1.251 EXENTO, DE 2011</div></div>", "i": 9303902}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 962, de 28 de septiembre de 2012, de este Ministerio, modif&#xED;case el art&#xED;culo 8&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1035605&amp;idParte=&amp;idVersion=\">decreto exento N&#xBA; 1.251, de 2011, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, en sentido de se&#xF1;alar que la cuota global anual de captura de la unidad de pesquer&#xED;a de Langostino colorado en el &#xE1;rea mar&#xED;tima comprendida entre la XV a la IV Regiones, a&#xF1;o 2012, ascender&#xE1; a 2.100 toneladas, fraccionadas de la manera se&#xF1;alada en el decreto extractado.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9303903, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de septiembre de 2012.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9303904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "962 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-962 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 1.251 EXENTO, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-28", "doble_articulado": false, "id_norma": "1044451", 