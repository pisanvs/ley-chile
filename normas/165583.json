{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD PESQUERA ALBATROS LIMITADA, PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6265078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 801, de 02 de Diciembre de 1985, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n se autoriza a Sociedad Pesquera Albatros Limitada, domiciliada en Santiago, para instalar y operar un establecimiento de cultivo suspendido de osti&#xF3;n del Norte, en un &#xE1;rea de 201,5 hect&#xE1;reas ubicada en Bah&#xED;a de Mejillones del Sur, provincia de Antofagasta, II Regi&#xF3;n.</div><br></div>", "i": 6265079}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 02 de Diciembre de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6265080}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "801", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-801"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD PESQUERA ALBATROS LIMITADA, PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-12-02", "fecha_derogacion": "1988-02-05", "doble_articulado": false, "id_norma": "165583", "numero_fuente": "32352", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-12-20", "vigencias": [{"desde": "1988-02-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-12-20", "hasta": "1988-02-04", "tipo_version": "0", "tipo_version_s": "Texto Original"}],