{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6480078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.323, de 10 de mayo de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MARINOS S.A. ALIMAR, para ampliar actividades pesqueras extractivas con la nave &quot;Querelema&quot;, en las &#xE1;reas que en cada caso se indica, donde podr&#xE1; capturar los recursos que a continuaci&#xF3;n se se&#xF1;alan: a) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones III, IV, VII, IX y X, con cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima correspondiente a la III Regi&#xF3;n, con arrastre de media agua: Jibia; c) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones IV, VII, IX y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia.</div><br></div>", "i": 6480079}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de mayo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6480080}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1323 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1323 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-05-10", "fecha_derogacion": "2020-12-30", "doble_articulado": false, "id_norma": "225461", "numero_fuente": "37865", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-05-20", "vigencias": [{"desde": "2020-12-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Vers