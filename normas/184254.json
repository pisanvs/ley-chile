{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6331142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 581 de 9 de abril de 2001 de esta Subsecretar&#xED;a, modif&#xED;case el n&#xFA;mero 4&#xBA; de la resoluci&#xF3;n N&#xBA; 285 de 2001, que autoriz&#xF3; a la UNIVERSIDAD AUSTRAL DE CHILE para efectuar una pesca de investigaci&#xF3;n, en el sentido de reemplazar el arte de pesca autorizado por redes de monofilamento y polifilamento con trama de redes entre 32 y 45 mm. de longitud de barra. Rectif&#xED;case el n&#xFA;mero 3&#xBA;, en el sentido de reemplazar la expresi&#xF3;n &quot;IX Regi&#xF3;n&quot; por &quot;X Regi&#xF3;n&quot;.</div><br></div>", "i": 6331143}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de abril de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6331144}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "581", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-581"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-09", "doble_articulado": false, "id_norma": "184254", "numero_fuente": "36940", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-18", "vigencias": [{"desde": "2001-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v