{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6502051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.791, de 1 de octubre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a AGROINDUSTRIAL CLAUDIO MATTE Y COMPA&#xD1;IA LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Panamericana Sur kil&#xF3;metro 35, N&#xBA; 74, Buin, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Seco Salado, Ahumado, Harina, Alga Seca y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6502052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de octubre de 2004.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6502053}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2791 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2791 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-01", "doble_articulado": false, "id_norma": "231664", "numero_fuente": "37993", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-23", "vigencias": [{"desde": "2004-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por