{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6583112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 525, de 31 de julio de 2006, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP (exento) N&#xBA; 540, de 30 de abril de 2002, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote N&#xBA; 12. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 12, fijada por la comisi&#xF3;n de peritos, con fecha 14 de diciembre de 1999, ascendente a la cantidad de $336.295.- para el N&#xBA; 12.</div><br></div>", "i": 6583113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6583114}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "525 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-525 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-31", "doble_articulado": false, "id_norma": "253367", "numero_fuente": "38566", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-15", "vigencias": [{"desde": "2006-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones