{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6279936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as fue de 5,44% anual durante el mes de mayo de 2000.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xBA;5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de mayo de 2000, fue de 5,48% anual.</div><br></div>", "i": 6279937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de junio de 2000.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6279938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-02", "doble_articulado": false, "id_norma": "170261", "numero_fuente": "36682", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-06", "vigencias": [{"desde": "2000-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fech