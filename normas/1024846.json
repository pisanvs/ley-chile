{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9135443}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 945, de 19 de abril de 2011, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=258673&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 411, de 2007</a>, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA SUNRISE S.A. para realizar actividades pesqueras extractivas con la nave &quot;Isla Orcas&quot;, respecto de los recursos hidrobiol&#xF3;gicos autorizados en el numeral 3&#xBA; letra i) de la mencionada resoluci&#xF3;n, con el arte de pesca espinel, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div><br><br></div>", "i": 9135444, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de abril de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9135445}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "945 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-945 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-04-19", "doble_articulado": false, "id_norma": "1024846", "numero_fuente": "39945", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-04-27", "vigencias": [{"desde": "2011-04-27", "hasta": ""