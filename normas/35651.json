{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294397}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 825 de 29 de Octubre de 1993 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 348, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA TRAFALGAR S.A., R.U.T. N&#xB0; 95.449.000-9, para sustituir una nave en construcci&#xF3;n por la nave &quot;Oficina Progreso&quot;.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto, de modo parcial y s&#xF3;lo en lo concerniente a la nave &quot;Oficina Progreso&quot;, la Resoluci&#xF3;n N&#xB0; 1.673, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la empresa antes individualizada para ampliar actividades pesqueras extractivas.</div><br></div>", "i": 8294398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 29 de Octubre de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8294399}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "825", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-825"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA TRAFALGAR S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-10-29", "doble_articulado": false, "id_norma": "35651", "numero_fuente": "34710", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-08", "vigencias": [{"desde": "1993-11-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}