{"html": [{"t": "<div><div class=\"p\">DERECHOS DE APROVECHAMIENTO DE AGUAS SUBTERR&#xC1;NEAS CONSTITUIDOS SEG&#xDA;N LO DISPUESTO EN EL ART. 6&#xB0; TRANSITORIO DE LA LEY N&#xB0; 20.017 </div></div>", "i": 6906893}, {"t": "<div><div class=\"p\">Mediante las siguientes resoluciones, se han constituido derechos de aprovechamiento de aguas subterr&#xE1;neas, en virtud de lo dispuesto en el art&#xED;culo 6&#xB0; Transitorio de la Ley N&#xB0; 20.017 Meses de Noviembre y Diciembre:</div><br><div class=\"p\">&nbsp; &nbsp;  VER DIARIO OFICIAL DE 15.01.2009, P&#xC1;GINA 39 </div></div>", "i": 6906894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "S/N", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-S/N"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "DIRECCIÓN GENERAL DE AGUAS"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.440 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-16", "doble_articulado": false, "id_norma": "285071", "numero_fuente": "39262", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-15", "vigencias": [{"desde": "2009-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMG", "fecha_ingreso": "2009-01-15", "fecha_version": "2009-01-15", "fecha_actualizacion_texto": "2009-01-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 69