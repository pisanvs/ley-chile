{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho de jubilar al Administrador de Correos Ambulante del Ferrocarril, don Zenon Gaete Lei n&#xFA;m. 2,381.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275232}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, a don Zenon Gaete, Administrador de Correos ambulante del Ferrocarril del Sur, el derecho de jubilar con el sueldo &#xED;ntegro asignado a dicho empleo.</div><br></div>", "i": 8275233}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de Setiembre de 1910.- EMILIANO FIGUEROA.- Luis Izquierdo.</div><br></div>", "i": 8275234}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2381", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2381"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE DERECHO DE JUBILAR AL ADMINISTRADOR DE CORREOS AMBULANTE DEL FERROCARRIL, DON ZENON GAETE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ZENON GATE", "ADMINISTRADOR CORREOS AMBULANTE", "FERROCARRIL DEL SUR", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-09-24", "doble_articulado": false, "id_norma": "23281", "numero_fuente": "9799", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-09-28", "vigencias": [{"desde": "1910-09-28", "hasta": "", "tipo_version": "3", "tipo_versi