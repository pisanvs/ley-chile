{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO N&#xBA; 177 EXENTO, DE 1999</div><br><br></div>", "i": 6190887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 177 de fecha 8 de julio de 1999 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Inacap, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 1999: Sede N&#xBA; 31 - La Serena:</div><div class=\"p\">Carrera: Secretariado Ejecutivo Biling&#xFC;e con menci&#xF3;n en Comercio Exterior.</div><div class=\"p\">T&#xED;tulo: Secretario (a) Ejecutivo (a) Biling&#xFC;e con menci&#xF3;n en Comercio Exterior.</div><div class=\"p\">(Decreto exento N&#xBA; 342 del 18.06.99).</div><br></div>", "i": 6190888}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6190889}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "177 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-177 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DECRETO Nº 177 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-08", "doble_articulado": false, "id_norma": "143302", "numero_fuente": "36464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-14", "vigencias": [{"desde": "1999-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-14", "fin_vigencia": "