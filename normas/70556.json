{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302373}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 449, de 27 de marzo de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; ampl&#xED;ase por tres meses, a contar de la fecha de la presente Resoluci&#xF3;n, el plazo otorgado a PESQUERA ATLANTICA LIMITADA, para continuar las actividades pesqueras con la nave &quot;Limar&#xED;&quot;, autorizada por Resoluci&#xF3;n N&#xBA; 89, de 1997, de esta Subsecretar&#xED;a, por haberse acreditado la existencia de una fuerza mayor.</div><br></div>", "i": 8302374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de marzo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302375}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "449", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-449"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMPLIACION", "PLAZO", "PESQUERA ATLANTICA LIMITADA", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-27", "doble_articulado": false, "id_norma": "70556", "numero_fuente": "11.04.1997", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-11", "vigencias": [{"desde": "1997-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-04-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion