{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,217.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170193}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a don Eduardo Vigneaux el derecho de jubilar con el sueldo &#xED;ntegro de que actualmente disfruta como jefe del Servicio de Materiales de los Ferrocarriles del Estado.</div><br></div>", "i": 6170194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a siete de setiembre de mil novecientos nueve.- Pedro Montt.- Pedro Garc&#xED;a de la Huerta. </div></div>", "i": 6170195}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2217", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2217"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-09-07", "doble_articulado": false, "id_norma": "136879", "numero_fuente": "9502", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-09-28", "vigencias": [{"desde": "1909-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1909-09-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1909-09-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "