{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,590.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Aum&#xE9;ntase, por gracia, a cien pesos ($ 100) la pension mensual de montep&#xED;o militar que actualmente percibe do&#xF1;a Clara D&#xE1;vila, viuda de Sota, madre del capitan de guardias nacionales movilizadas, don Ramon Sota D&#xE1;vila.</div><br></div>", "i": 6172338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto,&nbsp; prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintinueve de diciembre de mil novecientos once.-Ramon Barros Luco.- Alejandro Huneeus. </div></div>", "i": 6172339}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2590", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2590"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-12-29", "doble_articulado": false, "id_norma": "137517", "numero_fuente": "10168", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-12-30", "vigencias": [{"desde": "1911-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-12-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v