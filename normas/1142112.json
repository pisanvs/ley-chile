{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 380 EXENTA, DE 15 DE ENERO DE 2020</div></div>", "i": 10099136}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=1009454&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 8.497, de 2009, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Scuola Italiana Arturo Dell&apos;Oro, RBD 1638-1, comuna de Valpara&#xED;so, Regi&#xF3;n de Valpara&#xED;so, en el sentido de sustituir el plan de estudio de 1&#xBA;, 2&#xBA;, 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10099137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de enero de 2020.- Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 10099138}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "380 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-380 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 380 EXENTA, DE 15 DE ENERO DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1722446", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-15", "doble_articulado": false, "id_norma": "1142112", "numero_fuente": "42573", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-02-07", "vigencias": [{"desde": "2020-