{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA PLAN REGULADOR </div></div>", "i": 5946421}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 76, de fecha 6 de Octubre de 1992, de la Secretar&#xED;a Ministerial Metropolitana de Vivienda y Urbanismo, se ha aprobado el Plano Seccional</div><div class=\"p\">&quot;Eliminaci&#xF3;n de tres calles proyectadas en zona industrial&quot;, mediante el cual se suprimen los trazados de calle Desv&#xED;o Ferroviario, entre Rodrigo de Araya y Quil&#xED;n; de calle Nueva, entre Rodrigo de Araya y Juan Mitjans, y de calle Juan Mitjans, entre Til-Til y Desv&#xED;o Ferroviario.-</div><br></div>", "i": 5946422}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Sergio Puyol Carre&#xF1;o, Alcalde.</div><br></div>", "i": 5946423}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "76", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-76"}], "organismos": ["MUNICIPALIDAD DE MACUL"], "titulo_norma": "MODIFICA PLAN REGULADOR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD MACUL", "PLANO SECCIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-06", "doble_articulado": false, "id_norma": "21875", "numero_fuente": "34429", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-30", "vigencias": [{"desde": "1992-11-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-11-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1992-11-30", "fecha_actualizacion_texto": "1992-11-30", "tip