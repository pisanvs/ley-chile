{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.587 EXENTA, DE 2004 </div></div>", "i": 6509756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.587 de 07.12.2004, del Ministerio de Transportes y Telecomunicaciones, se invalida la resoluci&#xF3;n exenta N&#xBA;858 de 29.06.2004, del Ministerio de Transportes y Telecomunicaciones, publicada en extracto en el Diario Oficial del 15.07.2004, que declara desierta la comuna de La Florida, en el concurso p&#xFA;blico de radiodifusi&#xF3;n sonora en M&#xED;nima Cobertura, correspondiente al segundo cuatrimestre de 2003.</div><br></div>", "i": 6509757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Subsecretaria de Telecomunicaciones.</div><br></div>", "i": 6509758}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1587 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1587 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.587 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-17", "doble_articulado": false, "id_norma": "233833", "numero_fuente": "38040", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-20", "vigencias": [{"desde": "2004-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "ur