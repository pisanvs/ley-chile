{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO EXENTO No. 239, DE 1991 </div></div>", "i": 6056664}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 239 de fecha 07 de Agosto de 1991 del Ministerio de Educaci&#xF3;n, se insert&#xF3; en la Resoluci&#xF3;n Exenta No. 2.439 de 1989 del Centro de Formaci&#xF3;n T&#xE9;cnica Osorno, las adecuaciones introducidas a la carrera de Secretariado Ejecutivo con especialidad en Automatizaci&#xF3;n de Oficinas. Por este mismo cuerpo legal se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica mencionado que fueran aprobadas por Resoluci&#xF3;n Exenta No. 2.439 de 1989.</div><br></div>", "i": 6056665}, {"t": "<div><div class=\"p\">Santiago, 08 de Noviembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6056666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "239 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-239 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DECRETO EXENTO No. 239, DE 1991", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-08-07", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "80138", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-12-17", "vigencias": [{"desde": "2015-06-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-12-17", "hasta": "2015-06-24", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2015-06-25", "fin_vigencia": ""}, "vigencia