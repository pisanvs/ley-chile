{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6152304}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 2.524, de 30 de noviembre de 1998, se expropiaron los lotes de terreno N&#xBA;s. 3 y 6, superficies 104 y 105 m2., respectivamente, roles de aval&#xFA;o en tr&#xE1;mite y 53-4, comuna de Coltauco, para la obra Camino Coltauco Cementerio Rol H-366, San Luis y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Eliana Moreno C&#xE1;ceres y Petronila Valenzuela P&#xE9;rez, ascendentes a las cantidades de $ 744.480.- para el lote 3 y $ 488.565.- para el lote 6.</div><br></div>", "i": 6152305}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6152306}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2524", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2524"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-30", "doble_articulado": false, "id_norma": "131172", "numero_fuente": "36278", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-02-01", "vigencias": [{"desde": "1999-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-02-03", "fecha_version": "1999-02-01", "fecha_actualizacion_texto": "1999-02-01", "tipo_tr