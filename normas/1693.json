{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CERTIFICADO </div></div>", "i": 8871201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n pata operaciones reajustables entre 90 y 65 d&#xED;as, correspondiente a la primera quincena de agosto de 1991, fue 5,22% anual.</div><br></div>", "i": 8871202}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 20 de agosto de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 8871203}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES PROMEDIO", "TIP", "AGO`91", "OPERACIONES", "CREDITO DINERO", "OPERACIONES REAJUSTABLES", "CAPTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-20", "doble_articulado": false, "id_norma": "1693", "numero_fuente": "34048", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-21", "vigencias": [{"desde": "1991-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-08-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1991-08-21", "fecha_actualizacion_texto": "1991-08-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "