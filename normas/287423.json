{"html": [{"t": "<div><div class=\"p\">AUTORIZA A EMISORES DE BOLETAS ELECTR&#xD3;NICAS</div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 22 de 12 de febrero de 2009, que autoriza a contribuyentes como emisores de boletas electr&#xF3;nicas.</div><br><br></div>", "i": 7435699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de boletas electr&#xF3;nicas, a contar del mes de febrero del 2009, a los contribuyentes RUT N&#xBA; 72.754.700-2 y RUT N&#xBA; 72.755.300-2.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internaet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de febrero de 2009.</div><br><br></div>", "i": 7435700}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "22 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-22 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A EMISORES DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-12", "doble_articulado": false, "id_norma": "287423", "numero_fuente": "39291", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-18", "vigencias": [{"desde": "2009-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-02-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-02-18", "fin_vigencia": "", "tip