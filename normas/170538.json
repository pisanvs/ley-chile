{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6280885}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 383, del 25 de Septiembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IV Regi&#xF3;n de Coquimbo, se autoriza a don Alejandro Ademir Alvarez Barahona para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva.</div><br></div>", "i": 6280886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, Septiembre de 1987.- Jorge Vargas Borcosky, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6280887}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "383 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-383 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-25", "doble_articulado": false, "id_norma": "170538", "numero_fuente": "32961", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-05", "vigencias": [{"desde": "1988-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-01-05", "fin_vigencia": "", "tipo_version": "3"}], "e