{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 462 EXENTO, DE 1997 </div></div>", "i": 6038837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 462, de fecha 21 de abril de 1997, del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Inacap, las modificaciones al plan y programas de estudios de la carrera de Secretariado Ejecutivo Computacional, para ser impartida en todas las Sedes que contaban con su autorizaci&#xF3;n, a contar del a&#xF1;o 1997, con la siguiente denominaci&#xF3;n:</div><br><br><div class=\"p\">Carrera&nbsp; &nbsp; : Secretariado Ejecutivo Computacional, cambia por:</div><div class=\"p\">Carrera&nbsp; &nbsp; : Secretariado Gerencial menci&#xF3;n Inform&#xE1;tica.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp;  : Secretario (a) de Gerencia menci&#xF3;n Inform&#xE1;tica.</div><br></div>", "i": 6038838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de mayo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6038839}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "462 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-462 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 462 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA INACAP", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-21", "doble_articulado": false, "id_norma": "73430", "numero_fuente": "35784", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-07", "vigencias": [{"desde": "