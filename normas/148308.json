{"html": [{"t": "<div><div class=\"p\">DECLARA CADUCIDAD DE LA RESOLUCION QUE INDICA </div></div>", "i": 8542647}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 428, de 08 de Mayo de 1987, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, se declara la caducidad de la</div><div class=\"p\">resoluci&#xF3;n No. 577, de 12 de Septiembre de 1985, de esta</div><div class=\"p\">entidad, que autoriz&#xF3; a don C&#xE9;sar Gacit&#xFA;a Bravo para</div><div class=\"p\">desarrollar actividades pesqueras, por haber incurrido</div><div class=\"p\">su titular en la causal establecida en el inciso 1&#xB0; del</div><div class=\"p\">art&#xED;culo 7&#xB0; del Decreto No. 175, de 1980, del Ministerio de Econom&#xED;a.</div><br></div>", "i": 8542648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 08 de Mayo de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8542649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "428", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-428"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DECLARA CADUCIDAD DE LA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-08", "doble_articulado": false, "id_norma": "148308", "numero_fuente": "32773", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-18", "vigencias": [{"desde": "1987-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci