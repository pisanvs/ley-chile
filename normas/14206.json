{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REASUME MANDO DEL ESTADO Santiago, 29 de Julio de 1990.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 555.- Visto: Lo dispuesto en los art&#xED;culos 29&#xB0; y 32&#xB0;, N&#xB0; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica Decreto:</div><br></div>", "i": 8263803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: D&#xE9;jase constancia que a contar de esta fecha, S.E. el Presidente de la Rep&#xFA;blica, don Patricio Aylwin Az&#xF3;car, ha reasumido el mando del Estado, con motivo de su retorno al pa&#xED;s.</div><br></div>", "i": 8263804}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Enrique Krauss Rusque, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8263805}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "555", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-555"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE DE LA REPUBLICA", "PATRICIO AYLWIN AZOCAR", "MANDO DE LA NACION", "REASUME."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-29", "doble_articulado": false, "id_norma": "14206", "numero_fuente": "33740", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-08", "vigencias": [{"desde": "1990-08-08", "hasta": "", "tipo_version": "3",