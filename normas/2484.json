{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA </div></div>", "i": 5852886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Decreto Secc. 2da. N&#xB0; 470, 13/09/1996, Alcalde Municipalidad Santiago dispone expropiaci&#xF3;n parcial, conforme art. 85 Decreto 458 Ministerio Vivienda y Urbanismo inmueble San Francisco 1884 Rol N&#xB0; 3707-101, comuna Santiago, dominio aparente Oscar Cancino Vald&#xE9;s, superficie aproximada 45 metros cuadrados. Deslindes: Norte, 5 mts. espacio uso p&#xFA;blico; Sur, 5 mts. otro propietario; Oriente, 9 mts. resto propiedad y Poniente, 9 mts. San Francisco. Indemnizaci&#xF3;n $4.195.000.- pagadera contado.</div><br></div>", "i": 5852887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jaime Ravinet de la Fuente, Alcalde Santiago. </div></div>", "i": 5852888}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "470", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-470"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "DISPONE EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTIAGO", "REGION", "METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-09-13", "doble_articulado": false, "id_norma": "2484", "numero_fuente": "35579-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-10-01", "vigencias": [{"desde": "1996-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-10-01", "fin_vigencia": "", "tipo_version": "3"}], "