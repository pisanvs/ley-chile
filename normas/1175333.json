{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10329244}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 450, de 11 de marzo de 2022, extiende vigencia de los certificados de calibraci&#xF3;n y suspende prestaciones que indica del Departamento de Salud Ocupacional.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.-</div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10329245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10329246}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "450 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-450 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2119268", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-03-11", "doble_articulado": false, "id_norma": "1175333", "numero_fuente": "43237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-04-26", "vigencias": [{"desde": "2022-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2022-04-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "10418", "fech