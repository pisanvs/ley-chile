{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10075416}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 2.863, de 11 de noviembre de 2019, modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1130908&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 909, del 12 de abril de 2019</a>, que aprueba gu&#xED;a para la selecci&#xF3;n y control de equipos de protecci&#xF3;n respiratoria, elaborada por el Depto. Salud Ocupacional del Instituto de Salud P&#xFA;blica de Chile y deja sin efecto resoluci&#xF3;n que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><br></div>", "i": 10075417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mar&#xED;a Soledad Vel&#xE1;squez Urrutia, Directora Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10075418}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2863 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2863 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1690261", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-11-11", "doble_articulado": false, "id_norma": "1139426", "numero_fuente": "42518", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-12-03", "vigencias": [{"desde": "2019-12-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-12-03", "fin_vigenci