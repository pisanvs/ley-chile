{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.626 EXENTO, DE 2007 </div></div>", "i": 6631396}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.626 de fecha 20 de agosto de 2007 del Ministerio de Educaci&#xF3;n, se aprueba las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Juan Bohon, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, a contar de agosto del a&#xF1;o 2007, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera&nbsp;  : Administraci&#xF3;n de Empresa con menci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Finanzas; cambia por:</div><br><div class=\"p\">Carrera&nbsp;  : Administraci&#xF3;n de Empresas</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; : T&#xE9;cnico de Nivel Superior en Administraci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; de Empresas (DEX N&#xBA; 271 de fecha 20 de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; julio de 2000)</div><br></div>", "i": 6631397}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de noviembre de 2007.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6631398}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1626 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1626 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.626 EXENTO, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-20", "doble_articulado": false, "id_norma": "266996", "numero_fuente": "38925", "