{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION&nbsp; N&#xBA; 12 EXENTA,DE 2001 </div></div>", "i": 6325482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por res. ex. N&#xBA; 12 de 28 de febrero de 2001, se declara que las copias de declaraciones de impuestos obtenidas a trav&#xE9;s del sitio web del Servicio de Impuestos Internos (www.sii.cl) y los Certificados de Recepci&#xF3;n de declaraciones de impuestos presentadas por Internet, corresponden a la informaci&#xF3;n mantenida en la base de datos del Servicio de Impuestos Internos, a la fecha de su emisi&#xF3;n, y el documento en que consta es apto para ser presentado, para cualquier tr&#xE1;mite, ante personas naturales o jur&#xED;dicas o ante agrupaciones o entidades sin personalidad jur&#xED;dica.</div><div class=\"p\">&nbsp; &nbsp;  La resoluci&#xF3;n se publicar&#xE1; en extenso en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y en el Bolet&#xED;n del Servicio del mes de marzo.-</div><br></div>", "i": 6325483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Javier Etcheberry Celhay, Director.</div><br></div>", "i": 6325484}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 12 EXENTA,DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-28", "doble_articulado": false, "id_norma": "182609", "numero_fuente": "36905", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-06", "vigencias"