{"html": [{"t": "<div><div class=\"p\">LEY NUM. 16.098</div><br><div class=\"p\">MODIFICA LA LEY N.o 13.529, DE 1959</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6557018}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zase en el inciso primero del art&#xED;culo &#xFA;nico de la ley N.o 13.529, de 14 de Octubre de 1959, la expresi&#xF3;n &quot;8 a&#xF1;os&quot; por &quot;9 a&#xF1;os. </div></div>", "i": 6557019}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a seis de Enero de mil novecientos sesenta y cinco.- EDUARDO FREI MONTALVA.- Sergio Molina S.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a U. para su conocimiento.- Dios guarde a U.- Andr&#xE9;s Zald&#xED;var Larra&#xED;n, Subsecretario de Hacienda.</div><br></div>", "i": 6557020}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16098", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16098"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY N.o 13.529, DE 1959", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1965-01-06", "doble_articulado": false, "id_norma": "246196", "numero_fuente": "26047", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1965-01-23", "vigencias": [{"desde": "1965-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],