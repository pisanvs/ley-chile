{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8335699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.379, de 29 de septiembre de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a CULTIVOS MARINOS TONGOY S.A., para continuar desarrollando las actividades pesqueras autorizadas por resoluciones N&#xBA;289, de 1983, N&#xBA;298, de 1987, N&#xBA;316, de 1988, todas de esta Subsecretar&#xED;a, a Cultivos Marinos Tongoy Limitada, en virtud de la escritura p&#xFA;blica de modificaci&#xF3;n de sociedad de fecha 28 de septiembre de 1988, otorgada ante el Notario P&#xFA;blico de Santiago, don Enrique Morgan Torres, que modific&#xF3; y transform&#xF3; a &apos;&apos;Cultivos Marinos Tongoy Limitada&apos;&apos; en &apos;&apos;Cultivos Marinos Tongoy S.A.&apos;&apos;. </div></div>", "i": 8335700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de septiembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8335701}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1379", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1379"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "CULTIVOS MARINOS TONGOY S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-09-29", "doble_articulado": false, "id_norma": "125829", "numero_fuente": "36186", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-13", "vigencias": [{"desde": "1998-10-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici