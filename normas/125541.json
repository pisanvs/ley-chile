{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  EXTRACTO DE RESOLUCION</div><br></div>", "i": 6134011}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.362 de 29 de Diciembre de 1988, se adjudica a &quot;A. Denham y C&#xED;a. Ltda.&quot; La concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar del 01 de enero de 1989, un establecimiento ubicado en Avenida Fresia No. 2133, de Renca, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de buses y taxibuses cuyo &#xFA;ltimo d&#xED;gito de su placa patente &#xFA;nica sea cero o par, que presten servicio de transporte p&#xFA;blico en el Gran Santiago y de aquellos cuyos servicios tengan origen o destino en esta ciudad, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6134012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel J. G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6134013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1362 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1362 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-29", "doble_articulado": false, "id_norma": "125541", "numero_fuente": "33260", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-12-31", "vigencias": [{"desde": "1988-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig