{"html": [{"t": "<div><div class=\"p\">CLAUSURA DEL CONGRESO.</div><br><div class=\"p\">&nbsp; &nbsp;  A S.E. EL PRESIDENTE DE LA REP&#xDA;BLICA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 18 de 1832.</div></div>", "i": 10255335}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Concluyendo hoi el per&#xED;odo por que las C&#xE1;maras prorrogaron sus sesiones, la de Senadores ha cerrado las suyas a las nueve y cuarto de la noche, dejando en su receso la Comision permanente.</div></div>", "i": 10255336}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Dios guarde a V.e.- AGUSTIN DE VIAL.- Fernando Urizar Garfias, Pro-Secretario.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 20 de 1832.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon donde corresponda y ac&#xFA;sese recibo.</div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO</div><br><div class=\"p\">&nbsp; &nbsp;  Tocornal.</div></div>", "i": 10255337}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "CLAUSURA DEL CONGRESO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-10-20", "doble_articulado": false, "id_norma": "1161645", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-10-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-10-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci