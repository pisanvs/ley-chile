{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9722546}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP N&#xB0; 358 de 12 de julio de 2016, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1089935&amp;idParte=0&amp;idVersion=\">Decreto (Exento) MOP N&#xB0; 78 de 15 de marzo de 2016</a>, que orden&#xF3; la expropiaci&#xF3;n del Lote N&#xB0; 1, en la parte que se refiere al nombre del propietario seg&#xFA;n rol de aval&#xFA;o y rol de aval&#xFA;o, seg&#xFA;n certificado de aval&#xFA;o emitido por el Servicio de Impuestos Internos, quedando como a continuaci&#xF3;n se indica: LOTE 1, CEA ROMERO VICENTE, rol de aval&#xFA;o 336-67, Comuna de LAJA, superficie 650 m2. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xB0; 2.186, de 1978.</div></div>", "i": 9722547}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "358 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-358 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1047649", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-07-12", "doble_articulado": false, "id_norma": "1093636", "numero_fuente": "41534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-08-16", "vigencias": [{"desde": "2016-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2016-08-16", "fin_vig