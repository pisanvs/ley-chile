{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6475811}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 932, de 6 de abril de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Lascar&quot;, en las &#xE1;reas mar&#xED;timas que se indican, donde podr&#xE1; capturar el recurso Jibia: a) En el &#xE1;rea de la III a IV, VIII y X Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con cerco; b) En la III Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con arrastre de media agua; c) En el &#xE1;rea de la IV, VIII y X Regi&#xF3;n, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua.</div><br></div>", "i": 6475812}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6475813}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "932 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-932 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-04-06", "fecha_derogacion": "2004-12-07", "doble_articulado": false, "id_norma": "224362", "numero_fuente": "37849", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-30", "vigencias": [{"desde": "2004-12-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-04-30", "hasta": "2004-12-06", "tipo_version": "0", "tipo_v