{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; EXTRACTO DE RESOLUCION EXENTA No. 1.656, DE 1988 </div></div>", "i": 6152000}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.656 de fecha 23 de junio de 1988, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas al siguierite plan y programas de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Pit&#xE1;goras, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1988 en la Sede Central Concepci&#xF3;n y Sedes de Talca, Temuco, Chill&#xE1;n, Los Angeles y Valdivia, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera: Contabilidad General menci&#xF3;n Computaci&#xF3;n T&#xED;tulo: Contador General menci&#xF3;n Computaci&#xF3;n </div></div>", "i": 6152001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Agosto de 1988.- Ren&#xE9; Salam&#xE9; Martin Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6152002}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1656 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1656 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.656, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-06-23", "fecha_derogacion": "2021-12-31", "doble_articulado": false, "id_norma": "131062", "numero_fuente": "33176", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-09-20", "vigencias": [{"desde": "2021-12-31", "hasta": "", "tipo_version"