{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A CONTRIBUYENTES QUE INDICA </div></div>", "i": 6426348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional Valpara&#xED;so, revoca la calidad de agente retenedor del Impuesto al Valor Agregado en las ventas que se indican de los contribuyentes que se se&#xF1;alan:</div><br><br><div class=\"p\">Contribuyente&nbsp;  RUT N&#xBA;&nbsp; &nbsp; &nbsp; Res. N&#xBA;&nbsp; Fecha&nbsp;  Ventas de</div><br><div class=\"p\">Fernando</div><div class=\"p\">Labayru y</div><div class=\"p\">C&#xED;a. Limitada&nbsp; 79.766.710-2&nbsp; 26&nbsp; &nbsp;  20.05.2003&nbsp; Harina</div><div class=\"p\">Oscar Ra&#xFA;l</div><div class=\"p\">Cofr&#xE9;</div><div class=\"p\">Adasme&nbsp; &nbsp; &nbsp; &nbsp;  5.825.873-3&nbsp;  27&nbsp; &nbsp;  30.05.2003&nbsp; Harina</div><br><div class=\"p\">&nbsp; &nbsp;  A contar de la fecha de la publicaci&#xF3;n de este extracto en el Diario Oficial conforme a la facultad delegada en el dispositivo 17 de la resoluci&#xF3;n exenta N&#xBA; 5.282 del 30.11.2000, emanada de la Direcci&#xF3;n Nacional de este Servicio.</div><br></div>", "i": 6426349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de junio de 2003.- Erica Morales Lartiga, Directora Regional.</div><br></div>", "i": 6426350}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "26", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-26"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A\nCONTRIBUYENTES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "der