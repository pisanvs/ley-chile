{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6253768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 408, 16 de mayo de 1985, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza al se&#xF1;or Manual Ren&#xE9; Saldivia Ruiz, para efectuar servicio internacional de transporte terrestre de pasajeros entre &quot;Puerto Natales (Chile) y Villa Minera R&#xED;o Turbio - 28 de Noviembre (Argentina), por Paso La Dorotea (Mina Uno) o La Laurita - Casas Viejas, en caso de intransitabilidad del primero, efectuando dos servicios diarios de ida y vuelta de Lunes a Viernes y un servicio diario de ida y vuelta los d&#xED;as S&#xE1;bados, Domingos y feriados.-</div><br></div>", "i": 6253769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos Villegas Lorca, Subsecretario de Transportes subrogante.</div><br></div>", "i": 6253770}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "408", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-408"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-16", "doble_articulado": false, "id_norma": "161930", "numero_fuente": "32195", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-13", "vigencias": [{"desde": "1985-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-13", "fin_vigencia