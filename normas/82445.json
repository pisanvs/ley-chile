{"html": [{"t": "<div><div class=\"p\">CONCEDE PLAZO QUE INDICA</div><br><br></div>", "i": 8580967}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 954 de 08 de Agosto de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se concede un plazo de 30 d&#xED;as a contar de la fecha de la presente resoluci&#xF3;n, a don Pedro M. Osorio Bradley, R.U.T. No. 7.061.162-7, domiciliado en Llolleo, Santa Luc&#xED;a No. 140, para publicar el extracto de la resoluci&#xF3;n No. 84, de 1990, de esta Subsecretar&#xED;a, por la cual se le autoriz&#xF3; para iniciar actividades pesqueras extractivas, con motivo de haberse acreditado la ocurrencia de fuerza mayor.</div><br></div>", "i": 8580968}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 08 de Agosto de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8580969}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "954", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-954"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "CONCEDE PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-08", "doble_articulado": false, "id_norma": "82445", "numero_fuente": "33758", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-30", "vigencias": [{"desde": "1990-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-08-30", "fin_vigencia": "", "tipo_version": "3"}],