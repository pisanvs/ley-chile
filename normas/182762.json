{"html": [{"t": "<div><div class=\"p\"> EXTRACTO DE RESOLUCION N&#xBA; 13 EXENTA, DE 2001 </div></div>", "i": 6694297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Materia: Autoriza al Banco del Estado de Chile a no emitir documentos internos por comisiones asociadas a cuentas&nbsp; de ahorro.</div><br><div class=\"p\">&nbsp; &nbsp;  1&#xBA; Se autoriza al Banco del Estado de Chile a sustituir por un archivo magn&#xE9;tico los documentos internos que actualmente emite conforme a la Res. Ex. N&#xBA; 1.110, del 30.08.1978, en reemplazo de boletas de ventas y servicios por concepto de comisiones trimestrales asociadas a cuentas de ahorro por saldos inmovilizados.</div><br><div class=\"p\">&nbsp; &nbsp;  2&#xBA; La presente resoluci&#xF3;n regir&#xE1; a contar de la fecha de su publicaci&#xF3;n en el Diario Oficial.- </div></div>", "i": 6694298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Javier Etcheberry Celhay, Director.</div><br></div>", "i": 6694299}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-13 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 13 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["RESOLUCION SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "182762", "numero_fuente": "36911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-13", "vigencias": [{"desde": "2001-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-13", "fin_vigencia": ""}, "vigenc