{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 465, de 31 de marzo de 1997, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura N&#xBA; 93106069, presentada por</div><div class=\"p\">LUIS EVARISTO ROA MORALES, para un centro de cultivo</div><div class=\"p\">ubicado al Norte de Isla Linagua, Sureste Isla</div><div class=\"p\">Pichiguapi, Estero Yaldad, Comuna de Quell&#xF3;n, Provincia</div><div class=\"p\">de Chilo&#xE9;, X Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 78&#xBA; y 87&#xBA; de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xBA; del D.S. N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8302283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de marzo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "465", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-465"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "LUIS EVARISTO ROA MORALES", "DENEGACION", "QUELLON", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-26", "doble_articulado": false, "id_norma": "70453", "numero_fuente": "35735", "tipo_versi