{"html": [{"t": "<div><br><br><div class=\"p\">DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES</div><br><br><div class=\"p\">&nbsp; &nbsp;  PANTEON.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 13 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto:</div></div>", "i": 10071921}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Se guardaran exactamente las disposiciones prevenidas en el decreto Supremo de 21 de Julio del a&#xF1;o pasado, inserto con el n&#xFA;m. 113 en el Boletin n&#xFA;m. 13.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; El administrador del Panteon es responsable de la infraccion de cualquiera de dichas disposiciones; y dar&#xE1; cuenta al Gobierno de hallarse actualmente en observancia. Trascr&#xED;basele este decreto, e ins&#xE9;rtese en el Boletin.</div><br></div>", "i": 10071922}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Errazuriz.</div><br><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.</div></div>", "i": 10071923}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES; PANTEON", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-02-13", "doble_articulado": false, "id_norma": "1138340", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc