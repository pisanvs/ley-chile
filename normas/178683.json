{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 492 EXENTO, DE 2000 </div></div>", "i": 6311547}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 492 se autoriz&#xF3; a la Universidad de Aconcagua para impartir la carrera profesional y la carrera t&#xE9;cnica que se se&#xF1;alan, a contar del a&#xF1;o 2000, en la sede de Santiago en la direcci&#xF3;n que se indica:</div><br><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Ingenier&#xED;a de Ejecuci&#xF3;n en Comercio</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Internacional</div><div class=\"p\">T&#xED;tulo profesional : Ingeniero de Ejecuci&#xF3;n en Comercio</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Internacional.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (Miguel Claro N&#xBA; 1194-Providencia).</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Analista Programador</div><div class=\"p\">T&#xED;tulo t&#xE9;cnico&nbsp; &nbsp;  : T&#xE9;cnico de Nivel Superior de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Analista Programador (Miguel Claro</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  N&#xBA; 1194-Providencia).</div><br></div>", "i": 6311548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de noviembre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6311549}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "492 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-492 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 492 EXENTO, DE 2000", "fuente": "Diario Of