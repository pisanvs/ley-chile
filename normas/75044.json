{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.148, de 08 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xBA; 906, de 1997, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones habilitados para operar en la unidad de pesquer&#xED;a del Camar&#xF3;n nailon Heterocarpus reedi, en el litoral de la II a la VIII Regiones, se&#xF1;alada en el Art&#xED;culo 1&#xBA;, del D.S. N&#xBA; 611 de 1995, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, en el sentido de incorporar en el numeral 1&#xBA; lo siguiente: &quot;Pesquera Desa Ltda.: Puma I&quot;. </div></div>", "i": 8305696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 08 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305697}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1148", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1148"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "NOMINA DE ARMADORES", "CAMARON NAILON", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-08-08", "fecha_derogacion": "1998-01-24", "doble_articulado": false, "id_norma": "75044", "numero_fuente": "35846", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-08-20", "vigencias": [{