{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Reconstruccion del Congreso Nacional Lei n&#xFA;m.1,171.- Santiago, a 27 de Enero de 1899.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de doscientos setenta i tres mil pesos en la terminacion de los trabajos de reconstruccion del edificio del Congreso Nacional.</div><div class=\"p\">&nbsp; &nbsp; Esta lei comenzar&#xE1; a rejir desde la fecha de su publicacion en el Diario Oficial.</div><br><br></div>", "i": 8274129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8274130}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1171", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1171"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "RECONSTRUCCION DEL CONGRESO NACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "EDIFICIO", "RECONSTRUCCION", "FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-27", "doble_articulado": false, "id_norma": "22446", "numero_fuente": "6212", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-27", "vigencias": [{"desde": "1899-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici