{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6573882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.479, de 2 de junio de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a ATLANTIC PEARL CHILE LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Km. 12, camino Chill&#xE1;n a Yungay, sector Quilmo, Chill&#xE1;n Viejo, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga seca, el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada.</div><div class=\"p\">D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 4.541 de 2005, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6573883}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de junio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6573884}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1479 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1479 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-02", "doble_articulado": false, "id_norma": "250728", "numero_fuente": "38494", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-21", "vigencias": [{"desde": "2006-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic