{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 991.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.-Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta trescientos cincuenta mil pesos en los servicios de la Guardia Nacional.</div><div class=\"p\">&nbsp; &nbsp; Esta autorizacion durar&#xE1; por el t&#xE9;rmino de tres meses.</div><br><br></div>", "i": 5948104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a cuatro de enero de mil ochocientos noventa i ocho.- FEDERICO ERRAZURIZ.-Patricio Larrain A. </div></div>", "i": 5948105}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "991", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-991"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GUARDIA NACIONAL", "SERVICIOS", "FONDOS", "INVERSION."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-04", "doble_articulado": false, "id_norma": "22328", "numero_fuente": "5896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-07", "vigencias": [{"desde": "1898-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-01-07", "fin_vigencia": "", "ti