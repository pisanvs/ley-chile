{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 134 EXENTO, DE 1994 </div></div>", "i": 8605589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 134 de fecha 29 de marzo de 1994 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Sim&#xF3;n Bol&#xED;var las adecuaciones introducidas al Plan y Programas de Estudios de la Carrera de An&#xE1;lisis de Sistemas, las que se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 1.083 de 1989. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1994.</div><br></div>", "i": 8605590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 20 de Mayo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8605591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "134 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-134 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 134 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA SIMON BOLIVAR", "MODIFICACION", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "ANALISIS SISTEMA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-29", "doble_articulado": false, "id_norma": "20345", "numero_fuente": "34878", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-05-31", "vigencias": [{"desde": "1994-05-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-05-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-05-31", "fin_vigencia": "", "tipo_version"