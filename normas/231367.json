{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6500979}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP Exento N&#xBA; 1.305 de 20 de Septiembre de 2004, se dej&#xF3; sin efecto los numerales 3&#xBA; , 4&#xBA; , 5&#xBA; y 6&#xBA; del decreto MOP, exento N&#xBA; 1.139 de 30 de septiembre de 2003, en la parte que se refiere al convenio directo de precio ad refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmenge el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 1, fijada por la Comisi&#xF3;n de Peritos, con fecha 12 de octubre de 2001, ascendente a la cantidad de $611.800.- para el lote N&#xBA; 1.</div><br></div>", "i": 6500980}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6500981}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1305 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1305 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-20", "doble_articulado": false, "id_norma": "231367", "numero_fuente": "37986", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-15", "vigencias": [{"desde": "2004-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"te