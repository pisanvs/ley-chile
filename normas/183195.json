{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 95, DE 1990 </div></div>", "i": 6327633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 95 de 7 de marzo de 1990 se ha aprobado por un per&#xED;odo de seis a&#xF1;os, a contar desde 1990, a la Escuela Especial E No. 13 de Copiap&#xF3;, III Regi&#xF3;n de Atacama, un plan especial de estudio de orientaci&#xF3;n laboral para alumnos discapacitados. </div></div>", "i": 6327634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 09 de Marzo de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6327635}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "95 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-95 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 95, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-07", "doble_articulado": false, "id_norma": "183195", "numero_fuente": "33624", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-19", "vigencias": [{"desde": "1990-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-03-23", "fecha_version": "1990-03-19", "fecha_actualizacion_texto": "1990-03-19", "tipo_tratado": ""}, "alertas": [], "alerta_global