{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension Lei n&#xFA;m. 94.- Santiago, a 6 de Setiembre 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946750}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a do&#xF1;a Carolina Larenas Pradel, hija de don Adolfo Larenas i nieta del teniente-coronel don Manuel Larenas, una pension de seiscientos pesos anuales, de que disfrutar&#xE1; en conformidad a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 5946751}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Manuel Villamil Blanco.</div><br></div>", "i": 5946752}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "94", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-94"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAROLINA LARENAS PRADEL", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-09-06", "doble_articulado": false, "id_norma": "21961", "numero_fuente": "4616", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-09-09", "vigencias": [{"desde": "1893-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-09-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu