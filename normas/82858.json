{"html": [{"t": "<div><div class=\"p\">CONCEDE PLAZO QUE INDICA</div><br><br></div>", "i": 8314283}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 665 de 24 de Mayo de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se concede un plazo de 30 d&#xED;as a contar de la fecha de esta resoluci&#xF3;n, a don Manuel Roberto Barrientos S&#xE1;nchez, R.U.T. No. 5.353.608-5, domiciliado en Iquique, calle Esmeralda No. 1167, para publicar el extracto de la resoluci&#xF3;n No. 1740, de 1989, de esta Subsecretar&#xED;a, por haberse acreditado la ocurrencia&nbsp; de fuerza mayor. </div></div>", "i": 8314284}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 24 de Mayo de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314285}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "665", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-665"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "CONCEDE PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-24", "doble_articulado": false, "id_norma": "82858", "numero_fuente": "33701", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-22", "vigencias": [{"desde": "1990-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part":