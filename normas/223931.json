{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6474250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 946, de 6 de abril de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MARINOS S.A.</div><div class=\"p\">&quot;Alimar&quot; para ampliar actividades pesqueras extractivas con la nave &quot;G&#xE9;nesis&quot;, en las &#xE1;reas que a continuaci&#xF3;n se indican, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima correspondiente a las regiones V, VI, VII y X, con cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima correspondiente a las regiones V, VI, VII y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia.</div><br></div>", "i": 6474251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6474252}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "946", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-946"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-04-06", "fecha_derogacion": "2008-06-11", "doble_articulado": false, "id_norma": "223931", "numero_fuente": "37839", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-19", "vigencias": [{"desde": "2008-06-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-04-19", "hasta": "2008-06-10", "t