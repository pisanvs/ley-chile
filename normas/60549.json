{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 60, de 17 de enero de 1997 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por seis meses, a contar del 19 de enero de 1997, el plazo otorgado a&nbsp;  PESQUERA TRAVESIA S.A., para iniciar operaciones con la nave en construcci&#xF3;n autorizada por Resoluci&#xF3;n N&#xBA; 1.133 de 1995, de esta Subsecretar&#xED;a, en virtud de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 8300937}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 17 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8300938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "60", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-60"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRORROGA", "AUTORIZACION", "PESCA", "PESQUERA TRAVESIA S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["Extracto"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-17", "doble_articulado": false, "id_norma": "60549", "numero_fuente": "35679", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-30", "vigencias": [{"desde": "1997-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-01-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFIC