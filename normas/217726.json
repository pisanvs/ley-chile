{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7305584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.937, de 19 de noviembre de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.149 de 1988, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a EMPRESA DE DESARROLLO PESQUERO DE CHILE S.A. para operar la nave &quot;Unzen&quot;, respecto del recurso hidrobiol&#xF3;gico Besugo, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 44&#xB0;30&apos; L.S. y 57&#xB0; L.S., al weste de las l&#xED;neas de base recta, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7305585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7305586}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2937 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2937 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-19", "doble_articulado": false, "id_norma": "217726", "numero_fuente": "37719", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-25", "vigencias": [{"desde": "2003-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-25", "fin_v