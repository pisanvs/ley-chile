{"html": [{"t": "<div><div class=\"p\">EXTRACTO </div></div>", "i": 6398285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n Ministerial N&#xBA; 54, de fecha 6 de junio del a&#xF1;o 2002, se aprob&#xF3; la reforma parcial al estatuto de la Cooperativa Rural El&#xE9;ctrica Llanquihue Ltda., en adelante tambi&#xE9;n de sigla &quot;Crell Ltda.&quot; y de nombre de fantas&#xED;a &quot;Crell&quot;, en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica suscrita con fecha 13 de febrero del a&#xF1;o 2002, ante el Notario P&#xFA;blico don Sergio Corval&#xE1;n Valenzuela, suplente del titular de la Segunda Notar&#xED;a de Puerto Varas con oficio en la comuna de Llanquihue, don Ricardo Fontecilla Gallardo, Repertorio N&#xBA; 123.</div><br></div>", "i": 6398286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Ra&#xFA;l Oliva Camadro, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6398287}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "54", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-54"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-06", "doble_articulado": false, "id_norma": "203158", "numero_fuente": "37375", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-04", "vigencias": [{"desde": "2002-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],