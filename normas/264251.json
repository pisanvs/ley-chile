{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7352168}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.505, de 27 de agosto de 2007, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 700 de 1995, y N&#xBA; 65 de 1997, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autorizaron a PESQUERA FRIOSUR S.A., hoy Pesquera Friosur VIII S.A., para realizar actividades pesqueras extractivas con la nave &quot;Friosur VIII&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre el l&#xED;mite norte de la IX Regi&#xF3;n y el 41&#xBA;28,6&apos; L.S., sobre el recurso Raya, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7352169}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de agosto de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7352170}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2505 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2505 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-27", "doble_articulado": false, "id_norma": "264251", "numero_fuente": "38852", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-31", "vigencias": [{"desde": "2007-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi