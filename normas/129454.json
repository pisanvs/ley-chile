{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6147050}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1.321 de 03 de Agosto de 1988, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector no donado y Sector donado Predio &quot;Hijuela No. 1 del Fundo Sanita Filomena&quot; de la comuna de Paine, Regi&#xF3;n Metropolitana: y Derechos Aprovechamiento Aguas que corresponden a parcela No. 24 parte y sitios Nos. 1 al 12 del Proyecto de Parcelaci&#xF3;n &quot;os Maitenes y Santa Teresa&quot; formado por predio se&#xF1;alado. Los Derechos de Agua se extraen del canal Huidobro derivado del r&#xED;o Maipo y del canal Agua Clara derivado del Estero El Inca o Escorial. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.-</div><br></div>", "i": 6147051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6147052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1321 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1321 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-03", "doble_articulado": false, "id_norma": "129454", "numero_fuente": "33150", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-16", "vigencias": [{"desde": "1988-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-16", "fin_vigencia": ""}, "vigen