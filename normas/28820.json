{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LEY NUM.17.179 CONCEDE AMNISTIA A LAS PERSONAS QUE SE&#xD1;ALA Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5980293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese amnist&#xED;a a las personas condenadas por sentencia del Juzgado de Letras de Mayor Cuant&#xED;a de Victoria reca&#xED;da en el proceso Rol N&#xB0; 20.619, de dicho Juzgado.&quot; </div></div>", "i": 5980294}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, cuatro de Septiembre de mil novecientos sesenta y nueve.- EDUARDO FREI MONTALVA.- GUSTAVO LAGOS MATUS.</div><div class=\"p\">&nbsp; &nbsp; Lo digo a U. para su conocimiento.- Dios guarde a U.- Guillermo Piedrabuena R., Subsecretario de Justicia. </div></div>", "i": 5980295}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17179", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17179"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "LEY NUM.17.179\nCONCEDE AMNISTIA A LAS PERSONAS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMNISTIA", "VICTORIA", "PERSONAS CONDENADAS SENTENCIA", "JUZGADO LETRAS MAYOR CUANTIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1969-09-04", "doble_articulado": false, "id_norma": "28820", "numero_fuente": "27445", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1969-09-12", "vigencias": [{"desde": "1969-09-12"