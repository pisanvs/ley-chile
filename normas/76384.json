{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 971 EXENTO, DE 1997 </div></div>", "i": 6047618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto supremo exento de Educaci&#xF3;n N&#xBA; 971 de 22 de septiembre de 1997, se ha aprobado planes especiales de estudio para el Liceo &quot;El Rosario&quot; (Ex C N&#xBA; 41) de Litueche, provincia de Cardenal Caro, VI Regi&#xF3;n, y programas complementarios para Ense&#xF1;anza B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica, cuya aplicaci&#xF3;n se iniciar&#xE1; en el a&#xF1;o escolar 1997 en los cursos que se indican en el presente decreto.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para las asignaturas se&#xF1;aladas en el presente decreto. </div></div>", "i": 6047619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de octubre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6047620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "971 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-971 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 971 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "LICEO EL ROSARIO", "LITUECHE", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-22", "doble_articulado": false, "id_norma": "76384", "numero_fuente": "35894", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-18", "vigencias": [{"desde": "1997-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-18", "fi