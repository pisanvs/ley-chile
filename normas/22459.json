{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; L&#xED;nea telegr&#xE1;fica de Puerto Montt a Punta Arenas Lei n&#xFA;m. 1,191.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cincuenta mil pesos en el estudio de una l&#xED;nea telegr&#xE1;fica que una a Puerto Montt con Punta Arenas.</div><br><br></div>", "i": 8274148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 4 de Febrero de 1899.- FEDERICO ERRAZURIZ.- C. Walker Martinez.</div><br></div>", "i": 8274149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1191", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1191"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LINEA TELEGRÁFICO DE PUERTO MONTT A PUNTA ARENAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LINEA TELEGRAFICA", "PUERTO MONTT - PUNTA ARENAS", "FONDOS", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-02-04", "doble_articulado": false, "id_norma": "22459", "numero_fuente": "6221", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-02-07", "vigencias": [{"desde": "1899-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-02-07", "fin_vigencia": ""}, "vigen