{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8617451}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 21 de fecha 29 de enero de 1992 del Ministerio de Educaci&#xF3;n, se modific&#xF3; la Resoluci&#xF3;n Exenta No. 266 de fecha 11 de octubre de 1990, que aprueba plan y programas de estudio de la carrera de Secretario Ejecutivo al Centro de Formaci&#xF3;n T&#xE9;cnica Genoveva Guarniero de Hijuelas, para que se aplique plan especial de estudios por &#xFA;nica vez, a fin de regularizar la situaci&#xF3;n acad&#xE9;mica de los alumnos que ingresaron a la carrera en 1988 y 1989 en el Centro mencionado.-</div><br></div>", "i": 8617452}, {"t": "<div><div class=\"p\">Santiago, 13 de Abril de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8617453}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "21 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-21 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-29", "doble_articulado": false, "id_norma": "77720", "numero_fuente": "34346", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-20", "vigencias": [{"desde": "1992-08-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-08-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-08-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMB", "fecha_ingreso": "1997-11-25", "fecha_version":