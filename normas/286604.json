{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xB0; 754 EXENTA, DE 2008 </div></div>", "i": 6986214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por resoluci&#xF3;n exenta N&#xB0; 13, de 9 de enero de 2009, esta Superintendencia de Valores y Seguros rectifica la resoluci&#xF3;n exenta N&#xB0; 754, de 31 de diciembre de 2008, en que se aprueba el aumento de capital de Renta Nacional Compa&#xF1;&#xED;a de Seguros de Vida S.A., en lo siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- Se elimina la expresi&#xF3;n &quot;26&quot; del primer p&#xE1;rrafo de la citada resoluci&#xF3;n exenta.</div><div class=\"p\">&nbsp; &nbsp;  2.- Se elimina la expresi&#xF3;n &quot;26&quot; y se reemplaza la cantidad de &quot;$16.753.752.102.-&quot;, por la de</div><div class=\"p\">&quot;$16.653.752.102.-&quot;, del correspondiente Certificado, quedando el capital en la cantidad de $19.969.929.151.-, dividido en 6.153.792 acciones, &#xED;ntegramente suscrito y pagado.</div><br></div>", "i": 6986215}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de enero de 2009.- Carmen Undurraga Mart&#xED;nez, Secretario General.</div><br></div>", "i": 6986216}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-13 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "RECTIFICA RESOLUCIÓN N° 754 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-09", "doble_articulado": false, "id_norma": "286604", "numero_fuente": "39276", "tipo_version": "3", "tipo_version_s": "