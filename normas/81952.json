{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8313114}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.056 de 28 de Agosto de 1991 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xB0; de la Resoluci&#xF3;n No. 469, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SALMONES CALETA BAY LTDA., R.U.T. N 79.910.700-7 domiciliada en Osorno, para iniciar actividades pesqueras de cultivo de Trucha arcoiris, Oncorhynchus mykiss, en Lago Rupanco, Comuna Puerto Octay, Provincia de Osorno, X Regi&#xF3;n, en un &#xE1;rea de 106.652 m2., en el sentido de reemplazar la longitud del V&#xE9;rtice B: &quot;72&#xB0; 40&apos; 08,00&quot; W&quot; por &quot;72&#xB0; 40&apos; 03,00&quot; W&quot;. </div></div>", "i": 8313115}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 28 de agosto de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1056", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1056"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUPERINTENDENCIA DE ELECTRICIDAD Y COMBUSTIBLES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-28", "doble_articulado": false, "id_norma": "81952", "numero_fuente": "34059", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-03", "vigencias": [{"desde": "1991-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-03", "fin_vigencia": ""}, "vigencias_version_norm