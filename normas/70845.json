{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 536, de 17 de abril de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;quese el numeral 12&#xBA; de la Resoluci&#xF3;n N&#xBA; 427, de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don ROBERTO FERMANDOIS GATICA, para continuar desarrollando actividades pesqueras con la nave &quot;Tonyn&quot;, en el sentido que indica:</div><div class=\"p\">&nbsp; &nbsp;  &quot;D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 1.791, de 1989, de esta Subsecretar&#xED;a, en cuanto autoriz&#xF3; a Pesquera Santa Luc&#xED;a S.A., R.U.T. N&#xBA; 96.527.920-2 para operar con la nave &quot;Tonyn&quot;, en virtud de lo se&#xF1;alado en las escrituras p&#xFA;blicas indicadas en Visto.&quot;.</div><br></div>", "i": 8302557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de abril de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "536", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-536"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ROBERTO FERMANDOIS GATICA", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-17", "doble_articulado": false, "id_norma": "70845", "numero_fuente": "35750", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-25", "vigencias": [{"desde": "1997-04-25", "ha