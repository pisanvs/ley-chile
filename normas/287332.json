{"html": [{"t": "<div><div class=\"p\">@@</div></div>", "i": 7435538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 343 de 10 de febrero de 2009, y en base a la facultad otorgada por el art&#xED;culo 105 del DFL MOP N&#xBA; 850, de 1997, que fij&#xF3; el texto actualizado de la Ley N&#xBA; 15.840, se dej&#xF3; sin efecto el decreto MOP N&#xBA; 813 de 8 de noviembre de 2007, en atenci&#xF3;n a que la Empresa Concesionaria de Servicios Sanitarios S.A., tiene la necesidad de emplazar la obra de tratamiento en un lugar distinto al previsto. </div></div>", "i": 7435539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7435540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "342 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-342 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-10", "doble_articulado": false, "id_norma": "287332", "numero_fuente": "39289", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-16", "vigencias": [{"desde": "2009-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-02-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-02-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2009-02-16", "fecha_version": "2009-02-16", "fecha_actualizacion_texto": "2009-02-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "