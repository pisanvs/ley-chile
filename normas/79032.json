{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309480}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 421 de 14 de Mayo de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a Fomento y Reconstrucci&#xF3;n, dejase sin efecto las Resoluciones No. 332 y No. 1270, de 1988, ambas de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a PESQUERA SAN SEBASTIAN LTDA.. R.U.T. No.</div><div class=\"p\">79.731.090-5, domiciliada en Santiago, para desarrollar actividades pesqueras de transformaci&#xF3;n en la comuna de Lota, provincia de Concepci&#xF3;n, VIII Regi&#xF3;n, por renuncia total de su titular, ya individualizado.</div><br></div>", "i": 8309481}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 14 de Mayo de 1992.- Jorge Marshall Rivera, Subsecretario de Pesca Subrogante.</div><br></div>", "i": 8309482}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "421", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-421"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-05-14", "doble_articulado": false, "id_norma": "79032", "numero_fuente": "34275", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-05-26", "vigencias": [{"desde": "1992-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-05-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICA