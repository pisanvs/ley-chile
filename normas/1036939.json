{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 1.892 EXENTO, DE 2009, QUE ESTABLECI&#xD3; VEDA EXTRACTIVA PARA EL RECURSO LOBO MARINO COM&#xDA;N EN &#xC1;REA Y PER&#xCD;ODO QUE INDICA</div></div>", "i": 9234693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 115 de 26 de enero de 2012 de este Ministerio, modif&#xED;case el <a href=\"https://www.leychile.cl/Navegar?idNorma=1009418&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 1.892 de 2009</a>, de este Ministerio, que estableci&#xF3; una veda extractiva para el recurso Lobo marino com&#xFA;n Otaria flavescens, en todo el litoral de la Rep&#xFA;blica, por el t&#xE9;rmino de 3 a&#xF1;os, en los t&#xE9;rminos indicados en el decreto extractado.</div><br></div>", "i": 9234694, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de enero de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9234695}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "115 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-115 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA DECRETO Nº 1.892 EXENTO, DE 2009, QUE ESTABLECIÓ VEDA EXTRACTIVA PARA EL RECURSO LOBO MARINO COMÚN EN ÁREA Y PERÍODO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-26", "doble_articulado": false, "id_norma": "1036939", "numero_fuente": "40178", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-02-03", "vigencias": [{"desde": "2012-02-03", "hasta": "", "tipo_version": "3", "tip