{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 266 EXENTO, DE 1997 </div></div>", "i": 6034016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 266 de 10 de marzo de 1997, se ha aprobado al Colegio &quot;Saint Gabriel&apos;s School&quot; de Santiago, con sus sedes: Bilbao, Diamelos, Eleodoro Y&#xE1;&#xF1;ez y Pastene, un plan de estudio para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o (NB.1 y NB.2) de Ense&#xF1;anza B&#xE1;sica Biling&#xFC;e, que se comenzar&#xE1;n a aplicar a partir del a&#xF1;o escolar 1997.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Idioma Extranjero: Ingl&#xE9;s.</div><br></div>", "i": 6034017}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de marzo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6034018}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "266 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-266 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 266 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SAINT GABRIEL'S SCHOOL", "SANTIAGO", "REGION METROPOLITANA", "PLANES DE ESTUDIO", "ENSE ANZA BASICA BILINGUE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-10", "doble_articulado": false, "id_norma": "70506", "numero_fuente": "35737", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-10", "vigencias": [{"desde": "1997-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-10", "fin_vig