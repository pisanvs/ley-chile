{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 65, DE 1986 </div></div>", "i": 6241003}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 65, de 22 de abril de 1986 se ha aprobado para la Escuela T&#xE9;cnica Particular Santa Mar&#xED;a Micaela, de Talagante, Regi&#xF3;n Metropolitana, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar de 1991, en la especialidad de Peluquer&#xED;a y Belleza.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas para la asignatura de Psicolog&#xED;a y Filosof&#xED;a.</div><br></div>", "i": 6241004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de abril de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6241005}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "65 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-65 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 65, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-22", "doble_articulado": false, "id_norma": "158159", "numero_fuente": "32464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-07", "vigencias": [{"desde": "1986-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic