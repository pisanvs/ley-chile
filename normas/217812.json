{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6450420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.814, de 12 de noviembre</div><div class=\"p\">de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA</div><div class=\"p\">ALCAR S.A. para ampliar actividades pesqueras</div><div class=\"p\">extractivas con la nave &quot;Argos II&quot;, en el Archipi&#xE9;lago</div><div class=\"p\">de Juan Fern&#xE1;ndez, Isla de Pascua, Islas Sala y G&#xF3;mez e</div><div class=\"p\">Islas Desventuradas, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar, con arte de palangre, los siguientes recursos hidrobiol&#xF3;gicos: At&#xFA;n aleta amarilla, At&#xFA;n aleta azul, At&#xFA;n aleta larga, At&#xFA;n de escamas o At&#xFA;n chauchera, At&#xFA;n ojos grandes, Azulejo, Bonito, Marrajo o tibur&#xF3;n, Tollo, Marlin rayado, Marlin trompa corta, Marlin negro, Marlin azul o zuncho. </div></div>", "i": 6450421}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6450422}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2814 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2814 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-12", "doble_articulado": false, "id_norma": "217812", "numero_fuente": "37721", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-27", 