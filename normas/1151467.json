{"html": [{"t": "<div><div class=\"p\">&#xFEFF;ABONO DE PREST A LAS RECLUTAS.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 22 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  Considerando que la desercion de las reclutas es frecuente, y que en los costos de hacerlas y su prest, se grava enormemente el Erario sin provecho, a mas de lo que ocupan en su disciplina;</div><br><div class=\"p\">&nbsp; &nbsp;  DECRETO</div></div>", "i": 10175226}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Que en adelante por los tres primeros meses del recluta solo se abone a los cuerpos dos tercios del prest mensual. El Secretario de Estado en el Departamento de la Guerra es encargado del cumplimiento de este decreto. </div><br></div>", "i": 10175227}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese e imprimase.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><div class=\"p\">&nbsp; &nbsp;  Correa de Saa.</div></div>", "i": 10175228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ABONO DE PREST A LAS RECLUTAS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-08-22", "doble_articulado": false, "id_norma": "1151467", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic