{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 97 de 01 de Febrero de 1985, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a Sector excluido y Sector expropiado predio &quot;Hijuela Primera o del Norte de las Tres en que se dividi&#xF3; el Fundo Santo Tom&#xE1;s&quot; de las comunas de Parral y Retiro, VII Regi&#xF3;n; y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0; 1 a la 53, sitios N&#xB0; 1 al 35 y Reserva CORA N&#xB0; 1 del Proyecto de Parcelaci&#xF3;n &quot;Ajial Valdivieso&quot; formado por predio se&#xF1;alado y predio &quot;El Temblador&quot;. Los derechos de agua se extraen del Canal San Nicol s y Derrames del Fundo El Ajial.- Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377.-</div><br></div>", "i": 6236719}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6236720}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "97 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-97 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-01", "doble_articulado": false, "id_norma": "156786", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic