{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10065746}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Conforme DS N&#xBA; 274, de fecha 10 de julio del 2019, del Ministerio de Defensa Nacional, &#xCD;talo Mois&#xE9;s Canales Ram&#xED;rez RUT 11.828.212-4, casado, de ocupaci&#xF3;n operador tur&#xED;stico, domiciliado en Avenida Alemania N&#xBA; 7397, Cerro Mariposa, Valpara&#xED;so, concesi&#xF3;n mar&#xED;tima menor, otorgamiento, SIABC N&#xBA; 39567, sector de terreno de playa en el lugar denominado balneario Las Torpederas, comuna, provincia y Regi&#xF3;n de Valpara&#xED;so, superficie de 60,33 m&#xB2;. Objeto albergar y operar comercialmente una escuela de buceo, con una terraza de observaci&#xF3;n y un sector de secado de equipos. Antecedentes solicitud carpeta Capitan&#xED;a de Puerto Valpara&#xED;so a disposici&#xF3;n del p&#xFA;blico. Visaci&#xF3;n de Capitan&#xED;a de Puerto de Valpara&#xED;so.-</div></div>", "i": 10065747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Daniel Gonz&#xE1;lez Salinas, Capit&#xE1;n de Fragata LT, Capit&#xE1;n de Puerto de Valpara&#xED;so.</div></div>", "i": 10065748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "274", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-274"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "CAPITANÍA DE PUERTO DE VALPARAÍSO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1668322", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-07-10", "doble_articulado": false, "id_norma": "1138189", "numero_fuente": "42492", "tipo_version": "3", "tipo_versi