{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6219054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 703 de 07 de Julio de 1987 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a do&#xF1;a Alicia Ren&#xE9; Gonz&#xE1;lez C&#xE1;ceres, de la Asociaci&#xF3;n de Buses &quot;Talmocur&quot;, de Talca, para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6219055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mariano Varas Hern&#xE1;ndez, Secretario Regional Ministerial (S) de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6219056}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "703 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-703 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-07", "doble_articulado": false, "id_norma": "151237", "numero_fuente": "32822", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-17", "vigencias": [{"desde": "1987-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "19