{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISORES DE BOLETAS ELECTR&#xD3;NICAS</div></div>", "i": 8905147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n N&#xBA; 58 exenta, del Servicio de Impuestos Internos de 29 de marzo de 2010, que autoriza a contribuyentes como emisor de boleta electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boleta electr&#xF3;nica a contribuyentes RUT 81.640.900-4, RUT 77.790.420-5, RUT 76.047.103-8, RUT 78.276.830-1, y RUT 71.918.300-K, a contar del mes de abril de 2010. En la Oficina Virtual del SII en internet se podr&#xE1;n consultar los documentos que los contribuyentes est&#xE1;n autorizados a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de marzo de 2010.</div><br></div>", "i": 8905148}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "58 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-58 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-03-29", "doble_articulado": false, "id_norma": "1012255", "numero_fuente": "39628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-04-06", "vigencias": [{"desde": "2010-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-04-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2010-04-06", "fecha_version": "2010-04-06", "actualizado_por": "362", "fecha_actualizacion_texto": "2010-04-06", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8905147}, {"n": "Artículo", "i": 8905148, "t": 6}]}