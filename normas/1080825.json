{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA</div></div>", "i": 9631308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n ex N&#xBA; 77315048706 de fecha 14.08.2015, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=220193&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; ex. 403 del 10.12.2003</a>, que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de contrato de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contraten, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Guillermo Patricio Leddy Fuentes, RUT N&#xBA; 7.545.839-8, conforme a lo establecido en la resoluci&#xF3;n ex. N&#xBA; 142 de fecha 26.12.2005, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial de fecha 29.12.2005.</div><br></div>", "i": 9631309, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Christian Soto Torres, Director Regional.</div></div>", "i": 9631310}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77315048706 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77315048706 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-08-14", "doble_articulado": false, "id_norma": "1080825", "numero_fuente": "41241", "tipo_version": "3", "tip