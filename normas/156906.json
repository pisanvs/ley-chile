{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N&#xB0; 256 DE 17 DE JUNIO DE 1985 </div></div>", "i": 7262096}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo Industrial A N&#xB0; 27, de Temuco.</div><br><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES:</div><br><div class=\"p\">1.- Mec&#xE1;nica de M quinas Herramientas.</div><div class=\"p\">2.- Mec&#xE1;nica de Combusti&#xF3;n Interna y Automotriz.</div><div class=\"p\">3.- Electricidad Industrial con Menci&#xF3;n en Electromec&#xE1;nica.</div><div class=\"p\">4.- Electricidad Industrial con Menci&#xF3;n en Instalaciones El&#xE9;ctricas.</div><br></div>", "i": 7262097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  28 de junio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica, subrogante.</div><br></div>", "i": 7262098}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "256 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-256 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N° 256\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "156906", "numero_fuente": "32364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-06", "vigencias": [{"desde": "1986