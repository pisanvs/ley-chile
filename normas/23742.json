{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta los derechos de matadero en la comuna de Chillan</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,107.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275945}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Incl&#xFA;yese la Municipalidad de Chillan entre los municipios a los cuales el art&#xED;culo 1.&#xB0; de la lei de 26 de Noviembre de 1873 faculta para cobrar un impuesto de mataderos hasta de cuarenta i cinco centavos por cada cien kil&#xF3;gramos del peso bruto de los animales que se beneficien para el consumo de la poblacion.</div><br></div>", "i": 8275946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 28 de Agosto de 1916.- JUAN LUIS SANFUENTES.- Luis Izquierdo.</div><br></div>", "i": 8275947}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3107", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3107"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUMENTA LOS DERECHOS DE MATADERO EN LA COMUNA DE CHILLAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CHILLAN", "IMPUESTO MATADERO", "REAJUSTE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacit