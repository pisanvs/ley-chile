{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Edificio del Congreso Nacional Lei n&#xFA;m. 1,331.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 5948902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza la inversion de la suma de cincuenta mil ochocientos cincuenta i dos pesos sesenta i siete centavos en la continuacion de los trabajos de reconstruccion del edificio del Congreso Nacional.</div><br></div>", "i": 5948903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 11 de Enero de 1900.- Federico Err&#xE1;zuriz.- Jos&#xE9; F. Valdes C.</div><br></div>", "i": 5948904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1331", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1331"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "Edificio del Congreso Nacional", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "EDIFICIO", "RECONSTRUCCION", "FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-01-11", "doble_articulado": false, "id_norma": "22565", "numero_fuente": "6494", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-01-12", "vigencias": [{"desde": "1900-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-01-12", "fin_vigencia": ""}, "vigencias_version_norma":