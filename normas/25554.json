{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PRORROGA LA VIGENCIA DEL INCISO 2&#xB0; DEL ART. 1&#xB0; DE LA LEY N&#xB0; 6,039, SOBRE INTERNACION DE VACUNOS Y OVEJUNOS Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5963935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Prorr&#xF3;gase por un nuevo per&#xED;odo de tres a&#xF1;os, a contar desde el 20 de Febrero de 1943, la vigencia del inciso 2&#xB0; del art&#xED;culo 1&#xB0; de la ley n&#xFA;mero 6,039, de 7 de Febrero de 1937&quot;.</div><br></div>", "i": 5963936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintis&#xE9;is de Enero de mil novecientos cuarenta y tres.- JUAN ANTONIO RIOS M.- Fernando Moller B.- Gmo. del Pedregal.</div><br></div>", "i": 5963937}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7412", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7412"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "PRORROGA LA VIGENCIA DEL INCISO 2° DEL ART. 1° DE LA\nLEY N° 6,039, SOBRE INTERNACION DE VACUNOS Y OVEJUNOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRORROGA VIGENCIA", "EXENCION IMPUESTO", "MINISTERIO AGRICULTURA", "INTERNACION", "IMPORTACION", "OVEJUNOS", "VACUNOS", "EXONERACION", "FRANQUICIA ADUANERA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1943-01-26", "doble_articulado": false, "id_norma": "25554", "numero_fuente": "19475", "tipo_version": "3", "tipo_ve