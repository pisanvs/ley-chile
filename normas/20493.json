{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 164 EXENTO, DE 1996 </div></div>", "i": 5942159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 164, de 25 de marzo de 1996, se ha aprobado, a contar del a&#xF1;o escolar 1996, al Colegio Particular &quot;Santa Mar&#xED;a de Providencia&quot;, comuna de Providencia, Regi&#xF3;n Metropolitana, un plan especial de estudio de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica de adultos.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s se aprueba programa de estudio para la asignatura de Computaci&#xF3;n.</div><br></div>", "i": 5942160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de abril de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942161}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "164", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-164"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 164 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO PARTICULAR SANTA MARIA PROVIDENCIA", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-25", "doble_articulado": false, "id_norma": "20493", "numero_fuente": "35450", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-24", "vigencias": [{"desde": "1996-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-04-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend