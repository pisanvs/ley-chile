{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.788 EXENTA, DE 27.10.2011</div></div>", "i": 9201684}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente se han modificado las resoluciones exentas Nos <a href=\"https://www.leychile.cl/Navegar?idNorma=138856&amp;idParte=0&amp;idVersion=\">4.083</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=144154&amp;idParte=0&amp;idVersion=\">8.341</a>, ambas de 1999; <a href=\"https://www.leychile.cl/Navegar?idNorma=182591&amp;idParte=0&amp;idVersion=\">803, de 2001</a>, y <a href=\"https://www.leychile.cl/Navegar?idNorma=196388&amp;idParte=0&amp;idVersion=\">713, de 2002</a>, todas del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Mar&#xED;a Inmaculada, comuna de Providencia, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Sector de Computaci&#xF3;n Aplicada, en el Plan de Formaci&#xF3;n Diferenciada de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div></div>", "i": 9201685}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de noviembre de 2011.- Magdalena Kuzmanich &#xC1;vila, Jefa Divisi&#xF3;n de Educaci&#xF3;n General (S).</div></div>", "i": 9201686}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5788 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-5788 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.788 EXENTA, DE 27.10.2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011