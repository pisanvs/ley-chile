{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297409}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.450, de 6 de agosto de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a RODOLFO ROMAN SILVA MOLINA, para ampliar actividades pesqueras extractivas, en orden a operar la nave &quot;Neptuno&quot;, en el litoral de la III y IV Regiones, por fuera del &#xE1;rea de reserva artesanal, con cerco: Anchoveta, Jurel y Sardina espa&#xF1;ola.</div><div class=\"p\">&nbsp; &nbsp; La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades de acuerdo a las disposiciones legales y reglamentarias vigentes o que se establezcan.</div><br></div>", "i": 8297410}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297411}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1450", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1450"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "RODOLFO ROMAN SILVA MOLINA", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-08-06", "doble_articulado": false, "id_norma": "36995", "numero_fuente": "35552", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-08-27", "vigencias": [{"desde": "1996-08-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-08-27", "fin_vigencia": ""}, "vigencias