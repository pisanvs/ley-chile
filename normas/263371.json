{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7349555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.294, de 31 de julio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a CORPESCA S.A. para realizar actividades extractivas en alta mar con la nave &quot;Am&#xE9;rica 2&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; CB-3285</div><div class=\"p\">Puerto de Matr&#xED;cula&nbsp; &nbsp;  Valpara&#xED;so</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  1718</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; 21,95 m.</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp;  81,92</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  6,63 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2,59 m.</div><br></div>", "i": 7349556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de julio de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7349557}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2294 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2294 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2007-07-31", "fecha_derogacion": "2011-01-20", "doble_articulado": false, "id_norma": "263371", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "20