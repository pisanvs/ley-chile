{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 467, DE 1984</div><br><br><br></div>", "i": 7261206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 103, de 06 de Febrero de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n 467, de 1984, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la Pesquera Neptuno S.A., domiciliada en Iquique, para operar la embarcaci&#xF3;n denominada &quot;Pica&quot;, en orden a incluir en el numeral 5, entre las especies que la sociedad se&#xF1;alada podr&#xE1; extraer con dicha nave, el recurso bonito, que deber&#xE1; destinar a su industrializaci&#xF3;n para consumo humano. La embarcaci&#xF3;n deber&nbsp; contar a bordo con sistemas adecuados de preservaci&#xF3;n de la materia prima.</div><br></div>", "i": 7261207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 06 de Febrero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7261208}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "103", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-103"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 467, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-02-06", "fecha_derogacion": "2001-12-19", "doble_articulado": false, "id_norma": "155578", "numero_fuente": "32402", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-02-19", "vigencias": [{"desde": "2001-12-19", "hasta": "", "tipo_ve