{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6494083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.063, de 4 de agosto de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIALIZADORA DE PRODUCTOS DEL MAR SIFROMAR SOCIEDAD ANONIMA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta en Avenida Las Industrias N&#xBA; 202, Caldera, III Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-enfriado, Fresco-refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6494084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6494085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2063 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2063 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-08-04", "fecha_derogacion": "2010-02-19", "doble_articulado": false, "id_norma": "229562", "numero_fuente": "37948", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-08-28", "vigencias": [{"desde": "2010-02-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-08-28", "hasta": "2010-02-18", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2010-02-19", "fin_vigencia": ""}, "vigenc