{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6503242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 3.221 de 6 de octubre de 2004, Serviu V Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme art&#xED;culo 87 ley 8.946 y decreto ley 2.186, de 1978, de inmueble ubicado en Diego Portales s/n, rol aval&#xFA;o 75-6, comuna de Catemu, de dominio de Delf&#xED;n Valencia. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, Alvaro Verdejo Vidal, ingeniero constructor, y Pablo Caria Giurici, constructor civil, seg&#xFA;n Informe de fecha 15 de septiembre de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $533.320.- que ser&#xE1; pagada al contado.</div><br></div>", "i": 6503243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Valpara&#xED;so.</div><br></div>", "i": 6503244}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3221", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3221"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANIZACIÓN", "V REGIÓN DE VALPARAÍSO"], "titulo_norma": "DISPONE EXPROPIACIONES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-06", "doble_articulado": false, "id_norma": "232022", "numero_fuente": "38000", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-02", "vigencias": [{"desde": "2004-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-11-02", "fin_vigencia": ""}, "vigencias_vers