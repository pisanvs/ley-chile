{"html": [{"t": "<div><div class=\"p\">FIJA N&#xD3;MINA DE ESPECIES HIDROBIOL&#xD3;GICAS VIVAS DE IMPORTACI&#xD3;N AUTORIZADA</div></div>", "i": 10274108}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.662, de 29 de septiembre de 2021, de esta Subsecretar&#xED;a, se fija n&#xF3;mina de especies hidrobiol&#xF3;gicas vivas de importaci&#xF3;n autorizada, se&#xF1;aladas en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en las p&#xE1;ginas web www.subpesca.cl y www.sernapesca.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10274109}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de septiembre de 2021.- Cristian Espinoza Montenegro, Subsecretario de Pesca y Acuicultura (S).</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda atentamente a Ud., Daniela Bolbar&#xE1;n P&#xE9;rez, Jefe Departamento Administrativo (S).</div><br></div>", "i": 10274110}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2662 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2662 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "FIJA NÓMINA DE ESPECIES HIDROBIOLÓGICAS VIVAS DE IMPORTACIÓN AUTORIZADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2019551", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-29", "doble_articulado": false, "id_norma": "1166023", "numero_fuente": "43069", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-04", "vigencias": [{"desde": "2021-10-04", "hasta": "", "tipo_version": "3", "tip