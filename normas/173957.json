{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 357, DE 2000 </div></div>", "i": 6295388}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 357, de 27 de junio de 2000, se ha aprobado el Convenio de fecha 12 de junio de 2000, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Cerrillos, que modifica el Convenio de Traspaso de la Escuela B&#xE1;sica E N&#xBA; 267, de Cerrillos, traspasada a dicha Corporaci&#xF3;n, por Convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 496 de 4 de julio de 1986.</div><br></div>", "i": 6295389}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de agosto de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6295390}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "357", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-357"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 357, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-27", "doble_articulado": false, "id_norma": "173957", "numero_fuente": "36732", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-05", "vigencias": [{"desde": "2000-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-08-07", "fecha_version": "2000-08-05", "fecha_act