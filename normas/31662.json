{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCIONES </div></div>", "i": 8288988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 765 de 27 de Junio de 1991, de esta Subsecretar&#xED; de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 30 d&#xED;as a contar de la fecha de la presente resoluci&#xF3;n, el plazo para publicar en el Diario Oficial, el extracto de la resoluci&#xF3;n N&#xB0; 76, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don JOSE DOMINGO MARQUEZ FANZZINI, R.U.T. N&#xB0; 7.859.159-5, domiciliado en Pasaje Dalmacia N&#xB0; 3215, Iquique, para desarrollar actividades pesqueras extractivas.</div><br></div>", "i": 8288989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 27 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "765", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-765"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE DOMINGO MARQUEZ FANZZINI", "PESCA", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-27", "doble_articulado": false, "id_norma": "31662", "numero_fuente": "34019", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-17", "vigencias": [{"desde": "1991-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-07-17", "fin_vigencia