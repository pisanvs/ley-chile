{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10171698}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xB0; 702, de 21 de agosto de 2020, deja sin efecto la expropiaci&#xF3;n del lote N&#xB0;37, expropiado mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=1081054&amp;idParte=&amp;idVersion=\">Decreto Exento MOP N&#xB0;652, de 12 de agosto de 2015</a>, para la obra: &quot;Camino Mejoramiento Ruta L-45, Sector Escuela Llepo - El Pe&#xF1;asco, Tramo Kil&#xF3;metro 13,10000 a km. 20,13700&quot;, por cuanto, dicho lote fue eliminado por Resoluci&#xF3;n S.R.M. Regi&#xF3;n del Maule (Exenta) N&#xB0;487, de 21 de abril de 2020. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xB0; del Decreto Ley N&#xB0;2186, de 1978. </div><div class=\"p\"> </div></div>", "i": 10171699}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10171700}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "702 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-702 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1838686", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-21", "doble_articulado": false, "id_norma": "1151127", "numero_fuente": "42794", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-11-02", "vigencias": [{"desde": "2020-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi