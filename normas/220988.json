{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6462749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 279, de 22 de enero de</div><div class=\"p\">2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA LOTA</div><div class=\"p\">VEDDE S.A. SANTA MARIA Y COMPA&#xD1;IA COMANDITA POR</div><div class=\"p\">ACCIONES, para ampliar actividades pesqueras extractivas</div><div class=\"p\">con la nave &quot;Santa Mar&#xED;a II&quot; en el &#xE1;rea mar&#xED;tima de la V</div><div class=\"p\">a VII y IX a X Regiones, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar con cerco Vinciguerria y Cojinoba del sur.</div><br></div>", "i": 6462750}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de enero de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6462751}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "279 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-279 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-22", "doble_articulado": false, "id_norma": "220988", "numero_fuente": "37780", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-07", "vigencias": [{"desde": "2004-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-07", "fin_vigencia": "", "tipo_version": "3"}], "e