{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N</div></div>", "i": 10247200}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del SII, por resoluci&#xF3;n Ex. N&#xBA; 77321107661, de fecha 14.06.2021, otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en la venta de berries, a Patagonia Fruit SpA, RUT 76.769.209-9. Dicho acto de autoridad regir&#xE1; a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido en la resoluci&#xF3;n exenta SII N&#xBA; 55, del 02.06.2005, de la Direcci&#xF3;n Nacional.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10247201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 14 de junio de 2021.- Claudia Zuleta Munizaga, Directora Regional.</div><div class=\"p\"> </div><br></div>", "i": 10247202}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77321107661 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-77321107661 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL RANCAGUA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1969178", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-06-14", "doble_articulado": false, "id_norma": "1162085", "numero_fuente": "42990", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-06-30", "vigencias": [{"desde": "2021-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio