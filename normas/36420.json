{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.175, de 7 de Diciembre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 1392, de 1992, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a PESQUERA LOA SUR S.A. R.U.T. N&#xB0; 95.059.000-9, para operar una nave en construcci&#xF3;n, denominada &quot;Loa 24&quot;, en virtud de lo dispuesto en el art&#xED;culo 3&#xB0; transitorio, incisos 3&#xB0; y 4&#xB0; del D.S. N&#xB0;430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el sentido de se&#xF1;alar sus actuales caracter&#xED;sticas n&#xE1;uticas.</div><br></div>", "i": 8296165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 7 de Diciembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8296166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1175", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1175"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA LOA SUR", "S.A.", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-12-07", "fecha_derogacion": "1996-10-19", "doble_articulado": false, "id_norma": "36420", "numero_fuente": "35054", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-12-30", "vigencias": [{"desde": "1996-10-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Úl