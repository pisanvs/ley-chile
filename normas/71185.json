{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6035667}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 238, de 25 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s. 183 y 184, superficies 10.868 m2. y 5.735 m2., roles de aval&#xFA;o 1093-551 y 1093-553, comuna de Quill&#xF3;n, para la obra Camino Acceso Norte a Concepci&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Lorenzo Silva Parada, y Francisco Javier Cartes Saavedra, ascendente a las cantidades de $8.879.280.- y $1.350.150.- </div></div>", "i": 6035668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6035669}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "238", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-238"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "INDEMNIZACION", "QUILLON", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-25", "doble_articulado": false, "id_norma": "71185", "numero_fuente": "45755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-02", "vigencias": [{"desde": "1997-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAV", "fecha_ingreso": "1997-05-20", "fecha_version": "1997-05-02", "fecha_actualizacion_texto": "19