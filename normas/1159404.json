{"html": [{"t": "<div><div class=\"p\">DECRETO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 12 de 1830.</div><br><br></div>", "i": 10247080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Habi&#xE9;ndose declarado nulos y refractarios de la Constitucion del Estado todos los actos de las &#xFA;ltimas C&#xE1;maras; y siendo uno de ellos la eleccion de los ministros de la Suprema Corte de Justicia, a fin de evitar reclamos de nulidades, se declara: que aquel tribunal debe componerse de su Presidente en comision D. Juan de Dios Vial del Rio, y de los vocales D. Jos&#xE9; Gaspar Marin, D. Jos&#xE9; Gregorio Argomedo, D. Carlos Rodr&#xED;guez y D. Manuel Novoa, en cuyos t&#xE9;rminos se hallaba antes de dichas elecciones.- </div></div>", "i": 10247081}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese a quienes corresponda, t&#xF3;mese razon e impr&#xED;mase. </div><br><div class=\"p\">&nbsp; &nbsp;  R&#xFA;brica de S. E.</div><div class=\"p\">&nbsp; &nbsp;  Meneses.</div></div>", "i": 10247082}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DECRETO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-03-12", "doble_articulado": false, "id_norma": "1159404", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1830-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1830-03-12"