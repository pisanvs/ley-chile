{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6518935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 612, de 2 de marzo de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a YADRAN QUELLON S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Quell&#xF3;n Viejo Rural, Chilo&#xE9;, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco Enfriado, Fresco Refrigerado, Congelado, Seco Salado, Ahumado, Conserva y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6518936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de marzo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6518937}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "612 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-612 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-02", "doble_articulado": false, "id_norma": "236314", "numero_fuente": "38110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-14", "vigencias": [{"desde": "2005-03-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-03-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-03-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po