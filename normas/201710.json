{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA MUNICIPAL </div></div>", "i": 6393350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Honorable Concejo Municipal de Calle Larga, en reuni&#xF3;n de fecha 18 de julio de 2002, acord&#xF3; modificar la Ordenanza Municipal, que rige a nuestra comuna y que se encuentra actualmente vigente, respecto a lo siguiente:</div><br><br><div class=\"p\">-&nbsp; &nbsp; T&#xED;tulo IV, art&#xED;culo N&#xBA; 8 se agrega el N&#xBA; 9 como</div><div class=\"p\">&nbsp; &nbsp;  sigue Sellos verdes, rojos y amarillos por</div><div class=\"p\">&nbsp; &nbsp;  deterioro&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 12% UTM</div><br><div class=\"p\">-&nbsp; &nbsp; T&#xED;tulo V, art&#xED;culo N&#xBA; 10 N&#xBA; 3 con respecto</div><div class=\"p\">&nbsp; &nbsp;  a puesto de expendio de frutas y verduras de</div><div class=\"p\">&nbsp; &nbsp;  temporada, por mes o fracci&#xF3;n&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 17% UTM</div><br><div class=\"p\">-&nbsp; &nbsp; T&#xED;tulo VI, art&#xED;culo N&#xBA; 11 N&#xBA; 3 con respecto</div><div class=\"p\">&nbsp; &nbsp;  ferias libres y chacareros, por metro cuadrado</div><div class=\"p\">&nbsp; &nbsp;  mensual&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Sin cobro</div><br><div class=\"p\">-&nbsp; &nbsp; T&#xED;tulo VI, art&#xED;culo N&#xBA; 11 N&#xBA; 7 con respecto</div><div class=\"p\">&nbsp; &nbsp;  a puesto de expendio de frutas de temporada,</div><div class=\"p\">&nbsp; &nbsp;  por mes o fracci&#xF3;n por metro cuadrado ocupado</div><div class=\"p\">&nbsp; &nbsp;  o fracci&#xF3;n&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 1% UTM</div><br></div>", "i": 6393351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Saluda atentamente a Ud., Francisco Vial Lira, Alcalde.</div><br></div>", "i": 6393352}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "S/N", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-S/N"}], "organismos": ["MUNICIPALIDAD DE CALLE LARGA"], "titulo_norma": "MODIFICA ORDENANZA MUNICIPAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-07-18", "doble_articulado": false, "id_norma": "201710", "numero_fuente": "37337", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-19", "vigencias": [{"desde": "2002-08-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-08-19", "fecha_version": "2002-08-19", "fecha_actualizacion_texto": "2002-08-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6393350}, {"n": "Artículo", "i": 6393351, "t": 6}, {"n": "Promulgación", "i": 6393352}]}