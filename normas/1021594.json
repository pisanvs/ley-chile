{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N ORDINARIA N&#xBA;1582</div><br></div>", "i": 9088291}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n Ordinaria N&#xBA;1582, celebrada el 23 de diciembre de 2010, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">1582-02-101223-Tasa de inter&#xE9;s para pago diferido de derechos de aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del Art. 10 de la Ley N&#xBA;18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que vence el 30 de junio de 2011, ser&#xE1; de 5,5% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 9088292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de diciembre de 2010.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9088293}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1582", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1582"}, {"tipo": "5", "numero": "1582-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1582-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN ORDINARIA Nº1582", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-23", "doble_articulado": false, "id_norma": "1021594", "numero_fuente": "39846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-29", "vigencias": [{"desde": "2010-12-29", "hasta": "