{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div><br></div>", "i": 10321704}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 271 de 8 de marzo de 2022 del Serviu Regi&#xF3;n de &#xD1;uble, este Servicio orden&#xF3; expropiaci&#xF3;n parcial de inmueble ubicado en, comuna de Chill&#xE1;n, Rol de Aval&#xFA;o N&#xBA; 494-73, de aparente dominio de Arteaga Riquelme Maria Eugenia.- Rectif&#xED;case la publicaci&#xF3;n de fecha 15 de marzo de 2022 que corresponde a la <a href=\"https://www.leychile.cl/Navegar?idNorma=1173709&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 271 de fecha 08.03.2022</a>, en cuanto a la expropiaci&#xF3;n parcial del inmueble ubicado Francisco Ram&#xED;rez 141, comuna de Chill&#xE1;n, Rol de Aval&#xFA;o N&#xBA; 494-73, debiendo reemplazarse la superficie afecta a expropiaci&#xF3;n parcial de terreno de 6710, m2 y parcial de 28,272 m2 de edificaci&#xF3;n, por la superficie correcta de expropiaci&#xF3;n parcial de terreno que es de 6,710m2 y parcial de 28,272 m2 de edificaci&#xF3;n. </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10321705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n de &#xD1;uble.</div><div class=\"p\"> </div><br></div>", "i": 10321706}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "271 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-271 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE ÑUBLE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2106422"], "derogacion_tacita": [], "derogado": false, "fecha_promulgaci