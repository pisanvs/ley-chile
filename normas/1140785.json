{"html": [{"t": "<div><br><div class=\"p\">SUSPENSION DE LA INSPECCION FISCAL.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 23 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div></div>", "i": 10093940}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  A consecuencia, de las facultades concedidas al Directorio, por el acta de 21 de este mes, celebrada entre el Gobierno y Senado, susp&#xE9;ndase la inspeccion fiscal, quien deber&#xE1; remitir al Ministerio de Hacienda, todos los expedientes que all&#xED; existan, bajo la formalidad de inventario. Transcr&#xED;base a la inspeccion para su cumplimiento; t&#xF3;mese razon donde corresponda e impr&#xED;mase en el Boletin.</div><br></div>", "i": 10093941}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Diego Jos&#xE9; Benavente</div><br></div>", "i": 10093942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["DEPARTAMENTO DE HACIENDA"], "titulo_norma": "DEPARTAMENTO DE HACIENDA; SUSPENSION DE LA INSPECCION FISCAL.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-07-23", "doble_articulado": false, "id_norma": "1140785", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-07-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi