{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 13.469 EXENTA, DE 2001 </div></div>", "i": 6361105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 13.469, de 12 de noviembre del a&#xF1;o 2001, se ha aprobado al Colegio &quot;Patrocinio de San Jos&#xE9;&quot;, comuna de Providencia, provincia de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para 3&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001 y que, a partir del a&#xF1;o escolar 2003 se aplicar&#xE1; en 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio de Educaci&#xF3;n Tecnol&#xF3;gica para 4&#xBA; a&#xF1;o el que se aplicar&#xE1; en el a&#xF1;o escolar 2002.-</div><br></div>", "i": 6361106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6361107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13469 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-13469 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 13.469 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-12", "doble_articulado": false, "id_norma": "192492", "numero_fuente": "37134", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-12-13", "vigencias": [{"desde": "2001-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-12-13", "fin_vigencia": ""}, "vigencias_ver