{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8566538}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.363 de 28 de Septiembre de 1989 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 1&#xB0; de la Resoluci&#xF3;n No. 807, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera San Miguel Limitada, R.U.T. No. 81.740.200-3, domiciliada en Talcahuano, para operar la nave denominada &quot;Southport&quot;, en orden a sustituir las caracter&#xED;sticas n&#xE1;uticas de dicha embarcaci&#xF3;n por las que a continuaci&#xF3;n se indica:</div><br><div class=\"p\">Manga 9,28 mt.</div><div class=\"p\">Puntal 6,85 mt.</div><div class=\"p\">Toneladas de Registro Grueso 526,26 Toneladas de Registro Neto 154,88 Capacidad de Bodega 450 mt3.</div><br></div>", "i": 8566539}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 28 de Septiembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8566540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1363", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1363"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-09-28", "doble_articulado": false, "id_norma": "92155", "numero_fuente": "33497", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-16", "vigencias": [{"desde": "1989-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen