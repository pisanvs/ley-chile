{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6499015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.526, de 6 de septiembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SALMOALIMENTOS S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Carolina III&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a las Regiones V, VI, VII y X, con cerco, donde podr&#xE1; capturar, por fuera del &#xE1;rea de reserva artesanal, el recurso hidrobiol&#xF3;gico Jibia. </div></div>", "i": 6499016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6499017}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2526 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2526 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-06", "doble_articulado": false, "id_norma": "230848", "numero_fuente": "37975", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-01", "vigencias": [{"desde": "2004-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "2004-10-01", "fecha_versi