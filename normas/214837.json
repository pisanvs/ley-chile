{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6440327}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.116, de 28 de agosto de</div><div class=\"p\">2003, de esta Subsecretar&#xED;a, modif&#xED;canse los numerales 3&#xBA; y</div><div class=\"p\">5&#xBA; de la resoluci&#xF3;n N&#xBA; 878, de 2003, de esta Subsecretar&#xED;a,</div><div class=\"p\">que autoriz&#xF3; a la UNIVERSIDAD CATOLICA DEL NORTE, SEDE</div><div class=\"p\">COQUIMBO, para efectuar una pesca de investigaci&#xF3;n de</div><div class=\"p\">conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del</div><div class=\"p\">proyecto denominado &quot;Caracterizaci&#xF3;n de la pesca de Cabinza</div><div class=\"p\">(Isacia conceptionis)&nbsp; realizada por la flota pesquera</div><div class=\"p\">artesanal de Coquimbo&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se extender&#xE1; hasta el 31 de diciembre de 2003 y que la cuota de investigaci&#xF3;n del recurso Cabinza se incrementar&#xE1; en 1.500 toneladas.</div><br></div>", "i": 6440328}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6440329}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2116 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2116 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-28", "doble_articulado": false, "id_norma": "214837", "numero_fuente": "3