{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6565149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 393, de 6 de febrero de</div><div class=\"p\">2006, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de</div><div class=\"p\">la resoluci&#xF3;n N&#xBA; 172 de 2006, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a la UNIVERSIDAD DEL MAR, para efectuar una</div><div class=\"p\">pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos</div><div class=\"p\">T&#xE9;cnicos de Referencia del Proyecto denominado</div><div class=\"p\">&quot;Distribuci&#xF3;n espacio-temporal de las agregaciones de</div><div class=\"p\">Jurel (Trachurus murphyi) en la III Regi&#xF3;n, temporada</div><div class=\"p\">2006&quot;, en el sentido de incorporar a las embarcaciones</div><div class=\"p\">artesanales &quot;Santa Clara&quot; y &quot;Mar&#xED;a Fernanda I&quot; al listado de naves autorizadas a participar en la presente pesca de investigaci&#xF3;n.</div><br></div>", "i": 6565150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 6 de febrero de 2006.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6565151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "393 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-393 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-06", "doble_articulado": false, "id_norma": "248363", "numero_fuente": "38422", "tipo_version": "3