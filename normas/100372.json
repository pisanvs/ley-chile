{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6113770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Capitulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de septiembre de 1989, fue de 7,0% anual.</div><br></div>", "i": 6113771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 21 de septiembre de 1989.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6113772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-09-21", "doble_articulado": false, "id_norma": "100372", "numero_fuente": "33478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-22", "vigencias": [{"desde": "1989-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-06-17", "fecha_version": "1989-09-22", "fecha_actualizacion_texto": "1989-09-22", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6113770}, {"n": "Artículo", "i