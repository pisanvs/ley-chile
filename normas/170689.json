{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6281323}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 81, de 19 de Enero de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a don Guillermo Segundo Bustos Rojas, para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en calle Kurt M&#xF6;ller N&#xBA; 47 de la ciudad de Linares.-</div><br></div>", "i": 6281324}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Poblete Rodr&#xED;guez, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6281325}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "81 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-81 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-19", "doble_articulado": false, "id_norma": "170689", "numero_fuente": "32978", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-25", "vigencias": [{"desde": "1988-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-