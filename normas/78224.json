{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.483, de 7 de noviembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xBA; 115 de 1995, de esta Subsecretar&#xED;a, que fij&#xF3; las caracter&#xED;sticas n&#xE1;uticas de la nave &quot;Guanaye 2&quot;, matr&#xED;cula 2759, de Pesquera Iquique Guanaye S.A., en el sentido de se&#xF1;alar que sus actuales caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><br><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 43,1 m</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  626,0</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 820,7 m3</div><br></div>", "i": 8308553}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de noviembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8308554}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1483", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1483"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA IQUIQUE GUANAYE S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-11-07", "fecha_derogacion": "2001-05-05", "doble_articulado": false, "id_norma": "78224", "numero_fuente": "35924", "tipo_ve