{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.650 EXENTA, DE 2008 </div></div>", "i": 8377650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 7.650, de 22 de octubre de 2008, se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.095, de 2007, que aprob&#xF3; planes y programas de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio Alem&#xE1;n de Santiago, en representaci&#xF3;n de la Asociaci&#xF3;n de Colegios Alemanes de Chile.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Subsector &quot;Liderazgo y Emprendimiento&quot; para los cursos de 3&#xBA; y/o 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, correspondiente al Plan de Formaci&#xF3;n Diferenciada.</div><br></div>", "i": 8377651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de noviembre de 2008.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 8377652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7650 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7650 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.650 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-22", "doble_articulado": false, "id_norma": "282936", "numero_fuente": "39232", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-09", "vigencias": [{"desde": "2008-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-09", "fin_vig