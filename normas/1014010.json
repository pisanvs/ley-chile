{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8926392}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP N&#xBA; 571 de fecha 30 de abril del 2010, se expropi&#xF3; el lote de terreno N&#xBA; 51-A, superficie 690,00 m2, Rol N&#xBA; 1118-56, comuna de Ancud, X Regi&#xF3;n de Los Lagos para la obra &quot;Ampliaci&#xF3;n Reposici&#xF3;n Ruta 5 Chilo&#xE9;, Sector Bif. Puente Bicentenario Bif. Pupelde, tramo 8 Variante Ancud&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario DAVID ROBERTO KELCH MAYORGA, ascendente a la cantidad de $7.020.815.- para el lote N&#xBA;51-A. </div><br></div>", "i": 8926393}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 8926394}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "571 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-571 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-04-30", "doble_articulado": false, "id_norma": "1014010", "numero_fuente": "39674", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-01", "vigencias": [{"desde": "2010-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ingreso": "2010-06-01", "fecha_version": "2010-06-01", "actual