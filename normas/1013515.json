{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8919317}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.564 de 19 de enero del 2010, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1010289&amp;idParte=&amp;idVersion=2010-05-22\">Decreto Alcaldicio Secci&#xF3;n 1&#xAA;. N&#xB0; 173</a>, que Modifica Plan Regulador Comunal, con el error que se salva a continuaci&#xF3;n: p&#xE1;gina ocho, tercera columna, en el Art&#xED;culo &#xFA;nico, del Texto Aprobatorio Modificaci&#xF3;n N&#xB0; 7, punto 2., donde dice &quot; ... , calle Carlos Pe&#xF1;a Otaegui y antiguo trazado de Avenina Plaza, asignando la actual zona de Edificaci&#xF3;n ...&quot; debe decir &quot;... , calle Carlos Pe&#xF1;a Otaegui y antiguo trazado de Avenida Plaza, asignando la actual zona de Edificaci&#xF3;n ...&quot; </div><br><br></div>", "i": 8919318, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "131", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-131"}], "organismos": ["MUNICIPALIDAD DE LAS CONDES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1013515", "numero_fuente": "39666", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-05-22", "vigencias": [{"desde": "2010-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-05-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-05-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFIC