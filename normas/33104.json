{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 103, de 18 de Febrero de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por 30 d&#xED;as a contar de la fecha de la presente resoluci&#xF3;n, el plazo otorgado a PESQUERA EL GOLFO S.A., R.U.T. N&#xB0; 96.237.000-4, em el numeral 4&#xB0; de la resoluci&#xF3;n N&#xB0; de1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la peticionaria para desarrollar actividades pesqueras extractivas con la nave &quot;Saint John&quot;, en virtud de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8290271}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de Febrero de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8290272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "103", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-103"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESQUERA EL GOLFO S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-02-18", "doble_articulado": false, "id_norma": "33104", "numero_fuente": "34498", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-02-22", "vigencias": [{"desde": "1993-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-02-22", "fin_vigencia": "", "tipo_