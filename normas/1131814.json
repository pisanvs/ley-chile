{"html": [{"t": "<div><div class=\"p\">&#xFEFF;&nbsp; &nbsp;  BLOQUEO DEL CALLAO.</div><br><div class=\"p\">&nbsp; &nbsp;  El Presidente de la Rep&#xFA;blica de Chile.</div><br><div class=\"p\">&nbsp; &nbsp;  De conformidad con la declaracion de guerra proclamada con esta fecha al titulado Gobierno del Jeneral don Luis Jos&#xE9; Orbegoso, he acordado y decreto:</div></div>", "i": 10025881}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art 1.o El puerto del Callao deber&#xE1; considerarse y ser&#xE1;&nbsp; efectivamente bloqueado por los buques de guerra chilenos, desde el diez de Noviembre pr&#xF3;ximo.</div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Comun&#xED;quese este decreto a quienes corresponda y publ&#xED;quese por la prensa.</div><div class=\"p\">&nbsp; &nbsp;  Dado en el Palacio de Gobierno, sellado con las armas de la Rep&#xFA;blica, y refrendado por el Ministro de Estado y del despacho de Guerra y Marina, en Santiago de Chile, a 17 de Octubre de 1838.</div></div>", "i": 10025882}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO.</div><div class=\"p\">&nbsp; &nbsp;  Joaqu&#xED;n Tocornal.</div></div>", "i": 10025883}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE GUERRA Y MARINA"], "titulo_norma": "BLOQUEO DEL CALLAO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1838-10-17", "doble_articulado": false, "id_norma": "1131814", "numero_fuente": "1838", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1838-10-17", "hasta": "", "tipo_version": "3", "tipo_version