{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6245431}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 132, de 15 de Octubre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XII Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a Germ&#xE1;n Aliro Barr&#xED;a Mancilla, para prestar servicio de taxi colectivo urbano, cumpliendo el siguiente recorrido:</div><br><div class=\"p\">LINEA N&#xB0; 18</div><br><div class=\"p\">&nbsp; &nbsp;  Ida: R&#xF3;mulo Correa frente edificios Empart - Se&#xF1;oret - Maip&#xFA; - Chilo&#xE9; - Paraguaya - 21 de Mayo - frente ex-Pesquera Ceprel.</div><div class=\"p\">&nbsp; &nbsp;  Regreso: Frente ex-Pesquera Ceprel - 21 de Mayo - Magallanes - Diagonal Don Bosco Avda. Bulnes - R&#xF3;mulo Correa frente edificios Empart Plazoleta.-</div><br></div>", "i": 6245432}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Urbano Peralta, Secretario Regional Ministerial de Transportes y Telecomunicaciones XII Regi&#xF3;n.</div><br></div>", "i": 6245433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "132 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-132 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-10-15", "doble_articulado": false, "id_norma": "159528", "numero_fuente": "32609", "tipo_version": "3", "tipo_version