{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,142.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6177155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por el coronel graduado de Ej&#xE9;rcito, don Dem&#xF3;filo Fuenzalida, conc&#xE9;dese, por gracia, a su hija pol&#xED;tica do&#xF1;a Lucrecia Za&#xF1;artu de Fuenzalida, una pension mensual de cincuenta y tres pesos ($ 53), que disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6177156}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto ha transcurrido el plazo establecido en el art&#xED;culo 40 de la Constitucion Pol&#xED;tica, por tanto, oido el Consejo de Estado, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintinueve de noviembre de mil novecientos dieciseis.- Juan Luis Sanfuentes.- Oscar Urz&#xFA;a. </div></div>", "i": 6177157}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3142", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3142"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-11-29", "doble_articulado": false, "id_norma": "138973", "numero_fuente": "11653", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-12-20", "vigencias": [{"desde": "1916-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-12-20", "fin_vigencia": ""}