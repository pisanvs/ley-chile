{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A SUPERMERCADO LAS BRISAS LOS ANGELES LTDA.</div><br></div>", "i": 6376488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex-0319, de fecha 19 de marzo de 2002, revoca a Supermercado Las Brisas Los Angeles Ltda., RUT N&#xBA; 79.577.900-0, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las ventas de Harina, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 17 de la resoluci&#xF3;n Ex. N&#xBA; 5282/2000, de la Direcci&#xF3;n Nacional. </div></div>", "i": 6376489}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 19 de marzo de 2002.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6376490}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "319 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-319 EXENTA"}, {"tipo": "3", "numero": "DRE-0319 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-0319 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A SUPERMERCADO LAS BRISAS LOS ANGELES LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-19", "doble_articulado": false, "id_norma": "196611", "numero_fuente": "37232", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-11", "vig