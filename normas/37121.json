{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297661}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.532, de 26 de Octubre de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por SALMONES UNIMARC S.A., R.U.T. N&#xB0; 88.541.600-4, para el centro de cultivo ubicado al Este de Isla Traigu&#xE9;n, Canal Costa, Comuna y Provincia de Ays&#xE9;n, XI Regi&#xF3;n, por no haberse aprobado el respectivo proyecto t&#xE9;cnico, conforme a lo dispuesto en el art&#xED;culo 67, inciso 5&#xB0;, de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8297662}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Octubre de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297663}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1532", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1532"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SALMONES UNIMARC S.A.", "CONCESION ACUICULTURA", "AYSEN", "DECIMOPRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-26", "doble_articulado": false, "id_norma": "37121", "numero_fuente": "35309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-11-06", "vigencias": [{"desde": "1995-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"