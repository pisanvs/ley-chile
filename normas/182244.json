{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 878 EXENTA, DE 2001 </div></div>", "i": 6324230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 878, de fecha 8 de febrero de 2001, se rechaza la solicitud de reconocimiento oficial como Centro de Formaci&#xF3;n T&#xE9;cnica, presentada por la Sociedad Urrutia Aleu Limitada, organizadora del Centro de Formaci&#xF3;n T&#xE9;cnica Intecap de la ciudad de Los Angeles.</div><div class=\"p\">&nbsp; &nbsp;  Por este mismo documento se elimina del Libro de Registro de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xBA; 282 de fecha 27 de septiembre de 2000, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Intecap de la ciudad de Los Angeles.</div><br></div>", "i": 6324231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de febrero de 2001.- Patricio Vilaplana Barberis, Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 6324232}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "878 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-878 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 878 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-08", "doble_articulado": false, "id_norma": "182244", "numero_fuente": "36897", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-24", "vigencias": [{"desde": "2001-02-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-02-24"