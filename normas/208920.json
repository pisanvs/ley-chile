{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ley n&#xFA;m. 4,870</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional, ha dado su aprobaci&#xF3;n al siguiente,</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 7298850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Supr&#xED;mese del inciso 2&#xBA; del art&#xED;culo &#xFA;nico de la ley n&#xFA;mero 4,683, de 14 de Noviembre de 1929, las palabras finales que dicen &quot;percibidas en el a&#xF1;o respectivo&quot;.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7298851}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a nueve de Agosto de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Julio Philippi.</div><br></div>", "i": 7298852}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4870", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4870"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEY NUM. 4.870", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-08-09", "doble_articulado": false, "id_norma": "208920", "numero_fuente": "15761", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-08-29", "vigencias": [{"desde": "1930-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"