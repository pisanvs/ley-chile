{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6038461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 249, de 31 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s 1, 2 y 4, Canal Relb&#xFA;n y N&#xBA; 1, Canal Relb&#xFA;n Bocatoma, superficies 8.160, 15.630, 6.340 y 4.944 M&#xB2; respectivamente, roles de aval&#xFA;o 159-48, 159-39, 159-37 y 159-48, comuna de Pemuco, para la obra Proyecto Laja Diguill&#xED;n, Area de Riego Pemuco y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Carlos Antonio Flores&nbsp; Valdebenito, Miguel Luis Barrera Cartes y Juan Rosalino Flores Flores, ascendentes a las cantidades de $3.528.691, $4.110.116 y $2.018.136 respectivamente.-</div><br></div>", "i": 6038462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6038463}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "249", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-249"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "PEMUCO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "73296", "numero_fuente": "35779", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-02", "vigencias": [{"desde": "1997-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-02", "fin_vigencia": "", "tipo_version": "3"}], "event