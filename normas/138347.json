{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8346092}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.206, de 23 de junio de 1999, de esta Subsecretar&#xED;a, se rectifica las letras b) y c) del numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 274 de 1999, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a PESQUERA FRIOSUR S.A., para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Friosur VI&apos;&apos;, en el sentido de reemplazar la expresi&#xF3;n &apos;&apos;al Oeste&apos;&apos; por la expresi&#xF3;n &apos;&apos;hasta el l&#xED;mite Oeste&apos;&apos;.</div><br></div>", "i": 8346093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de junio de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8346094}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1206", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1206"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-23", "doble_articulado": false, "id_norma": "138347", "numero_fuente": "36402", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-02", "vigencias": [{"desde": "1999-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-07-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-07-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modif