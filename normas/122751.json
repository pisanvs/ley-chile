{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8332918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.080, de 30 de julio de 1998, de esta Subsecretar&#xED;a, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por JUANA NEGUE NEGUE, para operar un centro de cultivo en R&#xED;o Inio, comuna de Quell&#xF3;n, provincia de Chilo&#xE9;, X Regi&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 746, de 1991, de esta Subsecretar&#xED;a, en virtud de la presente resoluci&#xF3;n. </div></div>", "i": 8332919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de julio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8332920}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1080", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1080"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "QUELLON", "JUANA NEGUE NEGUE", "DECIMA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-30", "doble_articulado": false, "id_norma": "122751", "numero_fuente": "36132", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-05", "vigencias": [{"desde": "1998-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-08-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion