{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUMENTO DEL EJERCITO Lei n&#xFA;m. 290.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 9072124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Autor&#xED;zase al Presidente de la Rep&#xFA;blica para elevar de seis mil a nueve mil hombres el n&#xFA;mero de fuerzas del Ej&#xE9;rcito permanente, debiendo estenderse esta autorizacion, para los efectos de la vijencia, incorporada a la lei de 26 de Noviembre de 1894, n&#xFA;mero 214.</div><br><br></div>", "i": 9072125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 18 de Agosto de 1895.- Jorje Montt.- Ismael Valdes Valdes.</div><br></div>", "i": 9072126}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "290", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-290"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "AUMENTO DEL EJERCITO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO", "FUERZAS PERMANENTES", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-08-18", "doble_articulado": false, "id_norma": "22143", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-08-18", "vigencias": [{"desde": "1895-08-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-08-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":