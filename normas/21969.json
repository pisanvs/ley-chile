{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension Lei n&#xFA;m. 103.- Santiago, a 11 de Setiembre de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946784}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a do&#xF1;a Perpetua Osorio, nieta lej&#xED;tima del coronel de la Independencia don Agust&#xED;n L&#xF3;pez, una pensi&#xF3;n de cuarenta pesos mensuales de que gozar&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 5946785}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Manuel Villamil Blanco.</div><br></div>", "i": 5946786}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "103", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-103"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PERPETUA OSORIO", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-09-11", "doble_articulado": false, "id_norma": "21969", "numero_fuente": "4621", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-09-15", "vigencias": [{"desde": "1893-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones