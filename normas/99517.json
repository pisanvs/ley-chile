{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6112014}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xBA;561, de 29 de abril de 1998, se expropiaron los lotes de terreno N&#xBA;s. 2-A y 11-A, superficies 2.163 y 420 M2., respectivamente, roles de aval&#xFA;o 19-19 y 62-189, comuna de &#xD1;iquen, para la obra Ruta 5, Tramo Talca - Chill&#xE1;n, Intersecciones Desniveladas, Acceso a San Gregorio y Acceso a Tiuquilemu y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios do&#xF1;a Virginia I. Mu&#xF1;oz L&#xF3;pez y don Alberto Peterman Trillat, ascendente a las cantidades de $7.060.074, para el lote N&#xBA;2-A y $675.690, para el lote N&#xBA;11-A.</div><br></div>", "i": 6112015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6112016}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "561", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-561"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "IQUEN", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-29", "doble_articulado": false, "id_norma": "99517", "numero_fuente": "36089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-15", "vigencias": [{"desde": "1998-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":