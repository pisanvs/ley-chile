{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 104.- Santiago, a 11 de Setiembre de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese al &#xED;tem 1 de la partida 27 del Presupuesto del Ministerio de Marina un suplemento de ciento ochenta i cinco mil cuatrocientos treinta i siete libras esterlinas diez chelines (L 185,437.10).</div><br><br></div>", "i": 5946788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Manuel Villamil Blanco.</div><br></div>", "i": 5946789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "104", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-104"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1893", "MODIFICACION", "MINISTERIO", "MARINA", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-09-11", "doble_articulado": false, "id_norma": "21970", "numero_fuente": "4621", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-09-15", "vigencias": [{"desde": "1893-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-09-15", "fin_vigencia": "", "tipo_version": "3"}], "e