{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9304171}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.601, de 3 de octubre de 2012, de esta Subsecretar&#xED;a, rectif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1040877&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.491 de 2012</a> y de esta Subsecretar&#xED;a de Pesca, que estableci&#xF3; la n&#xF3;mina definitiva de armadores artesanales y sus embarcaciones, que participaron de las pescas de investigaci&#xF3;n a que se refiere el art&#xED;culo 3&#xB0; de la ley N&#xB0; 20.560, en el sentido de modificar sus numerales 1.-, 2.-, 5.-, 6.-, 7.-, 8.-, 9.-, 11.-. 12.- y 13.- de conformidad a lo indicado en resoluci&#xF3;n extractada.</div></div>", "i": 9304172}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de octubre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9304173}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2601 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2601 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-03", "doble_articulado": false, "id_norma": "1044515", "numero_fuente": "40380", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-08", "vigencias": [{"desde": "2012-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-08", "fin_vigencia": ""}, "vigen