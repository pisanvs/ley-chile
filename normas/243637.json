{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6546888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 957 de fecha 29 de septiembre del 2005, se expropiaron los lotes de terreno N&#xBA;s. 1 y 2 superficies 1.170 y 1.257 m2, respectivamente, rol N&#xBA; 603-127, comuna de San Ignacio, VIII Regi&#xF3;n para la obra &quot;Proyecto Laja Diguill&#xED;n, Canal Matriz Diguill&#xED;n Larqui, Laja Diguill&#xED;n Lotes Adicionales a Canal Matriz Km. 7,906 a Km. 8,032&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario V&#xED;ctor Javier Castillo Salazar, ascendente a la cantidad de $2.332.644.- para los lotes N&#xBA;s. 1 y 2.</div><br></div>", "i": 6546889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6546890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "957 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-957 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-29", "doble_articulado": false, "id_norma": "243637", "numero_fuente": "38301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-02", "vigencias": [{"desde": "2005-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-1