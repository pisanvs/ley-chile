{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL ITEM 07/01/27.7 DEL PRESUPUESTO DEL MINISTERIO DE ECONOMIA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase en el &#xED;tem 07/01/27.7 del Presupuesto del Ministerio de Econom&#xED;a del a&#xF1;o 1961, la glosa &quot;Consorcio Cooperativas Vitivin&#xED;colas de Chile&quot; por &quot;Cooperativas Vitivin&#xED;colas de Chile&quot;.</div><br></div>", "i": 8281558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a dos de Septiembre de mil novecientos sesenta y uno.- JORGE ALESSANDRI RODRIGUEZ.- L. Escobar C.</div><br></div>", "i": 8281559}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14619", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14619"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "MODIFICA EL ITEM 07/01/27.7 DEL PRESUPUESTO DEL\nMINISTERIO DE ECONOMIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O 1961", "MODIFICA", "MINISTERIO", "ECONOMIA", "COOPERATIVAS VITIVINICOLAS CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1961-09-02", "doble_articulado": false, "id_norma": "27812", "numero_fuente": "25042", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1961-09-09", "vigencias": [{"desde": "1