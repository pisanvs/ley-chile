{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 181 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6255371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo Industrial Particular de Pitrufqu&#xE9;n.</div><br><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- Electr&#xF3;nica Industrial.</div><div class=\"p\">&nbsp; &nbsp;  2.- Mec&#xE1;nica de Combusti&#xF3;n Interna y Automotriz. </div></div>", "i": 6255372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante.</div><br></div>", "i": 6255373}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "181 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-181 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 181\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "162447", "numero_fuente": "32283", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-09-28", "vigencias": [{"desde": "1985-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-09-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-09-2