{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6497996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.303, de 25 de agosto de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a LUIS HERNAN CARVAJAL JOPIA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Km. 920, Obispito, Caldera, III Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de proceso de cocido, fresco-enfriado, fresco-refrigerado, congelado, seco-salado, ahumado, harina y alga seca, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6497997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6497998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2303 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2303 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-25", "doble_articulado": false, "id_norma": "230595", "numero_fuente": "37969", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-24", "vigencias": [{"desde": "2004-09-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-09-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in