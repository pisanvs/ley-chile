{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 6.095 EXENTA, DE 2018</div></div>", "i": 9975000}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente, se han modificado, a contar del a&#xF1;o escolar 2019, las resoluciones exentas Nos <a href=\"https://www.leychile.cl/Navegar?idNorma=182292&amp;idParte=&amp;idVersion=\">540, de 2001</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=196617&amp;idParte=&amp;idVersion=\">2.614, de 2002</a>, modificada por la resoluci&#xF3;n exenta N&#xBA; 4.715, de 2008, todas del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Saint John&apos;s Villa Academy, comuna de La Reina, provincia de Santiago, Regi&#xF3;n Metropolitana, en el sentido de sustituir los planes de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Sector de Cultura Religiosa para 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div></div>", "i": 9975001}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de octubre de 2018.- Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9975002}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6095 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6095 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 6.095 EXENTA, DE 2018", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1507808", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018