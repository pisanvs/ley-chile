{"html": [{"t": "<div><div class=\"p\">Jurisdiccion de los delegados de minas</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 5 de 1820.</div></div>", "i": 9921652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Las justicias i jueces de la Rep&#xFA;blica no deben por motivo ni pretesto alguno embarazar la jurisdiccion i funciones de los delegados de minas en lo relativo a su fuero privativo: por el contrario, son obligados a prestarles los ausilios que les pidieren para el cumplimiento de sus deberes, con responsabilidad por cualquier infraccion u omision.-</div></div>", "i": 9921653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ins&#xE9;rtese este decreto en la Gazeta Ministerial.-O&apos;Higgins.-Echeverr&#xED;a.</div></div>", "i": 9921654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Jurisdiccion de los delegados de minas", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1820-12-05", "doble_articulado": false, "id_norma": "1117052", "numero_fuente": "1820", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1820-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1820-12-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1820-12-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2018-06-12", "fecha_version": "1820-12-05", "fecha_actualizacion_texto": "2018-06-12", "tipo_tratado":