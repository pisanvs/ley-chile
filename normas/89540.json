{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SUSESION No. 69</div><br><div class=\"p\">Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n No. 69, celebrada el 02 de noviembre de 1990, adopt&#xF3; el siguiente acuerdo:</div><br></div>", "i": 6082984}, {"t": "<div><div class=\"p\">69-01-901102 - Modifica Anexo No. 1 del Cap&#xED;tulo XVIII del T&#xED;tulo I del Compendio de Normas de Cambios Internacionales. Se acord&#xF3; sustituir, en el primer inciso del No. 1 del Anexo No. 1 del Cap&#xED;tulo XVIII del T&#xED;tulo I del Comprendio de Normas de Cambios Internacionales, el porcentaje &quot;87%&quot; por &quot;82% &quot;.</div><br></div>", "i": 6082985}, {"t": "<div><div class=\"p\">Santiago, 02 de noviembre de 1990.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino.</div><br></div>", "i": 6082986}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "69", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-69"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO BANCO CENTRAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-11-02", "doble_articulado": false, "id_norma": "89540", "numero_fuente": "33810", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-11-05", "vigencias": [{"desde": "1990-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-11-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fe