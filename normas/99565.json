{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA; 679</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 679, celebrada el 28 de mayo de 1998, adopt&#xF3; el siguiente Acuerdo:</div><br><br><br><br></div>", "i": 6112153}, {"t": "<div><div class=\"p\">679-02-980528 - Atenci&#xF3;n de p&#xFA;blico el d&#xED;a 31 de diciembre de cada a&#xF1;o</div><br><div class=\"p\">Se acord&#xF3; lo siguiente:</div><br><br><div class=\"p\">1.&nbsp;  Agregar el siguiente N&#xBA; 3 al Acuerdo N&#xBA; 01-03-891209:</div><br><div class=\"p\">&nbsp; &nbsp; &apos;&apos;No obstante lo dispuesto en el n&#xFA;mero 1 precedente, no se atender&#xE1; al p&#xFA;blico el d&#xED;a 31 de diciembre de cada a&#xF1;o&apos;&apos;.</div><br><div class=\"p\">2.&nbsp;  Derogar el Acuerdo N&#xBA; 641-02-971210 publicado en el Diario Oficial de fecha 22 de diciembre de 1997. </div></div>", "i": 6112154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de mayo de 1998.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6112155}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "679", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-679"}, {"tipo": "5", "numero": "679-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-679-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE;CHILE EN SU SESION Nº 679", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BANCO CENTRAL DE CHILE", "BANCOS", "HORARIO DE ATENCION", "31-DIC- DE CADA A O", "JORNADA DE TRABAJO", "FERIADO BANCARIO", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogaci