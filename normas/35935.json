{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 960, de 20 de mayo de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; decl&#xE1;rase la caducidad de las Resoluciones N&#xB0; 1.418, de 1992, N&#xB0; 35 y N&#xB0; 874, ambas de 1995, todas de esta Subsecretar&#xED;a, que autorizaron a don ROQUE MASSERA UNGERER, para desarrollar actividades extractivas con la nave &quot;Franco M&quot;, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br><br></div>", "i": 8294998}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 20 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294999}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "960", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-960"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ROQUE MASSERA UNGERER", "CADUCIDAD", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-20", "doble_articulado": false, "id_norma": "35935", "numero_fuente": "35477", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-28", "vigencias": [{"desde": "1996-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-05-28", "fin_vigencia": "", "tipo_ve