{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 73, DE 1987 </div></div>", "i": 6214471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se ha procedido a aprobar, a contar de 1987, planes y programas especiales de orientaci&#xF3;n laboral para alumnos discapacitados al Centro de Capacitaci&#xF3;n Laboral E No. 580 de Cosmito, Concepci&#xF3;n, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o.</div><div class=\"p\">&nbsp; &nbsp;  El plan aprobado se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de cuatro a&#xF1;os y contempla nivel de pre formaci&#xF3;n, formaci&#xF3;n y producci&#xF3;n.</div><div class=\"p\">La evaluaci&#xF3;n y promoci&#xF3;n de los alumnos se regir&#xE1; por las normas que se se&#xF1;alan.</div><br></div>", "i": 6214472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6214473}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "73 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-73 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 73, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-25", "doble_articulado": false, "id_norma": "149983", "numero_fuente": "32806", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-27", "vigencias": [{"desde": "1987-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-27", "fin_vigencia": ""}, "vigencias