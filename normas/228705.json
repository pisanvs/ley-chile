{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO DE EXPROPIACION </div></div>", "i": 6491086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Secci&#xF3;n 2da. N&#xB0; 1.121, de 16.10.87, Alcalde I. Municipalidad Santiago dispone expropiaci&#xF3;n total conforme Decreto Supremo N&#xB0; 458 Vivienda y Urbanismo, Decreto Ley 2.186 y 1.289, inmueble Abate Molina 652 rol N&#xB0; 890-172 Stgo., dominio aparente Felipe Morales Calvo y Otro. Deslindes: Norte: 39 mts. y 8,80 mts. otros propietarios. Sur: 47,80 mts. propiedad municipal. Oriente: 18,20 mts. otro propietario. Poniente: 7,95 mts. calle Abate Molina y 10,25 mts. otro propietario. Superficie aproximada 470,20 m2. Indemnizaci&#xF3;n provisional $ 2.600.000.- pagadera contado.</div><br></div>", "i": 6491087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gustavo Alessandri V., Alcalde Santiago. </div></div>", "i": 6491088}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1121", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1121"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "EXTRACTO DE DECRETO DE EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-16", "doble_articulado": false, "id_norma": "228705", "numero_fuente": "32909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-02", "vigencias": [{"desde": "1987-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu