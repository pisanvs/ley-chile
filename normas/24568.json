{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza erecci&#xF3;n monumento a don Diego Barros Arana Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8277303}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se autoriza la erecci&#xF3;n en Santiago, de un monumento costeado por subscripci&#xF3;n popular, destinado a perpetuar la memoria del ilustre servidor p&#xFA;blico e historiador, don Diego Barros Arana.</div><div class=\"p\">&nbsp; &nbsp; La Municipalidad de Santiago se&#xF1;alar&#xE1; el sitio en que ha de erigirse el monumento.</div><br></div>", "i": 8277304}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticuatro de Noviembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez C.- Enrique Balmaceda.</div><br></div>", "i": 8277305}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4211", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4211"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA MONUMENTO A DON DIEGO BARROS ARANA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIEGO BARROS ARANA", "MONUMENTO", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-11-24", "doble_articulado": false, "id_norma": "24568", "numero_fuente": "14939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1927-12-05", "vigencias": [{"desde": "1927-12-05", "hasta": "", "tipo_version": "3", "tipo_version