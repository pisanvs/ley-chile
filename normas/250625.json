{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6573331}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.305, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; de la resoluci&#xF3;n N&#xBA; 703 de 2006, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD CATOLICA DEL NORTE, sede Coquimbo para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Monitoreo de la captura de Anchoveta (Engraulis ringens) en el litoral de la IV Regi&#xF3;n, Temporada 2006&quot;, en el sentido de indicar que la cuota m&#xE1;xima total indicada en el inciso primero de dicho numeral, asignada a las embarcaciones artesanales autorizadas a participar en la citada pesca de investigaci&#xF3;n, podr&#xE1; ser capturada a contar de la fecha de la presente resoluci&#xF3;n.</div><br></div>", "i": 6573332}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de mayo de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6573333}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1305 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1305 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-15", "doble_articulado": false, "id_norma": "250625", "numero_fuente": "38491", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-17", "vigencias": [{"desde": "2006-06-17", "hasta": "", "tipo_version":