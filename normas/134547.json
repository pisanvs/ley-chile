{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,219.- Santiago, 1&#xBA; de julio de 1899- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162714}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Decl&#xE1;rase de abono, para los efectos de su retiro, al coronel don Florencio Baeza, los cuatro a&#xF1;os i diez meses que permaneci&#xF3; como cadete en la Escuela Militar, desde el 1.&#xBA; de febrero de 1867 hasta el 30 de diciembre de 1871.&quot; </div></div>", "i": 6162715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- J. A. Figueroa.</div><br></div>", "i": 6162716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1219", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1219"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-07-01", "doble_articulado": false, "id_norma": "134547", "numero_fuente": "6338", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-07-03", "vigencias": [{"desde": "1899-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1