{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISI&#xD3;N DE GU&#xCD;A DE DESPACHO ESPECIAL</div></div>", "i": 9322692}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 128 del 20 diciembre de 2012, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Autoriza la emisi&#xF3;n de Gu&#xED;as de Despacho en formato especial a contribuyentes que realicen movimiento o traslado de animales.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2012.</div></div>", "i": 9322693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "128 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-128 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISIÓN DE GUÍA DE DESPACHO ESPECIAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-20", "doble_articulado": false, "id_norma": "1047492", "numero_fuente": "40444", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-12-27", "vigencias": [{"desde": "2012-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-12-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-12-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingre