{"html": [{"t": "<div><div class=\"p\">&amp;#160;</div></div>", "i": 8468736}, {"t": "<div><br><div class=\"p\">Por decreto (exento) MOP. N&#xBA;409, de fecha 27 de febrero del 2009, se expropiaron los lotes de terrenos N&#xBA;s 26 y 29, superficie 574 y 1.679 m2 respectivamente, Rol N&#xBA;190-70, comuna de Cobquecura, VIII Regi&#xF3;n para la obra &quot;Camino Ruta N-102-M, Sector Cobquecura - L&#xED;mite Regional, Tramo II, Km. 10,50000 al Km. 18,60807, VIII Regi&#xF3;n.&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario RAUL ENRIQUE MU&#xD1;OZ VERA, ascendente a la cantidad de $2.444.487.</div></div>", "i": 8468737}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8468738}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "409 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-409 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-27", "doble_articulado": false, "id_norma": "288524", "numero_fuente": "39327", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-04-01", "vigencias": [{"desde": "2009-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "114", "fecha_ingreso": "2009-04-01", "fecha_version": "2009-04-01", "actualizado_por": "114", "fecha_actualizacion_texto