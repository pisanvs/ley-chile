{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta la pension de que disfrutan los soldados don Aniceto Garcia i don Francisco Vel&#xE1;squez</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,693.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se concede por gracia, a cada uno de los soldados inv&#xE1;lidos del Ej&#xE9;rcito Aniceto Garcia i Francisco Vel&#xE1;squez una pension mensual de 10 pesos en vez de la de 7 pesos de la que actualmente disfrutan. </div></div>", "i": 5953901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 4 de Setiembre de 1912.- RAMON BARROS LUCO.- Claudio Vicu&#xF1;a S.</div><br></div>", "i": 5953902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2693", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2693"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Aumenta la pension de que disfrutan los soldados don;Aniceto Garcia i don Francisco Velásquez", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ANICETO GARCIA", "FRANCISCO VELASQUEZ", "PENSION", "INVALIDEZ", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-09-04", "doble_articulado": false, "id_norma": "23429", "numero_fuente": "10371", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-09-05", "vigencias": [{"desde": "1912-09-05",