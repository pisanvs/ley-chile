{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO EX. N&#xBA;10, EN PARTE QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 153 exento.- Santiago, 16 de marzo de 2004. </div></div>", "i": 6491269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Modifica decreto Ex. N&#xBA;10, de 16 de enero de 2004, en el sentido que se otorga nuevo plazo de 30 d&#xED;as para publicar el extracto.</div><div class=\"p\">&nbsp; &nbsp;  2.- El presente decreto forma parte integrante del que se modifica.</div><br></div>", "i": 6491270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, reg&#xED;strese en el Ministerio de Bienes Nacionales, comun&#xED;quese, publ&#xED;quese en extracto en el &quot;Diario Oficial&quot; y arch&#xED;vese. Por orden del Presidente de la Rep&#xFA;blica, Jaime Ravinet de la Fuente, Ministro de Bienes Nacionales.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud., Jacqueline Weinstein Levy, Subsecretaria de Bienes Nacionales.</div><br></div>", "i": 6491271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "153 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-153 EXENTO"}], "organismos": ["MINISTERIO DE BIENES NACIONALES"], "titulo_norma": "MODIFICA DECRETO EX. Nº10, EN PARTE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-16", "doble_articulado": false, "id_norma": "228770", "numero_fuente": "37930", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-07", "vigencias": [{"desde": "2004-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-08-0