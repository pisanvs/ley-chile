{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,529.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por el sarjento mayor de Ej&#xE9;rcito don Jos&#xE9; Fidel Riquelme, se le concede, por gracia, el abono de los cuatro dias que le faltan para enterar dieciocho a&#xF1;os de servicios.</div><br></div>", "i": 6172183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto,&nbsp; prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de agosto de mil novecientos once.- Ramon Barros Luco.- An&#xED;bal Rodr&#xED;guez.</div><br></div>", "i": 6172184}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2529", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2529"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-08-05", "doble_articulado": false, "id_norma": "137461", "numero_fuente": "10050", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-08-07", "vigencias": [{"desde": "1911-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-08-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [