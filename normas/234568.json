{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;819 EXENTO, DE 2004 </div></div>", "i": 6512847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;819 de fecha 29 de septiembre de 2004, de Educaci&#xF3;n, se autoriza a la Universidad de Aconcagua, de acuerdo a la modificaci&#xF3;n del convenio de examinaci&#xF3;n con la Universidad de La Serena, para impartir en las sedes que se se&#xF1;alan, la siguiente carrera:</div><br><div class=\"p\">&nbsp; &nbsp;  Carrera: Educaci&#xF3;n General B&#xE1;sica conducente al grado acad&#xE9;mico de Licenciado en Educaci&#xF3;n y al t&#xED;tulo profesional de Profesor en Educaci&#xF3;n B&#xE1;sica - Sedes La Ligua, Limache y Santiago.</div><br></div>", "i": 6512848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de diciembre de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6512849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "819 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-819 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº819 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-29", "doble_articulado": false, "id_norma": "234568", "numero_fuente": "38057", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-11", "vigencias": [{"desde": "2005-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-01-11", "fin_vigencia": "", "tipo_version