{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 200.- Santiago, a 25 de Agosto de 1894.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese por gracia a do&#xF1;a C&#xE1;rmen Pe&#xF1;ailillo, viuda del jeneral de brigada don Jos&#xE9; Hinojosa, i a sus hijas solteras, una pension anual vitalicia de mil ochocientos pesos ($1,800), la que gozar&#xE1;n en conformidad a la lei de montep&#xED;o militar i con esclusion de toda otra asignacion fiscal.</div><br><br></div>", "i": 5947131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.-</div><div class=\"p\">S. Aldunate B.</div><br></div>", "i": 5947132}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "200", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-200"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARMEN PE AILILLO", "HIJAS SOLTERAS", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-25", "doble_articulado": false, "id_norma": "22058", "numero_fuente": "4909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-09-05", "vigencias": [{"desde": "1894-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-09-05", "fin_vigencia": ""},