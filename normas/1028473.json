{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9163901}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.072, de 3 agosto de 2011 de esta Subsecretar&#xED;a, apl&#xED;case a TRUSAL S.A., sanci&#xF3;n administrativa de multa equivalente a 2.000 unidades tributarias mensuales por la infracci&#xF3;n prevista en el 118 ter letra b) de la Ley General de Pesca y Acuicultura en relaci&#xF3;n a los art&#xED;culos 2 N&#xBA; 52 y 86 del mismo cuerpo legal y el DS N&#xBA; 319, de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. La multa impuesta deber&#xE1; ser pagada en Tesorer&#xED;a General de la Rep&#xFA;blica.</div></div>", "i": 9163902}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de Agosto de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9163903}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2072", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2072"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-08-03", "doble_articulado": false, "id_norma": "1028473", "numero_fuente": "40030", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-08-08", "vigencias": [{"desde": "2011-08-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-08-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-08-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": []