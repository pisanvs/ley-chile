{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8316933}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 160 de 01 de Febrero de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a. Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 3&#xB0; de la resoluci&#xF3;n No. 1.367 de 1989, de esta Subsecretar&#xED;a, por el cual se autoriz&#xF3; a Sociedad Pesquera Guanaye Limitada. R.U.T. No.</div><div class=\"p\">92.063.000-6, domiciliada en Santiago, para ampliar actividades pesqueras, en orden a se&#xF1;alar que la zona de operaci&#xF3;n de la embarcaci&#xF3;n autorizada ser&#xE1; el litoral de las Regiones III a VII y de la IX Regi&#xF3;n al paralelo 43&#xB0; L.S., excluidas las correspondientes aguas interiores. </div></div>", "i": 8316934}, {"t": "<div><div class=\"p\">Valpara&#xED;so. 01 de Febrero de 1990.- Roberto Cabezas Bello. Subsecretario de Pesca.</div><br></div>", "i": 8316935}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "160", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-160"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-02-01", "doble_articulado": false, "id_norma": "85075", "numero_fuente": "33607", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-27", "vigencias": [{"desde": "1990-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-27", "fin_vigencia": ""}, "vigencias_version_nor