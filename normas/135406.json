{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6165314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 105, de 19 de Febrero de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a don Jorge Orlando Ulloa Navarrete, para efectuar todo tipo de servicio de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6165315}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gast&#xF3;n Alvarez Briones, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o-B&#xED;o. </div></div>", "i": 6165316}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "105 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-105 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-19", "doble_articulado": false, "id_norma": "135406", "numero_fuente": "33021", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-15", "vigencias": [{"desde": "1988-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-03-15", "fin_vigencia": "", "tipo_version": "3"}