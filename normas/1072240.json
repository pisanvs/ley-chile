{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9539121}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xBA;1198 de 28 de noviembre de 2014, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1046368&amp;idParte=0&amp;idVersion=\">Decreto MOP (Exento) N&#xBA;2609</a> de 31 de octubre de 2012, que orden&#xF3; la expropiaci&#xF3;n, entre otros, el Lote N&#xBA;82, en la parte que se refiere al n&#xFA;mero de rol de aval&#xFA;o y nombre del propietario seg&#xFA;n rol de aval&#xFA;o, debe decir: SEPULVEDA PARADA MARIO RAFAEL, rol de aval&#xFA;o 3721-2, Comuna de Talca, superficie 772,37m2., expropiado con motivo de la obra: &quot;Camino Ampliaci&#xF3;n Reposici&#xF3;n Ruta 115-CH, Sector Talca - San Clemente, Tramo I Talca - Variante San Clemente, kil&#xF3;metro 0,00000 a km. 13,92941, Comuna de Talca, Provincia de Talca, Regi&#xF3;n del Maule&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978. </div><br></div>", "i": 9539122}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas (TP).</div><br></div>", "i": 9539123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1198 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1198 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-11-28", "doble_articulado": false, "id_norma": "1072240", "numero_fuente": "41032", "tipo_version": "3", "tipo_version_s": "Única"