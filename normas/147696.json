{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION PARCIAL DE INMUEBLE QUE SE&#xD1;ALA </div><br></div>", "i": 6205385}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;153, de 28 octubre 1999, Serviu V</div><div class=\"p\">Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme</div><div class=\"p\">art&#xED;culo 87 ley 8.946 y decreto ley 2.186, de 1978, de inmueble ubicado calle Jos&#xE9; Angel Ort&#xFA;zar N&#xBA;491-509, rol aval&#xFA;o 9002-8, comuna San Antonio, de dominio Sucesi&#xF3;n Jos&#xE9; del Carmen Far&#xED;as. Comisi&#xF3;n Tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana (arquitecto), Alvaro Verdejo Vidal (ingeniero constructor), y Pablo Caria Giurici (constructor civil) seg&#xFA;n informe fecha 31 agosto 1999, fij&#xF3; monto provisional indemnizaci&#xF3;n en $843.386.-, que ser&#xE1; pagada de contado.-</div><br></div>", "i": 6205386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gerardo Gonz&#xE1;lez L&#xF3;pez, Director (S) Serviu V Regi&#xF3;n.</div><br></div>", "i": 6205387}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "153", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-153"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "V REGIÓN DE VALPARAÍSO"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLE QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-28", "doble_articulado": false, "id_norma": "147696", "numero_fuente": "36514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-15", "vigencias": [{"desde": "1999-11-15", "hasta": "", "tipo_v