{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9061664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.190, de 21 de octubre de 2010, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=77670&amp;idParte=0&amp;idVersion=\">N&#xB0;1.458 de 1997,</a><a href=\"https://www.leychile.cl/Navegar?idNorma=162788&amp;idParte=0&amp;idVersion=\">N&#xB0; 442 de 2000</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=207330&amp;idParte=0&amp;idVersion=\">N&#xB0; 07 de 2003</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1008021&amp;idParte=0&amp;idVersion=\">N&#xB0; 3.676 de 2009</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1011102&amp;idParte=0&amp;idVersion=\">N&#xB0; 731 de 2010</a>, todas de esta Subsecretar&#xED;a, que autorizaron a TOM&#xC1;S HUGO QUEZADA BERNAL, para realizar actividades pesqueras extractivas con la nave &quot;T&#xED;o Tom&#xE1;s&quot;.</div></div>", "i": 9061665, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de octubre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9061666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3190 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3190 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-10-21", "doble_articulado": false, "id_norma": "1019811", "numero_fuente": "39818", "tipo_version": "3", "tipo_version_s": "Única", "