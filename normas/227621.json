{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6487635}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 357 de 21 de junio de 2004 de Serviu Metropolitano, orden&#xF3; expropiaci&#xF3;n, conforme D.L.</div><div class=\"p\">N&#xBA; 2.186 de 1978, del Lote N&#xBA; 34 correspondiente a parte del inmueble ubicado en calle Arica N&#xBA; 4040, presunto rol de aval&#xFA;o N&#xBA; 945-14, comuna de Estaci&#xF3;n Central, aparente dominio de Jovina Rubilar Bustamante. Comisi&#xF3;n integrada por peritos In&#xE9;s Ot&#xE1;rola Castillo, Arquitecto; Leonardo Bast&#xED;as Tessada, Constructor Civil; Patricio &#xD1;&#xFA;&#xF1;ez &#xD1;&#xFA;nez, Arquitecto. Seg&#xFA;n informe de 28 de abril de 2004, fij&#xF3; monto provisional indemnizaci&#xF3;n en $41.513.200.- pagadera al contado.</div><br></div>", "i": 6487636}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6487637}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "357", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-357"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-21", "doble_articulado": false, "id_norma": "227621", "numero_fuente": "37910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-15", "vigencias": [{"desde": "2004-07-15", "hasta": "", "tipo_version": "3", "ti