{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6034296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 177, de 28 de febrero de 1997, se expropiaron los lotes de terreno N&#xBA;s 2, 5, 6 y 7, superficies 1.238, 887, 2.178 y 983, roles de aval&#xFA;o 336-67 y 301-23, respectivamente, comuna de Cunco, para la obra Camino Temuco Cunco Sector III Etapa y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios: Eduardo Valdebenito Arriagada y Ruth Adriana Ahuile Sep&#xFA;lveda y otro, ascendente a las cantidades de $1.053.452.- y $3.252.192.- respectivamente.-</div><br></div>", "i": 6034297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6034298}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "177", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-177"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "CUNCO", "NOVENAREGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-02-28", "doble_articulado": false, "id_norma": "70630", "numero_fuente": "35741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-15", "vigencias": [{"desde": "1997-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CDG", "fecha_ingreso": "1997-04-22", "fecha_version": "1997-04-15", "fec