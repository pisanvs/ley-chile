{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 323, de 14 de Mayo de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 1128, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a do&#xF1;a TERESITA JESUS MASSRI RUIZ, R.U.T. N&#xB0; 11.020.564-3, para operar un establecimiento de cultivo en Chullanqu&#xE9;n, R&#xED;o Maull&#xED;n, Comuna de Maull&#xED;n, Provincia de Llanquihue, X Regi&#xF3;n, por renuncia de su titular, ya individualizada.</div><br></div>", "i": 8291788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 14 de Mayo de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8291789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "323", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-323"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TERESITA JESUS MASSRI RUIZ", "REVOCACION", "AUTORIZACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-05-14", "doble_articulado": false, "id_norma": "34317", "numero_fuente": "34574", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-05-26", "vigencias": [{"desde": "1993-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-05-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-05-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien