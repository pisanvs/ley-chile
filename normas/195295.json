{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6371840}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 104, de fecha 27 de noviembre del a&#xF1;o 2001, se aprob&#xF3; la disoluci&#xF3;n voluntaria de la Cooperativa de Reforma Agraria de Asignatarios San Miguel Limitada, que consta en la escritura p&#xFA;blica suscrita con fecha 17 de julio del 2001, ante el Notario P&#xFA;blico Titular de Talca, don Mario Bravo Ram&#xED;rez.</div><br></div>", "i": 6371841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6371842}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "104", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-104"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-27", "doble_articulado": false, "id_norma": "195295", "numero_fuente": "37204", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-07", "vigencias": [{"desde": "2002-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ing