{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,775.- Santiago, 24 de noviembre de 1905.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Ab&#xF3;nase, por gracia, al sarjento-mayor de Ej&#xE9;rcito don Rudecindo Palacios, los seis meses i tres dias que permaneci&#xF3; licenciado, desde el 11 de agosto de 1869 hasta el 14 de febrero de 1870.</div><br></div>", "i": 6165156}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Manuel F&#xF3;ster R.</div><br></div>", "i": 6165157}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1775", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1775"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-11-24", "doble_articulado": false, "id_norma": "135349", "numero_fuente": "8365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-11-25", "vigencias": [{"desde": "1905-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1905-11-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-22", "fecha_version": "1905-1