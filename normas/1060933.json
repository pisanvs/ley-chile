{"html": [{"t": "<div><div class=\"p\">TELEGRAMA CIRCULAR </div><div class=\"p\">BANCOS&nbsp; &nbsp; &nbsp; N&#xB0; 17&nbsp; </div><div class=\"p\">FINANCIERAS N&#xB0; 15&nbsp; </div><div class=\"p\">Santiago, 28 de julio de 1988.</div></div>", "i": 9575088}, {"t": "<div><div class=\"p\">EN RELACION CON REBAJA EN PORCENTAJES AJUSTE TASACION SOBRE GARANTIAS WARRANTS A QUE SE REFIERE ANEXO N&#xB0; 1 DE CIRCULAR N&#xB0; 2.377-774, DEBE TENERSE PRESENTE QUE ELLA SOLO REGIRA A CONTAR 31 DE MARZO DE 1989 EN CONCORDANCIA CON DISPOSICION MISMA CIRCULAR QUE SE&#xD1;ALA QUE DESDE ESA FECHA SE CONSIDERARAN TALES GARANTIAS COMO VALIDAS PARA EFECTOS MARGENES INDIVIDUALES DE CREDITO UNICAMENTE CUANDO CORRESPONDAN A VALES DE PRENDA EMITIDOS POR ALMACENISTAS CLASIFICADOS EN CATEGORIA &quot;A&quot;, DE ACUERDO CON NORMAS <a href=\"https://www.leychile.cl/Navegar?idNorma=30072&amp;idParte=0&amp;idVersion=\">LEY N&#xB0; 18.690</a> Y CIRCULAR N&#xB0;&nbsp; 2.343-745. SIRVASE HACER ANOTACION MARGINAL EN CIRCULAR N&#xB0; 2.377-774.</div></div>", "i": 9575089}, {"t": "<div><div class=\"p\">SUPERBANCOS</div></div>", "i": 9575090}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "32", "numero": "Bancos 17", "abreviacion": "TCI", "descripcion": "Telegrama Circular", "compuesto": "Telegrama Circular-Bancos 17"}, {"tipo": "32", "numero": "Financieras 15", "abreviacion": "TCI", "descripcion": "Telegrama Circular", "compuesto": "Telegrama Circular-Financieras 15"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE BANCOS E INSTITUCIONES FINANCIERAS"], "titulo_norma": "", "fuente": "Recopilación de instrucciones SBIF", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-07-28", "doble_articulado": fal