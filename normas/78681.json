{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309157}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.576, de 18 de noviembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xBA; 664, de 1994, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA HORIZONTE LTDA., para desarrollar actividades pesqueras extractivas con la nave &quot;Coray I&quot;, por no haber realizado operaciones de pesca por dos a&#xF1;os consecutivos, a partir del mes de julio de 1994, incurriendo en la causal de caducidad prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones, citada en Visto.</div><br></div>", "i": 8309158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de noviembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8309159}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1576", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1576"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA HORIZONTE LTDA.", "CADUCIDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-18", "doble_articulado": false, "id_norma": "78681", "numero_fuente": "35927", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-11-27", "vigencias": [{"desde": "1997-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-11-27", "fin_vigencia": ""}, "vi