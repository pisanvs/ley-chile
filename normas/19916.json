{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 52 EXENTO, DE 1995</div><br><br></div>", "i": 5940328}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 52 de 13 de enero de 1995, se ha aprobado a contar de 1995, un plan especial de estudio al Colegio &quot;The English Institute&quot; de Santiago, en los niveles de ense&#xF1;anza que se indican.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s se aprueba programa de estudio de la asignatura de Computaci&#xF3;n para los cursos y niveles que se indican.</div><br></div>", "i": 5940329}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 13 de enero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5940330}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "52 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-52 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 52 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO THE ENGLISH INSTITUTE", "SANTIAGO", "PROGRAMAS", "ESTUDIO", "PLANES ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-13", "doble_articulado": false, "id_norma": "19916", "numero_fuente": "35114", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-10", "vigencias": [{"desde": "1995-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-03-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version":