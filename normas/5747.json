{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Complementa ley N&#xFA;m. 5,005</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 94.- Santiago, 23 de Junio de 1932.- La Junta de Gobierno dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br></div>", "i": 7123275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Agr&#xE9;gase en la letra d) del art&#xED;culo 6.o de la ley n&#xFA;mero 5.005, de 24 de Noviembre de 1931, la siguiente frase: &quot;y dem&#xE1;s personal del servicio&quot;; y al final de la enumeraci&#xF3;n del mismo art&#xED;culo, el siguiente inciso:</div><div class=\"p\">&nbsp; &nbsp; &quot;Las del servicio de Protecci&#xF3;n de Menores&quot;. </div></div>", "i": 7123276, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o El presente decreto-ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial. </div></div>", "i": 7123277}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- CARLOS DAVILA.- Nolasco C&#xE1;rdenas.- A. Cabero.- Santiago P&#xE9;rez Pe&#xF1;a.</div><br></div>", "i": 7123278}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "94", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-94"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "Complementa ley Núm. 5,005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADMINISTRACION PUBLICA", "REGISTRO CIVIL", "PERSONAL", "VACANTES SERVICIO PROTECCION MENORES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-06-23", "doble_articulado": false, "id_norma": "5747", "numero_fuente"