{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8793485}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.530, de 21 de octubre de 2009, de esta Subsecretar&#xED;a, modif&#xED;case el <a href=\"https://www.leychile.cl/Navegar?idNorma=267812&amp;idParte=0&amp;idVersion=\">numeral 1&#xB0; de la resoluci&#xF3;n exenta N&#xBA;3.559, de 2007, de esta Subsecretar&#xED;a de Pesca</a> que autoriz&#xF3; a SOUTHPACIFIC KORP S.A. para desarrollar actividades pesqueras extractivas con la nave &quot;Vesterveg&quot;, en el sentido de incorporar las siguientes caracter&#xED;sticas n&#xE1;uticas de la nave:</div><br><div class=\"p\">Potencia principal&nbsp;  7.268,00 Hp</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; 2.253,00 Hp.</div></div>", "i": 8793486}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de octubre de 2009.- Germ&#xE1;n Loyola Bast&#xED;as, Subsecretario de Pesca (S).</div></div>", "i": 8793487}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3530 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3530 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2009-10-21", "fecha_derogacion": "2011-10-19", "doble_articulado": false, "id_norma": "1007493", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2009-10-29", "vigencias": [{"desde": "2011-10-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2009-10-29", "hasta": "2011-10-18", "tipo_version": "0", "tipo_versio