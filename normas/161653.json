{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6252871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 192, de 24 de Mayo de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Claudio Oyarz&#xFA;n Felmer, Pedro Saldivia Villarroel y Erminda Ruiz Asencio, para efectuar el servicio de taxi colectivo urbano de la l&#xED;nea N&#xBA; 5 &quot;Mirasol&quot; de Puerto Montt, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xBA; 111,de 27 de Junio de 1984, de esa Secretaria Regional.-</div><br></div>", "i": 6252872}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6252873}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "192 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-192 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-24", "doble_articulado": false, "id_norma": "161653", "numero_fuente": "32186", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-03", "vigencias": [{"desde": "1985-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-03", "fin_vigencia": "", "tipo_version": "3"}], "even