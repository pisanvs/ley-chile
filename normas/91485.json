{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6089096}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 441, de 9 de mayo 1989, de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186, de 1978, parte inmueble ubicado en Santa Isabel No. 464, presunto rol aval&#xFA;os No 621-16, comuna Santiago, aparentemente dominio de don Salom&#xF3;n Mois Sarfaty. Comisi&#xF3;n integrada por peritos Sres. Luis Rojas Quezada, constructor civil, Sergio Rojas Ib&#xE1;&#xF1;ez y Emilio Recabarren Solar, ingenieros civiles, seg&#xFA;n informe de 27.11.88, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 1.501.880.-, pagadera al contado.</div><br></div>", "i": 6089097}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6089098}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "441", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-441"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-09", "doble_articulado": false, "id_norma": "91485", "numero_fuente": "33386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-01", "vigencias": [{"desde": "1989-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha