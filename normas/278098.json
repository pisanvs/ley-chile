{"html": [{"t": "<div><div class=\"p\">AUTORIZA A CONTRIBUYENTE COMO EMISOR DE BOLETAS ELECTR&#xD3;NICAS</div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 108, de 16 de septiembre, que autoriza a contribuyente como emisor de boletas electr&#xF3;nicas.</div><br></div>", "i": 6660133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boletas electr&#xF3;nicas, a contar del mes de septiembre de 2008, al contribuyente RUT N&#xBA; 70.287.900-0.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2008. </div></div>", "i": 6660134}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "108 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-108 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A CONTRIBUYENTE COMO EMISOR DE BOLETAS\nELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-09-16", "doble_articulado": false, "id_norma": "278098", "numero_fuente": "39169", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-09-23", "vigencias": [{"desde": "2008-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-09-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-09-23", "fin_vigencia": "", "tipo_v