{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO NUMERO&nbsp; 410 EXENTO, DE 1997 </div></div>", "i": 6037250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 410 de fecha 16 de abril de 1997, del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Administraci&#xF3;n, el plan y programas de estudios de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en la Sede Central de Osorno y Sede N&#xBA; 1 de Los Angeles, a contar del a&#xF1;o 1997:</div><br><br><div class=\"p\">Carrera&nbsp; &nbsp; :&nbsp; T&#xE9;cnico en Computaci&#xF3;n e Inform&#xE1;tica.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp;  :&nbsp; T&#xE9;cnico de Nivel Superior en Computaci&#xF3;n e</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Inform&#xE1;tica.</div><br><br></div>", "i": 6037251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de mayo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6037252}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "410 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-410 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 410 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA ESCUELA DE ADMINISTRACION", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-16", "doble_articulado": false, "id_norma": "71512", "numero_fuente": "35771", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-22",