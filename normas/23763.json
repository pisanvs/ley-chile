{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede un suplemento de $ 350,000 al Presupuesto de Instruccion del a&#xF1;o 1916</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3.140.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5955067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se autoriza al Presidente de la Rep&#xFA;blica para suplementar con la suma de trescientos cincuenta mil pesos ($ 350,000) al &#xED;tem 2,142, partida 22 del Presupuesto de Instruccion P&#xFA;blica vijente. </div></div>", "i": 5955068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 14 de Noviembre de 1916.- JUAN LUIS SANFUENTES.- Alberto Romero.</div><br></div>", "i": 5955069}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3140", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3140"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "Concede un suplemento de $ 350,000 al Presupuesto de;Instruccion del año 1916", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL DE LA NACION", "1916", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-11-14", "doble_articulado": false, "id_norma": "23763", "numero_fuente": "11625", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-11-16", "vigencias": [{"desde": "1916-11-16", "hasta": "", "tipo_version": "3", "tipo_vers