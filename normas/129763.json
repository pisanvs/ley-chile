{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8338922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.971, de 31 de diciembre de 1998, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 1.467, de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a VASQUEZ Y COMPA&#xD1;IA LIMITADA, para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Huenulonco&apos;&apos;, conforme a lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura N&#xBA; 18.892.</div><br></div>", "i": 8338923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8338924}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1971", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1971"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-31", "doble_articulado": false, "id_norma": "129763", "numero_fuente": "36263", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-14", "vigencias": [{"desde": "1999-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-01-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso