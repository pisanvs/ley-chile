{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7194457}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 49, de 24 de junio de 1993, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se adjudic&#xF3; a Serviden C&#xED;a. Ltda. la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle Bima esquina El Tofo, Rol de Propiedad 1911-007, de la Comuna de Puerto Montt, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 7194458}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Arturo Hern&#xE1;ndez Orellana, Secretario Regional Ministerial Transportes y Telecomunicaciones, X Regi&#xF3;n. </div></div>", "i": 7194459}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "49", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-49"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "SERVIDEN CIA LTDA", "VEHICULOS MOTORIZADOS", "PUERTO MONTT", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-24", "doble_articulado": false, "id_norma": "32607", "numero_fuente": "34691-3", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-15", "vigencias": [{"desde": "1993-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"