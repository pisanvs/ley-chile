{"html": [{"t": "<div><br><div class=\"p\">DELEGA FACULTAD PARA OTORGAR CERTIFICADOS RELATIVOS A IMPUESTO DE HERENCIAS, CONFORME A RESOLUCI&#xD3;N EX. SII N&#xBA; 90, DE 21 DE SEPTIEMBRE DE 2004</div></div>", "i": 9725079}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En cumplimiento a lo dispuesto en el resolutivo primero de la <a href=\"https://www.leychile.cl/Navegar?idNorma=230633&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta SII N&#xBA; 90, de 21 de septiembre de 2004</a>, del Director del Servicio de Impuestos Internos, el suscrito ha dictado la resoluci&#xF3;n exenta N&#xBA; 157, de 16 de agosto de 2016, que delega en el Jefe de Grupo Atenci&#xF3;n de Contribuyentes N&#xBA; 1 del Departamento Regional de Asistencia al Contribuyente la facultad de otorgar certificados relativos al Impuesto de Herencias.- </div></div>", "i": 9725080}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mauricio Leiva Avil&#xE9;s, Director Regional.</div></div>", "i": 9725081}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "157 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-157 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL ARICA"], "titulo_norma": "DELEGA FACULTAD PARA OTORGAR CERTIFICADOS RELATIVOS A IMPUESTO DE HERENCIAS, CONFORME A RESOLUCIÓN EX. SII Nº 90, DE 21 DE SEPTIEMBRE DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1104259; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-08-16", "doble_articulado": false, "id_norma": "1094059", "numero_fuente": "41543", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-08-26", "vigencias": [{"desde"