{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6056926}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No.</div><div class=\"p\">1.964 de 29 de Noviembre de 1991, conforme art&#xED;culo 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; la Divisi&#xF3;n de Derechos de Aprovechamiento de Aguas proporcionales que corresponden al sector expropiado y al Sector de la Reserva de los predios denominados &quot;Hijuela No. 2, Hijuela No. 3, e Hijuela No. 4, de los antiguos fundos Santa Graciela de Alcones, El Chivato y El Cardonal&quot;, ubicados en la comuna de Marchihue, provincia de Cardenal Caro, VI Regi&#xF3;n. Los derechos de agua provienen del tranque El Sauce Tranque Porotales y derrames de aguas sobrantes de la Hijuela N&#xFA;mero Uno.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme Art. 13 Ley 18.377.- </div></div>", "i": 6056927}, {"t": "<div><div class=\"p\">Director Nacional.</div><br></div>", "i": 6056928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1964 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1964 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-29", "doble_articulado": false, "id_norma": "80247", "numero_fuente": "34143", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-16", "vigencias": [{"desde": "1991-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic