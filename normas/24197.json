{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,717, que suplementa el Presupuesto de Guerra</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,717.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7167151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de diez mil pesos ($ 10,000) al &#xED;tem 242 de la partida 11 del Presupuesto de Guerra vijente.</div><div class=\"p\">&nbsp; &nbsp; El gasto se deducir&#xE1; de la mayor entrada de los derechos de esportacion del salitre.</div><br></div>", "i": 7167152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a diez de Enero de mil novecientos veintiuno.- ARTURO ALESSANDRI.- C&#xE1;rlos Silva Cruz. </div></div>", "i": 7167153}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3717", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3717"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Lei núm. 3,717, que suplementa el Presupuesto de;Guerra", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1920", "MODIFICACION", "MINISTERIO", "GUERRA", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-01-10", "doble_articulado": false, "id_norma": "24197", "numero_fuente": "12868", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-01-11", "vigencias": [{"desde": "1921-01-11", "hasta": "", "tipo_version": "3", "tipo