{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6591685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;780 de fecha 31 de octubre del 2006, se expropiaron los lotes de terreno Nos 84, 85 y 86, superficies 207, 235 y 413 m&#xB2;, Rol N&#xBA;607-413, comuna de Nueva Imperial, IX Regi&#xF3;n para la obra &quot;Camino Reposici&#xF3;n Ruta S-40, Sector Nueva Imperial Carahue, Tramo Km. 0,00000 al Km. 21,58295, correspondiente al Subtramo III Km. 12,86300 al Km.</div><div class=\"p\">21,58295&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Antonia Liencheo Neculhual, ascendente a la cantidad de $1.333.366.- para los lotes N&#xBA;84, 85 y 86. </div></div>", "i": 6591686}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6591687}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "780 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-780 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-31", "doble_articulado": false, "id_norma": "255820", "numero_fuente": "38628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-01", "vigencias": [{"desde": "2006-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_