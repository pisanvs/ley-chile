{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6411333}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 47, de 9 de enero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA GENMAR LIMITADA, para realizar actividades extractivas en aguas internacionales con la nave &quot;Don Chelo I&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 538-Puerto de Valdivia</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-4747</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  16,68 m</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 49,63 t</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp; 76,69 m3</div><div class=\"p\">Potencia motor principal&nbsp;  425,00 Hp</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp; 60,00 Hp</div><br></div>", "i": 6411334}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6411335}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "47", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-47"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-09", "doble_articulado": false, "id_norma": "207028", "numero_fuente": "37467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-2