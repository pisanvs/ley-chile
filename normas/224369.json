{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6475832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.021, de 14 de abril de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a FISH MARKET LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en sector Playa Sereme&#xF1;o s/n, Iquique, I Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso Fresco-Enfriado, Fresco-Refrigerado, Congelado, Seco, Salado, Ahumado y Deshidratado los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6475833}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6475834}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1021 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1021 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-14", "doble_articulado": false, "id_norma": "224369", "numero_fuente": "37849", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-30", "vigencias": [{"desde": "2004-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":