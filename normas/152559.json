{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6223530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 44, de 14 de Octubre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a don: Ra&#xFA;l del Carmen Melero Vasquez, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del Territorio Nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de Locomoci&#xF3;n Colectiva de pasajeros.</div><br></div>", "i": 6223531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 25 de Septiembre de 1986.- Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 6223532}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "44 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-44 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-10-14", "doble_articulado": false, "id_norma": "152559", "numero_fuente": "32.600", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-18", "vigencias": [{"desde": "1986-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-10