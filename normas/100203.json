{"html": [{"t": "<div><div class=\"p\">DEROGA DECRETO No. 734, DE 1987</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 372.- Santiago, 20 de Abril de 1989.- Vistos: El Decreto Supremo de Hacienda No. 734, de 1987; la Ley No. 13.904: y el No. 10 del art&#xED;culo 32&#xB0; de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile, </div><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6113468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Der&#xF3;gase, el Decreto Supremo de Hacienda No. 734, de 1987.</div><div class=\"p\">&nbsp; &nbsp;  2.- Des&#xED;gnase, a don Roberto Toso Corezzola, Subsecretario de Hacienda, como Gobernador Suplente, en representaci&#xF3;n de Chile, ante el Banco Interamericano de Desarrollo.</div><br></div>", "i": 6113469}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Enrique Seguel Morel, Brigadier General, Ministro de Hacienda.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Roberto Toso Corezzola, Subsecretario de Hacienda.</div><br></div>", "i": 6113470}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "734", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-734"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA"], "titulo_norma": "DEROGA DECRETO No. 734, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-04-20", "doble_articulado": false, "id_norma": "100203", "numero_fuente": "33378", "tipo_version": "3", "tip