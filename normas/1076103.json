{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA;371 EXENTA, DE 2015</div><div class=\"p\"> </div></div>", "i": 9587945}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;871 de 31 de marzo de 2015 de esta Subsecretar&#xCD;a, rectif&#xED;quese el numeral 2.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1075199&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA;371 de 2015</a>, que otorg&#xF3; a Deris S.A., un permiso extraordinario de pesca para la unidad de pesquer&#xED;a del recurso Orange Roughy, en el sentido de se&#xF1;alar que el porcentaje indicado en el A&#xF1;o 1 corresponde a &quot;1,50 %&quot; y no como all&#xED; se indica.</div><br></div>", "i": 9587946}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de marzo de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9587947}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "871 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-871 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº371 EXENTA, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-03-31", "doble_articulado": false, "id_norma": "1076103", "numero_fuente": "41128", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-04-10", "vigencias": [{"desde": "2015-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-04-10", "fin_vig