{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293554}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 655 de 11 de Julio de 1994 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por el LICEO B-6, de la I. Municipalidad de Caldera, R.U.T. N&#xB0; 60.920.308-0, para instalar un centro de cultivo ubicado en Punta Caleta, Bah&#xED;a de Caldera, Comuna de Caldera, Provincia de Copiap&#xF3;, III Regi&#xF3;n, por no encontrarse ubicado dentro de las Areas Aptas para la Acuicultura, establecidas en el D.S.(M) N&#xB0; 612, de 1993, del Ministerio de Defensa Nacional.</div><br></div>", "i": 8293555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 11 de Julio de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "655", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-655"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "LICEO B-6", "TERCERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-07-11", "doble_articulado": false, "id_norma": "35306", "numero_fuente": "34920", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-07-21", "vigencias": [{"desde": "1994-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-07-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini