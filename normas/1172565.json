{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10310575}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 260, de 2 de febrero de 2022, de este Servicio, se estableci&#xF3; el procedimiento de estimaci&#xF3;n de capturas para la flota industrial de arrastre de fondo de Merluza com&#xFA;n y Merluza de cola, para embarcaciones con motores mayores a 1000 hp.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra publicado con esta fecha en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y en el de la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10310576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de febrero de 2022.- Jessica Fuentes Olmos, Directora Nacional (S), Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10310577}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "260 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-260 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2085523", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-02-02", "doble_articulado": false, "id_norma": "1172565", "numero_fuente": "43177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-02-12", "vigencias": [{"desde": "2022-02-12", "hasta"