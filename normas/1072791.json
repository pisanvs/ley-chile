{"html": [{"t": "<div><br><div class=\"p\">DONACIONES CON FINES CULTURALES</div></div>", "i": 9542897}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 118, del 12 de diciembre de 2014 que establece:</div><div class=\"p\">&nbsp; &nbsp;  Incorpora a los donatarios de Donaciones Culturales del <a href=\"https://www.leychile.cl/Navegar?idNorma=30353&amp;idParte=8596498&amp;idVersion=\">art&#xED;culo 8&#xBA;</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=30353&amp;idParte=0&amp;idVersion=\">Ley N&#xBA; 18.985</a>, sobre Donaciones con Fines Culturales, la obligaci&#xF3;n de presentar Declaraci&#xF3;n Jurada Anual N&#xBA; 1.828.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SIl del mes de diciembre de 2014.</div></div>", "i": 9542898}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "118 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-118 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DONACIONES CON FINES CULTURALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-12-12", "fecha_derogacion": "2023-09-06", "doble_articulado": false, "id_norma": "1072791", "numero_fuente": "41036", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2014-12-19", "vigenc