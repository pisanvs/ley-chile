{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9312056}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;2392 de 25 de octubre de 2012 y de conformidad a lo dispuesto en al art. 105 del DFL MOP N&#xBA; 850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;67, superficie 660 m2, rol de Aval&#xFA;o 252-176, comuna de Salamanca, para la obra &quot;REPOSICI&#xD3;N PAVIMENTO RUTA D-81, ILLAPEL &#x2013; SALAMANCA, IV REGI&#xD3;N&quot;. La Comisi&#xF3;n de Peritos integrada por JOS&#xC9; ANTONIO VALD&#xC9;S HERREROS, PABLO FLORES SALINAS Y PATRICIO CASAGRANDE ULLOA, fij&#xF3; el valor de tasaci&#xF3;n con fecha 29 de febrero de 2012, acord&#xE1;ndose el valor de la indemnizaci&#xF3;n con su propietaria, BERTA JAMETT VALENCIA, en la cantidad de $2.355.690.- suma que se pagar&#xE1; al contado.- </div></div>", "i": 9312057}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9312058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2392 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2392 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-25", "doble_articulado": false, "id_norma": "1045665", "numero_fuente": "40410", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-11-15", "vigencias": [{"desde": "2012-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc