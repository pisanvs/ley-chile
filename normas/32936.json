{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 83, de 15 de enero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 358, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA SAN SEBASTIAN S.A., para operar la nave Arteta, en la captura del recurso Albacora, en el litoral de la I a la X Regi&#xF3;n y Langostino amarillo, en el litoral de la III y IV Regiones, en virtud de lo se&#xF1;alado en el Art. 143 letra b), del D.S. N&#xB0; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8290088}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 15 de enero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8290089}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "83", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-83"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "PESQUERA SAN", "SEBASTIAN S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-15", "doble_articulado": false, "id_norma": "32936", "numero_fuente": "35373", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-01-23", "vigencias": [{"desde": "1996-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-01-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio