{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza a la Municipalidad de Valpara&#xED;so para cambiar nombre a la Avenida La Palma por Avenida Presidente Alfaro.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8277312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase a la Municipalidad de Valpara&#xED;so, para cambiar el nombre de la actual &quot;Avenida La Palma&quot; por el de &quot;Avenida Presidente Alfaro&quot;. </div></div>", "i": 8277313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticuatro de Noviembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez C.- Enrique Balmaceda.</div><br></div>", "i": 8277314}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4214", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4214"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA A LA MUNICIPALIDAD DE VALPARAÍSO PARA CAMBIAR NOMBRE A LA AVENIDA LA PALMA POR AVENIDA PRESIDENTE ALFARO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALPARAISO", "MUNICIPALIDAD", "AVENIDA", "DENOMINACION", "MODIFICACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-11-24", "doble_articulado": false, "id_norma": "24571", "numero_fuente": "14939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1927-12-05", "vigencias": [{"desde": "1927-12-05", "hasta": "", "tipo_