{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 1.412 EXENTO, DE 2013</div></div>", "i": 9508184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 541, de 16 de septiembre de 2014, de este Ministerio, modif&#xCD;case el art&#xED;culo 1&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1057672&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 1.412 de 2013, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, que estableci&#xF3; las cuotas anuales de captura para el recurso Sardina austral a ser extra&#xED;das en las aguas interiores de la X y XI Regi&#xF3;n, en el sentido de reemplazar la tabla indicada para la X Regi&#xF3;n, por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/43204.jpg\">.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9508185}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de septiembre de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura</div></div>", "i": 9508186}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "541 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-541 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 1.412 EXENTO, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "