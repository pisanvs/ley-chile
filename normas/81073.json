{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6058819}, {"t": "<div><div class=\"p\">Por Decreto MOP. No. 197 de 30 de agosto de 1991, se expropiaron los lotes No. s. 8 y 10, superficies 588 m2. y 1.299 m2. roles de aval&#xFA;o 2024-9 y 2024-7, Comuna de Melipilla para la ejecuci&#xF3;n de la obra Camino Autopista Santiago San Antonio, sector Melipilla Puangue y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarias Sras. Rebeca y Regina de las Mercedes Mart&#xED;nez Rubio, y Mar&#xED;a Ofelia de la Cruz Fern&#xE1;ndez Padilla, ascendente a las sumas de $ 1.253.994.- para el lote 8 y $ 1.291.662.- para el lote 10, respectivamente.-</div><br></div>", "i": 6058820}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6058821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "197", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-197"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-30", "doble_articulado": false, "id_norma": "81073", "numero_fuente": "34080", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-01", "vigencias": [{"desde": "1991-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "1997-12-24", "fecha_version": "1991-10-01", "fecha_actualizac