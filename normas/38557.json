{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA RESOLUCION N&#xB0; 576, DE 1991 Santiago, 12 de Febrero de 1992.- Hoy se resolv&#xED;o lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 205 exenta.- Vistos: Lo dispuesto en el Decreto Ley N&#xB0; 3.557, de 1980 sobre Protecci&#xF3;n Agr&#xED;cola, los art&#xED;culos 2&#xB0; y 4&#xB0; de la Ley N&#xB0; 18.755 y la Resoluci&#xF3;n N&#xB0; 576, de 1991 de este Servicio.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6021343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Der&#xF3;gase la resoluci&#xF3;n N&#xB0; 576, de 23 de Abril de 1991, de la Divisi&#xF3;n de Protecci&#xF3;n Agr&#xED;cola del Servicio Agr&#xED;cola y Ganadero.</div><br></div>", "i": 6021344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Orlando Morales Valencia, Director Divisi&#xF3;n.</div><br></div>", "i": 6021345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "205 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-205 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIVISIÓN PROTECCIÓN AGRÍCOLA"], "titulo_norma": "DEROGA RESOLUCION N° 576, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEROGACION", "PROHIBICION", "SALIDA", "HORTALIZAS", "FRUTAS", "REGION METROPOLITANA", "PROTECCION", "COLERA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-02-12", "doble_articulado": false, "id_norma": "38557", "numero_fuente": "34193", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-02-14", "vigencias": [{"desde": "1992-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],