{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA SOBRE DERECHOS MUNICIPALES A&#xD1;O 1997 </div></div>", "i": 7210551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Providencia, 2 de septiembre de 1997.- Se ha dictado la siguiente Ordenanza comunal:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 6.- Modifica la Ordenanza sobre Derechos Municipales A&#xF1;o 1997, aprobada por Ordenanza N&#xBA; 119 de 26 de noviembre de 1996, en el sentido de agregar en el T&#xED;tulo IV Derechos Municipales sobre Transporte, Tr&#xE1;nsito y Veh&#xED;culos, en el art&#xED;culo 9 un nuevo derecho.</div><div class=\"p\">&nbsp; &nbsp;  La presente Ordenanza se encuentra a disposici&#xF3;n del p&#xFA;blico para su conocimiento en Oficina de Partes ubicada en Avda. Pedro de Valdivia N&#xBA; 963.-</div><br><br></div>", "i": 7210552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div><br></div>", "i": 7210553}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "6", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-6"}], "organismos": ["MUNICIPALIDAD DE PROVIDENCIA"], "titulo_norma": "MODIFICA ORDENANZA SOBRE DERECHOS MUNICIPALES AÑO 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "ORDENANZA MUNICIPAL", "MUNICIPALIDAD DE PROVIDENCIA", "DERECHOS MUNICIPALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-02", "doble_articulado": false, "id_norma": "75582", "numero_fuente": "35861", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-09-06", "vigencias": [{"desde": "1997-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-09-06", "fin_vigencia": ""}, "vigencias_version_norm