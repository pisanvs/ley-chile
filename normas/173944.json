{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7275514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.587, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA DEL NORTE S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 286 de 1992, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Pedro Aguirre Cerda N&#xBA; 995, sector Lo Rojas, Coronel, provincia de Concepci&#xF3;n, VIII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Congelado, Fresco y Fresco-refrigerado: Caballa, Corvina, Cojinoba del norte, Cojinoba del sur, Reineta y Jurel.</div><br></div>", "i": 7275515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de julio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7275516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1587", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1587"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-07-17", "fecha_derogacion": "2001-03-30", "doble_articulado": false, "id_norma": "173944", "numero_fuente": "36733", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-08-07", "vigencias": [{"desde": "2001-03-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-08-07", "hasta": "2001-03-29", "tipo_version": "0", "tipo_version_s": "Texto Original