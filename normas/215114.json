{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 6 EXENTA, DE 2003 </div></div>", "i": 6441223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por R.M. (Ex.) N&#xBA; 6 del 23 de enero del 2003, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ac&#xF3;gese el recurso de reclamaci&#xF3;n interpuesto por Industria Pesquera Oce&#xE1;nica Dos S.A. en contra de las resoluciones N&#xBA; 2.985, N&#xBA; 2.992, N&#xBA; 2.993 y N&#xBA; 2.997, todas de 2002, de la Subsecretar&#xED;a de Pesca.</div><div class=\"p\">&nbsp; &nbsp;  Consid&#xE9;rese al recurrente titular de la embarcaci&#xF3;n en construcci&#xF3;n BEC 1993-01, para la determinaci&#xF3;n de los l&#xED;mites m&#xE1;ximos de captura en las unidades de pesquer&#xED;a de Jurel, V a IX regiones, Jurel X Regi&#xF3;n, Sardina com&#xFA;n y Anchoveta V a X regiones, Merluza de cola V a X regiones.</div><br></div>", "i": 6441224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de enero de 2003.- Jorge Rodr&#xED;guez Grossi, Ministro de Econom&#xED;a y Energ&#xED;a.</div><br></div>", "i": 6441225}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 6 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-23", "doble_articulado": false, "id_norma": "215114", "numero_fuente": "37671", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-29", "vigencias"