{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7296339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.959, de 20 de diciembre de</div><div class=\"p\">2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">parcial de la resoluci&#xF3;n N&#xBA;284 de 1989, de esta</div><div class=\"p\">Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESCA CISNE</div><div class=\"p\">S.A., para operar, en las aguas interiores al sur del</div><div class=\"p\">paralelo 47&#xBA; L.S., las naves &quot;Cisne Verde&quot; y &quot;Cisne</div><div class=\"p\">Blanco&quot;, sobre los recursos Merluza de tres aletas</div><div class=\"p\">y Merluza de cola, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7296340}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7296341}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2959", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2959"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-20", "doble_articulado": false, "id_norma": "206219", "numero_fuente": "37445", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-28", "vigencias": [{"desde": "2002-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-28", "f