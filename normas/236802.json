{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6520820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 725, de 18 de marzo de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a LUIS AMABLE JESUS BERNALES MAUJER para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Pasaje 3-A, N&#xBA; 725 (ex Fundo La Vega), sector Boca Sur, San Pedro de la Paz, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de procesos de Cocido, Fresco enfriado, Fresco refrigerado, Congelado, Seco salado, Deshidratado y Salado h&#xFA;medo, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6520821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 18 de marzo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6520822}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "725 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-725 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-18", "doble_articulado": false, "id_norma": "236802", "numero_fuente": "38127", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-05", "vigencias": [{"desde": "2005-04-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-04-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-04-05", "fin_vigencia": "", "tipo_version"