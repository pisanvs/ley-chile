{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6223473}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 589, de 27 de Agosto de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n, se autoriza a don Pedro Antonio Cornejo Morales para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6223474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Colorea Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule. </div></div>", "i": 6223475}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "589 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-589 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-27", "doble_articulado": false, "id_norma": "152538", "numero_fuente": "32.599", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-17", "vigencias": [{"desde": "1986-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-10-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso"