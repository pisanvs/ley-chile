{"html": [{"t": "<div><div class=\"p\">AMPLIA PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA </div><br></div>", "i": 6515834}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n (M) 1.626, de 1 de octubre de 2004, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div><div class=\"p\">&nbsp; &nbsp;  Ampl&#xED;ase por un a&#xF1;o, a contar de la publicaci&#xF3;n en el Diario Oficial de la presente resoluci&#xF3;n, el plazo para iniciar actividades de acuicultura autorizadas mediante resoluci&#xF3;n (M) 1.111, de fecha 21 de abril de 2003, cuyo Proyecto T&#xE9;cnico y Cronograma de Actividades fue aprobado por la resoluci&#xF3;n 681 de 2003, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.</div><br></div>", "i": 6515835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de enero de 2005.- Por el Subsecretario, Jaime Bravo Busquet, Subjefe Subsecretar&#xED;a de Marina Subrogante.</div><br></div>", "i": 6515836}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1626", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1626"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "AMPLIA PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "FECHA DE INICIACION DE ACTIVIDADES", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-01", "doble_articulado": false, "id_norma": "235451", "numero_fuente": "38085", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-02-12", "vigencias": [{"desde": "2005-02-12", "hasta": "", "tipo_versio