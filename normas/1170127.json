{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10293655}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 1.303 de 9 noviembre 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativa a Actividad Recreativa en la ciudad de Coyhaique, Organizada por la Agrupaci&#xF3;n de Motoqueros &quot;Los Baguales&quot;, y autoriz&#xF3; a Agrupaci&#xF3;n de Motoqueros &quot;Los Baguales&quot; para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - corte total de v&#xED;a en calle Francisco Bilbao, entre calles Lord Cochrane y Arturo Prat, entre las 14:00 hrs. y las 19:00 hrs. del d&#xED;a domingo 7 de noviembre de 2021.</div></div>", "i": 10293656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional de Ays&#xE9;n.- Javier Gonz&#xE1;lez Jara, Asesor Jur&#xED;dico.</div></div>", "i": 10293657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1303 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1303 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2056375", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-09", "doble_articulado": false, "id_norma": "1170127", "numero_fuente": "43130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-12-17", "vigencias": [{"desde": "2021-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "202