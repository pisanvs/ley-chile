{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8317277}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 772 de 15 de Junio de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 500, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Centro de Cultivos del Pac&#xED;fico Ltda., actualmente Comercializadora Centro de Cultivo del Pac&#xED;fico Limitada, R.U.T. No. 79.675.750-7, domiciliada en Copiap&#xF3;, en orden a sustituir en el numeral 2&#xB0; el &#xE1;rea &quot;69.230 m2&quot; por &quot;77.691,2 m2.&quot;.</div><br></div>", "i": 8317278}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 15 de Junio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8317279}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "772", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-772"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-06-15", "doble_articulado": false, "id_norma": "85726", "numero_fuente": "33705", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-27", "vigencias": [{"desde": "1990-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in