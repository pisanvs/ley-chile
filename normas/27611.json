{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE QUE LA MAIPU DE LA CIUDAD DE VICU&#xD1;A SE DENOMINARA,</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281132}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La Calle &quot;Maip&#xFA;&quot; de la ciudad de Vicu&#xF1;a se denominar&#xE1;, en lo sucesivo, &quot;Gabriela Mistral&quot;.&quot; </div></div>", "i": 8281133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de Julio de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o Gundi&#xE1;n.</div><br></div>", "i": 8281134}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13979", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13979"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DISPONE QUE LA MAIPU DE LA CIUDAD DE VICUÑA SE\nDENOMINARA,", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EN LO SUCESIVO", "GABRIELA MISTRAL", "CAMBIO NOMBRE", "CALLE GABRIELA MISTRAL", "VICU A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-07-30", "doble_articulado": false, "id_norma": "27611", "numero_fuente": "24715", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-08-10", "vigencias": [{"desde": "1960-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-08-10", "fin_vigencia": ""}, "vigencias_version_