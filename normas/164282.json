{"html": [{"t": "<div><div class=\"p\">MODIFICA EL ARANCEL ADUANERO</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 600.- Santiago, 28 de Junio de 1985.- Vistos: Lo dispuesto en el art&#xED;culo 4&#xBA; del decreto de Hacienda N&#xBA; 10, de 1967,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6261050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Reb&#xE1;jase a 20% (veinte por ciento) el derecho ad valorem de las mercanc&#xED;as que figuran en el Arancel Aduanero con un derecho ad valorem de 30% (treinta por ciento).</div><br></div>", "i": 6261051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Hern&#xE1;n B&#xFC;chi Buc, Ministro de Hacienda.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud., para su conocimiento.- Saluda atentamente a Ud. Manuel Concha Mart&#xED;nez, Coronel de Ej&#xE9;rcito, Subsecretario de Hacienda.</div><br></div>", "i": 6261052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "600", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-600"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA EL ARANCEL ADUANERO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-28", "doble_articulado": false, "id_norma": "164282", "numero_fuente": "32209", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-29", "vigencias": [{"desde": "1985-06-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-29", "fin_vi