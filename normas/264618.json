{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 6.666 EXENTA, DE 2007 </div></div>", "i": 6623410}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 6.666, de 30 de agosto del 2007, se han complementado las resoluciones exentas de Educaci&#xF3;n N&#xBA;s. 455 y 14.081, ambas de 2001, que aprobaron planes y programas especiales de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio Tabancura, comuna de Vitacura, de Santiago, en el sentido de agregar en el Plan de Formaci&#xF3;n Diferenciada el Subsector de &quot;Coro&quot; para los se&#xF1;alados cursos.</div><div class=\"p\">Adem&#xE1;s, se aprueba programa de estudio para el Subsector de &quot;Coro&quot; para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media. </div></div>", "i": 6623411}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de septiembre de 2007.- M&#xF3;nica Luna Gonz&#xE1;lez, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6623412}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6666 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6666 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 6.666 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-30", "doble_articulado": false, "id_norma": "264618", "numero_fuente": "38862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-12", "vigencias": [{"desde": "2007-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-09-12",