{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DIEGO DUBLE ALMEIDA Lei n&#xFA;m. 255.-Santiago, a 23 de Enero de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Consid&#xE9;rase, por gracia, al ex-coronel don Diego Dubl&#xE9; Almeida como retirado absolutamente del Ej&#xE9;rcito desde el 1.&#xB0; de Enero de 1892, desde cuya fecha se le abonar&#xE1;n las pensiones que le correspondan con relacion a los a&#xF1;os que hubiere servido i al sueldo de que ent&#xF3;nces disfrutaba.</div><br><br></div>", "i": 5947308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-</div><div class=\"p\">C&#xE1;rlos Rivera Jofr&#xE9;.</div><br></div>", "i": 5947309}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "255", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-255"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "DIEGO DUBLE ALMEIDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIEGO DUBLE ALMEIDA", "RETIRO ABSOLUTO", "RECONOCIMIENTO", "GRACIA", "PENSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-01-23", "doble_articulado": false, "id_norma": "22109", "numero_fuente": "5028", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-01-31", "vigencias": [{"desde": "1895-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia