{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6511341}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n N&#xBA; 830 de 13 de diciembre de 2004 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA;2.186 de 1978, del Lote C correspondiente a parte del inmueble ubicado en Departamental N&#xBA; 484, presunto Rol de Aval&#xFA;o N&#xBA;5430-33, comuna de San Joaqu&#xED;n, aparente dominio de Ra&#xFA;l P&#xE9;rez Serani. Comisi&#xF3;n integrada por peritos Nancy S&#xE1;nchez Sep&#xFA;lveda, arquitecto; Juan Alfredo D&#xED;az Velasco, arquitecto, y Fresia Mora Lepe, arquitecto. Seg&#xFA;n informe de fecha 21 de septiembre de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $6.256.737.- pagadera al contado.</div><br></div>", "i": 6511342}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6511343}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "830", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-830"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-13", "doble_articulado": false, "id_norma": "234215", "numero_fuente": "38050", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-03", "vigencias": [{"desde": "2005-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v