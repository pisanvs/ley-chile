{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6274263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 263, de 4 de Marzo de 1991, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad conforme con el</div><div class=\"p\">art&#xED;culo 7&#xB0; del Decreto Supremo No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de la Resoluci&#xF3;n No. 572, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA CHILEAN BAY KING CRAB LIMITADA, R.U.T.</div><div class=\"p\">No. 79.576.800-9, domiciliada en Puerto Natales, para desarrollar actividades pesqueras de cultivo. </div></div>", "i": 6274264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de Marzo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 6274265}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "263", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-263"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-04", "doble_articulado": false, "id_norma": "168311", "numero_fuente": "33938", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-09", "vigencias": [{"desde": "1991-04-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-09", "fin