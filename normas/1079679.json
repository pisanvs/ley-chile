{"html": [{"t": "<div><br><div class=\"p\">FIJA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESI&#xD3;N DE SALM&#xD3;NIDOS 62 XII REGI&#xD3;N</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp;  </div></div>", "i": 9623222}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.843 de 9 de julio de 2015 de esta Subsecretar&#xED;a, establece que los centros de cultivo integrantes de la agrupaci&#xF3;n de concesiones 62 deber&#xE1;n someterse a la densidad de cultivo establecida por <a href=\"https://www.leychile.cl/Navegar?idNorma=1003741&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.449 de 2009</a>, del Servicio Nacional de Pesca y Acuicultura, o la resoluci&#xF3;n que la reemplace, en virtud del art&#xED;culo 5&#xBA; transitorio del DS N&#xBA; 4 de 2013, de este Ministerio.</div></div>", "i": 9623223}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de julio de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9623224}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1843 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1843 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "FIJA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIÓN DE SALMÓNIDOS 62 XII REGIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-07-09", "doble_articulado": false, "id_norma": "1079679", "numero_fuente": "41211", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-07-20", "vigencias"