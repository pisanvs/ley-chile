{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.804, DE 1987 </div></div>", "i": 6269652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.904 de fecha 26 de Agosto de 1987 del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el art. 1&#xB0; de la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 2.225 de 1982 del Centro de Formaci&#xF3;n T&#xE9;cnica CEC de Santiago, en el sentido de impartir la carrera Programaci&#xF3;n de Computadores en dos semestres consecutivos a partir de Septiembre de 1987 a Agosto 1988, por &#xFA;nica vez, a fin de regularizar las diferentes situaciones acad&#xE9;micas de sus postulantes.</div><br></div>", "i": 6269653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6269654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1904 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1904 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.804, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-26", "doble_articulado": false, "id_norma": "166946", "numero_fuente": "32893", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-14", "vigencias": [{"desde": "1987-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-14", "fin_vigencia": "", "tipo_version": "3"}], "event