{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,306.- Santiago, 30 de diciembre de 1899.- Por cuanto el Congreso Nacional ha&nbsp; dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a la viuda del jeneral de divisi&#xF3;n don Luis Arteaga, do&#xF1;a Elvira Garc&#xED;a, i a su hija soltera, do&#xF1;a Herminia Arteaga, el goce de una pensi&#xF3;n anual de dos mil pesos.</div><br><div class=\"p\">&nbsp; &nbsp;  Esta pensi&#xF3;n ser&#xE1; incompatible con el goce de cualquiera otra pensi&#xF3;n fiscal.</div><br></div>", "i": 6163434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la&nbsp; Rep&#xFA;blica.- FEDERICO ERRAZURIZ - Ricardo Matte Perez.</div><br></div>", "i": 6163435}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1306", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1306"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-30", "doble_articulado": false, "id_norma": "134783", "numero_fuente": "6486", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-01-02", "vigencias": [{"desde": "1900-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-01-02", "fin_vigencia": "", "tipo_version":