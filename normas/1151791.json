{"html": [{"t": "<div><br><div class=\"p\">BULAS.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 10 de 1825.</div></div>", "i": 10191968}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Con lo expuesto por el Ministerio fiscal y oido el Consejo consultivo de Gobierno, vengo en disponer que se devuelva al Gobernador del Obispado, con el correspondiente execuatur, el rescripto del Vicario Apost&#xF3;lico dado en Valparaiso a veintinueve de octubre del a&#xF1;o pasado, sobre la continuacion del privilejio de la bula, para que lo haga fijar, publicar v circular en este Obispado; remiti&#xE9;ndose igualmente una copia certificada al Gobernador eclesi&#xE1;stico del de Concepcion para su publicacion y circulacion.</div></div>", "i": 10191969}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Campino.</div></div>", "i": 10191970}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE INTERIOR"], "titulo_norma": "BULAS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-11-10", "doble_articulado": false, "id_norma": "1151791", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-11-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-11-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2