{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 335 EXENTO, DE 2000 </div></div>", "i": 6303915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se revoca el reconocimiento oficial del Instituto Profesional Iquique English College, organizado por la Sociedad Umbral Educacional Limitada, y se elimina del Registro de Institutos Profesionales en que se encuentra inscrito con el N&#xBA; 57.</div><div class=\"p\">&nbsp; &nbsp;  Se deroga el decreto exento de Educaci&#xF3;n N&#xBA; 197, de fecha 8 de diciembre de 1989, modificado por decreto exento N&#xBA; 236, de fecha 25 de marzo de 1993, que autoriz&#xF3; el funcionamiento del Instituto Profesional Iquique English.</div><br></div>", "i": 6303916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de octubre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6303917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "335 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-335 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 335 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-04", "doble_articulado": false, "id_norma": "176508", "numero_fuente": "36781", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-06", "vigencias": [{"desde": "2000-10-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v