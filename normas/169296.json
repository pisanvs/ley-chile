{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6277274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xB0; 2366 de 10 de Noviembre de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Excluido, Reserva y Sector Expropiado Predios &quot;Santa Julia y Santa Ana Poniente&quot; y &quot;Santa Ana&quot; de la comunal de Freire, IX Regi&#xF3;n; y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 2 a la 12, 14 y 16 a la 25 del Proyecto de Parcelaci&#xF3;n &quot;La Uni&#xF3;n&quot; formado por predios se&#xF1;alados. Los Derechos de Agua se extraen del Canal Allip&#xE9;n derivado del R&#xED;o Allip&#xE9;n. Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377.</div><br></div>", "i": 6277275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6277276}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2366 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2366 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-10", "doble_articulado": false, "id_norma": "169296", "numero_fuente": "32921", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-16", "vigencias": [{"desde": "1987-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc