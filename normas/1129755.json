{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xB0; 784 EXENTO, DE 2019</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 836 exento.- Linares, 1 de marzo de 2019.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Vistos:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El decreto exento N&#xBA; 784 de fecha 21 de febrero de 2019, que aprueba la Enmienda N&#xBA; 1 al Plan Regulador Comunal de Linares.</div><div class=\"p\">&nbsp; &nbsp;  La necesidad de corregir un error involuntario de digitaci&#xF3;n en la confecci&#xF3;n del decreto exento N&#xBA; 784 de fecha 21 de febrero de 2019.</div><div class=\"p\">&nbsp; &nbsp;  El decreto exento N&#xBA; 6.391 del 29 de noviembre de 2018, que establece orden de subrogancia del Alcalde de la comuna de Linares.</div><div class=\"p\">&nbsp; &nbsp;  Las facultades que me confiere la Ley N&#xBA; 18.695 de 1988, Org&#xE1;nica Constitucional de Municipalidades y sus modificaciones,</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Decreto:</div></div>", "i": 10007800}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;quese el <a href=\"https://www.leychile.cl/Navegar?idNorma=1129754&amp;idParte=&amp;idVersion=\">decreto exento N&#xBA; 784</a>, mencionado en los Vistos, en el siguiente sentido:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Donde dice:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  . Reempl&#xE1;cese el cuadro de Normas de Subdivisi&#xF3;n y Edificaci&#xF3;n para la Zona Z-1 por el siguiente:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/90675.jpg\">.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Debe decir:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  . Reempl&#xE1;cese el cuadro de Normas de Subdivisi&#xF3;n y Edificaci&#xF3;n para la Zona Z-1 por el siguiente:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/90676.jpg\">.</div><div class=\"p\"> </div><br></div>", "i": 10007801, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese, transcr&#xED;base y arch&#xED;vese.- John Sancho Bichet, Alcalde (S).- Carmen Alicia Avaria Ram&#xED;rez, Secretaria Municipal.</div></div>", "i": 10007802}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "836 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-836 EXENTO"}], "organismos": ["MUNICIPALIDAD DE LINARES"], "titulo_norma": "MODIFICA DECRETO N° 784 EXENTO, DE 2019", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1561189"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2019-03-01", "fecha_derogacion": "2019-05-09", "doble_articulado": false, "id_norma": "1129755", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2019-03-16", "vigencias": [{"desde": "2019-05-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2019-03-16", "hasta": "2019-05-08", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2019-05-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-03-16", "fin_vigencia": "2019-05-08", "tipo_version": "0"}, {"inicio_vigencia": "2019-05-09", "fin_vigencia": "", "tipo_version": "2"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1289", "fecha_ingreso": "2019-03-18", "fecha_version": "2019-05-09", "actualizado_por": "906", "fecha_actualizacion_texto": "2019-05-09", "tipo_tratado": ""}, "alertas": [{"clase": "der