{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6066630}, {"t": "<div><div class=\"p\">Por Decreto MOP No. 390, de 06.12.89, se expropiaron los lotes de terrenos N&#xB0;s. 2, 12,13 y 4, superficies 3.078 m2, 293 m2. 1.328 m2. y 290 m2., roles de aval&#xFA;os N&#xB0;s. 19-2, 17-27, 18-5 y 19-3, Comuna de San Pedro, obra Camino Bifurcacion Loyca-Crucero Las Ara&#xF1;as, sector Acceso a San Vicente, Regi&#xF3;n Metropolitana, y se acord&#xF3; precio de indeminzaci&#xF3;n con sus propietarios. Ema Marta Ovalle Cruz, Ricardo Arist&#xED;a Ruiz y Julia Velasco, las cantidades ascendentes a $ 298.155.- $ 264.276.- y $ 58.715.- , respectivamente.</div><br></div>", "i": 6066631}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6066632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "390", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-390"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-06", "doble_articulado": false, "id_norma": "83927", "numero_fuente": "33570", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-15", "vigencias": [{"desde": "1990-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1998-01-12", "fecha_version": "1990-01-15", "fecha_actualizacion_te