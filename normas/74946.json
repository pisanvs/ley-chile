{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305485}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.068, de 31 de julio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2 de la Resoluci&#xF3;n N&#xBA; 859 de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA AURO SOCIEDAD ANONIMA para ampliar sus operaciones pesqueras con la nave &quot;Albimer&quot;, matr&#xED;cula 2684, al litoral de la X Regi&#xF3;n, en el sentido de incluir entre los recursos hidrobiol&#xF3;gicos que all&#xED; puede capturar, al siguiente: Merluza de cola. </div></div>", "i": 8305486}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305487}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1068", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1068"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA AURO SOCIEDAD ANONIMA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-07-31", "fecha_derogacion": "2001-12-27", "doble_articulado": false, "id_norma": "74946", "numero_fuente": "35842", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-08-14", "vigencias": [{"desde": "2001-12-27", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-08-14", "hasta": "2001-12-26", "tipo_version": "0", "tipo_version_s": "Texto Original"}],