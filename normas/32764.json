{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7194586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 64 de 8 de Junio de 1994, de la</div><div class=\"p\">Secretar&#xED;a Regional Ministerial de Transportes y</div><div class=\"p\">Telecomunicaciones de la V Regi&#xF3;n, se adjudic&#xF3; a la</div><div class=\"p\">Sociedad Andreani, Antognoli y Arata Ltda. (Centromotori</div><div class=\"p\">Ltda.), la concesi&#xF3;n para operar, hasta el 09.08.97, un</div><div class=\"p\">establecimiento ubicado en Avda. Bernardo O&apos;Higgins N&#xB0;</div><div class=\"p\">2807 de San Antonio, destinado a la revisi&#xF3;n t&#xE9;cnica y</div><div class=\"p\">verificaci&#xF3;n de emisi&#xF3;n de contaminantes de los</div><div class=\"p\">veh&#xED;culos que se se&#xF1;alan en el inciso segundo del</div><div class=\"p\">art&#xED;culo 7&#xB0; del D.S. N&#xB0; 156/90 del Ministerio de Transportes y Telecomunicaciones, en la forma y condiciones que se se&#xF1;ala en el contrato que se aprueba.-</div><br></div>", "i": 7194587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Mu&#xF1;oz Cisterna, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n.</div><br></div>", "i": 7194588}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-64"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "VEHICULOS MOTORIZADOS", "SAN ANTONIO", "QUINTA REGION", "PLANTA REVISION TECNICA", "SOCIEDAD ANDREANI ANTOGNOLI ARATA LTDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": []