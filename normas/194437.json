{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 16.275 EXENTA, DE 2001 </div><br></div>", "i": 7289556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 16.275 de 28 de diciembre del a&#xF1;o 2001, se ha aprobado al Liceo Polit&#xE9;cnico Ciencia y Tecnolog&#xED;a, comuna de La Cisterna, provincia de Santiago, Regi&#xF3;n Metropolitana, planes especiales de estudio para 1&#xBA;, 2&#xBA;, 3&#xBA; y 4&#xBA; a&#xF1;o de ense&#xF1;anza media t&#xE9;cnico - profesional, que se aplicar&#xE1;n en 1&#xBA;, 2&#xBA; y 3&#xBA; a&#xF1;o medio desde el a&#xF1;o escolar 2001 y en 4&#xBA; a&#xF1;o medio a partir del a&#xF1;o escolar 2002.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en el art&#xED;culo 2&#xBA; de la presente resoluci&#xF3;n.</div><br></div>", "i": 7289557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 7289558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16275 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-16275 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 16.275 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-28", "doble_articulado": false, "id_norma": "194437", "numero_fuente": "37180", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-07", "vigencias": [{"desde": "2002-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig