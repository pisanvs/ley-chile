{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,839.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8350096}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al doctor don Amable Caballero, para los efectos de su jubilacion, un abono del tiempo que le falta para completar su derecho a jubilar con el sueldo &#xED;ntegro de que actualmente goza, como jefe de la Oficina Central de Vacuna.</div><br></div>", "i": 8350097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiocho de enero de mil novecientos veintidos.- Arturo Alessandri.- Ismael Tocornal. </div></div>", "i": 8350098}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3839", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3839"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1922-01-28", "doble_articulado": false, "id_norma": "143452", "numero_fuente": "13200", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1922-02-13", "vigencias": [{"desde": "1922-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1922-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1922-02-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen