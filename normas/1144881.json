{"html": [{"t": "<div><div class=\"p\">RESOLUCI&#xD3;N N&#xBA; 1.682 EXENTA, DE 28.04.2020, DEL DIRECTOR NACIONAL DE ADUANAS, QUE DETERMINA NO CONVOCAR A CONCURSO DE AGENTES DE ADUANA EN EL A&#xD1;O 2020</div></div>", "i": 10118262}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.682, de 28.04.2020, del Director Nacional de Aduanas, determina no convocar a concurso de Agentes de Aduana en el a&#xF1;o 2020.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n exenta N&#xBA; 1.682, de 28.04.2020, se encuentra publicado en el sitio web del Servicio Nacional de Aduanas: www.aduana.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10118263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de abril de 2020.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas. </div><br></div>", "i": 10118264}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1682 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1682 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "RESOLUCIÓN Nº 1.682 EXENTA, DE 28.04.2020, DEL DIRECTOR NACIONAL DE ADUANAS, QUE DETERMINA NO CONVOCAR A CONCURSO DE AGENTES DE ADUANA EN EL AÑO 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1757683", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-04-28", "doble_articulado": false, "id_norma": "1144881", "numero_fuente": "42648", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-05-06", "vigencias": [{"desde": "2020-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni