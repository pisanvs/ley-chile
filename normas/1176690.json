{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 2.368 EXENTA, 12 DE MAYO DE 2022</div></div>", "i": 10337613}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.368, de 12 de mayo de 2022, de la Subsecretar&#xED;a de Transportes, se autoriza al siguiente taller para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo (GLP) y gas natural comprimido (GNC), como combustibles:</div><div class=\"p\"> </div><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/149260.jpg\"></div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.-</div></div>", "i": 10337614}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Denisse Alejandra Ram&#xED;rez Parra, Subsecretaria de Transportes (S).</div><div class=\"p\"> </div></div>", "i": 10337615}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2368 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2368 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 2.368 EXENTA, 12 DE MAYO DE 2022", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2134957", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-05-12", "doble_articulado": false, "id_norma": "1176690", "numero_fuente": "43265", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-05-30", "vigencias": [{"desde": "2022-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia