{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Retiro absoluto Lei n&#xFA;m. 1,226._ Santiago, a 29 de Junio de 1899.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br><br></div>", "i": 5948632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Consid&#xE9;rase, por gracia, retirado absolutamente del servicio al capitan de nav&#xED;o don Juan E. L&#xF3;pez, a partir desde el 1.&#xB0; de Marzo de 1892 i comprendido en la disposicion del n&#xFA;m. 3 del art. 1.&#xB0; de la lei de 7 de Febrero de 1895.</div><br><br></div>", "i": 5948633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- J. A. Figueroa.</div><br></div>", "i": 5948634}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1226", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1226"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "RETIRO ABSOLUTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN E. LOPEZ", "RETIRO POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-06-29", "doble_articulado": false, "id_norma": "22485", "numero_fuente": "6337", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-07-01", "vigencias": [{"desde": "1899-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes