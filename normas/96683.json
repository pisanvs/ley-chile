{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;. 365 DE 1990 </div></div>", "i": 6103779}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 365 de 27 de diciembre de 1990, se ha aprobado a partir del a&#xF1;o escolar de 1991 y por un per&#xED;odo de seis a&#xF1;os un plan de estudio y programas especiales de Educaci&#xF3;n General B&#xE1;sica y Media con orientaci&#xF3;n laboral al Centro de Estudios y Capacitaci&#xF3;n para alumnos con d&#xE9;ficit auditivo de la ciudad de Valpara&#xED;so V Regi&#xF3;n.</div><br></div>", "i": 6103780}, {"t": "<div><div class=\"p\">Santiago 22 de Febrero de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6103781}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "365 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-365 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº. 365 DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-27", "doble_articulado": false, "id_norma": "96683", "numero_fuente": "33905", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-27", "vigencias": [{"desde": "1991-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-02-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-03-31", "fecha_version": "1991-02-27", "fecha