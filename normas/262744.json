{"html": [{"t": "<div><div class=\"p\">CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A DISTRIBUIDORA MATCO S.A.</div><br></div>", "i": 6617098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Grandes Contribuyentes del SII, por Res. Ex. N&#xBA; 73, del 15 de junio de 2007, certifica que, a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n, Distribuidora Matco S.A., RUT N&#xBA; 96.913.960-K, tiene la calidad de agente retenedor del Impuesto al Valor Agregado en los contratos de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contrate en el desarrollo de su actividad, de acuerdo a lo establecido en la Res. Ex. N&#xBA; 142, del 26.12.2005, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6617099}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Bernardo Seaman Gonz&#xE1;lez, Director Grandes Contribuyentes.</div><br></div>", "i": 6617100}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "73 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-73 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN GRANDES CONTRIBUYENTES"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A\nDISTRIBUIDORA MATCO S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-15", "doble_articulado": false, "id_norma": "262744", "numero_fuente": "38815", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-18", "vigencias": [{"desde": "2007-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-07-18", "fin_vigencia": ""}, "vigencias_version_norma