{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 204, DE 1988 </div></div>", "i": 6094293}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 204 de 27 de diciembre de 1988 se han aprobado al Colegio Redland School de Santiago, programas de estudio de asignaturas que se indican del Plan Electivo de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica, de acuerdo con lo prevenido en el art&#xED;culo 4&#xB0; del decreto supremo exento de Educaci&#xF3;n N&#xB0; 319, de 1986. </div></div>", "i": 6094294}, {"t": "<div><div class=\"p\">Santiago, 06 de Enero de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6094295}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "204 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-204 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 204, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-27", "doble_articulado": false, "id_norma": "93448", "numero_fuente": "33276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-01-19", "vigencias": [{"desde": "1989-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-03-04", "fecha_version": "1989-01-19", "fecha_actualizacion_texto": "1989-01-19", "tipo