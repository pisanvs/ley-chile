{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 402.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para que invierta, durante el a&#xF1;o en curso, hasta la suma de trescientos mil pesos en atender a la construcci&#xF3;n, conservaci&#xF3;n i reparaci&#xF3;n de puentes. </div></div>", "i": 6162705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a 2 de febrero de 1899.- FEDERICO ERRAZURIZ.- Arturo Alessandri.</div><br></div>", "i": 6162706}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "402", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-402"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-02-02", "doble_articulado": false, "id_norma": "134544", "numero_fuente": "6218", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-02-03", "vigencias": [{"desde": "1899-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-02-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH",