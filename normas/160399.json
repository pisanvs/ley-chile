{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6248684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 226, de Marzo 20 de 1985, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se modifica la resoluci&#xF3;n No. 44/82, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, publicada en el Diario Oficial de 18 de Enero de 1982, en el sentido que la Empresa de origen argentino Transportes Automotores de Cuyo Limitada (T.A.C.) est&#xE1; autorizada para atender el servicio internacional de transporte terrestre de pasajeros entre Mendoza (Argentina) y Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar (Chile) por Paso Caracoles (T&#xFA;nel del Cristo Redentor). </div></div>", "i": 6248685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Y&#xE1;var Mar&#xED;n, Coronel de Ej&#xE9;rcito,- Subsecretario de Transportes.</div><br></div>", "i": 6248686}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "226", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-226"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-20", "doble_articulado": false, "id_norma": "160399", "numero_fuente": "32138", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-03", "vigencias": [{"desde": "1985-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-03", "fin_vigencia": ""}, "vigencias_versio