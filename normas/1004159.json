{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0;4.563 EXENTA, DE 2009</div></div>", "i": 8740744}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0;4.563, de fecha 30 de junio de 2009, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Quilacoya Capacitaci&#xF3;n Limitada&quot; (Quilacoya Capacitaci&#xF3;n Limitada), R.U.T. 76.536.130-3, contenida en la resoluci&#xF3;n exenta N&#xB0;4.556, de 19 de diciembre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xB0;2 del art&#xED;culo 21 de la ley 19.518.- </div><br></div>", "i": 8740745}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fernando Rouliez Fleck, Director Nacional.</div></div>", "i": 8740746}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4563 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-4563 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N°4.563 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-30", "doble_articulado": false, "id_norma": "1004159", "numero_fuente": "39409", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-07-11", "vigencias": [{"desde": "2009-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-07-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-07-11", "fin_vigencia": "", "tipo_version": "3"}], "ev