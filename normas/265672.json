{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A SOF SOUTH ORGANICS FRUITS S.A.</div><br></div>", "i": 6626930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/N&#xBA; Ex 9.479, de fecha 2 de octubre de 2007, otorga a SOF South Organics Fruits S.A., RUT N&#xBA; 99.588.390-2, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de berries, establecido en la resoluci&#xF3;n N&#xBA; Ex 55, de 02-06-2005, de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida. </div></div>", "i": 6626931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 2 de octubre de 2007.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6626932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9479 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-9479 EXENTA"}, {"tipo": "3", "numero": "DRE-08-9479 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-9479 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A SOF SOUTH ORGANICS FRUITS S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-02", "doble_articulado": false, "id_norma": "265672", "numero_fuente": "38889", "tipo_version": "3", "tipo_version_