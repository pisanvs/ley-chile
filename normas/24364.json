{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,935, que asciende al Coronel don Agustin Echavarr&#xED;a</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,935.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5957578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que, por gracia, conceda el t&#xED;tulo, sueldo, rango i prerrogativas de Jeneral de Brigada, para los efectos de su retiro i montep&#xED;o, al Coronel en retiro del Ej&#xE9;rcito, don Agustin Echavarr&#xED;a Moreno. </div></div>", "i": 5957579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 22 de Junio de 1923.- ARTURO ALESSANDRI.- Luis Altamirano.</div><br></div>", "i": 5957580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3935", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3935"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Lei núm. 3,935, que asciende al Coronel don Agustin;Echavarría", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGUSTIN ECHAVARRIA MORENO", "ASCENSO POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-06-22", "doble_articulado": false, "id_norma": "24364", "numero_fuente": "13608", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-06-22", "vigencias": [{"desde": "1923-06-22", "hasta": "", "t