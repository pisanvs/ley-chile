{"html": [{"t": "<div><br><div class=\"p\">COMPLEMENTA CIRCULAR N&#xBA; 33, DE 2013, SOBRE COPROPIEDAD INMOBILIARIA</div></div>", "i": 9544931}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xBA; 68, de fecha 26 de diciembre de 2014, que complementa la <a href=\"https://www.leychile.cl/Navegar?idNorma=1052197&amp;idParte=0&amp;idVersion=\">circular N&#xBA; 33, de 2013</a>, incorporando los procedimientos para que el propietario o el representante legal declare el aval&#xFA;o fiscal en copropiedades acogidas a las nuevas disposiciones contenidas en la ley N&#xBA; 20.741, de 2014, que modifican a la ley N&#xBA; 19.537, sobre Copropiedad Inmobiliaria.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este instructivo est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2014.</div></div>", "i": 9544932, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "68", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-68"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "COMPLEMENTA CIRCULAR Nº 33, DE 2013, SOBRE COPROPIEDAD", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-12-26", "doble_articulado": false, "id_norma": "1073013", "numero_fuente": "41045", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-12-31", "vigencias": [{"desde": "201