{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065908}, {"t": "<div><div class=\"p\">Por Decreto Secc. 2da. No. 74, de fecha 12 de Enero de 1990, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n parcial conforme DS No. 458 de Vivienda y Urbanismo, Decreto Ley 2.186 y Ley 18.695, inmueble Agustinas 2367, Rol 332-9 Santiago, aparente dominio Rosa Burgos Villal&#xF3;n, superficie aproximada a expropiar 478 m2. Deslindes: Norte, 14,25 mts. con resto del predio Sur, 14,25 con Agustinas; Oriente, 33.00 mts. con otro propietario y Poniente, 34,00 mts. con otro propietario. Indemnizaci&#xF3;n provisional $ 11.912.000.- pagadera contado.</div><br></div>", "i": 6065909}, {"t": "<div><div class=\"p\">M&#xE1;ximo Honorato Alamos, Alcalde Santiago.</div><br></div>", "i": 6065910}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "74", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-74"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "83647", "numero_fuente": "33585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-01", "vigencias": [{"desde": "1990-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-01-09", "fecha_version": "1990-02-01", "fecha_actualizacion_texto": "1