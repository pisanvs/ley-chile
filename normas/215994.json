{"html": [{"t": "<div><br><div class=\"p\"> EXTRACTO DE DECRETO N&#xB0; 954, DE 1984, QUE APRUEBA MODIFICACION DE</div><div class=\"p\"> CONVENIO DE TRASPASO DE LA ESCUELA BASICA&nbsp; F-166 DE TALCA</div><br></div>", "i": 7304407}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por decreto N&#xB0; 954, de 1984, se aprob&#xF3; una modificaci&#xF3;n al convenio de traspaso de la Escuela B&#xE1;sica F-166, de Talca, aprobado por decreto N&#xB0; 1.900, de 1981, que incide en la cl&#xE1;usula sexta. </div></div>", "i": 7304408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de Enero de 1985.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica, subrogante. </div></div>", "i": 7304409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "954", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-954"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 954, DE 1984, QUE APRUEBA MODIFICACION DE\nCONVENIO DE TRASPASO DE LA ESCUELA BASICA F-166 DE TALCA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-09", "doble_articulado": false, "id_norma": "215994", "numero_fuente": "32081", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-26", "vigencias": [{"desde": "1985-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "mo