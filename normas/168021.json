{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6273230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP No. 37, de 28 de febrero de 1991, se expropiaron los lotes No. s. 15 y 26, superficies 375 y 250 M2., roles de aval&#xFA;o 1737-22 y 2036-11, respectivamente, Comuna La Cisterna, para la obra Avenida Am&#xE9;rico Vespucio, sector Gran Avenida-Ochagav&#xED;a y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios do&#xF1;a Ema Castillo Guerra y se&#xF1;ores Rodolfo Lagos Guldemont y Elena Guldemont Rocha, ascendentes a $ 11.298.210 y $ 13.965.630, respectivamente.- </div></div>", "i": 6273231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6273232}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "37", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-37"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-02-28", "doble_articulado": false, "id_norma": "168021", "numero_fuente": "33931", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-01", "vigencias": [{"desde": "1991-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-05-05", "fecha_version": "1991-04-01", "fecha_actualizacion_texto": "1991-04-01", "tipo_tratado": ""},