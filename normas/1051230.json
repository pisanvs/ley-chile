{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9353780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.033, de 22 de abril de 2013, de esta Subsecretar&#xED;a, ampl&#xED;ese por doce meses, a contar del 28 de enero de 2013, el plazo otorgado a PESQUERA OMEGA LIMITADA para iniciar actividades pesqueras extractivas con la nave en construcci&#xF3;n &quot;BEC N&#xB0; 3092/11&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la XV a X Regiones, Isla de Pascua, Salas y G&#xF3;mez, Desventuradas y Archipi&#xE9;lago de Juan Fern&#xE1;ndez, por fuera del &#xE1;rea de reserva artesanal, con palangre y enmalle, sobre Albacora o Pez Espada y su fauna acompa&#xF1;ante.</div></div>", "i": 9353781}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9353782}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1033 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1033 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-04-22", "doble_articulado": false, "id_norma": "1051230", "numero_fuente": "40563", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-05-20", "vigencias": [{"desde": "2013-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-05-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-05-20", "f