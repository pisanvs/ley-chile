{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 187 EXENTO, DE 1987 </div></div>", "i": 6295816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 187 de 27 de agosto de 1987 se ha autorizado a The Grange School, de Santiago, a contar del a&#xF1;o lectivo 1988, para incorporar al plan de estudio especial aprobado por decreto supremo exento de Educaci&#xF3;n N&#xBA; 191 de 1982, la asignatura de Computaci&#xF3;n en 1ero. y 2do. a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban los programas especiales para la citada asignatura.</div><br></div>", "i": 6295817}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de Enero de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6295818}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "187 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-187 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO Nº 187 EXENTO, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-27", "doble_articulado": false, "id_norma": "174048", "numero_fuente": "32982", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-29", "vigencias": [{"desde": "1988-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-01-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes