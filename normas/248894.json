{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6566852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.029, de 5 de abril de 2006, de esta Subsecretar&#xED;a, rech&#xE1;zase la solicitud de concesi&#xF3;n de acuicultura N&#xBA; 96110091 presentada por Aquasur Fisheries Sociedad Pesquera Limitada, hoy ROBINSON CRUSOE Y COMPA&#xD1;IA LIMITADA, para instalar y operar un centro de cultivo ubicado en Estero Quitralco, XI Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Deja sin efecto resoluci&#xF3;n N&#xBA; 1.658, de 1999, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6566853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de abril de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6566854}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1029 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1029 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-05", "doble_articulado": false, "id_norma": "248894", "numero_fuente": "38439", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-13", "vigencias": [{"desde": "2006-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-04-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-04