{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6263861}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.542, de Noviembre 19 de 1984, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana, se autoriza a don Jos&#xE9; Miguel Guti&#xE9;rrez Morales para efectuar servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros en la L&#xED;nea de Taxibuses N&#xB0; 58 &quot;Metro - Las Condes&quot;, cuyo trazado se encuentra autorizado por resoluci&#xF3;n N&#xB0; 349, de Agosto 18 de 1982.</div><br><br></div>", "i": 6263862}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 29 de 1984.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6263863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1542 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1542 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-11-19", "doble_articulado": false, "id_norma": "165162", "numero_fuente": "32062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-04", "vigencias": [{"desde": "1985-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-04", "fin_vigencia": "", "tipo_version