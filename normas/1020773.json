{"html": [{"t": "<div><br><div class=\"p\">ORDENA EXPROPIACI&#xD3;N DE INMUEBLES QUE SE&#xD1;ALA</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9076172}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.033 de fecha 7 de diciembre de 2010, del Serviu Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiaci&#xF3;n, conforme art. 51 Ley 16.391 y DL 2.186 de 1978, del inmueble denominado Pol&#xED;gono N&#xBA; 25 ubicado en Caleta Hornos comuna de La Higuera, presunto Rol Aval&#xFA;o 28-001, de aparente dominio de la Sucesi&#xF3;n Flores-Villalobos, superficie aproximada de 2.062,00 metros cuadrados. Comisi&#xF3;n peritos integrada por profesionales do&#xF1;a Mar&#xED;a Iris Marcich Moller, Alfredo Prieto Parra y Luis Jeffery Mercado, seg&#xFA;n informe de 6 de diciembre del 2010, fij&#xF3; monto provisional indemnizaci&#xF3;n en $6.186.000, pagadera al contado. </div></div>", "i": 9076173}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Coquimbo.</div></div>", "i": 9076174}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1033", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1033"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "IV REGIÓN DE COQUIMBO"], "titulo_norma": "ORDENA EXPROPIACIÓN DE INMUEBLES QUE SEÑALA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-07", "doble_articulado": false, "id_norma": "1020773", "numero_fuente": "39835", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-15", "vigencias": [{"desde": "2010-12-15", "hasta": "