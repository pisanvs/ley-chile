{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA;1.653 EXENTA, DE 2009</div></div>", "i": 8553515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA;1.653, de 17 de marzo de 2009, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n a la entidad &quot;Sociedad de Capacitaci&#xF3;n Expro Sociedad An&#xF3;nima&quot; (Capacitaci&#xF3;n Expro S.A.), RUT 96.972.750-1, contenida en la resoluci&#xF3;n exenta N&#xBA;4.438, de 12 de abril de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA;2 del art. 21 de la ley N&#xBA;19.518.- </div></div>", "i": 8553516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fernando Rouliez Fleck, Director Nacional.</div></div>", "i": 8553517}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1653 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1653 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº1.653 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-03-17", "doble_articulado": false, "id_norma": "1001372", "numero_fuente": "39343", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-04-22", "vigencias": [{"desde": "2009-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-04-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-04-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente