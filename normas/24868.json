{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7169633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Suplem&#xE9;ntase el &#xED;tem 06/07/08/b/, del Presupuesto vigente, en la cantidad de cincuenta mil pesos ($ 50,000), que se deducir&#xE1; de la mayor entrada que produzca en el presente a&#xF1;o el impuesto a las Compa&#xF1;&#xED;as de Seguros, acordado por ley n&#xFA;mero 4,228, de 20 de Diciembre de 1927.</div><div class=\"p\">&nbsp; &nbsp; Esta ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7169634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.- Santiago, a diez y nueve de Diciembre de mil novecientos veintinueve. CARLOS IBA&#xD1;EZ C.- Rodolfo Jaramillo B.</div><br></div>", "i": 7169635}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4732", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4732"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1929", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-19", "doble_articulado": false, "id_norma": "24868", "numero_fuente": "15554", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-12-21", "vigencias": [{"desde": "1929-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci