{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIA QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 367.- Santiago, 7 de julio de 2004.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974 de 1979,</div><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6490508}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, III Regi&#xF3;n, a la siguiente funcionaria:</div><br><div class=\"p\">Maggie Encarnaci&#xF3;n Olgu&#xED;n Vilches, RUT: 9.670.298-1 </div></div>", "i": 6490509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Halabi Caffena, Director Nacional.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud., Encargado de Oficina de Partes.</div><br></div>", "i": 6490510}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "367", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-367"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO DE DESARROLLO AGROPECUARIO", "RECEPTOR JUDICIAL", "DESIGNACION", "INDAP"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-07", "doble_articulado": false, "id_norma": "228532", "numero_fuente": "37926", "tipo_version": "3", "tipo_ve