{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,535.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8352561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por don Ventura Carvallo Elizalde, conc&#xE9;dese a su viuda do&#xF1;a Adela Berdia de Carvallo una pension de tres mil pesos anuales&quot;.</div><br></div>", "i": 8352562}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintinueve de agosto de mil novecientos diecinueve.- Juan Luis Sanfuentes.- Luis Serrano A. </div></div>", "i": 8352563}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3535", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3535"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-08-29", "doble_articulado": false, "id_norma": "146404", "numero_fuente": "12467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-09-06", "vigencias": [{"desde": "1919-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1919-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1919-09-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "f