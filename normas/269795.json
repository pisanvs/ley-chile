{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6641740}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 553, de 27 de febrero de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a FRIGOR&#xCD;FICO FIORDOSUR S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, para operar una planta en Phillippi N&#xBA; 325, Valpara&#xED;so, donde podr&#xE1; elaborar en l&#xED;nea de proceso Cocido, Fresco-Enfriado, Fresco-Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.681 de 2004, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6641741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de febrero de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6641742}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "553 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-553 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-02-27", "doble_articulado": false, "id_norma": "269795", "numero_fuente": "39010", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-03-12", "vigencias": [{"desde": "2008-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio