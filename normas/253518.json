{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6583760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.509, de 28 de agosto de 2006, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 1.562 de 2004, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SALMONES MAINSTREAM S.A. para operar un vivero flotante en Caleta La Vega, X Regi&#xF3;n, en el sentido de cambiar la posici&#xF3;n del centro autorizado de conformidad con las coordenadas geogr&#xE1;ficas se&#xF1;aladas en la resoluci&#xF3;n extractada, y de incorporar en ella un plan de recaptura de especies en el evento de escape de las mismas. </div></div>", "i": 6583761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de agosto de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6583762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2509 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2509 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-08-28", "doble_articulado": false, "id_norma": "253518", "numero_fuente": "38571", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-23", "vigencias": [{"desde": "2006-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-09-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-09-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula