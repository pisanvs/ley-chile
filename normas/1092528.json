{"html": [{"t": "<div><br><div class=\"p\">CONSULTAS DEL ART&#xCD;CULO 26 BIS</div></div>", "i": 9714985}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 69, del 11 de julio de 2016, que se&#xF1;ala:</div><div class=\"p\">&nbsp; &nbsp;  Establece la forma en que se deber&#xE1; presentar la consulta vinculante del <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=9510273&amp;idVersion=\">art&#xED;culo 26 bis</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=0&amp;idVersion=\">C&#xF3;digo Tributario</a> y los requisitos que &#xE9;sta debe cumplir.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de julio de 2016.</div><br></div>", "i": 9714986}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "69 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-69 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CONSULTAS DEL ARTÍCULO 26 BIS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1042447; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-07-11", "doble_articulado": false, "id_norma": "1092528", "numero_fuente": "41508", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-07-14", "vigencias": [{"desde": "2016-07-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci