{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza a Junta de Alcaldes de Punta Arenas para cambiar nombre a diversas calles.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br><br></div>", "i": 8277266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase el cambio de nombre de las calles que se indican, de la ciudad de Punta Arenas, en la forma siguiente: &quot;Arauco&quot;, por &quot;Monse&#xF1;or Fagnano&quot;, &quot;Peruana&quot;, por &quot;Arauco&quot;, &quot;Aconcagua &quot;, por &quot;Jos&#xE9; Nogueira&quot;, &quot;Avenida Libertad&quot;, por &quot;Avenida Espa&#xF1;a&quot;, &quot;Chilena&quot;, por &quot;Manuel Se&#xF1;oret&quot;.</div><br></div>", "i": 8277267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, seis de Julio de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez C.- Enrique Balmaceda. </div></div>", "i": 8277268}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4131", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4131"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA A JUNTA DE ALCALDES DE PUNTA ARENAS PARA CAMBIAR NOMBRE A DIVERSAS CALLES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PUNTA ARENAS", "JUNTA ALCALDES", "FACULTAD", "DENOMINACION", "CALLES", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-07-06", "doble_articulado": false, "id_norma": "24496", "