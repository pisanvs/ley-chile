{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACIONES DE RESOLUCIONES QUE INDICA</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9690397}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 558 de 2 de marzo de 2015, la Direcci&#xF3;n Regional Serviu Regi&#xF3;n de Los Lagos dispuso la rectificaci&#xF3;n de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1078025&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.346 de 22 de mayo de 2015</a>, la que orden&#xF3; expropiaci&#xF3;n lote de terreno N&#xB0; 45 para la ejecuci&#xF3;n Proyecto &quot;Mejoramiento Av. Juan Mackenna en Osorno&quot;, Provincia de Osorno, Regi&#xF3;n de Los Lagos, rol de aval&#xFA;o seg&#xFA;n SII N&#xB0; 129-42, en el sentido de reemplazar el deslinde &quot;Oeste&quot;, por el siguiente texto: D-A en 10,60 mt. con rol 129-41&quot;, y no como erradamente se se&#xF1;al&#xF3; en la resoluci&#xF3;n exenta N&#xB0; 1.346.- </div></div>", "i": 9690398}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Directora Regional (S) Serviu Regi&#xF3;n de Los Lagos.</div></div>", "i": 9690399}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "558 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-558 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN X REGIÓN DE LOS LAGOS"], "titulo_norma": "RECTIFICACIONES DE RESOLUCIONES QUE INDICA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1007888", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-03-02", "doble_articulado": false, "id_norma": "1088940", "numero_fuente": "41421", "tipo_version": "3", "tipo_vers