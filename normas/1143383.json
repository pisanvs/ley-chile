{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10108180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 489, de 3 de marzo de 2020, del Servicio Nacional de Pesca y Acuicultura, se establece forma, requisitos y condiciones que deben cumplir armadores artesanales que participen en pesca de investigaci&#xF3;n que indica, en la Regi&#xF3;n de la Araucan&#xED;a.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n indicada, se encuentra publicado con esta fecha en el dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y en el de la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10108181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En Valpara&#xED;so, a 3 de marzo de 2020.- Jessica Fuentes Olmos, Directora Nacional (S), Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10108182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "489 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-489 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1738669", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-03-03", "doble_articulado": false, "id_norma": "1143383", "numero_fuente": "42603", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-03-13", "vigencias": [{"desde": "2020-03-13", "hasta": ""