{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede abono de tiempo de servicios a do&#xF1;a Mar&#xED;a Luisa Codorni&#xFA;</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Dec&#xE1;rase de abono, para los efectos de su jubilaci&#xF3;n, a do&#xF1;a Mar&#xED;a Luisa Codorni&#xFA; R., ex-profesora del Liceo de Ni&#xF1;as de La Serena, el tiempo que sirvi&#xF3; en dicho establecimiento con anterioridad al 1.o de Enero de 1905.</div><div class=\"p\">&nbsp; &nbsp; Esta ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5960762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, quince de Enero de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Rodolfo Jaramillo B. </div></div>", "i": 5960763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4785", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4785"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE ABONO DE TIEMPO DE SERVICIOS A DOÑA MARIA LUISA CODORNIU", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MARIA LUISA CODORNIU", "JUBILACION", "ABONO TIEMPO", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-01-15", "doble_articulado": false, "id_norma": "24910", "numero_fuente": "15576", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "