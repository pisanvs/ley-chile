{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 67 EXENTO, DE 1995 </div></div>", "i": 7160331}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 67 de fecha 25 de enero de 1995 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto AIEP, las adecuaciones introducidas a los Planes y Programas de Estudios de las carreras de Contabilidad General y de Administraci&#xF3;n de Empresas con menci&#xF3;n en Marketing, las que se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 1.321 de 1987 y N&#xB0; 1.596 de 1982, respectivamente. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1995.</div><br></div>", "i": 7160332}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 7 de Febrero de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160333}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "67 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-67 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 67 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "CENTRO", "FORMACION TECNICA INSTITUTO AIEP"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-25", "doble_articulado": false, "id_norma": "19987", "numero_fuente": "35093", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-02-14", "vigencias": [{"desde": "1995-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-02-14", "fin_vigencia": ""}, "vigencias_version_norm