{"html": [{"t": "<div><div class=\"p\">CORREOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 20 de 1832.</div><br><div class=\"p\">&nbsp; &nbsp;  Con lo espuesto por el Administrador jeneral de correos, he acordado y decreto:</div></div>", "i": 10250023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0; Se establecer&#xE1; un correo que conduzca, dos veces cada mes, la correspondencia oficial y del p&#xFA;blico, desde Santiago a San Pedro de Aconcagua.</div></div>", "i": 10250024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; El costo del espresado correo no deber&#xE1; exceder de seis pesos por cada viaje.</div></div>", "i": 10250025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  3.&#xB0; Comun&#xED;quese al Administrador jeneral de la renta para su cumplimiento, y t&#xF3;mese razon donde corresponda.</div></div>", "i": 10250026}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PRIETO.</div><div class=\"p\">&nbsp; &nbsp;  Joaqu&#xED;n Tocornal.</div></div>", "i": 10250027}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "CORREOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-11-20", "doble_articulado": false, "id_norma": "1161853", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-11-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-11-20", "fin_vigencia": "