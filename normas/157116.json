{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 150, DE 1984 </div></div>", "i": 6237666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 150, de 14 de Septiembre de 1984, se ha autorizado a Villa Mar&#xED;a Academy de Santiago, a contar del a&#xF1;o lectivo 1985 para intensificar la ense&#xF1;anza del idioma Ingl&#xE9;s en los cursos de Educaci&#xF3;n General B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp;  La intensificaci&#xF3;n se efectuar&#xE1; de 1&#xB0; a 4&#xB0; a&#xF1;o mediante la ense&#xF1;anza biling&#xFC;e: Castellano e Ingl&#xE9;s y de 5&#xB0; a 8&#xB0; a&#xF1;o incorporando a la asignatura de Ingl&#xE9;s, Laboratorio o Taller de Pr&#xE1;ctica del Idioma, con un m&#xE1;ximo de tres clases semanales, evaluada en la forma que se indica.</div><br></div>", "i": 6237667}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 01 de Febrero de 1985.- Mar&#xED;a Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante. </div></div>", "i": 6237668}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "150 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-150 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 150, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-09-14", "doble_articulado": false, "id_norma": "157116", "numero_fuente": "32117", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-09", "vigencias": [{"desde": "1985-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]