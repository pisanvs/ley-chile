{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9219187}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.317, de 12 de diciembre de 2011, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=265067&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.564 de 2007</a>, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA B&#xCD;O B&#xCD;O S.A., para realizar actividades pesqueras extractivas con una nave en construcci&#xF3;n en el &#xE1;rea mar&#xED;tima comprendida entre la XV Regi&#xF3;n y el paralelo 41&#xB0;28,6&apos; L.S., sobre el recurso hidrobiol&#xF3;gico Reineta, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante Memor&#xE1;ndum T&#xE9;cnico citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9219188}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de diciembre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9219189}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3317 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3317 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-12", "doble_articulado": false, "id_norma": "1035152", "numero_fuente": "40137", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-17", "vigencias": [{"desde": "2011-12-17", "hasta": "", "tipo_version": "3", "ti