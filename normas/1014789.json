{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N ORDINARIA N&#xBA; 1545</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n Ordinaria N&#xBA; 1545, celebrada el 17 de junio de 2010, adopt&#xF3; el siguiente Acuerdo:</div></div>", "i": 8936537}, {"t": "<div><br><div class=\"p\">1545-01-100617 &#x2013; Tasa de inter&#xE9;s para pago diferido de derechos de aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del Art. 10 de la ley N&#xB0; 18.634, la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que expira el 31 de Diciembre de 2010, ser&#xE1; de 5,5% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 8936538}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de junio de 2010.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 8936539}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1545", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1545"}, {"tipo": "5", "numero": "1545-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1545-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN ORDINARIA Nº 1545", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-06-23", "doble_articulado": false, "id_norma": "1014789", "numero_fuente": "39695", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-25", "vigencias": [{"desde": "2010-06-2