{"html": [{"t": "<div><br><div class=\"p\">INSTALACION DEL CONGRESO NACIONAL</div></div>", "i": 10098900}, {"t": "<div><br><div class=\"p\">EL DIRECTOR SUPREMO DE LA REPUBLICA DE CHILE &amp;c.</div><div class=\"p\">&nbsp; &nbsp;  Por cuanto la Representacion Nacional ha anunciado al Gobierno que se halla ya constituida y va a principiar sus sesiones; por tanto ordeno, que se publique solemnemente este acontecimiento por bando especial, y que se inserte en el Boletin para su circulacion. Dado en el Palacio Directorial de Santiago a 22 de Noviembre de 1824.</div></div>", "i": 10098901}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  J. A. Pinto.</div></div>", "i": 10098902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "36", "numero": "S/N", "abreviacion": "Bando", "descripcion": "Bando", "compuesto": "Bando-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "INSTALACION DEL CONGRESO NACIONAL", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-11-22", "doble_articulado": false, "id_norma": "1141580", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-11-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-11-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2020-02-06", "fecha_version": "1824-11-22", "fecha_actualizacion_texto": "2020-02-06", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "e