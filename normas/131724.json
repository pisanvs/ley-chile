{"html": [{"t": "<div><div class=\"p\">Forma en que debe hacerse la eleccci&#xF3;n de miembros de la Comisi&#xF3;n Conservadora</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Santiago, 4 de setiembre de 1884.-</div><br><div class=\"p\">&nbsp; &nbsp;  Por cnanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 6154198}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. La elecci&#xF3;n de miembros del Senado i de la C&#xE1;mara de Diputados que, seg&#xFA;n&nbsp; el art&#xED;culo 57 de la Constitucion, deben formar parte de la Comision Conservadora, se har&#xE1; por voto acumulativo&quot;. </div></div>", "i": 6154199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-</div><br><div class=\"p\">&nbsp; &nbsp;  Domingo Santa Mar&#xED;a.-</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Jos&#xE9; Manuel Balmaceda.-</div><br></div>", "i": 6154200}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "FORMA EN QUE DEBE HACERSE LA ELECCION DE MIEMBROS DE LA COMISION CONSERVADORA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1884-09-04", "doble_articulado": false, "id_norma": "131724", "numero_fuente": "2220", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1884-09-09", "vigencias": [{"desde": "1884-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1884-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1884-09-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "FMR", "fecha_ingreso": "1999-02-17", "fecha_version": "1884-09-09", "fecha_actualizacion_texto": "1884-09-09", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6154198}, {"n": "Artículo UNICO", "i": 6154199, "t": 6}, {"n": "Promulgación", "i": 6154200}]}