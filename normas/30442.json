{"html": [{"t": "<div><div class=\"p\">MODIFICA ARTICULOS 1&#xB0; Y 2&#xB0; DE LA LEY N&#xB0; 19.001 </div><div class=\"p\">&nbsp; &nbsp; Teniendo presente que el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente.</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br><br></div>", "i": 8287321}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Sustit&#xFA;yense en los art&#xED;culos 1&#xB0; y 2&#xB0; de la Ley N&#xB0; 19.001, los guarismos &quot;1990&quot;, &quot;1991&quot; y &quot;1992&quot; por &quot;1991&quot;, &quot;1992&quot; y &quot;1993&quot;, respectivamente.&quot;.</div><br><br></div>", "i": 8287322, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de Agosto de 1991.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Enrique Krauss Rusque, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud.- Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8287323}], "proyectos": [{"categoria": "Proyecto original", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=384-06", "informacion": "Prorroga por un año, la aplicación del sistema de calificaciones de los funcionarios Públicos y Municipales", "nroBoletin": "384-06"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "19075", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-19075"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "MODIFICA ARTICULOS 1° Y 2° DE LA LEY N° 19.001", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Estatuto Administrativo", "Proc