{"html": [{"t": "<div><div class=\"p\">AUTORIZA A RECEPTOR ELECTRONICO </div></div>", "i": 7341205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 47, de 26 de abril de 2007, que autoriza a Organismo P&#xFA;blico como receptor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como receptor de documentos tributarios electr&#xF3;nicos, a contar del mes de marzo de 2007, al Organismo P&#xFA;blico RUT 61.978.670-K.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril de 2007.</div><br></div>", "i": 7341206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "47 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-47 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A RECEPTOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-26", "doble_articulado": false, "id_norma": "260494", "numero_fuente": "38751", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-30", "vigencias": [{"desde": "2007-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-04-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc