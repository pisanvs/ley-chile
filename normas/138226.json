{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6174744}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 135 de 27 de enero de 1988 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a don Jos&#xE9; Francisco Retamal Letelier de la Asociaci&#xF3;n de Buses &quot;Interb&#xFA;s&quot;, para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6174745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Poblete Rodr&#xED;guez, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6174746}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "135 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-135 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-27", "doble_articulado": false, "id_norma": "138226", "numero_fuente": "32985", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-02", "vigencias": [{"desde": "1988-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-02", "fin_vi