{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6215542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 3.421, de 29 de octubre de 1999, se expropiaron los lotes de terreno N&#xBA;s. 4, 5 y 7, superficies 950, 130 y 790 m&#xB2;. respectivamente, roles de aval&#xFA;o 52-55, 52-92 y 52-58, comuna de Pumanque, para la obra Camino Ruta I-60, Sector Poblaci&#xF3;n-Pumanque y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Aladino Villagra Flores, Berta Flores Quinteros y Manuel Argomedo Cornejo, ascendente a las cantidades de $2.767.476, $570.546 y $984.793.</div><br></div>", "i": 6215543}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6215544}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3421", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3421"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-29", "doble_articulado": false, "id_norma": "150217", "numero_fuente": "36552", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-03", "vigencias": [{"desde": "2000-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-01-03", "fecha_version": "2000-01-03", "fecha_actualizacion_texto": "2000-01-03", "tipo_tratado": ""},