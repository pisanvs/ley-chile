{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6158437}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. No. 99, de 29 de abril de 1988, se expropiaron los lotes de terrenos N&#xB0;s. 3 y 4, superficie 396 M2. y 16.672 M2., respectivamente, roles de aval&#xFA;o 2196-142 y 329-4, Comuna de Puerto Montt, para la obra Mejoramiento Integral Agua Potable de Puerto Montt, y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Marta Livinia M&#xE1;rquez Maripani y Arzobispado de Puerto Montt, ascendente a las cantidades de $ 75.080 y $ 4.251.027.-</div><br></div>", "i": 6158438}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6158439}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "99", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-99"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-29", "doble_articulado": false, "id_norma": "133223", "numero_fuente": "33085", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-01", "vigencias": [{"desde": "1988-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-03-08", "fecha_version": "1988-06-01", "fecha_actualizacion_texto": "1988-06-01", "tipo_tratado": ""}, "alertas": [], "