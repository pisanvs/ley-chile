{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;446, del 6 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA Y CONSERVERA REAL LIMITADA, para ampliar actividades pesqueras autorizadas por resoluci&#xF3;n N&#xBA;1.118, de 1995 de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Juan Williams N&#xBA;11810, camino R&#xED;o Seco, Punta Arenas, XII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican los siguientes recursos hidrobiol&#xF3;gicos:&nbsp; Conserva, Congelado y Deshidratado: Caracol pintado, Caracol piquilhue, Caracol com&#xFA;n y Caracol atigrado.</div><br></div>", "i": 8329290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329291}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "446", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-446"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA Y CONSERVERA REAL LIMITADA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-06", "doble_articulado": false, "id_norma": "98293", "numero_fuente": "36041", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-04-16", "vigencias": [{"desde": "1998-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-04-1