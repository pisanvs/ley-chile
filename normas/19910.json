{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 51 EXENTO, DE 1994 </div></div>", "i": 7160255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 51, de 28 de enero de 1994, se ha aprobado un plan especial de estudio para Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica al Liceo &quot;Carmela Carvajal de Prat&quot;, de Santiago, para ser aplicado en forma gradual de acuerdo al siguiente cronograma:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; - 1994: en 1er. y 2do. a&#xF1;o medio.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; - 1995: en 3er. a&#xF1;o medio.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; - 1996: en 4to. a&#xF1;o medio.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s se aprueban programas de estudio para las asignaturas y cursos que se indican en el citado decreto.</div><br></div>", "i": 7160256, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de Febrero de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160257}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "51 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-51 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 51 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "LICEO CARMELA CARVAJAL PRAT", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-28", "doble_articulado": false, "id_norma": "19910", "numero_fuente": "34805", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-03", "vigencias": [{"desd