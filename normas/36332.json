{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.143, de 5 de Diciembre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case la Resoluci&#xF3;n N&#xB0; 940, de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; al SINDICATO DE TRABAJADORES INDEPENDIENTES PESCADORES DE LA CALETA COLIUMO, R.U.T. N&#xB0; 71.292.800-K, para operar un centro de cultivo de alga Gracilaria, en un sector de Caleta Coliumo, localidad de Coliumo, Comuna de Tom&#xE9;, Provincia de Concepci&#xF3;n, VIII Regi&#xF3;n, en virtud de lo dispuesto en el art&#xED;culo 7&#xB0; del D.S. N&#xB0; 175, de 1980 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8295961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 5 de Diciembre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295962}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1143", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1143"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SINDICATO TRABAJADORES INDEPENDIENTES PESCADORES", "CALETA COLIUMO", "CADUCIDAD", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-05", "doble_articulado": false, "id_norma": "36332", "numero_fuente": "35038", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-12", "vigencias": [{"desde": "1994-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic