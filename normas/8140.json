{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5886891}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto MOP. N&#xB0; 44, de 23 de febrero de 1993, se expropiaron los lotes de terreno N&#xB0;s. 7 y 9, superficies 310 m2. y 223 m2., respectivamente, roles de aval&#xFA;o 149-28 y 482-27, Comunas de Pemuco y Yungay, para la Obra Camino Pemuco- Yungay, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Salvador A. Matus Vega y Nora E. Otarola Galaz, ascendente a las cantidades de $145.332.- y $116.706.-</div><br></div>", "i": 5886892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5886893}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "44", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-44"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "PEMUCO", "YUNGAY"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-02-23", "doble_articulado": false, "id_norma": "8140", "numero_fuente": "34531-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-01", "vigencias": [{"desde": "1993-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1993-04-01", "fecha_actualizacion_texto": "1993-04-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n