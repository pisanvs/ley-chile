{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0;. 167, DE 1989 </div></div>", "i": 6082404}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0;. 167 de 03 de noviembre de 1989 se ha prorrogado el decreto supremo exento de Educaci&#xF3;n No. 276 de 1985 que aprob&#xF3; planes y programas de estudio de Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica de Adultos al Liceo A No. 89 &quot;Benjam&#xED;n Vicu&#xF1;a Mackenna&quot; de la Corporaci&#xF3;n Municipal de Educaci&#xF3;n de La Florida. Adem&#xE1;s, se agrega la asignatura de &quot;Salud e Higiene Mental&quot; al plan electivo, cuyos objetivos generales se aprueban tambi&#xE9;n por el presente decreto.</div><br></div>", "i": 6082405}, {"t": "<div><div class=\"p\">- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6082406}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "167 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-167 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°. 167, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-03", "doble_articulado": false, "id_norma": "89381", "numero_fuente": "33553", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-23", "vigencias": [{"desde": "1989-12-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-23", "fin_vigencia": "", "tipo_v