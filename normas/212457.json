{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6431505}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;446, de fecha 30 de abril del 2003, se expropi&#xF3; el lote de terreno N&#xBA;16, superficie 747 m2, Rol N&#xBA;1130-9, comuna de Pichilemu, VI Regi&#xF3;n para la obra &quot;Camino Pichilemu - Cahuil. Rol Ruta I-500.</div><div class=\"p\">Km. 0,980 a Km. 12,76217&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Guido Nazario C&#xE9;spedes Lorca y Otra, ascendente a la cantidad de $9.068.820. </div></div>", "i": 6431506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6431507}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "446", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-446"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-04-30", "doble_articulado": false, "id_norma": "212457", "numero_fuente": "37609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-15", "vigencias": [{"desde": "2003-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-07-15", "fecha_version": "2003-07-15", "fecha_actualizacion_texto": "2003-07-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura