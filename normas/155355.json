{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 170, DE 1986 </div></div>", "i": 8930350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1987 y hasta el a&#xF1;o escolar 1992, inclusive, para el Liceo Pol&#xED;t&#xE9;cnico, de Macul.</div><div class=\"p\">Especialidades:</div><div class=\"p\">1. Contabilidad.</div><div class=\"p\">2. Secretariado Administrativo.</div><div class=\"p\">3. Programaci&#xF3;n en Computaci&#xF3;n.</div><div class=\"p\">4. Mec&#xE1;nica Automotriz.</div><div class=\"p\">5. Electricidad Industrial.</div><div class=\"p\">6. Atenci&#xF3;n Social con menci&#xF3;n en Menores y Senescentes.</div><div class=\"p\">7. Vestuario con menci&#xF3;n en Dise&#xF1;o.</div><div class=\"p\">8. Vestuario con menci&#xF3;n en Patronaje Industrial.- </div></div>", "i": 8930351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 8930352}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "170 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-170 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 170, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. NO TIENE FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "155355", "numero_fuente": "32509", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-30", "vige