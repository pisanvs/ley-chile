{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 480, DE 1993 </div></div>", "i": 7161931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 480 de 20 de Septiembre de 1993 se ha aprobado al Colegio Redland School de Santiago, un plan de estudio especial para la Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, que ser&#xE1; aplicado simult&#xE1;neamente desde 1&#xB0; a 4&#xB0; a&#xF1;o.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban los programas para las asignaturas de Computaci&#xF3;n, Geograf&#xED;a General y Educaci&#xF3;n Musical.</div><br></div>", "i": 7161932, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Septiembre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 7161933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "480 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-480 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 480, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO REDLAND SCHOOL", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-09-20", "doble_articulado": false, "id_norma": "21329", "numero_fuente": "34695", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-20", "vigencias": [{"desde": "1993-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-10-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-10-20", "fin_vigenc