{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7295023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.399, de 31 de octubre de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.600 de 1997, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a LUIS HUMBERTO NOVOA SANCHEZ para operar la nave &quot;Estarka I&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a la VIII Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con arte de arrastre, respecto del recurso hidrobiol&#xF3;gico Camar&#xF3;n nailon Heterocarpus reedi, ello en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y del memor&#xE1;ndum de la Divisi&#xF3;n de Desarrollo Pesquero de esta Subsecretar&#xED;a, citado en Visto.</div><br></div>", "i": 7295024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de octubre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7295025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2399", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2399"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-31", "doble_articulado": false, "id_norma": "204284", "numero_fuente": "37402", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-07", "vigencias": [{"desde": "2002-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "