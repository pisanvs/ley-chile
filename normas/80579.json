{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 172, DE 1991 </div></div>", "i": 7215499}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 172 de 03 de julio de 1991 se ha complementado, a partir del presente a&#xF1;o escolar, el decreto supremo exento de Educaci&#xF3;n No. 276, de 1986, en el sentido de intercalar en el art&#xED;culo 1&#xB0; a continuaci&#xF3;n de la palabra &quot;inclusive&quot;, la expresi&#xF3;n &quot;y en los cursos de Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica&quot;, aplicable al Colegio Alem&#xE1;n de Chill&#xE1;n.</div><br></div>", "i": 7215500}, {"t": "<div><div class=\"p\">Santiago, 29 de Julio de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7215501}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "172 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-172 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 172, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-03", "doble_articulado": false, "id_norma": "80579", "numero_fuente": "34050", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-23", "vigencias": [{"desde": "1991-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-08-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingres