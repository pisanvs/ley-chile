{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6232454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 12, de 29 de Enero de 1986, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la XIIa. Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a Ra&#xFA;l P&#xE9;rez Vera, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6232455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jos&#xE9; Urbano Peralta, Secretario Regional Ministerial de Transportes y Telecomunicaciones. XIIa. Regi&#xF3;n.</div><br></div>", "i": 6232456}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-29", "doble_articulado": false, "id_norma": "155558", "numero_fuente": "32400", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-02-17", "vigencias": [{"desde": "1986-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-02-17", "fin_vigencia": "", "tipo_ve