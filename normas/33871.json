{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 234. de 6 abril, de 1993 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xB0; 564, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA ANGAMOS S.A., R.U.T. N&#xB0; 94.053.000-8, hoy Pesquera Indo S.A., R.U.T. N&#xB0; 92.484.000-5, para realizar actividades extractivas con la nave &quot;Patache II&quot;, en el sentido de se&#xF1;alar que el actual nombre y matr&#xED;cula de la nave que se autoriza en dicha Resoluci&#xF3;n es &quot;Angamos 4&quot; y su matr&#xED;cula es 2553.</div><br></div>", "i": 8291257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 abril 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8291258}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "234", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-234"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "MODIFICACION", "PESQUERA ANGAMOS S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-04-06", "doble_articulado": false, "id_norma": "33871", "numero_fuente": "34547", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-22", "vigencias": [{"desde": "1993-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-04-22", "fin_vigencia": "