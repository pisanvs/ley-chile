{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6351503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.197, de 31 de julio de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 147, superficie 940 m&#xB2;, rol de aval&#xFA;o 277-66, comuna de Algarrobo, para la obra Red Vial Litoral Central. Sector 2: Camino Algarrobo - Casablanca (Ruta F-90), Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Sergio Guti&#xE9;rrez Hurtado, ascendente a la cantidad de $3.612.815.</div><br></div>", "i": 6351504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6351505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1197", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1197"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-31", "doble_articulado": false, "id_norma": "190066", "numero_fuente": "37074", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-01", "vigencias": [{"desde": "2001-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-10-01", "fecha_version": "2001-10-01", "fecha_actualizacion_texto": "2001-10-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Enc