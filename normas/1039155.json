{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9249604}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;580 de fecha 29 de marzo de 2012, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;25, superficie 283 m2, rol N&#xBA;2208-24, para la obra &quot;Camino Ruta 7, Sector Lenca - Chaica, Tramo Km. 27,89372 a Km. 33,17100&quot;, Comuna de Puerto Montt, X Regi&#xF3;n. La Comisi&#xF3;n de Peritos integrada por Leopoldo Ram&#xF3;n Schumacher Guarda, Juan Samuel Barrientos Bahamonde y Nelson Bernardo Turra Turra, fij&#xF3; valor de tasaci&#xF3;n con fecha 09 de marzo de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario ERASMO SOTO HERN&#xC1;NDEZ, en la cantidad de $1.497.914, suma que se pagar&#xE1; al contado. </div><br></div>", "i": 9249605}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9249606}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "580 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-580 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-29", "doble_articulado": false, "id_norma": "1039155", "numero_fuente": "40238", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-16", "vigencias": [{"desde": "2012-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic