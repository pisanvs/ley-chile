{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6365965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.972, de 30 de noviembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;115, superficie 645 m2., rol de aval&#xFA;o 276-132, comuna de Algarrobo, para la obra Red Vial Litoral Central. Enlace Algarrobo.</div><div class=\"p\">Km. 28.700,00 al Km. 29.740,00, V Regi&#xF3;n, se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Waldo Jorje Bown Ortega, ascendente a la cantidad de $4.717.698. </div></div>", "i": 6365966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6365967}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1972", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1972"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "193796", "numero_fuente": "37160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-15", "vigencias": [{"desde": "2002-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-01-16", "fecha_version": "2002-01-15", "fecha_actualizacion_texto": "2002-01-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n"