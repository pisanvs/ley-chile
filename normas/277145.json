{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6658219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.908, de 23 de julio de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA HIELOS AUSTRALES LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en camino Predial, lote 14, parcelaci&#xF3;n Ruze-Ca&#xF1;adon, Porvenir, XII Regi&#xF3;n, para elaborar en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado, Congelado y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6658220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de julio de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6658221}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1908 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1908 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-23", "doble_articulado": false, "id_norma": "277145", "numero_fuente": "39149", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-08-28", "vigencias": [{"desde": "2008-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-08-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i