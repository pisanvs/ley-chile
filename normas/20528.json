{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 171 EXENTO, DE 1994 </div></div>", "i": 7160960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 171 de 19 de abril de 1994, se ha autorizado al Colegio Santa Mar&#xED;a Reina, comuna La Reina, Santiago, para agregar al Plan Electivo de 3&#xB0; y 4&#xB0; a&#xF1;o medio, la asignatura de Computaci&#xF3;n, la que tendr&#xE1; car&#xE1;cter de obligatoria, ser&#xE1; evaluada e incidir&#xE1; en la promoci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio de dicha asignatura.</div><br></div>", "i": 7160961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 de mayo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160962}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "171 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-171 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 171 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "COLEGIO SANTA MARIA REINA", "COMPUTACION", "PROGRAMAS ESTUDIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-04-19", "doble_articulado": false, "id_norma": "20528", "numero_fuente": "34870", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-05-20", "vigencias": [{"desde": "1994-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-05-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-05-20", "fin_vigencia": "", "tipo_version": "3"}