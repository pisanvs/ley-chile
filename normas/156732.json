{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A GUSTAVO FLORES MU&#xD1;OZ</div><br><br></div>", "i": 7262039}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n N&#xBA; Ex. 87 de fecha 8 de febrero de 2000, deja sin efecto la resoluci&#xF3;n N&#xBA; Ex. 374 de fecha 27/07/98 y revoca, a contar de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado del cambio de sujeto en las operaciones de ganado vivo, a Gustavo Flores Mu&#xF1;oz, RUT N&#xBA; 4.318.356-7, conforme a lo establecido en el dispositivo N&#xBA; 17 de la resoluci&#xF3;n N&#xBA; Ex. 5.088 de 28/07/99 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 24/04/98.- </div></div>", "i": 7262040}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 7262041}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "87 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-87 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A GUSTAVO FLORES MUÑOZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-08", "doble_articulado": false, "id_norma": "156732", "numero_fuente": "36592", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-18", "vigencias": [{"desde": "2000-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-02-18", "fin_vigencia":