{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 447, de 25 Junio de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto las Resoluciones N&#xB0; 161 y N&#xB0; 290, ambas de 1985 y N&#xB0; 1040, de 1988, todas de esta Subsecretar&#xED;a, que autorizaron a SOCIEDAD MARTINEZ, LEIVA, GUAJARDO Y CIA. LTDA.</div><div class=\"p\">&quot;Crassostrea Limitada&quot;, para operar un establecimiento de cultivo en Laguna Cahuil, provincia Cardenal Caro, Regi&#xF3;n VI, por renuncia total de su titular, ya individualizado.-</div><br></div>", "i": 8292523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 25 de junio de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8292524}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "447", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-447"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "AUTORIZACION", "SOCIEDAD MARTINEZ LEIVA", "GUAJARDO CIA LTDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-25", "doble_articulado": false, "id_norma": "34829", "numero_fuente": "34606", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-07-05", "vigencias": [{"desde": "1993-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-07-05", "fin_v