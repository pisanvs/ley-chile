{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7334697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.067 de 31 de octubre de 2006, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP. N&#xBA; 242 de 31 de agosto de 1992, en la parte que se refiere al Convenio Directo de Precio</div><div class=\"p\">Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 3-A, fijada por la Comisi&#xF3;n de Peritos, en junio de 1992, en la cantidad de $3.911.390. </div></div>", "i": 7334698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7334699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1067", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1067"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-31", "doble_articulado": false, "id_norma": "256391", "numero_fuente": "38639", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-15", "vigencias": [{"desde": "2006-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por"