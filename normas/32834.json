{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; APRUEBA REFORMA DE ESTATUTOS A &quot;CAJA REASEGURADORA DE CHILE S.A.&quot; </div></div>", "i": 7194626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico: Que por Resoluci&#xF3;n N&#xB0; 72 de 06 de junio de 1994, se aprob&#xF3; reforma de estatutos de la sociedad an&#xF3;nima &quot;Caja Reaseguradora de Chile S.A.&quot;, que consta de la escritura p&#xFA;blica de 19 de mayo de 1994, otorgada en la Notar&#xED;a de Santiago de don Gonzalo de la Cuadra Fabres.</div><div class=\"p\">&nbsp; &nbsp; La reforma consiste en disminuir de 11 a 9 el n&#xFA;mero de miembros del Directorio.</div><br></div>", "i": 7194627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 06 de junio de 1994.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 7194628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "72", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-72"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS A CAJA REASEGURADORA DE CHILE S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAJA REASEGURADORA CHILE S.A.", "REFORMA ESTATUTARIA", "ESTATUTOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-06", "doble_articulado": false, "id_norma": "32834", "numero_fuente": "34898", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-24", "vigencias": [{"desde": "1994-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-06-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-06-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v