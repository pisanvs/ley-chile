{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 810 EXENTA, DE 1999 </div><br></div>", "i": 6214603}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 810 de fecha 02/06/99, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; complementariamente a la empresa de origen argentino El Petr&#xF3;leo Sociedad An&#xF3;nima, para efectuar transporte internacional terrestre de pasajeros entre Puerto Huahum-San Mart&#xED;n de los Andes (Argentina) y Panguipulli-Puerto Pirihueico (Chile), utilizando el paso fronterizo Huahum en ambos sentidos, con siete (7) frecuencias semanales de ida y vuelta.-</div><br></div>", "i": 6214604}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Vicente Pardo D&#xED;az, Subsecretario de Transportes Subrogante.</div><br></div>", "i": 6214605}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "810 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-810 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 810 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-02", "doble_articulado": false, "id_norma": "150028", "numero_fuente": "36550", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-29", "vigencias": [{"desde": "1999-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-12-29", "fin_vigencia": "", "tipo_version": "3"}], 