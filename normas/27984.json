{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACLARA EL SENTIDO DEL ARTICULO NUMERO 22 DE LA LEY NUMERO 14.816, DE 1962</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5975258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Decl&#xE1;rase que el sentido del</div><div class=\"p\">art&#xED;culo 22.o de la ley N.o 14.816, de 4 de Enero de 1962, es que su beneficio comprenda tambi&#xE9;n a los ex Oficiales de la Armada reincorporados a las Fuerzas Armadas y que se encontraban en servicio a la fecha de su vigencia.&quot; </div></div>", "i": 5975259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintiocho de Septiembre de mil novecientos sesenta y dos. - JORGE ALESSANDRI RODRIGUEZ. - Julio Pereira Larra&#xED;n.</div><br></div>", "i": 5975260}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14915", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14915"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "ACLARA EL SENTIDO DEL ARTICULO NUMERO 22 DE LA LEY\nNUMERO 14.816, DE 1962", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ARMADA CHILE", "EX OFICIALES", "TIEMPO SERVIDO", "RECONOCIMIENTO", "ACLARA.-"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1962-09-28", "doble_articulado": false, "id_norma": "27984", "numero_fuente": "25361", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1962-10-06"