{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 17 de 1817.</div></div>", "i": 10282393}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno queda reconocido a la jenerosa oblacion de 128 pesos 5&#xBD; reales del ciudadano don Miguel Valdes que acredita el certificado de entero, que acompa&#xF1;an los ministros de la tesorer&#xED;a jeneral que se imprimir&#xE1; en la Gazeta para su satisfaccion i del p&#xFA;blico al ver tan repetidos ejemplos de virtudes del civicismo republicano. &#x2013; </div></div>", "i": 10282394}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Cruz. &#x2013; Dr. Villegas.&nbsp; </div></div>", "i": 10282395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-12-17", "doble_articulado": false, "id_norma": "1166923", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1917-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1917-12-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1917-12-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-11-08", "fecha_version": "1917-12-17", "fecha_actualizacion_texto": "1917-12-17", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10282393}, {"n": "Artículo", "i": 10282394, "t": 6}, {"n