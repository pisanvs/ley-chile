{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6666309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.953, de 11 de noviembre de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a JUVENAL ALEXANDER HERN&#xC1;NDEZ HERN&#xC1;NDEZ para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en caleta Level, Puerto Ed&#xE9;n, Puerto Natales, XII Regi&#xF3;n, para elaborar en las l&#xED;neas de proceso de cocido, fresco enfriado, fresco refrigerado, congelado, seco salado, ahumado, conserva, alga seca y deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6666310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de noviembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 6666311}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2953 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2953 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-11", "doble_articulado": false, "id_norma": "282864", "numero_fuente": "39231", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-06", "vigencias": [{"desde": "2008-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe