{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8683784}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.981, de 4 de junio de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a GLOBALPESCA S.A. para realizar actividades extractivas en alta mar, con la nave &quot;Globalpesca III&quot;, cuyas caracter&#xED;stica n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; CA2527</div><div class=\"p\">Puerto de Matr&#xED;cula&nbsp;  Valpara&#xED;so</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  3222</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; 55,00 m.</div><div class=\"p\">T.R.G. (nacional)&nbsp; &nbsp;  1.100.00</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  10 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 4,20 m.</div></div>", "i": 8683785}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de junio de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8683786}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1981 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1981 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-04", "doble_articulado": false, "id_norma": "1003262", "numero_fuente": "39384", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-06-11", "vigencias": [{"desde"