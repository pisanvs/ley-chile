{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 7.385 EXENTA, DE 2001 </div></div>", "i": 6343609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 7.385, de 4 de julio de 2001, se aprueban Plan y Programas Especiales de Estudio para Tercer A&#xF1;o de Ense&#xF1;anza Media al &quot;Instituto O&apos;Higgins&quot; (Hermanos Maristas) de Rancagua, el que se aplicar&#xE1; a contar del a&#xF1;o escolar 2001, de acuerdo a la gradualidad establecida en el decreto N&#xBA; 220, de 1998, y sus modificaciones. </div></div>", "i": 6343610}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de julio de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n Educaci&#xF3;n General.</div><br></div>", "i": 6343611}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7385 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7385 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 7.385 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-04", "doble_articulado": false, "id_norma": "187882", "numero_fuente": "37016", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-20", "vigencias": [{"desde": "2001-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-07-20", "fecha_version": "2001-07-20", "fech