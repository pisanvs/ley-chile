{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 97.- Santiago, 13 de Abril de 1931.- Visto lo dispuesto en el art&#xED;culo 5.o del decreto con fuerza de ley n&#xFA;mero 68, de 24 de Marzo ppdo., y en uso de la facultad que me otorga la ley n&#xFA;mero 4,945 de 6 de Febrero &#xFA;ltimo.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7117001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Cr&#xE9;ase en el Presupuesto Extraordinario del presente a&#xF1;o, un nuevo Item que se denominar&#xE1; E-16/03-j. &quot;Para atender a los gastos que origine la colonizaci&#xF3;n con obreros y empleados cesantes&quot;, $ 1.500.000.00. </div></div>", "i": 7117002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese en el Diario Oficial e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- C IBA&#xD1;EZ C.- Edecio Torreblanca.- Carlos Castro Ruiz.</div><br></div>", "i": 7117003}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "97", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-97"}], "organismos": ["MINISTERIO DE LA PROPIEDAD AUSTRAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO EXTRAORDINARIO NACION", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-04-13", "doble_articulado": false, "id_norma": "4577", "numero_fuente": "15951", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-04-18", "vigencias": [{"desde": "1931-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-04-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "193