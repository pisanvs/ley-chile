{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,018 que autoriza la enajenacion de los cazatorpederos &quot;Lynch&quot;, &quot;Condell&quot; i &quot;Simpson&quot;.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,018.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7165467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ART&#xCD;CULO &#xDA;NICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que enajene a una nacion amiga los caza-torpederos Almirante Lynch, Almirante Condell i Almirante Simpson.</div><br></div>", "i": 7165468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 12 de setiembre de 1907.- PEDRO MONTT.- Alejandro Lira.</div><br></div>", "i": 7165469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2018", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2018"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "LEI NÚM. 2.018 QUE AUTORIZA LA ENAJENACIÓN DE LOS CAZATORPEDEROS  LYNCH, CONDELL I SIMPSON", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "CAZATORPEDEROS", "ENAJENACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-09-12", "doble_articulado": false, "id_norma": "23070", "numero_fuente": "8900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-09-13", "vigencias": [{"desde": "1907-09-13", "hasta": "", "tipo_versi