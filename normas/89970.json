{"html": [{"t": "<div><div class=\"p\">DESIGNA SUBSECRETARIO GENERAL DE GOBIERNO</div><br><div class=\"p\">N&#xFA;m. 14.- Santiago, 11 de Marzo de 1990.- Visto: Lo dispuesto por el art&#xED;culo 32 No. 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica,</div><br><div class=\"p\">Decreto:</div><br></div>", "i": 6084241}, {"t": "<div><div class=\"p\">Art&#xED;culo &#xFA;nico: Des&#xED;gnase, a contar de esta fecha, a don Edgardo Sebasti&#xE1;n Riveros Mar&#xED;n en el cargo de Subsecretario General de Gobierno quien por razones de buen servicio deber&#xE1; asumir de inmediato sus funciones.</div><br></div>", "i": 6084242}, {"t": "<div><div class=\"p\">An&#xF3;tese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese y publ&#xED;quese PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Enrique Correa R&#xED;os, Ministro Secretario General de Gobierno. Lo que transcribo a Ud. para su conocimiento.- Nelson Avila C., Director, Divisi&#xF3;n Administrativa.</div><br></div>", "i": 6084243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "14", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-14"}], "organismos": ["MINISTERIO SECRETARÍA GENERAL DE GOBIERNO"], "titulo_norma": "DESIGNA SUBSECRETARIO GENERAL DE GOBIERNO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-11", "doble_articulado": false, "id_norma": "89970", "numero_fuente": "33637", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-03", "vigencias": [{"desde": "1990-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-04-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini