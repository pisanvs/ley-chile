{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA&nbsp; A&nbsp; SOCIEDAD PESQUERA MARLIMAR LTDA.</div><br></div>", "i": 6328056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por resoluci&#xF3;n Ex. N&#xBA; 3 de fecha 25.enero.2001 concede la calidad de agente retenedor del IVA, a contar del primer d&#xED;a del mes siguiente al de esta publicaci&#xF3;n a la Sociedad Pesquera Marlimar Ltda., RUT 77.094.750-2, por las adquisiciones de especies hidrobiol&#xF3;gicas que efect&#xFA;e, de acuerdo con lo establecido en la Res. N&#xBA; Ex.</div><div class=\"p\">3.311/2000 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial el d&#xED;a 03.07.2000.-</div><br></div>", "i": 6328057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rolando G&#xE1;rate Ega&#xF1;a, Director Regional (S). </div></div>", "i": 6328058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD\nPESQUERA MARLIMAR LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-25", "doble_articulado": false, "id_norma": "183308", "numero_fuente": "36925", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-29", "vigencias": [{"desde": "2001-03-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-29", "fin_vigencia": ""}, "