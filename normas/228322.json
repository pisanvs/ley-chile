{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6489902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 407 de 13 de julio de 2004 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL N&#xBA; 2.186 de 1978, del lote N&#xBA; 150 correspondiente a parte del inmueble ubicado en Santa Rosa 3932, presunto rol de aval&#xFA;o N&#xBA; 3638-54, comuna de San Joaqu&#xED;n, aparente dominio de Capitani Fuentes Gina Maritza. Comisi&#xF3;n integrada por peritos Jaime Lea-Plaza S&#xE1;enz, ingeniero civil; Gustavo Riego Allende, arquitecto, y Leonardo Bast&#xED;as Tessada, constructor civil. Seg&#xFA;n informe de 8 de octubre de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $22.500.018 pagadera al contado. </div></div>", "i": 6489903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6489904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "407", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-407"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA EN INMUEBLES QUE SEÑALA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-13", "doble_articulado": false, "id_norma": "228322", "numero_fuente": "37925", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-02", "vigencias": [{"desde": "2004-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic