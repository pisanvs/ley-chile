{"html": [{"t": "<div><div class=\"p\">DISPONE EXPROPIACION PARCIAL DE INMUEBLE </div></div>", "i": 6226080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto Secc. 2&#xAA; N&#xBA;1.052, diciembre 23 de 1999, Alcalde Municipalidad de Santiago dispone expropiaci&#xF3;n parcial conforme art&#xED;culo 85, decreto N&#xBA;458 Vivienda y Urbanismo inmueble Avda. Libertador Bernardo O&apos;Higgins N&#xBA;642-644 al 654 y 668 al 672 Rol 329-007-329-010 y 329-039 comuna Santiago, dominio aparente Inmobiliaria e Inversiones Sierra Bella S.A., superficie aproximada 151,91 m2, Deslindes: Norte: 22,70 mts y 28,60 mts. con Avda. Libertador Bernardo O&apos;Higgins; Sur: irregular, resto misma propiedad; Oriente: v&#xE9;rtice resto misma propiedad; Poniente: 36 mts. con Avda. Santa Rosa.</div><div class=\"p\">&nbsp; &nbsp;  Indemnizaci&#xF3;n $57.163.733.- se pagar&#xE1; mediante compensaci&#xF3;n derechos edificaci&#xF3;n.-</div><br></div>", "i": 6226081}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime Ravinet de la Fuente, Alcalde.</div><br><br></div>", "i": 6226082}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1052", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1052"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "DISPONE EXPROPIACION PARCIAL DE INMUEBLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-23", "doble_articulado": false, "id_norma": "153466", "numero_fuente": "36577", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-01", "vigencias": [{"desde": "2000-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc