{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE SE&#xD1;ALA </div></div>", "i": 6151549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1.375 de 29 de Agosto de 1988 aclar&#xF3; Resoluci&#xF3;n Exenta No. 990 de 9 de Junio de 1988, que aprob&#xF3; distribuci&#xF3;n derechos de aprovechamiento de aguas predio &quot;Hijuela N&#xFA;mero Uno o Santa Margarita&quot;, &quot;Hijuela N&#xFA;mero Dos o Las Barrancas&quot;, &quot;Hijuela N&#xFA;mero Tres Quimpo&quot;, &quot;Hijuela N&#xFA;mero Cuatro o Las Mercedes&quot; e &quot;Hijuela N&#xFA;mero Cinco o La Isla del Fundo Quimpo&quot; en el sentido de dejar establecido los derechos de agua de la exclusi&#xF3;n en el R&#xED;o &#xD1;uble conducidos por el Canal Reloca. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6151550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo </div></div>", "i": 6151551}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1375 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1375 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-29", "doble_articulado": false, "id_norma": "130936", "numero_fuente": "33161", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-01", "vigencias": [{"desde": "1988-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988