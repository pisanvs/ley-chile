{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO MUNICIPAL No. 14, DE 1982</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 4.- Lonquimay, 29 de Octubre de 1985.</div><div class=\"p\">&nbsp; &nbsp;  Vistos estos antecedentes: Decreto Municipal No. 14 de fecha 27 de Enero de 1982 y en uso de las atribuciones que me confiere el Art. 13 del Decreto Ley No. 1.289, de 1975, que contiene la Ley de Municipalidades, d&#xED;ctase la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Ordenanza:</div><br></div>", "i": 6268182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  No. 1.- Reempl&#xE1;zase la palabra &quot;Decreto&quot;, por &quot;Ordenanza&quot;, en el Decreto Municipal No. 14 de fecha 27 de Enero de 1982, sobre Derechos Municipales por concesiones, permisos y servicios.</div><br></div>", "i": 6268183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial de la Rep&#xFA;blica.- Edmundo Sven Fahrenkrog Butendieck, Alcalde.- Mario Adriasola Caulier, Secretario (S).</div><br></div>", "i": 6268184}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "4", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-4"}], "organismos": ["MUNICIPALIDAD DE LONQUIMAY"], "titulo_norma": "MODIFICA DECRETO MUNICIPAL No. 14, DE 1982", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-29", "doble_articulado": false, "id_norma": "166484", "numero_fuente": "32332", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-27", "vigencias": [{"desde": "1985-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "198