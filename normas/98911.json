{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 631, de 4 de mayo de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 742 de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a ESTEBAN HAUWAY TORRES&nbsp; para instalar y operar un centro de cultivo ubicado en Punta Arroyo, Bah&#xED;a Inglesa, comuna de Caldera, III Regi&#xF3;n, por haberse puesto t&#xE9;rmino al respectivo decreto de concesi&#xF3;n de acuicultura.</div><br></div>", "i": 8329915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329916}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "631", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-631"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "CALDERA", "ESTEBAN HAUWAY TORRES", "TERCERA REGION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-04", "doble_articulado": false, "id_norma": "98911", "numero_fuente": "36063", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-13", "vigencias": [{"desde": "1998-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-05-13", "fin_vigencia": "", "tipo_version": "3"}], "