{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7296351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.964 de 20 de diciembre de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 168 de 1997, modificada por resoluci&#xF3;n N&#xBA; 550 de 1999, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autorizaron a ALIMENTOS MARINOS S.A. para operar la nave &quot;Santa Irene&quot;, en la V, VI, VII y X Regiones, con cerco, sobre los recursos hidrobiol&#xF3;gicos Anchoveta y Sardina com&#xFA;n y entre la V a VII y X Regiones, con cerco, sobre el recurso hidrobiol&#xF3;gico Merluza de cola, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7296352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7296353}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2964", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2964"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-20", "doble_articulado": false, "id_norma": "206223", "numero_fuente": "37445", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-28", "vigencias": [{"desde": "2002-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic