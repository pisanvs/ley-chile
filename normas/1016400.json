{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div></div>", "i": 8967719}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de agosto de 2010, fue de 0,24% anual.</div></div>", "i": 8967720}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de agosto de 2010.- Juan Esteban Laval Zald&#xED;var, Ministro de Fe (S).</div></div>", "i": 8967721}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-08-18", "doble_articulado": false, "id_norma": "1016400", "numero_fuente": "39741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-08-20", "vigencias": [{"desde": "2010-08-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-08-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-08-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "118", "fecha_ingreso": "2010-08-20", "fecha_version": "2010-08-20", "actualizado_por": "118", "fecha_actualizacion_texto": "2010-08-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado