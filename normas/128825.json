{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.061 EXENTO, DE 1998 </div><br></div>", "i": 6145000}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.061 de fecha 30 de noviembre de 1998 del Ministerio de Educaci&#xF3;n, se registr&#xF3; la carrera de Derecho, conducente al grado acad&#xE9;mico de Licenciado en Ciencias Jur&#xED;dicas y Sociales de la Universidad Mar&#xED;tima de Chile, de conformidad al convenio de examinaci&#xF3;n y certificado de aprobaci&#xF3;n de planes y programas de estudios emitido por la Universidad de Talca en su calidad de entidad examinadora, la que podr&#xE1; impartirse a contar del a&#xF1;o 1999.</div><br></div>", "i": 6145001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de diciembre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6145002}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1061 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1061 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.061 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-30", "doble_articulado": false, "id_norma": "128825", "numero_fuente": "36252", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-31", "vigencias": [{"desde": "1998-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-12-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula