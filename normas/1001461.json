{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 8566921}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En el Diario Oficial N&#xBA;39.344, de fecha 23 de abril de 2009, se public&#xF3; el Acuerdo N&#xBA;1472-04-090416 - &quot;Modifica normas relativas a las personas jur&#xED;dicas autorizadas para formar parte del Mercado Cambiario Formal distintas de las empresas bancarias - Modifica Cap&#xED;tulo III del Compendio de Normas de Cambios Internacionales del Banco Central de Chile&quot;, con el error que se salva a continuaci&#xF3;n:</div><br><div class=\"p\">&nbsp; &nbsp;  En la p&#xE1;gina 19, primera columna:</div><br><div class=\"p\">&nbsp; &nbsp;  Reemplazar en el numeral 1. p&#xE1;rrafo 6 l&#xED;nea 4 donde dice &quot;sobreviviente&quot; debe decir &quot;sobreviniente&quot;.</div></div>", "i": 8566922, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 8566923}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1001461", "numero_fuente": "39346", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-04-25", "vigencias": [{"desde": "2009-04-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-04-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-04-25", "fin_vigenc