{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA N&#xD3;MINA DE &quot;GRANDES CONTRIBUYENTES&quot;</div></div>", "i": 9421386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 30, de 19 de marzo de 2014, que dispone:</div><div class=\"p\">&nbsp; &nbsp;  Complementa <a href=\"https://www.leychile.cl/Navegar?idNorma=1057863&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta SII N&#xBA; 109, de 27 de diciembre de 2013</a>, incorporando a la N&#xF3;mina de Grandes Contribuyentes a los siguientes contribuyentes, en cuanto cumple con uno o m&#xE1;s de los requisitos establecidos en los resolutivos 2&#xBA;, 3&#xBA; y/o 4&#xBA; de la resoluci&#xF3;n exenta SII N&#xBA; 109, de 27 de diciembre de 2013.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/38969.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  La presente resoluci&#xF3;n regir&#xE1; desde su publicaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Actual&#xED;cese en el sitio web del Servicio (www.sii.cl) el enlace mediante el cual los contribuyentes tienen acceso a la N&#xF3;mina de Grandes Contribuyentes, dentro del men&#xFA; &quot;Oficinas del SII&quot;, conforme la Res. Ex. SII N&#xBA; 109, de 2013.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en el mes de marzo de 2014.</div></div>", "i": 9421387}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "30 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-30 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "COMPLEMENTA NÓMINA DE \"GRANDES CONTRIBUYENTES\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-03-19", "doble_articulado": false, "id_norma": "1060449", "numero_fuente": "40814", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-03-22", "vigencias": [{"desde": "2014-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-03-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "17616", "fecha_ingreso": "2014-03-24", "fecha_version": "2014-03-22", "fecha_actualizacion_texto": "2014-03-24", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9421386}, {"n": "Artículo", "i": 9421387, "t": 6}]}