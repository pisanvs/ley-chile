{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6209382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 2.465, de 31 de agosto de 1999, se expropiaron los lotes de terreno N&#xBA;s. 1, 2, 8 y 17, superficies 6.619,7; 9.264,1; 1.782,3 y 377,7 m2., respectivamente, roles de aval&#xFA;os 212-1, 215-219 y 215-200, comuna de Teodoro Schmidt, obra Camino Costero Sur, sector Tranapuente-Puerto Saavedra Porma, tramo Chelle Hualpin-Puente Peule y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Mar&#xED;a Gonz&#xE1;lez Olgu&#xED;n y otra, Rosendo Huircan Trangol y Jos&#xE9; R. Calfan Huircan, ascendente a las cantidades de $3.270.018, lotes 1 y 2; $633.136, lote 8 y $144.609, lote 17. </div></div>", "i": 6209383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6209384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2465", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2465"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-31", "doble_articulado": false, "id_norma": "148617", "numero_fuente": "35528", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-01", "vigencias": [{"desde": "1999-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JR