{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6264021}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto No. 326, de 30 de Octubre de 1985, se expropiaron los lotes N&#xB0;s. 1 y 3, cuyas superficies son 2.477 M2. y 3.571 M2., roles de aval&#xFA;os 320-25 y 346-71, respectivamente, Comuna de R&#xED;o Negro, para Puente Esmeralda, Camino R&#xED;o Negro Riachuelo y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios don Luis F. Ponce Barr&#xED;a y don Jos&#xE9; D. Huilitraro Catrilef, ascendente a $ 111.441 y $ 154.034,.</div><br></div>", "i": 6264022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. (2) </div></div>", "i": 6264023}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "326", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-326"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-30", "doble_articulado": false, "id_norma": "165215", "numero_fuente": "32336", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-02", "vigencias": [{"desde": "1985-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-04-14", "fecha_version": "1985-12-02", "fecha_actualizacion_texto": "1985-12-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "e