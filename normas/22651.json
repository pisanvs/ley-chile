{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Mobiliario para la Camara de Senadores Lei n&#xFA;m. 1,441.- Santiago, a 19 de Enero de 1901.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese la suma de diecisiete mil pesos para completar la adquisicion del mobiliario para la C&#xE1;mara de Senadores.</div><div class=\"p\">&nbsp; &nbsp; Esta autorizacion durar&#xE1; por el t&#xE9;rmino de un a&#xF1;o. </div></div>", "i": 8274347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Juan Antonio Orrego.</div><br></div>", "i": 8274348}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1441", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1441"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MOBILIARIO PARA LA CAMARA DE SENADORES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMARA SENADORES", "MOBILIARIO", "ADQUISICION", "FONDOS", "DESTINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-19", "doble_articulado": false, "id_norma": "22651", "numero_fuente": "6800", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-01-24", "vigencias": [{"desde": "1901-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-01-24", "fin_vigencia": ""