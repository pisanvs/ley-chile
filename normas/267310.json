{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 6.772, DE 2007 </div></div>", "i": 7360091}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante la resoluci&#xF3;n N&#xBA; 6.772, de fecha 30 de noviembre de 2007, de la Direcci&#xF3;n Nacional de Aduanas, se modific&#xF3; el Cap&#xED;tulo III del Compendio de Normas Aduaneras, relativo a Normas sobre Registro de Importadores y Exportadores de Sustancias Agotadoras de la Capa de Ozono y a la forma de acreditar el cumplimiento de los requisitos, exigencias, documentos y visaciones aplicables a las sustancias y productos controlados establecidos por la ley N&#xBA; 20.096/06 regulados por el decreto supremo N&#xBA; 37/07.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de esta resoluci&#xF3;n se encuentra en la p&#xE1;gina web del Servicio Nacional de Aduanas. </div></div>", "i": 7360092}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6772", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6772"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 6.772, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPENDIO DE NORMAS ADUANERAS", "MODIFICACION", "SUSTANCIAS AGOTADORAS DE LA CAPA DE OZONO", "REGISTRO DE IMPORTADORES Y EXPORTADORES", "REQUISITOS", "EXIGENCIAS", "CALENTAMIENTO GLOBAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-30", "doble_articulado": false, "id_norma": "267310", "numero_fuente": "38932", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-10", "vigencias": [{"desde": "2007-12-10", "hasta": "", "tipo_version": "3", "tipo_