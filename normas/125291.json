{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6133275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 295, de fecha 12 de Diciembre de 1988, conforme art. 51 Ley 16.391, de 1965, y DS 181, de 1988, de Vivienda y Urbanismo, SERVIU IX Regi&#xF3;n dispuso expropiaci&#xF3;n inmueble ubicado en calle San Martin No. 1121, ciudad Temuco, Rol de Aval&#xFA;o No. 222-14, inscrito a nombre de Teorinda del Carmen Mora Rivas a fojas 30, No. 21, a&#xF1;o 1985, Registro Propiedad Conservador Bienes Raices Temuco. Comisi&#xF3;n Peritos integrada por se&#xF1;ores Jos&#xE9; M&#xE9;ndez Manriquez, ingeniero civil; Mario Molina Ramwell, constructor civil, y Pablo Reidel Wanner, arquit&#xE9;cto, fij&#xF3; monto provisional indemnizaci&#xF3;n suma de $ 311.000.-, seg&#xFA;n Informe de 28.11.88, pagadera contado.-</div><br></div>", "i": 6133276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Regional.</div><br></div>", "i": 6133277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "295", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-295"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION IX REGIÓN DE LA ARAUCANIA"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-12", "doble_articulado": false, "id_norma": "125291", "numero_fuente": "33246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-12-15", "vigencias": [{"desde": "1988-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],