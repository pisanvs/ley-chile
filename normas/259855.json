{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7339238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 719, de 27 de febrero de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a DORISMAN DEL CARMEN CARVAJAL LEDEZMA, RUT N&#xBA; 6.899.226-5, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Willy Linderman N&#xBA; 2427, Local 2, Guanaqueros, comuna de Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-enfriado, Fresco-refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 7339239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de febrero de 2007.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 7339240}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "719 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-719 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-02-27", "doble_articulado": false, "id_norma": "259855", "numero_fuente": "38734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-10", "vigencias": [{"desde": "2007-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-04-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-04-10", "fin_vigencia": "", "tipo_version": "3"}], "e