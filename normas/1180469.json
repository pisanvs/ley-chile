{"html": [{"t": "<div><div class=\"p\">MODIFICA ANEXOS 51-11, DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10360390}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.222, de 18 de agosto de 2022, del Director Nacional de Aduanas, se modifica el <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, en el siguiente sentido:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Agr&#xE9;gase al Anexo 51-11, los siguientes puntos habilitados como puertos: Paso Buta Mallin c&#xF3;digo 824; Aer&#xF3;dromo La Araucan&#xED;a c&#xF3;digo 825, y Estaci&#xF3;n de Medici&#xF3;n Recinto c&#xF3;digo 826.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div><br></div>", "i": 10360391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alejandra Arriaza Loeb, Directora Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10360392}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2222 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2222 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA ANEXOS 51-11, DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2176949", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-08-18", "doble_articulado":