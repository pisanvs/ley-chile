{"html": [{"t": "<div><div class=\"p\">CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A TRUSAL S.A.</div><br></div>", "i": 6104365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Metropolitana Santiago Oriente del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA; Ex. 357 de 06/02/98, certifica que a contar del 1 del mes siguiente al de esta publicaci&#xF3;n y hasta el 30 de junio de 1998, Trusal S.A., Rut N&#xBA; 96.566.740-7, tiene la calidad de Agente Retenedor del Impuesto al Valor Agregado, por las compras de especies hidrobiol&#xF3;gicas, por cuanto cumple los requisitos establecidos en la resoluci&#xF3;n N&#xBA; Ex. 3173 de 27-06-97.- </div></div>", "i": 6104366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ana Mar&#xED;a C&#xE1;rcamo Marambio, Director Regional (S). </div></div>", "i": 6104367}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "357 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-357 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO ORIENTE"], "titulo_norma": "CERTIFICA CALIDAD DE AGENTE RETENEDOR DEL IVA A TRUSAL S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "TRUSAL S.A.", "ESPECIES HIDROBIOLOGICAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-06", "doble_articulado": false, "id_norma": "96825", "numero_fuente": "35997", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-21", "vigencias": [{"desde": "1998-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-02-21", "fin_vigenci