{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 2.- Santiago, 12 de Febrero de 1931.- En uso de las facultades que me confiere la ley n&#xFA;mero 4,945, de 7 de Febrero</div><div class=\"p\">&nbsp; &nbsp; He acordado y decreto:</div><br></div>", "i": 7113290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Trasp&#xE1;sase al &#xED;tem 06/01/04/v, la suma de cuatrocientos cincuenta mil pesos ($ 450,000), que se deducir&#xE1; en la siguiente forma: de 06/01/10/a $ 400,000, y de 06/01/10/b, $ 50,000.</div><br></div>", "i": 7113291}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; La Contralor&#xED;a General de la Rep&#xFA;blica tomar&#xE1; raz&#xF3;n y las oficinas de Hacienda dar&#xE1;n curso al presente decreto.- C. IBA&#xD1;EZ C.- Carlos Castro Ruiz.</div><br></div>", "i": 7113292}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "2", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-2"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-02-12", "doble_articulado": false, "id_norma": "3481", "numero_fuente": "15982", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-28", "vigencias": [{"desde": "1931-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-05-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1931-05-28", "fecha_