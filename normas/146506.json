{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6201402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.787, de 30 de junio de 1999, se expropiaron los lotes de terreno N&#xBA;s. 58, 61, 61-A, 63, 64 y 64-A, superficies 428, 1.878, 989, 886, 1.741 y 1.772,22 m2 respectivamente, roles de aval&#xFA;o 9309-17, 9309-6, 9309-1 y en tr&#xE1;mite, comuna de Valpara&#xED;so, para la obra Habilitaci&#xF3;n nuevo Camino La P&#xF3;lvora Etapa I, Sector Ruta 68 - Acceso Sur a Valpara&#xED;so, Camino La P&#xF3;lvora, Rol F-724, F-730, sector Placilla - Puertas Negras y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Jos&#xE9; Schafer Mateluna y otro, Vicente Pizarro Tureo y Mar&#xED;a Contador Ba&#xF1;ados y otros, ascendente a las cantidades de $1.489.600, $9.465.435, $3.496.032, $6.689.982 y $6.257.059.-</div><br></div>", "i": 6201403}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6201404}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1787", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1787"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-30", "doble_articulado": false, "id_norma": "146506", "numero_fuente": "36503", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-02", "vigencias": [{"desde": "1999-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":