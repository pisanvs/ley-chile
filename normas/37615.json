{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298720}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.979 de 28 de noviembre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1 y 2 de la Resoluci&#xF3;n N&#xB0; 1.379 de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a ALIMENTOS MARINOS S.A., para sustituir varias embarcaciones, en el sentido de se&#xF1;alar que la nave reemplazante autorizada se denomina &quot;Santa Irene&quot; y no como all&#xED; se indica.</div><br></div>", "i": 8298721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de noviembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298722}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1979", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1979"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "MODIFICACION", "ALIMENTOS MARINOS S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-11-28", "doble_articulado": false, "id_norma": "37615", "numero_fuente": "35637", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-10", "vigencias": [{"desde": "1996-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-12-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificac