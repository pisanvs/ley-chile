{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,637.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir durante el presente a&#xF1;o hasta la suma de novecientos sesenta i cinco mil pesos ($ 965,000) en la inspeccion t&#xE9;cnica, espropiaciones de terrenos, polic&#xED;a i otros gastos del ferrocarril lonjitudinal.</div><br></div>", "i": 6173781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, ocho de febrero de mil novecientos doce.- Ramon Barros Luco.- Abraham A. Ovalle.</div><br></div>", "i": 6173782}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2637", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2637"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-02-08", "doble_articulado": false, "id_norma": "137979", "numero_fuente": "10204", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-02-13", "vigencias": [{"desde": "1912-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-02-13", "fin_vigencia": "", "tipo_version": "