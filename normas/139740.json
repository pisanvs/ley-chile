{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8347213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.307, de 12 de julio de 1999, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 3 de la resoluci&#xF3;n N&#xBA; 1.915, de 30 de diciembre de 1998, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA ISLADAMAS S.A., para ampliar actividades pesqueras con la nave &apos;&apos;Lonquimay&apos;&apos; en el sentido de eliminar de su literal a) la expresi&#xF3;n &apos;&apos;y s&#xF3;lo como fauna acompa&#xF1;ante de Camar&#xF3;n nail&#xF3;n&apos;&apos;, y de sus literales b) y c) la expresi&#xF3;n &apos;&apos;y s&#xF3;lo como fauna acompa&#xF1;ante de Camar&#xF3;n nail&#xF3;n y Merluza com&#xFA;n&apos;&apos;.</div><br></div>", "i": 8347214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de julio de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8347215}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1307", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1307"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-07-12", "fecha_derogacion": "2024-10-08", "doble_articulado": false, "id_norma": "139740", "numero_fuente": "36425", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-07-29", "vigencias": [{"desde": "2024-10-08", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-07-29", "hasta": "2024-10-07", "tipo_version": "0", "t