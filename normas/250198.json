{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 13.645 EXENTA, DE 2004 </div></div>", "i": 6571817}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 13.645, de 15 de noviembre de 2004, se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.937 de 2002 que aprob&#xF3; plan y programas especiales de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Colegio Compa&#xF1;&#xED;a de Mar&#xED;a de Apoquindo, comuna de Las Condes, de Santiago, en el sentido de sustituir su plan de estudio por el que se indica en la presente resoluci&#xF3;n.</div><br></div>", "i": 6571818}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de enero de 2005.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6571819}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13645 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-13645 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 13.645 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-15", "doble_articulado": false, "id_norma": "250198", "numero_fuente": "38481", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-05", "vigencias": [{"desde": "2006-06-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-06-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-06-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MOD