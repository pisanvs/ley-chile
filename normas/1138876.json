{"html": [{"t": "<div><div class=\"p\">CERTIFICADO N&#xB0; 513</div></div>", "i": 10069341}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por escritura p&#xFA;blica de fecha 21 de marzo de 2019, otorgada en la Quinta Notar&#xED;a de Santiago, del Notario P&#xFA;blico don Patricio Raby Benavente, domiciliado en calle Gertrudis Eche&#xF1;ique N&#xBA; 30, oficina 44, comuna de Las Condes, se redujo el acta de la junta extraordinaria de accionistas de Capitaria Administradora General de Fondos S.A., celebrada el 21 de marzo de 2019.</div><div class=\"p\">&nbsp; &nbsp;  Que, por resoluci&#xF3;n exenta N&#xBA; 7.396, de fecha 23 de octubre de 2019, de esta Comisi&#xF3;n para el Mercado Financiero, se aprob&#xF3; la disoluci&#xF3;n anticipada de Capitaria Administradora General de Fondos S.A.</div><br></div>", "i": 10069342}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de octubre de 2019.- Por orden del Consejo de la Comisi&#xF3;n para el Mercado Financiero, Gerardo Bravo Riquelme, Secretario General.</div><br></div>", "i": 10069343}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7396 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-7396 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "COMISIÓN PARA EL MERCADO FINANCIERO"], "titulo_norma": "CERTIFICADO N° 513", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1682659", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-10-23", "doble_articulado": false, "id_norma": "1138876", "numero_fuente": "42506", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-11-19", "vigencias": [{"desde": "2019-11-19", "hasta": "", "tipo