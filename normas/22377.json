{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Edificio del Congreso Lei n&#xFA;m. 1,052.- Santiago, a 23 de Julio de 1898.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 8274058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese un suplemento de doscientos mil pesos al &#xED;tem 6, partida 65 del presupuesto del Ministerio del Interior, destinado a la prosecucion de los trabajos del edificio del Congreso Nacional.</div><br><br></div>", "i": 8274059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8274060}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1052", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1052"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "EDIFICIO DEL CONGRESO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1898", "MODIFICACION", "CONGRESO NACIONAL", "EDIFICACION", "FONDOS", "DESTINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-07-23", "doble_articulado": false, "id_norma": "22377", "numero_fuente": "6057", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-07-23", "vigencias": [{"desde": "1898-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-07-23", "fin_vig