{"html": [{"t": "<div><div class=\"p\">Extracto de Resoluci&#xF3;n N&#xB0; 2.673 </div></div>", "i": 6091557}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta No. 2.673, de 10 de Noviembre de 1989, de este Servicio Nacional, se reconoci&#xF3; como organismo t&#xE9;cnico intermedio a la &quot;Corporaci&#xF3;n de Capacitaci&#xF3;n Promaule&quot;, domiciliada en Uno Poniente N&#xAA; 1258, de la ciudad de Talca, de acuerdo con lo dispuesto en el decreto con fuerza de Ley No. 1, de 1989, del Ministerio del Trabajo y Previsi&#xF3;n Social y su Reglamento contenido en el decreto supremo No. 42, de 1986, de la citada Secretar&#xED;a de Estado. </div></div>", "i": 6091558}, {"t": "<div><div class=\"p\">Santiago, de Noviembre de 1989.- Ricardo Hepp Dubiau, Director Nacional.</div><br></div>", "i": 6091559}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2673", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2673"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO RESOLUCION N°. 2673", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-10", "doble_articulado": false, "id_norma": "92436", "numero_fuente": "33558", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-30", "vigencias": [{"desde": "1989-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":