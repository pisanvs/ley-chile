{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 348 EXENTO, DE 2002 </div></div>", "i": 6392006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 348 de fecha 29 de abril de 2002, se declara aprobada a la Universidad Miguel de Cervantes la modificaci&#xF3;n al Plan y a los Programas de Estudio de la carrera de Periodismo, a contar del primer semestre de 2002. Dicha carrera se imparte en jornada diurna en su sede de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6392007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de mayo de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6392008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "348 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-348 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 348 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-29", "doble_articulado": false, "id_norma": "201343", "numero_fuente": "37331", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-10", "vigencias": [{"desde": "2002-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-08-12", "fecha_version": "2002-08-10", "fec