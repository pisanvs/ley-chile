{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 4,026, que destina fondos para atender a la Embajada Especial Italiana</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m 4,026.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5957748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cien mil pesos ($ 100,000) en moneda corriente en los gastos que demande la pr&#xF3;xima visita al pais de la Embajada Especial Italiana que viaja a bordo de la nave &quot;Italia&quot;. </div></div>", "i": 5957749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica</div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de junio de 1924.- Arturo Alessandri.- Galvarino Gallardo Nieto.</div><br></div>", "i": 5957750}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4026", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4026"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "LEI NUM. 4,026, QUE DESTINA FONDOS PARA ATENDER A LA EMBAJADA ESPECIAL ITALIANA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMBAJADA ESPECIAL ITALIANA", "FONDOS", "DESTINACION", "PRESIDENTE DE LA REPUBLICA", "INVERSION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1924-06-26", "doble_articulado": false, "id_norma": "24413", "numero_fuente": "13911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1924-06-26", "vigencias": [{"desde": "1924-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1924-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1924-06-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-03-03", "fecha_version": "1924-06-26", "fecha_actualizacion_texto": "1924-06-26", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5957748}, {"n": "Artículo UNICO", "i": 5957749, "t": 6}, {"n": "Promulgación", "i": 5957750}]}