{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 359, DE 1990 </div></div>", "i": 6270090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 359 de 27 de diciembre de 1990 se ha aprobado un programa de estudio, que se aplicar&#xE1; por un per&#xED;odo de 4 a&#xF1;os, a contar de marzo de 1991, para la Escuela Diferencial F No. 499 de la comuna de La Granja, Regi&#xF3;n Metropolitana, para impartir ense&#xF1;anza orientada a la vida laboral, a trav&#xE9;s de un curso taller de Jugueter&#xED;a y Tejidos.</div><br></div>", "i": 6270091}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de Marzo de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6270092}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "359 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-359 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 359, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-27", "doble_articulado": false, "id_norma": "167111", "numero_fuente": "33914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-09", "vigencias": [{"desde": "1991-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-04-27", "fecha_version": "1991-03-09", "fecha_actual