{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION DE EMISOR ELECTRONICO </div></div>", "i": 6526508}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 47 de 11-05-2005, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como emisor electr&#xF3;nico.</div><div class=\"p\">&nbsp; &nbsp;  Se deroga autorizaci&#xF3;n otorgada a contribuyente RUT N&#xBA; 94.479.000-4, para operar como emisor de Documentos Tributarios Electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de mayo de 2005.</div><br></div>", "i": 6526509}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "47 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-47 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACION DE EMISOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "EMISORES ELECTRONICOS", "AUTORIZACION", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-11", "doble_articulado": false, "id_norma": "238106", "numero_fuente": "38163", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-17", "vigencias": [{"desde": "2005-05-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-17", "fin_vigencia": ""}, "