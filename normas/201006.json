{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6390797}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;995, de fecha 28 de junio de 2002, se expropiaron los lotes de terreno N&#xBA;s. 28-D y 28-E, superficies 1.575 m&#xB2; y 2.560 m&#xB2;, respectivamente, rol de aval&#xFA;o 348-32, comuna de Constituci&#xF3;n, VII Regi&#xF3;n, para la obra &apos;&apos;Camino M-24-K, Quivolgo Puente Lautaro, sector La Trinchera - Put&#xFA; (Variante Costera), Km. 13,240 al 30,000&apos;&apos;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario don Edilio Vergara Mu&#xF1;oz, ascendente a la cantidad de $2.661.300. </div></div>", "i": 6390798}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras Publicas </div></div>", "i": 6390799}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "995 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-995 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-28", "doble_articulado": false, "id_norma": "201006", "numero_fuente": "37323", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-01", "vigencias": [{"desde": "2002-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-08-01", "fecha_version": "2002-08-01", "fe