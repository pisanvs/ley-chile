{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7296345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.961, de 20 de diciembre de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;979 de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESCA CHILE S.A., para operar la nave &quot;Puerto Ballena&quot;, en las aguas interiores al sur del paralelo 47&#xBA; L.S., sobre el recurso Merluza de tres aletas, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7296346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7296347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2961", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2961"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-20", "doble_articulado": false, "id_norma": "206221", "numero_fuente": "37445", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-28", "vigencias": [{"desde": "2002-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}, {"text": "CONCORD