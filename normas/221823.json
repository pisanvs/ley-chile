{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES </div></div>", "i": 6466780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Municipalidad de Curarrehue pone en conocimiento de la comunidad que por decreto alcaldicio N&#xBA; 1.029, de fecha 12 de agosto de 2003, fue aprobada la ordenanza que norma sobre el procedimiento a observar para el otorgamiento de las subvenciones municipales.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada ordenanza est&#xE1; a disposici&#xF3;n de quien lo solicite en la Secretar&#xED;a Municipal, cuya oficina se ubica en Avda. Estadio N&#xBA; 550, de Curarrehue.</div><br></div>", "i": 6466781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Abel Painefilo Barriga, Alcalde.</div><br></div>", "i": 6466782}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1029", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1029"}], "organismos": ["MUNICIPALIDAD DE CURARREHUE"], "titulo_norma": "APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-12", "doble_articulado": false, "id_norma": "221823", "numero_fuente": "37798", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-28", "vigencias": [{"desde": "2004-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-03-01", "fecha_version": "20