{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8892879}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 595, de 29 de enero de 2010, de esta Subsecretar&#xED;a, modif&#xED;quese el numeral 3.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=287925&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 283 de 2009</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD DE VALPARA&#xCD;SO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Ecolog&#xED;a tr&#xF3;fica de aves y mam&#xED;feros marinos en la Reserva Nacional Ping&#xFC;ino de Humboldt, III y IV Regi&#xF3;n&quot;, en el sentido de extender su per&#xED;odo de vigencia hasta el 21 de enero de 2011, inclusive.</div></div>", "i": 8892880}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de enero de 2010.- Mar&#xED;a &#xC1;ngela Barbieri Bellolio, Subsecretaria de Pesca (S).</div><br></div>", "i": 8892881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "595 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-595 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-01-29", "doble_articulado": false, "id_norma": "1011747", "numero_fuente": "39612", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-16", "vigencias": [{"desde": "2010-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i