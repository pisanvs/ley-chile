{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 349 EXENTA, DE 2001. </div></div>", "i": 6321621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de educaci&#xF3;n N&#xBA; 349 de 12 de enero del a&#xF1;o 2001, se ha aprobado al Colegio &apos;&apos;Nido de Aguilas&apos;&apos;, comuna de Lo Barnechea, de Santiago, un plan de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001 y 2002 respectivamente, de acuerdo a la gradualidad temporal establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 220 de 1998 y sus modificaciones.</div><br></div>", "i": 6321622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de enero de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6321623}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "349 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-349 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 349 EXENTA, DE 2001.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-12", "doble_articulado": false, "id_norma": "181632", "numero_fuente": "36884", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-09", "vigencias": [{"desde": "2001-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-02-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFIC