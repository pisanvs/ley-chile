{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;252, DE 1990 </div></div>", "i": 7217210}, {"t": "<div><div class=\"p\">Por Decreto Exento N&#xBA;252, de fecha 1&#xBA; de octubre de 1990, del Ministerio de Educaci&#xF3;n, se aprob&#xF3; el siguiente plan y programa de estudio al centro de Formaci&#xF3;n T&#xE9;cnica Centro Regional de Computaci&#xF3;n e Inform&#xE1;tica CRECIC de Concepci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1990:</div><div class=\"p\">Carrera: Contabilidad con menci&#xF3;n en Inform&#xE1;tica.</div><div class=\"p\">T&#xED;tulo: Contador General con menci&#xF3;n en Inform&#xE1;tica. </div></div>", "i": 7217211}, {"t": "<div><div class=\"p\">Santiago, 12 de noviembre de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7217212}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "252 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-252 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº 252, DE 1990", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-10-01", "fecha_derogacion": "2016-12-31", "doble_articulado": false, "id_norma": "82257", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1990-12-31", "vigencias": [{"desde": "2016-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1990-12-31", "hasta": "2016-12-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2016-12-31", "fin_vigencia": ""}, "vigen