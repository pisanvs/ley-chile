{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 362 EXENTO, DE 1997 </div></div>", "i": 7206076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 362 de 31 de marzo de 1997, se ha aprobado al Colegio &quot;Trewhela&apos;s English School&quot; de Santiago, un plan de estudio para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o (NB.1 y NB.2) de Ense&#xF1;anza B&#xE1;sica, los cuales podr&#xE1;n ser aplicados a partir del a&#xF1;o escolar 1997, de acuerdo al cronograma establecido en el Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996.</div><br></div>", "i": 7206077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de abril de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7206078}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "362 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-362 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 362 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "TREWHELA'S ENGLISH SCHOOL", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "70760", "numero_fuente": "35745", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-19", "vigencias": [{"desde": "1997-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-04-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac