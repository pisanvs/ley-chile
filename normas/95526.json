{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 106, DE 1989</div><br><br><br></div>", "i": 6100205}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 106 de 01.06.89 se ha aprobado, al Colegio Saint Gabriel&apos;s School de Santiago, un plan especial de estudio para ser aplicado, a partir del a&#xF1;o escolar 1989 en los cursos de 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n. Media Human&#xED;stico- Cient&#xED;fica y deroga decreto supremo exento de Educaci&#xF3;n No. 107, de 1983. </div></div>", "i": 6100206}, {"t": "<div><div class=\"p\">Santiago, 20 de Junio de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6100207}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "106 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-106 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 106, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-06-01", "fecha_derogacion": "1992-05-16", "doble_articulado": false, "id_norma": "95526", "numero_fuente": "33410", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-06-30", "vigencias": [{"desde": "1992-05-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-06-30", "hasta": "1992-05-15", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1992-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-30", "fin_vigencia": "1992-05-1