{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6224621}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 365 del 04 de Julio de 1986, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n, se autoriza a Juan Ram&#xF3;n Contador Le&#xF3;n y Jos&#xE9; Ram&#xF3;n Contador Peralta, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6224622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Eliecer Aedo Rivera, Secretario Regional Ministerial de Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6224623}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "365 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-365 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-04", "doble_articulado": false, "id_norma": "152910", "numero_fuente": "32532", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-26", "vigencias": [{"desde": "1986-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-07-26", "fin_vigencia": "", "tipo_version": "3"}