{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.330 EXENTO, DE 2005 </div></div>", "i": 6559530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.330, de fecha 23 de septiembre de 2005, del Ministerio de Educaci&#xF3;n, se aprueba el plan y programas de estudio de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica y se autoriza el funcionamiento del Local que se se&#xF1;ala del Centro de Formaci&#xF3;n T&#xE9;cnica Alfa de Constituci&#xF3;n, a contar de agosto de 2005:</div><br><div class=\"p\">Casa Central - O&apos;Higgins N&#xBA; 678 - Constituci&#xF3;n (clases</div><div class=\"p\">te&#xF3;ricas).</div><div class=\"p\">Local - Cruz N&#xBA; 60 - Constituci&#xF3;n (clases pr&#xE1;cticas).</div><br><div class=\"p\">Carrera&nbsp;  :&nbsp;  Procesos de la Madera.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; :&nbsp;  T&#xE9;cnico de Nivel Superior en Procesos de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  la Madera.</div><br><br></div>", "i": 6559531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de noviembre de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6559532}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1330 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1330 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.330 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-09-23", "fecha_derogacion": "2021-01-01", "doble_articulado": false, "id_norma": "246876", "numero_fuente": "38377", "tipo_version": "2", "tipo_versio