{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 263.-Santiago, a 4 de Febrero de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese por gracia a las hermanas solteras del capitan don Ricardo Soffia, muerto en servicio del pais en la batalla de Huara, el goce de una pensi&#xF3;n que corresponder&#xED;a a la viuda de sargento mayor, segun el art. 11 de la lei de 22 de Diciembre de 1881 i que gozar&#xE1;n en conformidad a la lei de montep&#xED;o militar siempre que por la muerte del citado capitan no hubiere otra asisgnaci&#xF3;n fiscal.</div><br><br></div>", "i": 5947338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-</div><div class=\"p\">C&#xE1;rlos Rivera Jofr&#xE9;.</div><br></div>", "i": 5947339}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "263", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-263"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RICARDO SOFFIA", "HERMANAS SOLTERAS", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-02-04", "doble_articulado": false, "id_norma": "22117", "numero_fuente": "5034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-02-07", "vigencias": [{"desde": "1895-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-02-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-26", "fecha_version": "1895-02-07", "fecha_actualizacion_texto": "1895-02-07", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5947337}, {"n": "Artículo UNICO", "i": 5947338, "t": 6}, {"n": "Promulgación", "i": 5947339}]}