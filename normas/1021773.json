{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISOR ELECTR&#xD3;NICO</div></div>", "i": 9092613}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 197 de 29 de diciembre de 2010, que autoriza a contribuyentes como emisor electr&#xF3;nico.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de documentos tributarios electr&#xF3;nicos al contribuyente RUT 79.706.120-4, a contar del mes de enero de 2011. En la Oficina Virtual del SII en Internet se podr&#xE1; consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2010.</div></div>", "i": 9092614}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "197 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-197 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-29", "doble_articulado": false, "id_norma": "1021773", "numero_fuente": "39850", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-04", "vigencias": [{"desde": "2011-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-01-04", "fin_vigencia": ""}, "vigencias_vers