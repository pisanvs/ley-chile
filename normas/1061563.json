{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE DECLARA &#xC1;REA DE PLAGA QUE INDICA</div></div>", "i": 9436913}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.065, de 17 de abril de 2014, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1050353&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 996</a> de 2013, de esta Subsecretar&#xED;a, que declar&#xF3; &#xE1;reas de plaga y de riesgo de plaga de la especie Didymosphenia geminata, en los sectores de cuerpos de aguas, ampli&#xE1;ndolos a la VIII Regi&#xF3;n, y nuevas cuencas, en la forma que se indica en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl.</div></div>", "i": 9436914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de abril de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9436915}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1065 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1065 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE DECLARA ÁREA DE PLAGA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-04-17", "doble_articulado": false, "id_norma": "1061563", "numero_fuente": "40842", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-04-26", "vigencias": [{"desde": "2014-04-26", "hasta": "", "