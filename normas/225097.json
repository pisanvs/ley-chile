{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A ELIZABETH DEL PILAR GENOVA NUALART </div></div>", "i": 8130298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n DRE09.00 N&#xBA; Ex. 169 de fecha 6 de mayo de 2004, deja sin efecto la resoluci&#xF3;n N&#xBA; Ex. 314 de fecha 09/10/2003 y revoca, a contar de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado del cambio de sujeto en las operaciones de Compra-Venta de Trigo, a Elizabeth del Pilar Genova Nualart, RUT N&#xBA; 7.066.959-5, conforme a lo establecido en el dispositivo N&#xBA;s. 14 y 18 de la resoluci&#xF3;n N&#xBA; 5.281 de 30.11.2000 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 04.12.2000.</div><br></div>", "i": 8130299}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 8130300}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "169 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-169 EXENTA"}, {"tipo": "3", "numero": "DRE-09-00-169 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-09-00-169 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A ELIZABETH DEL PILAR GENOVA NUALART", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-06", "doble_articulado": false, "id_norma": "225097", "numero_fuente": "37860", "tipo_version": "3", "tipo_version_s": "Única", "f