{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 416 EXENTO, DE 2002 </div></div>", "i": 6384863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 416 de 13 de mayo del 2002, se ha aprobado, a la Escuela &quot;San Antonio de Padua&quot; (ex E N&#xBA; 39), de Ollag&#xFC;e, II Regi&#xF3;n de Antofagasta, un plan de estudio biling&#xFC;e para 3&#xBA; y 4&#xBA; a&#xF1;o (NB.2) de Ense&#xF1;anza B&#xE1;sica, el que se empezar&#xE1; a aplicar a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en el presente decreto. </div></div>", "i": 6384864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de junio de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6384865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "416 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-416 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 416 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-13", "doble_articulado": false, "id_norma": "199163", "numero_fuente": "37285", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-17", "vigencias": [{"desde": "2002-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu