{"html": [{"t": "<div><div class=\"p\">DECRETO-LEY NUM. 451</div><br><div class=\"p\">Modifica el decreto-ley N.o 48</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 451.- Santiago, 19 de Agosto de 1932.- He acordado y dicto el siguiente,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto-ley:</div><br></div>", "i": 6581713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Agr&#xE9;gase en el inciso segundo del art&#xED;culo 7.o del decreto-ley n&#xFA;mero 48, modificado por el decreto-ley n&#xFA;mero 271, de 23 de Julio &#xFA;ltimo, despu&#xE9;s de las palabras &quot;y no impugnados&quot;, la frase &quot;por el s&#xED;ndico&quot;.</div><br></div>", "i": 6581714, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- CARLOS DAVILA.- Ernesto Barros.</div><br></div>", "i": 6581715}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "451", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-451"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA EL DECRETO-LEY N.o 48", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-08-19", "doble_articulado": false, "id_norma": "252920", "numero_fuente": "16351", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-08-22", "vigencias": [{"desde": "1932-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-08-22", "fin_vigencia": "", "tipo_version": "