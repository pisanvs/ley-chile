{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 184 EXENTO, DE 1995</div><br><br></div>", "i": 5942469}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 184 de 15 de Marzo de 1995, se aprobaron Planes y Programas Especiales de Estudio para el Liceo C-41 &quot;El Rosario&quot;, de la Comuna de Litueche, Provincia Cardenal Caro, VI Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins, para la Educaci&#xF3;n B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica, los que ser&#xE1;n aplicados a partir del a&#xF1;o escolar 1995.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s se aprueban Programas de Estudio para Educaci&#xF3;n B&#xE1;sica y Media de las asignaturas que se se&#xF1;alan en el presente decreto.</div><br></div>", "i": 5942470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de Marzo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942471}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "184 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-184 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 184 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO C-41 EL ROSARIO", "PROGRAMAS ESTUDIO", "PLANES", "ESTUDIO", "MODIFICACION", "LITUECHE", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-15", "doble_articulado": false, "id_norma": "20592", "numero_fuente": "35135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-04-04", "vigencias": [{"desde": "1995-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_