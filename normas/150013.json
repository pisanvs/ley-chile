{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 78, DE 1987 </div></div>", "i": 6214558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 78, de 21 de abril de 1987 se ha aprobado un programa de estudio especial para la asignatura de Historia Universal y Geograf&#xED;a General para 3&#xB0; v 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cientifica que ser&#xE1; aplicario en el Colegio Marambio de Melipilla en 3er. a&#xF1;o desde 1987 y a contar de 1988 en 4&#xB0; a&#xF1;o.</div><br></div>", "i": 6214559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6214560}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "78 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-78 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 78, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-21", "doble_articulado": false, "id_norma": "150013", "numero_fuente": "32807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-30", "vigencias": [{"desde": "1987-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-12-28", "fecha_version": "1987-06