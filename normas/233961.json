{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6510224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.404, de 29 de noviembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a DEL CENTRO S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en camino Bulnes Concepci&#xF3;n, kil&#xF3;metro 16, Quill&#xF3;n, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco Refrigerado, Congelado, Seco Salado, Conserva, Alga Seca y Deshidratado los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6510225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6510226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3404 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3404 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-29", "doble_articulado": false, "id_norma": "233961", "numero_fuente": "38044", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-24", "vigencias": [{"desde": "2004-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-12-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-12-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci