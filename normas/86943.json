{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 179, DE 1997 </div></div>", "i": 6074712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 179, de 25 de octubre de 1997, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se adjudic&#xF3; a don Carlos Mario Aravena Cuevas, la concesi&#xF3;n para operar hasta el 2 de diciembre de 1998 a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle Carlos Achar&#xE1;n Arce S/N&#xBA;, de la comuna de Paillaco, X Regi&#xF3;n, Rol de Propiedad N&#xBA; 554-5, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.- </div></div>", "i": 6074713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Oscar Silva Ortiz, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6074714}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "179", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-179"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 179, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "REVISION TECNICA", "DECIMA REGION", "CARLOS MARIO ARAVENA CUEVAS", "CONCESION", "PAILLACO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-25", "doble_articulado": false, "id_norma": "86943", "numero_fuente": "35961", "tip