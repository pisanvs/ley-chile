{"html": [{"t": "<div><div class=\"p\">REASUME MANDO DEL ESTADO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de febrero de 2005.- Hoy se decret&#xF3; lo que sigue:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 190.- Visto: Lo dispuesto en los art&#xED;culos 29&#xBA; y 32&#xBA;, N&#xBA; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; Decreto:</div><br><br></div>", "i": 8372495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con ocasi&#xF3;n de mi regreso al pa&#xED;s a contar de esta fecha reasumo el mando del Estado.</div><br></div>", "i": 8372496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- RICARDO LAGOS ESCOBAR, Presidente de la Rep&#xFA;blica.- Francisco Vidal Salinas, Ministro del Interior Subrogante.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda atte. a Ud., Pablo Guti&#xE9;rrez V&#xE1;squez, Subsecretario del Interior Subrogante.</div><br></div>", "i": 8372497}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "190", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-190"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-02-23", "doble_articulado": false, "id_norma": "236379", "numero_fuente": "38112", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-16", "vigencias": [{"desde": "2005-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"