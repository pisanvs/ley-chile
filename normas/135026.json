{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SESION N&#xB0; 747</div><br><br></div>", "i": 6164121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su Sesi&#xF3;n N&#xB0; 747, celebrada el 15 de abril de 1999, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">&nbsp; &nbsp;  747-06-990415 - Modifica Cap&#xED;tulo III.F.4 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; efectuar las siguientes modificaciones en el Cap&#xED;tulo III.F.4 del Compendio de Normas Financieras:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- En la letra p) del N&#xB0; 1, reemplazar el guarismo &apos;&apos;8%&apos;&apos; por &apos;&apos;10%&apos;&apos;.</div><br><div class=\"p\">&nbsp; &nbsp;  2.- En el quinto p&#xE1;rrafo del N&#xB0; 2, reemplazar el guarismo &apos;&apos;8%&apos;&apos; por &apos;&apos;10%&apos;&apos;.</div><br></div>", "i": 6164122}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de abril de 1999.- Miguel Angel Nacrur Gazali, Ministero de Fe.</div><br></div>", "i": 6164123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "747", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-747"}, {"tipo": "5", "numero": "747-06", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-747-06"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE;CHILE EN SESION N° 747", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-15", "doble_articulado": false, "id_norma": "135026", "numero_fuente": "36340", "tipo_