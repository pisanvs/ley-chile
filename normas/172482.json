{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 111, DE 1987 </div></div>", "i": 6287671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 111 de 4 de junio de 1987 se ha aprobado para el Colegio Particular &quot;Orden de San Jorge&quot;, de San Bernardo, Provincia de Maipo, Regi&#xF3;n Metropolitana, planes y programas especiales de estudio para la Educaci&#xF3;n Media, modalidad</div><div class=\"p\">T&#xE9;cnico-Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1987 y hasta el a&#xF1;o escolar de 1992, en las Especialidades de:</div><div class=\"p\">1.- Contabilidad</div><div class=\"p\">2.- Secretariado Administrativo Contable.</div><br></div>", "i": 6287672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6287673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "111 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-111 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 111, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-04", "doble_articulado": false, "id_norma": "172482", "numero_fuente": "32808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-01", "vigencias": [{"desde": "1987-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-01", "