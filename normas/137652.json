{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,663.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 8345626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados al Congreso Nacional por el inspector de la Secci&#xF3;n de Seguridad de la polic&#xED;a de Santiago, don Ignacio Arancibia, se le concede, por gracia, su retiro con una pension vitalicia equivalente a la totalidad del sueldo i gratificaci&#xF3;n de que actualmente disfruta.</div><br></div>", "i": 8345627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, dieciseis de julio de mil novecientos doce.- Ramon Barros Luco.- Guillermo Rivera.</div><br></div>", "i": 8345628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2663", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2663"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-07-16", "doble_articulado": false, "id_norma": "137652", "numero_fuente": "10334", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-07-23", "vigencias": [{"desde": "1912-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-07-23", "fin_vi