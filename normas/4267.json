{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 46.- Santiago, 16 de Mayo de 1931.- Vistas las facultades que me confiere la Ley N.o 4,945, de 6 de Febrero &#xFA;ltimo,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7116269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Agr&#xE9;gase a la Ley N.o 4,885, de 6 de Septiembre de</div><div class=\"p\">1930, el siguiente art&#xED;culo transitorio, que llevar&#xE1;</div><div class=\"p\">N&#xFA;m. 2:</div><div class=\"p\">&nbsp; &nbsp; &quot;La Universidad de Concepci&#xF3;n deducir&#xE1; de los fondos</div><div class=\"p\">que le corresponden, de acuerdo con la letra b) del</div><div class=\"p\">art&#xED;culo 3.&#xB0; de la presente ley, la suma necesaria para completar a la Cruz Roja Chilena una cuota de $ 1.200.000 durante el a&#xF1;o 1931 y de $ 1.000.000 durante los a&#xF1;os 1932 y 1933&quot;.</div><br></div>", "i": 7116270, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- Alberto Edwards.- Carlos Castro Ruiz. </div></div>", "i": 7116271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "46", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-46"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LOTERIA BENEFICENCIA PUBLICA", "UNIVERSIDAD CONCEPCION", "FONDOS", "CRUZ ROJA CHILENA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-16", "doble_articulado": false, "id_norma": "4267", "numero_fuente": "15983", "tipo_version": "3", "tipo_version_s": "Única",