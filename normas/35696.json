{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0;842, de 7 de mayo de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA ARAUCANIA S.A., para iniciar actividades pesqueras extractivas con la nave &quot;Tucano&quot;, en el litoral y respecto de los recursos hidrobiol&#xF3;gicos que m&#xE1;s adelante se se&#xF1;alan.</div><br><div class=\"p\"> _______________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 35.473, JUEVES 23 DE&nbsp; &nbsp; |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  MAYO DE 1996, PAGINA 6.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  |</div><div class=\"p\"> |_____________________________________________________|</div><br><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0;545, de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a V&#xE1;squez y Compa&#xF1;&#xED;a Limitada, R.U.T. 81.352.200-4, para realizar faenas de pesca extractiva con la nave &quot;Tucano&quot;.</div><br></div>", "i": 8294485}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 7 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294486}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "842", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-842"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA ARAUCANIA S.A", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "d