{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8296722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 1.284, de 28 de Diciembre de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, fac&#xFA;ltase a PESCA CHILE S.A., R.U.T. N&#xB0; 95.023.000-2, domiciliada en Santiago, calle Estado N&#xB0; 10, oficina N&#xB0; 801, para reiniciar las actividades pesqueras con la nave denominada &quot;Corfo I&quot;, autorizada mediante resoluci&#xF3;n N&#xB0; 1283, de 1992, dentro del plazo de nueve meses contados desde el 2 de enero de 1992, por haber acreditado fuerza mayor que justifica la paralizaci&#xF3;n de las actividades pesqueras extractivas de esa nave.</div><br></div>", "i": 8296723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de Diciembre de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8296724}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1284", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1284"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESCA CHILE S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-28", "doble_articulado": false, "id_norma": "36633", "numero_fuente": "34465", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-01-14", "vigencias": [{"desde": "1993-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_