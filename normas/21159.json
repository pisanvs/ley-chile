{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 401, DE 1992 </div></div>", "i": 7161789}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 401 de fecha 3 de Diciembre de 1992 del Ministerio de Educaci&#xF3;n, se insertaron en la Resoluci&#xF3;n y Decreto que en cada caso se se&#xF1;ala, del Centro de Formaci&#xF3;n T&#xE9;cnica ICCE las adecuaciones introducidas en las carreras que se indican, las que podr&#xE1;n aplicarse en su sede de la ciudad de Santiago, a contar de Agosto de 1992:</div><div class=\"p\">Carreras: Contabilidad y Auditor&#xED;a (Decreto Exento</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  N&#xB0; 229/90).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Administraci&#xF3;n Bancaria y T&#xE9;cnicas</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Contables (Decreto Exento N&#xB0; 229/90)</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Secretariado Ejecutivo Computacional</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (Resoluci&#xF3;n&nbsp; Exenta N&#xB0; 1082/89).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Secretariado Ejecutivo Biling&#xFC;e y</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Computacional (Resoluci&#xF3;n Exenta N&#xB0;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  1082/89).</div><br></div>", "i": 7161790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7161791}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "401 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-401 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 401, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTR