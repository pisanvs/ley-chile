{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE EMISORES ELECTR&#xD3;NICOS </div></div>", "i": 6931514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 8 de 19 de enero de 2009, que deroga autorizaci&#xF3;n otorgada a contribuyentes para operar como emisores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n del contribuyente RUT N&#xBA; 6.594.056-6, se deroga autorizaci&#xF3;n otorgada para operar como emisor de Documentos Tributarios Electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl)&nbsp;  y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2009.</div><br></div>", "i": 6931515}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACIÓN DE EMISORES ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-19", "doble_articulado": false, "id_norma": "285950", "numero_fuente": "39269", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-01-23", "vigencias": [{"desde": "2009-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-01-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-01-23", "fin_vigen