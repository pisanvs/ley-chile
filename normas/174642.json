{"html": [{"t": "<div><div class=\"p\">Extracto </div></div>", "i": 6297800}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 68, del 14 de julio del a&#xF1;o 2000, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la Cooperativa de Trabajo de Servicios para la Recreaci&#xF3;n y el Esparcimiento Farellones Limitada, de sigla Fallercoop Limitada, de la comuna de Lo Barnechea; en los t&#xE9;rminos que da testimonio el acta constitutiva reducida a escritura p&#xFA;blica otorgada con fecha 20 de junio del a&#xF1;o 2000, ante el Notario de Santiago do&#xF1;a Elena Torres Seguel.</div><br></div>", "i": 6297801}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6297802}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "68", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-68"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "Extracto", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-14", "doble_articulado": false, "id_norma": "174642", "numero_fuente": "36749", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-26", "vigencias": [{"desde": "2000-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-26"