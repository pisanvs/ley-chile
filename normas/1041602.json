{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9272206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.781, de 29 de junio de 2012, de esta Subsecretar&#xED;a, d&#xE9;janse sin efecto las resoluciones exentas N&#xBA; 3.355 de 2003, N&#xBA; 2.298 de 2004, <a href=\"https://www.leychile.cl/Navegar?idNorma=253609&amp;idParte=0&amp;idVersion=\">Nos 1.400</a> y 2.943, ambas de 2006, todas de esta Subsecretar&#xED;a, correspondientes al &#xE1;rea de manejo Punta Lobos, VI Regi&#xF3;n, del SINDICATO DE TRABAJADORES INDEPENDIENTES DE LA PESCA ARTESANAL DE PICHILEMU, en virtud del art&#xED;culo 21 del DS N&#xB0; 355, de 1995, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n y lo dispuesto en la resoluci&#xF3;n extractada, cuyo texto &#xED;ntegro se encuentra publicado en la p&#xE1;gina web www.subpesca.cl.</div><br></div>", "i": 9272207, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de junio de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9272208}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1781 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1781 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-29", "doble_articulado": false, "id_norma": "1041602", "numero_fuente": "40306", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-07", "vigencias": [{"desde": "2012-07-07", "hasta": "", "tipo_version": "3", "tipo_version_