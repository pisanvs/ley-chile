{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6374211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.252, de 31 de diciembre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;17-A, superficie 241 m&#xB2;, rol de aval&#xFA;o 1297-7, comuna de Quilpu&#xE9; para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago-Valpara&#xED;so-Vi&#xF1;a del Mar, Troncal Sur Enlace Quilpu&#xE9; Oriente, Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Eliseo Arancibia Vergara, ascendente a la cantidad de $20.793.271.- </div></div>", "i": 6374212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6374213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2252", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2252"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-31", "doble_articulado": false, "id_norma": "195982", "numero_fuente": "37211", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-15", "vigencias": [{"desde": "2002-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2002-03-26", "fecha_version": "2002-03-15", "fecha_actualizacion_texto": "2002-03-15", "tipo_tratado": ""}, "aler