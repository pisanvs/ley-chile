{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUAS EN COMUNA DE RENCA</div><br><br></div>", "i": 6412365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 3.070, del 10 de octubre de 2002, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, ratific&#xF3;, aclar&#xF3; y complement&#xF3; resoluci&#xF3;n exenta N&#xBA; 2.578, de 7 de octubre de 1980 que aprob&#xF3; el Proyecto de Distribuci&#xF3;n de Agua para atender el riego de las parcelas del Proyecto de Parcelaci&#xF3;n &quot;La Primavera&quot;, de la comuna de Renca, Regi&#xF3;n Metropolitana, en el sentido de establecer la equivalencia que se indica, expresada en unidad de volumen por unidad de tiempo, de los derechos de aprovechamiento de aguas subterr&#xE1;neas que se extraen del pozo profundo 3310-7050 B-11.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13 ley N&#xBA; 18.377.-</div><br></div>", "i": 6412366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div><br></div>", "i": 6412367}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3070 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3070 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUAS EN COMUNA DE RENCA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-10", "doble_articulado": false, "id_norma": "207242", "numero_fuente": "37474", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-02-0