{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7160638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 120 de 18 de marzo de 1994 se ha modificado el art&#xED;culo 1&#xB0; del decreto supremo exento de Educaci&#xF3;n N&#xB0; 454 de 1993 que aprueba un plan especial de estudio al Colegio &quot;Nido de Aguilas&quot; de Santiago, en cuanto a que el plan electivo del plan de estudio para 3&#xB0; y 4&#xB0; a&#xF1;o medio tendr&#xE1; una carga horaria de 10 clases semanales, conformado por dos asignaturas con una carga horaria de 5 clases semanales cada una.</div><br></div>", "i": 7160639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 4 de Abril de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160640}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "120 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-120 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO NIDO AGUILAS", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-18", "doble_articulado": false, "id_norma": "20271", "numero_fuente": "34838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-13", "vigencias": [{"desde": "1994-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-04-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION",