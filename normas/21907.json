{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension Lei n&#xFA;m 34.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 7162431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese por gracia a las hermanas solteras del teniente de la Armada Nacional, muerto en servicio del pais, don Jorje Pacheco, el goce de la pension que se&#xF1;ala la lei de 22 de Diciembre de 1881 para la viuda e hijos lej&#xED;timos de un capitan de corbeta muerto en accion de guerra.</div><br><br></div>", "i": 7162432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 4 de Febrero de 1893.- JORJE MONTT.- Francisco A. Pinto.</div><br></div>", "i": 7162433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "34", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-34"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MONTEPIO MILITAR", "JORJE PACHECO", "HERMANAS SOLTERAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-02-04", "doble_articulado": false, "id_norma": "21907", "numero_fuente": "4448", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-02-15", "vigencias": [{"desde": "1893-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-02-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-02-15", "f