{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA; 164 EXENTA, DE 2008 </div></div>", "i": 7370425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que, por resoluci&#xF3;n exenta N&#xBA; 287 de fecha 29 de abril de 2008, de esta Superintendencia de Valores y Seguros, se rectific&#xF3; la resoluci&#xF3;n exenta N&#xBA; 164 de 24 de marzo de 2008, que aprob&#xF3; la reforma de estatutos de &quot;BCI Administradora de Fondos Mutuos S.A.&quot; hoy &quot;BCI Asset Management Administradora General de Fondos S.A.&quot;, en el sentido que la cita a la escritura p&#xFA;blica extendida ante don Ra&#xFA;l Iv&#xE1;n Perry Pefaur, titular de la 21&#xAA; Notar&#xED;a de Santiago, es de fecha 10 de enero de 2008 y no 16 de enero de 2008, como err&#xF3;neamente se indic&#xF3;.</div><br></div>", "i": 7370426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de abril de 2008.- Carmen Undurraga Mart&#xED;nez, Secretario General.</div><br></div>", "i": 7370427}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "287 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-287 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº 164 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-29", "doble_articulado": false, "id_norma": "271365", "numero_fuente": "39067", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-22", "vigencias": [{"desde": "2008-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-05-22", "fin