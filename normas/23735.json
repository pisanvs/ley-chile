{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Modifica la glosa del &#xED;tem 3,482 del Presupuesto del Interior del a&#xF1;o 1916</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,099.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275939}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Modif&#xED;case la glosa del &#xED;tem 3,482, partida 25, del Presupuesto del Interior, reemplazando en ella la palabra &quot;Huara&quot; por la de &quot;Pozo Almonte.&quot; </div></div>", "i": 8275940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 30 de Junio de 1916.- JUAN LUIS SANFUENTES.- Luis Izquierdo.</div><br></div>", "i": 8275941}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3099", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3099"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA GLOSA DEL ITEM 3.482 DEL PRESUPUESTO DEL INTERIOR DEL AÑO 1916", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL DE LA NACION", "1916", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-06-30", "doble_articulado": false, "id_norma": "23735", "numero_fuente": "11588", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-10-03", "vigencias": [{"desde": "1916-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia