{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA SUBSECRETARIO DE BIENES NACIONALES N&#xFA;m. 154.- Santiago, 6 de abril de 1993.- Vistos: Lo dispuesto por el art&#xED;culo 32 N&#xB0; 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 8259424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: Des&#xED;gnase a contar del 12 de abril de 1993, a don Eduardo Jorge Jara Miranda (RUN.</div><div class=\"p\">3.087.577-K), Abogado, en el cargo de Subsecretario de Bienes Nacionales, quien por razones impostergables de buen servicio, deber&#xE1; asumir de inmediato sus funciones. </div></div>", "i": 8259425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, reg&#xED;strese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese, PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Luis Alvarado Constenla, Ministro de Bienes Nacionales.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud.- Eduardo Silva Villal&#xF3;n, Subsecretario de Bienes Nacionales Subrogante.</div><br></div>", "i": 8259426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "154", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-154"}], "organismos": ["MINISTERIO DE BIENES NACIONALES"], "titulo_norma": "DESIGNA SUBSECRETARIO DE BIENES NACIONALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EDUARDO JORGE JARA MIRANDA", "SUBSECRETARIO", "NOMBRAMIENTO", "MINISTERIO BIENES NACIONALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-04-06", "doble_articulado": false, "id_norma": "10155", "numero_fuente": "34556", "tipo_version": "3", "tipo_version_s": "Única"