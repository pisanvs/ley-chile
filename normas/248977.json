{"html": [{"t": "<div><div class=\"p\">AUTORIZA RECEPTOR ELECTRONICO </div></div>", "i": 6567097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 40, de 11-04-2006, que autoriza a organismo p&#xFA;blico como receptor electr&#xF3;nico. Se autoriza como receptor de documentos tributarios electr&#xF3;nicos, a contar del mes de abril de 2006, a organismo p&#xFA;blico RUT 69.070.300-9.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril de 2006.</div><br></div>", "i": 6567098}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "40 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-40 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA RECEPTOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ORGANISMOS PUBLICOS", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS", "RECEPTORES ELECTRONICOS", "PROCEDIMIENTOS DE OPERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-11", "doble_articulado": false, "id_norma": "248977", "numero_fuente": "38441", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-18", "vigencias": [{"desde": "2006-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-04-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-04-18", "fin_vigencia": "", "