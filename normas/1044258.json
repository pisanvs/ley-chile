{"html": [{"t": "<div><br><div class=\"p\">ORDENAN EXPROPIACIONES QUE INDICAN</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9299244}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 753, de fecha 7 de septiembre de 2012, del Serviu IV Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiar, conforme al art&#xED;culo 51 ley 16.391 y DL 2.186/78, el inmueble denominado Lote 2 de superficie aproximada de 282,90 m&#xB2;, Rol N&#xBA; 36-008, de aparente dominio de Francisco Enrique Godoy Esquivel y Otros; ubicado en calle Varela N&#xBA; 1677, comuna de Coquimbo. Comisi&#xF3;n de Peritos conformada por profesionales Marcia Aqueveque Mart&#xED;nez, Juan Manuel Gantes Mel&#xE9;ndez y Miguel Rubio Vega, seg&#xFA;n informe de 5 de junio de 2012, fij&#xF3; indemnizaci&#xF3;n provisional en $73.506.838.- pagadero al contado.- </div></div>", "i": 9299245}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu IV Regi&#xF3;n Coquimbo.</div></div>", "i": 9299246}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "753", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-753"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN IV REGIÓN DE COQUIMBO"], "titulo_norma": "ORDENAN EXPROPIACIONES QUE INDICAN; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-07", "doble_articulado": false, "id_norma": "1044258", "numero_fuente": "40374", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-01", "vigencias": [{"desde": "2012-10-01", "hasta": "", "tipo_version": "3", "tipo_ver