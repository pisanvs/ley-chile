{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 9334371}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 40.488, de 18 de febrero de 2013, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1048896&amp;idParte=&amp;idVersion=\">decreto n&#xFA;mero 31, de fecha 18/01/2013</a>, MODIFICA DECRETO N&#xBA; 80, DE 1983, EN EL SENTIDO DE AMPLIAR MONUMENTO HIST&#xD3;RICO &quot;ACUEDUCTO DE AMOLANAS&quot;, UBICADO EN LA COMUNA DE TIERRA AMARILLA, PROVINCIA DE COPIAP&#xD3;, REGI&#xD3;N DE ATACAMA, con el error que se salva a continuaci&#xF3;n: Cuerpo I, p&#xE1;gina dos, primera columna, primer p&#xE1;rrafo, donde dice &quot;... N&#xFA;m. 41.- Santiago, 18 de enero de 2013 ...&quot; debe decir: &quot;... N&#xFA;m. 31.- Santiago, 18 de enero de 2013 ...&quot;.</div><br></div>", "i": 9334372, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "241", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-241"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1048988", "numero_fuente": "40491", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-21", "vigencias": [{"desde": "2013-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-02-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-02-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part":