{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISOR DE BOLETA ELECTR&#xD3;NICA</div></div>", "i": 8846024}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 8 de 12 de enero de 2010, que autoriza a contribuyente como emisor de boleta electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boleta electr&#xF3;nica a contribuyente RUT 90.635.000-9, a contar del mes de enero de 2010. En la Oficina Virtual del SII en internet se podr&#xE1;n consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2010.</div></div>", "i": 8846025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR DE BOLETA ELECTRÓNICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-01-12", "doble_articulado": false, "id_norma": "1010263", "numero_fuente": "39562", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-01-16", "vigencias": [{"desde": "2010-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-01-16", "fin_vigencia": ""}, "vigencias_versio