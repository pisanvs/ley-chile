{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 434 EXENTO, DE 1999</div><br><br></div>", "i": 6222275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 434, de</div><div class=\"p\">27 de diciembre de 1999, se ha aprobado un plan de</div><div class=\"p\">estudio para 1&#xBA; a 4&#xBA; a&#xF1;o (NB.1 y NB.2) de ense&#xF1;anza</div><div class=\"p\">b&#xE1;sica, a la Escuela Especial N&#xBA; 1139 &apos;&apos;Dr. Jorge Otte</div><div class=\"p\">Gabler&apos;&apos;, para ni&#xF1;os y j&#xF3;venes sordos, Regi&#xF3;n</div><div class=\"p\">Metropolitana.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los</div><div class=\"p\">subsectores de lenguaje y comunicaci&#xF3;n y educaci&#xF3;n</div><div class=\"p\">art&#xED;stica.</div><br></div>", "i": 6222276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de diciembre de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6222277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "434 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-434 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 434 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-27", "doble_articulado": false, "id_norma": "152156", "numero_fuente": "36571", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-25", "vigencias": [{"desde": "2000-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-25", "fin_