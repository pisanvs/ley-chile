{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7268102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 131, de Febrero 8 de 1985, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza a la Sociedad Ferre y Grau Limitada (Chile Bus Ltda.), para efectuar servicio internacional de transporte terrestre de pasajeros entre las ciudades de Santiago (Chile) y R&#xED;o de Janeiro (Brasil), por Pasos Caracoles (T&#xFA;nel del Cristo Redentor) - De los Libres - Uruguayana, efectuando cuatro frecuencias semanales.</div><div class=\"p\">&nbsp; &nbsp;  La empresa antes se&#xF1;alada podr&#xE1; utilizar el Paso Puyehue como alternativa, cuando las condiciones clim&#xE1;ticas impidan el tr&#xE1;nsito por Caracoles.-</div><br></div>", "i": 7268103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Y&#xE1;var Martin, Coronel de Ej&#xE9;rcito, Subsecretario de Transportes.</div><br></div>", "i": 7268104}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "131 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-131 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-08", "doble_articulado": false, "id_norma": "166496", "numero_fuente": "32100", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-18", "vigencias": [{"desde": "1985-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-