{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6355906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.257, de 24 de octubre de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA LOS FIORDOS LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, con una planta ubicada en Camino San Antonio s/n, Quell&#xF3;n, X Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n: Cocido, Fresco-Enfriado, Fresco-Refrigerado, Congelado, Seco-Salado, Ahumado, los siguientes recursos hidrobiol&#xF3;gicos: Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n plateado y Trucha arcoiris. </div></div>", "i": 6355907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de octubre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6355908}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2257", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2257"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-24", "doble_articulado": false, "id_norma": "191306", "numero_fuente": "37104", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-07", "vigencias": [{"desde": "2001-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "C