{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 149 EXENTO, DE 1996 </div></div>", "i": 5941950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 149 de fecha 14 de Marzo de 1996 del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobado a la Universidad de Arte, Ciencias y Comunicaci&#xF3;n, UNIACC, inscrita en el Registro de Universidades bajo el Folio C-N&#xB0; 29 de 1989, el Programa de Licenciatura en Arte conducente al grado acad&#xE9;mico de Licenciado en Arte, para impartirse en su Sede de Santiago, de conformidad al acuerdo adoptado por el Consejo Superior de Educaci&#xF3;n, quien llevar&#xE1; a afecto la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 5941951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 01 de abril de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5941952}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "149 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-149 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 149 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD ARTE CIENCIAS COMUNICACION", "LICENCIATURA ARTE", "PLANES ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-14", "doble_articulado": false, "id_norma": "20428", "numero_fuente": "35461", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-08", "vigencias": [{"desde": "1996-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-05-08", "fin_vigencia": ""}, "vigencias_version_