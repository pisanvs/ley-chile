{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div><br></div>", "i": 6389620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 11 de fecha 26 de Enero de 1989 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la Asociaci&#xF3;n Gremial de Funcionarios No Acad&#xE9;micos Universitarios de Arica, inscrita bajo el N&#xB0; 106-1, del Registro que lleva este Ministerio, por haberse configurado respecto de ella la causal de cancelaci&#xF3;n contemplada en el articulo 18 N&#xB0; 2 letra a) del DL N&#xB0; 2757 de 1979.-</div><br></div>", "i": 6389621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ximena del Pozo Parada, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subrogante.</div><br></div>", "i": 6389622}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-01-26", "doble_articulado": false, "id_norma": "200685", "numero_fuente": "33304", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-21", "vigencias": [{"desde": "1989-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-21", "fin_vigencia": "", "tipo_ver