{"html": [{"t": "<div><div class=\"p\">FUERZA DEL EJ&#xC9;RCITO</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 8 de 1825.</div></div>", "i": 10237757}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Sin perjuicio de lo resuelto en 13 de Enero &#xFA;ltimo sobre la fuerza de que debe constar cada Batallon, se mantendr&#xE1;n todos los cuerpos veteranos de Ej&#xE9;rcito, asi de infanter&#xED;a como de caballer&#xED;a en el pi&#xE9; de fuerza que actualmente tienen, hasta tanto la Representacion Nacional, pr&#xF3;xima a reunirse, determine la fuerza veterana permanente que debe constituir el Ej&#xE9;rcito. </div></div>", "i": 10237758}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese a quien corresponda e impr&#xED;mase en el Boletin. </div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Muxica.</div></div>", "i": 10237759}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE GUERRA Y MARINA"], "titulo_norma": "FUERZA DEL EJÉRCITO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-07-08", "doble_articulado": false, "id_norma": "1158382", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-07-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr