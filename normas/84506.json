{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8316321}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 28 de fecha 02 de Febrero de 1990 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la Asociaci&#xF3;n Gremial de Comerciantes Mayoristas Minoristas Productores y Proveedores Agropecuarios de Antofagasta Segunda Regi&#xF3;n, inscrita bajo el n&#xFA;mero 402 del Registro que lleva esta Secretar&#xED;a de Estado por haberse configurado respecto de ella la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18 No. 2 letra A) del DL 2.757.-</div><br></div>", "i": 8316322}, {"t": "<div><div class=\"p\">Norman Bull de la Jara, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8316323}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "28", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-28"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-02-02", "doble_articulado": false, "id_norma": "84506", "numero_fuente": "33618", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-12", "vigencias": [{"desde": "1990-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fech