{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6125761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. No. 872, de 30 de junio de 1998, se expropiaron los lotes de terreno No. s. 1 y 2, superficies 3.893 y 922,50 m&#xB2;, roles de aval&#xFA;o 247-197 y 247-1, comuna de Salamanca, para la obra Camino Acceso a La Maroma, Puente La Maroma y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Rodolfo del Tr&#xE1;nsito Z&#xFA;&#xF1;iga Soto y Jorge Enrique Cepeda Vicencio, ascendente a la cantidad de $ 4.495.709, para el lote No. 1 y $ 1.857.493, para el lote No. 2.</div><br></div>", "i": 6125762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6125763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "872", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-872"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SALAMANCA", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-30", "doble_articulado": false, "id_norma": "123162", "numero_fuente": "36141", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-17", "vigencias": [{"desde": "1998-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-08-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1998-08-19", "fecha_version": "1998-08