{"html": [{"t": "<div><div class=\"p\">RECTIFICACION DEL ANEXO DE RESOLUCION N&#xBA; 7 DE 2000 </div><br></div>", "i": 7263449}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En la tercera l&#xED;nea del segundo p&#xE1;rrafo del Anexo donde dice: &apos;&apos;p * V(ICMO)feb2000&apos;&apos;, debe decir:</div><br><div class=\"p\">&apos;&apos;0,303 * V(ICMO)feb2000&apos;&apos;.</div><br><div class=\"p\">Asimismo, en la f&#xF3;rmula que se encuentra al final del Anexo, donde dice: &apos;&apos;p * V(ICMO)feb2000&apos;&apos;, debe decir:</div><br><div class=\"p\">&apos;&apos;0,303 * V(ICMO)feb2000&apos;&apos;.</div><br></div>", "i": 7263450}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos G&#xE1;rate S&#xE1;nchez, Subsecretario de Transportes (S).</div><br></div>", "i": 7263451}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "RECTIFICACION DEL ANEXO DE RESOLUCION Nº 7 DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["ESTA NORMA NO TIENE FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "158826", "numero_fuente": "36594", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-21", "vigencias": [{"desde": "2000-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-02-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-02-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modifica