{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7358061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.921, de 9 de octubre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a INVERSIONES E INMOBILIARIA CORONEL LIMITADA, para iniciar actividades pesqueras transformaci&#xF3;n, para operar planta ubicada calle B, sitio 8, Manzana D, Parque Industrial, Coronel, para elaborar en l&#xED;neas proceso Cocido, Fresco-Enfriado, Fresco-Refrigerado, Congelado, Seco Salado, Ahumado, Conserva y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">D&#xE9;jase sin efecto resoluci&#xF3;n N&#xBA; 1211-2002, Subpesca, en virtud de la presente resoluci&#xF3;n.</div><br></div>", "i": 7358062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de octubre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7358063}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2921 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2921 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-09", "doble_articulado": false, "id_norma": "266407", "numero_fuente": "38910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-11-13", "vigencias": [{"desde": "2007-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-11-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"in