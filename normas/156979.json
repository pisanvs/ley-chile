{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 346, DE 1985</div><br><br></div>", "i": 6237274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 346 de 13 de Diciembre de 1985, se han aprobado planos especiales de estudio de Educaci&#xF3;n Media Modalidad T&#xE9;cnico Profesional a las Escuelas Agr&#xED;colas Salesianas del Trabajo, para aplicarse gradualmente a partir del a&#xF1;o escolar de 1986.</div><div class=\"p\">&nbsp; &nbsp;  La evaluaci&#xF3;n de los alumnos se regir&#xE1; por las normas vigentes con las adecuaciones que se indican.</div><div class=\"p\">&nbsp; &nbsp;  El proceso de titulaci&#xF3;n de los alumnos se regir&#xE1; por las disposiciones del Decreto Exento de Educaci&#xF3;n N&#xB0; 231, de 1982.</div><br></div>", "i": 6237275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Diciembre de 1985.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6237276}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "346 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-346 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 346, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-13", "doble_articulado": false, "id_norma": "156979", "numero_fuente": "32368", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-10", "vigencias": [{"desde": "1986-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "19