{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6387363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 2,14% anual durante el mes de junio de 2002.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de junio de 2002, fue de 1,94% anual. </div></div>", "i": 6387364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1&#xBA; de julio de 2002.- Jorge Carrasco V&#xE1;squez, Ministro de Fe Subrogante.</div><br></div>", "i": 6387365}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-07-01", "doble_articulado": false, "id_norma": "199967", "numero_fuente": "37298", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-03", "vigencias": [{"desde": "2002-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado