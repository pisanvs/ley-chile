{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,877.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6175310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se aumenta, por gracia, a la cantidad de tres mil pesos ($ 3,000) la pensi&#xF3;n anual que percibe la viuda e hija del contralmirante de la Armada, don&nbsp; Javier Molina, las cuales disfrutar&#xE1;n de esta nueva pensi&#xF3;n con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6175311}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a ocho de febrero de mil novecientos catorce.- Ramon Barros Luco.- Ramon Corbalan Melgarejo. </div></div>", "i": 6175312}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2877", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2877"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-02-08", "doble_articulado": false, "id_norma": "138423", "numero_fuente": "10801", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-02-17", "vigencias": [{"desde": "1914-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1914-02-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen