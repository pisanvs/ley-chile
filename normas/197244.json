{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 44 EXENTO, DE 2002</div><br><br></div>", "i": 6378571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 44 de fecha 18 de enero de 2002 del Ministerio de Educaci&#xF3;n, se autoriza la sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura Cidec, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 2002.</div><br><div class=\"p\">Sede N&#xBA;13 - Punta Arenas</div><br><div class=\"p\">Carrera&nbsp; : T&#xE9;cnico Tributario</div><div class=\"p\">T&#xED;tulo&nbsp;  : T&#xE9;cnico Tributario de Nivel Superior</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Decreto exento N&#xBA;107 de 21.03.01)</div><br></div>", "i": 6378572}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de abril de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6378573}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "44 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-44 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 44 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-18", "doble_articulado": false, "id_norma": "197244", "numero_fuente": "37243", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-25", "vigencias": [{"desde": "2002-04-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenci