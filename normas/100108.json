{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 729, de 25 de mayo de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 287, de 1980, de esta Subsecretar&#xED;a, que autoriz&#xF3; a CONSERVAS CASTILLO LIMITADA, para instalar y operar el centro de cultivo ubicado en Laguna de Puerto Saavedra, en la desembocadura del R&#xED;o Imperial, comuna de Saavedra, provincia de Caut&#xED;n, IX Regi&#xF3;n, por haberse caducado la respectiva resoluci&#xF3;n de concesi&#xF3;n de acuicultura. </div></div>", "i": 8330579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "729", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-729"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "SAAVEDRA", "CONSERVAS CASTILLO LIMITADA", "NOVENA REGION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-25", "doble_articulado": false, "id_norma": "100108", "numero_fuente": "36080", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-03", "vigencias": [{"desde": "1998-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi