{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9228530}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;85, de 12 de enero de 2012, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1035849&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.536 de 2011</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESCA CHILE S.A. para realizar operaciones pesqueras de conformidad con lo dispuesto en el art&#xED;culo 12 Transitorio de la ley N&#xBA; 18.892, en el sentido de excluir a la nave f&#xE1;brica &quot;Chomapi Maru&quot;, e incorporar a la nave f&#xE1;brica denominada &quot;Puerto Toro&quot;, la que podr&#xE1; operar en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 44&#xBA;30&apos; L.S. y 57&#xBA; L.S., en aguas exteriores, respecto de los recursos y con las obligaciones establecidas en la resoluci&#xF3;n exenta N&#xBA;84, de 2012, de esta Subsecretar&#xED;a.</div></div>", "i": 9228531}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de enero de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9228532}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-85 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-12", "doble_articulado": false, "id_norma": "1036574", "numero_fuente": "40165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-0