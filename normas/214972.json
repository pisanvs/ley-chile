{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6440738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.938, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 2.402, de 1999, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA EL GOLFO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Lonconao&quot;, en el sentido de incorporar a esta &#xFA;ltima las siguientes caracter&#xED;sticas n&#xE1;uticas:</div><br><div class=\"p\">Potencia principal&nbsp; &nbsp; &nbsp; &nbsp; 565 Hp</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp;  29,00 Hp</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 7,65 m.</div><br></div>", "i": 6440739}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6440740}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1938 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1938 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-08-21", "fecha_derogacion": "2005-07-13", "doble_articulado": false, "id_norma": "214972", "numero_fuente": "37666", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-09-23", "vigencias": [{"desde": "2005-07-13", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-09-23", "has