{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6062844}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n exenta No. 133 de 20.02.90, se adjudica a A. Denham y C&#xED;a. Ltda., la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar del 05 de Marzo de 1990, un establecimiento ubicado en calle Toro Mazotte No. 0175, Estaci&#xF3;n Central, destinado a la Revisi&#xF3;n T&#xE9;cnica y Verificaci&#xF3;n de Emisi&#xF3;n de Contaminantes de Autom&#xF3;viles, Station Wagons, Motocicletas, Veh&#xED;culos de carga de menos de 1.750 Kg., de capacidad de carga &#xFA;til y sus remolques ubicadas en la Regi&#xF3;n Metropolitana, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.- </div></div>", "i": 6062845}, {"t": "<div><div class=\"p\">Carlos Silva Echibum, Ministro de Transportes y Telecomunicaciones.</div><br></div>", "i": 6062846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "133 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-133 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-02-20", "doble_articulado": false, "id_norma": "82660", "numero_fuente": "33721", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-07-17", "vigencias": [{"desde": "1990-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-07-17", "fin_vigencia": "