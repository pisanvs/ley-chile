{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 106, DE 1988 </div></div>", "i": 6154947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 106 de 3 de junio de 1988, se ha aprobado a la Escuela Diferencial F No. 837 de Maip&#xFA;, Regi&#xF3;n Metropolitana, dependiente de la Corporaci&#xF3;n Municipal de Servicios y Desarrollo de Maip&#xFA;, un plan y programa especial de estudio de orientaci&#xF3;n laboral para alumnos discapacitados, que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de 4 a&#xF1;os, a contar desde 1989.</div><br></div>", "i": 6154948}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de Junio de 1988.-&nbsp; Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6154949}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "106 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-106 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 106, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-03", "doble_articulado": false, "id_norma": "131963", "numero_fuente": "33104", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-24", "vigencias": [{"desde": "1988-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_in