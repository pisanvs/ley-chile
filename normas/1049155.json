{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9335501}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 405, de 12 de febrero de 2013, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CHILE S.A. para ampliar actividades pesqueras extractivas con la nave en construcci&#xF3;n &quot;BEC N&#xBA; 4333-05&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 41&#xBA;28,6&apos; LS y 47&#xBA; LS, por fuera de las l&#xED;neas de base recta, con palangre, sobre los siguientes recursos hidrobiol&#xF3;gicos: Br&#xF3;tula, Cojinoba moteada, Cojinoba del sur, Chancharro, Raya Zearaja spp., Raya Dipturus spp., Raya Psammobatis spp., Tollo y Calamar.</div></div>", "i": 9335502}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de febrero de 2013.- Maximiliano Alarma Carrasco, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9335503}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "405 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-405 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-02-12", "fecha_derogacion": "2014-10-28", "doble_articulado": false, "id_norma": "1049155", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-02-28", "vigencias": [{"desde": "2014-10-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2013-02-28", "hasta": "2014-10-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigen