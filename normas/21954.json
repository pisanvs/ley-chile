{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 85.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de diez i seis mil pesos al &#xED;tem 7 de la partida 5.a del presupuesto del Ministerio de Relaciones Esteriores.</div><br><br></div>", "i": 5946713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 28 de Agosto de 1893.- JORJE MONTT.- V. Blanco.</div><br></div>", "i": 5946714}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "85", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-85"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1893", "MODIFICACION", "MINISTERIO", "RELACIONES EXTERIORES", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-28", "doble_articulado": false, "id_norma": "21954", "numero_fuente": "4607", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-29", "vigencias": [{"desde": "1893-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente