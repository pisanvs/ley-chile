{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 909 EXENTO, DE 1998</div><br><br><br></div>", "i": 6134200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 909, de 23 de septiembre de 1998, se ha autorizado al Colegio &apos;&apos;Mano Amiga&apos;&apos; de Recoleta, Regi&#xF3;n Metropolitana, para suprimir la asignatura de Franc&#xE9;s en los cursos de 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, a partir del a&#xF1;o escolar 1998 y hasta el a&#xF1;o 2000 y 2001, respectivamente, reemplaz&#xE1;ndola por la asignatura de Computaci&#xF3;n, con dos horas de clases semanales y con una evaluaci&#xF3;n que incidir&#xE1; en la promoci&#xF3;n de los alumnos.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de computaci&#xF3;n para los cursos de 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica.- </div></div>", "i": 6134201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de octubre de 1998. Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6134202}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "909 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-909 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 909 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO MANO AMIGA", "RECOLETA", "REGION METROPOLITANA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-09-23", "doble_articulado": false, "id_norma": "125622", "numero_fuente": "36183", "tipo_version": "3", "tipo_version_s": "Única",