{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 339, DE 1999</div><br><br></div>", "i": 6192857}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 339, del 20 de agosto de 1999, que aprueba el Convenio de fecha 22 de febrero de 1999, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Concepci&#xF3;n que rectifica el Convenio de Traspaso de la Escuela B&#xE1;sica F N&#xBA; 588 de Concepci&#xF3;n, traspasada a dicha corporaci&#xF3;n, por Convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 2.038 de 20 de abril de 1981.</div><br></div>", "i": 6192858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de septiembre de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6192859}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "339", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-339"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 339, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-20", "doble_articulado": false, "id_norma": "143992", "numero_fuente": "36471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-23", "vigencias": [{"desde": "1999-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-09-23", "fecha_vers