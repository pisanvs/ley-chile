{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 95, DE 1985 </div></div>", "i": 6239503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 95, de 14 de Junio de 1985, se ha derogado el decreto supremo exento de Educaci&#xF3;n No. 141, de 1982, que autorizara al Colegio &quot;Padre A. Hurtado&quot; de Chill&#xE1;n para aplicar el decreto supremo exento de Educaci&#xF3;n No. 300 de 1981 con adecuaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, se declara que a contar del presente a&#xF1;o escolar el establecimiento mencionado, aplicar&#xE1; el plan y los programas de estudio vigentes para los establecimientos estatales diurnos de Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica.-</div><br></div>", "i": 6239504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6239505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "95 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-95 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 95, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-14", "doble_articulado": false, "id_norma": "157772", "numero_fuente": "32216", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-08", "vigencias": [{"desde": "1985-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig