{"html": [{"t": "<div><div class=\"p\">ADUANAS.</div><br><div class=\"p\">&nbsp; &nbsp;  A S.E. EL PRESIDENTE DE LA RE&#xDA;BLICA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 18 de 1832.</div><div class=\"p\">&nbsp; &nbsp;  El Congreso nacional ha sancionado el siguiente decreto:</div></div>", "i": 10255863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico. Se faculta al Poder ejecutivo para invertir en la compra o construccion de edificios capaces y adecuados para establecer las aduanas en los puertos de Talcahuano y Copiap&#xF3;, la cantidad que fuese necesaria.</div><br></div>", "i": 10255864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Dios guarde a V.E.-JOSE GABRIEL TOCORNAL- Ventura Marin, Pro Secretario.</div><br><div class=\"p\">&nbsp; &nbsp;  C&#xFA;mplase, t&#xF3;mese razon donde corresponda y arch&#xED;vese.</div><div class=\"p\">&nbsp; &nbsp;  PRIETO.&nbsp; &nbsp;  Manuel Rengifo.</div></div>", "i": 10255865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "ADUANAS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-10-18", "doble_articulado": false, "id_norma": "1161725", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-10-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v