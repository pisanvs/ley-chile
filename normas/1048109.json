{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9327669}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA;3246 de 27 de diciembre de 2012, de conformidad lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;23-A, superficie 224 m2, rol de Aval&#xFA;o N&#xBA;158-43, comuna de Cocham&#xF3;, para la obra &quot;CAMINO PUELO PASO EL BOLSON, SECTOR LAGO TAGUA &#x2013; TAGUA &#x2013; LLANADA GRANDE, TRAMO KM. 12,530 AL KM. 32,500&quot;. La Comisi&#xF3;n de peritos, integrada por JUAN CELESTINO GIOVANNINI MANSILLA, LEOPOLDO RAM&#xD3;N SCHUMACHER GUARDA Y ENRIQUE HOELCK ALTMANN, fij&#xF3; el valor de tasaci&#xF3;n con fecha 8 de febrero de 2007, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JOS&#xC9; SELSO TELLEZ GUERRERO, en la cantidad de $377.761.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9327670}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9327671}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3246 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3246 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-27", "doble_articulado": false, "id_norma": "1048109", "numero_fuente": "40459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-15", "vigencias": [{"desde": "2013-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-01-15", "fin_vigenc