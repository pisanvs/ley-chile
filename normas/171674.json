{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO FIJADO EN EL ARTICULO 4&#xBA; DE LA RESOLUCION N&#xBA; 125, DE 1987</div><br><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2.- Santiago, 12 de Enero de 1988.- Visto: La Ley 18.059, la Ley 18.290 el DFL 279/60, el DS 163/84 y la resoluci&#xF3;n N&#xBA; 125/87, ambos del Ministerio de Transportes y Telecomunicaciones,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7271367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Prorr&#xF3;gase en 19 d&#xED;as el plazo fijado en el</div><div class=\"p\">art&#xED;culo 4&#xBA; de la resoluci&#xF3;n N&#xBA; 125, de 17 de noviembre de 1987.</div><br></div>", "i": 7271368}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- Gustavo Arenas Corral, Coronel, Ministro de Transportes y Telecomunicaciones subrogante.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 7271369}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "PRORROGA PLAZO FIJADO EN EL ARTICULO 4º DE LA RESOLUCION Nº 125, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-12", "doble_articulado": false, "id_norma": "171674", "numero_fuente": "32970", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-15", "vigencias": [{"desde": "1988-