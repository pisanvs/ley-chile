{"html": [{"t": "<div><div class=\"p\">ORDENA&nbsp; EXPROPIACION&nbsp; DE&nbsp; INMUEBLES</div><br></div>", "i": 6156843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 132 de 31 de agosto de 1998, de Serviu Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiaci&#xF3;n, conforme Art. 51&nbsp; ley 16.391 y D.L. 2.186 de 1978, de parte del inmueble ubicado en calle Amun&#xE1;tegui N&#xBA; 223 presunto rol aval&#xFA;o 95-2 comuna La Serena, aparentemente dominio de do&#xF1;a Carmen Hern&#xE1;ndez, de una superficie aproximada de 96,00 metros cuadrados. Comisi&#xF3;n Peritos integrada por don Patricio Mena L&#xF3;pez, Alfredo Prieto Parra y do&#xF1;a Iris Marcich Moller, arquitectos, seg&#xFA;n informe de 30 de junio de 1998, fij&#xF3; monto provisional indemnizaci&#xF3;n en $11.161.702 pagadera al contado. </div></div>", "i": 6156844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Coquimbo.</div><br></div>", "i": 6156845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "132", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-132"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN IV REGIÓN DE COQUIMBO"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-31", "doble_articulado": false, "id_norma": "132672", "numero_fuente": "36302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-01", "vigencias": [{"desde": "1999-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-01", "fin_vigencia