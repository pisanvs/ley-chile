{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 137 EXENTO, DE 1995 </div></div>", "i": 7160742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 137, de 24 de febrero de 1995, se ha modificado el decreto supremo exento de Educaci&#xF3;n N&#xB0; 573, de 1993, que aprob&#xF3; un plan de estudio especial al Colegio Internacional SEK.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas de Ciencias y Arte y Dise&#xF1;o.</div><br></div>", "i": 7160743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de marzo de 1995.- Juan Eduardo Garc&#xED;a Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 7160744}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "137", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-137"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 137 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "COLEGIO INTERNACIONAL SEK", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-24", "doble_articulado": false, "id_norma": "20366", "numero_fuente": "35295", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-10-19", "vigencias": [{"desde": "1995-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-10-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-10-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MOD