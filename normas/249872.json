{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGROGESTION VITRA LTDA.</div><br></div>", "i": 6570700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA;709 de fecha 10 de mayo de 2006, otorga la calidad de Agente Retenedor de I.V.A. en la actividad cambio de sujeto de derecho del IVA en las ventas de Trigo a Agrogesti&#xF3;n Vitra Ltda. RUT N&#xBA;77.082.030-8. Resoluci&#xF3;n que entrar&#xE1; en vigencia a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido por la Resoluci&#xF3;n Ex.</div><div class=\"p\">N&#xBA;5.281 del 30 de noviembre de 2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6570701}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Luis Mu&#xF1;oz Arratia, Director Regional. </div></div>", "i": 6570702}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "709", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-709"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A AGROGESTION\nVITRA LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-10", "doble_articulado": false, "id_norma": "249872", "numero_fuente": "38471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-24", "vigencias": [{"desde": "2006-05-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-05-24", "fin_vigencia": ""}, "vigencias_version_norma