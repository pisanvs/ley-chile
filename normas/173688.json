{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6294525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.147, de fecha 29 de mayo del 2000, se expropi&#xF3; los lotes de terreno N&#xBA;s. 16, 18 y 25, superficie 4.500, 350 y 4.109 m&#xB2;, respectivamente, roles de aval&#xFA;o 1404-6 y 1441-007, comuna de Puerto Varas, para la obra &quot;Camino V-505, sector Pto. Varas-Los Alerces Pto. Montt, Km. 0,000 a Km. 16,340&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Guido Alfonso Bohle Puschmann y Ewaldo M&#xF6;dinger Leichtle, ascendente a las cantidades de $15.416.580.- para los lotes 16 y 18 y $6.982.161.- para el lote 25.-</div><br></div>", "i": 6294526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6294527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2147", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2147"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-29", "doble_articulado": false, "id_norma": "173688", "numero_fuente": "36728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-01", "vigencias": [{"desde": "2000-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-08-01", "fech