{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOCIEDAD DE ARTESANOS DE ANTOFAGASTA Lei n&#xFA;m. 1,398.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. C&#xF3;nc&#xE9;dese a la Sociedad de Artesanos i Socorros M&#xFA;tuos de Antofagasta el permiso requerido por el art&#xED;culo 556 de C&#xF3;digo Civil para que pueda conservar, hasta por treinta a&#xF1;os, la propiedad del bien raiz que posee en la calle de Maipu de esa ciudad.</div><br><br></div>", "i": 5949073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 13 de Diciembre de 1900.- FEDERICO ERRAZURIZ E.- Francisco J. Herboso.</div><br></div>", "i": 5949074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1398", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1398"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "SOCIEDAD DE ARTESANOS DE ANTOFAGASTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD ARTESANOS", "ANTOFAGASTA", "BIEN RAIZ", "POSESION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-12-13", "doble_articulado": false, "id_norma": "22618", "numero_fuente": "6773", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-12-21", "vigencias": [{"desde": "1900-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in