{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A JULIO A. KUNCAR SILHI </div></div>", "i": 7355764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex. 9.330, de fecha 28.09.07, otorga a Julio A. Kuncar Silhi, RUT N&#xBA; 2.873.640-1, en su condici&#xF3;n de excepcionado, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de Ganado Vivo, establecido en la resoluci&#xF3;n N&#xBA; Ex. 3.721/2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 7355765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 28 de septiembre de 2007.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 7355766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9330 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-9330 EXENTA"}, {"tipo": "3", "numero": "DRE-08-9330 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-9330 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A JULIO A. KUNCAR SILHI", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-09-28", "doble_articulado": false, "id_norma": "265424", "numero_fuente": "38883", "tipo_version": "3", "tipo_ver