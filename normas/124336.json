{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8334531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.266, de 31 de agosto de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a INTERCOMERCIAL SAMA S.A., para ampliar actividades pesqueras autorizadas por resoluciones N&#xBA; 554, de 1991, N&#xBA; 103 y N&#xBA;1.023, ambas de 1992 y N&#xBA; 322, de 1994, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Los Peumos N&#xBA; 535, Cerro Esperanza, Valpara&#xED;so, V Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican los siguientes recursos hidrobiol&#xF3;gicos: Conserva, congelado y fresco-refrigerado: Loco y Pota del Atl&#xE1;ntico.</div><br></div>", "i": 8334532}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8334533}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1266", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1266"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "INTERCOMERCIAL SAMA S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-31", "doble_articulado": false, "id_norma": "124336", "numero_fuente": "36167", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-17", "vigencias": [{"desde": "1998-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen