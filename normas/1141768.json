{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  VENTA DEL PAPEL SELLADO.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 26 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div></div>", "i": 10099250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Que todos los empleados p&#xFA;blicos a cuyo destino sea anexo el espendio del papel sellado, o los comisionados particulares que estos nombraren, den cuenta al fin de cada mes del producido de la venta de este ramo.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Para mediado del mes siguiente presentar&#xE1;n las Tesorer&#xED;as la cuenta jeneral de la venta del anterior. T&#xF3;mese razon, impr&#xED;mase y trascr&#xED;base.</div></div>", "i": 10099251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Diego Jos&#xE9; Benavente.</div></div>", "i": 10099252}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "VENTA DEL PAPEL SELLADO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-01-26", "doble_articulado": false, "id_norma": "1141768", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-01-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": []