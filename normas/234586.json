{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6512903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.650, de 24 de diciembre</div><div class=\"p\">de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA</div><div class=\"p\">LOTA VEDDE LIMITADA ARIES Y COMPA&#xD1;IA COMANDITA POR</div><div class=\"p\">ACCIONES para ampliar actividades pesqueras extractivas</div><div class=\"p\">con la nave &quot;La Ni&#xF1;a I&quot;, en las &#xE1;reas mar&#xED;timas que en</div><div class=\"p\">cada caso se indican, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar los recursos hidrobiol&#xF3;gicos que a continuaci&#xF3;n se se&#xF1;alan: a) Entre la V a VII Regiones, y entre la IX Regi&#xF3;n al paralelo 43&#xB0; L.S., con cerco: Pampanito, Jurelillo de Juan Fern&#xE1;ndez; b) En el Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Isla de Pascua, Islas Sala y G&#xF3;mez e Islas Desventuradas, con cerco: Jurelillo de Juan Fern&#xE1;ndez.</div><br></div>", "i": 6512904}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6512905}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3650 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3650 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-24", "doble_articulado": false, "id_norma": "234586", "numero_fuente": "38057", "tipo_version": "3", "ti