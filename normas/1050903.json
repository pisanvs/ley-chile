{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 861 EXENTA, DE 2013</div></div>", "i": 9351524}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 861, de fecha 16 de abril del 2013, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; mediante un Permiso Originario a la empresa chilena Transaustral Bus Ltda., para efectuar servicio de transporte terrestre internacional de pasajeros entre las localidades que se indican a continuaci&#xF3;n:</div><div class=\"p\">&nbsp; &nbsp;  Chile y Argentina y viceversa, atendiendo el servicio Futaleuf&#xFA; (Chile) / Esquel (Argentina), utilizando el paso R&#xED;o Futaleuf&#xFA;, efectuando una (1) frecuencia semanal de ida y vuelta.- </div></div>", "i": 9351525}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Enrique L. Arce Klein, Unidad de Permisos Internacionales, Subsecretar&#xED;a de Transportes.</div></div>", "i": 9351526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "861 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-861 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "UNIDAD DE PERMISOS INTERNACIONALES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 861 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-04-16", "doble_articulado": false, "id_norma": "1050903", "numero_fuente": "40555", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-05-10", "vigencias": [{"desde": "2013-05-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni