{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 10.823 EXENTA, DE 2005 </div></div>", "i": 6563797}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 10.823, de 30 de diciembre de 2005, se ha aprobado al Colegio Instituci&#xF3;n Teresiana, de la comuna de Las Condes, de Santiago, un plan de estudio para 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2006. Adem&#xE1;s, se aprueba programa de estudio para el Subsector de Cultura Religiosa del Sector de Historia y Ciencias Sociales para 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media.</div><br></div>", "i": 6563798}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de marzo de 2006.- Xavier Vanni Cucurella, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6563799}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10823 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10823 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 10.823 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-30", "doble_articulado": false, "id_norma": "247955", "numero_fuente": "38413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-14", "vigencias": [{"desde": "2006-03-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i