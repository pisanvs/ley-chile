{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 157 EXENTO, DE 1996 </div></div>", "i": 7160880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 157 de 19 de marzo de 1996, se ha sustituido, a partir del a&#xF1;o escolar 1996, en el decreto supremo exento de Educaci&#xF3;n N&#xB0; 12 de 1988 que aprob&#xF3; un plan y programas especiales de estudio al Colegio Menesiano de Melipilla, el plan de estudio para los cursos de 5&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico, por el que se indica en el presente decreto.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas especiales de estudio para la asignatura de Computaci&#xF3;n.</div><br></div>", "i": 7160881}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de abril de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160882}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "157 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-157 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 157 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "COLEGIO MENESIANO MELIPILLA", "REGION", "METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-19", "doble_articulado": false, "id_norma": "20466", "numero_fuente": "35438", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-10", "vigencias": [{"desde": "1996-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-10", "fin_vigencia": ""}, "vigencias_version_norma"