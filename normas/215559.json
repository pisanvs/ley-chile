{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CERTIFICADO</div><br></div>", "i": 6442631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n que suscribe certifica que el Instituto profesional Itesa autorizado a funcionar por Decreto Exento N&#xBA; 47 de 1990, ha presentado los planes y programas de estudio de la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Computaci&#xF3;n e Inform&#xE1;tica conducente al t&#xED;tulo profesional de Ingeniero de Ejecuci&#xF3;n en Computaci&#xF3;n e Inform&#xE1;tica, a la Universidad de Tarapac&#xE1; como entidad examinadora y revisados por &#xE9;sta, han sido aprobados en tiempo y forma, de acuerdo a convenio de examinaci&#xF3;n suscrito por ambas instituciones.</div><div class=\"p\">&nbsp; &nbsp;  La carrera profesional mencionada podr&#xE1; impartirse a contar del a&#xF1;o 1990.</div><br></div>", "i": 6442632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de Enero de 1991.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  RAUL ALLARD NEUMANN</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Subsecretario de Educaci&#xF3;n</div><br></div>", "i": 6442633}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-07", "doble_articulado": false, "id_norma": "215559", "numero_fuente": "34074", "tipo_version": "3", "tipo_version_s": "Úni