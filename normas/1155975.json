{"html": [{"t": "<div><div class=\"p\">AMPLIACION AL TERMINO CONCEDIDO PARA LA LIQUIDACION DE LA DEUDA NACIONAL INTERIOR.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 15 de 1828.</div><br><div class=\"p\">&nbsp; &nbsp;  El Vice-Presidente de la Rep&#xFA;blica ha acordado y decreta:</div></div>", "i": 10237590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0; El t&#xE9;rmino de seis meses concedido por el art. 3.&#xB0; del decreto de 12 de julio de 1827 relativo al rejistro de la deuda nacional interior, se prorroga por cuatro meses mas, contados desde el dia en que se cumpla el primero.</div><br><br></div>", "i": 10237591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; T&#xF3;mese razon en la contaduria mayor, Caja nacional de descuentos e impr&#xED;mase.</div><br><br></div>", "i": 10237592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><div class=\"p\">&nbsp; &nbsp;  Blanco.</div></div>", "i": 10237593}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "AMPLIACION AL TERMINO CONCEDIDO PARA LA LIQUIDACION DE LA DEUDA NACIONAL INTERIOR.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-01-15", "doble_articulado": false, "id_norma": "1155975", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-01-