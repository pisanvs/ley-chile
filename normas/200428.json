{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6388905}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;868 de fecha 31 de mayo de 2002, se expropi&#xF3; el lote de terreno N&#xBA;61-B, superficie 177 m2., sin rol de aval&#xFA;o, comuna de Alto del Carmen, para la obra &apos;&apos;Camino Ruta C-489, Sector Alto del Carmen - El Corral, Tramo Km. 0,000 al Km.</div><div class=\"p\">70,000, Etapa II&apos;&apos;, III Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario H&#xE9;ctor Villanueva Cort&#xE9;s, ascendente a la cantidad de $520.872.- </div></div>", "i": 6388906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6388907}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "868 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-868 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-31", "doble_articulado": false, "id_norma": "200428", "numero_fuente": "37308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-15", "vigencias": [{"desde": "2002-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-07-15", "fecha_version": "2002-07-15", "fecha_actualizacion_texto": "2002-07-15", "t