{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6288251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.011, de fecha 16 de mayo del 2000, se expropi&#xF3; los lotes de terreno N&#xBA;s. 89-A y 89-B, superficie 700 y 11.000 m&#xB2; respectivamente, sin rol de aval&#xFA;o, comuna de Alto del Carmen, para la obra &apos;&apos;Proyecto Embalse Santa Juana Sector La Laja IV Etapa&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Ismael Jofr&#xE9; Salazar, ascendente a la cantidad de $5.911.466.</div><br></div>", "i": 6288252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6288253}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2011", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2011"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-16", "doble_articulado": false, "id_norma": "172722", "numero_fuente": "36714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-15", "vigencias": [{"desde": "2000-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-07-18", "fecha_version": "2000-07-15", "fecha_actualizacion_texto": "2000-07-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estruc