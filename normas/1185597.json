{"html": [{"t": "<div><div class=\"p\">MODIFICA ANEXO 51-29, DEL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10384371}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 3.065, de 23.11.2022, de la Directora Nacional de Aduanas, se modifica el Anexo 51-29 del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, en el siguiente sentido:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Agr&#xE9;gase, en el numeral 29.5 del Anexo 51-29 a Servicios de Transporte y Log&#xED;stica SpA, como Transitorios y Forwarder.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><div class=\"p\">&nbsp; </div></div>", "i": 10384372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alejandra Arriaza Loeb, Directora Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10384373}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3065 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3065 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA ANEXO 51-29, DEL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2226478", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-11-23", "doble_articulado": false, "id_norma": "1185597", "numero_fuente": "43416", "tipo_version": "3", "t