{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 28 EXENTO, DE 1994 </div></div>", "i": 5939842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto supremo exento de Educaci&#xF3;n N&#xB0; 28 de 24 de enero de 1994 se ha autorizado, a contar del a&#xF1;o escolar 1994, al Colegio Parroquial San Miguel, de la comuna de San Miguel, de Santiago, para que imparta la asignatura de Inform&#xE1;tica y Computaci&#xF3;n desde 7&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica hasta 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, con una carga horaria de dos clases semanales.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio de la citada asignatura.</div><br></div>", "i": 5939843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de Febrero de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5939844}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "28 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-28 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 28 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INFORMATICA COMPUTACION", "COLEGIO PARROQUIAL SAN", "MIGUEL", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-02-24", "doble_articulado": false, "id_norma": "19763", "numero_fuente": "34803", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-01", "vigencias": [{"desde": "1994-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-03-01", "fin_vigencia":