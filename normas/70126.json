{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE&nbsp; DECRETO N&#xBA; 710&nbsp; EXENTO,&nbsp; DE 1996</div><br></div>", "i": 6032912}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 710, de 27 de diciembre de 1996, se han agregado, a contar del a&#xF1;o escolar 1997, al plan de estudio aprobado por decreto supremo exento de Educaci&#xF3;n N&#xBA; 300 de 1981 aplicado por el Colegio &quot;Leonardo Da Vinci&quot; de Calama, 2 clases semanales de Inform&#xE1;tica para los alumnos de 3&#xBA; a&#xF1;o (Inform&#xE1;tica 1) y 4&#xBA; a&#xF1;o (Inform&#xE1;tica 2) de Ense&#xF1;anza Media.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de Inform&#xE1;tica 1 y 2 para alumnos de 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media del Colegio &quot;Leonardo Da Vinci&quot; de Calama.</div><br></div>", "i": 6032913}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de diciembre de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6032914}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "710 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-710 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 710 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO LEONARDO DA VINCI", "PLAN DE ESTUDIO", "CALAMA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-27", "doble_articulado": false, "id_norma": "70126", "numero_fuente": "35721", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-20", "vigencias": [{"desde": "1997-03-20", "hasta": "", "tipo_