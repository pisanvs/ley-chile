{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA QUE FIJA HORARIO DE CIERRE O FUNCIONAMIENTO DE NEGOCIOS DE EXPENDIO DE BEBIDAS ALCOHOLICAS </div></div>", "i": 6257338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Municipalidad de Mulch&#xE9;n, por decreto administrativo N&#xBA; 92, de fecha 18 de enero de 2000, pone en conocimiento que fue aprobada la ordenanza que fija el horario de cierre o funcionamiento de los negocios de expendio de bebidas alcoh&#xF3;licas, en la comuna.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada ordenanza, se informa que est&#xE1; a disposici&#xF3;n de quien lo solicite, en la Secretar&#xED;a Municipal.-</div><br></div>", "i": 6257339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  H&#xE9;ctor Francisco Jara Delgado, Alcalde. </div></div>", "i": 6257340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "92", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-92"}], "organismos": ["MUNICIPALIDAD DE MULCHÉN"], "titulo_norma": "APRUEBA ORDENANZA QUE FIJA HORARIO DE CIERRE O FUNCIONAMIENTO DE NEGOCIOS DE EXPENDIO DE BEBIDAS ALCOHOLICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-18", "doble_articulado": false, "id_norma": "163079", "numero_fuente": "36627", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-30", "vigencias": [{"desde": "2000-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingres