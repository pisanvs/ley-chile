{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 140</div><br><div class=\"p\">Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n No. 140, celebrada el 27 de junio de 1991, adopt&#xF3; el siguiente acuerdo:</div><br><div class=\"p\">140-05-910627 - Tasa de inter&#xE9;s para pago diferido de derechos de aduana.</div><br></div>", "i": 6077249}, {"t": "<div><div class=\"p\">Se acord&#xF3;, de conformidad con lo establecido en la letra c) del Art&#xED;culo No. 10 de la Ley No. 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana, durante el semestre que expirar&#xE1; el 31 de diciembre de 1991, ser&#xE1; de 9,7% anual.</div><br></div>", "i": 6077250}, {"t": "<div><div class=\"p\">Santiago, 27 de junio de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 6077251}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "139", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-139"}, {"tipo": "5", "numero": "140-05", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-140-05"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDO BANCO CENTRAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-27", "doble_articulado": false, "id_norma": "87804", "numero_fuente": "34004", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-28", "vigencias": [{"desde": "1991-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-06-28", "fin_vigencia": ""}, "