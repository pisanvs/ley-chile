{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.007 EXENTA, DE 2014</div></div>", "i": 9441915}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.007, de 24 de abril de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Centro de Capacitaci&#xF3;n Laboral Chile Limitada (Cecal Chile Ltda.)&quot;, RUT 76.000.556-8, contenida en la resoluci&#xF3;n exenta N&#xBA; 1.654, de fecha 7 de marzo de 2008, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2 del Art. 21 de la ley 19.518.</div></div>", "i": 9441916}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marcia Pardo Gonz&#xE1;lez, Jefa de Evaluaci&#xF3;n y Organismos (PT).</div></div>", "i": 9441917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2007 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2007 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.007 EXENTA, DE 2014", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-04-24", "fecha_derogacion": "2014-07-04", "doble_articulado": false, "id_norma": "1062068", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2014-05-08", "vigencias": [{"desde": "2014-07-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2014-05-08", "hasta": "2014-07-03", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-07-04", "fin_vig