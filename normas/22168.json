{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MONTEPIO Lei n&#xFA;m. 317.- Santiago, a 6 de Diciembre de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a do&#xF1;a Margarita Larenas, viuda de la Fuente, el goce de montep&#xED;o de sarjento-mayor.</div><br><br></div>", "i": 5947504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Luis Barros Borgo&#xF1;o.</div><br></div>", "i": 5947505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "317", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-317"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MARGARITA LARENAS VIUDA DE LA FUENTE", "MONTEPIO", "MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-12-06", "doble_articulado": false, "id_norma": "22168", "numero_fuente": "5285", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-12-14", "vigencias": [{"desde": "1895-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-12-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-12-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-25", "fecha_ver