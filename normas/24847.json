{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede abono de tiempo a don Alfredo Rodr&#xED;guez, sargento 1.o artillero de la Armada.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Ab&#xF3;nase, por gracia, para los efectos de su retiro y montep&#xED;o, al sargento 1.o artillero de la Armada Nacional, don Alfredo Rodr&#xED;guez Acevedo, el tiempo que sirvi&#xF3; en la Armada con anterioridad al 17 de Septiembre de 1910.</div><br></div>", "i": 5960530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, cuatro de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Carlos O. Frodden. </div></div>", "i": 5960531}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4708", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4708"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "CONCEDE ABONO DE TIEMPO A DON ALFREDO RODRIGUEZ, SARGENTO 1.º ARTILLERO DE LA ARMADA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ALFREDO RODRIGUEZ ACEVEDO", "TIEMPO SERVIDO", "ABONO", "MONTEPIO MILITAR", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-04", "doble_articulado": false, "id_norma": "24847", "numero_fuente": "15540", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-12-05", "vigencias": [{"desde": "1929-12-05", "hasta": "", "tipo_