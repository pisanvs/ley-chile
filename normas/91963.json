{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6090257}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta N&#xBA; 340, de 18 de julio de 1989, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; al se&#xF1;or Secundino Nicol&#xE1;s Fern&#xE1;ndez G&#xF3;mez, para efectuar transporte terrestre de pasajeros entre Osorno y Punta Arenas, en tr&#xE1;nsito por territorio argentino, con dos frecuencias semanales, las que se realizar&#xE1;n en los siguientes d&#xED;as:</div><div class=\"p\">Osorno - Punta Arenas: Jueves - Domingo.</div><div class=\"p\">Punta Arenas - Osorno: Lunes - Jueves.</div><br></div>", "i": 6090258}, {"t": "<div><div class=\"p\">Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6090259}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "340 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-340 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-18", "doble_articulado": false, "id_norma": "91963", "numero_fuente": "33489", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-05", "vigencias": [{"desde": "1989-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-10-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-10-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fech