{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;AVENIDA FRANCISCO MORA VARGAS&quot; A LA AVENIDA CAYUMANQUI, DE LA LOCALIDAD DE QUILLON Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8283625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico Denom&#xED;nase &quot;Avenida Francisco Mora Vargas&quot; a la actual &quot;Avenida Cayumanqui&quot;, de la localidad de Quill&#xF3;n.&quot;.</div><br></div>", "i": 8283626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintisiete de septiembre de mil novecientos sesenta y ocho.- EDUARDO FREI MONTALVA.- Edmundo P&#xE9;rez.</div><br></div>", "i": 8283627}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16972", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16972"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DENOMINA AVENIDA FRANCISCO MORA VARGAS A LA AVENIDA CAYUMANQUI, DE LA LOCALIDAD DE QUILLON", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "AVENIDA FRANCISCO MORA VARGAS", "QUILLON"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-09-27", "doble_articulado": false, "id_norma": "28729", "numero_fuente": "27163", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-10-08", "vigencias": [{"desde": "1968-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1968-10-08", "fin_vigencia": ""}, "vigencias_