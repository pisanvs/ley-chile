{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 4,535</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6212407}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- La actual Legaci&#xF3;n de Chile en Francia, lo ser&#xE1; en lo sucesivo en Francia y Suiza; y trasl&#xE1;dase a B&#xE9;lgica la actual legaci&#xF3;n de la Rep&#xFA;blica en Suiza, servida por un Ministro Residente.</div><br></div>", "i": 6212408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diecis&#xE9;is de Enero de mil novecientos veintinueve.- Carlos Ib&#xE1;&#xF1;ez C.- Conrado R&#xED;os Gallardo. </div></div>", "i": 6212409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4535", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4535"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-01-16", "doble_articulado": false, "id_norma": "149491", "numero_fuente": "15282", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-01-25", "vigencias": [{"desde": "1929-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-01-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-01-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente