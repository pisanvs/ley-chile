{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO PARA PUBLICAR EXTRACTO DE RESOLUCION No. 715, DE 1987 </div></div>", "i": 6228710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.097 de 15 de Septiembre de 1987 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 10 d&#xED;as, a contar de la fecha de publicaci&#xF3;n del extracto de esta resoluci&#xF3;n, el plazo otorgado a don Arnoldo Guti&#xE9;rrez Cortez en el numeral 5&#xB0; de la resoluci&#xF3;n No. 715, de 13 de julio de 1987, en raz&#xF3;n de haberse acreditado la ocurrencia de un caso fortuito.</div><br></div>", "i": 6228711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de Septiembre de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 6228712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1097", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1097"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA PLAZO PARA PUBLICAR EXTRACTO DE RESOLUCION No. 715,\nDE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-15", "doble_articulado": false, "id_norma": "154344", "numero_fuente": "32878", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-25", "vigencias": [{"desde": "1987-09-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-25", "fin_vigencia": "", "tipo_version": "3"}