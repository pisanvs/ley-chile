{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6091173}, {"t": "<div><div class=\"p\">Por Decreto Secc. 2da. No.752, de 14 Agosto 1989. Alcalde I. Municipalidad de Santiago dispone expropiaci&#xF3;n parcial inmueble Mac Iver esquina Nor Poniente Merced roles 154-4, 154-147 y 154-148, aparentemente dominio sociedad Inversiones Acadian e In&#xE9;s Casanova vda. de Lamas. Superficie franja 577,50 m2. Deslindes: Norte, 7 mts. ensanche calle Merced; Sur, 7 mts. calle Merced; Oriente, 87,50 mts. calle Mac Iver; Poniente, 87,50 mts. resto predio. Indemnizaci&#xF3;n provisional $ 55.037.500, pagadera contado.</div><br></div>", "i": 6091174}, {"t": "<div><div class=\"p\">M&#xE1;ximo Honorato A., Alcalde Santiago.</div><br></div>", "i": 6091175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "752", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-752"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-14", "doble_articulado": false, "id_norma": "92303", "numero_fuente": "33463", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-01", "vigencias": [{"desde": "1989-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1998-03-02", "fecha_version": "1989-09-01", "fecha_actualizacion_texto": "1989-09-01", "tipo_tratado": ""}, "alertas": []