{"html": [{"t": "<div><br><div class=\"p\">AMPL&#xCD;A PLAZO QUE INDICA</div></div>", "i": 9624529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.820, de 7 de julio de 2015, de esta Subsecretar&#xED;a, ampl&#xED;ese por doce meses, a contar del 10 de agosto de 2015, el plazo otorgado en el numeral 7&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=254598&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.861, de 2006</a>, a Friosur VII S.A., hoy Pesquera Sur Austral S.A., para para iniciar actividades pesqueras extractivas con la nave en construcci&#xF3;n denominada &quot;BEC N&#xBA; 2861-06&quot;, con excepci&#xF3;n de aquellas especies cuya caducidad haya sido declarada mediante resoluci&#xF3;n, en virtud de haberse acreditado una circunstancia de fuerza mayor.</div></div>", "i": 9624530}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de julio de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9624531}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1820 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1820 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "AMPLÍA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-07-07", "doble_articulado": false, "id_norma": "1079925", "numero_fuente": "41218", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-07-28", "vigencias": [{"desde": "2015-07-28", "hasta": "", "t