{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 473, de 3 de abril de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; deni&#xE9;gase la autorizaci&#xF3;n solicitada por PESQUERA MAR S.A., para sustituir la nave &quot;Mar&quot; por la nave &quot;Granada&quot;, en virtud de lo dispuesto en el art&#xED;culo 19 letra d) de la Ley N&#xBA; 18.892 y sus modificaciones y art&#xED;culo 5&#xBA; del D.S. N&#xBA; 64, de 1992. </div></div>", "i": 8302307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de abril de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302308}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "473", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-473"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "PESCA", "PESQUERA MAR S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-03", "doble_articulado": false, "id_norma": "70503", "numero_fuente": "35737", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-10", "vigencias": [{"desde": "1997-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-04-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAV", "fecha_ingreso": "1997-04-16", "fe