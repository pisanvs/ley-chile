{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 110, DE 1987 </div></div>", "i": 6214480}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se ha procedido a aprobar, a contar de 1987, planes y programas de estudio a la Escuela Especial Talleres de Capacitaci&#xF3;n Laboral para Sordos, dependiente del Instituto de la Sordera, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  El plan aprobado contempla nivel pre formativo, formativo y productivo.</div><div class=\"p\">&nbsp; &nbsp;  La evaluaci&#xF3;n y promoci&#xF3;n de los alumnos se regir&#xE1; por las normas que se se&#xF1;alan.</div><br></div>", "i": 6214481}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de Junio de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6214482}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "110 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-110 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 110, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-25", "doble_articulado": false, "id_norma": "149986", "numero_fuente": "32806", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-27", "vigencias": [{"desde": "1987-06-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": []