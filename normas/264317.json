{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7352391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 699, de 26 de julio de 2007, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme DL N&#xBA; 2.186 de 1978, del Lote N&#xBA; 23-A, correspondiente a parte del inmueble ubicado en Lo Ruiz 2308, Rol de aval&#xFA;o N&#xBA; 451-3, comuna de Renca, aparente dominio de Refractarios RHI Chile Limitada. Comisi&#xF3;n integrada por peritos se&#xF1;ores M&#xF3;nica Conejeros R., ingeniero agr&#xF3;nomo; Douglas Herrera Flores, constructor civil y Mario Zamorano Villablanca, arquitecto. Seg&#xFA;n informe de 3 de mayo de 2007, fij&#xF3; monto provisional indemnizaci&#xF3;n en $20.138.800.-, pagadera al contado.</div><br></div>", "i": 7352392}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7352393}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "699", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-699"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-26", "doble_articulado": false, "id_norma": "264317", "numero_fuente": "38853", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-01", "vigencias": [{"desde": "2007-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia