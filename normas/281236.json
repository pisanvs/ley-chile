{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.212 EXENTA, DE 2008 </div></div>", "i": 6664362}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 8.212, de 3 de noviembre de 2008, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n a la sociedad &quot;Ser Humano Capacitaci&#xF3;n Limitada&quot; (Ser Humano Ltda.), RUT 77.031.260-4, contenida en la resoluci&#xF3;n exenta N&#xBA; 2.107, de 2 de abril de 2007, y modificada por la resoluci&#xF3;n exenta N&#xBA; 5.643, de 29 de julio de 2008. </div></div>", "i": 6664363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Rouliez Fleck, Director Nacional. </div></div>", "i": 6664364}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8212 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8212 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.212 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-03", "doble_articulado": false, "id_norma": "281236", "numero_fuente": "39209", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-11", "vigencias": [{"desde": "2008-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-11-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-11-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fec