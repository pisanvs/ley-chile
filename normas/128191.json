{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION DE INMUEBLE </div></div>", "i": 6142819}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 588 de 4 de noviembre de 1998 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L.</div><div class=\"p\">N&#xBA; 2.186 de 1978, del inmueble ubicado en calle Huel&#xE9;n S/N&#xBA;, presunto rol de aval&#xFA;os N&#xBA; 2896-15 comuna de Cerro Navia, de aparente dominio de la Sucesi&#xF3;n Castillo Cubillos - Carlos Cubillos Salvatierra y Otros. Comisi&#xF3;n integrada por peritos Gustavo Riego Allende, arquitecto, Eric Prenzel Leupolt, ingeniero civil y Enrique Escobar Thauby, constructor civil, seg&#xFA;n informe de 27 de julio de 1998 fij&#xF3; monto provisional de indemnizaci&#xF3;n en $68.510.000.- pagadera al contado.- </div></div>", "i": 6142820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6142821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "588", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-588"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-04", "doble_articulado": false, "id_norma": "128191", "numero_fuente": "36239", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-15", "vigencias": [{"desde": "1998-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-15", "fin_vigencia": ""}, "vigencias_version_norma"