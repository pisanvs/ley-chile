{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,423.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 9050987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al ex - delegado del Gobierno en los Ferrocarriles de Coquimbo al Norte, e interventor en el de Antofagasta a Bolivia, don Jos&#xE9; A. Bustamante, el derecho de jubilar de acuerdo con sus a&#xF1;os de servicios y con relacion a la renta de que disfrutaba en dicho empleo.</div><br></div>", "i": 9050988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a catorce de noviembre del mil novecientos dieciocho.- Juan Luis Sanfuentes.- Francisco Landa Z. </div></div>", "i": 9050989}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3423", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3423"}], "organismos": ["MINISTERIO DE FERROCARRILES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-11-14", "doble_articulado": false, "id_norma": "141360", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-11-19", "vigencias": [{"desde": "1918-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-11-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-11-19", "fin_vigencia": "", "tipo_vers