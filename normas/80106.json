{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8310606}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 690, de 11 de Junio de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fonento y Reconstrucci&#xF3;n, se prorroga por 6 meses a contarde esta fecha, el plazo otorgado a don MIGUEL ANGEL DIAZ ALVAREZ, RUT No. 6.350.898-7, domiciliado en calle Las Industrias No. 4579, San Juan de Llo-Lleo, San Antonio, para empezar a operar la planta autorizada por Resoluci&#xF3;n No. 704, de 1989 de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8310607}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 11 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8310608}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "690", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-690"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-11", "doble_articulado": false, "id_norma": "80106", "numero_fuente": "34107", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-04", "vigencias": [{"desde": "1991-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "in