{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.474 EXENTA, DE 22 DE AGOSTO DE 2018</div></div>", "i": 9953678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 3.474, de 2 de agosto de 2018, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, declara el cese de la inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la siguiente entidad, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.</div><br><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/84446.jpg\">.</div><br><br></div>", "i": 9953679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de agosto de 2018.- Andr&#xE9;s Toro Aguilar, Jefe del Departamento Desarrollo y Regulaci&#xF3;n de Mercado, Servicio Nacional de Capacitaci&#xF3;n y Empleo (S).</div></div>", "i": 9953680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3474 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3474 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DEL TRABAJO", "SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.474 EXENTA, DE 22 DE AGOSTO DE 2018", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1474272", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-08-02", "doble_articulado": false, "id_norma": "1123696", "numero_fuente": "42176", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-10-09", "vigencias": [{"desde": "2018-10-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in