{"html": [{"t": "<div><br><div class=\"p\">Registros de mercader&#xED;as.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 24 de 1822.</div></div>", "i": 10109752}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Continuando como hasta ahora los rejistros de las cargazones que se importan del Per&#xFA;, i esportan a &#xE9;l como de rec&#xED;proca seguridad de &#xE1;mbos estados, of&#xED;ciese a S. E. el se&#xF1;or Protector, para que se contin&#xFA;e la pr&#xE1;ctica interesant&#xED;sima de rejistros m&#xFA;tuos con que no solo se consulta la seguridad i aumento de &#xE1;mbos erarios, sino el buen &#xF3;rden, facilidad i breve espedicion de las oficinas.- </div><br></div>", "i": 10109753}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  O&apos;Higgins.- Rodr&#xED;guez.</div></div>", "i": 10109754}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Registros de mercaderías.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-04-24", "doble_articulado": false, "id_norma": "1142975", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-04-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-04-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2020-03-23", "fecha_version": "1822-04-24", "fecha_actualizacion_tex