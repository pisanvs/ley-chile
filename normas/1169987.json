{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10292875}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta 2.212, de 29 de noviembre 2021, Serviu Regi&#xF3;n del Biob&#xED;o orden&#xF3; expropiaci&#xF3;n parcial del inmueble ubicado en Maip&#xFA; 2330, Rol de Aval&#xFA;o N&#xBA; 271-8, comuna de Concepci&#xF3;n, de aparente dominio de Fisco Ej&#xE9;rcito de Chile, en una superficie de 19,31 m2 de terreno, conforme al plano S8R-41.421-1, para la ejecuci&#xF3;n de las obras del proyecto &quot;Mejoramiento Par Vial Collao/General Novoa, comuna de Concepci&#xF3;n&quot;, conforme art&#xED;culo 51 ley N&#xBA; 16.391 y DL N&#xBA; 2.186. Comisi&#xF3;n Peritos integrada por ingeniero civil Orlando Paredes V&#xE1;squez, por constructor civil &#xCD;talo Zerga Arancibia y por arquitecto Guillermo Villafa&#xF1;e Feres, seg&#xFA;n informe de fecha 29 de octubre 2021, fij&#xF3; monto provisional indemnizaci&#xF3;n en la suma de $12.094.569, pagadera de contado.- </div></div>", "i": 10292876}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n del Biob&#xED;o.</div><br></div>", "i": 10292877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2212 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2212 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL BIOBÍO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2051914", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-29", "doble_articulado": false, "id_norma": "116998