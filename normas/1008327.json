{"html": [{"t": "<div><br><div class=\"p\">DESAFILIA DEL SISTEMA DE FACTURACI&#xD3;N ELECTR&#xD3;NICA A CONTRIBUYENTES QUE INDICA</div></div>", "i": 8807264}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 170, de 18 de noviembre de 2009, que desafilia autorizaci&#xF3;n otorgada a contribuyentes para operar como emisores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase por desafiliados del Sistema de Facturaci&#xF3;n Electr&#xF3;nica, a los contribuyentes RUT N&#xBA; 76.028.323-1, RUT N&#xBA; 96.686.850-3 y RUT N&#xBA; 99.537.940-6.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2009.</div></div>", "i": 8807265}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "170 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-170 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESAFILIA DEL SISTEMA DE FACTURACIÓN ELECTRÓNICA A CONTRIBUYENTES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-11-18", "doble_articulado": false, "id_norma": "1008327", "numero_fuente": "39517", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-11-21", "vigencias": [{"desde": "2009-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi