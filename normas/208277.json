{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6416711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;567, de 24 de febrero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MARINOS S.A. para ampliar las actividades pesqueras extractivas con la nave &quot;G&#xE9;nesis&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la V a VII Regiones, y en la X Regi&#xF3;n, con arrastre de media agua, por fuera de las 60 millas n&#xE1;uticas contadas desde las l&#xED;neas de base, sobre los siguientes recursos hidrobiol&#xF3;gicos: Anchoveta, Agujilla, Caballa, Jurel, Sardina espa&#xF1;ola, Sardina com&#xFA;n, Merluza de cola, Bonito, Cojinoba del norte Seriolella violacea, Machuelo o tritre, Bacaladillo o mote, Cojinoba del sur. </div></div>", "i": 6416712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de febrero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6416713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "567", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-567"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-02-24", "fecha_derogacion": "2008-06-11", "doble_articulado": false, "id_norma": "208277", "numero_fuente": "37504", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-03-08", "vigencias": [{"desde": "2008-06-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-03-08", "hasta": "2008-06-10", "tipo_ver