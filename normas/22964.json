{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede la suma de 1800 pesos a don Jos&#xE9; Vicente Varas.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1857.- Santiago, a 13 de Febrero de 1906.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, a don Jos&#xE9; Vicente Varas, ex pesador de la Aduana de Pisagua, por una sola vez, la suma de mil ochocientos pesos como remuneracion de los servicios que prest&#xF3; durante tres a&#xF1;os en el desempe&#xF1;o del cargo de jefe de pesadores de aquella aduana.</div><br></div>", "i": 5952255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Belfor Fernandez </div></div>", "i": 5952256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1857", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1857"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE LA SUMA DE 1800 PESOS A DON JOSE VICENTE VARAS.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE VICENTE VARAS", "ADUANA PISAGUA", "SERVICIOS", "PRESTADOS", "REMUNERACION POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-02-13", "doble_articulado": false, "id_norma": "22964", "numero_fuente": "8437", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-02-22", "vigencias": [{"desde": "1906-02-22", "hasta": "", "tipo_version"