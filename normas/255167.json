{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br><br></div>", "i": 6589338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;586, de 4 de octubre de 2006, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA;2.186 de 1978, del lote N&#xBA;328, correspondiente al inmueble ubicado en Costanera, sitio 328, manzana 10, sector C, rol de aval&#xFA;o N&#xBA;4025-328, comuna de Quinta Normal, aparente dominio de Ram&#xF3;n D&#xED;az Henr&#xED;quez. Comisi&#xF3;n integrada por peritos se&#xF1;ores Roberto Correa Bezanilla, arquitecto; Mario Basso Passadore, constructor civil; y Andr&#xE9;s Ruiz Figueroa, ingeniero civil. Seg&#xFA;n informe de 15 de junio de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $4.117.000, pagadera al contado.</div><br></div>", "i": 6589339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6589340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "586", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-586"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES TOTALES DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-04", "doble_articulado": false, "id_norma": "255167", "numero_fuente": "38614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-15", "vigencias": [{"desde": "2006-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s"