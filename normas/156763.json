{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 44 de 17 de Enero de 1985, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a los sectores excluidos y expropiados de los predios &quot;Resto de la Hijuela Primera o Las Casas&quot; y &quot;El Nogal&quot; de la comuna de Buin, Regi&#xF3;n Metropolitana y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0; 1 a la 16, sitios N&#xB0; 1 al 15 del Proyecto de Parcelaci&#xF3;n &quot;Casas Nuevas&quot; formado por los predios se&#xF1;alados. Los derechos de agua se extraen del canal Fernandino por el Canal Mirador.- Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377.-</div><br></div>", "i": 6236655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6236656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "44 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-44 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-17", "doble_articulado": false, "id_norma": "156763", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-01", "fin_vigencia": ""}, "vigencias_versio