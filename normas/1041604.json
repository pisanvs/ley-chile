{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.365 EXENTA, DE 2012</div></div>", "i": 9272239}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Res. ex. N&#xBA; 1.365 , de 2012, autoriza al siguiente taller para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo (GLP) como combustible:</div><br><br><div class=\"p\">Empresa&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Nombre del taller&nbsp; &nbsp; &nbsp; Direcci&#xF3;n del Taller&nbsp;  Ciudad</div><div class=\"p\">Habilitada</div><div class=\"p\">Italgas S.A.&nbsp; &nbsp; Inversiones Mirasol S.A.&nbsp;  San Jos&#xE9; N&#xB0; 90&nbsp; &nbsp;  Valpara&#xED;so.</div><br><div class=\"p\">&nbsp; &nbsp;  Autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.-</div><br></div>", "i": 9272240}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Gloria Hutt Hesse, Subsecretaria de Transportes.</div></div>", "i": 9272241}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1365 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1365 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.365 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN FECHA DE PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1041604", "numero_fuente": "40306", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-07", "vigencias": [{"desde": "2012-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-07-07", "fin_vigenci