{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6297895}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.818, de 18 de agosto de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO-BIO S.A., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Biomar III&apos;&apos;, en el &#xE1;rea mar&#xED;tima comprendida entre la I y X Regiones, por fuera del &#xE1;rea de reserva artesanal, con trampa, sobre los siguientes recursos hidrobiol&#xF3;gicos: Centolla Lithodes wiracocha, Centolla&nbsp; Lithodes panamensis, Centolla Neolithodes diomedae, Centoll&#xF3;n Paralomis papillata, Centoll&#xF3;n Paralomis longipes, Centoll&#xF3;n&nbsp; Paralomis otsuae, Centoll&#xF3;n&nbsp; Paralomis&nbsp; spinosissima.</div><br></div>", "i": 6297896}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de agosto de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6297897}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1818", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1818"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-08-18", "fecha_derogacion": "2014-01-04", "doble_articulado": false, "id_norma": "174658", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-08-28", "vigencias": [{"desde": "2014-01-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-08-28", "hasta": "2014-01-03", "tipo_version": "0", "tipo_version_s": "Texto Origina