{"html": [{"t": "<div><div class=\"p\">Aclaracion de un decreto sobre donacion</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 2 de 1822.</div></div>", "i": 10098811}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La gracia concedida a do&#xF1;a Tadea Vel&#xE1;zquez por decreto de 8 del mes pr&#xF3;ximo pasado impreso en la Ministerial n&#xFA;mero 36, tomo 3.&#xB0;, para despues de los dias de la madre del sarjento mayor de injenieros, don Cayetano Letelier, debe correr i entenderse tambien con la hermana de &#xE9;ste do&#xF1;a Tr&#xE1;nsito Letelier, gozando &#xE1;mbas por igual de la hacienda donada.</div></div>", "i": 10098812}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon e impr&#xED;mase.-O&apos;Higgins.-Rodr&#xED;guez.</div></div>", "i": 10098813}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Aclaracion de un decreto sobre donacion", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-04-02", "doble_articulado": false, "id_norma": "1141679", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-04-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-04-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2020-02-06", "fecha_version": "1822-04-02", "fecha_actualizacion_texto": "2020-02