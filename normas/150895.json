{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION No. 863 EXENTA, DE 1987 </div></div>", "i": 6217693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 863 de fecha 29 de abril de</div><div class=\"p\">1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el</div><div class=\"p\">Art. lo de la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 741 de 1963, del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Arte Santa Elvira de Santiago, en el sentido de introducir nueva red secuencial de asignaturas y plan de estudios de la carrera T&#xE9;cnico en Sonido, a partir del a&#xF1;o 1984.- </div></div>", "i": 6217694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6217695}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "863 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-863 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION No. 863 EXENTA, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-29", "doble_articulado": false, "id_norma": "150895", "numero_fuente": "32801", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-22", "vigencias": [{"desde": "1987-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ing