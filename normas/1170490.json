{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.274 EXENTA, 19 DE NOVIEMBRE DE 2021</div></div>", "i": 10296448}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 4.274, de 19 de noviembre de 2021, de la Subsecretar&#xED;a de Transportes, se autoriza al siguiente taller para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo (GLP) y gas natural comprimido (GNC) como combustible:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/136779.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10296449}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Luis Dom&#xED;nguez Covarrubias, Subsecretario de Transportes.</div><div class=\"p\"> </div><br></div>", "i": 10296450}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4274 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4274 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.274 EXENTA, 19 DE NOVIEMBRE DE 2021", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2060956", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-19", "doble_articulado": false, "id_norma": "1170490", "numero_fuente": "43136", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-12-24", "v