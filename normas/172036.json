{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6286258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.845, de fecha 28 de abril del 2000, se expropiaron los lotes de terreno N&#xBA;s. 1, 2, 3 y 4, superficies 80, 1.151, 190 y 157 m&#xB2;, respectivamente, rol de aval&#xFA;o 104-11, comuna de Corral, para la obra &apos;&apos;Camino Longitudinal Costero Sur, Sector El Morro-Chaihuin I Km. 10,000 a Km. 15,747 &apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Jorge Segundo Franquez Reyes y otros, ascendente a la cantidad de $465.784.</div><br></div>", "i": 6286259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6286260}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1845", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1845"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "172036", "numero_fuente": "36702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-01", "vigencias": [{"desde": "2000-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "2000-07-06", "fecha_version": "2000-07-01", "fecha_actualizacion_texto": "2000-07-01", "tipo_tratado": ""}