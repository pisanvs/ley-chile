{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON JULIO IRIARTE RODRIGUEZ PARA DESARROLLAR ACTIVIDADES PESQUERAS </div></div>", "i": 7260957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 667, de 9 de Septiembre de 1986, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Julio Iriarte Rodr&#xED;guez, c&#xE9;dula de identidad No. 617.623-2, domiciliado en Mejillones, Caleta Prado s/n., para operar una embarcaci&#xF3;n actualmente en construcci&#xF3;n, en el litoral de las Regiones I, II y III, en labores extractivas de los siguientes recursos: pez espada (albacora) y mero o bacalao, destinados a consumo humano.</div><br></div>", "i": 7260958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de Septiembre de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7260959}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "667", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-667"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A DON JULIO IRIARTE RODRIGUEZ PARA DESARROLLAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-09-09", "fecha_derogacion": "1988-03-11", "doble_articulado": false, "id_norma": "155095", "numero_fuente": "32.574", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-09-16", "vigencias": [{"desde": "1988-03-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-09-16", "hasta": "1988-03-10", "tipo_versi