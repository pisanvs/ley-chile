{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9723341}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n exenta N&#xBA; 77316061352, de fecha 03/08/2016, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=221048&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; Ex. 55 del 30.01.2004</a>, que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de contrato de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contraten, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Empresa Constructora CBA Limitada, RUT N&#xB0; 77.334.760-3, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 142, de fecha 26.12.2005, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial de fecha 29.12.2005.- </div><br></div>", "i": 9723342, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lidia del Carmen Castillo Alarc&#xF3;n, Directora Regional.</div></div>", "i": 9723343}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77316061352 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-77316061352 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1100164; IdDO 1100164", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-08-03", "doble_articulado": false, "id_norma": "1093867", "numero_fuente": "41535", "tipo_version"