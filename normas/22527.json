{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Residencia de los Cuerpos del Ej&#xE9;rcito Lei n&#xFA;m. 1,279.- Santiago, a 22 de Noviembre de 1899- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Perm&#xED;tase, por el t&#xE9;rmino de un a&#xF1;o, la residencia de los cuerpos del Ej&#xE9;rcito permanente en el lugar de las sesiones del Congreso Nacional i diez leguas a su circunferencia.</div><br><br><br></div>", "i": 5948770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 5948771}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1279", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1279"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Residencia de los Cuerpos del Ejército", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO CHILE", "RESIDENCIA", "FIJACION", "CONGRESO", "NACIONAL", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-11-22", "doble_articulado": false, "id_norma": "22527", "numero_fuente": "6454", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-11-22", "vigencias": [{"desde": "1899-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-11-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-11-22", "fin_vigencia": "", "tipo_versio