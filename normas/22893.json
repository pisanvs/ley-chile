{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CONCEDE SUPLEMENTO AL PRESUPUESTO DEL MINISTERIO DEL INTERIOR.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1753.-Santiago, a 25 de Agosto de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese un suplemento de un mil novecientos ochenta pesos al &#xED;tem 24 de la partida 1.&#xB0; del presupuesto del Ministerio del Interior, para el servicio de la Guardia de la C&#xE1;mara de Senadores. </div></div>", "i": 8274665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JERMAN RIESCO.- Juan Antonio Orrego.</div><br></div>", "i": 8274666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1753", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1753"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE SUPLEMENTO AL PRESUPUESTO DEL MINISTERIO DEL INTERIOR.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1905", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-08-25", "doble_articulado": false, "id_norma": "22893", "numero_fuente": "8301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-08-25", "vigencias": [{"desde": "1905-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-08-25", "fin_vigencia": ""}, 