{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8346447}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.229, de 25 de junio de 1999, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA; 163 de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA LA PENINSULA S.A., para desarrollar actividades pesqueras, en el sentido de modificar el plazo de inicio de actividades en la unidad de pesquer&#xED;a Jurel X Regi&#xF3;n, indicando que &#xE9;ste es de dos a&#xF1;os contados desde la fecha de publicaci&#xF3;n del extracto de dicha resoluci&#xF3;n en el Diario Oficial, esto es, el 26 de febrero de 1997.</div><br></div>", "i": 8346448}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de junio de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8346449}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1229", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1229"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-06-25", "fecha_derogacion": "2002-11-07", "doble_articulado": false, "id_norma": "138849", "numero_fuente": "36409", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-07-10", "vigencias": [{"desde": "2002-11-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-07-10", "hasta": "2002-11-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "200