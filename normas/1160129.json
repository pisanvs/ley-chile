{"html": [{"t": "<div><div class=\"p\">INSTRUYE SOBRE SANCIONES APLICABLES CONFORME AL N&#xB0;6 DEL ART. 41 E DE LA LIR</div></div>", "i": 10229633}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xB0;32, de fecha 19 de mayo de 2021, instruye sobre sanciones aplicables conforme a lo dispuesto por el N&#xB0;6 del <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=9298702&amp;idVersion=\">art&#xED;culo 41 E</a> de la Ley sobre Impuesto a la Renta (LIR), por la no presentaci&#xF3;n de las declaraciones juradas a que se refiere dicha norma, o su presentaci&#xF3;n err&#xF3;nea, incompleta, extempor&#xE1;nea o maliciosamente falsa. Deroga circular N&#xB0;31, de 12 de mayo de 2016.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento, est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><div class=\"p\"> </div><br></div>", "i": 10229634}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "32", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-32"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "INSTRUYE SOBRE SANCIONES APLICABLES CONFORME AL N°6 DEL ART. 41 E DE LA LIR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1945455", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2021-05-19", "fecha_derogacion": "2022-06-30", "doble_articulado": false, "id_norma": "1160129", "numero_fuente": "42962", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2021-05-26", "vigencias": [{"desde": "2022-06-30", "hasta