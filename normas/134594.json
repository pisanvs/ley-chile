{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,298.- Santiago, 18 de diciembre de 1899.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162861}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Tr&#xE1;nsito Elgueta, viuda de C&#xE1;ceres, madre de los soldados Jos&#xE9; Gabriel i Juan C&#xE1;ceres, muertos en el servicio del pais, una pension vitalicia de quince pesos mensuales.</div><br></div>", "i": 6162862}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ricardo Matte P&#xE9;rez.</div><br></div>", "i": 6162863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1298", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1298"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-18", "doble_articulado": false, "id_norma": "134594", "numero_fuente": "6475", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-12-18", "vigencias": [{"desde": "1899-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-12-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-08", "f