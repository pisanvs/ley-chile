{"html": [{"t": "<div><div class=\"p\">SUSPENDE FUNCIONAMIENTO DE JUNTA INSCRIPTORA DE CHAIT&#xC9;N </div></div>", "i": 7371592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Susp&#xE9;ndese el funcionamiento de la Junta Inscriptora de Chait&#xE9;n, hasta el inicio del per&#xED;odo de inscripciones del a&#xF1;o 2009. Las &#xFA;ltimas inscripciones practicadas correspondieron a la N&#xBA; 081 del Registro 008 de mujeres y a la N&#xBA; 194 del Registro 013 de varones.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada por resoluci&#xF3;n O N&#xBA; 0976, del 4 de junio de 2008.</div><br></div>", "i": 7371593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de junio de 2008.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 7371594}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "976", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-976"}, {"tipo": "3", "numero": "O-976", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-976"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SUSPENDE FUNCIONAMIENTO DE JUNTA INSCRIPTORA DE CHAITÉN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUNTA INSCRIPTORA", "CHAITEN", "FUNCIONAMIENTO", "SUSPENSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-04", "doble_articulado": false, "id_norma": "271828", "numero_fuente": "39081", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-06-07", "vigencias": [{"desde": "2008-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-06-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20