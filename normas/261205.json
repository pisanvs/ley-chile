{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 55 EXENTA, DE 2007 </div></div>", "i": 7342946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 55, de 27 de abril de 2007, de la Secretar&#xED;a Regional Ministerial de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se dispuso el inicio de la Puesta en Marcha Definitiva de la Concesi&#xF3;n Dos, adjudicada a &quot;T&#xDC;V Rheinland Andino S.A.&quot;, para operar en la comuna de Concepci&#xF3;n, una Planta Revisora Clase AB, con cuatro (4) l&#xED;neas de revisi&#xF3;n liviana y dos (2) l&#xED;neas de revisi&#xF3;n pesada, a contar del d&#xED;a 30 de abril de 2007. </div></div>", "i": 7342947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Claudio V&#xE1;squez Fern&#xE1;ndez, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 7342948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "55 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-55 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 55 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-27", "doble_articulado": false, "id_norma": "261205", "numero_fuente": "38774", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-29", "vigencias": [{"desde": "2007-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-29", "fin_vigenc