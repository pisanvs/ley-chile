{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7292621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.334 de 26 de junio de 2002 de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto el numeral 12 de la resoluci&#xF3;n N&#xBA;844 de 2002, de esta Subsecretar&#xED;a, conforme al m&#xE9;rito de los antecedentes hechos valer por la peticionaria.</div><div class=\"p\">&nbsp; &nbsp;  En consecuencia, las resoluciones N&#xBA;11 de 1980, N&#xBA;553 de 1984, N&#xBA;183 de 1985, N&#xBA;410 de 1987, N&#xBA;1.239 de 1992, N&#xBA;1.730 de 1999 y N&#xBA;682 de 2000, todas de esta Subsecretar&#xED;a, se encuentran plenamente vigentes para todos los efectos legales.</div><br></div>", "i": 7292622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de junio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7292623}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1334", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1334"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-26", "doble_articulado": false, "id_norma": "200040", "numero_fuente": "37299", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-04", "vigencias": [{"desde": "2002-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente