{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6002049}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 2 de 2 de Mayo de 1994, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n, se adjudic&#xF3; a don N&#xE9;stor Roberto Inostroza San Mart&#xED;n, la concesi&#xF3;n para operar hasta el 1 de Diciembre de 1998 a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle Arauco N&#xB0; 290, de la comuna de Curacaut&#xED;n, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.</div><br></div>", "i": 6002050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Temuco, 5 de Julio de 1994.- Patricio Villanueva Rubilar, Secretario Regional Ministerial de Transportes y Telecomunicaciones, IX Regi&#xF3;n.</div><br></div>", "i": 6002051}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "VEHICULOS MOTORIZADOS", "NOVENA REGION", "CURACAUTIN", "NESTOR ROBERTO INOSTROZA SAN MARTIN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-05-02", "doble_articulado": false, "id_norma": "31819", "numero_fuente": "34913", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-07-13", "vigencias": [{"desde": "1994-07-13", "hasta": "", "tipo_versio