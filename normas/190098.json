{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6351600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.902, de 11 de septiembre de</div><div class=\"p\">2001, de esta Subsecretar&#xED;a, autor&#xED;zase a EMPRESA</div><div class=\"p\">PESQUERA BRAVAMAR Y COMPA&#xD1;IA LIMITADA, para ampliar</div><div class=\"p\">actividades pesqueras extractivas con la nave &quot;Punta</div><div class=\"p\">Talca&quot;, matr&#xED;cula 1644, autorizada por las resoluciones</div><div class=\"p\">citadas precedentemente, en las &#xE1;reas mar&#xED;timas que se</div><div class=\"p\">indican, por fuera del &#xE1;rea de reserva artesanal, con</div><div class=\"p\">arte de arrastre, sobre los recursos hidrobiol&#xF3;gicos:</div><div class=\"p\">a) Litoral de la I Regi&#xF3;n: Merluza com&#xFA;n, Gamba, Besugo, Congrio dorado, Pejerrata y Raya; b) Litoral de la III Regi&#xF3;n: Merluza com&#xFA;n; c) Litoral de la III a VII Regiones: Besugo, Congrio dorado, Pejerrata y Raya. </div></div>", "i": 6351601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de septiembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6351602}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1902", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1902"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-09-11", "fecha_derogacion": "2003-01-16", "doble_articulado": false, "id_norma": "190098", "numero_fuente": "37075", "tipo_version": "2", "tipo_vers