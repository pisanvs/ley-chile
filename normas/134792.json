{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,368.-Santiago, 6 de setiembre de 1900.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Mercedes Arce, viuda de Merino, madre del cirujano militar don Ismael Merino, que muri&#xF3; de fiebre amarilla en Chiclayo, durante la campa&#xF1;a contra el Per&#xFA; i Bolivia, una pension equivalente al montep&#xED;o de capitan de Ej&#xE9;rcito.&quot; </div></div>", "i": 6163462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- ELIAS FERNANDEZ A.- Ricardo Matte P&#xE9;rez.</div><br></div>", "i": 6163463}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1368", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1368"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-09-06", "doble_articulado": false, "id_norma": "134792", "numero_fuente": "6690", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-09-10", "vigencias": [{"desde": "1900-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-09-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-09-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":