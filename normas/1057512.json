{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO&nbsp; DE RESOLUCI&#xD3;N N&#xBA; 9.765 EXENTA, DE 2013</div></div>", "i": 9393824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 9.765 de 10 de diciembre de 2013 del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se establece la obligatoriedad del uso del sistema de control de asistencia para cursos a distancia-elearning que se ejecuten por los organismos t&#xE9;cnicos de capacitaci&#xF3;n.</div></div>", "i": 9393825}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de diciembre de 2013.- Juan Bennett Urrutia, Director Nacional Subrogante.</div></div>", "i": 9393826}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9765", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-9765"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 9.765 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-10", "doble_articulado": false, "id_norma": "1057512", "numero_fuente": "40738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-12-21", "vigencias": [{"desde": "2013-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-12-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2013-12-23", "fecha_version": "2013-12-21", "fecha_actualizacion_texto": "2013-12-23