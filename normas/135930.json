{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA </div></div>", "i": 8548844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 292 de 18 de Marzo de 1988 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por un a&#xF1;o, a contar de Enero de 1988, el plazo otorgado a Salmones Andes S.A. para empezar a operar el establecimiento de cultivo autorizado por la Resoluci&#xF3;n No. 113, de 1987, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de un caso fortuito. </div></div>", "i": 8548845}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de Marzo de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8548846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "292", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-292"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-18", "doble_articulado": false, "id_norma": "135930", "numero_fuente": "33033", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-29", "vigencias": [{"desde": "1988-03-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-03-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "1999-05-07", "fecha_versio