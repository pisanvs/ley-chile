{"html": [{"t": "<div><div class=\"p\">PAPEL SELLADO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 25 de 1824.</div></div>", "i": 10108951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  A consulta de la Illma. Corte de Apelaciones se declara que la lei de papel sellado de 11 de octubre de este a&#xF1;o, impresa en el Boletin n&#xFA;m. 6 lib. 2.&#xB0; no comprende a los instrumentos matrices que se escriben en los protocolos para los que se usar&#xE1; desde principio del a&#xF1;o de 1825 del papel de la tercera clase, espresado en el art. 4.&#xB0; de dicha lei: devu&#xE9;lvase con oficio a la Illma. Corte, t&#xF3;mese raz&#xF3;n donde corresponda e impr&#xED;mase.</div></div>", "i": 10108952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  FREIRE.&nbsp; &nbsp;  Diego Jos&#xE9; Benavente.</div></div>", "i": 10108953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["DEPARTAMENTO DE HACIENDA"], "titulo_norma": "PAPEL SELLADO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-11-25", "doble_articulado": false, "id_norma": "1141762", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-11-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2020-03-17", "fecha_version": "1824-11-25", "f