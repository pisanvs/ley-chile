{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 3.388 EXENTA, DE 2004 </div></div>", "i": 6478028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 3.388, de 29 de abril de 2004, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se revoc&#xF3; la autorizaci&#xF3;n otorgada al organismo t&#xE9;cnico de capacitaci&#xF3;n &quot;Centro de Estudios Sociales y Productivos de Tarapac&#xE1; Ltda.&quot;, RUT N&#xBA; 77.547.650-8, cancel&#xE1;ndose su inscripci&#xF3;n en el Registro Nacional correspondiente, atendido lo dispuesto en el art&#xED;culo 77, letra b) de la ley N&#xBA; 19.518.</div><br></div>", "i": 6478029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eduardo Rodr&#xED;guez Olivares, Jefe Departamento de Capacitaci&#xF3;n en Empresas.</div><br></div>", "i": 6478030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3388 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3388 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 3.388 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-29", "doble_articulado": false, "id_norma": "224908", "numero_fuente": "37855", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-08", "vigencias": [{"desde": "2004-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-05-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in