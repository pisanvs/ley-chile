{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6167796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 348, de 26 de febrero de 1999, se expropiaron los lotes de terreno No. s. 65, 83 y 84, superficies 148, 1.480 y 1.703 m2., roles de aval&#xFA;o 60-5 y 58-7, comuna de Ch&#xE9;pica, obra camino Ch&#xE9;pica - Bif. Teno, sector Cuesta El Peral - Ch&#xE9;pica, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Luis Orlando Donoso Donoso y Gladys Elena Urz&#xFA;a Urz&#xFA;a, ascendente a las cantidades de $ 777.742.- lote 65 y $ 4.738.944.- lotes 83 y 84.-</div><br></div>", "i": 6167797}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6167798}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "348", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-348"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-02-26", "doble_articulado": false, "id_norma": "136154", "numero_fuente": "36353", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-03", "vigencias": [{"desde": "1999-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-05-10", "fecha_version": "1999-05-03", "fecha_actualizacion_texto": "1999-05-03", "tipo_tratado": ""