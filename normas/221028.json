{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 2.097 EXENTA, DE 2004 </div></div>", "i": 6462988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 2.097, de 30 de enero de 2004, sustit&#xFA;yense los dos subsectores de &quot;Iniciaci&#xF3;n a la L&#xF3;gica&quot; y &quot;T&#xE9;cnica de la Investigaci&#xF3;n&quot; del Sector de Historia y Ciencias Sociales, por &quot;L&#xF3;gica y T&#xE9;cnica de la Investigaci&#xF3;n I y II&quot;, el cual se dar&#xE1; en 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media, seg&#xFA;n corresponda, a partir del a&#xF1;o 2004.</div><div class=\"p\">&nbsp; &nbsp;  Ambos subsectores utilizar&#xE1;n los mismos programas ya aprobados en las resoluciones antes mencionadas. </div></div>", "i": 6462989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de febrero de 2004.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6462990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2097 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2097 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 2.097 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-01-30", "doble_articulado": false, "id_norma": "221028", "numero_fuente": "37781", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-09", "vigencias": [{"desde": "2004-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"