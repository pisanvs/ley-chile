{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8337591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.644, de 23 de noviembre de 1998, de esta Subsecretar&#xED;a, autor&#xED;zase a AGAR DEL PACIFICO S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Federico Schwager N&#xBA; 1112, Parque Industrial Escuadr&#xF3;n, comuna de Coronel, VIII Regi&#xF3;n, donde podr&#xE1; procesar en la l&#xED;nea de elaboraci&#xF3;n de Agar-agar, el recurso alga del g&#xE9;nero Gracilaria. </div></div>", "i": 8337592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de noviembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8337593}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1644", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1644"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-23", "doble_articulado": false, "id_norma": "128567", "numero_fuente": "36243", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-19", "vigencias": [{"desde": "1998-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-12-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1998-12-21", "fecha_version": "19