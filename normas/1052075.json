{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N LEGAL PARTIDO ECOLOGISTA VERDE EN VIII REGI&#xD3;N DEL BIOB&#xCD;O</div></div>", "i": 9360802}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El se&#xF1;or Alejandro San Mart&#xED;n Bravo, Presidente de la Directiva Central del Partido Ecologista Verde, ha solicitado la constituci&#xF3;n legal del partido en la VIII Regi&#xF3;n del Biob&#xED;o. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de seis mil doscientas cuarenta y nueve (6.249) fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 10.364, de fecha 13 de junio de 2013.- </div></div>", "i": 9360803}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9360804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10364", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-10364"}, {"tipo": "3", "numero": "O-10364", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-10364"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN LEGAL PARTIDO ECOLOGISTA VERDE EN VIII REGIÓN DEL BIOBÍO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-06-13", "doble_articulado": false, "id_norma": "1052075", "numero_fuente": "40589", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-20", "vigencias": [{"desde": "2013-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v