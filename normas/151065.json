{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6218462}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 873 de 25 de Junio de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Reserva y sector Expropiado Predio &quot;Hijuela V o la Vi&#xF1;a Santa Mariana&quot;, de la comuna de Rengo, VI Regi&#xF3;n; y Derechos Aprovechamiento Aguas que corresponden a 12 parcelas N&#xB0;s. 1 a la 1l, sitios 1 al 14 y Reserva CORA No. 1 del Proyecto de Parcelaci&#xF3;n &quot;El Almendro&quot; formado por predio se&#xF1;alado y otros. Los Derechos de Agua se extraen de desag&#xFC;es Santa Mariana y Derrames del predio Las Virginias.- Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.-</div><br></div>", "i": 6218463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director&#xA8;Ejecutivo.</div><br></div>", "i": 6218464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "873 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-873 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-25", "doble_articulado": false, "id_norma": "151065", "numero_fuente": "32808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-01", "vigencias": [{"desde": "1987-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-01", "fin_vi