{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6227004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1.906 de 09.09.87, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Excluido y Sector Expropiado predio &quot;Santa Helena, Antes San Mart&#xED;n de Malleco&quot;, de la comuna de Angol, IX Regi&#xF3;n: y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 1 a la 25 y sitios N&#xB0;s. 1 al 6 del Provecto d&#xE9; Parcelaci&#xF3;n &quot;Unidad Campesina&quot;. formado por predio se&#xF1;alado. Los Derechos de Agua se extraen del Canal Santa Elena y del Estero Lolenco derivados del R&#xED;o Malleco.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.- </div></div>", "i": 6227005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejec&#xFA;tivo.</div><br></div>", "i": 6227006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1906 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1906 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-09", "doble_articulado": false, "id_norma": "153786", "numero_fuente": "32871", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-15", "vigencias": [{"desde": "1987-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni