{"html": [{"t": "<div><div class=\"p\">ACLARA DESLINDES EXPROPIACION </div></div>", "i": 8677319}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Alcaldicio No. 765 de 9 de julio de 1987 se aclara el Decreto No. 1581 de diciembre 12 de 1986 que orden&#xF3; la expropiaci&#xF3;n de un terreno ubicado en la comuna de Renca necesario para la apertura y/o ensanche de la Avda. Balmaceda, entre las calles Manuel Rodr&#xED;guez y Colo Colo, s&#xF3;lo en el sentido de agregar al final del punto No. 2 el deslinde particular del terreno expropiado se&#xF1;alado en el plano archivado en el Conservador de Bienes Ra&#xED;ces de Santiago, bajo el No. 28804 el cual es el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Norte&nbsp;  : 14,50 m. con resto de la misma propiedad</div><div class=\"p\">&nbsp; &nbsp;  Sur&nbsp; &nbsp;  : 14,50 m. calle Balmaceda</div><div class=\"p\">&nbsp; &nbsp;  Oriente : 12,00 m. con parte expropiada a Octavio</div><div class=\"p\">Beserer</div><div class=\"p\">&nbsp; &nbsp;  Poniente: 12,00 m. con parte expropiada a Norma y Ram&#xF3;n</div><div class=\"p\">Ortega.-</div><br></div>", "i": 8677320}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alcalde.</div><br></div>", "i": 8677321}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "765", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-765"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "ACLARA DESLINDES EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-09", "doble_articulado": false, "id_norma": "173271", "numero_fuente": "32820", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-0