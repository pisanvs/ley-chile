{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9249718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;609, de 29 de marzo de 2012, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xB0;, 5&#xB0; y 6&#xB0;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1030472&amp;idParte=0&amp;idVersion=\">Decreto Exento MOP. N&#xB0;2195, de 31 de agosto de 2011</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xB0;19, expropiado con motivo de la obra &quot;Camino Ruta 7, Sector Lenca - Chaica, Tramo Km. 27,89372 a Km. 33,17100&quot;. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijado mediante tasaci&#xF3;n de 9 de marzo de 2010, complementada por acta de fecha 25 de abril de 2011, en la suma de $366.000.</div><br></div>", "i": 9249719}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9249720}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "609 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-609 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-29", "doble_articulado": false, "id_norma": "1039182", "numero_fuente": "40238", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-16", "vigencias": [{"desde": "2012-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":