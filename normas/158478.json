{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6241969}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 84, del 17 de Abril de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IV Regi&#xF3;n de Coquimbo, se autoriza a don Emilio Segundo Pi&#xF1;ones Le&#xF3;n para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6241970}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 21 de Abril de 1986.- Jorge Vargas Borcosky, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6241971}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "84 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-84 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-17", "doble_articulado": false, "id_norma": "158478", "numero_fuente": "32464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-05-07", "vigencias": [{"desde": "1986-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-05-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-05-07", "fin_vigencia": "", "tipo_ver