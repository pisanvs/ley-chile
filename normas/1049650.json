{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N LEGAL DEL PARTIDO IGUALDAD</div></div>", "i": 9339951}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Iv&#xE1;n Carrasco Mora, Secretario General de la Directiva Central del Partido Igualdad, ha solicitado la constituci&#xF3;n legal del partido en la XI Regi&#xF3;n de Ays&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de trescientas setenta y cinco (375) afiliaciones.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O - N&#xBA; 242, de fecha 19 de marzo de 2013.- </div></div>", "i": 9339952}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9339953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "242", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-242"}, {"tipo": "3", "numero": "O-242", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-242"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN LEGAL DEL PARTIDO IGUALDAD", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-19", "doble_articulado": false, "id_norma": "1049650", "numero_fuente": "40518", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-03-25", "vigencias": [{"desde": "2013-03-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-03-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v