{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA PAGO EN MONEDA EXTRANJERA DEL IMPUESTO QUE INDICA</div></div>", "i": 9624030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 61, de 20 de julio de 2015.</div><div class=\"p\">&nbsp; &nbsp;  Autoriza el pago en d&#xF3;lares de Estados Unidos de Norteam&#xE9;rica y euros para los contribuyentes que paguen impuesto del <a href=\"https://www.leychile.cl/Navegar?idNorma=1067194&amp;idParte=9509286&amp;idVersion=\">art&#xED;culo vigesimocuarto transitorio</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1067194&amp;idParte=0&amp;idVersion=\">ley N&#xBA; 20.780</a>, de 2014.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de julio de 2015.</div></div>", "i": 9624031}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Alberto Rojas Barranti, Director (S).</div></div>", "i": 9624032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-61 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA PAGO EN MONEDA EXTRANJERA DEL IMPUESTO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-07-20", "doble_articulado": false, "id_norma": "1079821", "numero_fuente": "41215", "tipo_version": "3",