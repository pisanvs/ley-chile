{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;336, de 13 de marzo de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;janse sin efecto las resoluciones N&#xBA;1.009, N&#xBA;1.014, N&#xBA;1.017, N&#xBA;1.550, N&#xBA;1.551 y N&#xBA;1.555, todas de 1997, de la Subsecretar&#xED;a de Pesca, por haberse emitido &#xE9;stas con un error de hecho. </div></div>", "i": 8328651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de marzo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8328652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "336", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-336"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "VICTOR JOSE MIGUEL SHARP VLADILO", "MABEL DEL CARMEN ALVAREZ PINTO", "ROBERTO ORLANDO ESTEBAN RUIZ CAMPILLO", "JOSE ROBERTO CAIPILLAN DELGADO", "VICTOR JOSE ALMONACID RUIZ", "NATALES", "CHONCHI", "QUINCHAO", "QUELLON", "DECIMA REGION", "DECIMOSEGUNDA REGION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-13", "doble_articulado": false, "id_norma": "97354", "numero_fuente": "36021", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-21", "vigencias": [{"desde": "1998-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-03-21", "fin_vigencia": ""}, "vigencias_version_no