{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 02</div><br><div class=\"p\">Certifico que el Consejo de este Banco Central de Chile en su Sesi&#xF3;n No. 02, celebrada el 13 de diciembre de 1989, adopt&#xF3; los siguientes acuerdos:</div><br></div>", "i": 6101457}, {"t": "<div><div class=\"p\">02-05-891206 Elecci&#xF3;n de Vicepresidente del Consejo y del Banco Central de Chile.</div><div class=\"p\">El Consejo, por la unanimidad de sus miembros, acord&#xF3; elegir, como Vicepresidente del Consejo y del Banco Central de Chile, a contar desde el 13 de diciembre de 1989, al Consejero don Alfonso Serrano Spoerer.</div><br></div>", "i": 6101458}, {"t": "<div><div class=\"p\">Santiago, 15 de diciembre de 1989.- V&#xED;ctor Vial del Rio, Secretario General Interino.</div><br></div>", "i": 6101459}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-02"}, {"tipo": "5", "numero": "02-05", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-02-05"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE\nEN SU SESION No. 02", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-13", "doble_articulado": false, "id_norma": "95941", "numero_fuente": "33548", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-18", "vigencias": [{"desde": "1989-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-18", "fin_vigencia": ""}, "vigen