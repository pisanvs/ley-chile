{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,275, que concede derecho a jubilar a don Manuel Montero.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,275.-</div><div class=\"p\">&nbsp; &nbsp; Pro cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 5955431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al Ministro de la Corte Suprema don Manuel Montero, el derecho de jubilar con una pension equivalente al sueldo &#xED;ntegro del empleo que actualmente desempe&#xF1;a.</div><br></div>", "i": 5955432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a cuatro de Setiembre de mil novecientos diecisiete.- JUAN LUIS SANFUENTES.- Anjel Guarello. </div></div>", "i": 5955433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3275", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3275"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "LEI NUM. 3,275, QUE CONCEDE DERECHO A JUBILAR A DON MANUEL MONTERO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANUEL MONTERO", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-09-04", "doble_articulado": false, "id_norma": "23858", "numero_fuente": "11867", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-09-07", "vigencias": [{"desde": "1917-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc