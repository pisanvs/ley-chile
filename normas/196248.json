{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6375056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 397 de fecha 25 de febrero del 2002, se expropi&#xF3; el lote de terreno N&#xBA; 66, superficie 285 m2, rol de aval&#xFA;o N&#xBA; 159-35, comuna de Ranquil, para la obra &quot;Camino Ruta O-66-N, Sector Nueva Aldea-&#xD1;ipas, Tramo I Km. 0,00000 a Km. 5,58300&quot;, VIII Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Mar&#xED;a In&#xE9;s Venegas Dur&#xE1;n, ascendente a la cantidad de $21.884.100.</div><br></div>", "i": 6375057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6375058}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "397", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-397"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-25", "doble_articulado": false, "id_norma": "196248", "numero_fuente": "37223", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-01", "vigencias": [{"desde": "2002-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-04-01", "fecha_version": "2002-04-01", "fecha_actualizacion_texto": "2002-04-01", "tipo_tratado": ""}, "alertas": [], "alerta_global