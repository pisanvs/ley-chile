{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,367.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 9050972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al capitan de Ej&#xE9;rcito, don Luis Aro, para los efectos de su retiro, el abono de los ocho a&#xF1;os y tres dias, que sirvi&#xF3; en la polic&#xED;a de Santiago&quot;.</div><br></div>", "i": 9050973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, catorce de mayo de mil novecientos dieciocho.- Juan Luis Sanfuentes.- Jorje Valdivieso Blanco. </div></div>", "i": 9050974}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3367", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3367"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-05-14", "doble_articulado": false, "id_norma": "141112", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-08-23", "vigencias": [{"desde": "1918-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-08-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "19