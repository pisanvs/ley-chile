{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329325}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA; 528, de 8 de abril de 1998, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura N&#xBA; 95104043, presentada por AQUACHILE S.A., para operar un centro de cultivo en Sector Punta Centinela, Isla Puluqui, comuna de Calbuco, provincia de Llanquihue, X Regi&#xF3;n, conforme lo dispuesto en los art&#xED;culos 78 y 87 de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8329326}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 8 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329327}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "528", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-528"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "CALBUCO", "AQUACHILE S.A.", "DECIMA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-08", "doble_articulado": false, "id_norma": "98321", "numero_fuente": "36048", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-04-24", "vigencias": [{"desde": "1998-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-04-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-04-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ing