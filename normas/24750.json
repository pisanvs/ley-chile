{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuando el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 8277513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para traspasar de 04|02|01, del Presupuesto del Interior vigente, las cantidades que se indican, a los rubros que se expresan:</div><div class=\"p\">&nbsp; &nbsp; A 04|01|02|j|2, que consulta fondos para impresiones y publicaciones del Ministerio del Interior, incluso el Diario Oficial, 35,000 pesos;</div><div class=\"p\">&nbsp; &nbsp; A 04|01|02|k|3, que consulta fondos para gastos generales para las oficinas del Ministerio, $ 17,000. </div></div>", "i": 8277514, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, catorce de Diciembre de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez C.- Guillermo Edwards Matte. </div></div>", "i": 8277515}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4499", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4499"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1928", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-12-14", "doble_articulado": false, "id_norma": "24750", "numero_fuente": "15282", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-01-25", "vigencias": [{"desde": "192