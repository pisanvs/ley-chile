{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 8356434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 531 del 24 de Diciembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo, se autoriza a don Hugo Humberto Acosta Robles, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 8356435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 24 de Diciembre de 1986.- Jorge Vargas Borcosky, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 8356436}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "531 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-531 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-24", "doble_articulado": false, "id_norma": "151128", "numero_fuente": "32813", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-07", "vigencias": [{"desde": "1987-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ing