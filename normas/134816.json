{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,490.- Santiago, 7 de diciembre de 1901.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6163523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion de los importantes servicios prestados durante la guerra contra el Per&#xFA; i Bolivia por el coronel graduado de Ej&#xE9;rcito, don Francisco Mu&#xF1;oz Bezanilla, conc&#xE9;dese por gracia a su viuda do&#xF1;a Selima Brice&#xF1;o derecho a disfrutar de la pension que corresponde al empleo de coronel, muerto en accion de guerra, en vez de la que actualmente percibe.</div><br></div>", "i": 6163524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.-</div><div class=\"p\">B. Mathieu.</div><br></div>", "i": 6163525}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1490", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1490"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-07", "doble_articulado": false, "id_norma": "134816", "numero_fuente": "7093", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-10", "vigencias": [{"desde": "1901-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-12-10