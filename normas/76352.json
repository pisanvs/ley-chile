{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6047515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 800, de 29 de agosto de 1997, se expropiaron los lotes de terreno N&#xBA;s 12 y 52, superficies 135 y 1.000 m2., roles de aval&#xFA;o 3330-7 y 2590-109, comuna de San Bernardo, respectivamente, para la obra Estudio de Anteproyecto e Ingenier&#xED;a, para el Sistema Norte - Sur, sector Las Acacias - R&#xED;o Maipo y se acord&#xF3; precio de indemnizaci&#xF3;n con los propietarios Juan Osvaldo Venegas Mu&#xF1;oz e Ignacio Aguerrebere Mardones, ascendentes a las cantidades de $11.665.872, para el lote N&#xBA; 12, y $49.450.672, para el lote N&#xBA; 52.- </div></div>", "i": 6047516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6047517}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "800", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-800"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SAN BERNARDO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-29", "doble_articulado": false, "id_norma": "76352", "numero_fuente": "35891", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-15", "vigencias": [{"desde": "1997-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion