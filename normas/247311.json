{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE LOS VILOS</div><br><br><br><br></div>", "i": 6561334}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA;474 del 24 de enero de 2006, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, aprob&#xF3; Estudio T&#xE9;cnico que determina derechos de aprovechamiento de aguas del predio &quot;Fundo Mauro&quot;, de la comuna de Los Vilos, provincia de Choapa, IV Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Los derechos de aprovechamiento de aguas consisten en 135,5 litros por segundo que se extraen del r&#xED;o Pup&#xED;o, los que son consuntivos, de ejercicio permanente y continuo.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; ley N&#xBA;18.377.</div><br></div>", "i": 6561335}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Nacional.</div><br></div>", "i": 6561336}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "474 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-474 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE LOS VILOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS APROVECHAMIENTO DE AGUA", "COMUNA LOS VILOS", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-24", "doble_articulado": false, "id_norma": "247311", "numero_fuente": "38390", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-02-15", "vigencias": [{"desde": "2006-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "