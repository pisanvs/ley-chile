{"html": [{"t": "<div><div class=\"p\">INFORMA DICTACION DE MODIFICACION DE ORDENANZA </div></div>", "i": 6532119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se comunica que la Ilustre Municipalidad de La Pintana, con acuerdo del Concejo Municipal, manifestado en la 11&#xBA; Sesi&#xF3;n Ordinaria de fecha 7 de junio de 2005, ha acordado modificar la Ordenanza de Derechos Municipales, la cual se ha sancionado con el N&#xBA; 1 del 28 de junio de 2005, la que comenzar&#xE1; a regir a contar del 1 de julio de 2005. El texto puede ser adquirido en la Secretar&#xED;a Municipal de la Municipalidad de La Pintana. </div></div>", "i": 6532120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Jaime Pavez Moreno, Alcalde.- Angela Alvear Morales, Secretario Municipal.</div><br></div>", "i": 6532121}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1"}], "organismos": ["MUNICIPALIDAD DE LA PINTANA"], "titulo_norma": "INFORMA DICTACION DE MODIFICACION DE ORDENANZA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-28", "doble_articulado": false, "id_norma": "239891", "numero_fuente": "38203", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-06", "vigencias": [{"desde": "2005-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po