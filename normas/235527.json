{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6516113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 1.719, de 21 de diciembre de 2004, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del decreto exento MOP N&#xBA; 2.027, de 28 de diciembre de 2001, en la parte que se refiere al Convenio Directo de Precio Ad Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 97, fijada por la Comisi&#xF3;n de Peritos, con fecha 10 de julio de 1998, ascendente a la cantidad de $382.600.</div><br></div>", "i": 6516114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6516115}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1719 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1719 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-21", "doble_articulado": false, "id_norma": "235527", "numero_fuente": "38087", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-02-15", "vigencias": [{"desde": "2005-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-02-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-02-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fech