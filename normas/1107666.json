{"html": [{"t": "<div><div class=\"p\">DELEGACI&#xD3;N DE FACULTADES QUE INDICA</div></div>", "i": 9831718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Salud Metropolitano Central N&#xBA; 1.041, de 24 de abril de 2017, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Del&#xE9;gase en el Director(a) del Centro Metropolitano de Atenci&#xF3;n Prehospitalaria del Servicio de Salud Metropolitano Central, las facultades relativas a administraci&#xF3;n de personal; materias financieras, presupuestarias y contables; y de recursos f&#xED;sicos y gesti&#xF3;n, que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web del Samu Metropolitano (www.samu.cl).</div></div>", "i": 9831719}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eduardo Bartolom&#xE9; Bachelet, Director (S), Servicio de Salud Metropolitano Central.</div></div>", "i": 9831720}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1041 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1041 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "SUBSECRETARÍA DE REDES ASISTENCIALES", "SERVICIO DE SALUD METROPOLITANO CENTRAL XIII REGIÓN METROPOLITANA"], "titulo_norma": "DELEGACIÓN DE FACULTADES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1268123; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-04-24", "doble_articulado": false, "id_norma": "1107666", "numero_fuente": "41854", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-09-07", "vigencias": [{"desde": "2017-09-07", "hasta": "", "tipo_version"