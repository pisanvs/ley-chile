{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7277627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.128, de 29 de septiembre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ISLA DEL REY S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 1.930, de 1995, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Los Condestables N&#xBA; 390, Niebla, Valdivia, X Regi&#xF3;n, la l&#xED;nea de proceso de ahumado, respecto de los recursos autorizados en resoluci&#xF3;n N&#xBA; 1.930, de 1995.</div><br></div>", "i": 7277628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de septiembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 7277629}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2128", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2128"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-29", "doble_articulado": false, "id_norma": "176604", "numero_fuente": "36786", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-13", "vigencias": [{"desde": "2000-10-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "m