{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6219438}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 289, de 13 de Julio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XII Regi&#xF3;n, Magallanes y Ant&#xE1;rtica Chilena, se autoriza a Catalina Kusanovic Mihovilovic para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional; a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbana de pasajeros.-</div><br></div>", "i": 6219439}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Urbano Peralta, Secretario Regional Ministerial de Transportes y Telecomunicaciones XII Regi&#xF3;n.</div><br></div>", "i": 6219440}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "289 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-289 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XII REGIÓN DE MAGALLANES Y ANTÁRTICA CHILENA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-13", "doble_articulado": false, "id_norma": "151361", "numero_fuente": "32827", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-23", "vigencias": [{"desde": "1987-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-23", "fin_vigencia": "",