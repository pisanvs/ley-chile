{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION PARCIAL DE INMUEBLE QUE INDICA </div></div>", "i": 6104718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.080 de 3 de diciembre de 1997 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, parte inmueble ubicado en Avda. Santa Mar&#xED;a N&#xBA; 4176, presunto rol de aval&#xFA;os N&#xBA; 476-1 comuna de Renca, de aparente dominio de don Hugo Salinas Alvarado. Comisi&#xF3;n integrada por peritos Sra. Patricia Zavala Contreras, constructor civil, Jorge Navarro Navarrete, arquitecto y Ram&#xF3;n Undurraga Montes, ingeniero civil, seg&#xFA;n informe de 9 de octubre de 1997 fij&#xF3; monto provisional de indemnizaci&#xF3;n en $9.718.080.- pagadera al contado.-</div><br></div>", "i": 6104719}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6104720}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1080", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1080"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANISMO", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACION PARCIAL DE INMUEBLE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "RENCA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-03", "doble_articulado": false, "id_norma": "96950", "numero_fuente": "36004", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-02", "vigencias": [{"desde": "1998-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v