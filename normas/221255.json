{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 30 EXENTA, DE 10 DE FEBRERO DE 2004 </div></div>", "i": 6464544}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se autoriza a ZAP Televisi&#xF3;n Satelital Directa al Hogar, RUT 76.020.870-1, a emitir Boletas Electr&#xF3;nicas y Boletas Electr&#xF3;nicas de Ventas y Servicios no Afectos o Exentos de IVA. En la citada resoluci&#xF3;n se establecen los procedimientos que deber&#xE1; cumplir el contribuyente, en relaci&#xF3;n a estos documentos electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII de febrero de 2004.</div><br></div>", "i": 6464545}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "30 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-30 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 30 EXENTA, DE 10 DE FEBRERO DE\n2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BOLETAS ELECTRONICAS", "ZAP TELEVISION SATELITAL DIRECTA AL HOGAR", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-10", "doble_articulado": false, "id_norma": "221255", "numero_fuente": "37786", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-14", "vigencias": [{"desde": "2004-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_