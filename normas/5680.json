{"html": [{"t": "<div><div class=\"p\">Modifica decreto C. F. L. N.o 241</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 32.- Santiago, 15 de Junio de 1932.-</div><div class=\"p\">&nbsp; &nbsp; La Junta de Gobierno ha acordado y Decreta:</div><br><br></div>", "i": 8255704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Reempl&#xE1;zase el art&#xED;culo 5.o del decreto con fuerza de ley N.o 241, de 15 de Mayo de 1931, por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art. 5.o La administraci&#xF3;n superior de la Empresa estar&#xE1; a cargo de un Consejo formado por un presidente y ocho consejeros nombrados por el Presidente de la Rep&#xFA;blica&quot;.</div><br></div>", "i": 8255705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- ARTURO PUGA.- Eugenio Matte.- Rolando Merino Reyes.- A. Ruiz M. </div></div>", "i": 8255706}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "32", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-32"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA DECRETO N° 241", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-06-15", "doble_articulado": false, "id_norma": "5680", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-06-22", "vigencias": [{"desde": "1932-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones