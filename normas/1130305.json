{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N DE DELEGACI&#xD3;N DE FACULTADES</div></div>", "i": 10013731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Director Regional del Servicio de Impuestos Internos, Direcci&#xF3;n Regional Valdivia, de conformidad al Art.13 Inc. final del C&#xF3;digo Tributario, dispone publicar el siguiente extracto. El 28.03.2019 se dict&#xF3; Resoluci&#xF3;n N&#xB0; 94, relativa a delegaci&#xF3;n de facultades de autorizaci&#xF3;n al pago diferido de Impuesto a la Renta AT 2019, en los funcionarios que all&#xED; se se&#xF1;alan.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra a disposici&#xF3;n del contribuyente en el Departamento de Fiscalizaci&#xF3;n de dicha Direcci&#xF3;n Regional.- </div></div>", "i": 10013732}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jimena Castillo Bascu&#xF1;&#xE1;n, Directora Regional.</div></div>", "i": 10013733}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "94", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-94"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL VALDIVIA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN DE DELEGACIÓN DE FACULTADES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1571000", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-03-28", "doble_articulado": false, "id_norma": "1130305", "numero_fuente": "42323", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-04-05", "vigencias": [{"desde": "2019-04-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-04-05", "fi