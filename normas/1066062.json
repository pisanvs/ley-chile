{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9502511}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.226, de 25 de agosto de 2014, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1028908&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.107, de 2011</a>, s&#xF3;lo en cuanto autoriz&#xF3; a Pesquera Centro Sur S.A., hoy PESQUERA CENTRO SUR SpA, para realizar actividades pesqueras extractivas con la nave &quot;Toyita&quot;, respecto de los recursos hidrobiol&#xF3;gicos Jibia, Congrio dorado y Raya en el &#xE1;rea mar&#xED;tima correspondiente a la V a VII y IX Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9502512}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de agosto de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9502513}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2226 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2226 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-08-25", "fecha_derogacion": "2015-09-30", "doble_articulado": false, "id_norma": "1066062", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2014-09-03", "vigencias": [{"desde": "2015-09-30", "hasta":