{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA ORDENANZA N&#xB0; 55 DE 1992</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 5.- Santiago, 25 de enero de 1993:</div><br></div>", "i": 9047394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.- Modif&#xED;case la Ordenanza N&#xB0; 55, de 25 de septiembre de 1992, sobre la Feria Persa Internacional, en el siguiente sentido:</div><div class=\"p\">&nbsp; &nbsp; En el Art&#xED;culo 8&#xB0; se sustituyen los n&#xFA;meros 53 y 55 por &quot;56 y 58&quot;, respectivamente.</div><div class=\"p\">&nbsp; &nbsp; En el Art&#xED;culo 12&#xB0; se sustituye: &quot;Ordenanza sobre Permisos y Derechos Municipales&quot; por &quot;Ordenanza sobre Derechos Municipales por Permisos, Concesiones y Servicios Municipales&quot;.</div><div class=\"p\">&nbsp; &nbsp; En el Art&#xED;culo 15&#xB0;, letra a) se elimina la frase &quot;en la administraci&#xF3;n respectiva&quot;.</div><div class=\"p\">&nbsp; &nbsp; En el Art&#xED;culo 24&#xB0; se sustituye el n&#xFA;mero 14 por &quot;21&quot;.</div><br></div>", "i": 9047395}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "5", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-5"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "MODIFICA ORDENANZA N° 55 DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD SANTIAGO", "MODIFICACION ORDENANZA MUNICIPAL", "DERECHOS MUNICIPALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-01-25", "doble_articulado": false, "id_norma": "30987", "numero_fuente": "34479-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-01-30", "vigencias": [{"desde": "1993-01-30", "hasta": "", "tipo_version": "3", "tip