{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6274315}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 259, de 4 de Marzo de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se declara la caducidad de las siguientes autorizaciones, de conformidad a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n: a) Resoluci&#xF3;n No. 1283, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD VALMAR LIMITADA, domiciliada en Valdivia, para desarrollar actividades pesqueras de transformaci&#xF3;n. b) Resoluci&#xF3;n No. 291, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Sociedad Valmar Limitada, domiciliada en Valdivia, para desarrollar actividades pesqueras de transformaci&#xF3;n.</div><br></div>", "i": 6274316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de Marzo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 6274317}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "259", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-259"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-04", "doble_articulado": false, "id_norma": "168328", "numero_fuente": "33939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-10", "vigencias": [{"desde": "1991-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {