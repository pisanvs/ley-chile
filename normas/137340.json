{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,377.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase a seis mil pesos ($ 6,000) la pensi&#xF3;n anual de que disfrutan la viuda e hijos del capitan de nav&#xED;o don Manuel Thompson.</div><br></div>", "i": 6171675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintinueve de agosto de mil novecientos diez.- Emiliano Figueroa.- C&#xE1;rlos Larrain Claro. </div></div>", "i": 6171676}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2377", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2377"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-08-29", "doble_articulado": false, "id_norma": "137340", "numero_fuente": "9793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-09-14", "vigencias": [{"desde": "1910-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-09-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-06-07", "fecha_version": "1910-09-14", "fec