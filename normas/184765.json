{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6332944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 336, de 28 de febrero de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 20, superficie 7.552 m&#xB2;., rol de aval&#xFA;o 154-100, comuna de Casablanca, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago-Valpara&#xED;so-Vi&#xF1;a del Mar, Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Mar&#xED;a Eujenia Alvarez de la Rivera Zanetta, ascendente a la cantidad de $37.077.758.</div><br></div>", "i": 6332945}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6332946}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "336", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-336"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-28", "doble_articulado": false, "id_norma": "184765", "numero_fuente": "36951", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-02", "vigencias": [{"desde": "2001-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-05-02", "fecha_version": "2001-05-02", "fecha_actualizacion_texto": "2001-05-02", "tipo_tratado": ""}, "alertas": [], "alerta_g