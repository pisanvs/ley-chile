{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA DECRETO N&#xB0; 87 EXENTO, DE 1990</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 501 exento.- Santiago, 24 de Septiembre de 1993.- Visto: Lo dispuesto en las Leyes N&#xB0;s. 18.956 y 18.962; Decretos Supremos de Educaci&#xF3;n N&#xB0;s. 2.039 y 9.555, ambos de 1980; Resoluci&#xF3;n N&#xB0; 55, de 1992 de la Contralor&#xED;a General de la Rep&#xFA;blica; y en los art&#xED;culos 32 N&#xB0; 8 y 35 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7161998}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: Modif&#xED;case el Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 87 de 1990, en el sentido de establecer como duraci&#xF3;n m&#xED;nima de la clase para los cursos talleres del nivel laboral, 40 minutos.</div><br></div>", "i": 7161999, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese y publ&#xED;quese.- Por orden del Presidente de la Rep&#xFA;blica.- Jorge Arrate Mac Niven, Ministro de Educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a usted para su conocimiento.- Saluda a usted.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162000}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "501 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-501 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "MODIFICA DECRETO N° 87 EXENTO, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TALLERES", "CLASES", "DEFICIENTE MENTAL", "ESTABLECIMIENTOS EDUCACIONALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulg