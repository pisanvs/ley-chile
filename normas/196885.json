{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6377417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 263, de 31 de enero de 2002, se expropi&#xF3; el lote de terreno N&#xBA; 23-E1, superficie 613 m2, rol de aval&#xFA;o 50-4, comuna de Purranque, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo R&#xED;o Bueno Puerto Montt, Sector Poblaci&#xF3;n Dollinco, de Kms. 957,100 al 957,400, D&#xE9;cima Regi&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Bertoldo Quezado Sayada, ascendente a la cantidad de $45.485.731.- </div></div>", "i": 6377418}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6377419}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "263", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-263"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-31", "doble_articulado": false, "id_norma": "196885", "numero_fuente": "37235", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-15", "vigencias": [{"desde": "2002-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-04-17", "fecha_version": "2002-04-15", "fecha_actualizacion_texto": "2002-04-15", "tipo_tratado": ""}, "alertas": [], "aler