{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m.&nbsp; 1,124.- Santiago, 30 de noviembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6161583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Decl&#xE1;rase de abono al ex- sarjento-mayor don Francisco J. Herreros, para los efectos de su retiro, cinco a&#xF1;os nueve meses i once dias que sirvi&#xF3; como oficial ausiliar en la Tesorer&#xED;a Jeneral de Santiago. </div></div>", "i": 6161584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- V. Blanco.</div><br></div>", "i": 6161585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1124", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1124"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-11-30", "doble_articulado": false, "id_norma": "134190", "numero_fuente": "6169", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-06", "vigencias": [{"desde": "1898-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-12-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-03-30", "fecha_version": "1