{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXPROPIATORIO </div></div>", "i": 6410292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto N&#xBA; 811 del 9 de diciembre 2002, se dispuso expropiaci&#xF3;n inmueble ubicado en la localidad de Corinto de E.F.E. inscrito a fs. 1.264 vta.</div><div class=\"p\">N&#xBA; 1.229 a&#xF1;o 1969 del CBR Talca a&#xF1;o 1969, Rol pago contribuciones 91124-1 de 2001, de 699 m2; deslindes Norte en 15 metros con Guillermo Cruz, Sur en 15 metros con v&#xED;a f&#xE9;rrea, Este en 46,60 metros con Guillermo Cruz, Oeste en 46,60 metros con Lote Nor-Oriente resto propiedad.</div><br><div class=\"p\">&nbsp; &nbsp;  Se publica presente extracto de decreto referido para efectos decreto ley 2.186 de junio 1978.</div><br><br></div>", "i": 6410293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Pencahue, diciembre 23 de 2002.- Lucy Lara Leiva, Alcaldesa.</div><br></div>", "i": 6410294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "811", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-811"}], "organismos": ["MUNICIPALIDAD DE PENCAHUE"], "titulo_norma": "EXTRACTO DE DECRETO EXPROPIATORIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-09", "doble_articulado": false, "id_norma": "206738", "numero_fuente": "37459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-15", "vigencias": [{"desde": "2003-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-15", "fin_vigencia": "", "tipo_version": "3"}], "even