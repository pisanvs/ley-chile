{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,274, que da el nombre de Perquenco a la Comuna de Quillen.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,274.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- La comuna de Quillen, del departamento de Traiguen, se denominar&#xE1; en lo sucesivo comuna de Perquenco.</div><br></div>", "i": 8276134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiocho de Agosto de mil novecientos diecisiete.- JUAN LUIS SANFUENTES.- Ismael Tocornal. </div></div>", "i": 8276135}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3274", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3274"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NÚM. 3.274, QUE DA EL NOMBRE DE PERQUENCO A LA COMUNA DE QUILLEN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["QUILLEN", "PERQUENCO", "TRAIGUEN", "COMUNA", "DEPARTAMENTO", "DENOMINACION", "CAMBIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-08-28", "doble_articulado": false, "id_norma": "23857", "numero_fuente": "11868", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-09-08", "vigencias": [{"desde": "1917-09-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1917-09-08", "fin_vigencia": ""}, "vigencias_