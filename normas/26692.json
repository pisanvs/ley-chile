{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL ARTICULO 8&#xB0; DE LA LEY N&#xB0; 10,437, DE SEPTIEMBRE DE 1952</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Honorable Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5969459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase, en el art&#xED;culo 8&#xB0; de la ley N&#xB0; 10,437, de fecha 22 de Septiembre de 1952, la frase &quot;L&#xED;nea A&#xE9;rea Nacional&quot; por &quot;Fuerza A&#xE9;rea de Chile&quot;.</div><br></div>", "i": 5969460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, siete de Abril de mil novecientos cincuenta y cuatro.- CARLOS IBA&#xD1;EZ DEL CAMPO.- A. Parra U.</div><br></div>", "i": 5969461}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11517", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11517"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "MODIFICA EL ARTICULO 8° DE LA LEY N° 10,437, DE\nSEPTIEMBRE DE 1952", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 10437", "CESION GRATUITA", "DONACION", "TRANSFERENCIA GRATUITA", "FUERZA AEREA CHILE", "TERRENO", "BIEN RAIZ", "MUNICIPALIDAD PUERTO MONTT"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1954-04-07", "doble_articulado": false, "id_norma": "26692", "numero_fuente": "22837", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1954-05-03", "vigencias": [{"desde":