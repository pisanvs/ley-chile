{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6379768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;423 de 28 de febrero del 2002, se modific&#xF3; el decreto MOP N&#xBA;107, de 28 de febrero del 2001, que orden&#xF3; la expropiaci&#xF3;n de los lotes 1 al 61, en cuanto a que por una parte se rectific&#xF3; el numeral 2&#xBA;, en la parte que se refiere al nombre del propietario de los lotes 51 al 61 que es &quot;Comunidad Orrego&quot; y no como en &#xE9;l se indican, asimismo se dejaron sin efecto los numerales 3&#xBA; y 7&#xBA;, en cuanto a que la indemnizaci&#xF3;n definitiva de la expropiaci&#xF3;n, m&#xE1;s su correspondiente reajuste, es la suma de $8.174.143.- para los lotes N&#xBA;1 al 50 y $2.317.174.- para los lotes N&#xBA;51 al 61.-</div><br></div>", "i": 6379769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6379770}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "423", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-423"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-28", "doble_articulado": false, "id_norma": "197547", "numero_fuente": "37248", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-02", "vigencias": [{"desde": "2002-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi