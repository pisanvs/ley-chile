{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A IANSAGRO S.A.</div><br></div>", "i": 6520870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08 N&#xBA; Ex. 451 de fecha 17 de marzo de 2005, otorga a Iansagro S.A., RUT. N&#xBA;90.278.000-9, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las ventas de Trigo, establecido en la resoluci&#xF3;n N&#xBA; Ex-5281, de 30-11-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida. </div></div>", "i": 6520871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 17 de marzo de 2005.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6520872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "451 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-451 EXENTA"}, {"tipo": "3", "numero": "DRE-08-451 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-451 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A IANSAGRO\nS.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-17", "doble_articulado": false, "id_norma": "236815", "numero_fuente": "38124", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-01", "vigencia