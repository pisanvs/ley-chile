{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; TRASPASA FONDOS</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 396.- Santiago, 9 de Agosto de 1932.- Vistos estos antecedentes, el Presidente Provisional de la Rep&#xFA;blica ha acordado y dicta el siguiente,</div><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br></div>", "i": 8256056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Trasp&#xE1;sase la cantidad de doce mil pesos ($ 12,000), de 04/01/04/v) a 04/03/01.</div><br></div>", "i": 8256057, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Se fija en dos el n&#xFA;mero de cargos de inspectores visitadores, grado 5.o, de la planta de los servicios de Correos y Tel&#xE9;grafos, a que se refiere el decreto con fuerza de ley N.o 3,437, de 28 de Julio de 1930, y el decreto supremo N.o 1,823, de 19 de Mayo de 1931, del Ministerio del Interior.</div><br></div>", "i": 8256058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 3.o El presente decreto-ley empezar&#xE1; regir desde el 1.o de Agosto del a&#xF1;o en curso.</div><br></div>", "i": 8256059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de Leyes y Decretos del Gobierno.- CARLOS DAVILA.- Joaqu&#xED;n Fern&#xE1;ndez F.- Enrique Za&#xF1;artu.</div><br></div>", "i": 8256060}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "396", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-396"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "TRASPASA FONDOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1932", "MODIFICACION", "CORREOS Y TELEGRAFOS", "SERVICIOS", "PERSONAL", "PLANTA", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-08-09", "doble_articulado": false, "id_norma": "6047", "numero_fuente": "16352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-08-18", "vigencias": [{"desde": "1932-08-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-08-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-08-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}, {"text": "CONCORDANCIA", "url_part": "concordancia"}], "fecha_version": "1932-08-18", "fecha_actualizacion_texto": "1932-08-18", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8256056}, {"n": "Artículo 1", "i": 8256057, "t": 6}, {"n": "Artículo 2", "i": 8256058, "t": 6}, {"n": "Artículo 3", "i": 8256059, "t": 6}, {"n": "Promulgación", "i": 8256060}]}