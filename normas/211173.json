{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6426675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 268 de fecha 28 de marzo del 2003, se expropi&#xF3; el lote de terreno N&#xBA; 14-C, superficie 22.005 m&#xB2;, rol de aval&#xFA;o N&#xBA; 214-45, comuna de Curepto, VII Regi&#xF3;n para la obra &quot;Camino Ruta K-60 y K-16 Sector Mejoramiento Gualleco-Curepto-Puente Lautaro Tramo Km.</div><div class=\"p\">46,180 a Km. 83,91430&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Rodomiro Fern&#xE1;ndez Matus, ascendente a la cantidad de $4.547.332.- </div></div>", "i": 6426676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6426677}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "268", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-268"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-28", "doble_articulado": false, "id_norma": "211173", "numero_fuente": "37585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-17", "vigencias": [{"desde": "2003-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-06-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2003-06-17", "fecha_version": "2003-06-17", "fecha_actualizacion_texto": "2003-06-17", "tipo_tratado"