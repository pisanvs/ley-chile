{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 110 EXENTO, DE 1995 </div></div>", "i": 8969038}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 110 de 1&#xB0; de febrero de 1995, se ha modificado, a partir del a&#xF1;o 1995, el decreto supremo exento de Educaci&#xF3;n N&#xB0; 90 de 1990, que aprob&#xF3; plan de estudio al Colegio Punta Arenas, de la XII Regi&#xF3;n, en la forma que indica el presente decreto.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio para la asignatura de &quot;Iniciaci&#xF3;n al C&#xE1;lculo&quot;.-</div><br></div>", "i": 8969039}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 8969040}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "110 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-110 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 110 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO PUNTA ARENAS", "DECIMOSEGUNDA", "REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-01", "doble_articulado": false, "id_norma": "20213", "numero_fuente": "35117", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-14", "vigencias": [{"desde": "1995-03-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-03-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],