{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9114738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 321, de 2 de febrero de 2011, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1021935&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.855, de 2010</a>, modificada por resoluci&#xF3;n exenta N&#xBA; 189, de 2011, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto FIP 2010-04 denominado &quot;Evaluaci&#xF3;n hidroac&#xFA;stica de reclutamiento Anchoveta y Sardina com&#xFA;n entre la V-X Regiones, a&#xF1;o 2011&quot;, en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la citada pesca investigaci&#xF3;n hasta el d&#xED;a 28 de marzo de 2011, inclusive.</div></div>", "i": 9114739}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de febrero de 2011.- Maximiliano Alarma Carrasco, Subsecretario de Pesca (S).</div></div>", "i": 9114740}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "321 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-321 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-02-02", "doble_articulado": false, "id_norma": "1023256", "numero_fuente": "39892", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-22", "vigencias": [{"desde": "2