{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,180.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xBA; La Empresa de los Ferrocarriles del Estado transportar&#xE1; por la mitad de la tarifa actual el salitre, el guano i los abonos artificiales.</div><br></div>", "i": 6162708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 2.&#xBA; El Presidente de la Rep&#xFA;blica dictar&#xE1; un reglamento en el cual determinar&#xE1; la forma i condiciones en que debe solicitar el transporte de dichos art&#xED;culos i en que debe hacerlo la indicada Empresa.</div><br></div>", "i": 6162709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de enero de 1899.- FEDERICO ERRAZURIZ.- Arturo Alessandri.</div><br></div>", "i": 6162710}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1180", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1180"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-20", "doble_articulado":