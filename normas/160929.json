{"html": [{"t": "<div><div class=\"p\">EFECTUA DESIGNACIONES QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de Marzo de 1985.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 312.- Visto: Lo dispuesto en los decretos supremos N&#xB0;s. 447, de 1984 y 199, de 1985, ambos del Ministerio del Interior,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 8359968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Des&#xED;gnase Presidente del Consejo Econ&#xF3;mico y Social al se&#xF1;or Beltr&#xE1;n Urenda Zegers y Vicepresidentes del mismo Consejo a do&#xF1;a Elsa Adriana Gardeweg Baltra y a don Mario Torreblanca Guerrero. </div></div>", "i": 8359969}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Ricardo Garc&#xED;a Rodr&#xED;guez, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Alberto Cardemil Herrera, Subsecretario del Interior.</div><br></div>", "i": 8359970}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "312", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-312"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "EFECTUA DESIGNACIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-11", "doble_articulado": false, "id_norma": "160929", "numero_fuente": "32129", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-23"