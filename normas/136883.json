{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,220.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a los se&#xF1;ores don Jos&#xE9; Bernardo Su&#xE1;rez i don Manuel Salas el derecho de gozar su pension de jubilacion como visitadores de escuelas, de conformidad a la lei de sueldos n&#xFA;mero 1,975, de 31 de julio de 1907.</div><div class=\"p\">&nbsp; &nbsp;  La presente lei rejir&#xE1; desde la fecha de su publicacion&quot;.</div><br></div>", "i": 6170200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, doce de octubre de mil novecientos nueve.- Pedro Montt.- Emiliano Figueroa.</div><br></div>", "i": 6170201}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2220", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2220"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-10-12", "doble_articulado": false, "id_norma": "136883", "numero_fuente": "9518", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-10-16", "vigencias": [{"desde": "1909-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1909-10-16", "fin_vigencia": ""}, "vigencias_vers