{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8922408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Subsecretario de Educaci&#xF3;n quien suscribe, certifica que el Instituto Profesional ZIPTER, autorizado a funcionar mediante Decreto Exento N&#xB0; 156 de 1989, ha presentado modificaci&#xF3;n de los planes y programas de estudios de la Carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Minas, en el sentido de eliminar el t&#xED;tulo intermedio de &quot;T&#xE9;cnico en Minas&quot;, a la Universidad de Atacama, como entidad examinadora y revisados por &#xE9;sta, han sido aprobados en tiempo y forma, de acuerdo a certificado de fecha 30 de septiembre de 1993.- </div></div>", "i": 8922409}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; JULIO VALLADARES MU&#xD1;OZ</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Subsecretario de Educaci&#xF3;n</div><br></div>", "i": 8922410}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL ZIPTER", "MODIFICACION", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1777", "numero_fuente": "34820", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-21", "vigencias": [{"desde": "1994-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio