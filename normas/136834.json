{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 293.- Santiago, 4 de setiembre de 1895.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al teniente-coronel de Ej&#xE9;rcito don Amador Elgueta Talavera, para los efectos de su retiro, el abono de los ocho meses i veinticuatro dias que estuvo separado del Ej&#xE9;rcito el a&#xF1;o 1884.</div><br></div>", "i": 6170023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Ismael Valdes Valdes.</div><br></div>", "i": 6170024}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "293", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-293"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-09-04", "doble_articulado": false, "id_norma": "136834", "numero_fuente": "5206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-09-07", "vigencias": [{"desde": "1895-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-09-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-05-20", "fecha_ve