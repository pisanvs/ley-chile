{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6554305}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.181, de 30 de noviembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a CARLOS YIMI PE&#xD1;AILILLO JOPIA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Playa Las Conchillas, Km. 957, Cha&#xF1;aral, III Regi&#xF3;n de Atacama, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Picado de Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6554306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6554307}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4181 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4181 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-30", "doble_articulado": false, "id_norma": "245488", "numero_fuente": "38344", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-23", "vigencias": [{"desde": "2005-12-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-12-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2005-12-