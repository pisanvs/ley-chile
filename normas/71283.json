{"html": [{"t": "<div><div class=\"p\">DECRETO N&#xB0; 519, 11 DE ABRIL DE 1997 </div></div>", "i": 8933424}, {"t": "<div><div class=\"p\">LA ALCALDIA DE &#xD1;U&#xD1;OA DECRETO HOY LO SIGUIENTE:</div><br><div class=\"p\">&nbsp; &nbsp;  1&#xB0;) Incorp&#xF3;rese a la Ordenanza Municipal N&#xB0; 24, sobre&quot;Determinaci&#xF3;n de tarifa por el servicio domiciliario de aseo&quot;,el siguiente art&#xED;culo transitorio:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo Transitorio N&#xB0; 2.- El pago de la primera cuotatrimestral del derecho de aseo, para el a&#xF1;o 1997, se efectuar&#xE1;hasta el d&#xED;a 30 de mayo del presente a&#xF1;o.</div><br><div class=\"p\">&nbsp; &nbsp;  El plazo establecido en el art&#xED;culo 15&#xB0;, inciso primero deesta Ordenanza, se prorroga para el a&#xF1;o 1997, hasta el d&#xED;a 30 de mayo.&quot; </div></div>", "i": 8933425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PEDRO SABAT PIETRA CAPRINA, ALCALDE.</div><br></div>", "i": 8933426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "519", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-519"}], "organismos": ["MUNICIPALIDAD DE ÑUÑOA"], "titulo_norma": "DECRETO N° 519, 11 DE ABRIL DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "ORDENANZA MUNICIPAL", "ASEO DOMICILIARIO", "BASURA", "DERECHOS MUNICIPALES", "MUNICIPALIDAD DE ÑUÑOA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-11", "doble_articulado": false, "id_norma": "71283", "numero_fuente": "35759", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-07", "vigencias": [{"desde": "1997-05-07", "hasta": "", "tipo_version": "3", "tipo_version