{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 12,134</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br><br></div>", "i": 8859217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0; Interc&#xE1;lase en el art&#xED;culo &#xFA;nico de la ley N.o 12,134, a continuaci&#xF3;n de la frase &quot;han prestado servicios&quot; la siguiente: &quot;en la Defensa Nacional o&quot;.</div><div class=\"p\">&nbsp; &nbsp; El reajuste de pensiones a que diere lugar se pagar&#xE1; solamente desde la fecha de la vigencia de la presente ley&quot;.</div><br></div>", "i": 8859218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecinueve de Agosto de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Carlos Vial Infante.</div><br></div>", "i": 8859219}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13999", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13999"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "MODIFICA LA LEY N.O 12,134", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 12134"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-08-19", "doble_articulado": false, "id_norma": "27626", "numero_fuente": "24728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-08-26", "vigencias": [{"desde": "1960-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], 