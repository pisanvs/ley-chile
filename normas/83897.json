{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION DE INMUEBLE QUE INDICA </div></div>", "i": 6066546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.026 de 19 de noviembre de 1997 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, inmueble ubicado en calle Santa Luisa N&#xBA; 4219, presunto rol de aval&#xFA;os N&#xBA; 1044-13 comuna de La Florida, de aparente dominio de don Rafael Vel&#xE1;squez Vel&#xE1;squez. Comisi&#xF3;n integrada por peritos Sres. Jos&#xE9; Iglesias Cort&#xE9;s, ingeniero civil, Georgina Elorza Ferrada, arquitecto y Leonardo Bast&#xED;as Tessada, constructor civil seg&#xFA;n informe de 15 de marzo de 1997 fij&#xF3; monto provisional de indemnizaci&#xF3;n en $5.490.000.- pagadera al contado.-</div><br></div>", "i": 6066547}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6066548}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1026", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1026"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LA FLORIDA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-19", "doble_articulado": false, "id_norma": "83897", "numero_fuente": "35940", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-15", "vigencias": [{"desde": "1997-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini