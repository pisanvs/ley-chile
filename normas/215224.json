{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6441594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 844 de 14 de agosto de 2003, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP N&#xBA; 2.535, de 30 de noviembre de 1998, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n, en lo que respecta a la indemnizaci&#xF3;n del lote N&#xBA; 3 y a la asignaci&#xF3;n presupuestaria. Cons&#xED;gnese judicialmente el monto de la indemnizaci&#xF3;n del lote N&#xBA; 3, fijada por la comisi&#xF3;n pericial el 13 de agosto de 1996, ascendente a la cantidad de $148.500.</div><br></div>", "i": 6441595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6441596}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "844", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-844"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-14", "doble_articulado": false, "id_norma": "215224", "numero_fuente": "37673", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-01", "vigencias": [{"desde": "2003-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_par