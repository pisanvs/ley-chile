{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXPROPIATORIO </div></div>", "i": 6156473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto 51 del 05 de Abril de 1988 se dispuso expropiaci&#xF3;n de inmueble ubicado al norte de Pencahue de Sucesi&#xF3;n Rodr&#xED;guez Covarrubias inscrita a Fs. 3.440 vta.</div><div class=\"p\">No. 3597 del a&#xF1;o 1987 del Conservador de Bienes Ra&#xED;ces de Talca Rol pago de contribuciones 102-9 de 2,9 h&#xE1;s. deslindes; norte en 207,08 mts. con Oscar Rodr&#xED;guez Cerpa, Sur en 110 mts. con Oscar Rodr&#xED;guez Cerpa, Oriente en 168,30 mts. con Camino P&#xFA;blico, Poniente en 206 mts. con Nelson G&#xF3;mez Leppe. Se publica el presente extracto de Decreto referido para los efectos Decreto Ley 2.186 de Junio de 1978. Causa No. 67.823 del Primer Juzgado de Letras de Talca.-</div><br></div>", "i": 6156474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Osvaldo Hiriart Rodr&#xED;guez, Alcalde.</div><br></div>", "i": 6156475}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "51", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-51"}], "organismos": ["MUNICIPALIDAD DE PENCAHUE"], "titulo_norma": "EXTRACTO DE DECRETO EXPROPIATORIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-05", "doble_articulado": false, "id_norma": "132517", "numero_fuente": "33046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-15", "vigencias": [{"desde": "1988-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04-