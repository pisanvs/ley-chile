{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8333133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.130, de 5 de agosto de 1998, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 136 de 1987 en su numeral 4&#xBA;, que autoriz&#xF3; a SOCIEDAD PESQUERA DO&#xD1;A ELENA LIMITADA, para instalar y operar un establecimiento de cultivo destinado a realizar liberaci&#xF3;n controlada y control de retorno de especies en la desembocadura del r&#xED;o Bu&#xF1;ocoihue o Hue&#xF1;ocoihue, comuna de Dalcahue, provincia de Chilo&#xE9;, X Regi&#xF3;n.</div><br></div>", "i": 8333134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8333135}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1130", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1130"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "DALCAHUE", "SOCIEDAD PESQUERA DO A ELENA LIMITADA", "DECIMA REGION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-05", "doble_articulado": false, "id_norma": "122991", "numero_fuente": "36139", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-13", "vigencias": [{"desde": "1998-08-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-08-13", "fin_vigenci