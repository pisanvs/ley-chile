{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 5955898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Conc&#xE9;dese un suplemento de cien mil pesos ($ 100,000) al &#xED;tem 72, partida 3.a del presupuesto de Guerra vijente.</div><br></div>", "i": 5955899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o El &#xED;tem 64, partida 3.a del mismo presupuesto, se rebajar&#xE1; en una suma igual a la autorizacion concedida por el art&#xED;culo anterior. </div></div>", "i": 5955900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintisiete de diciembre de mil novecientos dieciocho.- Juan Luis Sanfuentes.- Enrique Berm&#xFA;dez.</div><br></div>", "i": 5955901}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3456", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3456"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1918", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-12-27", "doble_articulado": false, "id_norma": "23983", "numero_fuente": "12256", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-12-27", "vigencias": [{"desde": "1918-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia"