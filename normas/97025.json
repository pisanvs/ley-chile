{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 17 EXENTA, DE 1998 </div></div>", "i": 8328180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 17 de fecha 9 de febrero de 1998, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se ha rechazado el Recurso de Reclamaci&#xF3;n interpuesto por Alimentos Marinos S.A., Rut:</div><div class=\"p\">91.584.000-0 y confirmada la resoluci&#xF3;n N&#xBA; 1.984, de 1996 de la Subsecretar&#xED;a de Pesca, que declar&#xF3; la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.046 de 1993, de esa Subsecretar&#xED;a.-</div><br></div>", "i": 8328181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Oscar Landerretche Gacit&#xFA;a, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8328182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "17 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-17 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 17 EXENTA, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECURSO DE RECLAMACION", "ALIMENTOS MARINOS S.A.", "CADUCIDAD", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-02-09", "doble_articulado": false, "id_norma": "97025", "numero_fuente": "36002", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-27", "vigencias": [{"desde": "1998-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen