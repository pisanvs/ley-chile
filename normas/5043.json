{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 208.- Santiago, 15 de Mayo de 1931.- Vistas las facultades que me confiere la ley N.o 4,945, de 6 de Febrero &#xFA;ltimo.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7118756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.o Trasp&#xE1;sase la suma de diez mil pesos ($ 10,000), del &#xED;tem 10/01/04/g-2 al &#xED;tem 10/03/04/g-1.</div><div class=\"p\">&nbsp; &nbsp; 2.o C&#xE1;mbiase la denominaci&#xF3;n de la glosa 10/03/04/x-1, por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;Para subvencionar a los observadores de las estaciones de la Oficina Meteorol&#xF3;gica de Chile, $ 50,000&quot;.</div><br></div>", "i": 7118757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- H. Marchant M.- Carlos Castro Ruiz.</div><br></div>", "i": 7118758}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "208", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-208"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-15", "doble_articulado": false, "id_norma": "5043", "numero_fuente": "15980", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-26", "vigencias": [{"desde": "1931-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-26", "fin_vigencia": "