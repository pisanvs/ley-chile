{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6552635}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.061, de 11 de octubre de 2005, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP N&#xBA; 1.438, de 31 de agosto de 1998, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 1, fijada por la Comisi&#xF3;n de Peritos, con fecha 20 de febrero de 1998, ascendente a la cantidad de $445.600.</div><br></div>", "i": 6552636}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6552637}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1061", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1061"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-10-11", "doble_articulado": false, "id_norma": "244997", "numero_fuente": "38337", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-15", "vigencias": [{"desde": "2005-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresa