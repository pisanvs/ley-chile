{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6527603}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;358 de fecha 29 de abril del 2005, se expropi&#xF3; el lote de terreno N&#xBA;33-B, superficie 257 m&#xB2;, Rol N&#xBA;516-22, comuna de Santa Cruz, VI Regi&#xF3;n para la obra &quot;Camino Santa Cruz - Yaquil, Rol I-730, Km. 0,00000 a Km. 7,46939&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Sandra Jacqueline Navarro Gonz&#xE1;lez, ascendente a la cantidad de $1.126.639.</div><br></div>", "i": 6527604}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6527605}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "358 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-358 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-29", "doble_articulado": false, "id_norma": "238407", "numero_fuente": "38174", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-06-01", "vigencias": [{"desde": "2005-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-06-01", "fecha_version": "2005-06-01", "fecha_actualizacion_texto": "2005-06-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "est