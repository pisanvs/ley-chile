{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6240062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 186, de Febrero, 27 de 1985, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, se autoriza a los se&#xF1;ores V&#xED;ctor y Luis Mendoza Torres, para efectuar todo tipo de servicios de transportes de pasajeros por calle y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6240063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Febrero de 1985.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6240064}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "186 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-186 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-27", "doble_articulado": false, "id_norma": "157944", "numero_fuente": "32129", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-23", "vigencias": [{"desde": "1985-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-23", "fin_vigencia": "", "tip