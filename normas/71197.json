{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6035694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 244, de 25 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s 1, 1-A, 3, 4, 8 y 9 del Enlace Lo Gallardo, superficies 5.110 m2., 7.429 m2., 1.111,3 m2., 16.173,3 m2., 327,4 m2. y 738 m2., roles de aval&#xFA;o 9049-23, 9049-35 y 9049-21, comuna de San Antonio, para la obra Enlaces Ruta 78 del Camino Santiago-San Antonio, sector Leyda-Agua Buena, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Jorge Antonio Parot Benavides; Rodrigo D&#xED;az Alb&#xF3;nico y otra, y Max Correa Lecaros, ascendente a las cantidades de $28.385.033.- para los lotes 1 y 1-A; $54.088.261.- para los lotes 3 y 4, y $3.924.470.- para los lotes 8 y 9.-</div><br></div>", "i": 6035695}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6035696}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "244", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-244"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "INDEMNIZACION", "SAN ANTONIO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-25", "doble_articulado": false, "id_norma": "71197", "numero_fuente": "45755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-02", "vigencias": [{"desde": "1997-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-02", "fin_vigencia": ""}, "vigencias_version_norma"