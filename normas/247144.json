{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6560547}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;262, de 24 de enero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase al SINDICATO DE TRABAJADORES INDEPENDIENTES DE BUZOS MARISCADORES, ASISTENTES DE BUZOS Y PESCADORES ARTESANALES DE ANTOFAGASTA, CALETA CONSTITUCION, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Caleta Constituci&#xF3;n, II Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga Seca los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;3.405 de 2004, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6560548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6560549}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "262 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-262 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-24", "doble_articulado": false, "id_norma": "247144", "numero_fuente": "38384", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-02-08", "vigencias": [{"desde": "2006-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig