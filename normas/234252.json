{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6511449}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 1.656, de fecha 30 de noviembre del 2004, se expropi&#xF3; el lote de terreno N&#xBA; 20, superficie 8.640 m&#xB2;., Rol N&#xBA; 158-159, comuna de Cocham&#xF3;, X Regi&#xF3;n, para la obra &apos;&apos;Camino Puelo Paso El Bols&#xF3;n, Sector Lago Tagua Tagua-Llanada Grande Km.</div><div class=\"p\">12,530 a Km. 32,500&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Rom&#xE1;n N&#xFA;&#xF1;ez Rosas, ascendente a la cantidad de $1.137.328.- para el lote N&#xBA; 20.</div><br></div>", "i": 6511450}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6511451}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1656 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1656 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-30", "doble_articulado": false, "id_norma": "234252", "numero_fuente": "38050", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-03", "vigencias": [{"desde": "2005-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-01-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-01-03", "fecha_version": "2005-01-03", "fe