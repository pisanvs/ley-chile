{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6533230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.943, de 23 de junio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a WALTER FRANCISCO OPITZ OYARZUN y a WALTER OPITZ TURRA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Ruta A-16, Km. 35, comuna de Alto Hospicio, I Regi&#xF3;n, donde podr&#xE1;n elaborar en la l&#xED;nea de proceso de Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6533231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de junio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6533232}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1943 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1943 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-23", "doble_articulado": false, "id_norma": "240168", "numero_fuente": "38213", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-18", "vigencias": [{"desde": "2005-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-07-18", "fe