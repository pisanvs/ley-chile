{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente,</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 5961231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Trasp&#xE1;sase la suma de dos millones quinientos mil pesos ($ 2.500,000), del &#xED;tem E-0601-h) del Presupuesto Extraordinario vigente, partida destinada a la adquisici&#xF3;n de propiedades de la Caja de Cr&#xE9;dito Hipotecario, al &#xED;tem E-1503-a), creado en virtud de esta ley y destinado a la atenci&#xF3;n de los cesantes.</div><br><br></div>", "i": 5961232}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto publ&#xED;quese y ll&#xE9;vese a efecto en todas sus partes como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a quince de Diciembre de mil novecientos treinta y uno.- JUAN E. MONTERO.- S&#xF3;tero del R&#xED;o. </div></div>", "i": 5961233}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5010", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5010"}], "organismos": ["MINISTERIO DE BIENESTAR SOCIAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-12-15", "doble_articulado": false, "id_norma": "24993", "numero_fuente": "16151", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-12-17", "vigencias": [{"desde": "1931-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-12-17", "fin_vigencia": ""}, "vig