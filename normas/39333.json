{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AMPLIA FACULTADES QUE INDICA San Miguel, 18 de Marzo de 1993. Hoy se ha resuelto lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 825 exenta </div></div>", "i": 7201822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ampl&#xED;a facultades delegadas por Res. Ex. Ns. 1168, 1247 y 1136, de 1992, conforme a la Res. N002410, de 1992, del Director del Servicio en relaci&#xF3;n a la Ley N&#xB0; 17.235, a:</div><div class=\"p\">&nbsp; &nbsp; 1) Jefe de Departamento de Avaluaciones Regional, funcionarios de la planta de profesionales, fiscalizadores, administrativos y a contrata asimilados de esas plantas; y</div><div class=\"p\">&nbsp; &nbsp; 2) En los jefes de las Unidades de Puente Alto, La Granja y San Bernardo; funcionarios de la planta de profesionales, fiscalizadores, administrativos, y funcionarios a contrata asimilados a esas plantas, ubicados en esas Unidades.-</div><br></div>", "i": 7201823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 7201824}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "825 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-825 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "AMPLIA FACULTADES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERVICIO IMPUESTOS INTERNOS", "SII", "DELEGACION", "FACULTAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-03-18", "doble_articulado": false, "id_norma": "39333", "numero_fuente": "34533", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-03", "vigencias": [{"desde": "1993-04-03", "hasta": "", "tipo_version"