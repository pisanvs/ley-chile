{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 235.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. As&#xED;gnase a la viuda e hijas solteras de don Enrique Ballacey, do&#xF1;a Enriqueta, do&#xF1;a Mar&#xED;a Luisa i do&#xF1;a Mercedes, una pension de quinientos pesos por a&#xF1;o, que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 5947240}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 31 de Diciembre de 1894.- JORJE MONTT.-</div><div class=\"p\">O. Renjifo.</div><br></div>", "i": 5947241}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "235", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-235"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ENRIQUE BALLACEY", "VIUDA", "HIJAS SOLTERAS", "MONTEPIO", "MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-31", "doble_articulado": false, "id_norma": "22090", "numero_fuente": "5004", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-01-03", "vigencias": [{"desde": "1895-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-01-03", "fin_vigencia": ""}, "vigencias_version_n