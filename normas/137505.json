{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,531.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172299}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados en la campa&#xF1;a contra el Per&#xFA; i Bolivia por el teniente-coronel graduado de Ej&#xE9;rcito, don Alejandro Guzman i Guzman, ab&#xF3;nesele, por gracia, para los efectos de su retiro, los tres a&#xF1;os cinco meses doce dias que permaneci&#xF3; en la Escuela Militar, como cadete pensionista, desde el 10 de marzo de 1868 hasta el 22 de agosto de 1871.</div><br></div>", "i": 6172300}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto,&nbsp; prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de agosto de mil novecientos once.- Ramon Barros Luco.- An&#xED;bal Rodr&#xED;guez H.</div><br></div>", "i": 6172301}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2531", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2531"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-08-05", "doble_articulado": false, "id_norma": "137505", "numero_fuente": "10097", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-10-05", "vigencias": [{"desde": "1911-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-10