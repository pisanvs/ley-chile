{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 854, de 29 de Octubre de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 791, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Unimarc S.A., hoy SALMONES UNIMARC S.A. R.U.T. N&#xB0; 88.541.600-4, domiciliada en calle Gabriela Mistral 370, Castro, X Regi&#xF3;n, con direcci&#xF3;n postal en casilla 160 de esa ciudad, para operar un establecimiento de cultivo del recurso alga del g&#xE9;nero Gracilaria, en Caleta Cuarahue, Comuna de Castro, Provincia de Chilo&#xE9;, X Regi&#xF3;n, por renuncia de su titular.</div><br></div>", "i": 8294557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 29 de Octubre de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8294558}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "854", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-854"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA UNIMARC S.A.", "SALMONES UNIMARC", "ACUICULTURA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-10-29", "doble_articulado": false, "id_norma": "35724", "numero_fuente": "34713", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-11", "vigencias": [{"desde": "1993-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993