{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 407 EXENTO, DE 2004 </div></div>", "i": 6488209}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 407 de fecha 15 de junio de 2004, de Educaci&#xF3;n, se declara aprobada al Instituto Profesional Carlos Casanueva la carrera profesional que se indica:</div><br><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Psicopedagog&#xED;a.</div><div class=\"p\">T&#xED;tulo Profesional:&nbsp; &nbsp; Psicopedagogo.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera podr&#xE1; ser impartida en jornada vespertina en su sede de Santiago, a contar del segundo semestre del a&#xF1;o 2004, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6488210}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de julio de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6488211}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "407 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-407 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 407 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-06-15", "fecha_derogacion": "2021-12-31", "doble_articulado": false, "id_norma": "227806", "numero_fuente": "37912", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-07-17", "vigencias": [{"desde": "2021-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-07-17", "hasta": "2021-12-30