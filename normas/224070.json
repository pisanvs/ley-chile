{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.639 EXENTA, DE 2004 </div><br></div>", "i": 6474710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.639 de 24 de marzo de 2004, se ha complementado, a partir del a&#xF1;o escolar 2004, los planes de estudio para 2&#xBA;, 3&#xBA; y 4&#xBA; a&#xF1;os de la Ense&#xF1;anza Media, al Colegio Los Andes de Vitacura.</div><br><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para los subsectores y cursos que se se&#xF1;alan en el presente decreto.</div><br></div>", "i": 6474711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de abril de 2004.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6474712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4639 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4639 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.639 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-24", "doble_articulado": false, "id_norma": "224070", "numero_fuente": "37841", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-21", "vigencias": [{"desde": "2004-04-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2004-04-21", "fech