{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6596891}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.570, de 28 de diciembre de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA SURIBERICA S.A. para realizar operaciones pesqueras, a contar del 1 de enero del a&#xF1;o 2007 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fecha inclusive, con el barco f&#xE1;brica &quot;Isla Camila&quot;, en aguas exteriores, por fuera de las l&#xED;neas de base recta, al sur del paralelo 47&#xB0;00&apos; L.S., respecto de los recursos y con las obligaciones establecidas en su respectiva autorizaci&#xF3;n. </div></div>", "i": 6596892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de diciembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6596893}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3570 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3570 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-28", "doble_articulado": false, "id_norma": "257340", "numero_fuente": "38661", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-12", "vigencias": [{"desde": "2007-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-01-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione