{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6519467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 500, de 24 de febrero de 2005, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 3.382 de 2004, modificada mediante resoluciones N&#xBA; 3.480, N&#xBA; 3.710, ambas de 2004 y N&#xBA; 08 de 2005, todas de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a MARES CHILE LIMITADA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Control y monitoreo de la pesquer&#xED;a de Merluza del sur (Merluccius australis) en aguas interiores de la XII Regi&#xF3;n&quot;, en el sentido de aprobar el addendum a los T&#xE9;rminos T&#xE9;cnicos de Referencia y las modificaciones que se indican en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6519468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de febrero de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6519469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "500 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-500 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-02-24", "fecha_derogacion": "2005-04-08", "doble_articulado": false, "id_norma": "236400", "numero_fuente": "38113", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-03-17", "vigencias": [{"desde": "2005-04-08", "hasta": "", "tipo