{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8307913}, {"t": "<div><br><div class=\"p\">Por Resoluci&#xF3;n No. 870, de 08 de Septiembre de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n No. 610, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA BAQUEDANO LIMITADA, domiciliada en Coquimbo, para iniciar actividades pesqueras, en su numeral segundo, en cuanto a que donde dice &quot;en un Sector de Baquedano, Bah&#xED;a de Coquimbo, IV Regi&#xF3;n&quot;, debe decir &quot;en Camino al Fuerte No.</div><div class=\"p\">42, Coquimbo, IV Regi&#xF3;n,&quot;.</div><br></div>", "i": 8307914}, {"t": "<div><br><div class=\"p\">Valpara&#xED;so, 08 de Septiembre de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8307915}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "870", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-870"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-08", "doble_articulado": false, "id_norma": "77388", "numero_fuente": "34370", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-09-21", "vigencias": [{"desde": "1992-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-09-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac