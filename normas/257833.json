{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6599084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 186, de 19 de enero de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a JESSICA ORIELE VILLEGAS DUR&#xC1;N, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en caleta Cifuncho a 46 km. aproximadamente al sur de Taltal, II Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga seca, los recursos hidrobiol&#xF3;gicos se&#xF1;alados en la resoluci&#xF3;n extractada. </div></div>", "i": 6599085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6599086}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "186 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-186 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-01-19", "doble_articulado": false, "id_norma": "257833", "numero_fuente": "38673", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-26", "vigencias": [{"desde": "2007-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-01-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-01-26", "fec