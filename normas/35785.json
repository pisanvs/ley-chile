{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE EXPROPIACION DE INMUEBLE QUE INDICA NOTIFICACION </div></div>", "i": 6013264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 880 de 22 de septiembre de 1994 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xB0; 2.186 de 1978, de parte del inmueble ubicado en esquina de Avda. Guillermo Mann N&#xB0; 1850 y Avda. Marathon N&#xB0; 1670, presunto rol de aval&#xFA;os N&#xB0; 6115-2 comuna de &#xD1;u&#xF1;oa, aparente dominio del Fisco. Comisi&#xF3;n integrada por peritos Sres. Roberto Correa Bezanilla y Jorge Felipe C&#xE1;diz Bouch, arquitectos, y Luis Rojas Quezada, constructor civil, seg&#xFA;n informe de 10 de junio de 1994, fij&#xF3; monto provisional indemnizaci&#xF3;n en $2.372.000.- pagadera al contado.-</div><br></div>", "i": 6013265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director SERVIU Metropolitano.</div><br></div>", "i": 6013266}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "880", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-880"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "DISPONE EXPROPIACION DE INMUEBLE QUE INDICA\nNOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "BIEN INMUEBLE", "BIEN RAIZ", "U OA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-22", "doble_articulado": false, "id_norma": "35785", "numero_fuente": "35016-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-11-15", "vigencias": [{"desde": "1994-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini