{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6264775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 336, de 11 de Diciembre de 1985, del SERVIU V Regi&#xF3;n de Valpara&#xED;so, se dispuso expropiaci&#xF3;n conforme art&#xED;culo 87 Ley No. 8.946 y DL No.</div><div class=\"p\">2.186, de 1978, de partes de la porci&#xF3;n A del inmueble conocido como ex Hacienda Las 7 Hermanas, rol de aval&#xFA;o 5.022-2, comuna de Vi&#xF1;a del Mar, de dominio de Sociedad Forestal Las Colinas Ltda., Sociedad Silvoagropecuaria Ltda. y de Jorge Edmundo Bernales Espinosa, en una superficie de 21.580,35 m&#xB2;. Comisi&#xF3;n tasadora integrada por arquitecto Sr. Osvaldo Mu&#xF1;oz Quintana y constructores civiles Sres. Pablo Cari&#xE1; Giurici y Carlos Mu&#xF1;oz Rivera, seg&#xFA;n informe de fecha 09 de Diciembre de 1985 fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 971.116.-, la cual ser&#xE1; pagada de contado.</div><br></div>", "i": 6264776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "336", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-336"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "sin promulgación"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-11", "doble_articulado": false, "id_norma": "165474", "numero_fuente": "32348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-16", "vigencias": [{"desde": "1985-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ún