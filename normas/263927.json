{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.140 EXENTO, DE 2007 </div></div>", "i": 6620878}, {"t": "<div><div class=\"p\">de 2007 del Ministerio de Educaci&#xF3;n, se deja sin efecto a contar del a&#xF1;o 2007, la aprobaci&#xF3;n de los planes y programas de estudios de las carreras que se indican del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Altos Estudios de la Comunicaci&#xF3;n y Educaci&#xF3;n - EACE, aprobadas por los actos administrativos que se se&#xF1;alan, a petici&#xF3;n de la propia entidad, dado que no se continuar&#xE1;n ofreciendo:</div><br><div class=\"p\">Carreras:&nbsp; &nbsp;  - Animaci&#xF3;n T.V., Locuci&#xF3;n y Relatos</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Deportivos</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (DEX. N&#xBA; 79 de 14.05.91 y N&#xBA; 87 de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 10.04.92)</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; - T&#xE9;cnico en Producci&#xF3;n Multimedial</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (DEX. N&#xBA; 877 de 10.09.02).</div><br></div>", "i": 6620879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de agosto de 2007.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6620880}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1140 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1140 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.140 EXENTO, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita"