{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9282779}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.952, de 18 de julio de 2012, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de la <a href=\"https://www.leychile.cl/Navegar?idNorma=223460&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 888, de 2004</a>, que autoriz&#xF3; a Pesquera B&#xED;o-B&#xED;o S.A. hoy CAMANCHACA PESCA SUR S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Don Roberto I&quot;, respecto del recurso hidrobiol&#xF3;gico Jibia en el &#xE1;rea mar&#xED;tima comprendida entre la III a VII y IX a X Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 9282780, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9282781}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1952 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1952 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-18", "doble_articulado": false, "id_norma": "1042113", "numero_fuente": "40319", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-24", "vigencias": [{"desde": "2012-07-24", "hasta": "", "tipo_version": "3", "tipo_v