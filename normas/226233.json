{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6482770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.494, de 28 de mayo de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 3.555, de 2003, de esta Subsecretar&#xED;a que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Pesca de Investigaci&#xF3;n de Merluza del sur en la Regi&#xF3;n de Magallanes-Fase III, 2004&quot;, en el sentido de se&#xF1;alar que las actividades de investigaci&#xF3;n correspondientes al mes de junio se realizar&#xE1;n entre el 7 y el 30 de dicho mes, ambas fechas inclusive. </div></div>", "i": 6482771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de mayo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6482772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1494 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1494 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-28", "doble_articulado": false, "id_norma": "226233", "numero_fuente": "37882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-11", "vigencias": [{"desde": "2004-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-11", "fin_vigencia": ""}, "vigencias_version_no