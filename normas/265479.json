{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE EMISOR ELECTR&#xD3;NICO </div></div>", "i": 6700752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 120 de octubre de 2007, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como emisor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n del Representante Legal de los contribuyentes RUT N&#xBA; 96.619.660-2 y RUT N&#xBA; 79.693.220-1, se deroga autorizaci&#xF3;n otorgada a los contribuyentes se&#xF1;alados para operar como emisor de Documentos Tributarios Electr&#xF3;nicos.</div><br></div>", "i": 6700753}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2007.</div><br><br></div>", "i": 6700754}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "120 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-120 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACIÓN DE EMISOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACIÓN", "NORMA SIN FECHA DE PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "265479", "numero_fuente": "38884", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-11", "vigencias": [{"desde": "2007-10-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "