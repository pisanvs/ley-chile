{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9286145}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;1205 de 29 de junio de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;89-A, superficie 1.371 m2, rol de Aval&#xFA;o N&#xBA;213-240, comuna de Florida, para la obra &quot;MEJORAMIENTO RUTA 0-390, CRUCE RUTA 148 (Florida) - AUTOPISTA ITATA&quot;, VIII Regi&#xF3;n. La Comisi&#xF3;n de peritos, integrada por Mar&#xED;a Guti&#xE9;rrez Flores, Oscar Ch&#xE1;vez Alcaino y Valeska Ale Go&#xF1;i, fij&#xF3; el valor de tasaci&#xF3;n con fecha 14 de julio de 2009, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario VICTOR HUGO RIVERA RU&#xCD;Z, en la cantidad de $11.408.287.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9286146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9286147}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1205 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1205 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-29", "doble_articulado": false, "id_norma": "1042464", "numero_fuente": "40326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-01", "vigencias": [{"desde": "2012-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2