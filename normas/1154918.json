{"html": [{"t": "<div><div class=\"p\">SE DISPONE EL OTORGAMIENTO DEL SEXAG&#xC9;SIMO SEGUNDO, APORTE &#xDA;NICO DE CAR&#xC1;CTER REPARATORIO LEY N&#xB0; 20.874, A LAS PERSONAS QUE SE INDIVIDUALIZA Y POR LOS MONTOS QUE EN CADA CASO SE INDICA</div></div>", "i": 10194689}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 368, de 10 de diciembre de 2020, el Director Nacional del Instituto de Previsi&#xF3;n Social, aprob&#xF3; el Conc&#xE9;dase y p&#xE1;guese, en su totalidad y en un solo acto, el Aporte &#xDA;nico Reparatorio establecido en el <a href=\"https://www.leychile.cl/Navegar?idNorma=1083194&amp;idParte=9645034&amp;idVersion=\">art&#xED;culo 1&#xB0;</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1083194&amp;idParte=&amp;idVersion=\">Ley N&#xB0; 20.874</a>, por el monto &#xFA;nico y total que se consigna para los beneficiarios que indica.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10194690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Patricio Coronado Rojo, Director Nacional.</div><br></div>", "i": 10194691}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "368 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-368 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DE PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE DISPONE EL OTORGAMIENTO DEL SEXAGÉSIMO SEGUNDO, APORTE ÚNICO DE CARÁCTER REPARATORIO LEY N° 20.874, A LAS PERSONAS QUE SE INDIVIDUALIZA Y POR LOS MONTOS QUE EN CADA CASO SE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1882659", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgac