{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xB0; 83 EXENTA, DE 2022</div></div>", "i": 10307198}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  La resoluci&#xF3;n exenta N&#xB0; 83, de 10 enero de 2022, del Director Nacional del Servicio Nacional de Capacitaci&#xF3;n y Empleo, estableci&#xF3; sectores de beneficiarios elegibles por las empresas hasta el 31 de diciembre de 2022, para efectoS de celebrar contratos de capacitaci&#xF3;n en conformidad a lo dispuesto en el inciso sexto del art&#xED;culo 33 de la Ley 19.518.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n exenta N&#xB0; 83, de 10 enero de 2022, est&#xE1; disponible en l&#xED;nea, en el sitio web oficial del Servicio Nacional de Capacitaci&#xF3;n y Empleo, www.sence.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10307199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago,10 de enero de 2022.- Ricardo Ruiz de Vi&#xF1;aspre Rencoret, Director Nacional, Servicio Nacional de Capacitaci&#xF3;n y Empleo.</div><br></div>", "i": 10307200}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "83 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-83 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DEL TRABAJO", "SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO RESOLUCIÓN N° 83 EXENTA, DE 2022", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2080986", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-10", "doble_articulado": false, "id_norma": "1172255", "numero_fuente": "43169", "tipo_version": "3", "tipo_version_s": "Única",