{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,706.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese por gracia, a don Bernardo Irarr&#xE1;zaval, el derecho de jubilar con una pension igual a la renta de seis mil pesos ($ 6,000) anuales de que goza como inspector del servicio de los Ferrocarriles del Estado. </div></div>", "i": 6165008}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diecisiete de setiembre de mil novecientos cuatro.- JERMAN RIESCO.- Anfion Mu&#xF1;oz.</div><br></div>", "i": 6165009}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1706", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1706"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-09-17", "doble_articulado": false, "id_norma": "135312", "numero_fuente": "8012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-09-22", "vigencias": [{"desde": "1904-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1904-09-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi