{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7302483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA; 702 de fecha 17 de Mayo 1984, ratificada por resoluci&#xF3;n exenta N&#xBA; 610 de fecha 29 de Abril de 1991, conforme al art&#xED;culo 5&#xBA; Transitorio del C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento aguas proporcionales que corresponden al sector excluido del predio &quot;Chacra Pamela&quot; de la Comuna de Quilicura, y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xBA;s. 1 a 10 y sitios N&#xBA; A, B, C, D, E, F, G, H, I y J del Proyecto de Parcelaci&#xF3;n &quot;Pamela&quot; formado por el predio se&#xF1;alado. Los derechos de aguas se extraen del Estero Las Cruces.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13. Ley N&#xBA; 18.377.-</div><br></div>", "i": 7302484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div><br></div>", "i": 7302485}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "702 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-702 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-05-17", "doble_articulado": false, "id_norma": "213371", "numero_fuente": "34106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-02", "vigencias": [{"desde": "1991-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-