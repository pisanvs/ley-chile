{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;243 EXENTO, DE 2000</div><br><br></div>", "i": 6300372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 243 de fecha 4 de julio de 2000 del Ministerio de Educaci&#xF3;n, se aprueba el plan y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica Soesta, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 2000:</div><br><div class=\"p\">Carrera : T&#xE9;cnico Jur&#xED;dico</div><div class=\"p\">T&#xED;tulo&nbsp; : T&#xE9;cnico Jur&#xED;dico</div><br><div class=\"p\">&nbsp; &nbsp;  El nuevo plan y programas de estudios que se aprueba pasar&#xE1; a formar parte del proyecto institucional del Centro de Formaci&#xF3;n T&#xE9;cnica Soesta, correspondiendo al Ministerio de Educaci&#xF3;n la verificaci&#xF3;n de su desarrollo.</div><br></div>", "i": 6300373}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de julio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6300374}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "243 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-243 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 243 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-07-04", "fecha_derogacion": "2004-12-06", "doble_articulado": false, "id_norma": "175384", "numero_fuente": "36764", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-09-14", "vigencias": [{"desde": "2004-12-06", "hasta": "", "tipo_