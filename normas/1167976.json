{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCI&#xD3;N EXENTA QUE INDICA</div></div>", "i": 10282630}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.941, de 3 de noviembre de 2021, de esta Subsecretaria, d&#xE9;jese sin efecto la <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=265683&amp;idVersion=2021-11-09\">resoluci&#xF3;n exenta N&#xB0; 2.873, de 2007</a>, que autoriz&#xF3; a Camanchaca S.A. para realizar actividades extractivas en alta mar, con la nave &quot;Collen&quot;, matr&#xED;cula N&#xB0; 2258, por configurarse la causal establecida en el art&#xED;culo 11, letra a) del decreto supremo N&#xB0; 360, de 2005, del actual Ministerio de Econom&#xED;a, Fomento y Turismo.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10282631, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de noviembre de 2021.- M&#xF3;nica Orellana Vald&#xE9;s, Subsecretaria de Pesca y Acuicultura (S).</div><br></div>", "i": 10282632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2941 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2941 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIÓN EXENTA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2037486", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-03", "doble_articulado": false, "id_norma": "1167976", "numero_fuente": "43098", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-11-09", "vigencias": [{"desde": "2021-11-09", "hasta": "", "tipo_ve