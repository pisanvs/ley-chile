{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,888 que consulta fondos para gratificaciones a las Polic&#xED;as</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m 1,888.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico . Conc&#xE9;dese un suplemento de ciento cincuenta mil pesos a &#xED;tem 1,004, partida 54 del Presupuesto del Interior para gratificaciones al personal de polic&#xED;as.</div><br></div>", "i": 8274815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de diciembre de 1906.- PEDRO MONTT.- V. Santa Cruz.</div><br></div>", "i": 8274816}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1888", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1888"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Lei núm. 1,888 que consulta fondos para;gratificaciones a las Policías", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1906", "MODIFICACION", "MINISTERIO", "INTERIOR", "POLICIAS", "GRATIFICACION", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-12-06", "doble_articulado": false, "id_norma": "22985", "numero_fuente": "8669", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-12-06", "vigencias": [{"desde": "1906-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú