{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.179, EXENTA, DE 19.10.2009</div><br></div>", "i": 9017181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por la presente se han aprobado planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Liceo San Agust&#xED;n, comuna de &#xD1;u&#xF1;oa, de Santiago.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio de Antropolog&#xED;a y Moral del Plan de Formaci&#xF3;n General para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media.</div></div>", "i": 9017182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de octubre de 2009.- Jaime Veas S&#xE1;nchez, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 9017183}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7179 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-7179 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.179, EXENTA, DE 19.10.2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-19", "doble_articulado": false, "id_norma": "1017805", "numero_fuente": "39784", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-10-14", "vigencias": [{"desde": "2010-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-10-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-10-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "in