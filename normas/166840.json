{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6269347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 645 de 03 de agosto de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se prolonga por Avda. P. Aguirre Cerda el recorrido de taxi colectivo urbano autorizado por resoluci&#xF3;n No. 036 de 16 de enero de 1986, de esta Secretar&#xED;a Regional, desde Avda. P. Aguirre Cerda entre las calles Progreso y Matta, hasta Avda. P. Aguirre Cerda esq. pasaje Garc&#xED;a, lugar donde se ubica su terminal.</div><br></div>", "i": 6269348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial, Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 6269349}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "645 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-645 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-03", "doble_articulado": false, "id_norma": "166840", "numero_fuente": "32888", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-07", "vigencias": [{"desde": "1987-10-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-07", "fin_vigencia": "", "tipo_version": "3