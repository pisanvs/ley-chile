{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6422831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 848, de 16 de abril de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA GALEB LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Huasco N&#xBA; 86, Barrio Industrial, Antofagasta, II Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Fresco - refrigerado y congelado: Sardina redonda, Azulejo, Caz&#xF3;n, Jurel fino y Anchoveta blanca.</div><div class=\"p\">&nbsp; &nbsp;  La materia prima deber&#xE1; provenir de pescadores artesanales e industriales, debidamente autorizados. </div></div>", "i": 6422832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de abril de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6422833}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "848", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-848"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-04-16", "doble_articulado": false, "id_norma": "210000", "numero_fuente": "37550", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-05", "vigencias": [{"desde": "2003-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-0