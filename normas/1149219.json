{"html": [{"t": "<div><div class=\"p\">FIJA PUBLICACIONES PARA USO EN LAS RADIOESTACIONES MAR&#xCD;TIMAS DE TELECOMUNICACIONES</div></div>", "i": 10156707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n DGTM y MM Ordinario N&#xBA; 5800/1 Vrs., del 26 de agosto de 2020, fija publicaciones para uso en las radioestaciones mar&#xED;timas de telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><br></div>", "i": 10156708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de agosto de 2020.- Por orden del Sr. Director General, Ren&#xE9; Rojas Cabrejos, Capit&#xE1;n de Nav&#xED;o, Subdirector.- Cristi&#xE1;n Pfeifer Rojas, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico. </div><br></div>", "i": 10156709}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1"}, {"tipo": "3", "numero": "5800/1", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5800/1"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "FIJA PUBLICACIONES PARA USO EN LAS RADIOESTACIONES MARÍTIMAS DE TELECOMUNICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1811929", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-26", "doble_articulado": false, "id_norma": "1149219", "numero