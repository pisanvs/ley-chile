{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6276907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 237, de 02 de Noviembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n, se autoriza a do&#xF1;a Floida Elizabeth Mu&#xF1;oz Hern&#xE1;ndez, para efectuar servicio de taxi colectivo urbano en la ciudad de Temuco, L&#xED;nea N&#xB0; 15, &quot;Colectivos Sur&quot;, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xB0; 30, del 18 de Junio de 1984, de esta Secretar&#xED;a Regional. </div></div>", "i": 6276908}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Temuco, 02 de Noviembre de 1987.- Oscar C&#xF3;rdova Jim&#xE9;nez, Secretario Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n.</div><div class=\"p\">Secretar&#xED;a Regional Ministerial X Regi&#xF3;n </div></div>", "i": 6276909}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "237", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-237"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-02", "doble_articulado": false, "id_norma": "169200", "numero_fuente": "32917", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-11", "vigencias": [{"desde": "1987-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-11", "fin_vigencia": ""}, "vigencias