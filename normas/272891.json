{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.621, DE 2008 </div></div>", "i": 6700950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modifica el anexo N&#xBA; 18 del Compendio de Normas Aduaneras, impartiendo instrucciones respecto de la confecci&#xF3;n de la Declaraci&#xF3;n de Ingreso cuando la mercanc&#xED;a transita por un tercer pa&#xED;s y se acoge a una preferencia arancelaria.</div><div class=\"p\">&nbsp; &nbsp;  Texto &#xED;ntegro de la resoluci&#xF3;n citada se encuentra en la p&#xE1;gina web del Servicio Nacional de Aduanas (www.aduana.cl).</div><br></div>", "i": 6700951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Mujica Montes, Director Nacional de Aduanas. </div></div>", "i": 6700952}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4621", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4621"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.621, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "272891", "numero_fuente": "39097", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-06-26", "vigencias": [{"desde": "2008-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-06-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2008-06-26", "fecha_version": "2008-06-26", "fec