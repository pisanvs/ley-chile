{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MONTEPIO Lei n&#xFA;m. 198.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese por gracia a la viuda e hijos lej&#xED;timos del capitan de fragata don Leoncio Se&#xF1;oret el goce de montep&#xED;o correspondiente al empleo de capitan de nav&#xED;o, en conformidad a las leyes de 6 de Agosto de 1855 i de 22 de Setiembre de 1890.</div><br><br></div>", "i": 5947125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 27 de Agosto de 1894.-JORGE MONTT.-S. Aldunate B.</div><br></div>", "i": 5947126}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "198", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-198"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LEONCIO SE ORET", "VIUDA", "HIJOS LEGITIMOS", "MONTEPIO", "MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-27", "doble_articulado": false, "id_norma": "22056", "numero_fuente": "4903", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-08-29", "vigencias": [{"desde": "1894-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "189