{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA (Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 130.- Santiago, 10 de Octubre de 1988.- Vistos: Lo dispuesto en el Art. 11 del Decreto Ley 19&#xB0; 2.974,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6139336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local en conformidad a las disposiciones del Decreto Ley No. 2.974, en las Regiones I y II, al se&#xF1;or:</div><div class=\"p\">&nbsp; &nbsp;  Guillermo Navarrete Pinilla.</div><br></div>", "i": 6139337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Sergio Retamal Iglesias, Vicepresidente Ejecutivo.</div><br></div>", "i": 6139338}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "130", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-130"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-10-10", "doble_articulado": false, "id_norma": "127187", "numero_fuente": "33222", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-11-16", "vigencias": [{"desde": "1988-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-11-16", "fin_v