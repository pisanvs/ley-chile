{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6110767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. No 353, de 31 de marzo de 1998, se expropiaron los lotes de terreno Nos. 6, 7 y 13, superficies 144, 620 y 95 m2. respectivamente, roles de aval&#xFA;o 2452- 4 y 3502-1, comuna de Valdivia, para la obra Camino Niebla Los Molinos Ruta T-352, Sector Niebla Los Molinos y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Floridema Gonz&#xE1;lez Carrillo y otros y Juan Carios Ortiz Fuentes, ascendente a las cantidades de $11.081.632.- para los lotes 6 y 7 y $1.386.51O.- para el lote 13.-</div><br></div>", "i": 6110768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6110769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "353", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-353"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "VALDIVIA", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-31", "doble_articulado": false, "id_norma": "99028", "numero_fuente": "36054", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-02", "vigencias": [{"desde": "1998-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-05-13", "fecha