{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LAS CALLES QUE SE&#xD1;ALA EN LA COMUNA DE TALAGANTE</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8280083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- C&#xE1;mbiase el nombre de las calles &quot;Progreso&quot; y &quot;Comercio&quot; de la comuna de Talagante por el de &quot;Avenida Bernardo O&apos;Higgins&quot;.</div><br></div>", "i": 8280084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintis&#xE9;is de Junio de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Benjam&#xED;n Videla V.</div><br></div>", "i": 8280085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12046", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12046"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LAS CALLES QUE SEÑALA EN LA COMUNA\nDE TALAGANTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE", "TALAGANTE", "PROGRESO", "COMERCIO", "AVENIDA BERNARDO O'HIGGINS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-06-26", "doble_articulado": false, "id_norma": "27008", "numero_fuente": "23490", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-07-05", "vigencias": [{"desde": "1956-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "19