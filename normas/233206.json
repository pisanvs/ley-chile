{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6507617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.297, de 16 de noviembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a TEODORO RUBEN RIVADENEIRA RECABARREN, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en La P&#xF3;lvora N&#xBA;226, Isla Robinson Crusoe, comuna de Juan Fern&#xE1;ndez, V Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco-Enfriado, Fresco-Refrigerado, Congelado, Cocido y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  Dej&#xE1;se sin efecto la resoluci&#xF3;n N&#xBA;2.658 de 2004, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6507618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6507619}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3297 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3297 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-16", "doble_articulado": false, "id_norma": "233206", "numero_fuente": "38027", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-03", "vigencias": [{"desde": "2004-12-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc