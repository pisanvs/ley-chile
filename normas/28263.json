{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL ARTICULO 29&#xB0; Y EL INCISO 3&#xB0; DEL ARTICULO 134&#xB0; DEL CODIGO DEL TRABAJO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 5976463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase, en el art&#xED;culo 29&#xB0; y en el inciso 3&#xB0; del art&#xED;culo 134&#xB0; del C&#xF3;digo del Trabajo, la expresi&#xF3;n &quot;sesenta&quot; por &quot;ciento ochenta&quot;.&quot;. </div></div>", "i": 5976464}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, doce de septiembre de mil novecientos sesenta y cuatro.- JORGE ALESSANDRI RODRIGUEZ.- Miguel Schweitzer.</div><br></div>", "i": 5976465}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15699", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15699"}], "organismos": ["MINISTERIO DEL TRABAJO"], "titulo_norma": "MODIFICA EL ARTICULO 29° Y EL INCISO 3° DEL ARTICULO\n134° DEL CODIGO DEL TRABAJO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "CODIGO TRABAJO", "PRESCRIPCION", "PLAZO", "COBRO", "HORAS EXTRAORDINARIAS", "SOBRETIEMPO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1964-09-12", "doble_articulado": false, "id_norma": "28263", "numero_fuente": "25954", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1964-10-02", "vigencias": [{"desde": "1964-10-02", "hasta": "", "tipo_