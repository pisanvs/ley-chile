{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7353785}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 750 de 2 de agosto de 2007 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme D.L. N&#xBA; 2.186 de 1978, del inmueble ubicado en Vicu&#xF1;a Mackenna 8572, presunto Rol de Aval&#xFA;o N&#xBA; 2292-25, comuna de La Florida, de aparente dominio de Rom&#xE1;n Avendano Rosa y Otros; correspondiente al Lote N&#xBA; 23 Tramo 1, del Proyecto Vial &quot;Habilitaci&#xF3;n Corredor de Transporte P&#xFA;blico Avda. Vicu&#xF1;a Mackenna&quot;. Comisi&#xF3;n integrada por Dionisio Rodr&#xED;guez Astudillo, Constructor Civil; Mar&#xED;a Pilar Quiroga Gonz&#xE1;lez, Arquitecto y Gast&#xF3;n Bravo Hurtado, Ingeniero Civil; seg&#xFA;n informe de 6 de septiembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $17.218.000.- pagadera al contado.</div><br></div>", "i": 7353786}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7353787}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "750", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-750"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-02", "doble_articulado": false, "id_norma": "264819", "numero_fuente": "38865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-15", "vigencias": [{"desde": "2007-09-15