{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,896 que autoriza el pago de los billetes fiscales</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m 1,896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico . Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta en lo que resta del presente a&#xF1;o hasta la suma quince mil libras esterlinas (L 15,000) en el pago del valor de los billetes fiscales contratados con el ajente de la Compa&#xF1;&#xED;a Americana de Billetes de Banco.</div><br></div>", "i": 5952352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 15 de diciembre de 1906.- PEDRO MONTT.- Rafael Sotomayor.</div><br></div>", "i": 5952353}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1896", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1896"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NUM 1,896 QUE AUTORIZA EL PAGO DE LOS BILLETES FISCALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BILLETES FISCALES", "VALOR", "PAGO", "COMPA IA AMERICANA", "BILLETES BANCO", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-12-15", "doble_articulado": false, "id_norma": "22989", "numero_fuente": "8679", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":