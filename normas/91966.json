{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br><br></div>", "i": 8321012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.279, de 07 de Septiembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n N&#xBA; 123, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Jos&#xE9; Antonio Mu&#xF1;oz Infante, R.U.T. N&#xBA; 6.429.523-3, domiciliado en Poblaci&#xF3;n Benidorm, Block 1, Depto. N&#xBA; 24, Vi&#xF1;a del Mar, para desarrollar actividades pesqueras de extracci&#xF3;n, en orden a se&#xF1;alar que las actuales caracter&#xED;sticas n&#xE1;uticas de la embarcaci&#xF3;n a que se refiere dicha Resoluci&#xF3;n son las siguientes:</div><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;PETERSEO II&quot;</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  0749 de Capitan&#xED;a de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Puerto San Antonio.</div><div class=\"p\">Eslora&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 14,5 m.</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  4,2 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2,1 m.</div><div class=\"p\">Toneladas de Registro Grueso&nbsp; &nbsp; &nbsp; 34,47</div><div class=\"p\">Toneladas de Registro Neto&nbsp; &nbsp; &nbsp; &nbsp; 18,23</div><div class=\"p\">Capacidad de Bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  33,0 m3.</div><div class=\"p\">Arte de Pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Espinel y red</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; albacorera.</div><br></div>", "i": 8321013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de Septiembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br><br></div>", "i": 8321014}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1279", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1279"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-09-07", "fecha_derogacion": "1990-12-10", "doble_articulado": false, "id_norma": "91966", "numero_fuente": "33490", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-10-06", "vigencias": [{"desde": "1990-12-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-10-06", "hasta": "1990-12-09", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1990-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-10-06", "fin_vigencia": "1990-12-09", "tipo_version": "0"}, {"inicio_vigencia": "1990-12-10", "fin_vigencia": "", "tipo_version": "2"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PMZ", "fecha_ingreso": "2003-04-02", "fecha_version": "1990-12-10", "actualizado_por": "CMV", "fecha_actualizacion_texto": "1990-12-10", "tipo_t