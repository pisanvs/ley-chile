{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.504, DE 1987 </div></div>", "i": 6271664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.504, de fecha 9 de Julio de 1987, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el art. 1&#xB0; de la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 757, de 1986, del Centro de Formaci&#xF3;n T&#xE9;cnica ISI de Santiago, en el sentido de invertir el plan de estudio aprobado, autorizando plan especial de estudios, por &#xFA;nica vez, a las alumnas del cuarto semestre de la carrera Dise&#xF1;o y Decoraci&#xF3;n. </div></div>", "i": 6271665}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6271666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1504 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1504 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.504, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-09", "doble_articulado": false, "id_norma": "167557", "numero_fuente": "32902", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-24", "vigencias": [{"desde": "1987-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-10-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CM