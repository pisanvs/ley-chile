{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6467729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 2,00% anual durante el mes de febrero de 2004. Asimismo, en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de febrero de 2004, fue de 1,61% anual. </div></div>", "i": 6467730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de marzo de 2004.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6467731}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-03", "doble_articulado": false, "id_norma": "222072", "numero_fuente": "37803", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-05", "vigencias": [{"desde": "2004-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2