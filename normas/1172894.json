{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10312162}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 30, de 13 enero 2022, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativa a la actividad denominada &quot;Corte de &#xC1;rboles por Control Fitosanitario Gesti&#xF3;n Medio Ambiente&quot;, en la ciudad de Coyhaique, y autoriz&#xF3; a I. Municipalidad de Coyhaique para realizar las siguientes intervenciones en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte parcial de v&#xED;a en calle Per&#xFA; 065 de la ciudad de Coyhaique, el d&#xED;a jueves 13 de enero de 2022, desde las 09:00 hrs. hasta las 12:00 hrs. </div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10312163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Lara Acevedo, Gobernador Regional (S), Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesor Jur&#xED;dico, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10312164}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "30 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-30 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2088539", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-13", "doble_articulado": false, "id_norma": "1172894", "numero_fuente": "43183", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-02-19", "vigencias": [{"desde": "2022-02-19", "hasta": "", "tipo_vers