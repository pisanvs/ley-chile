{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 8326192}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No.1.174 de 29 de Agosto de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga la resoluci&#xF3;n No.607, de 1984, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Manuel Arriagada Neira, C&#xE9;dula de Identidad No.110.926, domiciliado Pichi-Pelluco, Manzana No.47, casa 24, Puerto Montt, para desarrollar actividades pesqueras de cultivo de alga Gracilaria, en el Estero Cheteb, Comuna de Quell&#xF3;n, Provincia de Chilo&#xE9;, X Regi&#xF3;n, por renuncia de su titular. </div></div>", "i": 8326193}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 29 de Agosto de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8326194}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1174", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1174"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-29", "doble_articulado": false, "id_norma": "95476", "numero_fuente": "33471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-12", "vigencias": [{"desde": "1989-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],