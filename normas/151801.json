{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6220821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 184, de 24.07.87 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n, se autoriza a la Empresa de Transportes Puma Ltda., para efectuar toda clase de servicios de transporte de pasajeros, por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbanos, de acuerdo a lo dispuesto en el DS 163/84.</div><br></div>", "i": 6220822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Temuco, 24.07.87.- Oscar C&#xF3;rdova Jim&#xE9;nez, Secretario Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n.</div><br></div>", "i": 6220823}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "184", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-184"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-24", "doble_articulado": false, "id_norma": "151801", "numero_fuente": "32838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-05", "vigencias": [{"desde": "1987-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient