{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 218 DE 17 JUNIO DE 1985 </div></div>", "i": 7267527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico-Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo Comercial B No. 64, de Los Angeles.</div><br><div class=\"p\">&nbsp; &nbsp;  Especialidades:</div><div class=\"p\">&nbsp; &nbsp;  1.- Contabilidad.</div><div class=\"p\">&nbsp; &nbsp;  2.- Ventas y Publicidad</div><div class=\"p\">&nbsp; &nbsp;  3.- Secretariado Administrativo.</div><div class=\"p\">&nbsp; &nbsp;  4.- Gesti&#xF3;n Administrativa.</div><br></div>", "i": 7267528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  28 de junio de 1985.- Ba&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 7267529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "218 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-218 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 218\nDE 17 JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "165332", "numero_fuente": "32342", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-09", "vigencias": [{"desde": "1985-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci