{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;12.861 EXENTA, DE 1999 </div><br></div>", "i": 6225129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;12.861, de 29 de diciembre de 1999, se ha aprobado, al Colegio Verbo Divino, comuna de Las Condes, de Santiago, un plan de estudio para segundo a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000, de acuerdo a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA;220 de 1998 y sus modificaciones.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 6225130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de enero de 2000.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6225131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12861 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12861 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº12.861 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "153093", "numero_fuente": "36575", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-29", "vigencias": [{"desde": "2000-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-29",