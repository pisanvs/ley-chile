{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6545206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.309, de 30 de septiembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SANTIAGO FERMIN FRE CORTES, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Camino a la Antena s/n, Ruta B-1, Taltal, comuna de Taltal, provincia de Antofagasta, II Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6545207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de septiembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6545208}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3309 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3309 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-30", "doble_articulado": false, "id_norma": "243226", "numero_fuente": "38293", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-22", "vigencias": [{"desde": "2005-10-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_in