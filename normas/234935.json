{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6514085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 3.594 de 20 de diciembre de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a PRODUCTOS ALIMENTICIOS CORBAC LIMITADA, para ampliar las actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en Altamirano N&#xBA; 2376, Independencia, Santiago, en la l&#xED;nea de proceso de Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.849 de 2004, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6514086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6514087}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3594 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3594 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-20", "doble_articulado": false, "id_norma": "234935", "numero_fuente": "38067", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-22", "vigencias": [{"desde": "2005-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-01-22", "