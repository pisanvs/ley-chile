{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6244287}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;3.038, de 30 de septiembre de 1999, se expropiaron los lotes de terreno N&#xBA;s. 27 y 52-A, superficies 319 m&#xB2; y 3.925 m&#xB2;, roles de aval&#xFA;os 9.317-296 y 9.316-7, comuna de Valpara&#xED;so, obra Proyecto Habilitaci&#xF3;n Nuevo Camino La P&#xF3;lvora, Etapa I, sector Ruta 68-Acceso Sur a Valpara&#xED;so y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Kurt Zahlhaas Elso y Luis Foppiano Cordano, ascendente a las cantidades de $1.363.863 y $12.142.475.</div><br></div>", "i": 6244288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6244289}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3038", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3038"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-30", "doble_articulado": false, "id_norma": "159172", "numero_fuente": "36602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-01", "vigencias": [{"desde": "2000-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "2000-03-01", "fecha_version": "2000-03-01", "fecha_actualizacion_texto": "2000-03-01", "tipo_tra