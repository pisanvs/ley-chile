{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9168328}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 2.135, de 9 de agosto de 2011, de esta Subsecretar&#xED;a, la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Merluza del sur, declarada en estado de plena explotaci&#xF3;n y sometida a dicho r&#xE9;gimen de administraci&#xF3;n en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 47&#xB0; LS y el paralelo 57&#xB0; LS, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, al 30 de junio de 2011, es la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp; <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/20131.jpg\"></div></div>", "i": 9168329}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de agosto de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9168330}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2135 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2135 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2011-08-09", "fecha_derogacion": "2011-11-30", "doble_articulado": false, "id_norma": "1028732", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2011-08-17", "vigencias": [{"desde": "2011-11-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2011-08-17", "hasta": "2011-11-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "v