{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10310777}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xB0; 14 de 13 de enero de 2022, se tuvo por desistida la expropiaci&#xF3;n del lote de terreno N&#xB0; 19-2, ordenada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1153511&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xB0; 1402 de 30 de noviembre de 2020</a>, para la obra: Relicitaci&#xF3;n Concesi&#xF3;n Camino Nogales - Puchuncav&#xED;, Sector: Sector 2 (By Pass a Ruta F 30E), Subsector: By Pass Puchuncav&#xED; Km. 25.500 al Km. 33.000,00, comuna de Puchuncav&#xED;, Provincia de Valpara&#xED;so, Regi&#xF3;n de Valpara&#xED;so. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xB0; y 32&#xB0; del Decreto Ley N&#xB0; 2186, de 1978. </div></div>", "i": 10310778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10310779}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "14 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-14 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2080739", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-13", "doble_articulado": false, "id_norma": "1172617", "numero_fuente": "43179", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-02-15", "vigencias": [{"desde": "2022-02-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú