{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10092942}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3730 de fecha 19 de diciembre de 2019 de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en El Sauzal Chacarilla, Rol N&#xBA; 167-214 comuna Maule, superficie 1.575 metros cuadrados de terreno, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Luna Olivares Paula Andrea y otros. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, arquitecto; Rodrigo Antonio Silva Lazo, constructor civil y Pedro Pablo Cruz Weston, arquitecto; seg&#xFA;n informe de tasaci&#xF3;n evacuado con fecha 4 de diciembre de 2019, fij&#xF3; monto provisional indemnizaci&#xF3;n en $46.185.600.- pagados al contado.- </div></div>", "i": 10092943}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10092944}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3730 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3730 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1707282", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-19", "doble_articulado": false, "id_norma": "1141185", "numero_fuente": "42553", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-01-15", "vigencias": [{"desde": "2020-0