{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 71.- Santiago, 27 de Marzo de 1931.- Vistas las facultades extraordinarias que me confiere la ley n&#xFA;mero 4,945, de 6 de Febrero del presente a&#xF1;o,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7116538}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ref&#xFA;ndense en una sola las letra g), h) e i), y denom&#xED;nase esta fusi&#xF3;n letra g) del &#xED;tem 1603 del Presupuesto de Gastos Extraordinarios del presente a&#xF1;o, con la siguiente glosa:</div><div class=\"p\">&nbsp; &nbsp; &quot;Para atender a adquisiciones, reparaciones, compromisos y dem&#xE1;s gastos____________________$7.716,000</div><br></div>", "i": 7116539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- E.v. Schroeders.</div><br></div>", "i": 7116540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "71", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-71"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO", "EXTRAORDINARIO NACION", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-03-27", "doble_articulado": false, "id_norma": "4430", "numero_fuente": "15975", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-19", "vigencias": [{"desde": "1931-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-19", "fin_vigencia": ""}, "vigencias_versi