{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA SALAZAR LIMITADA, PARA AMPLIAR ACTIVIDADES PESQUERAS </div></div>", "i": 7267563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 783, de 29 de Noviembre de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Salazar Limitada, domiciliada en Coquimbo, para instalar y operar un establecimiento suspendido de cultivo de osti&#xF3;n del Norte, en porciones de agua de la Bah&#xED;a de Tongoy, comuna de Coquimbo, IV Regi&#xF3;n.</div><br></div>", "i": 7267564}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de Noviembre de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7267565}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "783", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-783"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA SALAZAR LIMITADA, PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-29", "doble_articulado": false, "id_norma": "165399", "numero_fuente": "32347", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-14", "vigencias": [{"desde": "1985-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACI