{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743544}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 735, de 30 de noviembre de 1995, se expropiaron los lotes de terreno N&#xBA;s. 1, 2, 4, 11, 12, 13, 15 y 16, superficies 672, 591, 357, 556, 168, 186, 520 y 450 m2., respectivamente, roles de aval&#xFA;o 337-49, 333-43, y 1336-2, comunas de Nacimiento y Santa Juana, para la obra Camino de la Madera, sector Bifurcaci&#xF3;n Diuqu&#xED;n - Santa Juana y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Juan R&#xED;os Guzm&#xE1;n y otro, Pedro Gonz&#xE1;lez Medina y Te&#xF3;fila Gallardo y otro, ascendente a las cantidades de $ 233.454, $ 57.084 y $ 328.328.-</div><br></div>", "i": 6743545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "735", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-735"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-30", "doble_articulado": false, "id_norma": "224882", "numero_fuente": "35381", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-01", "vigencias": [{"desde": "1996-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingres