{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION QUE INDICA </div></div>", "i": 8929922}, {"t": "<div><div class=\"p\">Por Decreto No. 702 de 1992, Municipalidad de Macul orden&#xF3; expropiaci&#xF3;n de parte de inmueble ubicado en Los Olmos No. 2745, conforme DFL 458/76, DL 2186/78 y Ley No. 18.695, predio dominio aparente Adela Adel Abutom Jamis y Otro, inscrito Registro de Propiedad a fs. 31.168, No. 28.755 a&#xF1;o 1991, Conservador de Bienes Ra&#xED;ces de Santiago. Indemnizaci&#xF3;n se pact&#xF3; en $ 1.542.864,00.- , que se compensaron con derechos de edificaci&#xF3;n en resto del predio. </div></div>", "i": 8929923}, {"t": "<div><div class=\"p\">El Alcalde.</div><br></div>", "i": 8929924}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "702", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-702"}], "organismos": ["MUNICIPALIDAD DE MACUL"], "titulo_norma": "ORDENA EXPROPIACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EL PRESENTE DECRETO ALCALDICIO NO INDICA FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "84846", "numero_fuente": "34390", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-10-15", "vigencias": [{"desde": "1992-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PGA", "fecha_ingreso": "1998-01-14", "fecha_version": "1992-10-15", "fecha_actualizacion_texto": "1992-10-15", "tipo_tratado": ""}, "alertas": [],