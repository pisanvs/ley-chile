{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6302802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.974, de 7 de septiembre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; JOHN EDGAR GATT BRAVO, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Maip&#xFA; N&#xBA; 1.020, interior, comuna de Tom&#xE9;, provincia de Concepci&#xF3;n, VIII Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Congelado, Fresco-Refrigerado, Seco-Salado y Ahumado: Congrio colorado, Congrio negro, Merluza com&#xFA;n, Reineta y Macha.</div><br></div>", "i": 6302803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de septiembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 6302804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1974", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1974"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-07", "doble_articulado": false, "id_norma": "176166", "numero_fuente": "36774", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-28", "vigencias": [{"desde": "2000-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-28", "fin_vigencia": "", "tipo_version": "3"}