{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8332931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.075, de 29 de julio de 1998, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA OMEGA</div><div class=\"p\">LIMITADA, para iniciar actividades pesqueras extractivas con</div><div class=\"p\">una nave denominada &apos;&apos;Elena&apos;s&apos;&apos;, en el litoral</div><div class=\"p\">correspondiente a las Islas de Pascua, Salas y G&#xF3;mez, Juan</div><div class=\"p\">Fern&#xE1;ndez y San F&#xE9;lix, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar con espinel los siguientes recursos&nbsp; hidrobiol&#xF3;gicos: Anguila, At&#xFA;n aleta amarilla, At&#xFA;n aleta larga, At&#xFA;n ojos grandes, Bacalao de profundidad, Marrajo o tibur&#xF3;n, Toremo, Pez Volador, Remoremo y Tollo. </div></div>", "i": 8332932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de julio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8332933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1075", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1075"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA OMEGA LIMITADA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-07-29", "fecha_derogacion": "2017-05-12", "doble_articulado": false, "id_norma": "122771", "tipo_version": "2", "tipo_version_s": "Úl