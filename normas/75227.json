{"html": [{"t": "<div><div class=\"p\">PRORROGA VIGENCIA RESOLUCION QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.473 exenta.- Santiago, 31 de diciembre de 1986.- Visto: Lo dispuesto en los art&#xED;culos 28 y 29 de la Ley N&#xBA; 18.469 y teniendo presente las facultades que me confiere el art&#xED;culo 30 de dicho texto legal y el decreto ley N&#xBA; 2.763, de 1979, dicto la siguiente, </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n:</div><br></div>", "i": 9048650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Prorr&#xF3;gase la vigencia de la resoluci&#xF3;n exenta N&#xBA; 1.717, de 19 de diciembre de 1985, del Ministerio de Salud, hasta el 31 de diciembre de 1987.</div><br></div>", "i": 9048651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese.- Dr. Juan Giaconi Gandolfo, Ministro de Salud.- Hern&#xE1;n B&#xFC;chi Buc, Ministro de Hacienda.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Dr. Alfredo Rioseco Bezanilla, Subsecretario de Salud subrogante.</div><br></div>", "i": 9048652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1473 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1473 EXENTA"}], "organismos": ["MINISTERIO DE SALUD"], "titulo_norma": "PRORROGA VIGENCIA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRORROGA", "VIGENCIA", "REGIMEN DE PRESTACIONES DE SALUD", "APORTE FISCAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-31", "doble_articulado": false, "id_norma": "75227", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-14", "vigencias": [{"desde": "1987-02-14", "hasta": ""