{"html": [{"t": "<div><div class=\"p\">AUTORIZA A HIPERMERCADO JUMBO S.A. PARA DESARROLLAR ACTIVIDADES PESQUERAS </div></div>", "i": 6244127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 382, de 8 de Julio de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Hipermercado Jumbo S.A., domiciliada en la comuna de Santiago, para elaborar en su local ubicado en Bilbao No. 4144, Las Condes, Santiago, en la l&#xED;nea de congelado, los recursos hidrobiol&#xF3;gicos: camar&#xF3;n de r&#xED;o Norte, langosta de Juan Fern&#xE1;ndez, jaiba, erizo y piure.</div><br></div>", "i": 6244128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de Julio de 1985.- - Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6244129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "382", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-382"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A HIPERMERCADO JUMBO S.A. PARA DESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-08", "doble_articulado": false, "id_norma": "159119", "numero_fuente": "32227", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-20", "vigencias": [{"desde": "1985-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-20", "fin_vigencia": "", "tipo_version": "3"}], "event