{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8299216}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 91 de fecha 05 de Agosto de 1996, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se ha rechazado el Recurso de Reclamaci&#xF3;n interpuesto por la empresa Pesquera Santa Luc&#xED;a S.A., Rut.: 96.527.920-2 y confirmada la Resoluci&#xF3;n/N&#xB0; 1.599 de la Subsecretar&#xED;a de Pesca, del a&#xF1;o 1995 que declar&#xF3; la caducidad parcial de las Resoluciones N&#xB0; 1.791, de 1989 y 385 de 1991 de esa Subsecretar&#xED;a, que autorizaron a dicha empresa para desarrollar actividades con la nave &quot;Luc&#xED;a&quot;. </div></div>", "i": 8299217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Oscar Landerretche Gacit&#xFA;a, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8299218}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "91", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-91"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECURSO DE RECLAMACION", "PESQUERA SANTA LUCIA S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-08-05", "doble_articulado": false, "id_norma": "38270", "numero_fuente": "35607", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-11-05", "vigencias": [{"desde": "1996-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-11-05", "fin_vigen