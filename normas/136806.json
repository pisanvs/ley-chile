{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6169915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese por gracia una pensi&#xF3;n anual de dos mil pesos &#xE1; do&#xF1;a Virginia Donoso y Rodr&#xED;guez.&quot; </div></div>", "i": 6169916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, o&#xED;do el Consejo de Estado, he tenido &#xE1; bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese &#xE1; efecto en todas sus partes como ley de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Enero de 1893.- JORGE MONTT.- Isidoro Err&#xE1;zuriz.</div><br></div>", "i": 6169917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-S/N"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-01-26", "doble_articulado": false, "id_norma": "136806", "numero_fuente": "4435", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-01-28", "vigencias": [{"desde": "1893-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-01-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-01-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-05-20", "fecha_version"