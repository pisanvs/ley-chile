{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6562161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 437, de 8 de febrero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a SALMONOIL S.A. para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en sector La Campana s/n, Calbuco, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de harina y aceite los desechos provenientes de los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6562162}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Valpara&#xED;so, 8 de febrero de 2006.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6562163}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "437 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-437 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-08", "doble_articulado": false, "id_norma": "247508", "numero_fuente": "38397", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-02-23", "vigencias": [{"desde": "2006-02-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-02-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-02-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2006-02-23", "fecha_version": "2