{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6049953}, {"t": "<div><div class=\"p\">Por Decreto M.O.P. No. 219 de 20 de agosto de 1992, se expropiaron los lotes de terreno No. s. 1-A, 1-B, 2-A, 2-B y 3-A, superficies 1.840 M2., 1.770 M2, 2.460 M2., 1.280 M2. y 4.048,20 M2. respectivamente, roles de aval&#xFA;os 11-332, 81-28, y 11-330, Comuna de Pirque, obra Sector Acceso Puente y Defensa R&#xED;o Clarillo y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Max Silva del Campo, Enrique del Campo Garc&#xED;a de la Huerta y Jorge D&#xED;az Solar, ascendente a las cantidades de $ 5.802.600, $ 6.311.600, $ 7.482.300. </div></div>", "i": 6049954}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6049955}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "219", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-219"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-08-20", "doble_articulado": false, "id_norma": "77120", "numero_fuente": "34379", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-10-01", "vigencias": [{"desde": "1992-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1997-11-26", "fecha_version": "1992-10-01", "fecha_actualizacion_texto": "1992-10-01", "tipo_tratad