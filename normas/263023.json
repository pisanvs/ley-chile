{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 976 EXENTO, DE 2007 </div></div>", "i": 7348604}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 976, de fecha 24 de mayo de 2007, del Ministerio de Educaci&#xF3;n, se deja sin efecto la aprobaci&#xF3;n del plan y programas de estudio de la carrera de T&#xE9;cnico en Construcci&#xF3;n, aprobada para el Centro de Formaci&#xF3;n T&#xE9;cnica Alexander Von Humboldt, mediante decreto exento de Educaci&#xF3;n N&#xBA; 249 del 1 de octubre de 1990 modificado por decreto exento de Educaci&#xF3;n N&#xBA; 407 del 4 de junio de 2003, a petici&#xF3;n de la propia entidad, dado que no registra matr&#xED;cula de alumnos en los &#xFA;ltimos a&#xF1;os y no se continuar&#xE1; impartiendo.</div><br></div>", "i": 7348605}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de julio de 2007.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 7348606}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "976 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-976 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 976 EXENTO, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-05-24", "doble_articulado": false, "id_norma": "263023", "numero_fuente": "38823", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-27", "vigencias": [{"desde": "2007-07-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-07-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-