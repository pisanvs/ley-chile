{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6097285}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 478 de 12 de mayo 1989 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186 de 1978, inmueble ubicado calle Ricardo Santa Cruz No. 592, presunto rol aval&#xFA;os 624-54 comuna Santiago aparentemente dominio de don Fernando Echeverr&#xED;a Leiva. Comisi&#xF3;n integrada por peritos Sres. Teresa Sancho Pernas, arquitecto y Jos&#xE9; Miguel Haltenlhoff Aenishalslin y Carlos del Pedregal S&#xE1;nchez, constructores civiles, seg&#xFA;n informe de 1 de diciembre 1988, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 1.930.770.-, pagadera al contado.</div><br></div>", "i": 6097286}, {"t": "<div><div class=\"p\">- Director SERVIU Metropolitano.</div><br></div>", "i": 6097287}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "478", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-478"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-12", "doble_articulado": false, "id_norma": "94508", "numero_fuente": "33398", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-15", "vigencias": [{"desde": "1989-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ing