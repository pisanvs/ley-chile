{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6265808}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 423, de 09 de Octubre de 1984, de la de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n, se autoriza a Jos&#xE9; Armando Molina Vidal para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos dentro del territorio nacional excepci&#xF3;n de los servicios p&#xFA;blicos urbanos locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6265809}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6265810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "423 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-423 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-10-09", "doble_articulado": false, "id_norma": "165821", "numero_fuente": "32070", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-14", "vigencias": [{"desde": "1985-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr