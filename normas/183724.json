{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 458 EXENTO, DE 1999 </div></div>", "i": 6329475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 458 de fecha 29 de diciembre de 1999 del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobado a la Universidad Aut&#xF3;noma del Sur, el plan y los programas de estudios de la carrera de Contador Auditor conducente al t&#xED;tulo profesional de Contador Auditor, para ser impartida en jornada diurna en su Sede de la ciudad de Temuco, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6329476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de febrero de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6329477}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "458 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-458 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 458 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "183724", "numero_fuente": "36933", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-07", "vigencias": [{"desde": "2001-04-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingre