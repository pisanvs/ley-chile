{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;308, de 5 de marzo de 1998, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la reconsideraci&#xF3;n solicitada por PESQUERA MARFISH LIMITADA, respecto de la resoluci&#xF3;n N&#xBA;1.676 de 1997, de esta Subsecretar&#xED;a, que neg&#xF3; lugar a la iniciaci&#xF3;n de actividades pesqueras con la&nbsp; nave &quot;Do&#xF1;a Elsa&quot;, en la captura de recursos pel&#xE1;gicos en el litoral de la X Regi&#xF3;n, por encontrarse suspendida en dicha &#xE1;rea la recepci&#xF3;n de solicitudes y el otorgamiento de autorizaciones, por D.S. N&#xBA;548 de 1997, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8328634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de marzo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8328635}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "308", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-308"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MARFISH LIMITADA", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-05", "doble_articulado": false, "id_norma": "97350", "numero_fuente": "36021", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-21", "vigencias": [{"desde": "1998-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenci