{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6332284}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por R.M. (Ex.) N&#xBA; 74, de 19 de abril de 2001, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ac&#xF3;gese la reclamaci&#xF3;n de&nbsp; Pesquera Itata S.A. contra la resoluci&#xF3;n N&#xBA; 447 de 2001, de la Subsecretar&#xED;a de Pesca. Consid&#xE9;rese en la determinaci&#xF3;n de l&#xED;mite m&#xE1;ximo de captura en la unidad de pesquer&#xED;a Anchoveta, V a X Regiones, la siguiente captura total de la nave Pilmaiqu&#xE9;n I, en el mes que se indica:</div><br><div class=\"p\">&nbsp; &nbsp;  Mayo de 2000: 1.475,700 toneladas.</div><br></div>", "i": 6332285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alvaro D&#xED;az P&#xE9;rez, Ministro de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n (S).</div><br></div>", "i": 6332286}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "74 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-74 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-19", "doble_articulado": false, "id_norma": "184610", "numero_fuente": "36948", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-27", "vigencias": [{"desde": "2001-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-27", "fin_vigencia": "", "tipo_version": "3"}], "e