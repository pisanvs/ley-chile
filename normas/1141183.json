{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div><br></div>", "i": 10093092}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.843, de 26 de diciembre 2019, rectificada por resoluci&#xF3;n exenta N&#xBA; 3.979 de 31 diciembre 2019, ambas de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 Ley 16.391, de inmueble ubicado en 26 Sur 6 Poniente 260 LT 8, Rol Aval&#xFA;o N&#xBA; 3703-218, comuna de Talca, superficie de 101,04 m2, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Garrido Gonz&#xE1;lez Mariza y otros. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, Arquitecto; Rodrigo Antonio Silva Lazo, Constructor Civil y Pedro Pablo Cruz Weston, Arquitecto, seg&#xFA;n informe de fecha 18 diciembre de 2019, fij&#xF3; monto provisional indemnizaci&#xF3;n en $18.335.800.- pagados al contado.- </div><br></div>", "i": 10093093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10093094}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3979 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3979 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1707739", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-31", "doble_articulado": false, "id_norma": "1141183", "numero_fuente": "42553", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":