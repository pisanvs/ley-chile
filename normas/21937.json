{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension Lei n&#xFA;m. 65.- Santiago, a 8 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a do&#xF1;a Clarisa Cavada, vuida de Martinez, una pension de veinte pesos mensuales, de que gozar&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 5946656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- V. D&#xE1;vila Larrain.</div><br></div>", "i": 5946657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "65", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-65"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CLARISA CAVADA", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-08", "doble_articulado": false, "id_norma": "21937", "numero_fuente": "4593", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-11", "vigencias": [{"desde": "1893-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-07", "fecha_version"