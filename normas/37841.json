{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6019291}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 6 del 15 de Julio de 1993, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IV Regi&#xF3;n se adjudic&#xF3; a la Sociedad Touring Club Ltda., la concesi&#xF3;n para operar, por un plazo de cinco (5) a&#xF1;os a contar de la fecha de publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle Eduardo de la Barra N&#xB0; 435 de la comuna de La Serena, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de todos los veh&#xED;culos no comprendidos en el inciso 1&#xB0;, art&#xED;culo 7&#xB0; del D.S. N&#xB0; 156/90, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6019292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Freddy Bonilla Torreblanca, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6019293}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "SOCIEDAD TOURING CLUB LTDA", "VEHICULOS MOTORIZADOS", "SERENA", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-15", "doble_articulado": false, "id_norma": "37841", "numero_fuente": "34702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-28", "vigencias": [{"desde": "1993-10