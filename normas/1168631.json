{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 2.678 DE 11.11.2021, QUE MODIFICA RESOLUCI&#xD3;N 5.034 DE 24.10.2019, AMBAS DE LA DIRECCI&#xD3;N NACIONAL DE ADUANAS</div></div>", "i": 10286592}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 2.678, de 11 de noviembre de 2021, del Director Nacional de Aduanas, se modific&#xF3; el numeral 6.1 de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1138308&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 5.034, de 24 de octubre de 2019</a>, en lo que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10286593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de noviembre de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10286594}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2678 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2678 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 2.678 DE 11.11.2021, QUE MODIFICA RESOLUCIÓN 5.034 DE 24.10.2019, AMBAS DE LA DIRECCIÓN NACIONAL DE ADUANAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2044908", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-11", "doble_articulado": false, "id_norma": "1168631", "numero_fuente": "43111", "tipo_version": "3", "tipo_versi