{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6258030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 139 de 26 de Abril de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Tadimaq Ltda. para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos; incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos sus remolques y semirremolques y los taxis, en el establecimiento ubicado en calle Los Carrera N&#xBA; 467 de la ciudad de Osorno.-</div><br></div>", "i": 6258031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial, Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 6258032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "139", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-139"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-26", "doble_articulado": false, "id_norma": "163320", "numero_fuente": "32203", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-22", "vigencias": [{"desde": "1985-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":