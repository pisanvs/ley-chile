{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;58 EXENTO, DE 1999 </div></div>", "i": 6297857}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 58, de 12 de marzo de 1999, se ha aprobado al Colegio &apos;&apos;Orchard College&apos;&apos; de Curic&#xF3;, un plan de estudio para los cursos de 1&#xBA; a 6&#xBA; a&#xF1;o (NB.1 a NB.4) de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; a contar del a&#xF1;o escolar 1999, de acuerdo con lo se&#xF1;alado en el decreto supremo de Educaci&#xF3;n N&#xBA;40 de 1996 y sus modificaciones.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores y cursos que se indican en el presente decreto.</div><br></div>", "i": 6297858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de marzo de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 6297859}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "58 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-58 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº58 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-12", "doble_articulado": false, "id_norma": "174649", "numero_fuente": "36749", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-26", "vigencias": [{"desde": "2000-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-26