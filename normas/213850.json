{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6436353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.749, de 31 de julio de 2003, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 905 de 2003, modificada mediante resoluciones N&#xBA; 1.271, N&#xBA; 1.441 y N&#xBA; 1.615, todas de 2003, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD CATOLICA DEL NORTE, SEDE COQUIMBO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto FIP 2003-03 denominado &quot;Evaluaci&#xF3;n directa de langostino colorado entre la III y IV Regiones, a&#xF1;o 2003&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se extender&#xE1; hasta el 15 de agosto de 2003.</div><br></div>", "i": 6436354}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de julio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6436355}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1749 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1749 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-31", "doble_articulado": false, "id_norma": "213850", "numero_fuente": "37641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-22", "vigencias": [{"desde": "2003-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-22", "fin_vige