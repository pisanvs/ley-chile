{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6224786}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 456 de 08 de Septiembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Emilio Jofr&#xE9; Gonz lez y Luis Riquelme Aguilar para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 50 &quot;San Luis-Regional Centro&quot;, de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n exenta N&#xB0; 12 de 04 de enero de 1985 y modificado por resoluci&#xF3;n exenta N&#xB0; 474 de 30 de Octubre de 1985, de esta Secretar&#xED;a Regional.- </div></div>", "i": 6224787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6224788}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "456 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-456 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-08", "doble_articulado": false, "id_norma": "152972", "numero_fuente": "32.606", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-25", "vigencias": [{"desde": "1986-10-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-25", "fin_vigencia": ""}, "vigencias_version