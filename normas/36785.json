{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.359, de 18 de julio de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la Resoluci&#xF3;n N&#xB0; 680 de 1989, de esta Subsecretar&#xED;a, solamente en cuanto autorizaron a PESQUERA SAN MIGUEL S.A., para realizar actividades pesqueras extractivas con la nave &quot;Southport&quot;, matr&#xED;cula 2566, respecto de la autorizaci&#xF3;n para capturar Merluza com&#xFA;n, y Congrio negro, en el litoral de la IV a la IX Regiones, en virtud de lo se&#xF1;alado en el inciso 2&#xB0; de la letra b) del Art. 143 del D.S. N&#xB0; 430 de 1991 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8297014}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de julio de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297015}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1359", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1359"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA SAN MIGUEL S.A", "PESCA", "AUTORIZACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-07-18", "fecha_derogacion": "2004-05-03", "doble_articulado": false, "id_norma": "36785", "numero_fuente": "35526", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-07-26", "vigencias": [{"desde": "2004-05-03", "hasta"