{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 130 EXENTO, DE 1994 </div></div>", "i": 5941628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento N&#xB0; 130 de fecha 29 de marzo de 1994 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto AIEP, para impartir plan y programas de Estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 1994:</div><div class=\"p\"> - Sede N&#xB0; 8 - Curic&#xF3;</div><br><div class=\"p\">Carrera&nbsp; : Dibujo de Arquitectura (Resoluci&#xF3;n Exenta</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; N&#xB0; 578 de 1988).</div><div class=\"p\"> T&#xED;tulo&nbsp;  : T&#xE9;cnico Dibujante de Arquitectura. </div></div>", "i": 5941629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 20 de Mayo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5941630}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "130", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-130"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 130 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INSTITUTO AIEP", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "DIBUJO ARQUITECTURA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-29", "doble_articulado": false, "id_norma": "20322", "numero_fuente": "34877", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-05-30", "vigencias": [{"desde": "1994-05-30", "ha