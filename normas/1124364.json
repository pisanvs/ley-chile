{"html": [{"t": "<div><div class=\"p\">RESOLUCI&#xD3;N N&#xB0;4.400, DE 04.10.2018, DEL DIRECTOR NACIONAL DE ADUANAS, QUE DETERMINA NO CONVOCAR A CONCURSO DE AGENTES DE ADUANA EN EL A&#xD1;O 2018</div></div>", "i": 9956807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 4.400, de 04.10.2018, del Director Nacional de Aduanas, se determina no convocar a concurso de Agentes de Aduana para el a&#xF1;o 2018.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n N&#xB0; 4.400, de 04.10.2018, se encuentra publicado en el sitio web del Servicio Nacional de Aduanas, www.aduana.cl.</div></div>", "i": 9956808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de octubre de 2018.- Pablo Ib&#xE1;&#xF1;ez Beltrami, Director Nacional de Aduanas (S). </div></div>", "i": 9956809}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4400", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4400"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "RESOLUCIÓN N°4.400, DE 04.10.2018, DEL DIRECTOR NACIONAL DE ADUANAS, QUE DETERMINA NO CONVOCAR A CONCURSO DE AGENTES DE ADUANA EN EL AÑO 2018", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1479604", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-10-04", "doble_articulado": false, "id_norma": "1124364", "numero_fuente": "42184", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-10-19", "vigencias": [{"desde": "2018-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-10-19", "fin_vigencia": ""}, "vigencias_ve