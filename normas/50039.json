{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6027313}, {"t": "<div><div class=\"p\">Por Decreto M.O.P. N&#xBA;971, de 19 de noviembre de 1996, se expropi&#xF3; el lote &#xFA;nico de terreno, superficie 3.330 m2., rol de aval&#xFA;o 173-8, comuna de Yerbas Buenas, para la obra Proyecto Sistema Regad&#xED;o Maule Sur Canal Alimentador al Estero Abranquil y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietaria Mar&#xED;a Luisa Guti&#xE9;rrez Le&#xF3;n o Mar&#xED;a Luisa Guti&#xE9;rrez Mosqueira, ascendente a la cantidad de $ 1.093.357.</div><br></div>", "i": 6027314}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6027315}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "971", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-971"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "DECRETO EXPROPIATORIO", "BIEN INMUEBLE", "YERBAS BUENAS", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-11-19", "doble_articulado": false, "id_norma": "50039", "numero_fuente": "35655", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-02", "vigencias": [{"desde": "1997-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAV", "fecha_ingreso": "1997-01-08", "fecha_version": "1997-01-02", "fecha_actualizacion_texto": "1997-01