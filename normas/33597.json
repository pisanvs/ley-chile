{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNASE COMO RECEPTOR JUDICIAL AL FUNCIONARIO QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 179.- Santiago, 19 de Julio de 1993.- Vistos: Lo dispuesto en el art&#xED;culo 11 del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6007366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley citado, en la Regi&#xF3;n Metropolitana, al se&#xF1;or:</div><div class=\"p\"> - Jaime Gar&#xED;n Grubrasich </div></div>", "i": 6007367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese Raz&#xF3;n, Reg&#xED;strese, Comun&#xED;quese y Publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional.</div><br></div>", "i": 6007368}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "179", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-179"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNASE COMO RECEPTOR JUDICIAL AL FUNCIONARIO QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECEPTOR JUDICIAL", "CARGOS JUDICIALES", "NOMBRAMIENTO", "JAIME GARIN GRUBRASICH", "INSTITUTO DESARROLLO AGROPECUARIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-19", "doble_articulado": false, "id_norma": "33597", "numero_fuente": "34650", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-08-25", "vigencias": [{"desde": "1993-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s":