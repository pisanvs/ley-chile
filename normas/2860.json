{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA ORDENANZA MUNICIPAL RESPECTO A EXTRACCION DE ARIDOS </div></div>", "i": 5854356}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Concejo Municipal de Calle Larga, por unanimidad de sus miembros en sesi&#xF3;n legalmente constituida, celebrada el d&#xED;a 23 de Julio de 1996, acord&#xF3; rebajar la Ordenanza Municipal con respecto a la Extracci&#xF3;n de Aridos desde un 5% de la UTM a un 0,8% de la UTM, seg&#xFA;n consta en Acta N&#xB0; 18-A Extraordinaria.-</div><br></div>", "i": 5854357}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Renato Rodr&#xED;guez Vicencio, Alcalde.</div><br></div>", "i": 5854358}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-S/N"}], "organismos": ["MUNICIPALIDAD DE CALLE LARGA"], "titulo_norma": "MODIFICA ORDENANZA MUNICIPAL RESPECTO A EXTRACCION\nDE ARIDOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "ORDENANZA MUNICIPAL", "DERECHOS MUNICIPALES", "EXTRACCION ARIDOS", "MUNICIPALIDAD CALLE LARGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07-23", "doble_articulado": false, "id_norma": "2860", "numero_fuente": "35567", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-14", "vigencias": [{"desde": "1996-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-09-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1996-09-14", "fecha_actualizacion_texto": "1996-09-14", "tipo_tratado": "