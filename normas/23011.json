{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,919 que suprime la Municipalidad de Pica i la incorpora a la de Iquique.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Supr&#xED;mese la Municipalidad de Pica e incorp&#xF3;rase su territorio a la de Iquique.</div><br></div>", "i": 8274842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de enero de 1907.- PEDRO MONTT.- V. Santa Cruz.</div><br></div>", "i": 8274843}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1919", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1919"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Lei núm. 1,919 que suprime la Municipalidad de Pica;i la incorpora a la de Iquique.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD", "IQUIQUE", "INCORPORACION", "SUPRESION", "PICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-01-26", "doble_articulado": false, "id_norma": "23011", "numero_fuente": "8711", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-01-26", "vigencias": [{"desde": "1907-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-01-26", "fin_vigencia": "", "t