{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA DE DENOMINACION A LA CALLE DE SAN ANTONIO, DE LOS PLACERES DE VALPARAISO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- La calle San Antonio, de los Placeres, de la ciudad de Valpara&#xED;so, se denominar&#xE1;, en lo sucesivo &quot;Jos&#xE9; Malfatti&quot;.</div><div class=\"p\">&nbsp; &nbsp; Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8278275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta y uno de Agosto de mil novecientos cuarenta y dos.- JUAN ANTONIO RIOS M.- Ra&#xFA;l Morales. </div></div>", "i": 8278276}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7261", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7261"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA DE DENOMINACION A LA CALLE DE SAN ANTONIO, DE\nLOS PLACERES DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE", "SAN ANTONIO", "JOSE MALFATTI", "VALPARAISO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1942-08-31", "doble_articulado": false, "id_norma": "25464", "numero_fuente": "19356", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1942-09-10", "vigencias": [{"desde": "1942-09-10", "hasta": "", "tipo_version": "