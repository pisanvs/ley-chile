{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIOS QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 272.- Santiago, 10 de julio de 2003.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA;2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6434831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, X Regi&#xF3;n, a los siguientes funcionarios:</div><br><div class=\"p\">- Rudy Kim Little Teppa&nbsp; &nbsp; RUT 6.308.871-4</div><div class=\"p\">- Angelino Leal R&#xED;os&nbsp; &nbsp; &nbsp;  RUT. 3.957.021-1.</div><br></div>", "i": 6434832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Halabi Caffena, Director Nacional.</div><br></div>", "i": 6434833}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "272", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-272"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO DE DESARROLLO AGROPECUARIO", "RECEPTOR JUDICIAL", "DECIMA REGION", "DESIGNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-10", "doble_articulado": false, "id_norma": "213386", "numero_fuente": "37630", "tipo_version": "3", "tipo_vers