{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; JUAN DE DIOS OLIVARES Lei n&#xFA;m. 267.-Santiago, a 4 de Febrero de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese por gracia, i por una sola vez, al ex-sarjento mayor don Juan de Dios Olivares la suma de dos mil quinientos pesos, en m&#xE9;rito de sus servicios prestados a la Rep&#xFA;blica.</div><br><br></div>", "i": 5947350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-</div><div class=\"p\">C&#xE1;rlos Rivera Jofr&#xE9;.</div><br></div>", "i": 5947351}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "267", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-267"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "JUAN DE DIOS OLIVARES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUAN DE DIOS OLIVARES", "BENEFICIO POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-02-04", "doble_articulado": false, "id_norma": "22121", "numero_fuente": "5034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-02-07", "vigencias": [{"desde": "1895-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-02-07", "fin_vigencia": "", "tipo_version": "3"}]