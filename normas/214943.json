{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO LA CALIDAD DE AGENTE RETENEDOR DE IVA, SEGUN RESOLUCION EX. N&#xBA; S/N DE 1992 </div></div>", "i": 6440647}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional del Servicio de Impuestos Internos, por Res. Ex. N&#xBA; 48 del 9 de septiembre de 2003 deja sin efecto la calidad de agente retenedor del IVA, a contar de la fecha de su publicaci&#xF3;n en el Diario Oficial, a la sociedad Pesquera Francis Drake S.A., RUT N&#xBA; 84.566.800-0, en las adquisiciones de especies hidrobiol&#xF3;gicas, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 3.722, del 28.07.2000, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6440648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Erica Morales Lartiga, Directora Regional. </div></div>", "i": 6440649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "48 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-48 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "DEJA SIN EFECTO LA CALIDAD DE AGENTE RETENEDOR DE IVA,\nSEGUN RESOLUCION EX. Nº S/N DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-09", "doble_articulado": false, "id_norma": "214943", "numero_fuente": "37665", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-22", "vigencias": [{"desde": "2003-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-22", "fin_v