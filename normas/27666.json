{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA CALLE QUE SE&#xD1;ALA DEL CERRO ALEGRE DE LA COMUNA DE VALPARAISO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La calle Atahualpa del Cerro Alegre de la comuna de Valpara&#xED;so se denominar&#xE1; &quot;Augusto D&apos;Halmar&quot;.&quot; </div></div>", "i": 8281262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintid&#xF3;s de Septiembre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o G. </div></div>", "i": 8281263}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14091", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14091"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA CALLE QUE SEÑALA DEL CERRO ALEGRE\nDE LA COMUNA DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CERRO ALEGRE", "VALPARAISO", "CALLE AUGUSTO D'HALMAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-09-22", "doble_articulado": false, "id_norma": "27666", "numero_fuente": "24761", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-10-05", "vigencias": [{"desde": "1960-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-10-05", "fin_vigencia": ""}, "