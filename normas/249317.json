{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; EXTRACTO</div><br></div>", "i": 7329568}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 89, de 7 de abril de 2006, de la Secretar&#xED;a Regional Ministerial de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se declar&#xF3; extinguida la pr&#xF3;rroga del contrato de concesi&#xF3;n de la Planta de Revisi&#xF3;n T&#xE9;cnica Clase B 0808, que practica revisi&#xF3;n t&#xE9;cnica de veh&#xED;culos Clase B, en la comuna de Los Angeles, dispuesto y aprobado mediante la resoluci&#xF3;n N&#xBA; 62, de 25 de agosto de 1997, de la Seremi precitada, estableci&#xE9;ndose la siguiente fecha de cierre, 11 de abril de 2006. </div></div>", "i": 7329569}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Claudio V&#xE1;squez Fern&#xE1;ndez, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 7329570}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "89 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-89 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-07", "doble_articulado": false, "id_norma": "249317", "numero_fuente": "38453", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-03", "vigencias": [{"desde": "2006-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vige