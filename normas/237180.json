{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 711 EXENTA, DE 2005 </div></div>", "i": 6522398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 711, de 6 de abril de</div><div class=\"p\">2005, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se</div><div class=\"p\">cancel&#xF3; del Registro de Organismos T&#xE9;cnicos Intermedios</div><div class=\"p\">para Capacitaci&#xF3;n al &quot;Organismo T&#xE9;cnico Intermedio para</div><div class=\"p\">Capacitaci&#xF3;n de los Industriales de la Regi&#xF3;n de</div><div class=\"p\">Tarapac&#xE1;&quot; (OTIC Puerta Norte), RUT N&#xBA; 75.934.780-3, y,</div><div class=\"p\">por ende, qued&#xF3; sin efecto su correspondiente</div><div class=\"p\">personalidad jur&#xED;dica, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 78 letra c) y 79 de la ley N&#xBA; 19.518. </div></div>", "i": 6522399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jossie Esc&#xE1;rate M&#xFC;ller, Directora Nacional. </div></div>", "i": 6522400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "711 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-711 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 711 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-06", "doble_articulado": false, "id_norma": "237180", "numero_fuente": "38139", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-19", "vigencias": [{"desde": "2005-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc