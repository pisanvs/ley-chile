{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 461, de 7 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura N&#xBA;93106031, presentada por SALMONES PACIFIC STAR LTDA., para operar un centro de cultivo ubicado en Canal San Pedro, comuna de Quell&#xF3;n, provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los art&#xED;culos 78 y 87 de la Ley General de Pesca y Acuicultura y art&#xED;culo 14 del DS N&#xBA;290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8329213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329214}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "461", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-461"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "QUELLON", "SALMONES PACIFIC STAR LTDA.", "DECIMA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-07", "doble_articulado": false, "id_norma": "98121", "numero_fuente": "36042", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-04-17", "vigencias": [{"desde": "1998-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-04-17", "fin_vigencia": ""}, "v