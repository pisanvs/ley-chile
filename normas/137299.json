{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,305.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al teniente-coronel don An&#xED;bal Wilson, para los efectos de su retiro, el tiempo que permaneci&#xF3; de cadete en la Escuela Militar&quot;.</div><br></div>", "i": 6171495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lgase i ll&#xE9;vese a efecto como lei de la Bep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de junio de mil novecientos diez.- Pedro Montt.- C&#xE1;rlos Larrain Claaro&quot;. </div></div>", "i": 6171496}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2305", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2305"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-06-28", "doble_articulado": false, "id_norma": "137299", "numero_fuente": "9738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-07-09", "vigencias": [{"desde": "1910-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-07-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-07-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-06-07"