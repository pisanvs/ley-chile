{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7373802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 390 de fecha 30 de mayo del 2008, se expropi&#xF3; el lote de terreno N&#xBA; 32, superficie 968 m2, rol N&#xBA; 243-3, comuna de Villa Alegre, VII Regi&#xF3;n para la obra Camino Ruta L-202, sector Villa Alegre Putag&#xE1;n, tramo Km. 0,00000 al Km. 11,44287, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Selcia Francisca Grand&#xF3;n Grand&#xF3;n, ascendente a la cantidad de $1.666.442.- para el lote N&#xBA; 32. </div></div>", "i": 7373803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7373804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "390 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-390 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-05-30", "doble_articulado": false, "id_norma": "273188", "numero_fuente": "39101", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-07-01", "vigencias": [{"desde": "2008-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2008-07-01", "fecha_version": "2008-07-01", "fecha_actualizacion_texto": "2008-07-01", "tipo_tratado": ""}, "alertas