{"html": [{"t": "<div><br><div class=\"p\">CONSTITUYE PARTIDO PROGRESISTA EN LAS REGIONES VI Y VII</div></div>", "i": 9257249}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marco Enr&#xED;quez-Ominami Gumucio y Cristian Warner Villagr&#xE1;n, Presidente y Secretario General de la Directiva Central del Partido Progresista, respectivamente, han solicitado la constituci&#xF3;n legal del partido en las Regiones VI y VII. Las solicitudes se&#xF1;alan acompa&#xF1;ar la cantidad de 2.342 y 2.674 fichas de afiliaci&#xF3;n, respectivamente.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 1.041, de fecha 27 de abril de 2012.- </div></div>", "i": 9257250}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 9257251}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1041", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1041"}, {"tipo": "3", "numero": "O-1041", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-O-1041"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "CONSTITUYE PARTIDO PROGRESISTA EN LAS REGIONES VI Y VII", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-04-27", "doble_articulado": false, "id_norma": "1040164", "numero_fuente": "40264", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-17", "vigencias": [{"desde": "2012-05-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-05-17",