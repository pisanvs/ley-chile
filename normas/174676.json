{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6297969}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.809, de 17 de agosto de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; EMPRESA PESQUERA BRAVAMAR Y CIA. LTDA., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Linda Kay&apos;&apos;, en el &#xE1;rea mar&#xED;tima que se indica, por fuera del &#xE1;rea de reserva artesanal, con arrastre, sobre los siguientes recursos hidrobiol&#xF3;gicos: a) Area mar&#xED;tima de la I Regi&#xF3;n: Langostino amarillo y Camar&#xF3;n nailon; b) Area mar&#xED;tima de la II Regi&#xF3;n: Langostino amarillo. </div></div>", "i": 6297970}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de agosto de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6297971}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1809", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1809"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-08-17", "fecha_derogacion": "2003-01-16", "doble_articulado": false, "id_norma": "174676", "numero_fuente": "36751", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-08-29", "vigencias": [{"desde": "2003-01-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-08-29", "hasta": "2003-01-15", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2003-01-16", "fin_v