{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6050036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decretos M.O.P. N&#xBA;s. 953 y 954, de 30 de septiembre de 1997, se expropiaron los lotes de terreno N&#xBA;s. 21-B, 16, 17 y 24, superficies 840, 1.951, 2.032 y 2.297 M&#xB2;, roles de aval&#xFA;o 152-3, 170-3 y en tr&#xE1;mite, comuna de Cauquenes, para la Obra Camino Cauquenes L&#xED;mite Regional Quirihue, Sector By Pass Norte, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Carlos Moya Ferrada, Waldo Garc&#xED;a Moraga y Juan Inostroza Bustos, ascendentes a las cantidades de $6.942.800.- para el lote 21-B, $23.062.552.- para los lotes 16 y 17 y $18.843.576.- para el lote 24.- </div></div>", "i": 6050037}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6050038}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "953", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-953"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "CAUQUENES", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-30", "doble_articulado": false, "id_norma": "77173", "numero_fuente": "35917", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-11-15", "vigencias": [{"desde": "1997-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient