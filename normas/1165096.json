{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10268305}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 380 de 13 agosto 2021 de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n Parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en Chacra El Retiro PC 4 Sur, Rol Aval&#xFA;o N&#xBA; 167-263, comuna Maule, comprende dos lotes de terrenos de una superficie total de 669,06 metros cuadrados, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Inmobiliaria Pocuro Limitada. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, Arquitecto; Rodrigo Antonio Silva Lazo, Constructor Civil y Pedro Pablo Cruz Weston, Arquitecto, taso en $50.179.500 seg&#xFA;n informe de 5 abril 2021, monto provisional indemnizaci&#xF3;n, reajustada legalmente, es la suma de $51.183.090.-, pagados al contado.-</div></div>", "i": 10268306}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp; &nbsp; An&#xED;bal Fr&#xED;as D&#xE1;vila, Director (S) Serviu Regi&#xF3;n del Maule.</div><div class=\"p\"> </div><br></div>", "i": 10268307}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "380 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-380 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2010079", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-08-13", "doble_articulado": false, "id_norma": "1165096", "numero_fuente": "43055", "tipo_versi