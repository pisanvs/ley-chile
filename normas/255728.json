{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6591424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;656 de fecha 29 de septiembre del 2006, se expropi&#xF3; el lote de terreno N&#xBA;47, superficie 377,86 m&#xB2;, Rol N&#xBA;251-99, comuna de Salamanca, IV Regi&#xF3;n para la obra &quot;Mejoramiento Ruta D-825, Limahuida-Almendrillo, sector Tahuinco-Salamanca Km. 13,14000 a Km. 23,49783, II Etapa&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Ana Luisa Gonz&#xE1;lez Quiroz, ascendente a la cantidad de $1.416.346.- para el lote N&#xBA;47.</div><br></div>", "i": 6591425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6591426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "656 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-656 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-29", "doble_articulado": false, "id_norma": "255728", "numero_fuente": "38628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-01", "vigencias": [{"desde": "2006-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-12-01", "fecha_version": "2006-12-01", "fecha_actualizacion_texto": "2006-12