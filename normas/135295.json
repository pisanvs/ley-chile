{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,655.- Santiago, 8 de julio de 1904.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6164957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se declaran de utilidad p&#xFA;blica los terrenos necesarios para la via, estaciones i demas dependencias del ferrocarril de Ovalle a Trapiche, en conformidad a los planos aprobados por el Consejo de Obras P&#xFA;blicas i por el Ministerio del ramo.</div><br></div>", "i": 6164958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Anfion Mu&#xF1;oz.</div><br></div>", "i": 6164959}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1655", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1655"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-07-08", "doble_articulado": false, "id_norma": "135295", "numero_fuente": "7966", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-07-29", "vigencias": [{"desde": "1904-07-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-07-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1904-07-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM",