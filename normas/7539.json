{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA DECRETO N&#xB0; 212, DE 1992</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 14.- Santiago, 1 de Febrero de 1993.- Visto: El D.L. N&#xB0; 557 de 1974, los art&#xED;culos 3&#xB0; de la Ley N&#xB0; 18.696, 10&#xB0; de la Ley N&#xB0; 19.040 y 43&#xB0; de la Ley N&#xB0; 18.575, las leyes N&#xB0;s. 18.059 y 18.290 y lo prescrito en el art&#xED;culo 32&#xB0; N&#xB0; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 7132306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; En el art&#xED;culo 31&#xB0; del Decreto Supremo N&#xB0; 212 de 15 de Octubre de 1992, elim&#xED;nanse las palabras</div><div class=\"p\">&quot;interurbanos y&quot;.</div><br></div>", "i": 7132307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Sergio Gonz&#xE1;lez Tagle, Ministro de Transportes y Telecomunicaciones Subrogante.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 7132308}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "14", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-14"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "MODIFICA DECRETO N° 212, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERVICIO NACIONAL TRANSPORTE PUBLICO PASAJEROS", "REGLAMENTO", "MODIFICACION", "VEHICULOS MOTORIZADOS", "LOCOMOCION COLECTIVA", "TAXI", "REVISION TECNICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_pro