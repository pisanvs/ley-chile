{"html": [{"t": "<div><div class=\"p\">&#xFEFF;CESACION DEL MINISTRO DEL INTERIOR Y RELACIONES EXTERIORES.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 10 de 1827.</div></div>", "i": 10208733}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Habi&#xE9;ndosele admitido la renuncia de la Presidencia de la Rep&#xFA;blica que interpuso al Congreso nacional el Capitan jeneral D. Ramon Freire, ha cesado por lo mismo su ministerio en los departamentos de relaciones exteriores y del interior D. Manuel Jos&#xE9; Gandarillas desde el dia 8 del presente mes. T&#xF3;mese razon de este decreto, y publ&#xED;quese en el Boletin.</div></div>", "i": 10208734}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><br><div class=\"p\">&nbsp; &nbsp;  Alejandro Mardones.</div></div>", "i": 10208735}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "﻿CESACION DEL MINISTRO DEL INTERIOR Y RELACIONES EXTERIORES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1827-05-10", "doble_articulado": false, "id_norma": "1152891", "numero_fuente": "1827", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1827-05-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1827-05-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1827-05-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "17616", "fecha_ingreso": "2021-03-11", "fecha_version": "18