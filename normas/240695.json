{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6535066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP Exento N&#xBA;636 de 30 de junio de 2005, se expropi&#xF3; el lote de terreno N&#xBA;115-D, superficie 549 m2., Rol N&#xBA;601-795, comuna de Nueva Imperial, IX Regi&#xF3;n para la obra &quot;Camino Ruta S-16, sector Chol-Chol-Nueva Imperial Tramo Km. 24,30269 al Km.</div><div class=\"p\">43,50000, Sub-Tramo III Km. 35,380 al Km. 43,50000&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Gina Elizabeth Porma Sandoval, ascendente a la cantidad de $455.065.</div><br></div>", "i": 6535067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6535068}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "636 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-636 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-30", "doble_articulado": false, "id_norma": "240695", "numero_fuente": "38225", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-08-01", "vigencias": [{"desde": "2005-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-08-01", "fecha_version": "2005-08-01", "fecha_actualizacion_texto": "2005-08-