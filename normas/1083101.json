{"html": [{"t": "<div><br><div class=\"p\">CREA OFICINA QUE INDICA EN LA SUBDIRECCI&#xD3;N DE FISCALIZACI&#xD3;N</div></div>", "i": 9644034}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 86, del 20 de octubre de 2015, que establece:</div><br><div class=\"p\">&nbsp; &nbsp;  Crea la Oficina de An&#xE1;lisis de Elusi&#xF3;n, bajo dependencia directa del Subdirector de Fiscalizaci&#xF3;n, y se&#xF1;ala sus funciones.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2015.</div></div>", "i": 9644035}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "86 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-86 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CREA OFICINA QUE INDICA EN LA SUBDIRECCIÓN DE FISCALIZACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN; IdDO 958826"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-10-20", "doble_articulado": false, "id_norma": "1083101", "numero_fuente": "41291", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-10-26", "vigencias": [{"desde": "2015-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-10-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2015-10-26", "fin_vigencia