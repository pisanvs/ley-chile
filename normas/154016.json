{"html": [{"t": "<div><div class=\"p\">AUTORIZA A LA UNIVERSIDAD AUSTRAL DE CHILE PARA AMPLIAR SUS ACTIVIDADES PESQUERAS </div></div>", "i": 7260282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 545, de 23 de Julio de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la Universidad Austral de Chile, domiciliada en Valdivia, para instalar y operar un establecimiento de cultivo de alga gracilaria sp, en un sector del R&#xED;o Cariquilda, Comuna del Maull&#xED;n, Provincia de Llanquihue, X Regi&#xF3;n, en un &#xE1;rea de 39.912,5 m2 de fondo de r&#xED;o.</div><br></div>", "i": 7260283}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Julio de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7260284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "545", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-545"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A LA UNIVERSIDAD AUSTRAL DE CHILE PARA AMPLIAR\nSUS ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-23", "doble_articulado": false, "id_norma": "154016", "numero_fuente": "32554", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-22", "vigencias": [{"desde": "1986-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-08-22", "fin_vigencia": "", "tipo_versi