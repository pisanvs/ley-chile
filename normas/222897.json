{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 193.- Santiago, 15 de Mayo de 1931.- En uso de las facultades que me confiere la ley n&#xFA;mero 4,945, de 6 de febrero del presente a&#xF1;o,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6470747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Cond&#xF3;nanse las sumas que, por concepto de impuesto global complementario sobre la renta, correspondiente a los a&#xF1;os 1927, 1928, 1929 y 1930, adeuda la Universidad de Concepci&#xF3;n.</div><br></div>", "i": 6470748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese Raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- Carlos Castro Ruiz. </div></div>", "i": 6470749}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "193", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-193"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-05-15", "doble_articulado": false, "id_norma": "222897", "numero_fuente": "15984", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-05-29", "vigencias": [{"desde": "1931-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-05-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2004-03-24", "fecha_version": "1931-05-29", "fecha_actualizacion_texto": "1931