{"html": [{"t": "<div><div class=\"p\">LEY NUM. 17.427</div><br><div class=\"p\">CONCEDE AMNISTIA QUE SE&#xD1;ALA</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br><br></div>", "i": 6258595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese amnist&#xED;a a don Ra&#xFA;l Orlando Uni&#xF3;n Garc&#xED;a por los delitos a que fue condenado por la sentencia del Cuarto Juzgado Militar de Valdivia, reca&#xED;da en la causa N&#xBA; 942-65&quot;.</div><br></div>", "i": 6258596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  SANTIAGO, veintiuno de Abril de mil novecientos setenta y uno.- SALVADOR ALLENDE GOSSENS.- LISANDRO CRUZ P.</div><div class=\"p\">&nbsp; &nbsp;  Lo digo a U. para su conocimiento.- Dios guarde a U.- Jos&#xE9; Antonio Viera Gallo, Subsecretario de Justicia. </div></div>", "i": 6258597}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17427", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17427"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE AMNISTIA QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1971-04-21", "doble_articulado": false, "id_norma": "163500", "numero_fuente": "27933", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1971-04-28", "vigencias": [{"desde": "1971-04-28", "hasta": "", "tipo_version": "3", "tipo_ve