{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6155593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 835 de 13 de Mayo de 1988, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Excluido y Sector Expropiado Predio &quot;Resto del Fundo La Capilla&quot; de la comuna de Los Angeles VIII Regi&#xF3;n; y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 1 a la 11 sitios N&#xB0;s. 1 al 5 y 7 al 13 del Proyecto de Parcelaci&#xF3;n &quot;Pe&#xF1;aflor&quot; formado por predio se&#xF1;alado. Los Derechos de Agua se extraen del Canal del Laja derivado del r&#xED;o Laja y del estero o r&#xED;o Curanad&#xFA;. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6155594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6155595}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "835 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-835 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-13", "doble_articulado": false, "id_norma": "132204", "numero_fuente": "33085", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-01", "vigencias": [{"desde": "1988-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-01", "fin_vigenc