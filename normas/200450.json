{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6388967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;883 de fecha 31 de mayo de 2002, se expropi&#xF3; el lote de terreno N&#xBA;3, superficie 122 m2., rol de aval&#xFA;o en tr&#xE1;mite, comuna de Cauquenes, para la obra &apos;&apos;Camino Lecher&#xED;a-Cerro Alto, sector Puente San Miguel, tramo Km. 1,340 a Km. 1,670&apos;&apos;, VII Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Eduardo Rold&#xE1;n Recabal, ascendente a la cantidad de $492.757.-</div><br></div>", "i": 6388968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6388969}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "883 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-883 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-31", "doble_articulado": false, "id_norma": "200450", "numero_fuente": "37308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-15", "vigencias": [{"desde": "2002-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PSO", "fecha_ingreso": "2002-07-15", "fecha_version": "2002-07-15", "fecha_actualizacion_texto": "2002-07-15", "tipo_tratado": ""}, "alertas": [