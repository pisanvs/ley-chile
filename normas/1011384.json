{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8887026}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 886, de 23 de febrero de 2010, de esta Subsecretar&#xED;a, d&#xE9;janse sin efecto las resoluciones N&#xBA; 810, de 2000, <a href=\"https://www.leychile.cl/Navegar?idNorma=187034&amp;idParte=0&amp;idVersion=\">N&#xBA; 1.070, de 2001</a>, N&#xBA; 663 y N&#xBA; 2.826, ambas del 2002, N&#xBA; 1.011 y N&#xBA; 2.123, ambas del 2003, N&#xBA; 1.361 y N&#xBA; 2.816, ambas del 2004, todas de esta Subsecretar&#xED;a, correspondientes al &#xE1;rea de manejo Punta Atala, II Regi&#xF3;n, cuyo titular es el SINDICATO DE TRABAJADORES INDEPENDIENTES DE BUZOS MARISCADORES Y RAMOS SIMILARES DE LA CALETA PUNTA ATALA de la comuna de Tocopilla, en virtud del art&#xED;culo 16, letra g), del D.S. N&#xBA; 355, de 1995, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8887027, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de febrero de 2010.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8887028}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "886", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-886"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-02-23", "doble_articulado": false, "id_norma": "1011384", "numero_fuente": "39599", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-01", "vigencias": [{"desde": "2010-03-01"