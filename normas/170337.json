{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7270737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 994, de 1 de junio de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 322, de 1990, de esta Subsecretar&#xED;a, en cuanto autoriz&#xF3; a don ERASMO ANTONIO MU&#xD1;OZ FLORES, para operar la nave &apos;&apos;Skorpion II&apos;&apos;, s&#xF3;lo en lo relativo al recurso Raya, en el litoral comprendido entre la VIII Regi&#xF3;n y el paralelo 43&#xBA; L.S., y Albacora, At&#xFA;n de aleta amarilla, Cojinoba del norte y Machuelo de la I Regi&#xF3;n al paralelo 43&#xBA; L.S., de conformidad con lo establecido en la letra b) del art&#xED;culo 143 del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 7270738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de junio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7270739}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "994", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-994"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-01", "doble_articulado": false, "id_norma": "170337", "numero_fuente": "36683", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-07", "vigencias": [{"desde": "2000-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-07", "fin