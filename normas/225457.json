{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6480066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.322, de 10 de mayo de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MARINOS S.A. Alimar para ampliar actividades pesqueras extractivas con la nave &quot;Paniahue&quot;, en las &#xE1;reas que en cada caso se indica, donde podr&#xE1; capturar los recursos que a continuaci&#xF3;n se se&#xF1;alan: a) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones V, VI, VII, IX y X, con cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones V, VI, VII, IX y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia. </div></div>", "i": 6480067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de mayo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6480068}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1322", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1322"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-10", "doble_articulado": false, "id_norma": "225457", "numero_fuente": "37865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-20", "vigencias": [{"desde": "2004-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-05-20", "fin_vigencia": "", "tipo_version": "3"}], "eve