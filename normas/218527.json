{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6453041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.113, de 28 de noviembre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIAL ANDROC Y CIA. LTDA., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Camino Sur N&#xBA;6403, Km.6,5, Punta Arenas, XII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Fresco-Enfriado, Congelado, Conserva y Pasteurizado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;2.473 de 2003, de esta Subsecretar&#xED;a, en virtud de lo solicitado por la peticionaria mediante C.I. Subpesca N&#xBA;8.541 de 2003 y del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6453042}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6453043}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3113 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3113 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-28", "doble_articulado": false, "id_norma": "218527", "numero_fuente": "37733", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-12", "vigencias": [{"desde": "2003-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini