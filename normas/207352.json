{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6412708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la Universidad Bernardo O&#xB4;higgins inscrita bajo el n&#xFA;mero C-54 del Registro de Universidades del Ministerio de Educaci&#xF3;n, ha presentado los programas de estudios de la carrera de &quot;Ingenier&#xED;a Civil Industrial&quot; conducente al grado de &quot;Licenciado en Ciencias de la Ingenier&#xED;a&quot; y al t&#xED;tulo de &quot;Ingeniero Civil Industrial&quot;, a la Universidad del B&#xED;o-B&#xED;o, instituci&#xF3;n que ha aprobado los planes y programas de la carrera y se constituido en entidad examinadora.</div><div class=\"p\">&nbsp; &nbsp;  La carrera mencionada podr&#xE1; impartirse a contar desde 1991.</div><br></div>", "i": 6412709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6412710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "207352", "numero_fuente": "33909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-04", "vigencias": [{"desde": "1991-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-04", "fin_vigencia": ""}