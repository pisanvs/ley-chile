{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA; 314</div><br><div class=\"p\">Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 314, celebrada el 14 de octubre de 1993, adopt&#xF3; los siguientes acuerdos:</div><br><div class=\"p\">314-04-931014 - Modifica Capitulo VI del Titulo II del Compendio de Normas de Cambios Internacionales. </div></div>", "i": 6495778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; introducir la siguiente modificaci&#xF3;n en el Cap&#xED;tulo VI &quot;Financiamiento a las Exportaciones&quot; del Titulo II del Compendio de Normas de Cambios Internacionales:</div><br><div class=\"p\">- Reemplazar, en el inciso primero del N&#xB0; 2, el guarismo &quot;180&quot; por &quot;300&quot;.</div><br></div>", "i": 6495779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de octubre de 1993.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe.</div><br></div>", "i": 6495780}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "314", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-314"}, {"tipo": "5", "numero": "314-04", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-314-04"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE\nCHILE EN SU SESION Nº 314", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-10-14", "doble_articulado": false, "id_norma": "229991", "numero_fuente": "34692", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-16", "vigencias": [{"desde": "199