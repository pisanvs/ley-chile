{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 64 EXENTA, DE 2003 </div></div>", "i": 6446933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta SII N&#xBA; 64, de 30 de octubre de 2003, se prorroga vigencia de resoluci&#xF3;n Ex. SII N&#xBA; 40, de 2001, que dispone cambio opcional del sujeto del IVA en los casos que indica, por el per&#xED;odo comprendido entre el 31 de octubre de 2003 hasta el 31 de diciembre de 2003, ambas fechas inclusive.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra incluido en el sitio web del Servicio de Impuestos Internos, en Internet, cuya direcci&#xF3;n es http://www.sii.cl </div></div>", "i": 6446934}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-64 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 64 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-30", "doble_articulado": false, "id_norma": "216826", "numero_fuente": "37702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-05", "vigencias": [{"desde": "2003-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "i