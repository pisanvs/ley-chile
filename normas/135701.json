{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8344383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;707, de 22 de abril de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;1.146 de 1996, que autoriz&#xF3; a PESQUERA TARAPACA S.A., para operar la nave &apos;&apos;Oficina Tarapac&#xE1;&apos;&apos;, s&#xF3;lo en cuanto a la autorizaci&#xF3;n para capturar en la III y IV Regiones los recursos Anchoveta y Sardina espa&#xF1;ola, en virtud de lo dispuesto en el inciso segundo de la letra b) del art&#xED;culo 143 del D.S. N&#xBA;430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8344384}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8344385}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "707", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-707"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-22", "doble_articulado": false, "id_norma": "135701", "numero_fuente": "36351", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-29", "vigencias": [{"desde": "1999-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente