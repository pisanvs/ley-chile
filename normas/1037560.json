{"html": [{"t": "<div><br><div class=\"p\">MODIFICA MODELOS DE CERTIFICADOS Nos 25 Y 28</div><br></div>", "i": 9239231}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0;32 del 23 de febrero de 2012.</div><div class=\"p\">&nbsp; &nbsp;  Sustit&#xFA;yanse Modelos de Certificados Nos 25 y 28 e instrucciones de llenado a que se refiere la <a href=\"https://www.leychile.cl/Navegar?idNorma=1023478&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 31, de fecha 01.03.2011</a>, con vigencia a partir del A&#xF1;o Tributario 2012.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII de febrero de 2012.</div></div>", "i": 9239232}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "32 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-32 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA MODELOS DE CERTIFICADOS Nos 25 Y 28", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-02-23", "doble_articulado": false, "id_norma": "1037560", "numero_fuente": "40199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-02-28", "vigencias": [{"desde": "2012-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-02-28", "fin_vigencia": ""}, "vigencias_version_norma