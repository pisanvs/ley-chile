{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6157344}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 2.879, de 31 de diciembre de 1998, se expropiaron los lotes de terreno N&#xBA;s. 13-A, 13-B y 20, superficies 302, 402 y 36 m&#xB2;, respectivamente, roles de aval&#xFA;o 500-49, 500-51 y 6-18, comuna de Curic&#xF3;, para la obra Camino Ruta 5 Sur, Sector Acceso Norte a Curic&#xF3; y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Sociedad Impregnadora de Maderas Ltda. y H&#xE9;ctor Lillo Miranda y otros, ascendente a las cantidades de $47.492.860.- para los lotes 13-A y 13-B y $4.150.675.- para el lote 20. </div></div>", "i": 6157345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6157346}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2879", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2879"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-31", "doble_articulado": false, "id_norma": "132858", "numero_fuente": "36302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-01", "vigencias": [{"desde": "1999-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-03-02", "fecha_version": "1999-03-01", "