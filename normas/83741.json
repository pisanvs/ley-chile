{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA</div><br><br></div>", "i": 8315503}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 761, de 15 de Junio de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase nuevamente por un a&#xF1;o, a contar de la fecha de publicaci&#xF3;n del presente extracto, el plazo otorgado a Cultivos Marinos Chilo&#xE9; Limitada, actualmente Cultivos Marinos Chilo&#xE9; S.A., R.U.T. No. 79.784.980-4, domiciliada en la ciudad de Santiago, para empezar a operar el establecimiento de cultivo autorizado por resoluci&#xF3;n No. 920, de 1988 de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 8315504}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 15 de Junio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8315505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "761", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-761"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-06-15", "doble_articulado": false, "id_norma": "83741", "numero_fuente": "33718", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-07-13", "vigencias": [{"desde": "1990-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-07-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":