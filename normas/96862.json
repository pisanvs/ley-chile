{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO EXENTO No. 224 DE 1991 </div></div>", "i": 6104475}, {"t": "<div><div class=\"p\">Por Decreto Exento No.224 de fecha 05 de Agosto de 1991 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Capacitaci&#xF3;n de Ocupaciones Laborales ECOLE, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar de Agosto de 1991, con la siguiente denominaci&#xF3;n: Carrera: T&#xE9;cnico en Telecomunicaciones con menci&#xF3;n en Telefon&#xED;a o Telem&#xE1;tica o Radio-Comunicaci&#xF3;n.</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Telecomunicaciones con menci&#xF3;n en: Telefon&#xED;a, o Telem&#xE1;tica, o Radiocomunicaci&#xF3;n.</div><br></div>", "i": 6104476}, {"t": "<div><div class=\"p\">Santiago, 8 de Noviembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br><br></div>", "i": 6104477}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "224 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-224 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DECRETO EXENTO No. 224 DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-05", "doble_articulado": false, "id_norma": "96862", "numero_fuente": "34125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-25", "vigencias": [{"desde": "1991-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "