{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 392, de 14 de marzo de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura N&#xBA; 94103099, presentada por CELSO DEL CARMEN AGUILA BARRIA, para un centro de cultivo ubicado entre Punta Dequio y Punta Yutuy, Estero Castro, Comuna de Castro, Provincia de Chilo&#xE9;, X Regi&#xF3;n, en virtud de lo dispuesto el art&#xED;culo 78 inciso 2&#xBA; de la Ley General de Pesca y Acuicultura y sus modificaciones y el art&#xED;culo 14&#xBA; del D.S. N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8301931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de marzo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "392", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-392"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CELSO DEL CARMEN AGUILA BARRIA", "CONCESION DE ACUICULTURA", "DENEGACION", "CASTRO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-14", "doble_articulado": false, "id_norma": "70082", "numero_fuente": "35723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-22", "vigencias": [{"desde": "1997-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v