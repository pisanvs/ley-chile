{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 283, DE 1985 </div></div>", "i": 6257378}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 283, de 9 de Julio de 1985, se procedi&#xF3; a aprobar Planes Experimentales de Educaci&#xF3;n General B&#xE1;sica de Adultos Modalidad Presencial y Modalidad a Distancia.</div><br><div class=\"p\">&nbsp; &nbsp;  Constituyen la primera fase del Programa experimental de Educaci&#xF3;n de Adultos del Proyecto de Educaci&#xF3;n - Producci&#xF3;n de Areas Marginales Urbanas del Convenio Ministerio de Educaci&#xF3;n P&#xFA;blica - O.E.A.</div><br><div class=\"p\">&nbsp; &nbsp;  Se aprueban normas especiales de ingreso y de evaluaci&#xF3;n.</div><br></div>", "i": 6257379}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de Julio de 1985.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6257380}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "283 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-283 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 283, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-09", "doble_articulado": false, "id_norma": "163092", "numero_fuente": "32231", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-25", "vigencias": [{"desde": "1985-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-25", "fin_vigencia": ""}, "vigencias_ve