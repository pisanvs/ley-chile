{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6519582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;615, de 2 de marzo de 2005 de esta subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL MU&#xD1;OZ Y ESPEJO LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en avenida Los Aromos, manzana E, sitio 19, sector Agpia, Alto Hospicio, I Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado, Congelado, Seco salado, Ahumado y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA;1.762 de 2004, de esta Subsecretar&#xED;a, en virtud de la carta renuncia citada en Visto y del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6519583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de marzo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6519584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "615 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-615 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-02", "doble_articulado": false, "id_norma": "236434", "numero_fuente": "38114", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-18", "vigencias": [{"desde": "2005-03-18", "hasta": "", "tipo_ve