{"html": [{"t": "<div><div class=\"p\">CONSULADO JENERAL DE S.M.B.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 19 de 1828.</div></div>", "i": 10237716}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el C&#xF3;nsul jeneral de S.M.B. en Chile, debe regresar a Inglaterra en virtud de la licencia que ha obtenido de su gobierno, y segun autorizacion del mismo ha designado al actual Vicec&#xF3;nsul de Inglaterra en Valpara&#xED;so para que quede encargado de los asuntos consulares durante su ausencia; por tanto ser&#xE1; reconocido M. John White, que es expresado Vice-c&#xF3;nsul, como tal encargado de los negocios del consulado de S.M.B. durante la ausencia de M.R. Nugent. Comun&#xED;quese el presente decreto a quienes corresponda e impr&#xED;mase.</div></div>", "i": 10237717}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  PINTO - Rodr&#xED;guez.</div></div>", "i": 10237718}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "CONSULADO JENERAL DE S.M.B.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-04-19", "doble_articulado": false, "id_norma": "1157113", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-04-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul