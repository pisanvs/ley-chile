{"html": [{"t": "<div><div class=\"p\">INFORMA NUEVA COMPOSICION DIRECTIVA CENTRAL DEL PARTIDO DEMOCRATA CRISTIANO</div><br><br></div>", "i": 6572657}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Soledad Alvear Valenzuela, Presidenta de la Directiva Central, y Andr&#xE9;s Parra Vergara, Secretario del Tribunal Supremo del Partido Dem&#xF3;crata Cristiano, han informado la nueva composici&#xF3;n de la Directiva Central de dicho partido:</div><br><div class=\"p\">Directiva Central:</div><br><div class=\"p\">Presidenta&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  Soledad Alvear Valenzuela</div><div class=\"p\">1&#xBA; Vicepresidente&nbsp;  :&nbsp;  Sergio Micco Aguayo</div><div class=\"p\">2&#xBA; Vicepresidente&nbsp;  :&nbsp;  Jorge Burgos Varela</div><div class=\"p\">3&#xAA; Vicepresidenta&nbsp;  :&nbsp;  Ximena Rinc&#xF3;n Gonz&#xE1;lez</div><div class=\"p\">Tesorero&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  Walter Oliva Munizaga</div><div class=\"p\">Secretario&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  Mois&#xE9;s Valenzuela Mart&#xED;nez</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O N&#xBA; 1.348 de fecha 6 de junio de 2006.-</div><br></div>", "i": 6572658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6572659}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1348", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1348"}, {"tipo": "3", "numero": "O-1348", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1348"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA NUEVA COMPOSICION DIRECTIVA CENTRAL DEL PARTIDO DEMOCRATA CRISTIANO", "fuente": "Diario Ofici