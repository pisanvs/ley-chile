{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8337540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.793, de 11 de diciembre de 1998, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 536 de 1991, en cuanto autoriz&#xF3; a SOCIEDAD PESQUERA COLOSO S.A., para operar la nave &apos;&apos;B&#xED;o B&#xED;o&apos;&apos;, Matr&#xED;cula 2.196 ex &apos;&apos;Con Con&apos;&apos;, en la captura del recurso hidrobiol&#xF3;gico Jurel Trachurus murphyi, en el litoral de la III y IV Regiones, por no haber operado en dicha pesquer&#xED;a en el t&#xE9;rmino legal, de conformidad con lo se&#xF1;alado en el inciso segundo de la letra b) del art&#xED;culo 143 del D.S. N&#xBA; 430 de 1991 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8337541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8337542}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1793", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1793"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-11", "doble_articulado": false, "id_norma": "128527", "numero_fuente": "36242", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-18", "vigencias": [{"desde": "1998-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-18", "fin_vi