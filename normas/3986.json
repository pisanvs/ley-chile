{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 18.- Santiago, 27 de Febrero de 1931.- Vistas las facultades que me confiere la ley n&#xFA;m. 4,945, de 6 de Febrero del presente a&#xF1;o,</div><div class=\"p\">&nbsp; &nbsp; Dercreto:</div><br></div>", "i": 7115386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplem&#xE9;ntase el &#xED;tem 06/01/04/v del Presupuesto del Ministerio de Hacienda, en la suma de cinco millones de pesos ($ 5.000,000)</div><div class=\"p\">&nbsp; &nbsp; El mayor gasto se financiar&#xE1; con los recursos creados por el decreto con fuerza de ley n&#xFA;mero 17, expedido por el Ministerio de Hacienda, el 27 de Febrero del presente a&#xF1;o.</div><br></div>", "i": 7115387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. IBA&#xD1;EZ C.- Carlos Castro Ruiz. </div></div>", "i": 7115388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "18", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-18"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CREA CARGO PARALELO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-02-27", "doble_articulado": false, "id_norma": "3986", "numero_fuente": "15917", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-03-07", "vigencias": [{"desde": "1931-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi