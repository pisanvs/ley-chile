{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE AL HOSPITAL CLINICO REGIONAL DE CONCEPCION</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha tenido a bien </div></div>", "i": 5980405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- El Hospital Cl&#xED;nico Regional de Concepci&#xF3;n se denominar&#xE1; en lo futuro &quot;Guillermo Grant Benavente&quot;.</div><br></div>", "i": 5980406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de Octubre de mil novecientos sesenta y nueve.- EDUARDO FREI MONTALVA.- Ram&#xF3;n Valdivieso Delaunay.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a U. para su conocimiento.- Saluda a U.- Patricio Silva Gar&#xED;n, Subsecretario de Salud P&#xFA;blica.</div><br></div>", "i": 5980407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17222", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17222"}], "organismos": ["MINISTERIO DE SALUD PÚBLICA"], "titulo_norma": "CAMBIA NOMBRE AL HOSPITAL CLINICO REGIONAL DE\nCONCEPCION", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Hospital Clínico Regional de Concepción", "Cambio de Nombre", "Hospital Regional Guillermo Grant Benavente"], "terminos_libres": ["PRESTAR CAMBIO NOMBRE", "HOSPITAL", "CONCEPCION", "GUILLERMO GRAUT BENAVENTE SU APROBACION AL SIGUIENTE: PROYECTO DE LEY:"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1969-10-17", "doble_articulado": false, "id_norma": "28839", "numero_fuente": "27482", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publica