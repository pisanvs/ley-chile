{"html": [{"t": "<div><div class=\"p\">DESIGNA SUBSECRETARIO DE PREVISION SOCIAL</div><div class=\"p\">N&#xFA;m. 26.- Santiago, 11 de Marzo de 1990.- Visto: Lo dispuesto por el art&#xED;culo 32 No. 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica.</div><br><div class=\"p\">Decreto:</div><br></div>", "i": 6083849}, {"t": "<div><div class=\"p\">Art&#xED;culo &#xFA;nico: Des&#xED;gnase a contar de esta fecha, a don Jos&#xE9; Mart&#xED;n Manterola Urz&#xFA;a en el cargo de Subsecretario de Previsi&#xF3;n Social, quien por razones impostergables de buen servicio deber&#xE1; asumir de inmediato sus funciones. </div></div>", "i": 6083850}, {"t": "<div><div class=\"p\">An&#xF3;tese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese y publ&#xED;quese. PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Ren&#xE9; Cort&#xE1;zar Sanz, Ministro del Trabajo y Previsi&#xF3;n Social.- Mart&#xED;n Manterola Urz&#xFA;a, Subsecretario de Previsi&#xF3;n Social. </div></div>", "i": 6083851}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "26", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-26"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARIA DE PREVISION SOCIAL"], "titulo_norma": "DESIGNA SUBSECRETARIO DE PREVISION SOCIAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-11", "doble_articulado": false, "id_norma": "89846", "numero_fuente": "33632", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-28", "vigencias": [{"desde": "1990-03-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-28", "fin_vigencia": ""}, "vig