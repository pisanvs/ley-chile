{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 165, DE 1984 </div></div>", "i": 6251509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n exento No. 165, de 14 de Septiembre de 1984, se ha procedido a aprobar, a contar del a&#xF1;o 1985, un plan especial de estudio para 3&#xB0; y 4&#xB0; a&#xF1;o medio human&#xED;stico cient&#xED;fico del Colegio El Carmen Teresiano I de las Hermanas Carmelitas Teresas de San Jos&#xE9;.</div><div class=\"p\">&nbsp; &nbsp;  La evaluaci&#xF3;n y promoci&#xF3;n de los alumnos se regir&#xE1; por las normas vigentes sobre la materia.</div><br></div>", "i": 6251510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de Febrero de 1985.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6251511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "165 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-165 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 165, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-09-14", "doble_articulado": false, "id_norma": "161242", "numero_fuente": "32150", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-19", "vigencias": [{"desde": "1985-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "