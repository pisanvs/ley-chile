{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301282}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 132, de 31 de enero de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2 de la Resoluci&#xF3;n N&#xBA; 2.174 de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA PLAYA BLANCA S.A., para realizar actividades pesqueras extractivas con la nave &quot;Gangstad Junior&quot;, en el sentido de agregar el recurso Jurel, entre los autorizados a capturar con cerco en el litoral de las III y IV Regiones por fuera del &#xE1;rea de reserva artesanal.</div><br></div>", "i": 8301283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "132", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-132"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA PLAYA BLANCA S.A.", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-01-31", "fecha_derogacion": "2002-12-21", "doble_articulado": false, "id_norma": "60946", "numero_fuente": "35691", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-02-13", "vigencias": [{"desde": "2002-12-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-02-13", "hasta": "2002-12-20", "tipo_version": "0", "tipo_version_s": "Texto Original