{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA COLOSO S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br><br><br></div>", "i": 8330130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 555, de 26 de Noviembre de 1984, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Coloso S.A., domiciliada en Santiago, para operar una embarcaci&#xF3;n actualmente en construcci&#xF3;n, en el litoral comprendido entre la I, II, III y IV Regi&#xF3;n, en la extracci&#xF3;n de jurel, sardina espa&#xF1;ola, caballa y anchoa.</div><br></div>", "i": 8330131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Noviembre de 1984.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 8330132}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "555", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-555"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA COLOSO S.A. PARA AMPLIAR ACTIVIDADES\nPESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1984-11-26", "fecha_derogacion": "1999-10-18", "doble_articulado": false, "id_norma": "99289", "numero_fuente": "32050", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1984-12-20", "vigencias": [{"desde": "1999-10-18", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1984-12-20", "hasta": "1999-10-17", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1999-10-18", "fin_vigencia": ""}, "v