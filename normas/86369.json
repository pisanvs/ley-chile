{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8317942}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 14, de 6 enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 663 de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a HUGO ERNESTO MU&#xD1;OZ GARCES, para instalar y operar el centro de cultivo ubicado en R&#xED;o Cariquilda, comuna de Maull&#xED;n, provincia de Llanquihue, X Regi&#xF3;n, por haberse puesto t&#xE9;rmino a la respectiva concesi&#xF3;n de acuicultura.</div><br></div>", "i": 8317943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8317944}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "HUGO ERNESTO MU OZ GARCES", "MAULLIN", "DECIMA REGION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-06", "doble_articulado": false, "id_norma": "86369", "numero_fuente": "35963", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-13", "vigencias": [{"desde": "1998-01-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe