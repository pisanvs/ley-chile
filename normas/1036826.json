{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9231550}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 160, de 20 de enero de 2012, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1036573&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 84 de 2012</a>, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a PESCA CHILE S.A. para operar por sustituci&#xF3;n la nave f&#xE1;brica &quot;Puerto Toro&quot;, en el sentido de reemplazar en sus numerales 1&#xBA; y 10&#xBA; y en el extracto de la se&#xF1;alada resoluci&#xF3;n la expresi&#xF3;n &quot;BEC2299/10&quot; por &quot;BEC2291/11&quot;.</div></div>", "i": 9231551}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de enero de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9231552}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "160 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-160 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2012-01-20", "fecha_derogacion": "2014-12-06", "doble_articulado": false, "id_norma": "1036826", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2012-01-30", "vigencias": [{"desde": "2014-12-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2012-01-30", "hasta": "2014-12-05", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-12-06", "fin_vigencia": ""}, "vig