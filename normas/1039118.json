{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9249407}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;542, de 23 de marzo de 2012, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xB0;, 5&#xB0; y 6&#xB0;, del Decreto Exento MOP. N&#xB0;508, de 31 de marzo de 2011, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xB0;16-A, expropiado con motivo de la obra &quot;Camino Construcci&#xF3;n Ruta U-91, Sector R&#xED;o Correntoso - Las Gaviotas, Tramo Km. 65,58046 a Km. 72,78493&quot;. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n, fijado mediante tasaci&#xF3;n de 31 de marzo de 2009, complementada por acta de fecha 23 de septiembre de 2010, en la suma de $23.465.750.</div></div>", "i": 9249408}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9249409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "542 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-542 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-23", "doble_articulado": false, "id_norma": "1039118", "numero_fuente": "40238", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-16", "vigencias": [{"desde": "2012-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-04-16", "fin_vi