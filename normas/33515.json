{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8949267}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 159, de 23 de enero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 893, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., para reemplazar las embarcaciones &quot;Ral&#xFA;n&quot; y &quot;Burca&quot;, por haberse configurado la causal de caducidad prevista en el art&#xED;culo 143 letra b) de la ley N&#xB0; 18.892 citada en Visto.</div><div class=\"p\">&nbsp; &nbsp; Ampl&#xED;ase por un a&#xF1;o, a contar de la fecha de publicaci&#xF3;n de la presente Resoluci&#xF3;n, el plazo de vigencia de la Resoluci&#xF3;n N&#xB0; 64, de 1983, de esta Subsecretar&#xED;a, por haberse acreditado la existencia de fuerza mayor.</div><br></div>", "i": 8949268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 23 de enero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8949269}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "159", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-159"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPA IA PESQUERA CAMANCHACA S.A", "CADUCIDAD", "AUTORIZACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-01-23", "fecha_derogacion": "1996-08-14", "doble_articulado": false, "id_norma": "33515", "numero_fuente": "35386", "tipo_version": "2", "tipo_version_s": "Última Ve