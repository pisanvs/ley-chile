{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,978.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6166527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a la viuda e hijos lej&#xED;timos del capitan de fragata, don Luis A. Barrientos, el derecho a una pension anual de montep&#xED;o de un mil ochocientos pesos, en vez de la que perciben actualmente.</div><div class=\"p\">&nbsp; &nbsp;  Esta pension se rejir&#xE1; por la lei jeneral de montep&#xED;o militar.</div><br></div>", "i": 6166528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, tres de agosto de mil novecientos siete.- Pedro Montt.- Alejandro Lira.</div><br></div>", "i": 6166529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1978", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1978"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-08-03", "doble_articulado": false, "id_norma": "135774", "numero_fuente": "8872", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-08-10", "vigencias": [{"desde": "1907-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-08-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-08-10", "fi