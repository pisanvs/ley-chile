{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 5,449.- Santiago, 14 de Noviembre de 1928.- Teniendo presente:</div><div class=\"p\">&nbsp; &nbsp; Que por los decretos n&#xFA;meros 5,230, 5,231, 5,283, 5,319, 5,334 y 5,338, de 25, 30 y 31 de Octubre y 2 de Noviembre, se ha dado una nueva organizaci&#xF3;n a la Educaci&#xF3;n P&#xFA;blica, y que las disposiciones del decreto n&#xFA;mero 7,500, de 10 de Diciembre de 1927, o se encuentran t&#xE1;citamente derogadas o no guardan con ellos concordancia,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 9034962}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.o Der&#xF3;gase el decreto n&#xFA;mero 7,500, de 10 de Diciembre de 1927.</div><div class=\"p\">&nbsp; &nbsp; 2.o Los establecimientos de ense&#xF1;anza del Estado continuar&#xE1;n funcionando en las actuales condiciones mientras se dictan disposiciones especiales sobre el particular.</div><br></div>", "i": 9034963}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese. C. IBA&#xD1;EZ C.- Pablo Ram&#xED;rez.</div><br></div>", "i": 9034964}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "13", "numero": "5449", "abreviacion": "DFL", "descripcion": "DFL", "compuesto": "DFL-5449"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Recopilacion de Decretos con Fuerza de Ley de la Contraloria", "resumenes": [], "materias": [], "terminos_libres": ["EDUCACION", "REORGANIZACION", "DEROGACION", "REFORMA", "EDUCACION PRIMARIA", "EDUCACION SECUNDARIA", "ESCUELAS", "EDUCACION TECNICO MANUAL", "UNIVERSIDADES", "EDUCACION", "SUPERIOR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-11-14", "doble_articulado": false, "id_norma": "5651",