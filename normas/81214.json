{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 77 EXENTO, DE 1991</div><br><br><br></div>", "i": 6059193}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 77 de fecha 13 de mayo de 1991 del Ministerio de Educaci&#xF3;n, se modific&#xF3; el art&#xED;culo 1&#xB0; del Decreto Exento No. 57 de 1989 del Instituto Profesional de Los Angeles, en el sentido de que su domicilio a contar del a&#xF1;o 1991, ser&#xE1; en Avda. Ricardo Vicu&#xF1;a No. 776 de Los Angeles.</div><br></div>", "i": 6059194}, {"t": "<div><div class=\"p\">Santiago, 08 de Julio de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6059195}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "77 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-77 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO No. 77 EXENTO, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-05-13", "doble_articulado": false, "id_norma": "81214", "numero_fuente": "34062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-06", "vigencias": [{"desde": "1991-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "1997-12-24", "fecha_version": "1991-09-06", "fecha_actualizacion_texto": "1991-09-06", "tipo_tratado": ""}, "alertas": [], "alerta_glob