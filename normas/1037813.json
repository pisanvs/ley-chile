{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 1.034, DE 2011</div><br></div>", "i": 9241265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 1.034, de 30 de diciembre de 2011, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Arica y Parinacota, se dispuso el cierre de la Planta de Revisi&#xF3;n T&#xE9;cnica Clase AB. c&#xF3;digo AB 0111, de la comuna de Arica, Regi&#xF3;n de Arica y Parinacota, concesionada a &quot;Middleton y C&#xED;a. Ltda.&quot; en el a&#xF1;o 1999, a contar del 25 de diciembre de 2011, y se declara la extinci&#xF3;n de la Pr&#xF3;rroga del Contrato de Concesi&#xF3;n de la misma Planta Revisora.-</div></div>", "i": 9241266}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Emilio Guzm&#xE1;n Cepeda, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Arica y Parinacota.</div></div>", "i": 9241267}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1034", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1034"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XV REGIÓN DE ARICA Y PARINACOTA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 1.034, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-30", "doble_articulado": false, "id_norma": "1037813", "numero_fuente": "40209", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-03-10", "vigencias": [{"desde": "2012-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s":