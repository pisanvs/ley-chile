{"html": [{"t": "<div><br><div class=\"p\">NOMBRA ALCALDE DE MAR AD-HON&#xD3;REM A LA PERSONA QUE SE INDICA</div></div>", "i": 9881783}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n D.G.T.M. y M. M. Ord. N&#xB0; 1105/1 Vrs., de fecha 8 de enero de 2018, nombra alcalde de mar ad-hon&#xF3;rem a la persona que se indica.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de estas resoluciones se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div></div>", "i": 9881784}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de enero de 2018.- Otto Mrugalski Meiser, Contraalmirante LT, Director General Subrogante.- Mar&#xED;a Riesco Fuenzalida, Capit&#xE1;n de Corbeta JT, Jefe Depto. Jur&#xED;dico Subrogante.</div></div>", "i": 9881785}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1"}, {"tipo": "3", "numero": "1105/1", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1105/1"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "NOMBRA ALCALDE DE MAR AD-HONÓREM A LA PERSONA QUE SE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1346572; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-01-08", "doble_articulado": false, "id_norma": "1114633", "numero_fuente": "41973", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-02-02", "vigencias": [{"desde": "2018-02-