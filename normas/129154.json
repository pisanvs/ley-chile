{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.068 EXENTO, DE 1998 </div><br></div>", "i": 6146198}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 1.068, de 1&#xBA; de diciembre de 1998, se ha aprobado, a partir del a&#xF1;o escolar 1999, un programa de Religi&#xF3;n de la Uni&#xF3;n Chilena de la Iglesia Adventista del S&#xE9;ptimo D&#xED;a para los cursos de 5&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, los que podr&#xE1;n aplicarse conforme a la gradualidad establecida en los decretos supremos de Educaci&#xF3;n N&#xBA;s 40 de 1996 y 220 de 1998.</div><br></div>", "i": 6146199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de diciembre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6146200}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1068 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1068 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.068 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-01", "doble_articulado": false, "id_norma": "129154", "numero_fuente": "36257", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-07", "vigencias": [{"desde": "1999-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-01-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":