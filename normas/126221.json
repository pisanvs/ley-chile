{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8336033}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 1.071 de 11 de Octubre de 1988 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 6 meses a contar de 25 de septiembre de 1988, el plazo otorgado a Pesquera D&#xED;az, Santa Cruz y Correa Limitada R.U.T. No. 79.727.930-7, domiciliada en Ancud, para empezar a operar el establecimiento de cultivo autorizado por la Resoluci&#xF3;n No. 1.120, de 1987, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de un caso fortuito.</div><br></div>", "i": 8336034}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de Octubre de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8336035}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1071", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1071"}], "organismos": ["SUBSECRETARIA DE PESCA", "MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-10-11", "doble_articulado": false, "id_norma": "126221", "numero_fuente": "33206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-10-27", "vigencias": [{"desde": "1988-10-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-10-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "198