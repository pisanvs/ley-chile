{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO N&#xBA;1.128 EXENTO, DE 1999</div><br><br><div class=\"p\">&nbsp; &nbsp;  Rancagua, septiembre 16 de 1999.- Con esta fecha la Alcald&#xED;a decret&#xF3; lo siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 1.346 exento.</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br><br></div>", "i": 6194127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case el decreto exento N&#xBA; 1.128, de fecha 4</div><div class=\"p\">de agosto de 1999, a trav&#xE9;s del cual se modific&#xF3; el</div><div class=\"p\">art&#xED;culo 6&#xBA; de la Ordenanza de Ferias Libres, en su parte resolutiva, en la forma como se indica a continuaci&#xF3;n:</div><br><div class=\"p\">Donde dice&nbsp; &nbsp; &nbsp; :</div><br><div class=\"p\">&apos;&apos;D&#xED;as s&#xE1;bados&nbsp; : Poblaci&#xF3;n Granja Estadio, en An&#xED;bal</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Pinto, desde Avda. Las Torres</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; hasta 15 mts. antes de llegar a Manuel</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Rodr&#xED;guez&apos;&apos;</div><br><div class=\"p\">Debe decir&nbsp; &nbsp; &nbsp; :</div><br><div class=\"p\">&apos;&apos;D&#xED;as s&#xE1;bados&nbsp; : Poblaci&#xF3;n Granja Estadio, en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; calle Covadonga (oriente), ambos</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; costados, desde Manuel Rodr&#xED;guez,</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Lord Cochrane, costado norte, y</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; calle Covadonga (poniente), ambos</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; costados, hasta Manuel Rodr&#xED;guez&apos;&apos;.</div><br></div>", "i": 6194128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y arch&#xED;vese.- Dar&#xED;o Valenzuela van Treek, Alcalde.- Carlos Morales Lara, Secretario Municipal.</div><br></div>", "i": 6194129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1346 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1346 EXENTO"}], "organismos": ["MUNICIPALIDAD DE RANCAGUA"], "titulo_norma": "MODIFICA DECRETO Nº1.128 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-16", "doble_articulado": false, "id_norma": "144399", "numero_fuente": "36477", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-30", "vigencias": [{"desde": "1999-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JCT", "fecha_ingreso": "1999-09-30", "fecha_version": "1999-09-30", "fecha_actualizacion_texto": "1999-09-30", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6194127}, {"n": "Artículo", "i": 6194128, "t": 6}, {"n": "Promulgación", "i": 6194129}]}