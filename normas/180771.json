{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 13.485</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A MARGARITA GUZMAN LUCERO.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6318453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Margarita Guzm&#xE1;n Lucero una pensi&#xF3;n de $ 30.000 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande la aplicaci&#xF3;n de esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.&quot;</div><br><br></div>", "i": 6318454}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticuatro de Septiembre de mil novecientos cincuenta y nueve. JORGE ALESSANDRI RODRIGUEZ.- Roberto Vergara H.</div><br></div>", "i": 6318455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13485", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13485"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA MARGARITA GUZMAN LUCERO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-09-24", "doble_articulado": false, "id_norma": "180771", "numero_fuente": "24466", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-10-14", "vigencias": [{"desde": "1959-10-14", "hasta": "", "tipo_version"