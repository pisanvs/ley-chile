{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA </div><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">N&#xFA;m. 305.- Santiago 15 de Noviembre de 1991.- Vistos: Lo dispuesto en el art&#xED;culo 4&#xB0; del Decreto Ley No. 2.974 de 1979.</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 6073085}, {"t": "<div><div class=\"p\">Des&#xED;gnanse como Ministros de Fe para actuar en las localidades ubicadas en la VIII Regi&#xF3;n, en que no hayan Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><br><div class=\"p\">- Nelda Moraga Ojeda - M&#xF3;nica Rivera Espinoza </div></div>", "i": 6073086}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional. </div></div>", "i": 6073087}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "305", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-305"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-15", "doble_articulado": false, "id_norma": "86423", "numero_fuente": "34138", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-10", "vigencias": [{"desde": "1991-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-12-10", "fin_vigencia": "", "tipo_version": "3"}], "