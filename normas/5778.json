{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Modifica decreto-ley N.o 24, de 14 de Junio de 1932 N&#xFA;m. 117.- Santiago, 30 de Junio de 1932.- La Junta de Gobierno ha acordado y dicta del siguiente, Decreto-ley:</div><br></div>", "i": 5871754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Der&#xF3;gase la letra b) del decreto-ley N.o 24, de fecha 14 del actual y reempl&#xE1;zase por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; b) Direcci&#xF3;n General de Sanidad, Direcci&#xF3;n General de Beneficencia y Asistencia Social e Instituto Bacteriol&#xF3;gico.</div><br></div>", "i": 5871755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- CARLOS DAVILA.- Nolasco C&#xE1;rdenas.- J. E. Pe&#xF1;a Villal&#xF3;n.- Dr. A. Quijano.</div><br></div>", "i": 5871756}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "117", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-117"}], "organismos": ["MINISTERIO DE SALUBRIDAD PÚBLICA"], "titulo_norma": "Modifica decreto-ley N.o 24, de 14 de Junio de 1932", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIRECCION GENERAL SANIDAD", "INSTITUTO BACTERIOLOGICO", "DIRECCION GENERAL BENEFICENCIA Y ASISTENCIA SOCIAL", "MINISTRO SALUBRIDAD PUBLICA", "DEPARTAMENTOS", "COMPOSICION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-06-30", "doble_articulado": false, "id_norma": "5778", "numero_fuente": "16317", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-07-07", "vigencias": [{"desde": "1932-07-07", "hasta": "", "tipo_version": "3", "tipo_