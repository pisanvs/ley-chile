{"html": [{"t": "<div><div class=\"p\">MODIFICA EL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10307077}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 238, de 25 de enero de 2022, del Director Nacional de Aduanas, se modifican los Anexos 14 y 40 del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, en orden a sustituir las primeras filas de sus primeras tablas, incorporando el concepto de arma de fuego.</div><div class=\"p\">&nbsp; &nbsp;  Esta resoluci&#xF3;n entrar&#xE1; en vigencia a partir de su publicaci&#xF3;n en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl),</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10307078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de enero de 2022.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10307079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "238 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-238 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2081456", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-25", "doble_articulado": false, "id_norma": "1172249", "numero_fuente": "43169", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-02-03",