{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9104216}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 132, de 13 de enero de 2011 de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA ENFEMAR LIMITADA, para ampliar actividades pesqueras extractivas con la nave &quot;Mar&#xED;a Emperatriz III&quot;, en las &#xE1;reas mar&#xED;timas que a continuaci&#xF3;n se indican, donde podr&#xE1; extraer los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima comprendida entre la IV a VII Regiones, por fuera del &#xE1;rea de reserva artesanal, con poteras: Jibia o Calamar rojo; b) En el &#xE1;rea mar&#xED;tima correspondiente a la V Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con arrastre: Jibia o Calamar rojo.</div></div>", "i": 9104217}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de enero de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9104218}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "132 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-132 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2011-01-13", "fecha_derogacion": "2021-12-18", "doble_articulado": false, "id_norma": "1022400", "numero_fuente": "39870", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2011-01-27", "vigencias": [{"desde": "2021-12-18", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2011-01-27", "hasta": "2