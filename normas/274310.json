{"html": [{"t": "<div><div class=\"p\">NOTIFICACI&#xD3;N </div></div>", "i": 7375663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.956 de 25 de junio de 2008 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme D.L. N&#xBA;2.186 de 1978, del inmueble ubicado en Catorce de la Fama 2656, Rol de Aval&#xFA;o N&#xBA;3805-84, comuna de Independencia, de aparente dominio de Sa&#xE9;z C&#xE1;ceres Rodolfo y Otros;</div><div class=\"p\">correspondiente al Lote N&#xBA;8, del Proyecto Vial &quot;Habilitaci&#xF3;n Corredor de Transporte P&#xFA;blico Avda. Dorsal&quot;. Comisi&#xF3;n integrada por Ariel Quiroga Casta&#xF1;eda, Arquitecto, Armando Pinochet Landero, Constructor Civil y M. In&#xE9;s M&#xE1;rquez Guti&#xE9;rrez, ingeniero civil, seg&#xFA;n informe de 16 de abril de 2008, fij&#xF3; monto provisional indemnizaci&#xF3;n en $1.198.350, pagadera al contado.</div><br></div>", "i": 7375664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Metropolitano.</div><br></div>", "i": 7375665}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3956 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3956 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "DISPONE EXPROPIACIÓN PARCIAL Y TOTAL DE INMUEBLES QUE INDICAN; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-25", "doble_articulado": false, "id_norma": "274310", "numero_fuente": "39113", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-07-15", "vigencias": [{"des