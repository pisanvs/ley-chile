{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 497 EXENTO, DE 2000 </div></div>", "i": 6311730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 497 de fecha 9 de noviembre de 2000 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; a la Universidad San Sebasti&#xE1;n la Carrera de T&#xE9;cnico de Nivel Superior en Enfermer&#xED;a, conducente al T&#xED;tulo de T&#xE9;cnico de Nivel Superior en Enfermer&#xED;a, para ser impartida desde el segundo semestre del a&#xF1;o 2000 en jornada diurna, en su sede de la ciudad de Concepci&#xF3;n, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6311731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de noviembre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6311732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "497 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-497 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 497 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-09", "doble_articulado": false, "id_norma": "178734", "numero_fuente": "36837", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-12-14", "vigencias": [{"desde": "2000-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-12-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-12-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v