{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,957.-&nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6192681}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.-&nbsp; Conc&#xE9;dese, por gracia, a cada una de las hijas del ex Ministro de la Corte Suprema de Justicia, don C&#xE1;rlos Varas Herrera: do&#xF1;a Mar&#xED;a, do&#xF1;a Josefina y do&#xF1;a Raquel Varas Olea, y do&#xF1;a Elena Varas viuda de Ureta, el goce de una pension anual de dos mil cuatrocientos pesos ($ 2,400).&quot; </div></div>", "i": 6192682}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a seis de julio de mil novecientos veintitres.-&nbsp; Arturo Alessandri.-&nbsp; Alcib&#xED;ades Roldan.</div><br></div>", "i": 6192683}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3957", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3957"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-07-06", "doble_articulado": false, "id_norma": "143913", "numero_fuente": "13621", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-07-09", "vigencias": [{"desde": "1923-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1923-07-09", "fin_vigencia": ""}, "vigencias_version_n