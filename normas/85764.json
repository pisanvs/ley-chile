{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 2.392, DE 1989 </div><br></div>", "i": 7220643}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n exenta No. 2.392 de fecha 01 de septiembre de 1989 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se insert&#xF3; en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 516 de 1988, del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Las Am&#xE9;ricas de Temuco, las adecuaciones introducidas a la carrera de Contabilidad Computarizada, las que podr&#xE1;n aplicarse a contar del segundo semestre 1989.</div><br></div>", "i": 7220644}, {"t": "<div><div class=\"p\">Santiago, 26 de Octubre de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7220645}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2392 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2392 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 2.392, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-09-01", "doble_articulado": false, "id_norma": "85764", "numero_fuente": "33595", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-13", "vigencias": [{"desde": "1990-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACI