{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 388 EXENTO, DE 1997 </div></div>", "i": 7206526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 388, de 7 de abril de 1997, se ha aprobado al Colegio &quot;The Wessex School&quot; de Concepci&#xF3;n, un plan de estudio para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o (NB.1 y NB.2) de Ense&#xF1;anza B&#xE1;sica, los cuales podr&#xE1;n ser aplicados a partir del a&#xF1;o escolar 1997, de acuerdo al cronograma establecido en el Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996. </div></div>", "i": 7206527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas complementarios propios del establecimiento que se se&#xF1;alan en el presente decreto.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de abril de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7206528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "388 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-388 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 388 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "ENSE ANZA BASICA", "COLEGIO THE WESSEX SCHOOL", "CONCEPCION", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-07", "doble_articulado": false, "id_norma": "71202", "numero_fuente": "35761", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-09", "vigencias": [{"desde": "1997-05-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci