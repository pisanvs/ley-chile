{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 153, DE 1991</div><br><br></div>", "i": 6057598}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 153 de 28 de junio de 1991 se ha aprobado al Liceo Dar&#xED;o E. Salas (A No.</div><div class=\"p\">16) de Santiago, un plan especial de estudio para ser aplicado progresivamente a partir del a&#xF1;o escolar 1991 en 7&#xB0; y 8&#xB0; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica y 1er. y 2do. a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico - Cient&#xED;fica; del a&#xF1;o 1992 en 3er. a&#xF1;o medio y del a&#xF1;o 1993 en 4to. a&#xF1;o medio.</div><br></div>", "i": 6057599}, {"t": "<div><div class=\"p\">Santiago, 29 de Julio de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6057600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "153 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-153 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 153, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-28", "doble_articulado": false, "id_norma": "80541", "numero_fuente": "34053", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-27", "vigencias": [{"desde": "1991-08-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-08-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-08-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fe