{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A DON CLAUDIO SANDOVAL ALLER </div></div>", "i": 6627756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex. 9.673, de fecha 9 de octubre de 2007, otorga a Claudio Sandoval Aller, RUT N&#xBA; 5.292.361-1, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de ganado vivo, establecido en la resoluci&#xF3;n N&#xBA; Ex. 3.721, de 28-07-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida. </div></div>", "i": 6627757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 9 de octubre de 2007.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6627758}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9673 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-9673 EXENTA"}, {"tipo": "3", "numero": "DRE-08-9673 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-9673 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A DON CLAUDIO SANDOVAL ALLER", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-09", "doble_articulado": false, "id_norma": "265916", "numero_fuente": "38895", "tipo_version": "3", "tipo_version_s": "Ún