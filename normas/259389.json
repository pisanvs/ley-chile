{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; EXTRACTO</div><br></div>", "i": 7338241}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 25, de 5 de marzo de 2007, de la Secretar&#xED;a Regional Ministerial de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se declar&#xF3; extinguida la Pr&#xF3;rroga de Contrato de Concesi&#xF3;n, de la Planta de Revisi&#xF3;n T&#xE9;cnica Clase AB, concesionario &quot;M &amp; M Servicios y Construcciones Limitada&quot;, que practica revisi&#xF3;n t&#xE9;cnica de veh&#xED;culos Clase A y B, en la comuna de Yumbel, dispuesto y aprobado mediante la resoluci&#xF3;n exenta N&#xBA; 62 de 25 de agosto de 1997, de la Seremi precitada, estableci&#xE9;ndose la siguiente fecha de cierre, 07 de marzo de 2007.</div><br></div>", "i": 7338242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Claudio V&#xE1;squez Fern&#xE1;ndez, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 7338243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "25 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-25 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-03-05", "doble_articulado": false, "id_norma": "259389", "numero_fuente": "38723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-26", "vigencias": [{"desde"