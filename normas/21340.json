{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 488 EXENTO, DE 1995 </div><br></div>", "i": 5944843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 488, de fecha 22 de agosto de 1995 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el inciso 1&#xB0; del art&#xED;culo 1&#xB0; del Decreto Exento N&#xB0; 199 de 1988, correspondiente al Instituto Profesional Alem&#xE1;n de Valpara&#xED;so, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Autor&#xED;zase el funcionamiento del Instituto Profesional que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala:</div><div class=\"p\">&nbsp; &nbsp; Nombre de la Instituci&#xF3;n : Instituto Profesional Alem&#xE1;n de Valpara&#xED;so.</div><div class=\"p\">&nbsp; &nbsp; Domicilio : Valpara&#xED;so.</div><div class=\"p\">&nbsp; &nbsp; Organizador : Corporaci&#xF3;n Instituto Profesional Alem&#xE1;n de Valpara&#xED;so.&quot;.</div><br></div>", "i": 5944844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 4 de Septiembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "488 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-488 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 488 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PERSONALIDAD JURIDICA", "AUTORIZACION", "INSTITUTO PROFESIONAL ALEMAN VALPARAISO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-08-22", "fecha_derogacion": "2003-08-13", "doble_articulado": false, "id_norma":