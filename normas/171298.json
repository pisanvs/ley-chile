{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 179 EXENTO, DE&nbsp; 2000 </div></div>", "i": 6283242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 179, de 29 de mayo de 2000, se ha aprobado al&nbsp; Colegio &apos;&apos;Andre&#xE9; English School&apos;&apos;, comuna de La Reina, de Santiago, las adecuaciones que se indican en el presente decreto, para los cursos de 5&#xBA;, 6&#xBA;, 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, las que ser&#xE1;n aplicadas conforme a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 40, de 1996 y sus modificaciones.</div><br></div>", "i": 6283243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de junio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6283244}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "179 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-179 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 179 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-29", "doble_articulado": false, "id_norma": "171298", "numero_fuente": "36695", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-22", "vigencias": [{"desde": "2000-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr