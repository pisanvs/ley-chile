{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 95, DE 1989 </div></div>", "i": 7229664}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 95 de 12 de mayo de 1989 se ha aprobado a contar del a&#xF1;o escolar 1989, al Liceo A No. 85 &quot;Jos&#xE9; Manuel Balmaceda&quot; de la comuna de Concepci&#xF3;n, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, un plan de estudio especial para la Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica de Adultos y programas especiales para las asignaturas que conforman las Areas de Orientaci&#xF3;n Formativa, Educaci&#xF3;n T&#xE9;cnica y Educaci&#xF3;n Complementaria.</div><br></div>", "i": 7229665}, {"t": "<div><div class=\"p\">- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7229666}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "95", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-95"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 95, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-12", "doble_articulado": false, "id_norma": "95411", "numero_fuente": "33404", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-22", "vigencias": [{"desde": "1989-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in