{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 396 EXENTO, DE 2002 </div></div>", "i": 6383626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 396, de fecha 8 de mayo de 2002, del Ministerio de Educaci&#xF3;n, se deja sin efecto el decreto exento de Educaci&#xF3;n N&#xBA; 488 del 29 de abril de 1997 que autoriz&#xF3; el funcionamiento de la Sede N&#xBA; 1 del Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Navieros Concepci&#xF3;n, de la ciudad de Valpara&#xED;so, en raz&#xF3;n a que dicha sede ha dejado de funcionar.</div><br></div>", "i": 6383627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de mayo de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6383628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "396 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-396 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 396 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-08", "doble_articulado": false, "id_norma": "198752", "numero_fuente": "37273", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-03", "vigencias": [{"desde": "2002-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2002-06-03", "fecha_version": "2002-06-03", "fecha