{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6596326}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.252, de 24 de noviembre de 2006, de esta Subsecretar&#xED;a, modifica numeral 5.- de resoluci&#xF3;n N&#xBA; 2.744 de 2006, de esta Subsecretar&#xED;a, en el sentido de establecer que podr&#xE1;n participar en las actividades extractivas de pesca investigaci&#xF3;n autorizada todas las personas y embarcaciones inscritas en el Registro Pesquero Artesanal de X Regi&#xF3;n, conforme a requisitos se&#xF1;alados en resoluci&#xF3;n extractada. </div></div>", "i": 6596327}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de noviembre de 2006.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 6596328}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3252 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3252 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-24", "doble_articulado": false, "id_norma": "257169", "numero_fuente": "38651", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-30", "vigencias": [{"desde": "2006-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-12-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion