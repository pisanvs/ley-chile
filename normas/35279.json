{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 640, de 10 de abril de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la</div><div class=\"p\">Resoluci&#xF3;n N&#xB0; 1.158, de 1988, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a PESQUERA LOA NORTE S.A., para ampliar</div><div class=\"p\">actividades pesqueras extractivas, por haberse</div><div class=\"p\">configurado la causal de caducidad prevista en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca. </div></div>", "i": 8293495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 10 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293496}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "640", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-640"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA LOA NORTE S.A", "AMPLIACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-10", "doble_articulado": false, "id_norma": "35279", "numero_fuente": "35445", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-18", "vigencias": [{"desde": "1996-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-04-1