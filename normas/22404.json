{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Convencion Postal Reglamento Lei n&#xFA;m. 1.093.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br><br></div>", "i": 8931381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Que aprueba la convencion i reglamento suscrito en W&#xE1;shington el 12 de Agosto de 1897 entre Chile i los Estados Unidos de Am&#xE9;rica, destinados a establecer un servicio regular de jiros postales.</div><br><br></div>", "i": 8931382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- J. J. Latorre.</div></div>", "i": 8931383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1093", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1093"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "CONVENCION POSTAL REGLAMENTO", "fuente": "Boletin de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": ["ACUERDOS INTERNACIONALES", "CHILE - ESTADOS UNIDOS DE AMERICA", "CONVENCION POSTAL", "GIROS POSTALES", "SERVICIO REGULAR", "APOBACION", "REGLAMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["ESTA LEY NO HA SIDO PUBLICADA EN EL DIARIO OFICIAL. ADEMAS, NO TIENE FECHA DE PROMULGACION."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-08-12", "doble_articulado": false, "id_norma": "22404", "numero_fuente": "SUPLEMENTO A O 1898, PAGINA N 52", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1897-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic