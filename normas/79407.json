{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0;362, DE 1991 </div></div>", "i": 7214362}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 362 de fecha 26 de diciembre de 1991 del Ministerio de Educaci&#xF3;n, se dej&#xF3; sin efecto el art&#xED;culo 2&#xB0; y siguientes de la Resoluci&#xF3;n Exenta No. 1560 de 1988, y se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Estudios Agr&#xED;colas CEA, a contar del segundo semestre acad&#xE9;mico 1991 .</div><br></div>", "i": 7214363}, {"t": "<div><div class=\"p\">Santiago, 29 de Enero de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7214364}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "362 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-362 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°362, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-12-26", "doble_articulado": false, "id_norma": "79407", "numero_fuente": "34227", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-03-25", "vigencias": [{"desde": "1992-03-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-03-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-03-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "PGA", "fecha_ingreso": "1997-12-10", "fecha_version": "1992-03-2