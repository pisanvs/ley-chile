{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,098.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los importantes servicios prestados al pais por el se&#xF1;or don Amado Pissis, conc&#xE9;dese a su viuda, la se&#xF1;ora Emilia Vicu&#xF1;a, viuda de Pissis, i a su hija la se&#xF1;orita Enriqueta Pissis Vicu&#xF1;a, una pension anual de dos mil pesos, de que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar. </div></div>", "i": 6161536}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a siete de octubre de mil ochocientos noventa y ocho.- FEDERICO ERRAZURIZ.- Carlos A. Palacios Z.</div><br></div>", "i": 6161537}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1098", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1098"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-10-07", "doble_articulado": false, "id_norma": "134170", "numero_fuente": "6123", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-10-12", "vigencias": [{"desde": "1898-10-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-10-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"i