{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6570593}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.311 de 16 de mayo de 2006 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; de la resoluci&#xF3;n N&#xBA;1.252 de 2006, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Determinaci&#xF3;n de la Distribuci&#xF3;n Espacial de Jurel entre la V y X Regiones, Oto&#xF1;o 2006&quot;, en el sentido de indicar que la nave &quot;Libas&quot;, del armador South Pacific Korp S.A., s&#xF3;lo podr&#xE1; ser utilizada como nave reemplazante en caso de que la nave &quot;Malleco&quot; deba abandonar el estudio por fuerza mayor.</div><br></div>", "i": 6570594}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de mayo de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6570595}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1311 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1311 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-16", "doble_articulado": false, "id_norma": "249847", "numero_fuente": "38470", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-23", "vigencias": [{"desde": "2006-05-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio