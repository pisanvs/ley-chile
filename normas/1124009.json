{"html": [{"t": "<div><br><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9955254}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 5.513 de 4 de octubre de 2018, Serviu Regi&#xF3;n de Valpara&#xED;so, dispuesto expropiaci&#xF3;n conforme al art&#xED;culo 51 ley 16.391 y decreto ley 2.186 de 1978, del inmueble signado como lote 182 I, en el plano &quot;Proyecto de Expropiaciones DRS-P N&#xB0; 12201&quot; L&#xE1;mina 20 de 23, comuna de Quilpu&#xE9;, presunto dominio de Lionel Kovacs y C&#xED;a. SCI Limitada, rol aval&#xFA;o 472-2 / 472-3. Comisi&#xF3;n Tasadora integrada por Guillermo Parra Silva; Julia Venegas Escalante y Jaime Jurgens Bittner, seg&#xFA;n informe de 2018 fij&#xF3; monto indemnizaci&#xF3;n provisional en $4.928.609.-, que ser&#xE1; pagada al contado.- </div></div>", "i": 9955255}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Directora (S) Serviu. </div><br></div>", "i": 9955256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5513 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5513 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "V REGIÓN DE VALPARAÍSO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1476051", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-10-04", "doble_articulado": false, "id_norma": "1124009", "numero_fuente": "42181", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-10-16", "vigencias": [{"desde": "2018-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-10-16", "fin_v