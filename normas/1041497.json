{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9270754}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;997 de 31 de mayo de 2012, se modific&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1017146&amp;idParte=0&amp;idVersion=\">Decreto MOP Exento N&#xBA;1158 de 30 de agosto de 2010</a>, en los siguientes aspectos: en el numeral 2&#xB0;, el propietario del predio afecto a expropiaci&#xF3;n es don DANIEL ENRIQUE VERA AGUILAR y, en el numeral 3&#xB0;, se autoriza el convenio ad refer&#xE9;ndum directo de precio, suscrito por dicho propietario y el Director Regional de Vialidad de la Regi&#xF3;n del B&#xED;o B&#xED;o, con fecha 15 de noviembre de 2011. </div></div>", "i": 9270755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9270756}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "997 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-997 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-31", "doble_articulado": false, "id_norma": "1041497", "numero_fuente": "40302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-03", "vigencias": [{"desde": "2012-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part":