{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO ALCALDICIO N&#xB0; 62, DE 1980</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 35 exento.- Futrono, 20 de Diciembre de 1985.- Vistos: Estos antecedentes, el decreto alcaldicio N&#xB0; 62 del 30 de diciembre de 1980 y en uso de las atribuciones que me confiere el art&#xED;culo 13 del DL N&#xB0; 1.289 de 1975, org&#xE1;nico de municipios y administraci&#xF3;n comunal, dicto el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6235174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.- Reempl&#xE1;zase la palabra &quot;Decreto N&#xB0; 62&quot; por &quot;Ordenanza N&#xB0; 1&quot; en el Decreto Alcaldicio N&#xB0; 62 del 30 de diciembre de 1980 sobre derechos municipales por concesiones, permisos y servicios.</div><br></div>", "i": 6235175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, publ&#xED;quese en el Diario Oficial de la Rep&#xFA;blica y archivese.- Fernando P&#xE9;rez V&#xE1;squez, alcalde.- Rebeca Asenjo Jaramillo, Secretario Municipal.</div><br></div>", "i": 6235176}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "35 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-35 EXENTO"}], "organismos": ["MUNICIPALIDAD DE FUTRONO"], "titulo_norma": "MODIFICA DECRETO ALCALDICIO N° 62, DE 1980", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-20", "doble_articulado": false, "id_norma": "156319", "numero_fuente": "32392", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-02-07", "vigencias": [{"desde": "1986-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic