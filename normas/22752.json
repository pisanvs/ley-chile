{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que concede un suplemento al presupuesto de Marina Santiago, a 5 de Diciembre de 1902.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5950551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de veinticinco mil pesos ($ 25,000) al &#xED;tem 11,566 del presupuesto vijente que consulta fondos para art&#xED;culos de armamento, pertrechos, consumos i acarreos de &#xE9;stos a los faros.</div><br></div>", "i": 5950552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Francisco Baeza.</div><br></div>", "i": 5950553}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1566", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1566"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "QUE CONCEDE UN SUPLEMENTO AL PRESUPUESTO DE MARINA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1902", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1902-12-05", "doble_articulado": false, "id_norma": "22752", "numero_fuente": "7453", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1902-12-06", "vigencias": [{"desde": "1902-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1902-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1902-12-06", "fin_vigencia": ""