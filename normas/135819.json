{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,050.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6166715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Lucrecia, do&#xF1;a Mercedes, do&#xF1;a Zoila Rosa i do&#xF1;a Julia Marzan, hermanas del coronel de Ej&#xE9;rcito don David Marzan, derecho a disfrutar de la correspondiente pension de montep&#xED;o militar, con arreglo a las leyes de 6 de agosto de 1855 i 22 de setiembre de 1890.</div><br></div>", "i": 6166716}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, dieciseis de setiembre de mil novecientos siete.- Pedro Montt.- Alejandro Lira.</div><br></div>", "i": 6166717}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2050", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2050"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-09-16", "doble_articulado": false, "id_norma": "135819", "numero_fuente": "8914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-10-03", "vigencias": [{"desde": "1907-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-10-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-10-03", "fin