{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Espediente de Invalidez Lei n&#xFA;m. 976.- Santiago, a 23 de Diciembre de 1897.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se rehabilita al ex-subteniente del batallon movilizado Maule, don Edelmiro de la Rosa, para que pueda tramitar su expediente de invalidez con arreglo a la lei de 22 de Diciembre de 1881.</div><br><br></div>", "i": 7162782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Patricio Larrain A.</div><br></div>", "i": 7162783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "976", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-976"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "ESPEDIENTE DE INVALIDEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EDELMIRO DE LA ROSA", "REHABILITACION", "INVALIDEZ", "TRAMITACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-12-23", "doble_articulado": false, "id_norma": "22317", "numero_fuente": "5889", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-12-28", "vigencias": [{"desde": "1897-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-12-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1897-12-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": []