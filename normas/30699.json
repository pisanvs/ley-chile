{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; FIJA COMO FERIADO DIA QUE SE&#xD1;ALA, PARA COMUNA QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; Teniendo presente que el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto del ley:</div><br></div>", "i": 8287964}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- F&#xED;jase como feriado, con &#xE1;mbito de aplicaci&#xF3;n restringido para la comuna de La Serena, el d&#xED;a 26 de Agosto de 1994.&quot;.</div><br></div>", "i": 8287965}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de Agosto de 1994.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Germ&#xE1;n Correa D&#xED;az, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8287966}], "proyectos": [{"categoria": "Proyecto original", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=1273-06", "informacion": "Establece el día 26 de Agosto de 1994, como feriado para la ciudad de La Serena", "nroBoletin": "1273-06"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "19332", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-19332"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "FIJA COMO FERIADO DIA QUE SEÑALA, PARA COMUNA QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Comuna de La Serena", "Feriado 26 de agosto 1994", "Ley no. 19.332"], "terminos_libres": ["FERIADO LEGAL", "SERENA", "CUARTA REGION", "26-AGO-1994"], "categorias_norma": [], "nombre