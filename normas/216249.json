{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6444982}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la Universidad del Mar inscrita bajo el n&#xFA;mero C-30 del Registro de Universidades del Ministerio de Educaci&#xF3;n, presentado los programas de estudios de la carrera de Comercio Internacional conducente al T&#xED;tulo de Administrador de Empresas a la Universidad Arturo Prat, quien los ha aprobado y se ha constituido en entidad examinadora, de conformidad al convenio celebrado entre ambas instituciones con fecha 14 de Noviembre de 1990.</div><div class=\"p\">&nbsp; &nbsp;  La carrera mencionada podr&#xE1; impartirse a contar desde 1991, en la Sede Vi&#xF1;a del Mar de dicha Universidad.</div><br></div>", "i": 6444983}, {"t": "<div><div class=\"p\">Santiago, 19 de Julio de 1991.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; RAUL ALLARD NEUMANN</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6444984}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-19", "doble_articulado": false, "id_norma": "216249", "numero_fuente": "34032", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-01", "vigencias": [{"desde": "1991-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic