{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6540864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.955, de 7 de septiembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL E INDUSTRIAL AGROMAR LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en Teniente Merino N&#xBA;004, Dalcahue, X Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado, Congelado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6540865}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de septiembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br><br><br></div>", "i": 6540866}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2955 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2955 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-07", "doble_articulado": false, "id_norma": "242249", "numero_fuente": "38268", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-09-22", "vigencias": [{"desde": "2005-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-09-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha