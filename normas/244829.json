{"html": [{"t": "<div><div class=\"p\">AUTORIZA A RECEPTORES ELECTRONICOS</div><br><br></div>", "i": 6551924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 132, de 2 de diciembre de 2005, que autoriza a Organismos P&#xFA;blicos como receptores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; Se autoriza como receptores de documentos tributarios electr&#xF3;nicos, a contar del mes de diciembre de 2005, a los Organismos P&#xFA;blicos, RUT 61.933.600-3 y RUT 72.240.400-9.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2005. </div></div>", "i": 6551925}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "132 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-132 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A RECEPTORES ELECTRONICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ORGANISMOS PUBLICOS", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS", "RECEPTORES ELECTRONICOS", "PROCEDIMIENTOS DE OPERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-02", "doble_articulado": false, "id_norma": "244829", "numero_fuente": "38332", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-09", "vigencias": [{"desde": "2005-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":