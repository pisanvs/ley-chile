{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 56, DE 2019, DICTADA POR EL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES</div></div>", "i": 10096677}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 56, de 26 de noviembre de 2019, tomada de raz&#xF3;n por la Contralor&#xED;a General de la Rep&#xFA;blica, se renovaron y modificaron las Condiciones de Operaci&#xF3;n, aprobadas por resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1077919&amp;idParte=&amp;idVersion=\">N&#xBA; 1.218</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1078039&amp;idParte=&amp;idVersion=\">N&#xBA; 1.249</a>, de 2015, modificadas por resoluciones exentas N&#xBA; 2.908, de 2015; N&#xBA; 3.230 y N&#xBA; 3.257, de 2016; N&#xBA; 1.742, de 2018, y N&#xBA; 151, de 2019, y resoluci&#xF3;n N&#xBA; 45, de 2019, todas del Ministerio de Transportes y Telecomunicaciones. Texto &#xED;ntegro de la resoluci&#xF3;n se encuentra en la p&#xE1;gina web www.dtpm.cl.- </div></div>", "i": 10096678}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Gloria Hutt Hesse, Ministra de Transportes y Telecomunicaciones.</div><br></div>", "i": 10096679}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "56", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-56"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 56, DE 2019, DICTADA POR EL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1718334; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-11-26", "doble_ar