{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10192484}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.382, de 28 de diciembre de 2020, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en V. Los Aromos St 164, Rol Aval&#xFA;o N&#xBA; 624-6, Comuna Constituci&#xF3;n, superficie terreno 14,50 M2, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Sede Junta de Vecinos. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, Arquitecto; Rodrigo Antonio Silva Lazo, Constructor Civil y Pedro Pablo Cruz Weston, Arquitecto, seg&#xFA;n informe de 21 diciembre 2020, fij&#xF3; monto provisional indemnizaci&#xF3;n en $435.000.- pagados al contado.- </div></div>", "i": 10192485}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10192486}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2382 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2382 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1876090", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-28", "doble_articulado": false, "id_norma": "1154680", "numero_fuente": "42855", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-01-15", "vigencias": [{"desde": "2021-01-15", "hasta": "