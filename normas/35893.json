{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 929, de 10 de octubre de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto las Resoluciones N&#xB0; 3 y N&#xB0; 936, ambas de 1988, de esta Subsecretar&#xED;a, que autorizaron a SOCIEDAD EXPLOTADORA DE RECURSOS MARINOS LIMITADA &quot;Serman Ltda.&quot;, para operar un establecimiento de cultivo, en un sector denominado Piedra Azul, comuna de Puerto Montt, Provincia de Llanquihue, Regi&#xF3;n de Los Lagos, X Regi&#xF3;n, por haberse caducado la concesi&#xF3;n mar&#xED;tima de acuicultura. </div></div>", "i": 8294899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 10 de Octubre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294900}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "929", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-929"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD EXPLOTADORA RECURSOS MARINOS LIMITADA", "CADUCIDAD", "CONCESION ACUICULTURA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-10-10", "doble_articulado": false, "id_norma": "35893", "numero_fuente": "34993", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-10-18", "vigencias": [{"desde": "1994-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"