{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 6, DE 1988 </div></div>", "i": 6178585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 6, de 22 de enero de 1988, se ha aprobado a contar desde 1988, a la Escuela Especial F No. 19, de Rancagua, Provincia de Cachapoal, VI Regi&#xF3;n del Libertador General Bernardo O&apos;Higgins, dependiente de la Corporaci&#xF3;n Municipal de Servicios P&#xFA;blicos de Rancagua, un plan de estudio que ser&#xE1; desarrollado en Talleres de Capacitaci&#xF3;n Laboral. Adem&#xE1;s, se aprueban programas de estudio para las Areas Com&#xFA;n, Laboral y Complementaria.</div><br></div>", "i": 6178586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de Enero de 1988.- Mar&#xED;a Piedad Ruiz Ferreras, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6178587}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "6 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-6 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 6, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-22", "doble_articulado": false, "id_norma": "139467", "numero_fuente": "32999", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-18", "vigencias": [{"desde": "1988-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-18", "fin_vigencia": "", "tipo_version": "3