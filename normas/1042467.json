{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9286160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA;1208 de 29 de junio de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;1, superficie 62.361 m2, rol de Aval&#xFA;o N&#xBA;158-137, comuna de Cocham&#xF3;, para la obra &quot;CONSTRUCCI&#xD3;N CAMINO PUELO - PASO EL BOLS&#xD3;N, SECTOR: SEGUNDO CORRAL - EL BOLS&#xD3;N&quot;. La Comisi&#xF3;n de peritos, integrada por LEOPOLDO RAM&#xD3;N SCHUMACHER GUARDA, JUAN SAMUEL BARRIENTOS BAHAMONDE Y NELSON BERNARDO TURRA TURRA, fij&#xF3; el valor de tasaci&#xF3;n con fecha 28 de septiembre de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JOS&#xC9; OSCAR ARGEL CARABANTE, en la cantidad de $16.324.951.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9286161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9286162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1208 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1208 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-29", "doble_articulado": false, "id_norma": "1042467", "numero_fuente": "40326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-01", "vigencias": [{"desde": "2012-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-01", "fin_vigencia": ""}, "vigencias_ve