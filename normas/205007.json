{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A MOLINERA MAULE S.A.</div><br></div>", "i": 6404113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Santiago Poniente del SII, por resoluci&#xF3;n N&#xBA; Ex. 447, de 10 de mayo de 2002, concede la calidad de Agente Retenedor del Impuesto al Valor Agregado en las compras de trigo a la empresa Molinera Maule S.A., RUT 96.969.060-8, con vigencia a contar del d&#xED;a 1&#xBA; del mes siguiente al de su publicaci&#xF3;n en el Diario Oficial y en forma indefinida, mientras se mantenga el fiel cumplimiento de la resoluci&#xF3;n N&#xBA; Ex.</div><div class=\"p\">5.281, de 30 de noviembre de 2000 (D.O. de 04.12.2000).- </div></div>", "i": 6404114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 6404115}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "447 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-447 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO PONIENTE"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A MOLINERA MAULE S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-10", "doble_articulado": false, "id_norma": "205007", "numero_fuente": "37419", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-27", "vigencias": [{"desde": "2002-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic