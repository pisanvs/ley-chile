{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6075602}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 1.063, de 31 de Octubre de 1997, se expropiaron los lotes de terreno N&#xBA;s. 1, 2, 40, 41 45 y 46, superficies 1.106, 378, 154, 1.371, 74 y 571 M2. respectivamente, roles de aval&#xFA;o 427-2, 427-45, 426-20 y 427-25, comuna de Cauquenes, para la obra Camino Cauquenes - L&#xED;mite Regional - Quirihue, Sector Cauquenes - L&#xED;mite Regional y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Zacar&#xED;as Salgado Salgado, Jaime Rojas Torres, Eugenio Barras P&#xE9;rez, Gabriel Y&#xE1;&#xF1;ez V&#xE1;squez y Jos&#xE9; Merino Quevedo, ascendente a las cantidades de $704.200.- para el lote 1, $178.350.- para el lote 2, $2.226.250.- para los lotes 40 y 41, $248.700.- para el lote 45 y 42.072.825.- para el lote 46.</div><br></div>", "i": 6075603}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.- </div></div>", "i": 6075604}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1063", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1063"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "CAUQUENES", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-31", "doble_articulado": false, "id_norma": "87210", "numero_fuente": "35965", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-15", "vigencias": [{"desde": "1998-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":