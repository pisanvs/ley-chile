{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,144, que fija el derecho que debe pagar por internacion la leche condensada</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,144.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7165553}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. La leche condensada, con o sin az&#xFA;car, que se importe del estranjero, pagar&#xE1; un derecho espec&#xED;fico de internacion de treinta i ocho centavos por kil&#xF3;gramo bruto de peso.</div><br></div>", "i": 7165554}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de Noviembre de 1908.- PEDRO MONTT.- Pedro N. Montenegro.</div><br></div>", "i": 7165555}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2144", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2144"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NÚM. 2.144, QUE FIJA EL DERECHO QUE DEBE PAGAR POR INTERNACIÓN LA LECHE CONDENSADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LECHE CONDENSADA", "DERECHO ESPECIFICO INTERNACION", "PAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-11-24", "