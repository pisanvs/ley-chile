{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9327623}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA;3242 de 27 de diciembre de 2012, de conformidad lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;92, superficie 485 m2, rol de Aval&#xFA;o N&#xBA;203-239, comuna de Chait&#xE9;n, para la obra &quot;CONSTRUCCI&#xD3;N RUTA 7, SECTOR PICHANCO &#x2013; SANTA B&#xC1;RBARA, TRAMO CALETA GONZALO &#x2013; STA. B&#xC1;RBARA&quot;. La Comisi&#xF3;n de peritos, integrada por JUAN SAMUEL BARRIENTOS BAHAMONDE, LEOPOLDO RAM&#xD3;N SCHUMACHER GUARDA Y CHRISTIAN EMIL RAUCH Y&#xC1;&#xD1;EZ, fij&#xF3; el valor de tasaci&#xF3;n con fecha 28 de febrero de 2012, acord&#xE1;ndose la indemnizaci&#xF3;n con AMANDA DEL CARMEN MANSILLA MANSILLA, en la cantidad de $565.968.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9327624}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9327625}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3242 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3242 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-27", "doble_articulado": false, "id_norma": "1048105", "numero_fuente": "40459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-15", "vigencias": [{"desde": "2013-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-01-15", "fin_vige