{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7269916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 460, de 12 de Abril de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 3 de la resoluci&#xF3;n No.</div><div class=\"p\">1.565, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don CRISTIAN KOLBACH FRUGONE, R.U.T. No. 6.752.994-1, domiciliado en Valdivia, para iniciar actividades pesqueras, en el sentido de autorizar la extracci&#xF3;n del recurso Albacora o pez espada, con la nave &quot;Mar&#xED;a Ignacia III&quot; en el litoral de las Regiones I a X, con el arte de pesca enmalle. </div></div>", "i": 7269917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de Abril de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7269918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "460", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-460"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-04-12", "fecha_derogacion": "2000-10-23", "doble_articulado": false, "id_norma": "168967", "numero_fuente": "33952", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-04-25", "vigencias": [{"desde": "2000-10-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-04-25", "hasta": "2000-10-22", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"in