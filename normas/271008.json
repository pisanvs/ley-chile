{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7368899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0;931, de 16 de abril de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a SUDMARIS CHILE S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en Astilleros s/n, Dalcahue sector rural, Chilo&#xE9;, X Regi&#xF3;n, para elaborar en la l&#xED;nea de proceso de congelado los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xB0;1.784 de 2005, de esta Subsecretar&#xED;a, en virtud de la renuncia citada en Visto y del contenido de la presente resoluci&#xF3;n. </div></div>", "i": 7368900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de abril de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7368901}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "931 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-931 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-16", "doble_articulado": false, "id_norma": "271008", "numero_fuente": "39055", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-07", "vigencias": [{"desde": "2008-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-05-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc