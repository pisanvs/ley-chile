{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6078294}, {"t": "<div><div class=\"p\">El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Capitulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente ala primera quincena de enero de 1991, fue de 6,06% anual.</div><br></div>", "i": 6078295}, {"t": "<div><div class=\"p\">Santiago, 18 de enero de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 6078296}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-18", "doble_articulado": false, "id_norma": "88160", "numero_fuente": "33872", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-19", "vigencias": [{"desde": "1991-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PGA", "fecha_ingreso": "1998-02-06", "fecha_version": "1991-01-19", "fecha_actualizacion_texto": "1991-01-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6078294}, {"n": "Artículo", "i": 6078295, "t": 6}, {"n": "Promulgación", "i": 6078296}]}