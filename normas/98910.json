{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 630, de 4 de mayo de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad total de las resoluciones N&#xBA; 1.235 de 1990 y N&#xBA; 374, de 1991, ambas de esta Subsecretar&#xED;a, que autorizaron a MAURICIO VILLARROEL SALAZAR para desarrollar actividades pesqueras extractivas con la nave &apos;&apos;Soberana&apos;&apos;, conforme a lo dispuesto en el art&#xED;culo 143 letras b) y d) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8329912}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329913}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "630", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-630"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "MAURICIO VILLARROEL SALAZAR", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-04", "doble_articulado": false, "id_norma": "98910", "numero_fuente": "36063", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-13", "vigencias": [{"desde": "1998-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-05-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend