{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6410619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 24, de 8 de enero de 2003, de esta Subsecretar&#xED;a, recon&#xF3;cese la participaci&#xF3;n conjunta de los armadores que se indican, en la unidad de pesquer&#xED;a de Jurel, I y II Regiones, individualizada en el art&#xED;culo 2&#xBA; letra r) de la ley 19.713, para ejercer el l&#xED;mite m&#xE1;ximo de captura establecido por decreto exento N&#xBA; 1.126 de 2002, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, a partir de la fecha de la presente resoluci&#xF3;n y hasta el 31 de diciembre del 2003:</div><br><div class=\"p\">CORPESCA S.A.; SAN JOSE S.A., PESQ.; SOUTH PACIFIC KORP S.A.</div><br></div>", "i": 6410620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6410621}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "24", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-24"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-08", "doble_articulado": false, "id_norma": "206848", "numero_fuente": "37461", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-17", "vigencias": [{"desde": "2003-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-17", "fin_vigencia