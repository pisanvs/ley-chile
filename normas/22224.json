{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMINO PUBLICO DE RENGO A PANQUEHUE I POPETA Lei n&#xFA;m. 374.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declaran de utilidad p&#xFA;blica los terrenos necesarios, a juicio del Presidente de la Rep&#xFA;blica, para restablecer el camino p&#xFA;blico de Rengo a Panquehue i Popeta.</div><br><br></div>", "i": 5947766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 13 de Agosto de 1896.- JORJE MONTT.-</div><div class=\"p\">El&#xED;as Fern&#xE1;ndez A.</div><br></div>", "i": 5947767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "374", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-374"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "CAMINO PUBLICO DE RENGO A PANQUEHUE I POPETA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMINO PUBLICO", "RENGO-PANQUEHUE-POPETA", "EXPROPIACION", "TERRENOS", "UTILIDAD PUBLICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-08-13", "doble_articulado": false, "id_norma": "22224", "numero_fuente": "5485", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-08-19", "vigencias": [{"desde": "1896-08-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "