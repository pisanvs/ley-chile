{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,348.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Eduvijis Ureta v. de Zegers, madre del subteniente de Ej&#xE9;rcito, don Eduardo 2.&#xBA; Zegers, muerto a consecuencia de heridas que recibi&#xF3; en la batalla de Chorrillos, derecho a la pension que la lei de 22 de diciembre de 1881 acuerda a la madre-viuda de un subteniente de Ej&#xE9;rcito, muerto en acci&#xF3;n de guerra.</div><br></div>", "i": 6171542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, trece de agosto de mil novecientos diez.-</div><div class=\"p\">El&#xED;as Fern&#xE1;ndez A.- C&#xE1;rlos Larrain Claro.</div><br></div>", "i": 6171543}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2348", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2348"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-08-13", "doble_articulado": false, "id_norma": "137314", "numero_fuente": "9769", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-08-16", "vigencias": [{"desde": "1910-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-08-16", "fin_