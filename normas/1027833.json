{"html": [{"t": "<div><br><div class=\"p\">Caja de Ahorros para empleados p&#xFA;blicos.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, octubre 8 de 1872</div><br></div>", "i": 9159205}, {"t": "<div><br><div class=\"p\">(288) Vista la nota que precede i lo dictaminado sobre ella por el fiscal de Hacienda, se declara que, por <a href=\"https://www.leychile.cl/Navegar?idNorma=1027697&amp;idParte=0&amp;idVersion=\">lei de 19 de julio de 1868</a>, no corresponden las multas en que se incurre cuando se declara no haber nulidad en las sentencias contra las que se establece recurso a la caja de ahorros de empleados p&#xFA;blicos.</div><br></div>", "i": 9159206}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese y publ&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  ERR&#xC1;ZURIZ.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Ramon Barros Luco </div><br></div>", "i": 9159207}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "288", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-288"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Caja de Ahorros para empleados públicos.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1872-10-08", "doble_articulado": false, "id_norma": "1027833", "numero_fuente": "LIBRO XL, PÁGINA 806", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1872-10-08", "vigencias": [{"desde": "1872-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1872-10-08", "fin_vigencia": ""}, "vigencia