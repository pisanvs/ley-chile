{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 277.- Santiago, 26 de febrero de 1925.- La Junta de Gobierno, de acuerdo con el Consejo de Secretarios de Estado, dicta el siguiente,</div><div class=\"p\">&nbsp; &nbsp; DECRETO-LEI:</div><br></div>", "i": 7123714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Ampl&#xED;anse los beneficios de la lei n&#xFA;mero 4,056, de 8 de setiembre &#xFA;ltimo, a las faenas mar&#xED;timas, sin perjuicio de las facultades que por leyes especiales competan a la autoridad respectiva.</div><div class=\"p\">&nbsp; &nbsp; Rija desde su publicacion en el Diario Oficial. </div></div>", "i": 7123715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes y Decretos del Gobierno.- Emilio Bello C.- C. A. Ward.- Pedro P. Dartnell E.- B. Bahamondes M.</div><br></div>", "i": 7123716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "277", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-277"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONFLICTOS COLECTIVOS TRABAJO", "BENEFICIOS", "FAENAS", "MARITIMAS", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-02-26", "doble_articulado": false, "id_norma": "5930", "numero_fuente": "14117", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-03-03", "vigencias": [{"desde": "1925-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1925-03-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1925-03-03", "fin_v