{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6222184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1493 de 12 de Agosto de 1987, que ratifica la resoluci&#xF3;n exenta No. 1138 de 12 de Mayo de 1981, conforme art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento de Aguas que corresponden a las Parcelas N&#xB0;s. 1 a la 9 y sitios 1 al 6 del Proyecto de Parcelaci&#xF3;n &quot;La Primavera&quot;, conformado por predio expropiado &quot;Hijuela Cuarta en que se dividi&#xF3; el Fundo Los Maitenes&quot;, de la comuna de Pe&#xF1;aflor, Regi&#xF3;n Metropolitana. Los derechos de agua se extraen del R&#xED;o Maipo por el canal Santa Cruz y del Zanj&#xF3;n de La Aguada, por el Canal Larra&#xED;n.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme art. 13 Ley No. 18.377.- </div></div>", "i": 6222185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6222186}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1493 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1493 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-12", "doble_articulado": false, "id_norma": "152126", "numero_fuente": "32847", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-17", "vigencias": [{"desde": "1987-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú