{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Suspension temporal del Estanco del tabaco</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 21 de 1821.</div></div>", "i": 9927203}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  De acuerdo con el Excmo. Senado i accediendo a la solicitud del Tribunal del Consulado, se suspende por t&#xE9;rmino de dos a&#xF1;os el Estanco de tabacos en polvo i rama, quedando libre su venta i la internacion por mar o cordillera, adeudado como &#xFA;nico derecho, un cuarenta por ciento, que deber&#xE1; pagarse en met&#xE1;lico a los cincuenta dias de haber pasado las aduanas.</div><br></div>", "i": 9927204}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, impr&#xED;mase i circ&#xFA;lese.-O&apos;Higgins. Dr. Rodr&#xED;guez.</div></div>", "i": 9927205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Suspension temporal del Estanco del tabaco", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1821-05-21", "doble_articulado": false, "id_norma": "1117667", "numero_fuente": "1821", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1821-05-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1821-05-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1821-05-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1096974", "fecha_ingreso": "2018-06-29", "fecha_version": "1821-05-21", "f