{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6096888}, {"t": "<div><div class=\"p\">Por Decreto M.O.P. No. 339 de 24 de octubre de 1989, se expropiaron los lotes N&#xB0;s. 19 20, 23-a, 24 y 23-b, superficies 1.703 m2., 5.886; m2. 2.243 m2., 1.912 m2. y 2.999 roles de aval&#xFA;os N&#xB0;s. 1290-20, 1290-73, 1290-53, 1281-53, Comuna de Penco, para la obra Ampliaci&#xF3;n y Reposici&#xF3;n Ruta 150, Concepci&#xF3;n-Lirqu&#xE9;n, sector Concepci&#xF3;n-Penco y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Sociedad Comercial Inmobiliaria Cruper Limitada, Rosario Selva Lobos Mu&#xF1;oz y Juan Becerra D&#xED;az, ascendente a las sumas de $ 1.274.236, $ 10.689.983, $ 1.850.924, $ 5.855.619 y 3.205.631, respectivamente. </div></div>", "i": 6096889}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6096890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "339", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-339"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-24", "doble_articulado": false, "id_norma": "94377", "numero_fuente": "33522", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-15", "vigencias": [{"desde": "1989-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_