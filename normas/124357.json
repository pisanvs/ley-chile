{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6130488}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. No. 845, de 25 de junio de 1998, se expropiaron los lotes de terreno No. s.4-B, Canal San Miguel Pal-Pal Bajo Ramal No. 2-A y No. 4, Canal San Pal-Pal Bajo Ramal No. 6, superficies 126 y 1.914 m&#xB2; roles de aval&#xFA;o 160-110 y 160-172, comuna de Pemuco, para la obra Proyecto Laja Diguill&#xED;n, Area de Riego Pemuco y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Myriam Erna Campos Bravo y Guillermo Hugo Leandro Gabriel Estrada Finsterbusch, ascendente a la cantidad de $ 112.506 y $ 751.380, respectivamente.-</div><br></div>", "i": 6130489}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6130490}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "845", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-845"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "PEMUCO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-06-25", "fecha_derogacion": "2000-03-15", "doble_articulado": false, "id_norma": "124357", "numero_fuente": "36165", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-09-15", "vigencias": [{"desde": "2000-03-15", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-09-15", "hasta": "2000-03-14", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2000-03-15", "fin_vigencia": ""}, "vigencias_version_nor