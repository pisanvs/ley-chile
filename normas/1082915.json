{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9642378}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n O N&#xBA;208 de 10 de septiembre de 2015 del Servicio Electoral, se ha ordenado publicar el siguiente Balance Ejercicio 2014 del Partido Progresista.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp; <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/52881.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El d&#xED;a 7 de mayo de 2014 fue publicado en el Diario Oficial el extracto de la escritura p&#xFA;blica de la fusi&#xF3;n por absorci&#xF3;n del Partido Progresista con el Partido Progresista del Norte (ex Partido Liberal), dando origen a una nueva colectividad pol&#xED;tica denominada Partido Progresista. De esta forma, el nuevo partido asumi&#xF3; legalmente los activos y pasivos de los partidos fusionados.</div><div class=\"p\"> </div></div>", "i": 9642379}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  ELIZABETH CABRERA BURGOS</div><div class=\"p\">&nbsp; &nbsp;  Directora (S)</div><div class=\"p\">&nbsp; &nbsp;  Servicio Electoral</div></div>", "i": 9642380}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "208", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-208"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; IdDO 955187"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-09-10", "doble_articulado": false, "id_norma": "1082915", "numero_fuente": "41283", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-10-16", "vigencias": [{"desde": "2015-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2015-10-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2015-10-16", "fecha_version": "2015-10-16", "fecha_actualizacion_texto": "2015-10-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9642378}, {"n": "Artículo", "i": 9642379, "t": 6}, {"n": "Promulgación", "i": 9642380}]}