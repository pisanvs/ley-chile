{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 717, DE 1993 </div></div>", "i": 7162271}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Supremo exento de Educaci&#xF3;n N&#xB0; 717 de 31 de Diciembre de 1993 se ha aprobado a contar del a&#xF1;o escolar 1993, al Liceo Industrial Chileno-Alem&#xE1;n de &#xD1;u&#xF1;oa, de Santiago, un plan de estudio de ense&#xF1;anza media t&#xE9;cnico-profesional, especialidad Mec&#xE1;ncia Industrial.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas del plan de estudio aprobado en el art&#xED;culo anterior.</div><br></div>", "i": 7162272}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 23 de Febrero de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162273}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "717 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-717 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 717, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "LICEO INDUSTRIAL CHILENO ALEMAN", "U OA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-12-31", "doble_articulado": false, "id_norma": "21735", "numero_fuente": "34802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-02-28", "vigencias": [{"desde": "1994-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-02-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-02-28", "fin_vigencia": "", "tipo