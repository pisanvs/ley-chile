{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8322142}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.640, de 06 de Noviembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 302, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Salmones Ant&#xE1;rtica Ltda., actualmente Salmones Ant&#xE1;rtica S.A., R.U.T.</div><div class=\"p\">No. 86.100.500-3, domiciliada en Santiago para incorporar especies salmon&#xED;deas al establecimiento de cultivo ubicado en Chacabuco, en el sentido de sustituir en su numeral 2&#xB0; la expresi&#xF3;n &quot;N&#xB0; 262, de 1987&quot; por &quot;N&#xB0; 231, de 1983&quot;. </div></div>", "i": 8322143}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 06 de Noviembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8322144}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1640", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1640"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-06", "doble_articulado": false, "id_norma": "92650", "numero_fuente": "33531", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-25", "vigencias": [{"desde": "1989-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989