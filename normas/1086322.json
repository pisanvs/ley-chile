{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\"><a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=8656064&amp;idVersion=\">ART&#xCD;CULO 34</a> DE LA <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=0&amp;idVersion=\">LEY SOBRE IMPUESTO A LA RENTA</a></div></div>", "i": 9664766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xBA; 124, del 31 de diciembre de 2015, que establece.</div><div class=\"p\">&nbsp; &nbsp;  Establece obligaci&#xF3;n de llevar libro auxiliar de control del l&#xED;mite de ventas o ingresos de los contribuyentes acogidos a un r&#xE9;gimen de renta presunta, que no est&#xE9;n obligados a llevar libro de compras y ventas y que no califiquen como microempresas.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2015.</div></div>", "i": 9664767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "124 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-124 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ARTÍCULO 34 DE LA LEY SOBRE IMPUESTO A LA RENTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 985349; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-31", "doble_articulado": false, "id_norma": "1086322", "numero_fuente": "41354", "tipo_version": "3", "t