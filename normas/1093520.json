{"html": [{"t": "<div><br><div class=\"p\">ART&#xCD;CULO 38 BIS DE LA LEY SOBRE IMPUESTO A LA RENTA.</div></div>", "i": 9722139}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 74 de 5 de agosto de 2016 que:</div><br><div class=\"p\">&nbsp; &nbsp;  Establece forma y plazo en que las empresas, comunidades o sociedades deben certificar el valor de costo para fines tributarios, a la fecha de t&#xE9;rmino de giro, de los bienes que se adjudiquen sus due&#xF1;os, comuneros, socios o accionistas en la disoluci&#xF3;n o liquidaci&#xF3;n de aquellas.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2016.</div></div>", "i": 9722140}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "74 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-74 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ARTÍCULO 38 BIS DE LA LEY SOBRE IMPUESTO A LA RENTA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1050956; EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-08-05", "doble_articulado": false, "id_norma": "1093520", "numero_fuente": "41531", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-08-11", "vigencias": [{"desde": "2016-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-08-11", "