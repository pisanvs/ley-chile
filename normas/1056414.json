{"html": [{"t": "<div><br><div class=\"p\">DEJA SIN EFECTO CALIDAD DE AGENTE RETENEDOR DEL IVA A AUSTRALIS S.A.</div></div>", "i": 9386463}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La V Direcci&#xF3;n Regional Valpara&#xED;so del Servicio de Impuestos Internos, por resoluci&#xF3;n Ex. N&#xBA; 7.868, de fecha 29 de octubre de 2013, deja sin efecto la calidad de Agente Retenedor del IVA a contar de la fecha de su publicaci&#xF3;n en el Diario Oficial, a la sociedad Australis S.A., RUT N&#xBA; 96.792.010-K, en las ventas de especies hidrobiol&#xF3;gicas que le realicen, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 3.311 del 30.06.2000, de la Direcci&#xF3;n Nacional.- </div><br></div>", "i": 9386464}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Otty Vivanco Jim&#xE9;nez, Directora Regional (S).</div></div>", "i": 9386465}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7868 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-7868 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL VALPARAÍSO"], "titulo_norma": "DEJA SIN EFECTO CALIDAD DE AGENTE RETENEDOR DEL IVA A AUSTRALIS S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-10-29", "doble_articulado": false, "id_norma": "1056414", "numero_fuente": "40709", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-11-18", "vigencias": [{"desde": "2013-11-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-11-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-11-18", "fin_vig