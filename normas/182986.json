{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.088 EXENTA, DE&nbsp; 2001 </div></div>", "i": 6326948}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 1.088, de 22 de febrero de 2001, se ha aprobado al Colegio &apos;&apos;Bradford School&apos;&apos; de la comuna de Vitacura, Santiago, planes y programas especiales de estudio para tercer a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores de la Formaci&#xF3;n Diferenciada que se se&#xF1;alan en la presente resoluci&#xF3;n.</div><br></div>", "i": 6326949}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de marzo de 2001.- Rafael Andaur Troncoso, Jefe Divisi&#xF3;n Educaci&#xF3;n General (S). </div></div>", "i": 6326950}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1088 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1088 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.088 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-22", "doble_articulado": false, "id_norma": "182986", "numero_fuente": "36917", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-20", "vigencias": [{"desde": "2001-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-20", "fin_vigencia": "", "tipo_version": "3"}], "ev