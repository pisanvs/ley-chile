{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6582992}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 505, de fecha 30 de junio de 2006, se expropiaron los lotes de terreno N&#xBA;s. 2, 3, 4, 5 y 6, superficies 4.823, 3.271, 1.304, 771 y 1.373 m&#xB2;, Rol N&#xBA; 3281-7, comuna de Vilc&#xFA;n, IX Regi&#xF3;n, para la obra &quot;Ampliaci&#xF3;n, Reposici&#xF3;n, Pavimentaci&#xF3;n Ruta 5 Sur, Sector Acceso Norte a Temuco, Km. 0,50000 al Km.</div><div class=\"p\">8,66000&quot; y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Sociedad Agr&#xED;cola y Comercial Von Baer y Compa&#xF1;&#xED;a Limitada ascendente a la cantidad de $211.399.863.- para los lotes N&#xBA;s. 2, 3, 4, 5 y 6. </div></div>", "i": 6582993}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6582994}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "505", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-505"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-30", "doble_articulado": false, "id_norma": "253323", "numero_fuente": "38566", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-15", "vigencias": [{"desde": "2006-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p