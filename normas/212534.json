{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6431730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;553, de 30 de mayo de 2003, se dej&#xF3; sin efecto el decreto MOP N&#xBA;1.667 de 30 de septiembre de 2002, en la parte que autorizaba el Convenio de Precio Ad-Refer&#xE9;ndum y fijaba el precio de la indemnizaci&#xF3;n definitiva. Por medio del mismo decreto, se acord&#xF3; con don Miguel Luciano Margas Garetto un nuevo valor de la indemnizaci&#xF3;n ascendente a la cantidad de $53.738.360.</div><br></div>", "i": 6431731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6431732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "553", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-553"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-30", "doble_articulado": false, "id_norma": "212534", "numero_fuente": "37609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-15", "vigencias": [{"desde": "2003-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "CMV", "fecha_ingreso": "2003-07-15", "fecha_version": "2003-07-15", "fecha_actualizacion_texto": "2003-07-15", "tipo_tratado": ""}, "alertas": [], "ale