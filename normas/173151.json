{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCION N&#xBA;29, DE 1998 </div></div>", "i": 6292621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Primera Direcci&#xF3;n Regional Tarapac&#xE1; del SII, por resoluci&#xF3;n Ex. N&#xBA;09, de 4 de julio de 2000 deja sin efecto a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n la resoluci&#xF3;n N&#xBA;Ex. 29, de 13/10/98, que excepcion&#xF3; a Comercial Hern&#xE1;ndez S.A., RUT N&#xBA;93.981.000-5, del cambio parcial de sujeto de derecho del Impuesto al Valor Agregado en las ventas de ganado vivo a contribuyentes que tengan la calidad de retenedor del Impuesto al Valor Agregado. En virtud de lo resuelto el peticionario deja de tener la calidad de retenedor del Impuesto al Valor Agregado en sus operaciones de ganado vivo.-</div><br></div>", "i": 6292622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Julio Echavarr&#xED;a Cornejo, Director Regional. </div></div>", "i": 6292623}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-9"}, {"tipo": "3", "numero": "09", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-09"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "I DIRECCIÓN REGIONAL IQUIQUE"], "titulo_norma": "DEJA SIN EFECTO RESOLUCION Nº29, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-04", "doble_articulado": false, "id_norma": "173151", "numero_fuente": "36719", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-21", "vigencias": [{"desde": "2000-07-21", "hasta": "", "tipo_versi