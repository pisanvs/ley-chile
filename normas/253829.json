{"html": [{"t": "<div><div class=\"p\">AUTORIZA RECEPTOR ELECTRONICO </div></div>", "i": 6584900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;116, de 29 de septiembre, que autoriza a organismo p&#xFA;blico como receptor electr&#xF3;nico. Se autoriza como receptor de documentos tributarios electr&#xF3;nicos, a contar del mes de septiembre de 2006, a organismo p&#xFA;blico RUT 69.070.400-5.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2006. </div></div>", "i": 6584901}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "116 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-116 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA RECEPTOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-29", "doble_articulado": false, "id_norma": "253829", "numero_fuente": "38581", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-10-05", "vigencias": [{"desde": "2006-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-10-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-10-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fec