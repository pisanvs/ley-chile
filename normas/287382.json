{"html": [{"t": "<div><div class=\"p\">INFORMA NOMBRAMIENTO DE TESORERO DEL PARTIDO DEM&#xD3;CRATA CRISTIANO </div></div>", "i": 7435634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Carlos Latorre Carmona, Presidente de la Directiva Central del Partido Dem&#xF3;crata Cristiano y Osvaldo D&#xED;az Dum&#xE9;nez, Secretario del Tribunal Supremo de la colectividad, han informado el nombramiento de don David Enrique Guzm&#xE1;n Silva como Tesorero de la Directiva Central del partido, en reemplazo de don Diego M&#xE9;ndez Amor.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O-N&#xBA; 773 de fecha 30 de enero de 2009.- </div></div>", "i": 7435635}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div><br><br></div>", "i": 7435636}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "773", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-773"}, {"tipo": "3", "numero": "O-773", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-773"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "INFORMA NOMBRAMIENTO DE TESORERO DEL PARTIDO DEMÓCRATA CRISTIANO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-30", "doble_articulado": false, "id_norma": "287382", "numero_fuente": "39290", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-17", "vigencias": [{"desde": "2009-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-02-17", "fin_vi