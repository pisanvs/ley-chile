{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 1.030 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1.030, celebrada el 26 de diciembre de 2002, adopt&#xF3; el siguiente Acuerdo:</div><br><br></div>", "i": 6408085}, {"t": "<div><div class=\"p\">1030-06-021226 - Tasa de inter&#xE9;s para pago diferido de derechos de Aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del Art&#xED;culo 10 de la Ley N&#xBA; 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que expira el 30 de junio de 2003, ser&#xE1; de 6,61% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 6408086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de diciembre de 2002.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6408087}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1030", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1030"}, {"tipo": "5", "numero": "1030-06", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1030-06"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1.030", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-26", "doble_articulado": false, "id_norma": "206203", "numero_fuente": "37445", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-28", "vigencias": [{"desde": "2002-12-28", "hasta": "", "tipo_version": "3", "tipo