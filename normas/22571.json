{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede una subvencion estraordinaria a la Sociedad Protectora de la Infancia de Santiago</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 27 de Julio de 1900.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se concede una subvencion estraordinaria de cincuenta mil pesos a la Sociedad Protectora de la Infancia de Santiago.</div><br></div>", "i": 8274270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- El&#xED;as Fern&#xE1;ndez A.- Rafael Err&#xE1;zuriz Urmeneta.</div><br></div>", "i": 8274271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1339", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1339"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE UNA SUBVENCION ESTRAORDINARIA A LA SOCIEDAD PROTECTORA DE LA INFANCIA DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD PROTECTORA INFANCIA", "SANTIAGO", "SUBVENCION", "EXTRAORDINARIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-07-27", "doble_articulado": false, "id_norma": "22571", "numero_fuente": "6655", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-07-28", "vigencias": [{"desde": "1900-07-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-07-28", "fin_vigencia"