{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6277211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xB0; 2331 de 09 de Noviembre de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Reserva y Sector Expropiado Predio &quot;Fundo Alhu&#xE9;&quot; de la comunal de Curacav&#xED;, Regi&#xF3;n Metropolitana; y Derechos Aprovechamiento Aguas que corresponden a Parcelas N&#xB0;s. 1 a la 21, sitios N&#xB0;s. 1, 2, 5 al 10, y Reserva Cora N&#xB0; 1 del Proyecto de Parcelaci&#xF3;n &quot;Alhu&#xE9;&quot; formado por predio se&#xF1;alado. Los Derechos de Agua se extraen del Estero Puangue y de Pozo Profundo. Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377. </div></div>", "i": 6277212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6277213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2331 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2331 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-09", "doble_articulado": false, "id_norma": "169275", "numero_fuente": "32921", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-16", "vigencias": [{"desde": "1987-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc