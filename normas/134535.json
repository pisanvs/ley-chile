{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,174.- Santiago, 19 de enero de 1899.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a do&#xF1;a Dominga O&apos;Ryan, viuda del sarjento segundo del Rejimiento de Granaderos a Caballo, Juan de Dios Riquelme, una pension vitalicia de diez pesos mensuales, la que percibir&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6162678}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido abien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha </div></div>", "i": 6162679}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1174", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1174"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-19", "doble_articulado": false, "id_norma": "134535", "numero_fuente": "6205", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-19", "vigencias": [{"desde": "1899-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso