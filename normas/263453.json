{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CERTIFICADO</div><br></div>", "i": 7349790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 0,57% anual durante el mes de julio de 2007.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de julio de 2007, fue de 0,66% anual. </div></div>", "i": 7349791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de julio de 2007.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 7349792}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN NÚMERO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-03", "doble_articulado": false, "id_norma": "263453", "numero_fuente": "38832", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-07", "vigencias": [{"desde": "2007-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-08-07", "fin_vigencia": "", "tipo_v