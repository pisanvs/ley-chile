{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7295132}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.587, de 8 de noviembre de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA;132 de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA QUINTERO S.A. para operar la nave &quot;Eversen&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la IV y VII Regiones, sobre los recursos hidrobiol&#xF3;gicos Jurel, Sardina espa&#xF1;ola, Sardina com&#xFA;n, Anchoveta y Caballa, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado por memor&#xE1;ndum de la Divisi&#xF3;n de Desarrollo Pesquero de esta Subsecretar&#xED;a citado en Visto. </div></div>", "i": 7295133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de noviembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7295134}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2587", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2587"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-08", "doble_articulado": false, "id_norma": "204770", "numero_fuente": "37411", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-18", "vigencias": [{"desde": "2002-11-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"in