{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7243756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1.322 de 03 de Agosto de 1988, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 10, 12, 13 y parte de las N&#xB0;s. 11, 14 y 15 y sitios N&#xB0;s. 1, 2, 4, 8 y 10 al 14 del Proyecto de Parcelaci&#xF3;n &quot;San Ram&#xF3;n&quot;, de la comuna de Petorca, Quinta Regi&#xF3;n, formado por predios &quot;Artificio de Pedegua&quot; y &quot;San Ram&#xF3;n de Pedegua, antes Santa Flora&quot;. Los Derechos de Agua se extraen de los Pozos Llano Bajo, Hinojal o Vinagral y El Franc&#xE9;s y de la Vertiente Mar&#xED;n. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.-</div><br></div>", "i": 7243757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 7243758}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1322 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1322 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-03", "doble_articulado": false, "id_norma": "129578", "numero_fuente": "33147", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-16", "vigencias": [{"desde": "1988-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_