{"html": [{"t": "<div><div class=\"p\">DECLARA QUE EL PUEBLO DE LA UNION, DEL DEPARTAMENTO DE ELQUI, SE DENOMINARA, EN LO SUCESIVO, &quot;PISCO ELQUI&quot; </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 8376735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. El pueblo de La Uni&#xF3;n, del departamento de Elqui, se denominar&#xE1; en lo sucesivo, &quot;Pisco Elqui&quot;.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley comenzar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8376736}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintid&#xF3;s de Enero de mil novecientos treinta y seis.- ARTURO ALESSANDRI.- Luis Cabrera. </div></div>", "i": 8376737}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5798", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5798"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DECLARA QUE EL PUEBLO DE LA UNION, DEL DEPARTAMENTO DE ELQUI, SE DENOMINARA, EN LO SUCESIVO, PISCO ELQUI", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1936-01-22", "doble_articulado": false, "id_norma": "269333", "numero_fuente": "17.382", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1936-02-01", "vigencias": [{"desde": "1936-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia