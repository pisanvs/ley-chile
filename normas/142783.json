{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,592.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6189314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Se concede,&nbsp; por gracia, una pensi&#xF3;n anual de cinco mil pesos ($ 5,000) a las hijas solteras del ex - fiscal de la Corte de Apelaciones de Santiago, don Juan Bianchi Tupper, de que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar&quot;.</div><br></div>", "i": 6189315}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diecinueve de enero&nbsp; de mil novecientos veinte.- Juan Luis Sanfuentes.- Jos&#xE9; Bernales. </div></div>", "i": 6189316}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3592", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3592"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1920-01-19", "doble_articulado": false, "id_norma": "142783", "numero_fuente": "12575", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1920-01-21", "vigencias": [{"desde": "1920-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1920-01-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1920-01-21", "fin_vigencia": "", "tipo_version": "3"