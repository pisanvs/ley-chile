{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6378661}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 678, de 4 de abril de 2002, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 638 de 1999, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD DE ANTOFAGASTA, para instalar colectores de captaci&#xF3;n de larvas de la especie Osti&#xF3;n del norte, en el sentido de que podr&#xE1; instalar un m&#xE1;ximo de hasta 5.000 colectores durante los per&#xED;odos de reproducci&#xF3;n y de asentamiento larval del Osti&#xF3;n. </div></div>", "i": 6378662}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de abril de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6378663}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "678", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-678"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-04-04", "fecha_derogacion": "2003-08-02", "doble_articulado": false, "id_norma": "197264", "numero_fuente": "37244", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-04-26", "vigencias": [{"desde": "2003-08-02", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-04-26", "hasta": "2003-08-01", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2003-08-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-0