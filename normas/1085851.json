{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA</div><div class=\"p\">&nbsp;  </div></div>", "i": 9659752}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n de Grandes Contribuyentes del SII. Por resoluci&#xF3;n exenta N&#xBA; 181 de 4 de diciembre de 2015, otorga a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n al contribuyente Walmart Chile S.A., RUT N&#xBA; 76.042.014-K, la calidad de agente retenedor del impuesto a las ventas y servicios en las ventas de carne que efect&#xFA;e, en conformidad con la resoluci&#xF3;n exenta N&#xBA; 3.722 del 28 de julio de 2000 de este Servicio.</div><br></div>", "i": 9659753}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Bernardo Seaman Gonz&#xE1;lez, Director de Grandes Contribuyentes.</div></div>", "i": 9659754}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "181 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-181 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN DE GRANDES CONTRIBUYENTES"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 980882; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-04", "doble_articulado": false, "id_norma": "1085851", "numero_fuente": "41343", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-12-29", "vigencias": [{"desde": "2015-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2