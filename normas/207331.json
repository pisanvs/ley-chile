{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6412648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 26, de 8 de enero de 2003, de esta Subsecretar&#xED;a,&nbsp; autor&#xED;zase a SOCIEDAD PESQUERA VIENTO SUR S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Sunnan IV&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2143-Puerto de Valpara&#xED;so</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CB-2670</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 36,14 m</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; &nbsp;  410,92 t</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp;  265,05 m3</div><div class=\"p\">Potencia motor principal&nbsp; 800,00 Hp.</div><div class=\"p\">Potencia motor auxiliar&nbsp;  225,00 Hp.</div><br></div>", "i": 6412649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6412650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "26", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-26"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-08", "doble_articulado": false, "id_norma": "207331", "numero_fuente": "37477", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-02-05", "vigenc