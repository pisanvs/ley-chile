{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2,272.-&nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase la inversion de la suma de dos millones de pesos ($ 2.000,000) en los trabajos de construccion de edificios p&#xFA;blicos.</div><br></div>", "i": 6170523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, quince de febrero de mil novecientos diez.- Pedro Montt.-&nbsp; Eduardo D&#xE9;lano.</div><br></div>", "i": 6170524}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2272", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2272"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-02-15", "doble_articulado": false, "id_norma": "136991", "numero_fuente": "9618", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-02-16", "vigencias": [{"desde": "1910-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-02-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-02-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-05-28", "fecha_version":