{"html": [{"t": "<div><div class=\"p\">AUTORIZA A LA SOCIEDAD &quot;ENPROMAR Y COMPA&#xD1;IA LIMITADA&quot; PARA DESARROLLAR ACTIVIDADES PESQUERAS </div></div>", "i": 7266455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 292, de 27 de Mayo de 1985, de la</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, se autoriza a la Sociedad</div><div class=\"p\">&quot;Enpromar y Compa&#xF1;&#xED;a Limitada&quot;, domiciliada en Santiago,</div><div class=\"p\">para instalar y operar una planta deshidratadora</div><div class=\"p\">artificial de algas en Camino Cementerio s/n. comuna de Puerto Varas, provincia de Llanquihue, X Regi&#xF3;n, en la que podr&#xE1; utilizar algas de los siguientes g&#xE9;neros: pelillo, chasca, cochayuyo, chasc&#xF3;n y huiro. </div></div>", "i": 7266456}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Mayo de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7266457}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "292", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-292"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A LA SOCIEDAD ENPROMAR Y COMPAÑIA LIMITADA PARA DESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-27", "doble_articulado": false, "id_norma": "163340", "numero_fuente": "32206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-26", "vigencias": [{"desde": "1985-06-26", "hasta": "", "tipo_versi