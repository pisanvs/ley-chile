{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6159858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.885, de 31 de diciembre de 1998, se expropiaron los lotes de terreno N&#xBA;s. 31, 32, 33, 34 y 35, superficies 782, 1.560, 8.230, 235 y 652 M2.</div><div class=\"p\">respectivamente, rol de aval&#xFA;o 22-35, comuna de R&#xED;o Claro, para la obra Camino Los Robles - Huencuecho - Bajo Perqu&#xED;n, Sector Los Robles - Huencuecho y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietario Pablo Scagliotti Barbano, ascendente a la cantidad de $3.497.891.-</div><br></div>", "i": 6159859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras p&#xFA;blicas. </div></div>", "i": 6159860}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2885", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2885"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-31", "doble_articulado": false, "id_norma": "133697", "numero_fuente": "36314", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-15", "vigencias": [{"desde": "1999-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-03-16", "fecha_version": "1999-03-15", "fecha_actualizacion_texto": "1999-03-15", "tipo_tratado": ""},