{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 67, DE 1987</div><br><br><br><br></div>", "i": 6211111}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 67 de 10 de abril de 1987 se ha aprobado programas de Religi&#xF3;n Cat&#xF3;lica para la asignatura de Religi&#xF3;n de la Educaci&#xF3;n General B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se deroga el decreto supremo de Educaci&#xF3;n No. 430 de 1975, que aprob&#xF3; programas de Religi&#xF3;n (Formaci&#xF3;n Cristiana) para la Educaci&#xF3;n General B&#xE1;sica. </div></div>", "i": 6211112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Mayo de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6211113}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "67 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-67 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 67, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-04-10", "fecha_derogacion": "1996-11-18", "doble_articulado": false, "id_norma": "149100", "numero_fuente": "32769", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-05-13", "vigencias": [{"desde": "1996-11-18", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-05-13", "hasta": "1996-11-17", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1996-11-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "19