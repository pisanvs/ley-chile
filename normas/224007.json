{"html": [{"t": "<div><div class=\"p\">FIJA NUEVO HORARIO DE ATENCION EN JUNTAS INSCRIPTORAS </div><br></div>", "i": 6474526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Las Juntas Inscriptoras de todo el pa&#xED;s funcionar&#xE1;n a contar del d&#xED;a lunes 3 de mayo y hasta el cierre del per&#xED;odo extraordinario de inscripciones electorales de 2004, en horario de 9:00 a 13:00 horas.</div><div class=\"p\">&nbsp; &nbsp;  Sin embargo, si al t&#xE9;rmino del horario de funcionamiento se encontraren a&#xFA;n presentes personas que requieran su inscripci&#xF3;n, &#xE9;stas extender&#xE1;n su funcionamiento no m&#xE1;s all&#xE1; de las 20:00 horas, salvo el d&#xED;a s&#xE1;bado en que no exceder&#xE1; de las 14:00 horas. Publicaci&#xF3;n ordenada por resoluci&#xF3;n O N&#xBA; 671 del 12 de abril de 2004.</div><br></div>", "i": 6474527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de abril de 2004.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 6474528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "671", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-671"}, {"tipo": "3", "numero": "O-671", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-671"}], "organismos": ["MUNICIPALIDAD DE COIHUECO"], "titulo_norma": "FIJA NUEVO HORARIO DE ATENCION EN JUNTAS INSCRIPTORAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-12", "doble_articulado": false, "id_norma": "224007", "numero_fuente": "37838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-17", "vigencias": [{"desde": "2004-04-17", "hasta": "", "