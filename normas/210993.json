{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 328 EXENTO, DE 2003</div><br><br></div>", "i": 6426127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;328 de fecha 14 de mayo de 2003, de Educaci&#xF3;n, se rectifica, en el sentido que se&#xF1;ala, el decreto exento de Educaci&#xF3;n N&#xBA;165 de 20 de marzo de 2003 que autoriza a la Universidad de Puerto Varas para impartir la carrera de Ingenier&#xED;a Civil de Industrias (jornada diurna).</div><br><div class=\"p\">Donde dice:</div><div class=\"p\">T&#xED;tulo Profesional: Ingeniero Civil de Industrial </div><div class=\"p\">Debe decir:</div><div class=\"p\">T&#xED;tulo Profesional: Ingeniero Civil de Industrias.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6426128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de junio de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6426129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "328 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-328 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 328 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-14", "doble_articulado": false, "id_norma": "210993", "numero_fuente": "37578", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-07", "vigencias": [{"desde": "2003-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-07", "fin_vig