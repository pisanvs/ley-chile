{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Deroga los n&#xFA;mero 7 y 8 del art&#xED;culo 4.o de la ley 4,043, de 13 de Septiembre de 1924.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5959100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Der&#xF3;ganse los n&#xFA;meros 7.o y 8.o del art&#xED;culo 4.o de la ley n&#xFA;mero 4,043, de 13 de Septiembre de 1924.</div><div class=\"p\">&nbsp; &nbsp; La presente ley comenzar&#xE1; a regir, desde la fecha de su promulgaci&#xF3;n.</div><br></div>", "i": 5959101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, once de Febrero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Bartolom&#xE9; Blanche E. </div></div>", "i": 5959102}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4305", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4305"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Deroga los número 7 y 8 del artículo 4.o de la ley;4,043, de 13 de Septiembre de 1924.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FABRICAS Y MAESTRANZAS DEL EJERCITO", "CONSEJO", "ATRIBUCIONES", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-11", "doble_articulado": false, "id_norma": "24645", "numero_fuente": "15004", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-20", "vigencias": [{"desde": "1928-02-20", "hasta": "", "tipo_ver