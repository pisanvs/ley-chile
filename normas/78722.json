{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309239}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 479, de 29 de Mayo de 1992, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, cad&#xFA;case en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b), del DS 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, la Resoluci&#xF3;n No. 57, de 1984, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a EMPRESA PESQUERA ZONA CENTRAL LIMITADA, R.U.T. No.</div><div class=\"p\">88.844.500-5, domiciliada en Santiago, para realizar actividades pesqueras con la nave &quot;Mar&#xED;a Luisa&quot;. </div></div>", "i": 8309240}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 29 de Mayo de 1992. Jorge Marshall Rivera, Subsecretario de Pesca Subrogante.</div><br></div>", "i": 8309241}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "479", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-479"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-05-29", "doble_articulado": false, "id_norma": "78722", "numero_fuente": "34287", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-06-09", "vigencias": [{"desde": "1992-06-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-06-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-06-09", "fin_vigencia": "", "ti