{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 11, DE 1995</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 21.- Santiago, 13 de Febrero de 1995.- Vistos: Lo dispuesto en el Art. 4&#xB0; del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; R e s u e l v o:</div><br></div>", "i": 7194091}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Modif&#xED;case la Resoluci&#xF3;n N&#xB0; 11 de 20 de enero de 1995, que designa ministros de fe, en lo relativo a la IX Regi&#xF3;n, en orden a rectificar el nombre del se&#xF1;or Hern&#xE1;n Fuentes Hern&#xE1;ndez y que debe decir Hern&#xE1;n Fuentes Fern&#xE1;ndez.</div><br></div>", "i": 7194092}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Alfonso Jasmen Correa, Director Nacional (S).</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Encargado Oficina de Partes.</div><br></div>", "i": 7194093}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "21", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-21"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCION N° 11, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTRO FE", "INSTITUTO DESARROLLO AGROPECUARIO", "MODIFICACION", "NOVENA REGION", "HERNAN FUENTES FERNANDEZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-13", "doble_articulado": false, "id_norma": "32222", "numero_fuente": "35114", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-10", "vigencias": [{"desde": "1995-0