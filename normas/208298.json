{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 51 EXENTO, DE 2003</div><br><br><br><br></div>", "i": 6416777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 51, de fecha 23 de enero de 2003, de Educaci&#xF3;n, se autoriza al Instituto Profesional Andali&#xE9;n la creaci&#xF3;n de la Sede de Curacaut&#xED;n.</div><br><div class=\"p\">&nbsp; &nbsp;  Asimismo, se autoriza para impartir en dicha sede la carrera de Relaciones P&#xFA;blicas conducente al T&#xED;tulo Profesional de Relacionador P&#xFA;blico.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6416778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de febrero de 2003.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6416779}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "51 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-51 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 51 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-01-23", "fecha_derogacion": "2004-12-16", "doble_articulado": false, "id_norma": "208298", "numero_fuente": "37504", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-03-08", "vigencias": [{"desde": "2004-12-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-03-08", "hasta": "2004-12-15", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2004-12-16", "fin_vigencia": ""}, "