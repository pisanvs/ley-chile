{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISOR DE BOLETAS ELECTR&#xD3;NICAS </div></div>", "i": 7354218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;109 de 13 de septiembre de 2007, que autoriza a contribuyente como emisor de boletas electr&#xF3;nicas.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boletas electr&#xF3;nicas a contribuyente RUT 96.936.470-0 a contar del mes de septiembre de 2007.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2007. </div></div>", "i": 7354219}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "109 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-109 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-09-13", "doble_articulado": false, "id_norma": "264972", "numero_fuente": "38868", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-22", "vigencias": [{"desde": "2007-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-09-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],