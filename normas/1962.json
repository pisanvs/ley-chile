{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CIRCULAR N&#xB0; 61 QUE ESTABLECE PROCEDIMIENTOS OPERATIVOS QUE SE&#xD1;ALA </div></div>", "i": 9031520}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El d&#xED;a 18 de Octubre de 1996 se emiti&#xF3; la Circular N&#xB0; 61, que establece procedimientos operativos a Notar&#xED;as y Conservadores de Bienes Ra&#xED;ces, para el traspaso de informaci&#xF3;n al Servicio de Impuestos Internos sobre transferencia de Bienes Ra&#xED;ces.</div><div class=\"p\">&nbsp; &nbsp; El texto &#xED;ntegro de esta Circular se publicar&#xE1; en el Bolet&#xED;n del Servicio de Impuestos Internos correspondiente al mes de Noviembre.</div><br></div>", "i": 9031521}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "61", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "CIR-61"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CIRCULAR N° 61 QUE ESTABLECE PROCEDIMIENTOS\nOPERATIVOS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROCEDIMIENTOS OPERATIVOS", "SERVICIO DE IMPUESTOS INTERNOS", "NOTARIAS", "CONSERVADOR BIENES RAICES", "TRANSFERENCIA", "DERECHO PROPIEDAD", "BIEN INMUEBLE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-10-18", "doble_articulado": false, "id_norma": "1962", "numero_fuente": "35602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-10-29", "vigencias": [{"desde": "1996-10-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-10-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-10-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p