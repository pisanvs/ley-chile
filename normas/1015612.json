{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.668 EXENTA, DE 2010</div></div>", "i": 8948483}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.668 de fecha 21 de junio del 2010, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; complementariamente a la empresa peruana &quot;Transportes Cruz del Sur S.A.C.&quot;, para efectuar servicio de transporte terrestre internacional de pasajeros entre Per&#xFA; y Chile y viceversa, atendiendo el servicio Lima (Per&#xFA;) / Santiago (Chile), utilizando los pasos fronterizos Concordia con Dos (2) frecuencias semanales, de Ida y Vuelta.-</div></div>", "i": 8948484}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Enrique L. Arce Klein, Unidad de Permisos Internacionales Subsecretaria de Transportes.</div><br></div>", "i": 8948485}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1668 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1668 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.668 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-06-21", "doble_articulado": false, "id_norma": "1015612", "numero_fuente": "39716", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-22", "vigencias": [{"desde": "2010-07-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20