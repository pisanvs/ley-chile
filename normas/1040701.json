{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.490 EXENTA, DE 29 DE MAYO DE 2012</div></div>", "i": 9262811}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta que se indica, del Ministerio de Educaci&#xF3;n, se elimina del Libro de Registro de Centros de Formaci&#xF3;n T&#xE9;cnica en que se encuentra inscrito el Centro de Formaci&#xF3;n T&#xE9;cnica Pitag&#xF3;rico (en formaci&#xF3;n), con el N&#xBA; 379 de fecha 30 de junio de 2010, organizado por la Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica Pitag&#xF3;rico Limitada o CFT Pitag&#xF3;rico Ltda., ubicado en camino a Talagante, paradero 1, lote 3, Isla de Maipo, de la ciudad de Santiago.- </div></div>", "i": 9262812}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9262813}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3490 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3490 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.490 EXENTA, DE 29 DE MAYO DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-29", "doble_articulado": false, "id_norma": "1040701", "numero_fuente": "40277", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-02", "vigencias": [{"desde": "2012-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-06-02", "fin_vigencia": "", "tipo_version": "3"}], "event