{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 8.905 EXENTA, DE 1999 </div></div>", "i": 6196815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 8.905 de 22 de septiembre de 1999, se ha aprobado al Colegio &apos;&apos;Isabel La Cat&#xF3;lica&apos;&apos;, comuna de &#xD1;u&#xF1;oa, de Santiago, un plan especial de estudio para segundo a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000. Adem&#xE1;s, se aprueban programas de estudio para segundo a&#xF1;o de ense&#xF1;anza media de los subsectores que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 6196816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de octubre de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6196817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8905 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8905 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 8.905 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-22", "doble_articulado": false, "id_norma": "145238", "numero_fuente": "36487", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-13", "vigencias": [{"desde": "1999-10-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-10-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-10-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient