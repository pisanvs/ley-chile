{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9499104}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.153, de 14 de agosto de 2014, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la <a href=\"https://www.leychile.cl/Navegar?idNorma=222744&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 570 de 2004</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a CORPESCA S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Eperva 49&quot;, respecto del recurso hidrobiol&#xF3;gico Jibia, en las &#xE1;reas mar&#xED;timas comprendidas entre la XV a II regiones, respectivamente, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 9499105}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de agosto de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9499106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2153 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2153 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-08-14", "doble_articulado": false, "id_norma": "1065667", "numero_fuente": "40938", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-08-21", "vigencias": [{"desde": "2014-08-21", "hasta": "", "tipo_version": "3", "tipo_versio