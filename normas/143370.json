{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6191110}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 28 de 14 de Enero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Sally Raddatz Hoflich para efectuar el servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros en la L&#xED;nea No. 2 de Puerto Montt, cuyo trazado fue autorizado por resoluci&#xF3;n No. 100 de 25 de mayo de 1982 y modificado por resoluci&#xF3;n No. 126 de 05 de julio de 1982, de esta Secretar&#xED;a Regional.- </div></div>", "i": 6191111}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6191112}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "28 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-28 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-14", "doble_articulado": false, "id_norma": "143370", "numero_fuente": "32683", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-28", "vigencias": [{"desde": "1987-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-01-28", "fin_vigencia": "", "tipo_v