{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Casa de Orates de Santiago Lei n&#xFA;m. 1,294.- Santiago, a 23 de Diciembre de 1899.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br></div>", "i": 8274241}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que pueda invertir hasta la suma de $ 42,815.31 en construir cuatro nuevas salas en la Casa de Orates de Santiago.</div><br><br></div>", "i": 8274242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- El&#xED;as Fern&#xE1;ndez A.</div><br></div>", "i": 8274243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1294", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1294"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CASA DE ORATES DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CASA ORATES SANTIAGO", "AMPLIACION", "FONDOS", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-23", "doble_articulado": false, "id_norma": "22536", "numero_fuente": "6480", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-12-23", "vigencias": [{"desde": "1899-12-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-12-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-12-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos