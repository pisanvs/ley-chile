{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,743.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios que don Eduardo de la Barra prest&#xF3; al pais, se concede a su viuda do&#xF1;a Lupercia Lastarria de la Barra i a su hija soltera do&#xF1;a Juana de la Barra una pension anual de dos mil pesos ($ 2,000), de que gozar&#xE1;n en conformidad a la lei de montep&#xED;o militar.</div><br></div>", "i": 6165075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, 10 de agosto de 1905.- JERMAN RIESCO.- Antonio Huneeus.</div><br></div>", "i": 6165076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1743", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1743"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-08-10", "doble_articulado": false, "id_norma": "135329", "numero_fuente": "8283", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-08-14", "vigencias": [{"desde": "1905-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-08-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1905-08-14", "fin_vigencia": "", "tipo