{"html": [{"t": "<div><div class=\"p\">&#xFEFF;&nbsp; &nbsp;  Tr&#xE1;nsito de europeos</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 6 de 1813.</div></div>", "i": 10195929}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha determinado que inmediatamente haga US. saber a los Guardas de la Cordillera, impidan absolutamente el tr&#xE1;nsito de todo europeo a las provincias de este Reino, bajo las mas graves penas si se les notare falta u omision en tan importante encargo. Para que tenga efecto lo mandado se le participa a Ud. para que en el dia haga saber a dichos Guardas la &#xF3;rden prevenida.-</div></div>", "i": 10195930}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Juan Jos&#xE9; Carrera. - Francisco Antonio P&#xE9;rez. - Jos&#xE9; Miguel Infante. - Se&#xF1;or Administrador de la Aduana.</div></div>", "i": 10195931}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "S/N", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "Ordenanza-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Tránsito de europeos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1813-04-06", "doble_articulado": false, "id_norma": "1154233", "numero_fuente": "1813", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1813-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1813-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1813-04-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ingreso": "2021-01-25", "fe