{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6591418}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;654, de fecha 29 de septiembre del 2006, se expropi&#xF3; el lote de terreno N&#xBA;4 superficie 1.669 m&#xB2;, Rol N&#xBA;248-22, comuna de Salamanca, IV Regi&#xF3;n, para la obra &quot;Sistema Regad&#xED;o Valle del Choapa&quot;, Obra: &quot;Descarga de Emergencia Nocuy, Canal Alimentador Embalse Corrales&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Augusto del Carmen Leiva Ossand&#xF3;n, ascendente a la cantidad de $786.366.- para el lote N&#xBA;4.</div><br></div>", "i": 6591419}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6591420}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "654 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-654 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-29", "doble_articulado": false, "id_norma": "255726", "numero_fuente": "38628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-01", "vigencias": [{"desde": "2006-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-12-01", "fecha_version": "2006-12-01", "fecha_actualizacion_te