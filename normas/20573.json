{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0;181, DE 1993 </div></div>", "i": 8596411}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0;181 de fecha 21 de abril de</div><div class=\"p\">1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el</div><div class=\"p\">art&#xED;culo &#xFA;nico del Decreto Exento de Educaci&#xF3;n N&#xB0;170 de 1982 correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Academia Universo, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;: Autor&#xED;zase el funcionamiento del Centro de Formaci&#xF3;n T&#xE9;cnica que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala, cuyo fin es la docencia a nivel t&#xE9;cnico para egresados de ense&#xF1;anza media:</div><div class=\"p\">&nbsp; &nbsp; Nombre de la Instituci&#xF3;n: Centro de Formaci&#xF3;n T&#xE9;cnica Academia Universo.</div><div class=\"p\">&nbsp; &nbsp; Domicilio: Santiago.</div><div class=\"p\">&nbsp; &nbsp; Organizador: Sociedad Academia Universo Limitada.&quot;.</div><br></div>", "i": 8596412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 8596413}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "181", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-181"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°181, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA ACADEMIA UNIVERSO", "MODIFICACION", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-04-21", "doble_articulado