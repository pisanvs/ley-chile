{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6531608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 536 de fecha 31 de mayo del 2005, se expropi&#xF3; el lote de terreno N&#xBA; 153, superficie 1.661 m2, rol N&#xBA; 238-103, comuna de Tolt&#xE9;n, IX Regi&#xF3;n para la obra &quot;Camino Ruta S-790, sector Nueva Tolt&#xE9;n - L&#xED;mite Regional (Queule), Tramo Km. 87,50000 a Km. 103,33500, correspondiente al Sub-Tramo III, Km.</div><div class=\"p\">87,50000 a Km. 92,33000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Josefa Neculm&#xE1;n Collilef, ascendente a la cantidad de $863.668.- para el lote N&#xBA; 153.</div><br></div>", "i": 6531609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6531610}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "536 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-536 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-31", "doble_articulado": false, "id_norma": "239753", "numero_fuente": "38199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-01", "vigencias": [{"desde": "2005-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "200