{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 571, de 18 de Mayo de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por PESQUERA LOS FIORDOS LTDA., para un sector ubicado en Puntilla Tabla, localidad de Puerto Cisnes, comuna de Cisnes, Provincia de Ays&#xE9;n, XI Regi&#xF3;n, por no dar cumplimiento el respectivo proyecto t&#xE9;cnico al art&#xED;culo 87&#xB0; de la Ley General de Pesca y Acuicultura.</div><br><br></div>", "i": 8293159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de Mayo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293160}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "571", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-571"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA LOS FIORDOS LTDA", "DENEGACION", "CONCESION ACUICULTURA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-05-18", "fecha_derogacion": "1995-07-19", "doble_articulado": false, "id_norma": "35123", "numero_fuente": "35178", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1995-05-27", "vigencias": [{"desde": "1995-07-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1995-05-27", "hasta": "1995-07-18", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia":