{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6340953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 757, de fecha 30 de abril de 2001, se expropiaron los lotes de terreno N&#xBA;s 23 y 25, superficies 510,52 M2 y 336,26 M2, respectivamente, rol de aval&#xFA;o 385-19, comuna de Pitrufqu&#xE9;n, para la obra &apos;&apos;Dise&#xF1;o Definitivo Regad&#xED;o Faja Maisan, Expropiaciones Red Primaria 5/5, Derivado Mahuidanche, Sector Km.</div><div class=\"p\">7.790,94 al 15.096,56&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Eduardo Mauricio Simi&#xE1;n y Otra, ascendente a la cantidad de $3.030.753.-. </div></div>", "i": 6340954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6340955}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "757", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-757"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-30", "doble_articulado": false, "id_norma": "187177", "numero_fuente": "37001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-03", "vigencias": [{"desde": "2001-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-07-03", "fecha_version": "2001-07-0