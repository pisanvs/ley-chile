{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6095105}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 623, de 28 de junio de 1989, de SERVIU Metroplitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2186 de 1978, inmueble ubicado en calle Ricardo Santa Cruz No. 641, presunto rol aval&#xFA;os No. 593-15, comuna Santiago, aparentemente dominio de don Sergio Acevedo Campos. Comisi&#xF3;n integrada por peritos Sres. Gabriel Urrutia Benavente y Mario Vergara Navarrete, arquitectos y Walter Soto Silva, ingeniero civil, seg&#xFA;n informe de 31 de enero de 1989 fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 2.729.250.- pagadera al contado.-</div><br></div>", "i": 6095106}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6095107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "623", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-623"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-06-28", "doble_articulado": false, "id_norma": "93719", "numero_fuente": "33437", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-01", "vigencias": [{"desde": "1989-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1998-03-04", "fecha_version": "1989-08-01", "fecha_actualizacion_texto": "1989-08-01