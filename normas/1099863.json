{"html": [{"t": "<div><br><div class=\"p\">CUMPLIMIENTO OBLIGACI&#xD3;N ART&#xCD;CULO 75 DEL C&#xD3;DIGO TRIBUTARIO</div></div>", "i": 9767189}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 16, del 31 de enero de 2017</div><br><div class=\"p\">&nbsp; &nbsp;  Establece procedimiento a que deber&#xE1;n ajustarse los contribuyentes para acreditar el pago del tributo, cuando corresponda, ante los Ministros de Fe que se indican.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, se incluir&#xE1; en el Bolet&#xED;n del SII correspondiente al mes de enero de 2017.</div></div>", "i": 9767190}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-16 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CUMPLIMIENTO OBLIGACIÓN ARTÍCULO 75 DEL CÓDIGO TRIBUTARIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1178264, EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-01-31", "doble_articulado": false, "id_norma": "1099863", "numero_fuente": "41676", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-02-04", "vigencias": [{"desde": "2017-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-02-04", "fin_vigencia": "",