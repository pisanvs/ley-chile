{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6229626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 40, de fecha 02.06.86, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XI Regi&#xF3;n, se autoriza a don Jos&#xE9; Chodil Maripillan para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 1 &quot;Circunvalaci&#xF3;n&quot; cuyo trazado que a continuaci&#xF3;n se indica fue autorizado por Resoluci&#xF3;n N&#xB0; 12 de fecha 21.06.84, de esta Secretar&#xED;a Regional.</div><div class=\"p\">&nbsp; &nbsp;  Ida y Regreso: A. Prat - Simpson - Victoria - Baquedano - General Parra - Magallanes - Bilbao. </div></div>", "i": 6229627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Coyhaique, 02 de Junio de 1986.- Ra&#xFA;l Castillo Ceardi, Secretario Regional Ministerial de Transportes y Telecomunicaciones XI Regi&#xF3;n.</div><br></div>", "i": 6229628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "40 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-40 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XI REGIÓN DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-02", "doble_articulado": false, "id_norma": "154650", "numero_fuente": "32501", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-20", "vigencias": [{"desde": "1986-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s