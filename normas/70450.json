{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 410, de 26 de marzo de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase hasta el 31 de marzo de 1997, el plazo para permanecer sin efectuar operaciones pesqueras a SOCIEDAD INDUSTRIAL PESQUERA MC HUGH Y COMPA&#xD1;IA LIMITADA, con la nave &quot;Timonel 8&quot;, autorizada por Resoluci&#xF3;n N&#xBA; 648, de 1987, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor. </div></div>", "i": 8302274}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de marzo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302275}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "410", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-410"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMPLIACION", "PLAZO", "PESCA", "SOCIEDAD INDUSTRIAL PESQUERA MC HUGH Y COMPA IA LIMITADA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-03-10", "fecha_derogacion": "2002-01-17", "doble_articulado": false, "id_norma": "70450", "numero_fuente": "35735", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-04-08", "vigencias": [{"desde": "2002-01-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-04-08", "hasta": "2002-01-16", "tipo_version": "0", "tipo_version_s": "Texto Original"}]