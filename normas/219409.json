{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION&nbsp; N&#xB0; 1103 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 1103, celebrada el 23 de diciembre de 2003, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6455900}, {"t": "<div><div class=\"p\">1103-02-031223 - Modifica Anexo del Cap&#xED;tulo I del Compendio de Normas de Cambios Internacionales.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el Anexo del Cap&#xED;tulo I del Compendio de Normas de Cambios Internacionales, reemplazando la letra a) por la siguiente:</div><br><div class=\"p\">&quot;a)&nbsp; El valor de la CRM antes indicado se corregir&#xE1;, diariamente, en 0,008077% entre el 10 de enero del 2004 y el 9 de enero del 2005, ambas fechas incluidas&quot;.</div><br></div>", "i": 6455901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de diciembre de 2003.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6455902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1103", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1103"}, {"tipo": "5", "numero": "1102-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1102-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N° 1103", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-23", "doble_articulado": false, "id_norma": "219409", "numero_fuente": "37746", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-29", "vigencias": [{"desde": "2003-12-29", "hasta"