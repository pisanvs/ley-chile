{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,168.- Santiago, 9 de enero de 1899.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se considera por gracia, para los efectos de la lei de 2 de febrero de 1892, que el teniente de Ej&#xE9;rcito, don Alberto Phillips Huneeus, fu&#xE9; herido en el asalto de Vi&#xF1;a del mar el 23 de agosto de 1891, estando en posesion de ese empleo, i que, en consecuencia, debe percibir la pensi&#xF3;n correspondiente a capitan de Ej&#xE9;rcito. </div></div>", "i": 6162672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 6162673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1168", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1168"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-09", "doble_articulado": false, "id_norma": "134533", "numero_fuente": "6196", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-09", "vigencias": [{"desde": "1899-01-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-01-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-01-09", "fin_vigencia": "", "tipo_version": "3"}]