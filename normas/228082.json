{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6489041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.731, de 30 de junio de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a EMILIO ALFREDO TAPIA BONILLA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Coquimbo N&#xBA; 181, Poblaci&#xF3;n V&#xED;ctor Domingo Silva, Tongoy, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-enfriado, Fresco-refrigerado, Congelado, Alga Seca y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6489042}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6489043}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1731 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1731 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-30", "doble_articulado": false, "id_norma": "228082", "numero_fuente": "37919", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-26", "vigencias": [{"desde": "2004-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe