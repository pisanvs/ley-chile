{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION </div></div>", "i": 7194401}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 42 de 24 de junio de 1993, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se adjudic&#xF3; a don Alejandro Osvaldo Fuentes Aichele, la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la publicaci&#xF3;n del presente extracto un establecimiento ubicado en calle Lautaro esquina Camino a Lago Ranco, Ruta T-85, Rol de Propiedad 501 - 5, de la comuna de R&#xED;o Bueno, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.- </div></div>", "i": 7194402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Arturo Hern&#xE1;ndez Orellana, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 7194403}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "42", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-42"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "VEHICULOS MOTORIZADOS", "ALEJANDRO OSVALDO FUENTES AICHELE", "RIO BUENO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-24", "doble_articulado": false, "id_norma": "32530", "numero_fuente": "34689", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-13"