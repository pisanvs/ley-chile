{"html": [{"t": "<div><div class=\"p\">FIJA CRITERIOS GENERALES QUE INDICA</div></div>", "i": 10380414}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 106, de fecha 17 de noviembre de 2022, que Fija criterios generales para aceptar las bases de acuerdo para conciliar y avenir, conforme con lo dispuesto en los art&#xED;culos <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=8573475&amp;idVersion=\">132</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=9843193&amp;idVersion=\">132 bis</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=10104243&amp;idVersion=\">132 ter</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=&amp;idVersion=\">C&#xF3;digo Tributario</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n exenta est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).- </div><br></div>", "i": 10380415}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Andr&#xE9;s Frigolett C&#xF3;rdova, Director.</div><br></div>", "i": 10380416}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "106 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-106 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "FIJA CRITERIOS GENERALES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2219935", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-11-17", "doble_articulado": false, "id_norma": "1184607", "numero_fuente": "43407", "t