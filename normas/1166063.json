{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.402 EXENTA, DE 2021, DICTADA POR EL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES</div></div>", "i": 10274258}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.402, de 23 de septiembre de 2021, del Ministerio de Transportes y Telecomunicaciones, se aprob&#xF3; la solicitud que indica y se modific&#xF3; la <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1133028\">resoluci&#xF3;n exenta N&#xBA; 1.771, de 2019, del Ministerio de Transportes y Telecomunicaciones</a>, que establece condiciones espec&#xED;ficas de operaci&#xF3;n y de utilizaci&#xF3;n de v&#xED;as para servicios de transporte p&#xFA;blico de pasajeros de la Unidad de Negocio N&#xBA; 4. Texto &#xED;ntegro de la resoluci&#xF3;n exenta se encuentra en la p&#xE1;gina web www.dtpm.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10274259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gloria Hutt Hesse, Ministra de Transportes y Telecomunicaciones.</div><div class=\"p\"> </div><br></div>", "i": 10274260}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3402 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3402 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.402 EXENTA, DE 2021, DICTADA POR EL MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2020104", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-23", "doble_articulado": false, "id_norma": "1166063", "numero_fuente": "4