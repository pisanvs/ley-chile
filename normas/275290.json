{"html": [{"t": "<div><div class=\"p\">&#xA0;&nbsp; &nbsp; CONCEDEN PERSONALIDAD JUR&#xCD;DICA</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 2941.- Santiago, 3 de Agosto de 1942.- Vistos estos antecedentes, de acuerdo con lo establecido en el decreto reglamentario N.o 2.736, de 31 de Octubre de 1925, y con lo informado por el Consejo de Defensa Fiscal,</div><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7376652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.o Conc&#xE9;dese personalidad jur&#xED;dica a la corporaci&#xF3;n denominada &quot;Manuel Egidio Ballesteros y Leocadia Barros de Ballesteros&quot;, con domicilio en Santiago, y</div><div class=\"p\">&nbsp; &nbsp;  2.o Apru&#xE9;banse los estatutos por los cuales ha de regirse dicha corporaci&#xF3;n, en los t&#xE9;rminos de que da testimonio la escritura p&#xFA;blica adjunta, otorgada ante el notario p&#xFA;blico de Santiago, don Jos&#xE9; Mar&#xED;a B&#xF3;rquez Andrade, con fecha 13 de Julio de 1942.</div><br></div>", "i": 10028894}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- J.A. RIOS M.- J. Ort&#xFA;zar Rojas.</div></div>", "i": 10028895}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2941", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2941"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDEN PERSONALIDAD JURÍDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1942-08-03", "doble_articulado": false, "id_norma": "275290", "numero_fuente": "19339", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1942-08-21", "vigencias": [{"desde": "1942