{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,596.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de tres millones quinientos mil pesos ($ 3.500,000), oro de dieciocho peniques, en la adquisicion de equipos en Chile i el estranjero, destinado a los Ferrocarriles del Estado. </div></div>", "i": 6172484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintisiete de diciembre de mil novecientos once.- Ramon Barros Luco.- Enrique Za&#xF1;artu P. </div></div>", "i": 6172485}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2596", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2596"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-12-27", "doble_articulado": false, "id_norma": "137579", "numero_fuente": "10173", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-01-08", "vigencias": [{"desde": "1912-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-01-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-01-08", "fin_vigencia": "", "tipo_version": "3"}], "e