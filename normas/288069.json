{"html": [{"t": "<div><div class=\"p\">@@</div></div>", "i": 8624245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 672, de 18 de febrero de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a MARCELO FERNANDO C&#xC1;RDENAS PINTO para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en Notuco s/n, comuna de Chonchi, Chilo&#xE9;, X Regi&#xF3;n, en las l&#xED;neas de proceso Fresco Enfriado, Fresco Refrigerado, Congelado, Ahumado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><br></div>", "i": 8624246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de febrero de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 8624247}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "672 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-672 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-18", "doble_articulado": false, "id_norma": "288069", "numero_fuente": "39312", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-03-14", "vigencias": [{"desde": "2009-03-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-03-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-03-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PBC", "fecha_ingreso": "2009-03-16", "fe