{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6054961}, {"t": "<div><div class=\"p\">Por Decretos M.O.P. N&#xB0;s 57 y 63, de fechas 26 y 27 de febrero de 1992, se expropiaron los lotes N&#xB0;s. 14 y 20, superficies 330 m2. y 804 m2., roles de aval&#xFA;os 1737-21 y 2036-6, ambos de la comuna de La Cisterna, para la obra Avenida Am&#xE9;rico Vespucio, sector Gran Avenida - Ochagav&#xED;a y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Elvira del Carmen Uribe Jorquera y otros y Ana Candia Canales y otros, ascendente a las cantidades de $ 8.408.880.- y $ 12.109.520.-, respectivamente. </div></div>", "i": 6054962}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6054963}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "57", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-57"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-02-26", "doble_articulado": false, "id_norma": "79470", "numero_fuente": "34233", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-04-01", "vigencias": [{"desde": "1992-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMB", "fecha_ingreso": "1997-12-10", "fecha_version": "1992-04-01", "fecha_actualizacion_texto": "1992-04-01", "tipo_tratado": ""}