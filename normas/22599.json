{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Sobre jubilacion de don Mateo L&#xF3;pez Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949014}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia a don Mateo L&#xF3;pez derecho de jubilar, con arreglo a sus a&#xF1;os de servicios i al sueldo que disfrutaba como portero del Ministerio de Hacienda.</div><br></div>", "i": 5949015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 1.&#xB0; de Setiembre de 1900.- ELIAS FERNANDEZ A.- Manuel Salinas.</div><br></div>", "i": 5949016}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1377", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1377"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SOBRE JUBILACION DE DON MATEO LOPEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MATEO LOPEZ", "JUBILACION", "DERECHO POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["LA PRESENTE LEY HA SIDO PUBLICADA EN EL DIARIO OFICIAL CON EL Nº 1477"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-09-01", "doble_articulado": false, "id_norma": "22599", "numero_fuente": "6694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-09-14", "vigencias": [{"desde": "1900-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-09-14",