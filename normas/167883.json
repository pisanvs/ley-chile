{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 1.246, DE 1987 </div></div>", "i": 7269069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.440, de 14 de Diciembre de 1987, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2 de la resoluci&#xF3;n No. 1.246, de 1987, en el sentido de se&#xF1;alar que la peticionaria podr&#xE1; operar en la planta que se autoriza, adem&#xE1;s, la l&#xED;nea de congelado en el procesamiento de los recursos autorizados. </div></div>", "i": 7269070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de Diciembre de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7269071}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1440", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1440"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 1.246, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-14", "doble_articulado": false, "id_norma": "167883", "numero_fuente": "32951", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-22", "vigencias": [{"desde": "1987-12-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "J