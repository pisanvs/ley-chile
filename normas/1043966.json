{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9296554}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;1798, de 30 de agosto de 2012, y de conformidad a lo dispuesto en el art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;7, superficie 197 m2., Rol N&#xBA;2411-19, para la obra &quot;MEJORAMIENTO RUTA 35, LOS LAGOS &#x2013; VALDIVIA, SECTOR ANTILHUE &#x2013; VALDIVIA TRAMO 1&quot;, comuna de Valdivia, Regi&#xF3;n de Los R&#xED;os. La comisi&#xF3;n de peritos integrada por Patricio Fernando Casagrande Ulloa, Sonia Catalina Gallegos Blanch y Norman Calder&#xF3;n Pontiggia, fij&#xF3; el valor de tasaci&#xF3;n con fecha 12 de febrero de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario CLAUDIO H&#xC9;CTOR JAVIER ESPARZA DE LA CRUZ, en la cantidad de $1.620.571.- suma que se pagar&#xE1; al contado. </div></div>", "i": 9296555}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9296556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1798 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1798 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-08-30", "doble_articulado": false, "id_norma": "1043966", "numero_fuente": "40364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-15", "vigencias": [{"desde": "2012-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-15", "fin_vi