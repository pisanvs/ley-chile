{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6124326}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. No. 882, de 30 de junio de 1998, se expropiaron los lotes de terreno No. s. 4, 6, 14 y 17, superficies 156, 377, 119 y 193 m&#xB2;, roles de aval&#xFA;o 6-20, 56-10 y 56-14, comuna de Curic&#xF3;, para la obra Camino Ruta 5 Sur, Sector Acceso Norte a Curic&#xF3;, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Jos&#xE9; Oliva Concha, Mar&#xED;a Avenda&#xF1;o Puebla, Narciso Rojas Flores y Hugo Rivera Rojas, ascendente a las cantidades de $ 15.739.323.- para el lote 4, $ 31.386.450.- para el lote 6, $ 8.261.940.- para el lote 14 y $ 20.052.835.- para el lote 17.-</div><br></div>", "i": 6124327}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6124328}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "882", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-882"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "CURICO", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-30", "doble_articulado": false, "id_norma": "122685", "numero_fuente": "36129", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-01", "vigencias": [{"desde": "1998-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [