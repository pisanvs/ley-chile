{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N N&#xBA; 917 </div><div class=\"p\">917-01-010628 - Tasa de inter&#xE9;s para pago diferido de derechos de Aduana.</div><br><br></div>", "i": 6340830}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del Art. N&#xB0; 10 de la ley N&#xB0; 18.634, publicada en el Diario Oficial del 5 de agosto de 1987, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que expira el 31 de diciembre de 2001, ser&#xE1; de 7,83% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 6340831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de junio de 2001.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6340832}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "917", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-917"}, {"tipo": "5", "numero": "917-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-917-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN Nº 917", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-06-28", "doble_articulado": false, "id_norma": "187136", "numero_fuente": "37000", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-30", "vigencias": [{"desde": "2001-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06