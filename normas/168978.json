{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7269935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 383, de 5 de Abril de 1991 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 30 d&#xED;as a contar de esta fecha, el plazo otorgado en el numeral 4&#xB0; de la Resoluci&#xF3;n No. 182, de 1991, de esta Subsecretar&#xED;a, a don VICTOR SANTIAGO CORREA CACERES, R.U.T. No. 5.587.530-8, domiciliado en Pasaje Isla San Ambrosio No. 026, San Antonio, en virtud de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 7269936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de Abril de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7269937}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "383", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-383"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-04-05", "doble_articulado": false, "id_norma": "168978", "numero_fuente": "33954", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-27", "vigencias": [{"desde": "1991-04-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "in