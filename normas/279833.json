{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7379782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.558, de 30 de septiembre de 2008, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la resoluci&#xF3;n N&#xBA; 1.216, de 2008, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD DE CONCEPCI&#xD3;N para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto &quot;Indicadores de din&#xE1;mica poblacional y din&#xE1;mica de la flota que opera sobre Sardina com&#xFA;n y Anchoveta entre la VII y X Regi&#xF3;n&quot;, en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la presente pesca de investigaci&#xF3;n hasta el d&#xED;a 9 de diciembre de 2008, inclusive.</div><br></div>", "i": 7379783}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de septiembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 7379784}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2558 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2558 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-09-30", "doble_articulado": false, "id_norma": "279833", "numero_fuente": "39190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-10-17", "vigencias": [{"desde": "2008-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-10-17", "fin