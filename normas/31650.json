{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 8923955}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 749, de 27 de Junio de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 6 meses a contar de esta fecha, el plazo otorgado en el numeral 5&#xB0; de la Resoluci&#xF3;n N&#xB0; 675, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don RAUL ESTABAN TORRES JARAMILLO, R.U.T.</div><div class=\"p\">N&#xB0; 10.610.345-3, domiciliado en calle Arauco N&#xB0; 852, Valdivia, para operar un establecimiento de cultivo en canal Caica&#xE9;n, Comuna de Calbuco, Provincia de Llanquihue, X Regi&#xF3;n, en raz&#xF3;n de haberse acreditado la existencia de una fuerza mayor.</div><br></div>", "i": 8923956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 27 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8923957}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "749", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-749"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RAUL ESTABAN TORRES JARAMILLO", "PESCA", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-27", "doble_articulado": false, "id_norma": "31650", "numero_fuente": "34024", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-23", "vigencias": [{"desde": "1991-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_