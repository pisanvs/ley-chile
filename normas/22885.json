{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la inversion de 300 000 pesos en combatir las enfermedades infecciosas.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1735.- Santiago, a 13 de Julio de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente:</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de trescientos mil pesos ($ 300 000) en la adopcion de medidas para combatir las emfermedades infecciosas i en los gastos ocasionados con motivo de las mismas.</div><br></div>", "i": 8274650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Luis A. Vergara.</div><br></div>", "i": 8274651}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1735", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1735"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA INVERSION DE 300 000 PESOS EN COMBATIR LAS ENFERMEDADES INFECCIOSAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ENFERMEDADES INFECCIOSAS", "PREVENCION", "FONDOS", "INVERSION PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-07-13", "doble_articulado": false, "id_norma": "22885", "numero_fuente": "8256", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-07-13", "vigencias": [{"desde": "1905-07-13", "hasta": "", "tip