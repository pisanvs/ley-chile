{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 11.348 EXENTA, DE 1999 </div><br></div>", "i": 6218246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 11.348, de 22 de noviembre de 1999, se ha aprobado al Colegio Aconcagua, de Providencia, de Santiago, un plan de estudio para segundo a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000, de acuerdo a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 220, de 1998.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para el subsector Elementos de Computaci&#xF3;n.</div><br></div>", "i": 6218247}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de diciembre de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6218248}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11348 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11348 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 11.348 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-22", "doble_articulado": false, "id_norma": "151021", "numero_fuente": "36560", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-12", "vigencias": [{"desde": "2000-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-12", "fin_vigencia": "", "tipo_version": "3"}], "evento