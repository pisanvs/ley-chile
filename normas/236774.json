{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;15.255 EXENTA, DE 2004 </div></div>", "i": 6520742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;15.255 de 29 de diciembre de 2004, se ha modificado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;1.219 de 2002, que aprob&#xF3; plan y programas especiales de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Instituto O&apos;Higgins (Hermanos Maristas) de Rancagua, en el sentido de sustituir el plan de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media en lo referido a la Formaci&#xF3;n General y Formaci&#xF3;n Diferenciada, por el que se indica en la presente resoluci&#xF3;n, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2005.</div><br></div>", "i": 6520743}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de marzo de 2005.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6520744}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "15255 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-15255 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº15.255 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-29", "doble_articulado": false, "id_norma": "236774", "numero_fuente": "38126", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-04", "vigencias": [{"desde": "2005-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-04-04", "fin_vigencia": ""}, "vigencia