{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 376 EXENTO, DE 1990 </div></div>", "i": 6275648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 376 de 28 de Diciembre de 1990 se han derogado, a contar del a&#xF1;o escolar 1991, los decretos supremos exentos de Educaci&#xF3;n N&#xB0;s. 146, de 1984 y 105, de 1988, que autorizaron planes especiales de estudio al Colegio Ditzel, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  El establecimiento aplicar&#xE1;, a partir de igual fecha, los planes y programas de estudio aprobados por el decreto supremo exento de Educaci&#xF3;n No. 300, de 1981. </div></div>", "i": 6275649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de Abril de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6275650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "376 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-376 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO No. 376 EXENTO, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "168781", "numero_fuente": "33946", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-18", "vigencias": [{"desde": "1991-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"