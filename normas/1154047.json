{"html": [{"t": "<div><div class=\"p\">DECLARA CADUCIDAD DE RESOLUCI&#xD3;N QUE INDICA</div></div>", "i": 10188759}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.879, de 22 de diciembre de 2020, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de la <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=1102696&amp;idParte=&amp;idVersion=2017-05-12\">resoluci&#xF3;n exenta N&#xBA; 2.305, de 2014</a>, que autoriz&#xF3; a Sociedad Mar&#xED;tima y Comercial Albamar Limitada, para continuar desarrollando actividades pesqueras extractivas con la &quot;Elena S&quot; sobre el recurso Albacora o Pez Espada y su fauna acompa&#xF1;ante, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10188760, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de diciembre de 2020.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><br></div>", "i": 10188761}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2879 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2879 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DECLARA CADUCIDAD DE RESOLUCIÓN QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1873037", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-22", "doble_articulado": false, "id_norma": "1154047", "numero_fuente": "42842", "tipo_version": "3",