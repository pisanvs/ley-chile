{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,107.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Catalina Guti&#xE9;rrez v. de Goetz, madre del arquitecto fiscal don Luis Goetz, muerto en actos del servicio, una pension anual de mil quinientos pesos, de que gozar&#xE1; con sus hijas solteras en conformidad a la lei de montepio militar.</div><br></div>", "i": 6168052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, diecinueve de febrero de mil novecientos ocho.- Pedro Montt.- Joaquin Figueroa.</div><br></div>", "i": 6168053}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2107", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2107"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1908-02-19", "doble_articulado": false, "id_norma": "136241", "numero_fuente": "9040", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1908-03-05", "vigencias": [{"desde": "1908-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1908-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1908-03-05", "fin_vigencia": "", "tipo_