{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6312975}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;4.596, de fecha 29 de septiembre de 2000, se expropi&#xF3; el lote de terreno N&#xBA;4, superficie 760 M2, rol de aval&#xFA;o 591-7, comuna de Ovalle, para la obra &apos;&apos;Camino Ruta D-595 Ovalle - Hurtado, Sector Tranque Recoleta-Samo Alto, Km. 9.780,00 a Km.</div><div class=\"p\">31.840,00, Etapa I&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Nelly Ester Fern&#xE1;ndez L&#xF3;pez, ascendente a la cantidad de $422.895.- </div></div>", "i": 6312976}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6312977}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4596", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4596"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-29", "doble_articulado": false, "id_norma": "179208", "numero_fuente": "36838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-12-15", "vigencias": [{"desde": "2000-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "2000-12-19", "fecha_version": "2000-12-15", "fecha_actualizacion_texto": "2000-12-15", "tipo_tratado": ""}, "ale