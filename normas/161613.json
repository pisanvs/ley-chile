{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO N&#xBA; 180, DE 1985, QUE APRUEBA MODIFICACION DE CONVENIO DE TRASPASO DE LA ESCUELA BASICA F-85, COMUNA DE IQUIQUE </div></div>", "i": 6252755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto N&#xBA; 180, de 1985, se aprob&#xF3; una modificaci&#xF3;n al convenio de traspaso de la Escuela B&#xE1;sica F-85 de Iquique, aprobado por decreto N&#xBA; 2.934 de Educaci&#xF3;n, de 1981, que incide en la cl&#xE1;usula sexta, relativa al bien ra&#xED;z.</div><br></div>", "i": 6252756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de Mayo de 1985.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6252757}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "180", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-180"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DECRETO Nº 180, DE 1985, QUE APRUEBA MODIFICACION DE CONVENIO DE TRASPASO DE LA ESCUELA BASICA F-85, COMUNA DE IQUIQUE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-24", "doble_articulado": false, "id_norma": "161613", "numero_fuente": "32185", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-01", "vigencias": [{"desde": "1985-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-03-20", "fecha_version": "1