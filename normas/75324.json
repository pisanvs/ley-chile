{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9048718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 14, de 10 de Enero de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xBA; de la Resoluci&#xF3;n N&#xBA; 8, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA DEL NORTE S.A., R.U.T. N&#xBA; 87.913.200-2 domiciliada en Recinto Portuario s/n&#xBA; Direcci&#xF3;n postal Casilla 25-D, Iquique, para ampliar actividades pesqueras extractivas, en orden a se&#xF1;alar las actuales caracter&#xED;sticas n&#xE1;uticas de dos de las naves autorizadas, las denominadas &quot;Ordinat&quot; (ex - Grotinum) y &quot;Karibib&quot;.</div><br></div>", "i": 9048719}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de Enero de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 9048720}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "PESQUERA DEL NORTE S.A.", "AMPLIACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-01-10", "fecha_derogacion": "2004-11-24", "doble_articulado": false, "id_norma": "75324", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1992-01-27", "vigencias": [{"desde": "2004-11-24", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1992-01-27", "hast