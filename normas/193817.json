{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6366019}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.971, de 30 de noviembre de 2001, se expropiaron los lotes de terreno N&#xBA;s. 24-B1, 24-C1, 24-D, 24-E, 24-F, 24-G, 24-H y 24-I, superficies 213 m2., 2.233 m2., 21 m2., 2.446 m2. 2.565 m2., 297 m2., 3.843 m2. y 478 m2., respectivamente, rol de aval&#xFA;o en tr&#xE1;mite, comuna de Casablanca, para la obra Red Vial Litoral Central, Sector 3: Eje Costero Interior. Subtramo: Rosario - Orrego Abajo Km. 16.840,00 al Km.</div><div class=\"p\">20.673,30 V Regi&#xF3;n, se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Agr&#xED;cola Teutsch Limitada, ascendente a la cantidad de $10.647.197. </div></div>", "i": 6366020}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6366021}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1971", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1971"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "193817", "numero_fuente": "37160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-15", "vigencias": [{"desde": "2002-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr