{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por&nbsp; Resoluci&#xF3;n N&#xBA; 837 de 19 de junio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto las Resoluciones N&#xBA; 1060, de 1991, y N&#xBA; 1469, de 1995, ambas de esta Subsecretar&#xED;a, que autorizaron a CLAUDIO ADRIAN CORNIDE GREZ, para operar un centro de cultivo ubicado en Punta Negro, Comuna de Caldera, Provincia de Copiap&#xF3;, III Regi&#xF3;n, por haberse dejado sin efecto la respectiva Resoluci&#xF3;n de concesi&#xF3;n de acuicultura.</div><br></div>", "i": 8304228}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de junio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304229}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "837", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-837"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "CLAUDIO ADRIAN CORNIDE GREZ", "DEJA SIN EFECTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-19", "doble_articulado": false, "id_norma": "73845", "numero_fuente": "35799", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-25", "vigencias": [{"desde": "1997-06-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-25", "fin_vigencia": "", "t