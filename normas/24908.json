{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a don Emilio Lafoy Despott Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960755}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a don Pablo Emilio Lafoy Despott, una pensi&#xF3;n anual de tres mil seiscientos pesos ($ 3,600), que disfrutar&#xE1; con arreglo a la Ley de Montep&#xED;o Militar.</div><div class=\"p\">&nbsp; &nbsp; Esta ley regir&#xE1; desde el 1.o de Enero de 1930. </div></div>", "i": 5960756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diez de Enero de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Rodolfo Jaramillo B.</div><br></div>", "i": 5960757}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4781", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4781"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION DE GRACIA A DON EMILIO LAFOY DESPOTT", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMILIO LAFOY DESPOTT", "PENSION GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-01-10", "doble_articulado": false, "id_norma": "24908", "numero_fuente": "15572", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-01-14", "vigencias": [{"desde": "1930-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-01-14", "fin_vigencia"