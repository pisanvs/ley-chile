{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7378897}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.420, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n exenta N&#xB0; 2.117 de 2008, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto FIP 2008-01 denominado &quot;Evaluaci&#xF3;n del stock desovante de Anchoveta en la I y II Regiones, a&#xF1;o 2008&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se extender&#xE1; hasta el 14 de septiembre de 2008, inclusive.</div><br></div>", "i": 7378898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de septiembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 7378899}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2420 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2420 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-09-12", "doble_articulado": false, "id_norma": "278416", "numero_fuente": "39172", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-09-26", "vigencias": [{"desde": "2008-09-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-09-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-09-26