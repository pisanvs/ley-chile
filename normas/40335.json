{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; COMPLEMENTA RESOLUCION EXENTA N&#xB0; 894, DE 1987 </div><br></div>", "i": 7202756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n</div><div class=\"p\">Exenta N&#xB0; 3.344 del 29 de octubre de 1996, conforme</div><div class=\"p\">art&#xED;culo 5&#xB0; transitorio C&#xF3;digo Aguas, aclara y complementa Resoluci&#xF3;n Exenta N&#xB0; 894 del 25 de junio de 1987, que determin&#xF3; Derechos de aprovechamiento aguas proporcionales que corresponden a las parcelas N&#xB0;s. 1 a 43 del proyecto de Parcelaci&#xF3;n &quot;Miraflores&quot;, de la comuna de Renca, Regi&#xF3;n Metropolitana, en el sentido de reconocer que al sector no expropiado del predio &quot;Hijuela Chorrillos de Lipangui&quot; le corresponde el derecho de aprovechamiento de aguas sobre los pozos denominados Pozo N&#xB0; 4 y Pozo N&#xB0; 5 de la inscripci&#xF3;n de fojas 33 N&#xB0; 35 del Registro de Propiedad de Aguas del a&#xF1;o 1969, del Conservador de Bienes Ra&#xED;ces de Santiago.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n hecha conforme art&#xED;culo 13 Ley N&#xB0; 18.377.-</div><br></div>", "i": 7202757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 7202758}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3344 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3344 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "COMPLEMENTA RESOLUCION EXENTA N° 894, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO DE APROVECHAMIENTO AGUAS", "PARCELACION", "MIRAFLORES", "RENCA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados":