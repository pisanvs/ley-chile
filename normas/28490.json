{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N&#xB0; 13.678, DE 1959 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8282892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Sustit&#xFA;yese en el art&#xED;culo 3&#xB0; de la ley N&#xB0; 13.678, de 19 de Noviembre de 1959, la frase: &quot;en la construcci&#xF3;n del edificio municipal&quot;, por la siguiente: &quot;en la adquisici&#xF3;n o construcci&#xF3;n de un edificio destinado a la Municipalidad&quot;.</div><br></div>", "i": 8282893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintid&#xF3;s de Junio de mil novecientos sesenta y seis.- EDUARDO FREI MONTALVA.- B. Leighton G.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a U. para su conocimiento.- Dios gue. a U.- Juan Hamilton Depassier, Subsecretario del Interior.</div><br></div>", "i": 8282894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16499", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16499"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY N° 13.678, DE 1959", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 13.678", "FACULTAD", "MUNICIPALIDAD PUNTA ARENAS", "CONTRATACION", "PRESTAMO", "EMPRESTITO", "CONSTRUCCION", "DESTINACION", "BIEN INMUEBLE", "PAGO", "INTERES", "AMORTIZACION", "CREDITO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1966-06-22", "doble_articulado": false,