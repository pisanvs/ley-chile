{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6531629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 543 de fecha 31 de mayo de 2005, se expropi&#xF3; el lote de terreno N&#xBA; 2, superficie 4.774,00 m2, Rol N&#xBA; 2210-347, comuna de Hualaihue X Regi&#xF3;n para la obra &quot;Camino Sin Rol, Sector Puente Cisne N&#xBA; 2, Tramo Km. 1,031 a Km. 1,430&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Juana Luz Soto Ojeda, ascendente a la cantidad de $2.272.266.- para el lote N&#xBA; 2.</div><br></div>", "i": 6531630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6531631}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "543 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-543 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-31", "doble_articulado": false, "id_norma": "239760", "numero_fuente": "38199", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-01", "vigencias": [{"desde": "2005-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2005-07-01", "fecha_version": "2005-07-01", "fecha_actualizacion_texto": "2005-07-01", "tipo_tratado": ""}, "alertas": [], "alerta_global