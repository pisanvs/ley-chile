{"html": [{"t": "<div><br><div class=\"p\">DESAFILIA DEL SISTEMA DE FACTURACI&#xD3;N ELECTR&#xD3;NICA</div><br></div>", "i": 8821799}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 3, de 11 de enero de 2010, que desafilia del sistema de facturaci&#xF3;n electr&#xF3;nica a contribuyentes que se se&#xF1;alan.</div><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase por desafiliados del Sistema de Facturaci&#xF3;n Electr&#xF3;nica a los contribuyentes RUT N&#xBA; 73.432.200-8 y RUT N&#xBA; 12.927.531-6.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2010.</div><br></div>", "i": 8821800}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESAFILIA DEL SISTEMA DE FACTURACIÓN ELECTRÓNICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-01-11", "doble_articulado": false, "id_norma": "1010120", "numero_fuente": "39560", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-01-14", "vigencias": [{"desde": "2010-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-01-14", "fin_vigencia": "", "tip