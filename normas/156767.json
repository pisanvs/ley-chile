{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xB0; 46 de 17 de Enero de 1985, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcional. es que corresponden a Reserva, Derechos de Adquisici&#xF3;n y Sector expropiado de los predios &quot;Resto del Fundo El Progreso&quot;, y &quot;Resto del predio r&#xFA;stico El C&#xF3;ndor&quot; de la comuna de Quillota, V Regi&#xF3;n, y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s. 1 a la 24, sitios N&#xB0;s. 1 al 15 y Reserva CORA N&#xB0; 2, del Proyecto de Parcelaci&#xF3;n &quot;El C&#xF3;ndor&quot;, formado por los predios se&#xF1;alados. Los derechos de agua se extraen del Canal Candelaria y Pozos N&#xB0;s. 1-2 y 3.-Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377.-</div><br></div>", "i": 6236664}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6236665}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "46 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-46 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-17", "doble_articulado": false, "id_norma": "156767", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v