{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 537 EXENTO, DE 1997 </div></div>", "i": 6042201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 537 de fecha 16 de mayo de 1997 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica INACAP Antofagasta, las adecuaciones al plan y programas de estudios de la carrera de An&#xE1;lisis de Sistemas. Modific&#xE1;ndose en consecuencia, el Decreto exento del Ministerio de Educaci&#xF3;n N&#xBA; 698 de 1995, en el sentido de incorporar dichas adecuaciones, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1997.</div><br></div>", "i": 6042202}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de julio de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6042203}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "537 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-537 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 537 EXENTO, DE 1997", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA INACAP ANTOFAGASTA", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-05-16", "fecha_derogacion": "2013-01-01", "doble_articulado": false, "id_norma": "74570", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-08-01", "vigencias": [{"desde": "2013-01-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1997-08-01", "hasta": "2012-12-31", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2013