{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6032426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 99, de 31 de enero de 1997, se expropiaron los lotes de terreno N&#xBA;s. 40, 41 y 43, superficies 1.295 m2., 283 m2. y 138 m2., respectivamente, roles de aval&#xFA;o 512-82, 512-94 y 512-2, comuna de Longav&#xED;, para la obra Camino Ruta 5 Longitudinal Sur, sector San Javier-Parral I, Tramo B, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Carlos Camerati Serafini y Humberto Robles Maureira, ascendente a las cantidades de $21.038.150.-;</div><div class=\"p\">$1.613.100.- y $877.800.-</div><br></div>", "i": 6032427}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6032428}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "99", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-99"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LONGAVI", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-31", "doble_articulado": false, "id_norma": "61700", "numero_fuente": "35717", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-15", "vigencias": [{"desde": "1997-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAV", "fecha_ingreso": "1997