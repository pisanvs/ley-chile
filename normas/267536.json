{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD MOLINERA DE LOS ANDES S.A.</div><br></div>", "i": 6633152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional de la Araucan&#xED;a del SII, por resoluci&#xF3;n Ex N&#xBA; 417 de 4 de diciembre de 2007 otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, al contribuyente Sociedad Molinera de Los Andes S.A., RUT N&#xBA; 76.876.810-2, la calidad de agente retenedor del Impuesto al Valor Agregado en las compras de trigo que efect&#xFA;e, conforme lo establecido en la Res. Ex. N&#xBA; 5281 de 30/11/2000 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial de fecha 04.12.2000.</div><br></div>", "i": 6633153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 6633154}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "417 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-417 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "DIRECCIÓN REGIONAL DE LA ARAUCANÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-04", "doble_articulado": false, "id_norma": "267536", "numero_fuente": "38938", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-17", "vigencias": [{"desde": "2007-12-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p