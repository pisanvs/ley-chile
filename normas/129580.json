{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7243759}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 1.323 de 03 de Agosto de 1988, conforme Art. 5&#xB0; Transitorio Codigo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Reserva y Sector Expropiado Predio &quot;Illalol&#xE9;n&quot;, de la comuna La Ligua, Quinta Regi&#xF3;n; y Derechos Aprovechamiento Aguas que corresponden a parcelas Nos. 1 a la 42, parte de la No. 80 y 81 a la 96, sitios Nos. 1 al 21, 23, 25 al 63, 114 al 135, 137, 138 y 141 y Reservas CORA N&#xB0;s. 1y 2 del Proyecto de Parcelaci&#xF3;n &quot;EI Carmen&quot; formado, entre otros, por predio se&#xF1;alado. Los Derechos de Agua se extraen en forma mec&#xE1;nica de los Pozos La Cruz, La Higuera o La Paloma, Los Loros, lllalol&#xE9;n No. 1 e Illalol&#xE9;n No. 2. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.-</div><br></div>", "i": 7243760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo </div></div>", "i": 7243761}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1323 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1323 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-03", "doble_articulado": false, "id_norma": "129580", "numero_fuente": "33147", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-16", "vigencias": [{"desde": "1988-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única