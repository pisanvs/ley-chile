{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 240 EXENTO, DE 1996 </div></div>", "i": 5943073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 240 de fecha 24 de abril de 1996 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura Cidec, para impartir plan y programas de estudio aprobado para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, a partir del a&#xF1;o 1996:</div><div class=\"p\">&nbsp; &nbsp; Sede N&#xB0; 3 de Ovalle Carrera : Programador Analista</div><div class=\"p\">&nbsp; &nbsp; T&#xED;tulo : T&#xE9;cnico en Programaci&#xF3;n de Computadores (4 semestres)</div><div class=\"p\">&nbsp; &nbsp; T&#xE9;cnico en Programaci&#xF3;n de Computadores y Analista de Sistemas (2 semestres adicionales).</div><br></div>", "i": 5943074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago 24 de mayo de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "240", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-240"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 240 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO INTERAMERICANO EDUCACION CULTURA CIDEC", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "OVALLE", "CUARTA REGION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-24", "doble_articulado": false, "id_norma": "20774", "numero_fuente": "35540", "tipo_version": "3", "tipo_vers