{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8313033}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xB0;. 1.117 de 02 de Septiembre de 1991 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xB0;. 927, de 1989, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a PESQUERA MONTEMAR S.A., RUT N&#xB0;. 96.502.580-4, domiciliada en Santiago, para operar la nave &quot;Kuky&quot;, en el litoral y respecto de los recursos que all&#xED; se indican, en virtud de lo dispuesto en el art&#xED;culo 6&#xB0; del DS N&#xB0;. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8313034}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 02 de Septiembre de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313035}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1117", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1117"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-09-02", "doble_articulado": false, "id_norma": "81920", "numero_fuente": "34079", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-30", "vigencias": [{"desde": "1991-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09-30", "fin_vigencia": "", "tipo_version": "3"}], "event