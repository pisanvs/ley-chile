{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;FRANCISCO ARAYA BENNETT&quot; AL INSTITUTO SUPERIOR DE COMERCIO DE VALPARAISO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5970552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- El Instituto Superior de Comercio de Valpara&#xED;so se denominar&#xE1; &quot;Instituto Superior de Comercio Francisco Araya Bennett.&quot; </div></div>", "i": 5970553}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dieciocho de Octubre de mil novecientos cincuenta y cinco.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Tob&#xED;as Barros O.</div><br></div>", "i": 5970554}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11941", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11941"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DENOMINA FRANCISCO ARAYA BENNETT AL INSTITUTO SUPERIOR DE COMERCIO DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO SUPERIOR COMERCIO VALPARAISO", "FRANCISCO ARAYA BENNETT CAMBIO NOMBRE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1955-10-18", "doble_articulado": false, "id_norma": "26932", "numero_fuente": "23292", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1955-11-08", "vigencias": [{"desde": "1955-11-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":