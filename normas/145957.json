{"html": [{"t": "<div><div class=\"p\">AUTORIZA A COMPA&#xD1;IA PESQUERA CAMANCHACA S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS </div></div>", "i": 8548962}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 155, de 13 de Febrero de 1987, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Compa&#xF1;&#xED;a Pesquera Camanchaca S.A., domiciliada en Santiago, para realizar actividades de cultivo de Salm&#xF3;n plateado, en la Piscicultura de Polcura, ubicada a 7 kms. de Polcura, Comuna de Tucapel, Provincia Los Angeles, VIII Regi&#xF3;n, en la que realizar&#xE1; la etapa de crianza de la especie solicitada. </div></div>", "i": 8548963}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de Febrero de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8548964}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "155", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-155"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-13", "doble_articulado": false, "id_norma": "145957", "numero_fuente": "32721", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-13", "vigencias": [{"desde": "1987-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-03-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie