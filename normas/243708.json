{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 1.226 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1.226, celebrada el 3 de noviembre de 2005, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6547121}, {"t": "<div><div class=\"p\">1226-02-051103 - Modifica Cap&#xED;tulo III.H.5 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; lo siguiente:</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; En la parte final de la disposici&#xF3;n transitoria contenida en el Cap&#xED;tulo III.H.5 del Compendio de Normas Financieras, eliminar la frase &quot;En todo caso, deber&#xE1; obtener la referida autorizaci&#xF3;n de funcionamiento previa antes del 31 de octubre de 2005&quot;.</div><br></div>", "i": 6547122}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de noviembre de 2005.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6547123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1226", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1226"}, {"tipo": "5", "numero": "1226-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1226-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1.226", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPENDIO DE NORMAS FINANCIERAS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-03", "doble_articulado": false, "id_norma": "243708", "numero_fuente": "38304", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-05", "vigencias"