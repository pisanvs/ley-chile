{"html": [{"t": "<div><div class=\"p\">NOTIFICACION </div></div>", "i": 6264075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.061 de 30 de octubre de 1985 del SERVIU Metropolitano, se orden&#xF3; expropiaci&#xF3;n, conforme DL. No. 2186 de 1978, parte inmueble ubicado en Avenida Libertador Bernardo O&apos;Higgins y Pasaje Hotel Crowne Plaza, presunto rol de aval&#xFA;os No. 30337 (parte) comuna Santiago, aparentemente de dominio de don Mario Alvo. Comisi&#xF3;n integrada por peritos Pastor Correa Prats, arquitecto, Luis Rojas Quezada, constructor civil y Jorge Cavagnaro Michelis, ingeniero civil, seg&#xFA;n informe de fecha 30 de septiembre de 1985 fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 13.922.550.-, pagadera al contado.</div><br></div>", "i": 6264076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director SERVIU Metropolitano.</div><br></div>", "i": 6264077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1061", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1061"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-30", "doble_articulado": false, "id_norma": "165233", "numero_fuente": "32336", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-02", "vigencias": [{"desde": "1985-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen