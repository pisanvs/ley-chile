{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACEPTA RENUNCIA VOLUNTARIA QUE INDICA Santiago, 3 de Marzo de 1994.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 58.- Visto: Las atribuciones que me confiere la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica, en su art&#xED;culo 32 N&#xB0; 9.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 5889152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ac&#xE9;ptase, a contar del 11 de Marzo de 1994, la renuncia voluntaria presentada por don Carlos Fuensalida Claro, a su cargo de Subsecretario de Planificaci&#xF3;n y Cooperaci&#xF3;n.</div><br></div>", "i": 5889153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Sergio Molina Silva, Ministro de Planificaci&#xF3;n y Cooperaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Carlos Fuenzalida Claro, Subsecretario de Planificaci&#xF3;n y Cooperaci&#xF3;n.</div><br></div>", "i": 5889154}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "58", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-58"}], "organismos": ["MINISTERIO DE PLANIFICACIÓN Y COOPERACIÓN"], "titulo_norma": "ACEPTA RENUNCIA VOLUNTARIA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RENUNCIA VOLUNTARIA", "SUBSECRETARIO", "CARLOS FUENSALIDA CLARO", "MINISTERIO PLANIFICACION COOPERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-03", "doble_articulado": false, "id_norma": "8421", "numero_fuente": "34826", "tipo_version": "3", "tipo_version_s": "Única"