{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO NUMERO 497 EXENTO, DE 1993 </div></div>", "i": 5944928}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento N&#xB0; 497 de fecha 23 de septiembre de 1993 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica ESUCOMEX, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en todas las sedes que contaban con su aprobaci&#xF3;n, a contar del a&#xF1;o 1993, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\"> Carrera:&nbsp; Secretariado Ejecutivo Computacional.</div><br><div class=\"p\"> T&#xED;tulo:&nbsp;  Secretario (a) Ejecutivo (a) Computacional. </div></div>", "i": 5944929}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de Abril de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944930}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "497", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-497"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 497 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "ESUCOMEX", "SECRETARIADO EJECUTIVO COMPUTACIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-04-08", "doble_articulado": false, "id_norma": "21365", "numero_fuente": "34849", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-26", "vigencias": [{"desde": "1994-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in