{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6316920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;4.987, de fecha 31 de octubre de 2000, se expropi&#xF3; el lote de terreno N&#xBA;27, superficie 60 m&#xB2;, rol de aval&#xFA;o 324-9, comuna de R&#xED;o Negro, para la obra &apos;&apos;Camino Ruta U-72, Sector Huilma-Riachuelo, Tramo Km.</div><div class=\"p\">18,14000 a Km. 33,91000&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Benigno Hidalgo Carrillo, ascendente a la cantidad de $371.895.</div><br></div>", "i": 6316921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6316922}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4987", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4987"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-31", "doble_articulado": false, "id_norma": "180362", "numero_fuente": "36862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-15", "vigencias": [{"desde": "2001-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-01-16", "fecha_version": "2001-01-15", "fecha_actualizacion_texto": "2001-01-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "