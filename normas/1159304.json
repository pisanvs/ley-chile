{"html": [{"t": "<div><div class=\"p\">BATALLON VALDIVIA</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 7 de 1829.</div><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div></div>", "i": 10253074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0;&nbsp; El batallon Valdivia, credo por decreto de 30 de marzo &#xFA;ltimo, usar&#xE1; del mismo uniforme designado a los demas cuerpos de la misma arma, con solo la diferencia que el color del cuello ser&#xE1; carmes&#xED;.</div><br><br></div>", "i": 10253075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0;&nbsp; El Ministro de la Guerra queda encargo de la ejecucion del presente decreto, el que se transcribir&#xE1; a quienes corresponda y dispondr&#xE1; se imprima.</div><br><br></div>", "i": 10253076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PINTO.&nbsp; &nbsp;  Borgo&#xF1;o.</div></div>", "i": 10253077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "BATALLON VALDIVIA", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1829-04-07", "doble_articulado": false, "id_norma": "1159304", "numero_fuente": "1829", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1829-04-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1829-04-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1829-04-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-07-19", "fecha_version": "1829-04-07", "fecha_actualizacion_texto": "2021-07-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10253074}, {"n": "Artículo 1°", "i": 10253075, "t": 6}, {"n": "Artículo 2°", "i": 10253076, "t": 6}, {"n": "Promulgación", "i": 10253077}]}