{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10383847}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 5.028 de 11 de octubre de 2022, Serviu Regi&#xF3;n de Valpara&#xED;so, dispuesto expropiaci&#xF3;n parcial conforme al art&#xED;culo 51 ley 16.391 y decreto ley 2.186 de 1978, del lote signado con el n&#xFA;mero 1, ubicado en El Estero, de la comuna de San Felipe, en el plano DRS-P l&#xE1;mina 01 de 04 &quot;Proyecto Parque L&#xFA;dico Estero Quilpu&#xE9;, de la comuna de San Felipe&quot; de Presunto Dominio de Vergara Morales Enrique Eliseo, rol aval&#xFA;o 15-102. Comisi&#xF3;n Tasadora integrada por Mar&#xED;a Elena Giacaman Gray, &#xC1;lvaro Verdejo Vidal e Ismael Allendes Mar&#xED;n, seg&#xFA;n informe de tasaci&#xF3;n respectivo, se fij&#xF3; monto indemnizaci&#xF3;n provisional en $495.279.600, que ser&#xE1; pagada al contado.- </div></div>", "i": 10383848}, {"t": "<div><br><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu.</div><br></div>", "i": 10383849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5028 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5028 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN DE VALPARAÍSO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2221875", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-10-11", "doble_articulado": false, "id_norma": "1185500", "numero_fuente": "43415", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-12-01", "vigencias": [{"d