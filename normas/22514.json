{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Maestro Artificiero don Federico Gille Lei n&#xFA;m. 1,263.- Santiago, a 6 de Setiembre de 1899.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948727}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 5948728}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1263", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1263"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "MAESTRO ARTIFICIERO DON FEDERICO GILLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FEDERICO GILLE", "INDEMNIZACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-09-06", "doble_articulado": false, "id_norma": "22514", "numero_fuente": "6394", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-09-07", "vigencias": [{"desde": "1899-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-09-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-29", "fecha_version": "1899-09-07", "fecha_actualizacion_texto": "1899-09-07", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5948727}, {"n": "Promulgación", "