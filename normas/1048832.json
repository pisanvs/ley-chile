{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9333486}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 353, de 7 de febrero de 2013, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=252001&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.179, de 2006</a>, que autoriz&#xF3; a Pesquera B&#xED;o B&#xED;o S.A., hoy CAMANCHACA PESCA SUR S.A. para realizar actividades pesqueras extractivas con la nave &quot;BEC N&#xBA; 2179-06&quot;, respecto del recurso hidrobiol&#xF3;gico Jibia en el &#xE1;rea mar&#xED;tima comprendida entre la III a X Regiones, en virtud de lo dispuesto en el art&#xED;culo 143 letra b de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9333487}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de febrero de 2013.- Maximiliano Alarma Carrasco, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9333488}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "353 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-353 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-02-07", "doble_articulado": false, "id_norma": "1048832", "numero_fuente": "40484", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-13", "vigencias": [{"desde": "2013-02-13", "hasta": "", "tipo_version": "3",