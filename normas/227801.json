{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6488194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.725, de 30 de junio de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIALIZADORA DE PESCADOS MARISCOS LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Cuarta Poniente N&#xBA;2310, Tocopilla, II Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n Cocido, Fresco-Enfriado, Fresco-Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos individualizados en la resoluci&#xF3;n extractada. </div></div>", "i": 6488195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6488196}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1725 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1725 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-30", "doble_articulado": false, "id_norma": "227801", "numero_fuente": "37912", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-17", "vigencias": [{"desde": "2004-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingre