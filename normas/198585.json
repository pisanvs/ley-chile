{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 282 EXENTO, DE 2002 </div></div>", "i": 6383062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 282, de 8 de abril de 2002, se ha aprobado al Colegio &quot;British Royal School&quot;, comuna de La Reina, Santiago, un plan de estudio para 5&#xBA; a&#xF1;o (NB.3) de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en el presente decreto. </div></div>", "i": 6383063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de abril de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6383064}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "282 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-282 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 282 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-08", "doble_articulado": false, "id_norma": "198585", "numero_fuente": "37270", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-30", "vigencias": [{"desde": "2002-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2002-05-30", "fecha_vers