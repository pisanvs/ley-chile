{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9565301}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.930, de 9 de diciembre de 2014, de este Servicio, se modifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1064782&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.975</a>, de caducidad de inscripciones de embarcaciones que indica en el Registro Pesquero Artesanal.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la citada resoluci&#xF3;n y el informe, donde se individualizan las embarcaciones eliminadas de la caducidad y sus respectivos titulares, se encuentran publicados con esta fecha en el dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y de la Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 9565302, "v": ["MODIFICACION"]}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de diciembre de 2014.- Jos&#xE9; Miguel Burgos Gonz&#xE1;lez, Director Nacional.</div></div>", "i": 9565303}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4930 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4930 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-12-09", "doble_articulado": false, "id_norma": "1074787", "numero_fuente": "41083", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-02-14", "vigencias"