{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6175697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 59 del 08 de febrero de 1988, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones, de la IV Regi&#xF3;n de Coquimbo, se autoriza a Transportes Algarrobo Ltda., para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. La Serena;</div><div class=\"p\">08.02.88.</div><br></div>", "i": 6175698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge Vargas Borcosky, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6175699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "59 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-59 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-08", "doble_articulado": false, "id_norma": "138544", "numero_fuente": "32998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-17", "vigencias": [{"desde": "1988-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-17", "fin_vigencia": "", "tipo_version"