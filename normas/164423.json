{"html": [{"t": "<div><div class=\"p\">AUTORIZA A COMPA&#xD1;IA PESQUERA CAMANCHACA S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS QUE INDICA</div><br><br></div>", "i": 7267008}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 64, de 23 de Febrero de 1983, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la Compa&#xF1;&#xED;a Pesquera Camanchaca S.A., para operar la embarcaci&#xF3;n denominada &quot;Burca&quot;, en el litoral comprendido entre Coquimbo y Corral y destinarla a la extracci&#xF3;n de las siguientes especies: jurel, sardina com&#xFA;n, sardina espa&#xF1;ola, anchoa, corvina, caballa, tollo, pejegallo, merluza y congrio.</div><br></div>", "i": 7267009}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Febrero de 1983.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7267010}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-64"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A COMPAÑIA PESQUERA CAMANCHACA S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1983-02-23", "fecha_derogacion": "1996-08-14", "doble_articulado": false, "id_norma": "164423", "numero_fuente": "31503", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1983-02-26", "vigencias": [{"desde": "1996-08-14", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1983-02-26", "hasta": "1996-08