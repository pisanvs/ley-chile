{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aranceles Aduaneros </div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,316.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162990}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO PRIMERO. El Presidente de la rep&#xFA;blica dictar&#xE1; anualmente los arnaceles que han de rejir en las aduanas para el pago de los servicios de descarga, movilizacion i despacho de las mercader&#xED;as que se internen por los puertos de la Rep&#xFA;blica.</div><br><br></div>", "i": 7162991}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ART. 2.&#xB0; En la Lei de Presupuestos se consultar&#xE1;n los fondos necesarios para el pago de los servicios indicados en el art&#xED;culo anterior.</div><br></div>", "i": 7162992}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO TRANSITORIO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir en estos pagos hasta la suma de quinientos mil pesos durante el a&#xF1;o 1900.</div><br></div>", "i": 7162993}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 30 de Diciembre de 1899.- FEDERICO ERRAZURIZ.- Manuel Salinas.</div><br></div>", "i": 7162994}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1316", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1316"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ARANCELES ADUANEROS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ARANCEL ADUANERO", "APROBACION", "ADUANAS", "DISPOSICIONES", "MERCANCIAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-30", "doble_articulado": false, "id_norma": "22552", "numero_fuente": "6488", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-01-04", "vigencias": [{"desde": "1900-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-01-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-02-01", "fecha_version": "1900-01-04", "fecha_actualizacion_texto": "1900-01-04", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7162990}, {"n": "Artículo PRIMERO", "i": 7162991, "t": 6}, {"n": "Artículo 2", "i": 7162992, "t": 6}, {"n": "Artículo 1 Transitorio", "i": 7162993, "t": 6}, {"n": "Promulgación", "i": 7162994}]}