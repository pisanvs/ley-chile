{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 1065 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1065, celebrada el 29 de mayo de 2003, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6425224}, {"t": "<div><div class=\"p\">1065-02-030529 - Modifica Cap&#xED;tulo III.F.4 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; introducir la siguiente modificaci&#xF3;n en el Cap&#xED;tulo III.F.4 del Compendio de Normas Financieras:</div><br><div class=\"p\">&nbsp; &nbsp;  - Reemplazar en el numeral 6.1 de la letra B del T&#xED;tulo I, el porcentaje 20% por 25%.</div><br></div>", "i": 6425225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de mayo de 2003.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6425226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1065", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1065"}, {"tipo": "5", "numero": "1065-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1065-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1065", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-29", "doble_articulado": false, "id_norma": "210741", "numero_fuente": "37571", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-30", "vigencias": [{"desde": "2003-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-30", "fin_vigencia": ""}, "vigencias_ve