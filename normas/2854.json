{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA ORDENANZA SOBRE DERECHOS, PERMISOS O CONCESIONES </div></div>", "i": 8922508}, {"t": "<div><div class=\"p\"> A) Modifica Ordenanza sobre Derechos, Permisos o Concesiones vigente en el a&#xF1;o 1994, eliminando y modificando el siguiente art&#xED;culo:</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; TITULO VII</div><br><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 19&#xB0; Alumbrado P&#xFA;blico:</div><div class=\"p\">&nbsp; &nbsp; Se elimina letra b). Se cambia en letra c) Mantenci&#xF3;n de Alumbrado P&#xFA;blico a otras Comunas, por luminaria de 1/20 UTM... a 0,20 UTM.</div><br></div>", "i": 8922509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Saluda Atentamente a Ud.- Gonzalo Espinoza P&#xE9;rez, Alcalde.- Patricia Estrada Iturra, Secretaria Municipal. </div></div>", "i": 8922510}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-S/N"}], "organismos": ["MUNICIPALIDAD DE VALDIVIA"], "titulo_norma": "MODIFICA ORDENANZA SOBRE DERECHOS, PERMISOS O\nCONCESIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "ORDENANZA MUNICIPAL", "DERECHOS MUNICIPALES", "MUNICIPALIDAD VALDIVIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "2854", "numero_fuente": "34810", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-09", "vigencias": [{"desde": "1994-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-03-09", "fin_vigencia": "", "tipo_version": "3"}], "evento