{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Segregacion de la subdelegacion 8.a, Tango, del departamento de la Victoria</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,628.- Santiago, a 24 de Diciembre de 1903.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br></div>", "i": 8274497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se segrega de la subdelegacion 8.a, Tango, del departamento de la Victoria, el fundo Catemito i lo anexa al distrito n&#xFA;m. 1 de la subdelegacion 1.a San Bernardo del mismo departamento. </div></div>", "i": 8274498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Arturo Besa.</div><br></div>", "i": 8274499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1628", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1628"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SEGREGACION DE LA SUBDELEGACION 8.A, TANGO, DEL DEPARTAMENTO DE LA VICTORIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEPARTAMENTO DE LA VICTORIA", "SUBDELEGACION 8.", "TANGO", "FUNDO CATEMITO", "SEGREGACION", "DISTRITO 1", "SUBDELEGACION SAN BERNARDO", "ANEXION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-12-24", "doble_articulado": false, "id_norma": "22803", "numero_fuente": "7787", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-12-24", "vigencias": [{"desde": "1903-12-24", "hasta": "", "tipo_ve