{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 173 EXENTO, DE 1987 </div></div>", "i": 7275726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 173 de 3 de agosto de 1987 se ha rectificado el decreto supremo exento de Educaci&#xF3;n No. 156 de 1987 que aprob&#xF3; planes y programas especiales de estudio para Educaci&#xF3;n Media al Liceo Comercial C No. 43 de San Antonio, provincia de San Antonio, V Regi&#xF3;n de Valpara&#xED;so, en el sentido de reemplazar en el Area de Asignaturas B&#xE1;sicas Comunes a las Especialidades, la asignatura de &quot;Educaci&#xF3;n C&#xED;vica&quot; por &quot;Educaci&#xF3;n F&#xED;sica&quot;. </div></div>", "i": 7275727}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de Agosto de 1987.- Mar&#xED;a Piedad Ruiz Ferreras, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 7275728}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "173 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-173 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO No. 173 EXENTO, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-03", "doble_articulado": false, "id_norma": "174027", "numero_fuente": "32856", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-27", "vigencias": [{"desde": "1987-08-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-27", "fin_vigencia": "", "tipo_version