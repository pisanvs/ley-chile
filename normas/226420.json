{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 235 EXENTO, DE 2004</div><br><br></div>", "i": 6483345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 235 de 13 de abril de 2004, se han declarado oficialmente &quot;biling&#xFC;e&quot; al Liceo &quot;Lorenzo Baeza Vega&quot;, de Isla de Pascua, V Regi&#xF3;n de Valpara&#xED;so, a partir del a&#xF1;o 2004, para el nivel de Ense&#xF1;anza B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban los siguientes planes de estudio especiales para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica al Liceo &quot;Lorenzo Baeza Vega&quot; de Isla de Pascua, V Regi&#xF3;n de Valpara&#xED;so, el que se aplicar&#xE1; a contar del a&#xF1;o escolar 2004.</div></div>", "i": 6483346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de junio de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6483347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "235 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-235 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 235 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-13", "doble_articulado": false, "id_norma": "226420", "numero_fuente": "37886", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-16", "vigencias": [{"desde": "2004-06-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-16", "fin_vigencia": ""}, "vigencias_version_no