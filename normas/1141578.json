{"html": [{"t": "<div><br><div class=\"p\">TAQUIGRAFOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Valparaiso, Noviembre 9 de 1824. </div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto:</div></div>", "i": 10099844}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Los profesores de taquigrafia D. Fracisco Solano Perez y D. Melchor Ramos, se presentar&#xE1;n al Gobernador Intendente de Santiago para que les se&#xF1;ale y prepare lugar en la Sala del Congreso, en donde puedan c&#xF3;modamente copiar las sesiones y debates de la Representacion Nacional.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; La asignacion que deben disfrutar por este trabajo, les ser&#xE1; se&#xF1;alada por el mismo Soberano Congreso, Comun&#xED;quese e impr&#xED;mase.</div><br></div>", "i": 10099845}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Freire.</div><br><div class=\"p\">&nbsp; &nbsp;  F. A. Pinto</div><br></div>", "i": 10099846}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "TAQUIGRAFOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-11-09", "doble_articulado": false, "id_norma": "1141578", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-11-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-11-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-11-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones