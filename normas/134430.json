{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xBA; 248, DE 1986 </div><br><br><br><br></div>", "i": 7247363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xBA; 248, de fecha 23 de enero de</div><div class=\"p\">1986, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el</div><div class=\"p\">art. 1&#xBA; y 2&#xBA; de la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xBA; 2.574, de 1982, del Centro de Formaci&#xF3;n T&#xE9;cnica &quot;Instituto de Idiomas de la VIII Regi&#xF3;n&quot;, en el sentido de reemplazar la red secuencial de asignaturas del plan y programas de estudio de la carrera interpretariado y Traducci&#xF3;n Ingl&#xE9;s Espa&#xF1;ol y modificar las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n, a contar de agosto de 1984, respectivamente.- </div></div>", "i": 7247364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7247365}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "248 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-248 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA Nº 248, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-01-23", "fecha_derogacion": "1999-03-02", "doble_articulado": false, "id_norma": "134430", "numero_fuente": "32442", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-04-09", "vigencias": [{"desde": "1999-03-02", "hasta": "", "tipo_version": "2", "