{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9296497}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA;1693 de 27 de agosto de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;13, superficie 40 m2, rol de Aval&#xFA;o N&#xBA;2369-2, comuna de Chiguayante, para la obra &quot;Canal Papen, Tramo Cochrane &#x2013; O&apos;Higgins, Etapa 1&quot;. La Comisi&#xF3;n de peritos, integrada por Orlando Javier Paredes V&#xE1;squez, Hern&#xE1;n Danilo C&#xE1;ceres Moscoso y Rodrigo Enrique Vilches Rysselberghe, fij&#xF3; el valor de tasaci&#xF3;n con fecha 8 de agosto de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario Pedro Toledo P&#xE9;rez, en la cantidad de $1.808.276.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9296498}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 9296499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1693 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1693 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-08-27", "doble_articulado": false, "id_norma": "1043881", "numero_fuente": "40364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-15", "vigencias": [{"desde": "2012-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v