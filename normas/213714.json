{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6435878}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 714 de fecha 30 de junio de 2003, se expropi&#xF3; el lote de terreno N&#xBA; 16-A, superficie 11.452 m&#xB2;, Rol de aval&#xFA;o N&#xBA; 157-17, comuna de Pemuco, para la obra: &quot;Proyecto Laja Diguill&#xED;n, Area de Riego Pemuco Canal El Oyente Alternativa Dos Faja Adicional Km. 0,135 al Km. 8,062&quot;, VIII Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Julio C&#xE9;sar Ocampo Salinas, ascendente a la cantidad de $6.045.522. </div></div>", "i": 6435879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6435880}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "714", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-714"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-30", "doble_articulado": false, "id_norma": "213714", "numero_fuente": "37636", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-16", "vigencias": [{"desde": "2003-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-08-18", "fecha_version": "2003-08-16", "fecha_actualizacion_texto": "2003-08-16", "tipo_tratado": ""}