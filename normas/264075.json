{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION DE AGENTE RETENEDOR DE IVA A SOCIEDAD AGRICOLA Y FAENADORA DE CARNES LTDA. </div></div>", "i": 8603158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del S.I.I., por Res/Dre07/Ex. N&#xBA;4.299 de fecha 8 de agosto de 2007, deroga a contribuyente Sociedad Agr&#xED;cola y Faenadora de Carnes Ltda., RUT N&#xBA;89.900.300-4, a contar del d&#xED;a 1&#xBA; del mes siguiente a la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, en las ventas de ganado vivo y de mataderos y otros en las ventas de carnes, de acuerdo a lo establecido en las resoluciones Ex. N&#xBA;s. 3.721 y 3.722 del 28.07.2000, de la Direcci&#xF3;n Nacional.- Talca, 8 de agosto de 2007.</div><br></div>", "i": 8603159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Mirtha Barra Paredes, Directora Regional. </div></div>", "i": 8603160}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4299 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-4299 EXENTA"}, {"tipo": "3", "numero": "DRE-07-4299 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-07-4299 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "DEROGA AUTORIZACION DE AGENTE RETENEDOR DE IVA A SOCIEDAD AGRICOLA Y FAENADORA DE CARNES LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-08", "doble_articulado": false, "id_norma": "264075", "numero_fuente": "38846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":