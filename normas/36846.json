{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297136}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.386, de 22 de septiembre de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por SALMONES UNIMARC S.A., para un centro de cultivo ubicado en el sur de Isla Simpson, Canal Nalcayec, Comuna de Ays&#xE9;n, Provincia de Ays&#xE9;n, XI Regi&#xF3;n, por no dar cumplimiento el respectivo proyecto t&#xE9;cnico a lo dispuesto en el art&#xED;culo 78, inciso 2&#xB0; y 87 de la Ley General de Pesca y Acuicultura.</div><br><br></div>", "i": 8297137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 22 de septiembre de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297138}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1386", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1386"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SALMONES UNIMARC S.A", "CONCESION ACUICULTURA", "DENEGACION", "DECIMOPRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-09-22", "doble_articulado": false, "id_norma": "36846", "numero_fuente": "35282", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-10-03", "vigencias": [{"desde": "1995-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-10-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-1