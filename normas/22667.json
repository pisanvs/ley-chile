{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Edificio del Congreso Nacional Lei n&#xFA;m. 1,460.- Santiago, a 26 de Enero de 1901.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274355}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de sesenta i dos mil cuatrocientos treinta pesos setenta i dos i medio centavos ($ 62,430.721 /2) en la terminacion del edificio del Congreso Nacional.</div><br></div>", "i": 8274356}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Juan Antonio Orrego.</div><br></div>", "i": 8274357}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1460", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1460"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Edificio del Congreso Nacional", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "EDIFICACION", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-26", "doble_articulado": false, "id_norma": "22667", "numero_fuente": "6834", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-03-07", "vigencias": [{"desde": "1901-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic