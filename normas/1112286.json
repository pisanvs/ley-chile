{"html": [{"t": "<div><div class=\"p\">CONCEPTO DE ESTABLECIMIENTO PERMANENTE, EN RELACI&#xD3;N CON LA OBLIGACI&#xD3;N DE INSCRIPCI&#xD3;N EN EL ROL &#xDA;NICO TRIBUTARIO</div></div>", "i": 9864941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de Circular del Servicio de Impuestos Internos N&#xB0; 57, de fecha 7 de diciembre de 2017, mediante la cual se precisa el concepto de establecimiento permanente para efectos de cumplir con la obligaci&#xF3;n de inscribirse en el Rol &#xDA;nico Tributario.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta Circular est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII, en diciembre de 2017.</div></div>", "i": 9864942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "57", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-57"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CONCEPTO DE ESTABLECIMIENTO PERMANENTE, EN RELACIÓN CON LA OBLIGACIÓN DE INSCRIPCIÓN EN EL ROL ÚNICO TRIBUTARIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1317814; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-12-07", "doble_articulado": false, "id_norma": "1112286", "numero_fuente": "41931", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-12-13", "vigencias": [{"desde": "2017-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-12-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-12-13", "fin_vigencia": "", "tipo_versi