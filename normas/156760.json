{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6236648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 22 de 11 de Enero de 1985, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a la Reserva y Sector expropiado predio &quot;Hijuela Primera o San Miguel&quot; de la comuna de San Esteban, V Regi&#xF3;n, y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s 6 a la 14, sitios N&#xB0;s 4 al 13 del Proyecto de Parcelaci&#xF3;n &quot;San Miguel&quot; formado entre otros, por el predio se&#xF1;alado. Los derechos de agua se extraen de los Canales Ram&#xED;rez, Hurtado y Vizcachas, y Quebrada Huapi. Publicaci&#xF3;n hecha conforme Art. 13, Ley N&#xB0; 18.377.-</div><br></div>", "i": 6236649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6236650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "22 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-22 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-11", "doble_articulado": false, "id_norma": "156760", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic