{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 80 EXENTO, DE 1994 </div></div>", "i": 5940808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 80 de 3 de marzo de 1994 se ha aprobado, al Colegio &quot;St. Gabriel&apos;s School&quot;, de Quillota, un plan especial de estudio para la Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, el cual se aplicar&#xE1; a partir de 1994.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s se aprueba programa de estudio para la asignatura de L&#xF3;gica en 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media. </div></div>", "i": 5940809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 21 de Marzo de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n </div></div>", "i": 5940810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "80", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-80"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 80 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO ST. GABRIEL'S SCHOOL", "QUILLOTA", "PLANES ESTUDIOS", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-03", "doble_articulado": false, "id_norma": "20064", "numero_fuente": "34828", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-30", "vigencias": [{"desde": "1994-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-03-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula