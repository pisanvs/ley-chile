{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8952431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 527 de 24 de Mayo de 1994 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o a contar del 13 de Junio de 1994, el plazo otorgado a COMPA&#xD1;IA PESQUERA SAN BERNARDO S.A., hoy Mar&#xED;tima San Bernardo S.A., R.U.T. N&#xB0; 96.651.710-7, en orden a iniciar actividades pesqueras extractivas con la nave &quot;Mar&#xED;a Jos&#xE9;&quot;, autorizada mediante la Resoluci&#xF3;n N&#xB0; 482, de 1992, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 8952432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 27 de Mayo de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8952433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "527", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-527"}], "organismos": ["MINISTERIO DE ECONOMÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "AUTORIZACION", "COMPA IA PESQUERA SAN BERNARDO S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-05-27", "fecha_derogacion": "1997-09-25", "doble_articulado": false, "id_norma": "35030", "numero_fuente": "34886", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-06-10", "vigencias": [{"desde": "1997-09-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-06-10", "hasta": "1997-09-24", "tipo_version": "0", "tipo_version_s": "Texto Origin