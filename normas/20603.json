{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 186 EXENTO, DE 1988 </div></div>", "i": 5942497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 186 de 1&#xB0; de diciembre de 1988 se han aprobado, al Colegio &quot;Coraz&#xF3;n de Mar&#xED;a&quot; de la comuna de San Miguel, de Santiago, planes especiales de estudio para ser aplicados a contar del a&#xF1;o escolar 1989 en Educaci&#xF3;n General B&#xE1;sica y en 1&#xB0;, 2&#xB0; y 3er. a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, y en el a&#xF1;o escolar de 1990 en 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica. </div></div>", "i": 5942498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Diciembre de 1988.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 5942499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "186", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-186"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 186 EXENTO, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO CORAZON MARIA", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION", "SAN MIGUEL", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-01", "doble_articulado": false, "id_norma": "20603", "numero_fuente": "35179", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-29", "vigencias": [{"desde": "1995-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-29", "fin_vigencia": ""}, "vigencias_versio