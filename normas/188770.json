{"html": [{"t": "<div><div class=\"p\">EXTRACTO DECRETO No. 1.032, DE 1985, QUE APRUEBA MODIFICACION CONVENIO DE TRASPASO DE LA ESCUELA BASICA E766, COMUNA DE SAN BERNARDO </div></div>", "i": 6347023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto No. 1.032, de 1985, se aprob&#xF3; una modificaci&#xF3;n al convenio de traspaso de la Escuela B&#xE1;sica E-766, de San Bernardo, aprobado por Decreto de Educaci&#xF3;n No. 946, de 1982, que incide en la cl&#xE1;usula sexta, relativa al bien ra&#xED;z.</div><br></div>", "i": 6347024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago 06 de Marzo de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6347025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1032", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1032"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DECRETO No. 1.032, DE 1985, QUE APRUEBA\nMODIFICACION CONVENIO DE TRASPASO DE LA ESCUELA BASICA\nE766, COMUNA DE SAN BERNARDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-03-06", "doble_articulado": false, "id_norma": "188770", "numero_fuente": "32420", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-12", "vigencias": [{"desde": "1986-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-03-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ing