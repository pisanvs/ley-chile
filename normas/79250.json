{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309680}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 387, de 07 de Mayo de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga la Resoluci&#xF3;n No. 1446, de 1989, de esta Subsecretar&#xED;a, que autoriza a don Vicente Marcelo Soto Soto, R.U.T. No. 11.413.573-9, para instalar y operar un establecimiento de cultivo del recurso alga del g&#xE9;nero Gracilaria, en el R&#xED;o Quenuir, Comuna de Maull&#xED;n, Provincia de Llanquihue, X Regi&#xF3;n, por renuncia de su titular. </div></div>", "i": 8309681}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 07 de Mayo de 1992.- Jorge Marshall Rivera, Subsecretario de Pesca Subrogante.</div><br></div>", "i": 8309682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "387", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-387"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-05-07", "doble_articulado": false, "id_norma": "79250", "numero_fuente": "34265", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-05-13", "vigencias": [{"desde": "1992-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "J