{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 435, DE 2008 </div></div>", "i": 6664153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 435, de 11 de agosto de 2008, se modific&#xF3; convenio de fecha 2 de noviembre de 1981, celebrado entre el Ministerio de Educaci&#xF3;n y la Ilustre Municipalidad de Conchal&#xED;, sobre Traspaso de Servicio Educacional y sus Bases que presta la Escuela B&#xE1;sica F-156 de Conchal&#xED;, aprobado por decreto supremo de Educaci&#xF3;n N&#xBA;8.211, de 1981, en el sentido de corregir deslindes y t&#xED;tulo de dominio de la propiedad ra&#xED;z en que se encuentra emplazada dicha Escuela.</div><br></div>", "i": 6664154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de octubre de 2008.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6664155}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "435", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-435"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 435, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-08-11", "doble_articulado": false, "id_norma": "281096", "numero_fuente": "39206", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-11-07", "vigencias": [{"desde": "2008-11-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-11-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-11-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacio