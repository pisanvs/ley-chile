{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6089006}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 409, de 8 de mayo 1989, de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186, de 1978, inmueble ubicado calle Ricardo Santa Cruz No. 593, tambi&#xE9;n signado por calle San Isidro con No. 498, presunto rol aval&#xFA;os 592-12, comuna Santiago, aparentemente dominio de don Mario Mart&#xED;nez Valles. Comisi&#xF3;n integrada por peritos se&#xF1;ores Jos&#xE9; Miguel Haltenhoff Aenishanslin y Carlos del Pedregal S&#xE1;nchez, constructores civiles, y Teresa Sancho Pernas, arquitecto, seg&#xFA;n informe de 01.12.88, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 11.552.450, pagadera al contado.</div><br></div>", "i": 6089007}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6089008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "409", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-409"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-08", "doble_articulado": false, "id_norma": "91448", "numero_fuente": "33386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-01", "vigencias": [{"desde": "1989-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-01", "fin_vigencia": "", "tipo_version": "3