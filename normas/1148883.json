{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE LA CALERA</div></div>", "i": 10155144}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xB0; 848, de 31 de enero de 2020, conforme al Art&#xED;culo 5&#xB0; transitorio C&#xF3;digo de Aguas, complementa la <a href=\"https://www.leychile.cl/Navegar?idNorma=152101&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.467, de 1987</a>, del Servicio Agr&#xED;cola y Ganadero, en el sentido de establecer que los derechos de aprovechamiento de aguas de los derrames de Vista Hermosa se originan en los Canales Ocoa y Pequenes que tienen su bocatoma en la Tercera Secci&#xF3;n del R&#xED;o Aconcagua, en la comuna de Llay Llay.</div></div>", "i": 10155145}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xB0; ley N&#xB0; 18.377.- Director Nacional.</div><br></div>", "i": 10155146}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "848 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-848 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE LA CALERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1802968", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-31", "doble_articulado": false, "id_norma": "1148883", "numero_fuente": "42745", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-09-01", "vigencias": [{"desde": "2020-09-01", "hasta": "", "tipo_version": "3", "tipo_