{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,570, que autoriza a la Municipalidad de Santiago para cambiar el nombre de una avenida.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,570.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276485}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase a la Municipalidad de Santiago para cambiar el nombre de la &quot;Avenida de las Quintas&quot;, de esta ciudad, por el de &quot;Jeneral Bustamante&quot;.</div><br></div>", "i": 8276486}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a diez de Diciembre de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Florencio Valdes C. </div></div>", "i": 8276487}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3570", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3570"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,570, QUE AUTORIZA A LA MUNICIPALIDAD DE SANTIAGO PARA CAMBIAR EL NOMBRE DE UNA AVENIDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SANTIAGO", "MUNICIPALIDAD", "CALLES", "DENOMINACION", "CAMBIO", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-12-10", "doble_articulado": false, "id_norma": "24079", "numero_fuente": "12550", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-12-20", "vigencias": [{"desde": "1919-12-20", "hasta": "", "tipo_version