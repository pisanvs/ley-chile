{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,281.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; En atencion a los servicios prestados por el ex-teniente de Ej&#xE9;rcito, don Belisario Acu&#xF1;a, se concede, por gracia, a su madre do&#xF1;a Carlota Jim&#xE9;nez, viuda de Acu&#xF1;a, una pension de veinte pesos ($ 20) mensuales, de la que gozar&#xE1; desde la fecha de la promulgacion de esta ley. </div></div>", "i": 6170571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de marzo de mil novecientos diez.- Pedro Montt.-&nbsp; An&#xED;bal Rodr&#xED;guez H.</div><br></div>", "i": 6170572}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2281", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2281"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-03-05", "doble_articulado": false, "id_norma": "137008", "numero_fuente": "9651", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-03-30", "vigencias": [{"desde": "1910-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-03-30", "fin_