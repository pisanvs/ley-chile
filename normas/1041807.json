{"html": [{"t": "<div><br><div class=\"p\">DERECHOS DE AGUA EN COMUNAS DE LA LIGUA Y CABILDO</div></div>", "i": 9275290}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA; 3.833 de 29 de junio de 2012, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, aclar&#xF3; y complement&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=129580&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.323 de 3 de agosto de 1988</a>, que aprob&#xF3; Estudio T&#xE9;cnico de Divisi&#xF3;n de Derechos de Aprovechamiento de Aguas de parte del predio &quot;Illalolen&quot; y de parte del Proyecto de Parcelaci&#xF3;n &quot;El Carmen&quot;, de las comunas de La Ligua y Cabildo, Regi&#xF3;n de Valpara&#xED;so, en el sentido de expresar en unidad de volumen por unidad de tiempo los derechos de aprovechamiento de aguas del Sector Reserva del predio &quot;Illalolen&quot;, y que dichos derechos son consuntivos, de ejercicio permanente y continuo.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; ley N&#xBA; 18.377.- </div><br></div>", "i": 9275291}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Nacional.</div></div>", "i": 9275292}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3833 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3833 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNAS DE LA LIGUA Y CABILDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-29", "do