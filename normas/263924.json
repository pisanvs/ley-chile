{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7351162}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.407, de 10 de agosto de 2007, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 284 de 2001, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a DAVID CRUZ LOPEZ para realizar actividades pesqueras extractivas con la nave &quot;Marleen&quot;, en el &#xE1;rea mar&#xED;tima de la XII Regi&#xF3;n, sobre los recursos Pez espada, At&#xFA;n aleta larga, At&#xFA;n ojos grandes y At&#xFA;n aleta amarilla, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7351163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de agosto de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7351164}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2407 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2407 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-10", "doble_articulado": false, "id_norma": "263924", "numero_fuente": "38840", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-17", "vigencias": [{"desde": "2007-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-08-17", "fin_vigencia": "", "ti