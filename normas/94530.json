{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6097342}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 534 de 29 de mayo 1989 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186 de 1978, -parte inmueble- ubicado en Santa Isabel No. 0310, presunto rol aval&#xFA;os No. 916-20, comuna de Providencia, aparentemente dominio de la Sucesi&#xF3;n de don Diego Fern&#xE1;ndez S&#xE1;nchez. Comisi&#xF3;n integrada por peritos Jorge Navarrete Navarrete, arquitecto, Emilio Recabarren Solar, ingeniero civil y Luis Rojas Quezada, constructor civil, seg&#xFA;n informe de 21 de diciembre 1989, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 2.660.200.- pagadera al contado. </div></div>", "i": 6097343}, {"t": "<div><div class=\"p\">- Director SERVIU Metropolitano.</div><br></div>", "i": 6097344}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "534", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-534"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-29", "doble_articulado": false, "id_norma": "94530", "numero_fuente": "33398", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-15", "vigencias": [{"desde": "1989-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM",