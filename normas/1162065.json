{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10246888}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.203, de fecha 23 de junio de 2021, de la Gobernaci&#xF3;n Provincial de Isla de Pascua, se Aprueba Procedimiento Destinado a Determinar la Forma en que se Acreditar&#xE1; el Desarrollo Permanente de Actividades Econ&#xF3;micas Independientes una vez Otorgada la Habilitaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de dicho acto administrativo se encuentra publicado en la p&#xE1;gina web de la Gobernaci&#xF3;n Provincial de Isla de Pascua (http://www.gobernacionisladepascua.gov.cl/).</div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10246889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Isla de Pascua, 24 de junio de 2021.- Ren&#xE9; Alberto de la Puente Hey, Gobernador Provincial de Isla de Pascua.</div><div class=\"p\"> </div><br></div>", "i": 10246890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1203 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1203 EXENTA"}], "organismos": ["MINISTERIO DEL INTERIOR Y SEGURIDAD PÚBLICA", "GOBERNACIÓN DE ISLA DE PASCUA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1969559", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-06-23", "doble_articulado": false, "id_norma": "1162065", "numero_fuente": "42990", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-06-30", "vigencias": [{"desde": "2021-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-06-30", "fin_vigencia":