{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA; 185, DE 2009</div></div>", "i": 8815566}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n (M) N&#xBA; 2.045, de 27 de octubre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3; lo siguiente:</div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la r<a href=\"https://www.leychile.cl/Navegar?idNorma=1006374&amp;idParte=0&amp;idVersion=\">esoluci&#xF3;n 1.560, de 17 de julio de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional</a>, que autoriz&#xF3; al Sr. Manuel Alejandro Norambuena Pradenas a transferir a Pesquera El Golfo la Concesi&#xF3;n de Acuicultura de Porci&#xF3;n de Agua y Fondo de Mar, otorgada por resoluci&#xF3;n 1.759 de 2007, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina.</div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase en el numeral 1.- de la parte resolutiva lo siguiente:</div><br><div class=\"p\">Donde dice: El Golf S.A.</div><div class=\"p\">Debe decir: El Golfo S.A.</div></div>", "i": 8815567}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de diciembre de 2009.- Por la Sra. Subsecretaria, Felipe Garc&#xED;a-Huidobro Correa, Subjefe Subsecretar&#xED;a de Marina.</div></div>", "i": 8815568}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2045", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2045"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº 185, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-27", "doble_a