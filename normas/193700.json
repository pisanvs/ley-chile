{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6365689}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.576, de 27 de diciembre de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA SURIBERICA S.A. para realizar operaciones pesqueras, a contar del 1 de enero del a&#xF1;o 2002 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con el barco f&#xE1;brica denominado &quot;Isla Camila&quot;, en aguas interiores, al sur del paralelo 47&#xB0; L.S., respecto de los recursos y con las obligaciones establecidas en sus respectivas resoluciones.</div><br></div>", "i": 6365690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6365691}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2576", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2576"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-27", "doble_articulado": false, "id_norma": "193700", "numero_fuente": "37161", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-16", "vigencias": [{"desde": "2002-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-01-16", "fe