{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOLICITA CONSTITUCION LEGAL DEL &quot;PARTIDO COMUNISTA DE CHILE&quot; EN LA X REGION DE LOS LAGOS </div></div>", "i": 7199269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gladys Mar&#xED;n Millie y Lautaro Carmona Soto, Presidente y Secretario General, respectivamente, en representaci&#xF3;n del &quot;Partido Comunista de Chile&quot;, han solicitado la constituci&#xF3;n legal del Partido en la X Regi&#xF3;n de Los Lagos, acompa&#xF1;ando 2.727 fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0; 1.371, de fecha 09 de mayo de 1996. </div></div>", "i": 7199270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 09 de mayo de 1996.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 7199271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1371", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1371"}, {"tipo": "3", "numero": "O-1371", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1371"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION LEGAL DEL PARTIDO COMUNISTA DE CHILE EN LA X REGION DE LOS LAGOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDO COMUNISTA CHILE", "CONSTITUCION LEGAL", "DECIMA REGION", "PARTIDOS POLITICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-09", "doble_articulado": false, "id_norma": "36814", "numero_fuente": "35472", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-22", "vigencias": [{"desde": "1996-05-22", "h