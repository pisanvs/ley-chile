{"html": [{"t": "<div><div class=\"p\">ESTABLECE VEDA BIOL&#xD3;GICA PARA EL RECURSO CULENGUE EN &#xC1;REA Y PER&#xCD;ODO QUE INDICA</div></div>", "i": 10230617}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 202100085, de 26 de mayo de 2021, de este Ministerio, establ&#xE9;cese veda biol&#xF3;gica para el recurso Culengue, en el &#xE1;rea mar&#xED;tima correspondiente a la Regi&#xF3;n de Los Lagos, la que regir&#xE1; durante los meses de diciembre, enero y febrero.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10230618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de mayo de 2021.- Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><br></div>", "i": 10230619}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "202100085 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-202100085 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "ESTABLECE VEDA BIOLÓGICA PARA EL RECURSO CULENGUE EN ÁREA Y PERÍODO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1952735", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-05-26", "doble_articulado": false, "id_norma": "1160446", "numero_fuente": "42967", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-06-01", "vigencias": [{"desde": "2021-06-01", "hasta": "", "tipo_version": "3", "tipo_version