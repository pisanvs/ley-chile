{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 511, de 14 de abril de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 45, de 1997, que caduc&#xF3; la Resoluci&#xF3;n N&#xBA; 36 de 1991, ambas de esta Subsecretar&#xED;a, a PESQUERA OCEANICA LIMITADA, en virtud de haberse acreditado por la peticionaria la operaci&#xF3;n de la nave &quot;Don Nelson&quot;, en la forma exigida por la Ley N&#xBA; 18.892.</div><br></div>", "i": 8302947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de abril de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302948}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "511", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-511"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA OCEANICA LIMITADA", "AUTORIZACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-14", "doble_articulado": false, "id_norma": "71243", "numero_fuente": "35762", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-10", "vigencias": [{"desde": "1997-05-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones