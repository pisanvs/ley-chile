{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8932899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.324 de 14 de octubre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar del 31 de Julio de 1997, el plazo otorgado a PESQUERA OCEANICA LIMITADA, para continuar operaciones pesqueras con la nave &quot;Don Nelson&quot;, autorizada por las Resoluciones N&#xBA; 451, de 1988; N&#xBA; 36, de 1991; N&#xBA; 46 y N&#xBA; 512, ambas de 1997, todas de esta Subsecretar&#xED;a; en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 8932900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de octubre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8932901}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1324", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1324"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA OCEANICA LIMITADA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-10-14", "fecha_derogacion": "1997-10-24", "doble_articulado": false, "id_norma": "76523", "numero_fuente": "35899", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-24", "vigencias": [{"desde": "1997-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"