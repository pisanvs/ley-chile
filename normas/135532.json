{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,557.- Santiago, 25 de setiembre de 1902. </div></div>", "i": 6165707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que conceda al ex-piloto segundo de la Armada, don Ernesto Alfieri, la pension de retiro correspondiente a sus a&#xF1;os de servicio:</div><br></div>", "i": 6165708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN-RIESCO.- V&#xED;ctor Manuel Lamas.</div><br></div>", "i": 6165709}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1557", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1557"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1902-09-25", "doble_articulado": false, "id_norma": "135532", "numero_fuente": "7375", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1902-09-29", "vigencias": [{"desde": "1902-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1902-09-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1902-09-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-04-27", "fecha_version": "1902-09-29", "fecha_actualizacion_texto": "1902-09-29", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabez