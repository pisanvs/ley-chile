{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 65 EXENTO, DE 1999</div><br><br></div>", "i": 6166405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 65 de fecha 22 de marzo de 1999 del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada a la Universidad San Sebasti&#xE1;n, la Carrera de Kinesiolog&#xED;a conducente al T&#xED;tulo Profesional de Kinesi&#xF3;logo, y al Grado Acad&#xE9;mico de Licenciado en Kinesiolog&#xED;a para ser impartida en jornada diurna, en su Sede de la ciudad de Concepci&#xF3;n, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo. </div></div>", "i": 6166406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de abril de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6166407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "65 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-65 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 65 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-22", "doble_articulado": false, "id_norma": "135735", "numero_fuente": "36352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-30", "vigencias": [{"desde": "1999-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM",