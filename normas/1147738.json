{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xB0;465 EXENTA, DE 16.01.2020</div></div>", "i": 10138348}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=195682&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.287, de 2002, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 3&#xB0; y 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Colegio Coyancura, RBD 12086-3, comuna de Las Condes, Regi&#xF3;n Metropolitana, en el sentido de sustituir los planes de estudio de 3&#xB0; y 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10138349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n. </div><br></div>", "i": 10138350}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "465 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-465 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO RESOLUCIÓN N°465 EXENTA, DE 16.01.2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1787990", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-16", "doble_articulado": false, "id_norma": "1147738", "numero_fuente": "42712", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-07-23", "vigencias": [{"desde": "2020-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-07-23", "fin_vig