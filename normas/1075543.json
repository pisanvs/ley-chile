{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETOS QUE INDICA, REGULARIZANDO CARTOGRAF&#xCD;A EN &#xC1;REAS DE MANEJO Y EXPLOTACI&#xD3;N DE RECURSOS BENT&#xD3;NICOS UBICADAS EN LA XIV REGI&#xD3;N</div></div>", "i": 9581282}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;163, de 11 de marzo de 2015, de este Ministerio, modif&#xED;case el <a href=\"https://www.leychile.cl/Navegar?idNorma=145580&amp;idParte=0&amp;idVersion=\">DS N&#xBA;506 de 1999</a>, los decretos exentos <a href=\"https://www.leychile.cl/Navegar?idNorma=204856&amp;idParte=0&amp;idVersion=\">N&#xBA;919</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=204334&amp;idParte=0&amp;idVersion=\">N&#xBA;942</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=205019&amp;idParte=0&amp;idVersion=\">N&#xBA;983</a>, todos de 2002, <a href=\"https://www.leychile.cl/Navegar?idNorma=216016&amp;idParte=0&amp;idVersion=\">N&#xBA;663</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=216201&amp;idParte=0&amp;idVersion=\">N&#xBA;677</a>, ambos de 2003, <a href=\"https://www.leychile.cl/Navegar?idNorma=229108&amp;idParte=0&amp;idVersion=\">N&#xBA;371</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=226611&amp;idParte=0&amp;idVersion=\">N&#xBA;429</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=229040&amp;idParte=0&amp;idVersion=\">N&#xBA;627</a>, todos de 2004, todos del actual Ministerio de Econom&#xED;a, Fomento y Turismo que establecieron &#xE1;reas de manejo y explotaci&#xF3;n de recursos bent&#xF3;nicos en la XIV Regi&#xF3;n, en el sentido de regularizar su cartograf&#xED;a, de acuerdo a lo se&#xF1;alado en el decreto extractado.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretaria de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9581283, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de marzo de 2015.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9581284}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "163 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-163 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETOS QUE INDICA, REGULARIZANDO CARTOGRAFÍA EN ÁREAS DE MANEJO Y EXPLOTACIÓN DE RECURSOS BENTÓNICOS UBICADAS EN LA XIV REGIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-03-11", "doble_articulado": false, "id_norma": "1075543", "numero_fuente": "41109", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-03-17", "vigencias": [{"desde": "2015-03-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-03-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2015-03-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "2932", "fecha_ingreso": "2015-03-17", "fecha_version": "2015-03-17", "fecha_actualizacion_texto": "2015-03-17", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9581282}, {"n": "Artículo", "i": 9581283, "t": 6}, {"n": "Promulgación", "i": 9581284}]}