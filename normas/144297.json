{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6193773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 522, de 09 de Julio de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n se autoriza a don Alberto Antonio Gonz&#xE1;lez L&#xF3;pez para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6193774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6193775}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "522 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-522 EXENTA"}], "organismos": ["SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE", "MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-09", "doble_articulado": false, "id_norma": "144297", "numero_fuente": "32692", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-07", "vigencias": [{"desde": "1987-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "