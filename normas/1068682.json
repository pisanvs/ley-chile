{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9520872}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.730, de 15 de octubre de 2014, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1051726&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.360 de 2013</a>, s&#xF3;lo en cuanto autoriz&#xF3; a SOCIEDAD PESQUERA LANDES S.A., para realizar actividades pesqueras extractivas con la nave &quot;Walrus&quot;, respecto del recurso hidrobiol&#xF3;gico Jibia, en el &#xE1;rea mar&#xED;tima de la V Regi&#xF3;n, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum citado en visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9520873}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de octubre de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9520874}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2730 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2730 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-10-15", "doble_articulado": false, "id_norma": "1068682", "numero_fuente": "40900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-10-23", "vigencias": [{"desde": "2014-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"