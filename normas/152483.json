{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6223287}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. 117, de 30 de Mayo de 1986, se expropiaron los lotes N&#xB0;s. 4, 5 y 6, roles de aval&#xFA;o 273-208, 273-165 y 273-165, superficies 260 m2, 3.465 m2 y 2.590 m2, respectivamente, comuna de San Fernando, VI Regi&#xF3;n, para Camino Angostura- El Tambo rol 190-H, Km.</div><div class=\"p\">2,809 al 3.415, sector accesos al Puente Charquic&#xE1;n y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietario don Jos&#xE9; Torres Mu&#xF1;oz, ascendente a $ 536.062.</div><br></div>", "i": 6223288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. (1&#xB0;) </div></div>", "i": 6223289}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "117", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-117"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-30", "doble_articulado": false, "id_norma": "152483", "numero_fuente": "32510", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-01", "vigencias": [{"desde": "1986-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-01-27", "fecha_version": "1986-07-01", "fecha_actualizacion_texto": "1986-07-01", "tipo_tratad