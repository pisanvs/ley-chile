{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL ARTICULO N.o 39 DEL DECRETO CON FUERZA DE LEY N.o 209, de 1953</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7173602}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- En el art&#xED;culo 39 del decreto con fuerza de ley N.o 209, de fecha 5 de Agosto de 1953, y a contar desde su vigencia, col&#xF3;quese una coma (,) a continuaci&#xF3;n de la palabra &quot;Ej&#xE9;rcito&quot; y, agr&#xE9;guese la palabra &quot;Armada&quot;.</div><br></div>", "i": 7173603, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diez de Octubre de mil novecientos cincuenta y tres.- CARLOS IBA&#xD1;EZ DEL CAMPO.- A. Parra U. </div></div>", "i": 7173604}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11344", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11344"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "MODIFICA EL ARTICULO N.o 39 DEL DECRETO CON FUERZA DE LEY N.o 209, de 1953", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FUERZAS ARMADAS", "RETIRO", "MONTEPIO", "MODIFICACION", "OBREROS", "JORNALEROS", "ARMADA", "REGIMEN PREVISIONAL", "CAJA PREVISION DEFENSA NACIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1953-10-10", "doble_articulado": false, "id_norma": "26653", "numero_fuente": "22694", "tipo_version": "3", "tipo_version_s": "Única",