{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9498382}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.146 de 13 de agosto de 2014 de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1064545&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA;1.770 de 2014</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 9 B, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 9498383}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de agosto de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9498384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2146 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2146 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-08-13", "doble_articulado": false, "id_norma": "1065608", "numero_fuente": "40937", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-08-20", "vigencias": [{"desde": "2014-08-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-08-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-08-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modifi