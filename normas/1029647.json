{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9183662}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;1560 de fecha 29 de julio de 2011, se expropiaron los lotes de terreno N&#xBA;s 72 y 74, superficie 628 y 106 m2 respectivamente, rol N&#xBA;320-12, para la obra &quot;Camino Cauquenes - Chanco N&#xBA;Rol M-50, Sector Tutuven - Chanco, Tramo Km. 15,20000 a Km. 28,80000&quot;, Comunas de Cauquenes, Pelluhue y Chanco, Provincia de Cauquenes, Regi&#xF3;n del Maule y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario JOS&#xC9; LUIS CASTILLO ARELLANO Y OTRA, ascendente a la cantidad de $703.472.-</div></div>", "i": 9183663}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9183664}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1560 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1560 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-29", "doble_articulado": false, "id_norma": "1029647", "numero_fuente": "40062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-15", "vigencias": [{"desde": "2011-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ingreso": "2011-09-15", "fecha_ver