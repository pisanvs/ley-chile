{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 7338701}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que por resoluci&#xF3;n N&#xBA; E-189-2007, de fecha 15 de marzo de 2007, se cancel&#xF3; la autorizaci&#xF3;n de existencia de la sociedad &quot;Habitat Desarrollo Internacional S.A.&quot;, filial de la Administradora de Fondos de Pensiones Habitat S.A., por haber concurrido a su respecto, la causal de disoluci&#xF3;n establecida en el n&#xFA;mero 2) del art&#xED;culo 103 de la ley N&#xBA; 18.046, sobre Sociedades An&#xF3;nimas, esto es, haberse reunido todas las acciones en manos de una sola persona. Santiago, 15 de marzo de 2005.</div><br></div>", "i": 7338702}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Solange Berstein J&#xE1;uregui, Superintendenta de A.F.P.</div><br></div>", "i": 7338703}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "189", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-189"}, {"tipo": "3", "numero": "E-189-2007", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-E-189-2007"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARIA DE PREVISION SOCIAL", "SUPERINTENDENCIA DE ADMINISTRADORAS DE FONDOS DE PENSIONES"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["HABITAT DESARROLLO INTERNACIONAL S.A.", "EXISTENCIA LEGAL", "CANCELACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-03-15", "doble_articulado": false, "id_norma": "259684", "numero_fuente": "38728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-31", "vigencias": [{"desde": "2007-03-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "