{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 1,293.- Santiago, a 15 de Diciembre de 1899.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de siete mil quinientos pesos al &#xED;tem 685 de la partida 56 del presupuesto del Interior, correspondiente al Tel&#xE9;grafo del Estado, para atender al pago de mayores c&#xE1;nones de arrendamientos de las oficinas, pago de empleados suplentes i otros gastos imprevistos.</div><br><br></div>", "i": 8274239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- El&#xED;as Fern&#xE1;ndez A.</div><br></div>", "i": 8274240}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1293", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1293"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1899", "MODIFICACION", "MINISTERIO", "INTERIOR", "TELEGRAFOS ESTADO", "ARRIENDO OFICINAS", "EMPLEADOS", "SUELDOS", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-15", "doble_articulado": false, "id_norma": "22535", "numero_fuente": "6473", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-12-15", "vigencias": [{"desde": "1899-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "