{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8872097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1476 de 12 de Agosto de 1987, conforme art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parte del Proyecto de Parcelaci&#xF3;n &quot;El Parr&#xF3;n&quot;, de la comuna de Mar&#xED;a Pinto, Regi&#xF3;n Metropolitana, correspondiente a las parcelas N&#xB0;s. 1 a la 6 y 31 a la 60, sitios N&#xB0;s. 41 al 45, 47 al 53 y 55 al 63, formado por predio &quot;Santa Teresa formado por las hijuelas Santa Teresa de Lo Ovalle, El Parr&#xF3;n y Cancha de Piedra&quot;. Los derechos de agua se extraen del Estero Puangue y de dos pozos profundos.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme art. 13 Ley No. 18.377.- </div></div>", "i": 8872098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 8872099}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1476 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1476 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-12", "doble_articulado": false, "id_norma": "152109", "numero_fuente": "32847", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-17", "vigencias": [{"desde": "1987-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc