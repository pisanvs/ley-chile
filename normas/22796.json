{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede 3,000 pesos para la instalacion del Juzgado de Letras de Pisagua</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,621.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br></div>", "i": 5950717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de tres mil pesos en la instalacion del Juzgado de Letras de Pisagua. </div></div>", "i": 5950718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 6 de Noviembre de 1903.- JERMAN RIESCO.- Francisco J. Concha.</div><br><br><br></div>", "i": 5950719}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1621", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1621"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE 3,000 PESOS PARA LA INSTALACION DEL JUZGADO DE LETRAS DE PISAGUA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PISAGUA", "JUZGADO LETRAS", "FONDOS", "CONCESION", "INSTALACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-11-06", "doble_articulado": false, "id_norma": "22796", "numero_fuente": "7750", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-11-10", "vigencias": [{"desde": "1903-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-11-