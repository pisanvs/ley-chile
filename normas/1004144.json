{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8741652}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.044, de 9 de junio de 2009, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n exenta N&#xBA;439 de 2009, modificada mediante resoluci&#xF3;n exenta N&#xBA;1.244, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a MARES CHILE LIMITADA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Monitoreo de la pesquer&#xED;a de Congrio dorado y Raya en la Regi&#xF3;n de Magallanes y Ant&#xE1;rtica Chilena, 2009&quot;, en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la citada pesca de investigaci&#xF3;n hasta el d&#xED;a 30 de junio de 2009, inclusive.</div></div>", "i": 8741653}, {"t": "<div><div class=\"p\">&nbsp; Valpara&#xED;so, 9 de junio de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8741654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2044 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2044 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-09", "doble_articulado": false, "id_norma": "1004144", "numero_fuente": "39410", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-07-13", "vigencias": [{"desde": "2009-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia