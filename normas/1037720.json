{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISOR ELECTR&#xD3;NICO</div></div>", "i": 9240398}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 38, de 1 de marzo de 2012, que autoriza a contribuyentes como emisores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de documentos tributarios a contribuyentes RUT 99.581.430-7, RUT 76.934.290-7, RUT 76.830.030-5, RUT 96.858.440-5, RUT 79.605.650-9, RUT 76.021.031-5, RUT 77.832.800-3, RUT 96.934.730-K, RUT 76.100.531-6, RUT 76.006.366-5, RUT 76.699.530-6, RUT 99.516.970-3, RUT 76.182.531-3, RUT 76.782.750-4, RUT 86.383.800-2, RUT 76.332.410-9, RUT 76.205.060-9, RUT 77.842.750-8, RUT 76.355.950-5, RUT 76.037.969-7, RUT 76.181.893-7, RUT 79.967.370-3, RUT 77.573.560-0, RUT 76.153.986-8, RUT 96.637.520-5, RUT 78.952.610-9, RUT 78.413.030-4, RUT 76.619.410-9, RUT 76.144.941-9, RUT 08.488.051-5, RUT 85.475.200-6, RUT 79.894.010-4, RUT 78.464.570-3, RUT 96.936.630-4, RUT 78.708.490-7, RUT 79.769.000-7, RUT 77.528.610-5, RUT 78.950.580-2, RUT 76.240.240-8, RUT 76.140.031-2, RUT 76.136.173-2, RUT 76.037.125-4, RUT 96.806.010-4, RUT 76.057.010-9, RUT 76.564.340-6, RUT 96.635.520-4, RUT 76.044.946-6, RUT 76.082.927-7, RUT 76.319.070-6, RUT 96.812.070-0, RUT 76.047.741-9, RUT 96.969.120-5, RUT 93.135.000-5, RUT 76.049.203-5, RUT 77.800.010-5, RUT 91.903.000-3, RUT 90.828.000-8, RUT 76.167.346-7, RUT 76.711.200-9, RUT 76.092.210-2, RUT 76.105.518-6, RUT 86.146.400-8, RUT 89.502.700-6, RUT 80.752.000-8, RUT 76.333.370-1, RUT 96.832.030-0, RUT 76.830.910-8, RUT 84.634.200-1, RUT 76.179.476-0, RUT 83.414.900-1, RUT 76.168.155-9, RUT 77.803.570-7, RUT 76.090.724-3, RUT 96.847.590-8, RUT 76.693.390-4, RUT 77.120.160-1, RUT 76.161.255-7, RUT 76.014.051-1, RUT 78.098.060-5, RUT 76.180.171-6, RUT 76.000.562-2, RUT 99.507.910-0, RUT 79.839.670-6, RUT 78.141.380-1, RUT 78.633.080-7, RUT 76.014.748-6, RUT 99.562.840-6, RUT 77.90