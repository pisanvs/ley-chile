{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 68 EXENTO, DE 1994 </div></div>", "i": 8605583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 68 de fecha 9 de febrero de 1994 del Ministerio de Educaci&#xF3;n, se declar&#xF3; que para todos los efectos legales la denominaci&#xF3;n de la carrera aprobada para el Centro de Formaci&#xF3;n T&#xE9;cnica Instituto AIEP por Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 1596, de 21 de julio de 1982 y N&#xB0; 1027 de 4 de abril de 1989, es la siguiente:</div><div class=\"p\"> Carrera : Administraci&#xF3;n de Empresas con menci&#xF3;n en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Marketing</div><div class=\"p\"> T&#xED;tulo&nbsp; : T&#xE9;cnico en Administraci&#xF3;n de Empresas con</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  menci&#xF3;n en Marketing</div><br></div>", "i": 8605584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Marzo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8605585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "68", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-68"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 68 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARRERA PROFESIONAL", "CENTRO FORMACION TECNICA", "INSTITUTO AIEP", "ADMINISTRACION EMPRESAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-02-09", "doble_articulado": false, "id_norma": "19991", "numero_fuente": "34836", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-11", "vigencias": [{"desde": "