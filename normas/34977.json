{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 506, de 20 de Julio de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case en inciso 1&#xB0; del numeral 5&#xB0; de la Resoluci&#xF3;n N&#xB0; 300, de 1993, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD CATOLICA DE LA SANTISIMA CONCEPCION, R.U.T. N&#xB0; 71.915.800-5, para realizar una pesca de investigaci&#xF3;n sobre el recurso Calamar rojo o jibia, Dosidicus spp., en el sentido de reemplazarlo por el siguiente: &quot;La pesca de investigaci&#xF3;n que por la presente Resoluci&#xF3;n se autoriza tendr&#xE1; una duraci&#xF3;n de seis meses a contar del 21 de Julio de 1993&quot;.</div><br></div>", "i": 8292823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 20 de Julio de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8292824}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "506", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-506"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA INVESTIGACION", "UNIVERSIDAD CATOLICA SANTISIMA", "CONCEPCION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-20", "doble_articulado": false, "id_norma": "34977", "numero_fuente": "34628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-07-30", "vigencias": [{"desde": "1993-07-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "