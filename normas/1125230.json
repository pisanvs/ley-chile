{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA A INSTITUCIONES SIN FINES DE LUCRO, COMO RECEPTORAS Y/O DISTRIBUIDORAS DE ALIMENTOS CUYA COMERCIALIZACI&#xD3;N SEA INVIABLE</div></div>", "i": 9965832}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xBA; 109, de 9 de noviembre de 2018, autoriza a instituciones sin fines de lucro, como receptoras y/o distribuidoras de alimentos cuya comercializaci&#xF3;n sea inviable.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2018. </div></div>", "i": 9965833}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "109 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-109 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A INSTITUCIONES SIN FINES DE LUCRO, COMO RECEPTORAS Y/O DISTRIBUIDORAS DE ALIMENTOS CUYA COMERCIALIZACIÓN SEA INVIABLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1493906", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-11-09", "doble_articulado": false, "id_norma": "1125230", "numero_fuente": "42204", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-11-14", "vigencias": [{"desde": "2018-11-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-11-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2018-11-14", "f