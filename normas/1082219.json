{"html": [{"t": "<div><br><div class=\"p\">Ley n&#xFA;m. 8,223</div><br><div class=\"p\">DEROGA DISPOSICIONES LEGALES VIGENTES QUE ESTABLECEN COMO FERIADO LEGAL EL DIA 20 DE SEPTIEMBRE</div><br><br><div class=\"p\">&nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp;  Proyecto de ley:</div></div>", "i": 9639645}, {"t": "<div><br><div class=\"p\">&nbsp;  &quot;Art&#xED;culo 1.o Se derogan las disposiciones legales vigentes que establecen como feriado legal el d&#xED;a 20 de Septiembre.</div></div>", "i": 9639646}, {"t": "<div><br><div class=\"p\">&nbsp;  Art&#xED;culo 2.o Esta ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 9639647}, {"t": "<div><br><div class=\"p\">&nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto corno ley de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp;  Santiago, doce de Septiembre de mil novecientos cuarenta y cinco.- JUAN ANTONIO RIOS M.- Luis Alamos B.</div><br></div>", "i": 9639648}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "8223", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-8223"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DEROGA DISPOSICIONES LEGALES VIGENTES QUE ESTABLECEN COMO FERIADO LEGAL EL DIA 20 DE SEPTIEMBRE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1945-09-12", "doble_articulado": false, "id_norma": "1082219", "numero_fuente": "20255", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1945-09-13", "vigencias": [{"desde": "1945-09-13", "hasta": "", "tipo_version": "