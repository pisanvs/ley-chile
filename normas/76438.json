{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8307018}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.339, de 14 de octubre de 1997,</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la</div><div class=\"p\">solicitud de concesi&#xF3;n de acuicultura, solicitud N&#xBA;</div><div class=\"p\">94106048, presentada por CULTIVOS YADRAN S.A., para el</div><div class=\"p\">centro de cultivo ubicado en Punta Guacahue, Bah&#xED;a</div><div class=\"p\">Huellonquen, Isla Cail&#xED;n, Comuna de Quell&#xF3;n, Provincia</div><div class=\"p\">de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los</div><div class=\"p\">art&#xED;culos 14&#xBA;, del D.S. N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n y art&#xED;culos 78 y 87, de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8307019}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de octubre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8307020}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1339", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1339"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "CULTIVOS YADRAN S.A.", "DENEGACION", "QUELLON", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-14", "doble_articulado": false, "id_norma": "76438", "numero_fuente": "35897", "tipo_version": "3", "t