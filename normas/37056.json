{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.494, de 9 de agosto de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a CONSERVERA LEYMO S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Av. Bernardo O&apos;Higgins N&#xB0; 300, Calbuco, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Conserva, Congelado, Deshidratado y Seco-salado, los siguientes recursos hidrobiol&#xF3;gicos: Jibia, Erizo, Pepino de mar, Piure.</div><br></div>", "i": 8297524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 9 de agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297525}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1494", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1494"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "CONSERVERA LEYMO S.A.", "AMPLIACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-08-09", "fecha_derogacion": "1998-01-15", "doble_articulado": false, "id_norma": "37056", "numero_fuente": "35557-1", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-09-02", "vigencias": [{"desde": "1998-01-15", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-09-02", "hasta": "1998-01-14", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inic