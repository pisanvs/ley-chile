{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD PESQUERA BIO BIO LIMITADA PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br><br><br></div>", "i": 7268154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 78, del 04 de Enero de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Sociedad Pesquera B&#xED;o B&#xED;o Limitada, para operar la embarcaci&#xF3;n &quot;ICALMA&quot;, en la zona del litoral comprendida entre la IV y la VIII Regi&#xF3;n cuando efect&#xFA;e pesca de arrastre y en el litoral de la VIII cuando realice pesca de cerco. Con la embarcaci&#xF3;n se&#xF1;alada podr&#xE7; extraer: jurel, sardina espa&#xF1;ola, caballa, anchoa, sardina com&#xFA;n y merluza com&#xFA;n:</div><br></div>", "i": 7268155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 04 de Enero de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7268156}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "78", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-78"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD PESQUERA BIO BIO LIMITADA PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-01-04", "fecha_derogacion": "1996-01-09", "doble_articulado": false, "id_norma": "166578", "numero_fuente": "32102", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-02-20", "vigencias": [{"desde": "1996-01-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Últi