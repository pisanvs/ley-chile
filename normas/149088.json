{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 66, DE 1987 </div></div>", "i": 6211075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 66 de 31 de marzo de 1987 se ha modificado el decreto supremo exento de Educaci&#xF3;n No. 254 de 1981, que autoriz&#xF3; al &quot;Villa Mar&#xED;a Academy&apos;, de Santiago, para aplicar normas especiales de evaluaci&#xF3;n y promoci&#xF3;n escolar, en el sentido que se elimina en el art&#xED;culo 5&#xB0; la expresi&#xF3;n &quot;sin aproximaci&#xF3;n y sustit&#xFA;yese la coma (,) por un punto (.)&quot;. La modificaci&#xF3;n anterior, regir&#xE1; a contar desde el a&#xF1;o lectivo 1987. </div></div>", "i": 6211076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 02 de Abril de 1987.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6211077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "66 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-66 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 66, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-31", "doble_articulado": false, "id_norma": "149088", "numero_fuente": "32764", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-07", "vigencias": [{"desde": "1987-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe