{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8319748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 74, de 21 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la autorizaci&#xF3;n solicitada por PESQUERA ATITLAN S.A., para ampliar el plazo para iniciar actividades pesqueras con las naves &quot;Gustavo&quot; y &quot;Kristina&quot;, autorizadas por resoluciones N&#xBA; 601 y N&#xBA; 602 de 1996, de esta Subsecretar&#xED;a, por no haberse acreditado una circunstancia de fuerza mayor. </div></div>", "i": 8319749}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8319750}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "74", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-74"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA ATITLAN S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-21", "doble_articulado": false, "id_norma": "90950", "numero_fuente": "35978", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-30", "vigencias": [{"desde": "1998-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFIC