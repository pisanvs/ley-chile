{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6230758}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 800 de fecha 05 de Agosto de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana, se autoriza a do&#xF1;a Rina Astrid Maggi Zavala, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6230759}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 07 de 1986. Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana. </div></div>", "i": 6230760}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "800 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-800 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-05", "doble_articulado": false, "id_norma": "155012", "numero_fuente": "32.573", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-09-15", "vigencias": [{"desde": "1986-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-09-15", "fin_vigencia": "", "tipo_version": "