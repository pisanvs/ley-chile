{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9329631}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 166, de 17 de enero de 2013, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la <a href=\"https://www.leychile.cl/Navegar?idNorma=225349&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.316 de 2004</a>, que autoriz&#xF3; a Pesquera B&#xED;o-B&#xED;o S.A., hoy CAMANCHACA PESCA SUR S.A. para realizar actividades pesqueras extractivas con la nave denominada &quot;Duqueco&quot; en el &#xE1;rea mar&#xED;tima comprendida entre la III a VII y IX a X Regiones, sobre el recurso hidrobiol&#xF3;gico Jibia o Calamar rojo, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum t&#xE9;cnico citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9329632}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de enero de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9329633}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "166 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-166 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-01-17", "doble_articulado": false, "id_norma": "1048400", "numero_fuente": "40468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-25", "vigencias": [{"desde": "2013-01-25", "hasta": "", "ti