{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6392623}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;1.076 de 25 de julio de 2002, se dej&#xF3; sin efecto el decreto MOP exento N&#xBA;1.755 de fecha 21 de noviembre del 2001, en la parte que se refiere a la expropiaci&#xF3;n de los lotes N&#xBA;s. C1-14-A y C1-14-A1, roles de Aval&#xFA;o N&#xBA;s. 31-6 y 31-11, comuna de Curacav&#xED;, superficies 94,50 m&#xB2;. respectivamente, que figuran a nombre de Dur&#xE1;n Cerda F&#xE9;lix E. y Dur&#xE1;n Cerda Georgina. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.-</div><br></div>", "i": 6392624}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6392625}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1076 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1076 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-07-25", "doble_articulado": false, "id_norma": "201506", "numero_fuente": "37335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-16", "vigencias": [{"desde": "2002-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificac