{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7430184}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 529, de 06 de octubre de 1989, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza en forma complementaria a la empresa argentina La Uni&#xF3;n del Sud Sociedad de Responsabilidad Limitada, para efectuar servicio internacional de transporte terrestre de pasajeros entre Zapala (Argentina) y Temuco (Chile), utilizando el paso Pino Hachado, efectuando cuatro frecuencias semanales de ida y vuelta.</div><br></div>", "i": 7430185}, {"t": "<div><div class=\"p\">Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 7430186}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "529", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-529"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-06", "doble_articulado": false, "id_norma": "92661", "numero_fuente": "33510", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-31", "vigencias": [{"desde": "1989-10-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-10-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-10-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}, {"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "PMZ", "fecha_i