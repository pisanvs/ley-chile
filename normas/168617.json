{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8910374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 847, de 5 de mayo de 2000, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las</div><div class=\"p\">resoluciones N&#xBA; 1.065, de 1988, N&#xBA; 1.173, de 1991 y N&#xBA;</div><div class=\"p\">1.096, de 1992, de esta Subsecretar&#xED;a, que autorizaron a</div><div class=\"p\">PESQUERA GUIMAR S.A., para operar la nave &apos;&apos;Barba</div><div class=\"p\">Negra&apos;&apos;, matr&#xED;cula 2719, en virtud de lo se&#xF1;alado en el</div><div class=\"p\">art&#xED;culo 143 letra b) del D.S. N&#xBA; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, por no haber operado la mencionada nave por m&#xE1;s de doce meses en las pesquer&#xED;as autorizadas.</div><br></div>", "i": 8910375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de mayo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 8910376}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "847", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-847"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-05", "doble_articulado": false, "id_norma": "168617", "numero_fuente": "36662", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-13", "vigencias": [{"desde": "2000-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen