{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Sustitucion del inciso 59 del articulo 7.&#xB0; de la lei n&#xFA;m. 980</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,166.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Sustit&#xFA;yese el inciso 59 (no numerado) del art&#xED;culo 7.&#xB0; de la lei n&#xFA;mero 980 de 23 de Diciembre de 1897, por este otro:</div><div class=\"p\">&nbsp; &nbsp; &quot;Hilos e hilados para tejer, bordar o marcar.&quot; </div><br></div>", "i": 5948477}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 9 de Enero de 1899.- FEDERICO ERRAZURIZ.- R. Sotomayor.</div><br></div>", "i": 5948478}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1166", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1166"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SUSTITUCION DEL INCISO 59 DEL ARTICULO 7.° DE LA LEI NUM. 980", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS INTERNACION", "HILOS", "HILADOS", "LIBERACION", "ORDENANZA", "ADUANAS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-01-09", "doble_articulado": false, "id_norma": "22442", "numero_fuente": "6196", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-01-09", "vigencias": [{"desde": "1899-01-09", "hasta": "", "tipo_ve