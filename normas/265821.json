{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 277.- Santiago, 6 de agosto de 2007.- Vistos: Lo dispuesto en el Art. 4&#xBA; del decreto ley N&#xBA; 2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7356745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Ministros de Fe para actuar en las localidades ubicadas en la X Regi&#xF3;n, en que no haya Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><br><div class=\"p\">- Ernesto Alejandrino Schwerter Birke - RUT 7.165.635-7 - Sergio Alejandro Galaz Sanzana - RUT 10.619.171-9. </div></div>", "i": 7356746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hern&#xE1;n Rojas Olavarr&#xED;a, Director Nacional.</div><br></div>", "i": 7356747}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "277", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-277"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO DE DESARROLLO AGROPECUARIO", "MINISTROS DE FE", "DECIMA REGION", "DESIGNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-06", "doble_articulado": false, "id_norma": "265821", "numero_fuente": "38892", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-22", "vigencias": [{"desde": "2007-10-22", "hasta": "", "tipo_version": "3", "tipo_versi