{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;mero 4,532</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6211244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; Lib&#xE9;ranse de derechos de internaci&#xF3;n, hasta por la suma de cuatro mil quinientos pesos ($ 4,500) moneda legal, un caj&#xF3;n que contiene una estatua de bronce y dos cajones con m&#xE1;rmoles, el primero con peso 270 k. y los segundos, con 1,076 K., llegados a Valpara&#xED;so por el vapor &quot;Taormina&quot;, y destinados al mausoleo que la Colonia Italiana posee en el Cementerio General de Santiago.</div><br></div>", "i": 6211245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a quince de Enero de mil novecientos veintinueve.-&nbsp; Carlos Ib&#xE1;&#xF1;ez C.- Pablo Ram&#xED;rez. </div></div>", "i": 6211246}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4532", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4532"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-01-15", "doble_articulado": false, "id_norma": "149139", "numero_fuente": "15275", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-01-17", "vigencias": [{"desde": "1929-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i