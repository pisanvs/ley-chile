{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.767 EXENTA, DE 2015</div></div>", "i": 9659781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.767, de fecha 11 de junio de 2015, que modifica la resoluci&#xF3;n exenta N&#xBA; 491, de 26 de septiembre de 1989, que aprueba el programa de ense&#xF1;anza para obtenci&#xF3;n de licencia de conductor Clase B, a la Escuela de Conductores No Profesionales o Clase B &quot;Instituto de Conductores Godoy&quot;, cuyo propietario y director es el se&#xF1;or Daniel Alberto Godoy L&#xF3;pez, RUT N&#xBA; 3.294.821-9, en el sentido de aprobar el cambio de domicilio de la escuela ubicada en Gran Avda. Jos&#xE9; Miguel Carrera N&#xBA; 7954, comuna de La Cisterna. </div></div>", "i": 9659782}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mat&#xED;as Salazar Zegers, Secretario Regional Ministerial Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div></div>", "i": 9659783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2767 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2767 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.767 EXENTA, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 980877; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-06-11", "doble_articulado": false, "id_norma": "1085872", "numero_fuente": "41343", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-12-29", "vigencias": [{"desde": "2015-12-29", "h