{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8317372}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 971, de 13 de Octubre de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n No. 160, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don FELIX PEDRO HEIN CERNOCH, R.U.T. No. 2.227.847-9, domiciliado en Los Carrera S/N&#xB0;, Maull&#xED;n, para operar un establecimiento de cultivo del recurso alga del g&#xE9;nero Gracilaria, en el R&#xED;o Cariquilda, Comuna de Maull&#xED;n, Provincia de Llanquihue, X&#xAA; Regi&#xF3;n, en un&nbsp; rea de 75.000 m2., por renuncia total de su titular, ya individualizado.</div><br></div>", "i": 8317373}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 13 de Octubre de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8317374}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "971", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-971"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-13", "doble_articulado": false, "id_norma": "85796", "numero_fuente": "34397", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-10-23", "vigencias": [{"desde": "1992-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-10-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-10-23", "fin_vigencia": "", "tipo_version": "