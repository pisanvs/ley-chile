{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Goce del rango de oficiales</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de Febrero de 1818.</div></div>", "i": 9965693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Los individuos que forman los distinguidos cuerpos de las lejiones de honor de voluntarios de infanter&#xED;a de arjentinos, i caballer&#xED;a de Chile, deben gozar del rango de oficiales, i ser respetados por la tropa del ej&#xE9;rcito como tales, gozando de la misma distincion en las concurrencias p&#xFA;blicas en que asistan.-</div></div>", "i": 9965694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;se en la &#xF3;rden del dia, para que por los comandantes de los cuerpos de l&#xED;nea i nacionales se haga saber a sus tropas, insert&#xE1;ndose tambien en la Gazeta.- Cruz.</div><br></div>", "i": 9965695}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "20", "numero": "S/N", "abreviacion": "ORD", "descripcion": "Orden", "compuesto": "Orden-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Goce del rango de oficiales", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1818-02-16", "doble_articulado": false, "id_norma": "1124394", "numero_fuente": "1818", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1818-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1818-02-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1818-02-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2018-11-14", "fecha_version": "18