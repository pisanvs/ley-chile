{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6445012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.546, de 17 de octubre de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 2.496 de 2000, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA PACIFICO SUR S.A. para realizar actividades con la nave &quot;Don Enrique&quot;, sobre el recurso Alfonsino, en el &#xE1;rea mar&#xED;tima de la I Regi&#xF3;n, en el &#xE1;rea comprendida entre el l&#xED;mite norte de la III Regi&#xF3;n y el paralelo 41&#xB0;28,6&apos; L.S., y en el Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Islas Desventuradas e Isla de Pascua. </div></div>", "i": 6445013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6445014}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2546 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2546 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-17", "doble_articulado": false, "id_norma": "216260", "numero_fuente": "37693", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-24", "vigencias": [{"desde": "2003-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-10-24", "fin_vigencia": "", "tipo_version": "3"}],