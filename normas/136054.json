{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 82, DE 1988 </div></div>", "i": 7248429}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 82 de 20 de abril de 1988 se ha aprobado para el Liceo Industrial B No. 124 de Melipilla, provincia de Melipilla, Regi&#xF3;n Metropolitana, un plan y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar de 1988 y hasta el a&#xF1;o escolar de 1989, en la Rama Agr&#xED;cola, Especialidad Agr&#xED;cola. </div></div>", "i": 7248430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de abril de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7248431}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "82 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-82 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°  82, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-20", "doble_articulado": false, "id_norma": "136054", "numero_fuente": "33068", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-11", "vigencias": [{"desde": "1988-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-05-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci