{"html": [{"t": "<div><div class=\"p\">DESIGNA&nbsp; COMO&nbsp; RECEPTOR&nbsp; JUDICIAL A FUNCIONARIA QUE</div><div class=\"p\">INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 144.- Santiago, 12 de mayo de 1999.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6173190}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, I Regi&#xF3;n, a la siguiente funcionaria.</div><br><div class=\"p\">- Marina Leonor Roa&nbsp; Rodr&#xED;guez</div><br></div>", "i": 6173191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Luis Marambio Canales, Director Nacional.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud., para su conocimiento.- Encargado Oficina de Partes.</div><br></div>", "i": 6173192}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "144", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-144"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIA QUE INDICA", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-05-12", "fecha_derogacion": "2011-02-17", "doble_articulado": false, "id_norma": "137787", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-06-16", "vigenc