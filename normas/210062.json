{"html": [{"t": "<div><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A ESTER NU&#xD1;EZ VIUDA DE QUINTEROS</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6423130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Ester Nu&#xF1;ez viuda de Quinteros una pensi&#xF3;n de $35.000 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande el cumplimiento de esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.</div><br></div>", "i": 6423131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticinco de Noviembre de mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- Roberto Vergara H.</div><br></div>", "i": 6423132}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13886", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13886"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA ESTER NUÑEZ VIUDA DE\nQUINTEROS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-11-25", "doble_articulado": false, "id_norma": "210062", "numero_fuente": "24517", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-12-14", "vigencias": [{"desde": "1959-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen