{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 616.- Santiago, 16 de octubre de 1925.- Vistos estos antecedentes, y teniendo presente que no hai conveniencia en interrumpir la publicaci&#xF3;n de la Recopilaci&#xF3;n de Leyes por &#xF3;rden num&#xE9;rica, de la cual est&#xE1; encargada la Secretar&#xED;a del Consejo de Estado, y de acuerdo con el Consejo de Ministros del Despacho, dicto el siguiente DECRETO-LEI:</div><br></div>", "i": 8256465}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Suplem&#xE9;ntase en la cantidad de veintiseis quinientos pesos ($ 26,500), el n&#xFA;mero 108, de la partida 2.a del Presupuesto del Interior, destinados a los gastos que demande la publicaci&#xF3;n de la Recopilacion de Leyes, por &#xF3;rden num&#xE9;rico.</div><br></div>", "i": 8256466}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, rej&#xED;strese, comun&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- Luis Barros Borgo&#xF1;o.- Manuel E. V&#xE9;lis.</div><br></div>", "i": 8256467}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "616", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-616"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GASTOS NACION", "A O", "1925", "MODIFICACION", "MINISTERIO INTERIOR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-10-16", "doble_articulado": false, "id_norma": "6231", "numero_fuente": "14304", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-10-23", "vigencias": [{"desde": "1925-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"