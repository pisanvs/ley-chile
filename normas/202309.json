{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6395378}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.482 de 19 de julio de 2002, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 1.341 de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Esfuerzo de la pesca artesanal de merluza del sur en la zona Chilo&#xE9; - Palena, 2002&quot;, en el sentido de se&#xF1;alar que el l&#xED;mite de captura autorizado para el mes de julio ascender&#xE1; a 217 toneladas.</div><br></div>", "i": 6395379}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de julio de 2002.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6395380}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1482", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1482"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-07-19", "doble_articulado": false, "id_norma": "202309", "numero_fuente": "37352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-05", "vigencias": [{"desde": "2002-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-09-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [