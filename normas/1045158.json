{"html": [{"t": "<div><br><div class=\"p\">Ley n&#xFA;m. 8,109</div><br><div class=\"p\">AUTORIZA AL PRESIDENTE DE LA REPUBLICA PARA RECONOCER LA EXISTENCIA DEL ESTADO DE GUERRA ENTRE CHILE Y EL JAPON</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div></div>", "i": 9309772}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico: Autor&#xED;zase al Presidente de la Rep&#xFA;blica para reconocer la existencia del estado de guerra entre Chile y el Jap&#xF3;n.&quot;</div></div>", "i": 9309773}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, once de Abril de mil novecientos cuarenta y cinco.- JUAN ANTONIO R&#xCD;OS M.- Joaqu&#xED;n Fern&#xE1;ndez.</div><br></div>", "i": 9309774}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "8109", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-8109"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "AUTORIZA AL PRESIDENTE DE LA REPUBLICA PARA RECONOCER LA EXISTENCIA DEL ESTADO DE GUERRA ENTRE CHILE Y EL JAPON", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1945-04-11", "doble_articulado": false, "id_norma": "1045158", "numero_fuente": "20130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1945-04-13", "vigencias": [{"desde": "1945-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in