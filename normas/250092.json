{"html": [{"t": "<div><div class=\"p\">Ordena medidas a tomar para prevenir riesgos de inundaciones durante el per&#xED;odo de lluvias.</div><br></div>", "i": 6571480}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se informa a todos los canalistas y usuarios de esta regi&#xF3;n que la Direcci&#xF3;n Regional de Aguas ha emitido la resoluci&#xF3;n D.G.A.R.M. N&#xBA; 507 de fecha 13/04/2006, que ordena medidas a tomar para prevenir riesgos de inundaciones durante el per&#xED;odo de lluvias. EL texto completo estar&#xE1; a disposici&#xF3;n d elos interesados en Bombero Salas N&#xBA; 1351, piso 5&#xBA;. P&#xE1;gina www.dga.cl </div></div>", "i": 6571481}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  EL DIRECTOR REGIONAL DIRECCION</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; GENERAL DE AGUAS R.M</div><br></div>", "i": 6571482}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "507", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-507"}], "organismos": ["DIRECCIÓN GENERAL DE AGUAS REGIÓN METROPOLITANA"], "titulo_norma": "ORDENA MEDIDAS A TOMAR PARA PREVENIR RIESGOS DE INUNDACIONES DURANTE EL PERIODO DE LLUVIAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INUNDACIONES POR LLUVIAS", "MEDIDAS DE PREVENCION", "REGION METROPOLITANA", "TEMPORALES DE LLUVIA", "CANALISTAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-13", "doble_articulado": false, "id_norma": "250092", "numero_fuente": "38478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-01", "vigencias": [{"desde": "2006-06-01", "hasta": "", "tipo_version": "3", "tipo_version_