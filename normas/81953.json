{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 141, DE 1991 </div></div>", "i": 7216918}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 141 de fecha 25 de Junio de 1991 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; el plan y programa de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Superior de T&#xE9;cnicas de la Comunicaci&#xF3;n Isteco, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 1991:</div><div class=\"p\">Carrera: Fotograf&#xED;a Period&#xED;stica</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Fotograf&#xED;a Period&#xED;stica. </div></div>", "i": 7216919}, {"t": "<div><div class=\"p\">Santiago, 21 de Agosto de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7216920}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "141 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-141 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 141, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-25", "doble_articulado": false, "id_norma": "81953", "numero_fuente": "34059", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-03", "vigencias": [{"desde": "1991-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i