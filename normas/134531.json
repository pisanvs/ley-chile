{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,008.- Santiago, 18 de enero de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6162668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Disp&#xE9;nsase, por gracia, al capitan de Ej&#xE9;rcito don Jos&#xE9; Manuel Latorre, el a&#xF1;o de servicio en cuerpo que la lei de 23 de setiembre de 1890 exije, para que pueda ser ascendido al empleo inmediatamente superior, cuando por su antig&#xFC;edad le corresponda.</div><br></div>", "i": 6162669}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Patricio Larra&#xED;n A.</div><br></div>", "i": 6162670}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1008", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1008"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-18", "doble_articulado": false, "id_norma": "134531", "numero_fuente": "5908", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-21", "vigencias": [{"desde": "1898-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-01-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad