{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6495722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.362, de 27 de agosto de 2004, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 888 de 2001, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto que autoriz&#xF3; a PESQUERA MAR PROFUNDO S.A. para operar la nave &quot;Arauco I&quot;, entre la I a III Regiones, con palangre, sobre el recurso hidrobiol&#xF3;gico Reineta, entre la I a III Regiones, con palangre, sobre el recurso hidrobiol&#xF3;gico Alfonsino, y entre la I a X Regiones, con trampas, sobre el recurso hidrobiol&#xF3;gico Alfonsino, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6495723}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6495724}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2362 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2362 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-27", "doble_articulado": false, "id_norma": "229972", "numero_fuente": "37954", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-04", "vigencias": [{"desde": "2004-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-04", "fin_vigencia": ""}, "vigencias_versi