{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 140 EXENTO, DE 1995 </div></div>", "i": 5941786}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 140 de 27 de Febrero de 1995, se ha autorizado al Colegio Teresiano &quot;Enrique de Oss&#xF3;&quot; de la Comuna de La Reina, Regi&#xF3;n Metropolitana, para agregar, a contar del a&#xF1;o escolar 1995, la asignatura de Computaci&#xF3;n para los cursos de 1&#xB0; a 7&#xB0; a&#xF1;o, y a contar del a&#xF1;o escolar 1996, para el 8&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio de la asignatura de Computaci&#xF3;n para los cursos de 1&#xB0; a 8&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica.</div><br></div>", "i": 5941787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 07 de Marzo de 1995.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 5941788}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "140", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-140"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 140 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO TERESIANO ENRIQUE DE OSSO", "LA REINA", "REGION METROPOLITANA ASIGNATURA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-02-27", "doble_articulado": false, "id_norma": "20376", "numero_fuente": "35123", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-21", "vigencias": [{"desde": "1995-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única