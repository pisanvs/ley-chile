{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6509404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA;1.614 de 24 de noviembre</div><div class=\"p\">de 2004, y en base a la facultad otorgada por el</div><div class=\"p\">art&#xED;culo 105 del DFL MOP N&#xBA;850 de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA;15.840, se expropi&#xF3; el lote de terreno N&#xBA;110-A, para la obra: Camino Santa Cruz - Y&#xE1;quil, Rol I-730, km. 0,00000 a km. 7,46939, que figura a nombre de N&#xFA;&#xF1;ez Cancino Elcira, rol de aval&#xFA;o 609-6, comuna de Santa Cruz, VI Regi&#xF3;n, superficie 142 m&#xB2;. La Comisi&#xF3;n de Peritos fij&#xF3; con fecha 14 de marzo de 2003 en la cantidad de $629.600.- lote N&#xBA;110-A. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.</div><br></div>", "i": 6509405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6509406}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1614 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1614 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-24", "doble_articulado": false, "id_norma": "233725", "numero_fuente": "38036", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-15", "vigencias": [{"desde": "2004-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenci