{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;NEANDRO SHILLINS&quot; AL LICEO DE HOMBRES DE SAN FERNANDO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7175477}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Denom&#xED;nase &quot;Neandro Schilling&quot; al Liceo de Hombres de San Fernando&quot;.</div><br></div>", "i": 7175478}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, siete de Octubre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Moore Montero.</div><br></div>", "i": 7175479}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14132", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14132"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DENOMINA NEANDRO SHILLINS AL LICEO DE HOMBRES DE SAN FERNANDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "LICEO HOMBRES", "SAN FERNANDO", "LICEO NEANDRO SCHILLING"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-10-07", "doble_articulado": false, "id_norma": "27702", "numero_fuente": "24774", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-10-21", "vigencias": [{"desde": "1960-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1960-10-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1960-10-21", "fin_vigencia": "