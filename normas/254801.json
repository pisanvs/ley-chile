{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6588173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xB0; 618 de fecha 31 de julio del 2006, se expropi&#xF3; el lote terreno N&#xB0; 1, superficie 9.924,63 m2, Rol N&#xB0; 383-3, comuna de Pitrufqu&#xE9;n, IX Regi&#xF3;n para la obra &quot;Dise&#xF1;o Definitivo de la Red Secundaria y Terciaria de Canales de Riego Proyecto Faja Maisan, Canal Quinque&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Ricardo Brun Frey y otros, ascendente a la cantidad de $6.474.869.- para el lote N&#xB0; 1.</div><br></div>", "i": 6588174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6588175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "618", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-618"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-31", "doble_articulado": false, "id_norma": "254801", "numero_fuente": "38603", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-02", "vigencias": [{"desde": "2006-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-11-02", "fecha_version": "2006-11-02", "fecha_actualizacion_texto": "2006-11-02", "tipo_tratado": ""}, "alert