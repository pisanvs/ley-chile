{"html": [{"t": "<div><div class=\"p\">MINISTRO PLENIPOTENCIARIO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Mayo 14 de 1824.</div></div>", "i": 10075377}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Todos los pliegos de correspondencia que se dirijan al Ministro Plenipotenciario del Gobierno de los Estados Unidos de Norte Am&#xE9;rica, y al C&#xF3;nsul Jeneral de S.M.B. residentes cerca del Gobierno de este Estado, se declaran libres de todo porte. Comun&#xED;quese al Administrador jeneral de la renta de Correos, e ins&#xE9;rtese en el Boletin.</div></div>", "i": 10075378}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Benavente.</div></div>", "i": 10075379}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "MINISTRO PLENIPOTENCIARIO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-05-14", "doble_articulado": false, "id_norma": "1138787", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-05-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2019-12-03", "fecha_version": "1824-05-14", "fecha_actualizacion_texto": "1824-05-14", "tip