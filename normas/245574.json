{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6554618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.139, del 30 de noviembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a ATACAMA BIO NATURAL PRODUCTS SOCIEDAD ANONIMA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden de instalar y operar una planta ubicada en Fundo San Antonio, Ruta A-665, comuna de Pozo Almonte, Provincia de Iquique, II Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Extracto Aceite o CO2, Polvo de Microalgas y Polvo de Microalgas Aceite, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6554619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6554620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4139 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4139 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-30", "doble_articulado": false, "id_norma": "245574", "numero_fuente": "38348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-28", "vigencias": [{"desde": "2005-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-12-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p