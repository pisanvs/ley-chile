{"html": [{"t": "<div><br><div class=\"p\">N&#xFA;mero de &#xF3;rden de algunas de las subdelegaciones del departamento de Talca</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, setiembre 12 de 1884.</div><br><div class=\"p\">&nbsp; &nbsp;  Vista la nota que antecede,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div></div>", "i": 9892383}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Habi&#xE9;ndose segregado del departamento de Talca las subdelegaciones n&#xFA;meros 17 a 24 inclusive, para agregarlas al departamento de Curepto, asignase los n&#xFA;meros 17, 18 i 19, respectivamente, a las subdelegaciones denominadas Pencahue, Fluvial de Perales i Matadero, del primero de dichos departamentos.</div></div>", "i": 9892384}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese i publ&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  SANTA MARIA.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  J. M. Balmaceda.</div></div>", "i": 9892385}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Número de órden de algunas de las subdelegaciones del departamento de Talca", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1884-09-12", "doble_articulado": false, "id_norma": "1112919", "numero_fuente": "1884", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1884-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1884-09-12", "fin_vige