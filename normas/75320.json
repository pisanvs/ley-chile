{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xBA; 925 de 1991 </div></div>", "i": 9048712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 925 de fecha 08.11.91, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza en forma complementaria a la empresa de origen paraguayo Expreso Brujula Sociedad An&#xF3;nima, para efectuar servicio internacional terrestre de pasajeros entre Asunci&#xF3;n (Paraguay) y Santiago (Chile), utilizando el paso fronterizo T&#xFA;nel Cristo Redentor (Sistema Cristo Redentor), realizando una (1), frecuencia semanal de ida y vuelta.-</div><br></div>", "i": 9048713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes.-</div><br></div>", "i": 9048714}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "925 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-925 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA Nº 925 de 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "EXPRESO BRUJULA SOCIEDAD ANONIMA", "SERVICIO DE PASAJEROS", "SERVICIO INTERNACIONAL TERRESTRE", "PARAGUAY", "CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-08", "doble_articulado": false, "id_norma": "75320", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-22", "vigencias": [{"desde": "1991-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-22", "fin_vigencia": ""}, "vigencias_version_norm