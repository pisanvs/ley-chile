{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 15.671 EXENTA, DE 2002 </div><br></div>", "i": 6418906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 15.671 de 30</div><div class=\"p\">de diciembre del a&#xF1;o 2002, se ha aprobado al Instituto</div><div class=\"p\">Art&#xED;stico de Estudios Secundarios de la comuna de Santiago, Regi&#xF3;n Metropolitana, de la Facultad de Artes de la Universidad de Chile, un plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para el Subsector de &quot;Dise&#xF1;o M&#xFA;ltiple y Est&#xE9;tica II&quot; de la Formaci&#xF3;n Diferencial.</div><br></div>", "i": 6418907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de enero de 2003.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6418908}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "15671 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-15671 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 15.671 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-30", "doble_articulado": false, "id_norma": "208857", "numero_fuente": "37521", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-28", "vigencias": [{"desde": "2003-03-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-28", "fin_vigencia": ""}, "vig