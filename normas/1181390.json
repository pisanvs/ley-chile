{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10365938}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xB0; 625 de 17 de agosto de 2022, se tuvo por desistida la expropiaci&#xF3;n de los lotes de terreno N&#xB0;s 42 y 47, ordenada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1134490&amp;idVersion=2022-09-15\">Decreto MOP (Exento) N&#xB0; 555 de 8 de julio de 2019</a>, para la obra &quot;Relicitaci&#xF3;n Concesi&#xF3;n Camino Nogales - Puchuncav&#xED;, Sector: Sector 1 (Ruta F-20), Subsector: Plaza Peaje - Fin Cuesta, Km. 6.500,00 al Km. 19.000,00&quot;, Comuna de Puchuncav&#xED;, Provincia de Valpara&#xED;so, Regi&#xF3;n de Valpara&#xED;so. En todo lo no modificado se mantiene plenamente vigente el Decreto Exento MOP N&#xB0; 555 de 8 de julio de 2019. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xB0; y 32&#xB0; del Decreto Ley N&#xB0; 2186, de 1978.</div><br></div>", "i": 10365939, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div><br></div>", "i": 10365940}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "625 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-625 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2184731", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-08-17", "doble_articulado": false, "id_norma": "1181390", "numero_fuente": "43354", "tipo_version": "3", "tipo_version_s": "Única", "f