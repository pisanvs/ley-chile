{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7269838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 400 de 12 de Abril de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 625, de 1989, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a EMPRESA PESQUERA NICHIRO CHILE LTDA., domiciliada en La Pastora No. 138, piso 3, Las Condes, Santiago, para el cultivo de 25.000 ovas de salm&#xF3;n sockeye en la localidad de Puerto Montt, en el sentido de eliminar en el numeral 2 la autorizaci&#xF3;n otorgada respecto del recurso salm&#xF3;n sockeye (Oncorhynchus nerka).</div><br></div>", "i": 7269839}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de Abril de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7269840}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "400", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-400"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-04-12", "doble_articulado": false, "id_norma": "168835", "numero_fuente": "33950", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-23", "vigencias": [{"desde": "1991-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien