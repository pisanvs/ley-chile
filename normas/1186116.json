{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10386824}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP. N&#xB0;1226, de 09 de noviembre de 2022, se modific&#xF3; y desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xB0;73, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1138260&amp;idParte=&amp;idVersion=\">Decreto (Exento) MOP. N&#xB0;1186, de 14 de octubre de 2019</a>, reduci&#xE9;ndose la superficie expropiada a 1.022 m2.; modificando el numeral primero y segundo de dicho Decreto, se&#xF1;alando como kilometraje de inicio, Km. 30,58540, nuevo propietario ALMONACID OJEDA ALBERTO y rol de aval&#xFA;o 162-99, de la comuna de Quemchi, expropiado para la ejecuci&#xF3;n de obra &quot;Mejoramiento Ruta W-175 Sector: Linao - Quemchi, Comuna de Quemchi, Regi&#xF3;n de Los Lagos&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xB0; y 32&#xB0; del Decreto Ley N&#xB0;2186, de 1978. </div></div>", "i": 10386825}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10386826}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1226 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1226 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2231795", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-11-09", "doble_articulado": false, "id_norma": "1186116", "numero_fuente": "43426", "tipo_version": "3", "tipo_version_s": "Única