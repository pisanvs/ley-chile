{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION EXENTA No. 347, DE 1987</div><br><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 636 exenta.- Santiago, 22 de Junio de 1987.- Visto: El Decreto Supremo No. 83 de 1985, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7258710}, {"t": "<div><div class=\"p\">Art&#xED;culo &#xFA;nico.- Sustit&#xFA;yese en el art&#xED;culo 1&#xB0; de la resoluci&#xF3;n exenta No. 347/87, en la categor&#xED;a vial Colectora - Distribuidora, lo siguiente:</div><div class=\"p\">&quot;Av. Jos&#xE9; Miguel Infante&quot; por &quot;Av. Jos&#xE9; Manuel Infante&quot;.</div><br><br></div>", "i": 7258711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Enrique Escobar Rodr&#xED;guez, General de Aviaci&#xF3;n, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 7258712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "636 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-636 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA RESOLUCION EXENTA No. 347, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-22", "doble_articulado": false, "id_norma": "151143", "numero_fuente": "32816", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-10", "vigencias": [{"desde": "1987-