{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0;3.226 EXENTA, DE 2013</div></div>", "i": 9352035}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 3.226, de 30 de abril de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Sinecio Leal Carrasco, Otec Capacitaci&#xF3;n E.I.R.L. (Centro de Educaci&#xF3;n y Capacitaci&#xF3;n de Chile E.I.R.L.)&quot;, RUT 76.086.323-8, contenida en la resoluci&#xF3;n exenta N&#xB0; 5.953, de 23 de junio de 2010, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xB0; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9352036}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9352037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3226 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3226 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N°3.226 EXENTA, DE 2013", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-04-30", "fecha_derogacion": "2013-06-06", "doble_articulado": false, "id_norma": "1050967", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-05-11", "vigencias": [{"desde": "2013-06-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2013-05-11", "hasta": "2013-06-05", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2