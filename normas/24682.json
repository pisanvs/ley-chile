{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar, con una pensi&#xF3;n anual de $ 3,000, al guardi&#xE1;n de la C&#xE1;mara de Diputados, don Ismael Jorquera Silva.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8277434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese al guardi&#xE1;n de la C&#xE1;mara de Diputados, don Ismael Jorquera Silva, derecho a jubilar, con una pensi&#xF3;n anual de tres mil pesos. </div></div>", "i": 8277435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecinueve de Julio de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Guillermo Edwards Matte. </div></div>", "i": 8277436}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4354", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4354"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Concede derecho a jubilar, con una pensión anual de;$ 3,000, al guardián de la Cámara de Diputados, don;Ismael Jorquera Silva.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ISMAEL JORQUERA SILVA", "PENSION JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-07-19", "doble_articulado": false, "id_norma": "24682", "numero_fuente": "15135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-07-28", "vigencias": [{"desde": "1928-07-28", "hasta": "", "tipo_version": "3", "ti