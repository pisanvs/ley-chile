{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6084906}, {"t": "<div><div class=\"p\">El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 11,79% anual durante el mes de Febrero de 1990. Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de febrero de 1990, fue de 12,17% anual.</div><br></div>", "i": 6084907}, {"t": "<div><div class=\"p\">Santiago, 05 de marzo de 1990.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino.</div><br></div>", "i": 6084908}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-05", "doble_articulado": false, "id_norma": "90182", "numero_fuente": "33613", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-06", "vigencias": [{"desde": "1990-03-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-02-18", "fecha_version": "1990-03-06", "fecha_act