{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xB0; 1306 </div></div>", "i": 6591158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 1306, celebrada el 23 de noviembre de 2006, adopt&#xF3; el siguiente Acuerdo:</div><div class=\"p\">1306-01-061123 - Modifica Cap&#xED;tulo III.F.6 del Compendio de Normas Financieras.</div><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar en el Cap&#xED;tulo III.F.6 del Compendio de Normas Financieras, la expresi&#xF3;n &quot;2006&quot; por &quot;2007&quot;.</div><div class=\"p\">&nbsp; &nbsp;  Esta modificaci&#xF3;n entrar&#xE1; en vigencia el 1 de enero de 2007.</div><br></div>", "i": 6591159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de noviembre de 2006.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6591160}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "S/N", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-S/N"}, {"tipo": "23", "numero": "1306", "abreviacion": "SES", "descripcion": "Sesión", "compuesto": "SES-1306"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N° 1306", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPENDIO DE NORMAS FINANCIERAS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-23", "doble_articulado": false, "id_norma": "255643", "numero_fuente": "38626", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-29", "vigencias": [{"desde": "2007-01-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "20