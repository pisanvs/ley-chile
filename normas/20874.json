{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 278, DE 1990 </div></div>", "i": 8605601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 278 de fecha 25 de octubre de 1990 del Ministerio de Educaci&#xF3;n, se insert&#xF3; en la Resoluci&#xF3;n Exenta N&#xB0; 2917 de 1982 del Centro de Formaci&#xF3;n T&#xE9;cnica ECACEC, las adecuaciones introducidas a las carreras de Contabilidad con menci&#xF3;n en Finanzas y Administraci&#xF3;n de Empresas con menci&#xF3;n en Finanzas y en la Resoluci&#xF3;n Exenta N&#xB0; 1211 de 1987, las adecuaciones introducidas a la carrera de T&#xE9;cnico en Auditor&#xED;a, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1990.- </div></div>", "i": 8605602}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 8605603}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "278 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-278 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 278, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EDUCACION", "ESTABLECIMIENTOS EDUCACIONALES", "CENTRO", "FORMACION TECNICA ECACEC", "CONTABILIDAD", "TECNICO", "AUDITORIA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-25", "doble_articulado": false, "id_norma": "20874", "numero_fuente": "34012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-09", "vigencias": [{"desde": "1991-07-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-07-09", "fin_vigencia": ""}