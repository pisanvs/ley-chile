{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 74 EXENTO, DE 1999</div><br><br><br></div>", "i": 6185279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 74, de 23 de marzo de 1999, se ha aprobado al Colegio &apos;&apos;Lirima&apos;&apos; de Iquique, un plan de estudio para 5&#xBA; a&#xF1;o (NB.3) de Ense&#xF1;anza B&#xE1;sica, que comenzar&#xE1; a aplicarse a partir del a&#xF1;o escolar 1999.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio para todos los subsectores de aprendizaje (asignaturas) del plan de estudio aprobado precedentemente, excepto el subsector de Religi&#xF3;n.</div><br></div>", "i": 6185280}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de marzo de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6185281}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "74 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-74 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 74 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-23", "doble_articulado": false, "id_norma": "141418", "numero_fuente": "36449", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-26", "vigencias": [{"desde": "1999-08-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-08-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-08-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones