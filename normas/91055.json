{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8319838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 90, de 21 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud presentada por COMPA&#xD1;IA INMOBILIARIA Y DE INVERSIONES TRICELTA LIMITADA, para ampliar el plazo de inicio de actividades pesqueras extractivas autorizadas por Resoluci&#xF3;n N&#xBA; 284 de 1996 de esta Subsecretar&#xED;a, por no haberse acreditado debidamente una causal de caso fortuito o fuerza mayor.</div><br></div>", "i": 8319839}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8319840}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "90", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-90"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "COMPA IA INMOBILIARIA Y DE INVERSIONES TRICELTA LIMITADA", "AMPLIACION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-21", "doble_articulado": false, "id_norma": "91055", "numero_fuente": "35978", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-30", "vigencias": [{"desde": "1998-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi