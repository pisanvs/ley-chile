{"html": [{"t": "<div><div class=\"p\">AUTORIZA POR CAUSA DE FUERZA MAYOR MEDIDAS QUE INDICA, PREVIA EVALUACI&#xD3;N T&#xC9;CNICA</div></div>", "i": 10111004}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta n&#xFA;mero 565, de 16 de marzo de 2020, de este Servicio, autoriza por causa de fuerza mayor medidas que indica, previa evaluaci&#xF3;n t&#xE9;cnica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10111005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, a 16 de marzo de 2020.- Alicia Gallardo Lagno, Directora Nacional del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 10111006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "565 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-565 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA POR CAUSA DE FUERZA MAYOR MEDIDAS QUE INDICA, PREVIA EVALUACIÓN TÉCNICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1745668", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2020-03-16", "fecha_derogacion": "2022-01-04", "doble_articulado": false, "id_norma": "1143845", "numero_fuente": "42617", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2020-03-28", "vigencias": [{"desde": "2022-01-04