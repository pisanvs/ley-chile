{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6180658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 53/99 de 21 junio de 1999, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se aprob&#xF3; el contrato de concesi&#xF3;n adjudicada mediante resoluci&#xF3;n exenta N&#xBA;41/99 de la misma Secretar&#xED;a Regional, a la sociedad Ormaz&#xE1;bal Hijos Limitada para operar, por un plazo de seis a&#xF1;os a contar de la publicaci&#xF3;n del presente extracto, una planta revisora ubicada en Avda. Industrial N&#xBA; 7200, Antofagasta, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6180659}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gast&#xF3;n Viveros Viveros, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n de Antofagasta.</div><br></div>", "i": 6180660}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "53", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-53"}, {"tipo": "3", "numero": "53/99", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-53/99"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-21", "doble_articulado": false, "id_norma": "140077", "numero_fuente": "36430", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-04", "vigencias": [{"desde": "1999-08-04", "hasta": "", "tipo_version": "3