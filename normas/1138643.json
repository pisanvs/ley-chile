{"html": [{"t": "<div><div class=\"p\">DELEGA FACULTAD PARA ENAJENAR ACCIONES DE PROPIEDAD DEL SERVICIO DE IMPUESTOS INTERNOS</div></div>", "i": 10068295}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 125, de 12 de noviembre de 2019, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Delega facultad de enajenar acciones que indica, de propiedad del Servicio de Impuestos Internos, y de suscribir en su representaci&#xF3;n todos los documentos que para tales fines resulten necesarios, en el Jefe de Adquisiciones.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div><br></div>", "i": 10068296}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "125 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-125 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DELEGA FACULTAD PARA ENAJENAR ACCIONES DE PROPIEDAD DEL SERVICIO DE IMPUESTOS INTERNOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1681635; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-11-12", "doble_articulado": false, "id_norma": "1138643", "numero_fuente": "42503", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-11-15", "vigencias": [{"desde": "2019-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-11-15", "fin_vige