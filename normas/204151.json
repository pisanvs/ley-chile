{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;28 EXENTA, DE 2002 </div></div>", "i": 6401522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;28 Ex., de fecha 28 de octubre de 2002, se prorroga la vigencia de la resoluci&#xF3;n N&#xBA; Ex.</div><div class=\"p\">40, de 14 de septiembre de 2001, que dispone el cambio de sujeto opcional de derecho del IVA por el per&#xED;odo comprendido entre el 1&#xBA; de noviembre de 2002 hasta el 30 de octubre de 2003, ambas fechas inclusive.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra incluido en el sitio web del Servicio en Internet, cuya direcci&#xF3;n es www.sii.cl y adem&#xE1;s, se publicar&#xE1; en Bolet&#xED;n del SII del mes de octubre de 2002.</div><br></div>", "i": 6401523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alfredo Echeverr&#xED;a Herrera, Director (S). </div></div>", "i": 6401524}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "28 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-28 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº28 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-28", "doble_articulado": false, "id_norma": "204151", "numero_fuente": "37399", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-11-04", "vigencias": [{"desde": "2002-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-11-04", "fin_vigencia": ""}, "vigencias_versi