{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 232 EXENTO, DE 1997 </div></div>", "i": 6032595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 232 de fecha 18 de febrero de 1997 del Ministerio de Educaci&#xF3;n, se ampli&#xF3; el per&#xED;odo de ejecuci&#xF3;n del &quot;Plan Especial de Titulaci&#xF3;n&quot; para los alumnos egresados en el per&#xED;odo 1983-1991 del Centro de Formaci&#xF3;n T&#xE9;cnica INACAP y que de acuerdo a disposiciones reglamentarias se encuentra con su plazo de titulaci&#xF3;n vencido, durante el plazo de un a&#xF1;o, y se aplicar&#xE1; por &#xFA;nica vez s&#xF3;lo a las promociones antes indicadas.</div><br></div>", "i": 6032596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de&nbsp; febrero de 1997.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6032597}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "232 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-232 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 232 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AMPLIACION", "PLANES DE ESTUDIO", "CENTRO DE FORMACION TECNICA INACAP", "PROGRAMAS DE ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-02-18", "doble_articulado": false, "id_norma": "70034", "numero_fuente": "35720", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-19", "vigencias": [{"desde": "1997-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-03-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic