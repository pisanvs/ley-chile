{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 562 EXENTO, DE 1994 </div></div>", "i": 5945238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento de Educaci&#xF3;n N&#xB0; 562, de fecha 21 de Noviembre de 1994, se ha adecuado, a partir de 1995, el plan de estudio de 7&#xB0; y 8&#xB0; A&#xF1;o B&#xE1;sico de la Escuela N&#xB0; 225 &quot;Eleuterio Ram&#xED;rez Molina&quot;, de la Comuna de Pe&#xF1;alol&#xE9;n, Regi&#xF3;n Metropolitana, aumentando de 6 a 8 horas el n&#xFA;mero de clases semanales de la Asignatura de Castellano, suprimiendo la Asignatura de Franc&#xE9;s. </div></div>", "i": 5945239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 5 de Diciembre de 1994.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945240}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "562", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-562"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 562 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION", "ESCUELA N 225 ELEUTERIO RAMIREZ MOLINA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-11-21", "doble_articulado": false, "id_norma": "21469", "numero_fuente": "35040", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-14", "vigencias": [{"desde": "1994-12-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-12-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-12-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi