{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 5, DE 1988 </div></div>", "i": 6167512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 5 de 20 de enero de 1988 se ha aprobado, a contar del a&#xF1;o lectivo 1988 y por un periodo de 4 a&#xF1;os, con car&#xE1;cter de experimental a la Escuela Especial D No. 597 de La Cisterna, provincia de Santiago, Regi&#xF3;n Metropolitana, dependiente de la I. Municipalidad de La Cisterna, un plan de estudio de capacitaci&#xF3;n laboral para educandos sordos.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para el plan aprobado en el art&#xED;culo 1&#xB0; del presente decreto. </div></div>", "i": 6167513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 06 de Mayo de 1988.- Mar&#xED;a Piedad Ruiz Ferreras, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6167514}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-5 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 5, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-20", "doble_articulado": false, "id_norma": "136062", "numero_fuente": "33070", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-13", "vigencias": [{"desde": "1988-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"in