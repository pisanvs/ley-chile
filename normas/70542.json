{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 269 EXENTO, DE 1997 </div></div>", "i": 6034118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 269 de 13 de marzo de 1997, se ha aprobado al Colegio &quot;The English Institute&quot; de Santiago, un plan de estudio para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o (NB.1 y NB.2) de ense&#xF1;anza b&#xE1;sica, que se comenzar&#xE1;n a aplicar a partir del a&#xF1;o escolar 1997, de acuerdo a lo que establece el art&#xED;culo 4&#xBA; del Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para la asignatura (Subsector de Aprendizaje: Lenguaje y Comunicaci&#xF3;n) de Ingl&#xE9;s.</div><br></div>", "i": 6034119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de marzo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6034120}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "269 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-269 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 269 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO THE ENGLISH INSTITUTE", "SANTIAGO", "REGION METROPOLITANA", "PLANES DE ESTUDIO", "ENSE ANZA BASICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-13", "doble_articulado": false, "id_norma": "70542", "numero_fuente": "35736", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-09", "vigencias": [{"desde": "1997-04-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig