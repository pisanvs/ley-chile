{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6275162}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 844, de 5 de mayo de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones N&#xBA; 216, de 1990 y N&#xBA; 77, de 1991, de esta Subsecretar&#xED;a, que autorizaron a SOCIEDAD AGRICOLA, FORESTAL Y PESQUERA YBAR Y ABAD COMPA&#xD1;IA LIMITADA, para operar la nave &apos;&apos;Bruma&apos;&apos;, matr&#xED;cula 566 de Constituci&#xF3;n, en virtud de lo se&#xF1;alado en el art&#xED;culo 143 letra b) del D.S. N&#xBA; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, por no haber operado la mencionada nave por m&#xE1;s de doce meses en las pesquer&#xED;as autorizadas.</div><br></div>", "i": 6275163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de mayo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6275164}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "844", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-844"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-05", "doble_articulado": false, "id_norma": "168614", "numero_fuente": "36662", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-13", "vigencias": [{"desde": "2000-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20