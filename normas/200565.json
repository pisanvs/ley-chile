{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE LOS ANDES</div><br><br></div>", "i": 6389288}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero, mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 1.844, del 27 de junio de 2001, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, determin&#xF3; Derechos de Aprovechamiento de Aguas proporcionales entre los Sitios 2-A, 2-B, 4-A, 4-B, 5, 6, 13, 14, 15, 16-A, 16-B, 17-A, 17-B, 18, 19, 20, 21, 22, 23, 24, 25-A, 25-B, 26, 27-A y 27-B del Proyecto de Parcelaci&#xF3;n &quot;El Sauce&quot;, de la Comuna de Los Andes, V Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Los derechos de aguas se extraen del Canal Los Quilos, derivado del r&#xED;o Aconcagua.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13 ley N&#xBA; 18.377.-</div><br></div>", "i": 6389289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Nacional </div></div>", "i": 6389290}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1844 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1844 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE LOS ANDES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-27", "doble_articulado": false, "id_norma": "200565", "numero_fuente": "37308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-15", "vigencias": [{"desde": "2002-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "