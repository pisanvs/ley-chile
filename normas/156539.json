{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6235899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xB0; 157 de 31 de enero de 1986, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos de Aprovechamiento de Aguas proporcionales que corresponden a Reserva y Sector Expropiado Predio &quot;Fundo La Manresa&quot; de la comuna de Talagante, Regi&#xF3;n Metropolitana. Los Derechos de Agua se extraen del canal La Manresa y Derrames del Predio &quot;Hijuela Oriente, hoy Parcela Santa Mariana&quot;. Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377.</div><br></div>", "i": 6235900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6235901}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "157 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-157 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-31", "doble_articulado": false, "id_norma": "156539", "numero_fuente": "32411", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-01", "vigencias": [{"desde": "1986-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula