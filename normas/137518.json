{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,591.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 7249466}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a tres mil pesos ($ 3,000) al a&#xF1;o la pension de que disfruta actualmente do&#xF1;a Elvira Carrera Pinto, en virtud de la lei n&#xFA;mero 1,737, de 14 de julio de 1905.</div><br></div>", "i": 7249467, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto,&nbsp; prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintinueve de diciembre de mil novecientos once.-Ramon Barros Luco.- Alejandro Huneeus. </div></div>", "i": 7249468}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2591", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2591"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-12-29", "doble_articulado": false, "id_norma": "137518", "numero_fuente": "10168", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-12-30", "vigencias": [{"desde": "1911-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-12-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"tex