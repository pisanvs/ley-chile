{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza a la Municipalidad de Santiago para que se cambie el nombre de la calle de &quot;Claras&quot; por el de &quot;Enrique Mac-Iver&quot;.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277397}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Autor&#xED;zase a la Municipalidad de Santiago para que cambie el nombre de la calle de &quot;Claras&quot;, por el de &quot;Enrique Mac-Iver&quot;.</div><br></div>", "i": 8277398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, nueve de Febrero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Enrique Balmaceda. </div></div>", "i": 8277399}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4300", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4300"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA A LA MUNICIPALIDAD DE SANTIAGO PARA QUE SE CAMBIE EL NOMBRE DE LA CALLE DE CLARAS POR EL DE \"ENRIQUE MAC-IVER\".", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD", "SANTIAGO", "CALLE", "DENOMINACION", "CAMBIO", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-09", "doble_articulado": false, "id_norma": "24641", "numero_fuente": "15001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-16", "vigencias": [{"desde": "1928-02-16", "hasta": "", "tipo_version": "3", "