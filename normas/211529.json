{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 6.665 EXENTA, DE 2003 </div><br></div>", "i": 6428121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 6.665, de 30 de mayo del a&#xF1;o 2003, se han modificado, a partir del a&#xF1;o escolar 2003, las resoluciones exentas de Educaci&#xF3;n N&#xBA;s 366 y 12.383, ambas de 2001, y 5.253 de 2002, que aprobaron planes y programas especiales de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Colegio Apoquindo-Hombres, de la comuna de Lo Barnechea, provincia de Santiago, en el sentido de sustituir los planes de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, por los que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6428122}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de junio de 2003.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6428123}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6665 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-6665 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 6.665 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-30", "doble_articulado": false, "id_norma": "211529", "numero_fuente": "37590", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-23", "vigencias": [{"desde": "2003-06-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi