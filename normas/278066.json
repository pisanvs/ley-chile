{"html": [{"t": "<div><div class=\"p\">ACLARACI&#xD3;N </div></div>", "i": 6701083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La resoluci&#xF3;n N&#xBA; 6.125 de 11.08.2008 del Director Nacional de Aduanas, que actualiza el listado de objetos que estar&#xE1;n incluidos en el concepto de &quot;equipaje&quot; de cada viajero, fue publicada en el Diario Oficial los d&#xED;as 3 y 11 de septiembre del presente a&#xF1;o.</div><div class=\"p\">&nbsp; &nbsp;  Se comunica que para todos los efectos que involucra su aplicaci&#xF3;n, la fecha de publicaci&#xF3;n que se debe considerar es la del 3 de septiembre pasado.- </div></div>", "i": 6701084}, {"t": "<div><div class=\"p\">Director Nacional de Aduanas.</div><br></div>", "i": 6701085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS"], "titulo_norma": "ACLARACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "278066", "numero_fuente": "39165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-09-16", "vigencias": [{"desde": "2008-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-09-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-09-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "CMV", "fecha_ingreso": "2008-09-22", "fecha_version": "2008-09-16", "fecha_actualizacion_texto": "