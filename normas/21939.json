{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Montep&#xED;o Lei n&#xFA;m. 67.- Santiago, a 8 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Cogreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946661}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese por gracia a do&#xF1;a Mar&#xED;a Mercedes Fr&#xED;as, viuda del sarjento mayor graduado don Lorenzo Justiniano Sir, el goce de la pension de montep&#xED;o a que seria acreedora si hubiera obtenido el permiso necesario para contraer matrimonio, la que gozar&#xE1; en conformidad a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 5946662}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- V. D&#xE1;vila Larrain.</div><br></div>", "i": 5946663}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "67", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-67"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION DE MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MARIA MERCEDES FRIAS", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-08", "doble_articulado": false, "id_norma": "21939", "numero_fuente": "4593", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-11", "vigencias": [{"desde": "1893-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-11", "fin_vigencia": ""}, "vigencias_version_norma":