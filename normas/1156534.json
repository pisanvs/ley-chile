{"html": [{"t": "<div><div class=\"p\">Ley num. 7,455</div><br><div class=\"p\">&nbsp; &nbsp;  DISPONE QUE LA ESCUELA N.o 6 DE VILLA ALEGRE SE DENOMINARA &quot;TIMOTEO ARAYA ALEGRIA&quot;</div><br><div class=\"p\">&nbsp; &nbsp;  El Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley</div></div>", "i": 10256984}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. La Escuela N.o 6 de Villa Alegre se denominar&#xE1; en lo sucesivo &quot;Timoteo Araya Alegr&#xED;a&quot;.</div><br><div class=\"p\">&nbsp; &nbsp;  Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial&quot;.</div></div>", "i": 10256985}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de Julio de mil novecientos cuarenta y tres.- JUAN ANTONIO RIOS MORALES.- E.I. Marshall.</div></div>", "i": 10256986}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7455", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-7455"}], "organismos": ["MINISTERIO DE EDUCACION"], "titulo_norma": "DISPONE QUE LA ESCUELA N.o 6 DE VILLA ALEGRE SE DENOMINARA \"TIMOTEO ARAYA ALEGRIA\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1943-07-28", "doble_articulado": false, "id_norma": "1156534", "numero_fuente": "19683", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1943-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig