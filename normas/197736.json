{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 188 EXENTO, DE 2002 </div></div>", "i": 7291509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 188 de fecha 12 de marzo de 2002 del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas de estudios de la carrera de Gimnasia Jazz del Centro de Formaci&#xF3;n T&#xE9;cnica Estudio Profesor Valero, que se encuentran anexas y forman parte del presente decreto. Modif&#xED;case, en consecuencia, el decreto exento del Ministerio de Educaci&#xF3;n N&#xBA; 334 del 1 de julio de 1993, en el sentido de incorporar dichas adecuaciones.</div><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones que se aprueban mediante este decreto, podr&#xE1;n aplicarse a contar del a&#xF1;o 2002. </div></div>", "i": 7291510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de abril de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7291511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "188 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-188 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 188 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-03-12", "fecha_derogacion": "2021-06-30", "doble_articulado": false, "id_norma": "197736", "numero_fuente": "37250", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-05-04", "vigencias": [{"desde": "2021-06-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-05-04", "hasta": "2021-06-29", "tipo_version":