{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6555136}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.287, de 14 de diciembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EL GOLFO S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por las resoluciones citadas en visto, en orden a incorporar a su planta ubicada en Avenida Col&#xF3;n N&#xBA;2400, Talcahuano, VIII Regi&#xF3;n, en la l&#xED;nea de proceso de congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6555137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de diciembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6555138}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4287 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4287 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-14", "doble_articulado": false, "id_norma": "245709", "numero_fuente": "38351", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-31", "vigencias": [{"desde": "2005-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-12-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-01-02", "fecha_v