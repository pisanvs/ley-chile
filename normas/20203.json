{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 109 EXENTO DE 1994 </div></div>", "i": 7160563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 109 de 8 de marzo de 1994 se ha aprobado, al Colegio San Agust&#xED;n de Melipilla, un plan especial de estudio para Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, que se aplicar&#xE1; de acuerdo a la sigueinte calendarizaci&#xF3;n:</div><div class=\"p\">&nbsp; &nbsp; 1994=I y II a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica.</div><div class=\"p\">&nbsp; &nbsp; 1995=III a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica.</div><div class=\"p\">&nbsp; &nbsp; 1996=IV a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas de Introducci&#xF3;n al Desarrollo del Pensamiento L&#xF3;gico y Desarrollo Personal.</div><br></div>", "i": 7160564, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 21 de Marzo de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160565}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "109 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-109 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO N° 109 EXENTO DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO SAN AGUSTIN MELIPILLA", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-08", "doble_articulado": fals