{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6207866}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 79, de 12 de Mayo de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicacion&#xEB;s de la Regi&#xF3;n de Atacama, se a&#xFB;toriza al se&#xF1;or Manuel Avalos Puga para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 7 &quot;Universidad de Atacama - Estaci&#xF3;n Paipote&quot;, cuyo trazado fue autorizado por resoluci&#xF3;n No. 40, de 22 de Junio de 1087, de esta Secretar&#xED;a Regional. </div></div>", "i": 6207867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Antonio Aecvedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 6207868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "79 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-79 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-12", "doble_articulado": false, "id_norma": "148324", "numero_fuente": "32774", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-19", "vigencias": [{"desde": "1987-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-05-19", "fin_vigencia": "", "tipo_version"