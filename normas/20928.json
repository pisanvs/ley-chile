{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 296 EXENTO, DE 1996 </div></div>", "i": 7161524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 296 de fecha 27 de mayo de 1996 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica SOEDUC, las adecuaciones a los planes y programas de estudios de las carreras de An&#xE1;lisis de Sistemas y de Programaci&#xF3;n de Aplicaciones menci&#xF3;n Administrativo Contable, modific&#xE1;ndose, en consecuencia, la Resoluci&#xF3;n Exenta N&#xB0; 1.255 de 1989. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996.</div><br></div>", "i": 7161525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 14 de junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "296 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-296 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 296 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA SOEDUC", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-27", "doble_articulado": false, "id_norma": "20928", "numero_fuente": "35506", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-03", "vigencias": [{"desde": "1996-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-07-03", "fin_vige