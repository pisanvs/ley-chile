{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6278022}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 435 del 19 de Noviembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Primera Regi&#xF3;n, se autoriza a dona Mar&#xED;a Estela Ibarra Cornejo para efectuar el servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros &quot;L&#xED;nea N&#xB0; 6 Taxibuses de Arica&quot;, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xB0; 127, del 15 de Febrero de 1972, de esta Secretar&#xED;a Regional. </div></div>", "i": 6278023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial de Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6278024}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "435 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-435 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-19", "doble_articulado": false, "id_norma": "169542", "numero_fuente": "32932", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-28", "vigencias": [{"desde": "1987-11-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-28", "fin_vigencia": "",