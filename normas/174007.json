{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7275710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.685, de 31 de julio de 2000, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 1.458 de 1997, de esta Subsecretar&#xED;a, en</div><div class=\"p\">cuanto autoriz&#xF3; a don Tomas Hugo Quezada Bernal, para</div><div class=\"p\">operar la nave &apos;&apos;T&#xED;o Tom&#xE1;s&apos;&apos;, s&#xF3;lo en lo relativo al</div><div class=\"p\">recurso Camar&#xF3;n nailon, en el litoral de la V Regi&#xF3;n, de</div><div class=\"p\">conformidad con lo establecido en la letra b) del</div><div class=\"p\">art&#xED;culo 143 del D.S. N&#xBA; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 7275711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de julio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7275712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1685", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1685"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-31", "doble_articulado": false, "id_norma": "174007", "numero_fuente": "36735", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-09", "vigencias": [{"desde": "2000-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "