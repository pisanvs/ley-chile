{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO N&#xB0; 100, DE 1986 </div></div>", "i": 6229950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 100, de 06 de Junio de 1986, se ha prorrogado la vigencia del decreto supremo exento de Educaci&#xF3;n N&#xB0; 104, de 1983, que autoriz&#xF3; a la Corporaci&#xF3;n de Ayuda al Ni&#xF1;o Limitado, COANIL, para aplicar planes de estudio, a contar del presente a&#xF1;o lectivo y hasta el a&#xF1;o 1988, inclusive. </div></div>", "i": 6229951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6229952}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "100 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-100 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO N° 100, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-06", "doble_articulado": false, "id_norma": "154750", "numero_fuente": "32506", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-26", "vigencias": [{"desde": "1986-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-06-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-02-04", "fecha_version": "1986-06-26",