{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8353859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.338, de 18 de noviembre de 1999, de esta Subsecretar&#xED;a, rectif&#xED;quese la resoluci&#xF3;n N&#xBA; 2.252 de 1999, que declar&#xF3; la caducidad de la resoluci&#xF3;n N&#xBA; 688, de 1997, ambas de esta Subsecretar&#xED;a, en el sentido de se&#xF1;alar que la resoluci&#xF3;n caducada es la N&#xBA; 688 de 1987 de esta Subsecretar&#xED;a y no la que se se&#xF1;ala en esa resoluci&#xF3;n.</div><br></div>", "i": 8353860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de noviembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8353861}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2338", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2338"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-18", "doble_articulado": false, "id_norma": "148352", "numero_fuente": "36523", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-25", "vigencias": [{"desde": "1999-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-11-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JCT", "fecha_ingreso": "1999-11-25", "fecha_version