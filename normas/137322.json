{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,372.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a do&#xF1;a Ester, do&#xF1;a Elvira, do&#xF1;a Domitila, do&#xF1;a Pastorisa, do&#xF1;a C&#xE1;rmen i do&#xF1;a Ana Rosa Cruzat Fern&#xE1;ndez, nietas del coronel de la Independencia, don Santiago Fern&#xE1;ndez, una pension mensual de ciento veinte pesos, de que disfrutar&#xE1;n con arreglo a la lei de montep&#xED;o militar. </div></div>", "i": 6171560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, treinta i uno de agosto de mil novecientos diez.- El&#xED;as Fern&#xE1;ndez Albano.- C&#xE1;rlos Larrain Claro.</div><br></div>", "i": 6171561}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2372", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2372"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-08-31", "doble_articulado": false, "id_norma": "137322", "numero_fuente": "9783", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-09-01", "vigencias": [{"desde": "1910-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-09-01", "fin_vigencia": ""}, "vigencias_version_