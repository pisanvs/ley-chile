{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 100, DE 1989 </div></div>", "i": 7225961}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 100 de 12 de mayo de 1989 se ha sustituido, a contar del a&#xF1;o escolar 1989, el art&#xED;culo 5&#xB0; del decreto supremo exento de Educaci&#xF3;n No. 296 de 1981, agregado por decreto supremo exento de Educaci&#xF3;n No. 250, de 1987, sobre normas especiales de evaluaci&#xF3;n para el Instituto Comercial Alem&#xE1;n de Santiago. </div></div>", "i": 7225962}, {"t": "<div><div class=\"p\">Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7225963}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "100 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-100 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 100, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-12", "doble_articulado": false, "id_norma": "91302", "numero_fuente": "33412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-03", "vigencias": [{"desde": "1989-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMB", "fecha_ingreso": "1998-02-24", "fecha_version": "1989-07-03", "fecha_actualizacion_texto": "1989-07-03", "tipo_trata