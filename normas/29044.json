{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA ARTICULOS 446 Y 467 DEL CODIGO PENAL Por cuanto el H. Congreso Nacional ha dado su </div></div>", "i": 7179168}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Sustit&#xFA;yese en los art&#xED;culos 446 y 467 del C&#xF3;digo Penal, la expresi&#xF3;n &quot;un sueldo vital&quot; por &quot;medio sueldo vital.&quot;.</div><br></div>", "i": 7179169, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; SANTIAGO, dieciocho de Agosto de mil novecientos setenta y uno.- SALVADOR ALLENDE G.- LISANDRO CRUZ P.</div><div class=\"p\">&nbsp; &nbsp; Lo digo a U. para su conocimiento.- Dios guarde a U.- Jos&#xE9; A. Viera Gallo, Subsecretario de Justicia. </div></div>", "i": 7179170}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17472", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17472"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "MODIFICA ARTICULOS 446 Y 467 DEL CODIGO PENAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["APROBACION MODIFICACION", "CODIGO PENAL", "DELITO HURTO", "ROBO", "ESPECIE", "CASO AL SIGUIENTE PROYECTO DE LEY:"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1971-08-18", "doble_articulado": false, "id_norma": "29044", "numero_fuente": "28037", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1971-08-30", "vigencias": [{"desde": "1971-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1971-08-30", "