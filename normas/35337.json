{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293614}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 664, de 30 de Mayo de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 1061, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA RECURSOS MARITIMOS S.A., R.U.T. N&#xB0; 96.553.460-1, para iniciar actividades pesqueras con las naves &quot;Austral&quot; y &quot;Angelm&#xF3;&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143, letra b) de la Ley N&#xB0; 18.892, citada en Visto.</div><br><br></div>", "i": 8293615}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 30 de Mayo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293616}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "664", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-664"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESQUERA RECURSOS MARITIMOS S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-30", "doble_articulado": false, "id_norma": "35337", "numero_fuente": "35187", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-07", "vigencias": [{"desde": "1995-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-06-07", "fin_vigencia": "", "tipo_version": "3"}], "e