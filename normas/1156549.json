{"html": [{"t": "<div><div class=\"p\">MODIFICA FECHA DE ENTRADA EN VIGENCIA DE LAS RES. EX. N&#xBA; 108 Y N&#xBA; 165, DE 2020</div></div>", "i": 10207522}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 24, de fecha 26 de febrero de 2021, modifica fecha de entrada en vigencia de la resoluci&#xF3;n ex. SII <a href=\"https://www.leychile.cl/Navegar?idNorma=1149388&amp;idParte=&amp;idVersion=\">N&#xBA; 108</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1153961&amp;idParte=&amp;idVersion=\">N&#xBA; 165</a>, de 2020, que deja sin efecto las instrucciones relativas a vales en reemplazo de boletas y vales electr&#xF3;nicos en reemplazo de la boleta de ventas y servicios en la forma y condiciones que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><div class=\"p\"> </div><br></div>", "i": 10207523}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "24 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-24 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA FECHA DE ENTRADA EN VIGENCIA DE LAS RES. EX. Nº 108 Y Nº 165, DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1904603", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-02-26", "doble_articulado": false, "id_norma": "1156549", "numero_fuente": "42896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-03-04", "vigen