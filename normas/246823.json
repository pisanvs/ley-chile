{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6559235}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 245, de 24 de enero de 2006, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 4.568, de 2005, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Besugo Epigonus crassicaudus, declarada en estado de plena explotaci&#xF3;n y sometida a dicho r&#xE9;gimen de administraci&#xF3;n, en el &#xE1;rea mar&#xED;tima de la III a X Regiones, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, al 30 de diciembre de 2005, en el sentido de incluir en su numeral 1&#xBA; lo siguiente:</div><br><div class=\"p\">Armador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Nave</div><div class=\"p\">EL GOLFO S.A. PESQ.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Pelikan</div><br><br></div>", "i": 6559236}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6559237}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "245 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-245 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-24", "doble_articulado": false, "id_norma": "246823", "numero_fuente": "38375", "tipo_version": "3", "tipo_version_s": "Única",