{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6238336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 115, de 18 de Diciembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a Daniel Alvarez Brice&#xF1;o y otros, para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 4 &quot;Torreblanca - Avenida Matta&quot;, cuyo trazado que a continuaci&#xF3;n se indica fue autorizado por Resoluci&#xF3;n N&#xB0; 029, de 15 de Junio de 1984, de esta Secretar&#xED;a Regional.</div><div class=\"p\">&nbsp; &nbsp;  Ida: Avenida Matta - Merced - Brasil - Rafael Torreblanca.</div><div class=\"p\">&nbsp; &nbsp;  Regreso: Torreblanca - Brasil - Santiago Aldea - Colchagua - Ram&#xED;rez - Avenida Matta.</div><br></div>", "i": 6238337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sergio Antonio Acevedo Oyarce.- Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n de Atacama.</div><br></div>", "i": 6238338}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "115 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-115 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-18", "doble_articulado": false, "id_norma": "157384", "numero_fuente": "32377", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-21", "