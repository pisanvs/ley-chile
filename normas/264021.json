{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7351475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.245 de 27 de julio de 2007 de esta Subsecretar&#xED;a, autor&#xED;zase a RIGOBERTO FRANCISCO VARNET BARRIENTOS para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en la localidad de Piruquina Rural, Panamericana Norte Km 10, Castro, Chilo&#xE9;, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado, Congelado, Seco salado, Ahumado, Conserva y Alga seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. Valpara&#xED;so, 27 de julio de 2007.</div><br></div>", "i": 7351476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 7351477}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2245 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2245 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-27", "doble_articulado": false, "id_norma": "264021", "numero_fuente": "38844", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-22", "vigencias": [{"desde": "2007-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-08-22", "fin_vigencia": "", "tipo_versi