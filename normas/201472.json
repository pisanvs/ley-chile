{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6392530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;945, de fecha 31 de mayo de 2002, se expropi&#xF3; el lote de terreno N&#xBA;1-B, superficie 5.790 m2, rol de aval&#xFA;o N&#xBA;500-40, comuna de Saavedra, para la obra &apos;&apos;Camino Costero Sur, Sector Tranapuente - Puerto Saavedra - Porma, Tramo Tranapuente - Puerto Saavedra - Chelle, Km.</div><div class=\"p\">53.250,000 al Km. 56.315,096 y Km. 65.260,000 al Km. 100.240,000, correspondiente al subtramo II Km. 65.260 al Km. 67.577,949&apos;&apos;, IX Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Armin Fernando Luer Walper, ascendente a la cantidad de $4.665.555.-</div><br></div>", "i": 6392531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6392532}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "945 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-945 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-31", "doble_articulado": false, "id_norma": "201472", "numero_fuente": "37335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-16", "vigencias": [{"desde": "2002-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul