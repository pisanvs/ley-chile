{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9696547}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA;69 de 26/01/16. Exp. N&#xBA;1501908. Vistos: Ley N&#xB0;18.755; Ley N&#xBA;18.575, resoluci&#xF3;n N&#xBA;1.600/2008 de la CGR. Considerando: 1.- ADC N&#xB0;097147, que se&#xF1;ala que al revisar el equipaje, se encuentran 02 unidades de manzanas que no fueron declaradas. 2.- El infractor se&#xF1;ala que las manzanas las tra&#xED;a para comer durante el viaje. 3.- El infractor no registra denuncias anteriores. Resuelvo: Absu&#xE9;lvase por esta &#xFA;nica vez a don Seraf&#xED;n Condori D&#xED;az, Pasaporte N&#xBA;3016960, nacionalidad boliviana, domicilio indeterminado. </div></div>", "i": 9696548}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Firma: C&#xE9;sar Cardozo Rojas, Director Regional Regi&#xF3;n de Tarapac&#xE1; SAG.</div></div>", "i": 9696549}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "69 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-69 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO REGIÓN DE TARAPACÁ"], "titulo_norma": "NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1012763; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-01-26", "doble_articulado": false, "id_norma": "1089412", "numero_fuente": "41433", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-04-15", "vigencias": [{"desde": "2016-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2016-04-