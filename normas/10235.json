{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5897335}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto MOP. N&#xB0; 159, de 28 de mayo de 1993, se expropiaron los lotes de terreno N&#xB0;s 8, 12, 18 y 56, superficies 95 m2., 5.050 m2., 2.665 m2. y 3.250 m2., roles de aval&#xFA;o 149-6, 144.4, 149-5 y 35-1, Comunas de Nancagua y Ch&#xE9;pica, para la obra Camino Nancagua-Puquillay, Ch&#xE9;pica y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Soc. Agr&#xED;cola Casagrande Ltda., Mar&#xED;a Cristina Vera, Mar&#xED;a Luisa Concha Benavente y Rosario del C. Mu&#xF1;oz Navarro, ascendente a las cantidades de $ 376.476.-, $ 3.131. 820.-, $ 1.870.050.- y $ 1.986.500.-, respectivamente.- </div></div>", "i": 5897336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5897337}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "159", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-159"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DECRETO EXPROPIATORIO", "EXPROPIACION", "BIEN RAIZ", "BIEN INMUEBLE", "NANCAGUA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-05-28", "doble_articulado": false, "id_norma": "10235", "numero_fuente": "34615-3", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-07-15", "vigencias": [{"desde": "1993-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi