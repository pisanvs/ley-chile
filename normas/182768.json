{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 366 EXENTA, DE 2001 </div></div>", "i": 6326090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 366, de 15 de enero del a&#xF1;o 2001, se ha aprobado al Colegio Apoquindo Hombres, comuna de Lo Barnechea, de Santiago, un plan de estudio para 3&#xBA; a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6326091}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de enero de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6326092}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "366 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-366 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 366 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-15", "doble_articulado": false, "id_norma": "182768", "numero_fuente": "36911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-13", "vigencias": [{"desde": "2001-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "