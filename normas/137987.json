{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,646.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8345776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Aum&#xE9;ntase a la cantidad mensual de cien pesos ($ 100) la pension de que disfruta do&#xF1;a Felicia Toledo v. de Castro, por los servicios de Camilo Henr&#xED;quez, en conformidad a lo dispuesto en la lei de 30 de agosto de 1850.</div><br></div>", "i": 8345777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Valparaiso, dieciseis de febrero de mil novecientos doce.- Ramon Barros Luco.- Ismael Tocornal.</div><br></div>", "i": 8345778}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2646", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2646"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-02-16", "doble_articulado": false, "id_norma": "137987", "numero_fuente": "10229", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-03-15", "vigencias": [{"desde": "1912-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones