{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N 6.855 EXENTA, DE 2019</div></div>", "i": 10062165}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xBA; 6.855, de 27 de septiembre de 2019, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, aprueba Contrato Ad-Refer&#xE9;ndum de Concesi&#xF3;n 15 para operar una Planta Revisora Clase A en la comuna de El Bosque y una planta revisora clase AB en la comuna de Paine, celebrado entre el Ministerio de Transportes y Telecomunicaciones, a trav&#xE9;s de la referida Secretar&#xED;a Regional y &quot;Algoritmos y Mediciones Ambientales SpA&quot;, con vigencia de diez a&#xF1;os contados desde la publicaci&#xF3;n del presente extracto en el Diario Oficial.- </div><br></div>", "i": 10062166}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eddy Rold&#xE1;n Cabrera, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana de Santiago.</div><br></div>", "i": 10062167}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6855 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6855 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XIII REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN 6.855 EXENTA, DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1668071", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-09-27", "doble_articulado": false, "id_norma": "1137743", "numero_fuente": "42478", "tipo_version": "3", "tipo_version_s": "Única", "f