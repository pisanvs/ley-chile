{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6278973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;505, de 28 de febrero del 2000, se expropi&#xF3; el lote de terreno N&#xBA;89, superficie 4.846 m2., rol de aval&#xFA;o 600-10, comuna de Mulch&#xE9;n, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Chill&#xE1;n-Collipulli, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Delmira Humilde Morales Monsalve, ascendente a la cantidad de $2.781.860.-</div><br></div>", "i": 6278974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6278975}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "505", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-505"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-28", "doble_articulado": false, "id_norma": "169746", "numero_fuente": "36678", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-01", "vigencias": [{"desde": "2000-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-06-01", "fecha_version": "2000-06-01", "fecha_actualizacion_texto": "2000-06-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "