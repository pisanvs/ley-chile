{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 323, DE 1982</div><br><div class=\"p\">(Extracto) </div></div>", "i": 8549035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 841, de 10 de Noviembre de 1986 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n N&#xBA; 323, de 1982, de esa Subsecretar&#xED;a que autoriz&#xF3; a Empacadora del Pac&#xED;fico Limitada para operar una planta elaboradora de congelado, en las instalaciones de la Sociedad Agroindustrial Lo Espejo Ltda., en orden a incluir en el numeral 3&#xBA; de dicha resoluci&#xF3;n entre los recursos que podr&#xE1; utilizar la solicitante como materia prima en la elaboraci&#xF3;n de productos congelados el siguiente: langosta de Juan Fern&#xE1;ndez, Jasus frontalis. </div></div>", "i": 8549036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de Noviembre de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8549037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "841", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-841"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION Nº 323, DE 1982", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-11-10", "doble_articulado": false, "id_norma": "155741", "numero_fuente": "32628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-11-21", "vigencias": [{"desde": "1986-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i