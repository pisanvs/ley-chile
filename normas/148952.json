{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8354292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.315, de 15 de noviembre de 1999, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 2.314 de 1999, de esta Subsecretar&#xED;a que autoriz&#xF3; al INSTITUTO DE INVESTIGACION PESQUERA OCTAVA REGION, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto FIP N&#xBA; 99-14 denominado &apos;&apos;Condiciones Biol&#xF3;gicas del Jurel en Altamar&apos;&apos;, en el sentido de eliminar la nave &apos;&apos;Hilmir&apos;&apos;, de propiedad de Pesquera Qurbosa S.A. y de incorporar la nave &apos;&apos;Golondrina&apos;&apos;, de propiedad de Pesquera El Golfo S.A., en virtud de haberse incurrido en un error de hecho.</div><br></div>", "i": 8354293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de noviembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8354294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2315", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2315"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-15", "doble_articulado": false, "id_norma": "148952", "numero_fuente": "36532", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-06", "vigencias": [{"desde": "1999-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"