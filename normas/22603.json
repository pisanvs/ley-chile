{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 1,381.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949026}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. C&#xF3;nc&#xE9;dese un suplemento de sesenta mil pesos al &#xED;tem 16 de la partida 34 del presupuesto de Hacienda.</div><br></div>", "i": 5949027}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 14 de Noviembre de 1900.- FEDERICO ERRAZURIZ E.- Nicolas Gonz&#xE1;lez E.</div><br></div>", "i": 5949028}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1381", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1381"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1900", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-11-14", "doble_articulado": false, "id_norma": "22603", "numero_fuente": "6743", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-11-15", "vigencias": [{"desde": "1900-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-02-01", "fecha_vers