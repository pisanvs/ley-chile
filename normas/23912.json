{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,345, que suplementa el Presupuesto de Guerra.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,345.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7166570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de catorce mil doscientos pesos ($ 14,200) al &#xED;tem 203, partida 10, del Presupuesto de Guerra, que consulta fondos para atender a los gastos jenerales de la Escuela de Aeron&#xE1;utica Militar.</div><br></div>", "i": 7166571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a ocho de Enero de mil novecientos dieciocho.- JUAN LUIS SANFUENTES.- Oscar Viel. </div></div>", "i": 7166572}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3345", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3345"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NÚM. 3,345, QUE SUPLEMENTA EL PRESUPUESTO DE GUERRA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1917", "MODIFICACION", "ESCUELA", "AERONAUTICA MILITAR", "GASTOS GENERALES", "MINISTERIO", "GUERRA", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-01-08", "doble_articulado": false, "id_norma": "23912", "numero_fuente": "11972", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-01-16", "vigencias": [{"desde": "1918-01-16", "hasta": "", "tip