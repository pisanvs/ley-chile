{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6336846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 344, de fecha 30 de marzo de 2001, se expropiaron los lotes de terreno N&#xBA;s 18 y 23, superficies 844,5 M2 y 1.109,1 M2, roles de aval&#xFA;os 68-291 y 68-290, respectivamente, comuna de Temuco, para la obra &quot;Camino Teno - Maitenes, Sector La Monta&#xF1;a - Maitenes Tramo Km. 25,00046 al 27,61620&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Servando del Carmen Reyes Gonz&#xE1;lez, ascendente a la cantidad de $2.263.758.-</div><br></div>", "i": 6336847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6336848}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "344 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-344 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "185917", "numero_fuente": "36976", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-01", "vigencias": [{"desde": "2001-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-06-01", "fecha_version": "2001-06-01", "fecha_actualizacion_texto": "2001-06-01", "tipo