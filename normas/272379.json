{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7372781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 291 de fecha 30 de abril del 2008, se expropi&#xF3; el lote de terreno N&#xBA; 61-A, superficie 487,00 m2, rol N&#xBA; 2202-51, comuna de Puerto Montt, X Regi&#xF3;n para la obra &quot;Mejoramiento Ruta 7, sector Quillaipe - La Arena, tramo Km. 15,84700 a Km.</div><div class=\"p\">40,41746, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Mar&#xED;a Adelaida Gonz&#xE1;lez Igor y Otro, ascendente a la cantidad de $1.133.047.- para el lote N&#xBA;61-A.</div><br></div>", "i": 7372782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7372783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "291 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-291 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-30", "doble_articulado": false, "id_norma": "272379", "numero_fuente": "39088", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-06-16", "vigencias": [{"desde": "2008-06-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-06-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-06-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2008-06-18", "fecha_version": "2008-06-16", "fecha_actualizacion_texto": "2008