{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6550960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 1.196 de 14 de noviembre</div><div class=\"p\">de 2005, y en base a la facultad otorgada por el</div><div class=\"p\">art&#xED;culo 105 del D.F.L. M.O.P. N&#xBA;850, de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA;15.840, se dejaron sin efecto las expropiaciones de los lotes N&#xBA;1, expropiado mediante decreto MOP exento N&#xBA; 265 de 26 de abril de 2005 y del lote N&#xBA;1, expropiado mediante decreto exento N&#xBA; 266 de 26 de abril de 2005, en atenci&#xF3;n a que Aguas Araucan&#xED;a S.A., adquiri&#xF3; mediante compraventa el dominio del lote de terreno expropiado mediante decreto exento N&#xBA; 266 de 26 de abril de 2005 y suscribi&#xF3; contrato de promesa de compraventa respecto del lote expropiado mediante decreto MOP exento N&#xBA;265 de 26 de abril de 2005.</div><br></div>", "i": 6550961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6550962}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1196 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1196 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-11-14", "doble_articulado": false, "id_norma": "244540", "numero_fuente": "38326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-12-01", "vigencias": [{"desde": "2005-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini