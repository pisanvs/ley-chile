{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xB0; 1.669</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 1.669, celebrada el 31.07.85, adopt&#xF3; el siguiente acuerdo:</div><br></div>", "i": 6382534}, {"t": "<div><br><div class=\"p\">1669-19-850731 - Modifica Cap&#xED;tulo XIII del Compendio de Normas de Cambios Internacionales.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar en el inciso primero de la Disposici&#xF3;n Transitoria del Cap&#xED;tulo XIII &quot;Sistema para el Pago de Obligaciones Acuerdo 1657-03-850627&quot; del Compendio de Normas de Cambios Internacionales, la frase &quot;31.07.85&quot; por &quot;20.08.85&quot;.</div><br></div>", "i": 6382535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 01.08.85.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6382536}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1669", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1669"}, {"tipo": "5", "numero": "1669-19", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1669-19"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION N° 1.669", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-01", "doble_articulado": false, "id_norma": "198454", "numero_fuente": "32239", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-03", "vigencias": [{"desde": "1985-08