{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6097390}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 548 de 30 de mayo 1989 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.188 de 1978, -parte inmueble-, ubicado en calle Ricardo Santa Cruz No. 739-743, presunto rol aval&#xFA;os No. 596-12, comuna de Santiago, aparentemente dominio de do&#xF1;a Olga Moneta Ormaz&#xE1;bal. Comisi&#xF3;n integrada por peritos Ricardo Carvallo Rodr&#xED;guez y Luis del Pozo Concha, arquitectos y Ra&#xFA;l Varela Hern&#xE1;ndez, ingeniero civil, seg&#xFA;n informe de 2 de diciembre 1988, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 1.171.800.-, pagadera al contado.</div><br></div>", "i": 6097391}, {"t": "<div><div class=\"p\">- Director SERVIU Metropolitano.</div><br></div>", "i": 6097392}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "548", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-548"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-30", "doble_articulado": false, "id_norma": "94549", "numero_fuente": "33398", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-15", "vigencias": [{"desde": "1989-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fech