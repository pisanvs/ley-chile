{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Empleados de las C&#xE1;maras.- Gratificacion Lei n&#xFA;m. 1,010.- Santiago, a 24 de Enero de 1898.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Dest&#xED;nanse las sumas de diezisiete mil pesos i de dieziocho mil quinientos pesos a gastos de la Secretar&#xED;a del Senado i de la C&#xE1;mara de Diputados, respectivamente, debiendo invertirse de estas sumas las cantidades necesarias para pagar las gratificaciones acordadas por dichas Corporaciones a favor de sus empleados.</div><br><br></div>", "i": 8274052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Antonio Valdes C.</div><br></div>", "i": 8274053}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1010", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1010"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "EMPLEADOS DE LAS CAMARAS.- GRATIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMARA SENADORES", "CAMARA DIPUTADOS", "PERSONAL", "GRATIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-24", "doble_articulado": false, "id_norma": "22344", "numero_fuente": "5911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-25", "vigencias": [{"desde": "1898-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}