{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL ARTICULO 30&#xB0; DE LA LEY 6.382, DE 9 DE AGOSTO DE 1939, QUE ESTABLECIO LAS COOPERATIVAS DE PEQUE&#xD1;OS AGRICULTORES.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7175176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zanse en el art&#xED;culo 30 de la ley 6.382, de 9 de agosto de 1939, modificado por la ley 8.829, de 9 de septiembre de 1947, las palabras &quot;$ 150.000&quot;, por &quot;veinticinco sueldos vitales mensuales del departamento de Santiago.&quot;.</div><br></div>", "i": 7175177, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, trece de octubre de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Elzo Pertuiset.</div><br></div>", "i": 7175178}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13091", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13091"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "MODIFICA EL ARTICULO 30° DE LA LEY 6.382, DE 9 DE\nAGOSTO DE 1939, QUE ESTABLECIO LAS COOPERATIVAS DE\nPEQUEÑOS AGRICULTORES.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SANEAMIENTO", "TITULO DOMINIO", "DERECHO DOMINIO", "POSEEDOR MATERIAL", "PREDIO RUSTICO", "BIEN RAIZ AGRICOLA", "INMUEBLE AGRICOLA", "MONTO", "AVALUO FISCAL", "BENEFICIO", "MODIFICACION", "LEY 6382"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-10-13", "doble_artic