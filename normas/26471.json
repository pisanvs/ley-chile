{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CONDONA EL PAGO DEL IMPUESTO QUE INDICA A LA COMPA&#xD1;IA DEL TELEGRAFO COMERCIAL</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5968663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Cond&#xF3;nase a la Compa&#xF1;&#xED;a del Tel&#xE9;grafo Comercial el impuesto a la cifra de los negocios que estaba adeudando a la fecha en que entr&#xF3; en vigencia la ley N.o 10,268, de 4 de Marzo de 1952&quot;. </div></div>", "i": 5968664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, siete de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca Garnham.</div><br></div>", "i": 5968665}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10688", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10688"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONDONA EL PAGO DEL IMPUESTO QUE INDICA A LA\nCOMPAÑIA DEL TELEGRAFO COMERCIAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONDONACION", "COMPA IA TELEGRAFO COMERCIAL", "IMPUESTO", "CIFRA NEGOCIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-07", "doble_articulado": false, "id_norma": "26471", "numero_fuente": "22378", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-10-18", "vigencias": [{"desde": "1952-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ún