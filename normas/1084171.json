{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9650349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n Ex. N&#xBA; 1.121 de fecha 17 de noviembre de 2015, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=251259&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; Ex. 202 del 27.06.2006</a>, que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de contrato de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contraten, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Constructora Smithouse Limitada, RUT N&#xBA; 78.947.750-7, conforme a lo establecido en la Resoluci&#xF3;n Ex. N&#xBA; 142 de fecha 26.12.2005, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial de fecha 29.12.2005.</div><br></div>", "i": 9650350, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lidia Castillo Alarc&#xF3;n, Directora Regional.</div></div>", "i": 9650351}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1121 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1121 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 968268", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-11-17", "doble_articulado": false, "id_norma": "1084171", "numero_fuente": "41312", "tipo_versi