{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6112763}, {"t": "<div><div class=\"p\">Por decreto M.O.P. No. 123, de 13 de febrero de 1998, se expropi&#xF3; el lote de terreno No. 10, superficie 15.300 m., respectivamente, rol de aval&#xFA;o 62-189, comuna de &#xA5;iqu&#xE9;n, para la obra Ruta 5, Tramo Talca - Chill&#xE1;n, Intersecciones Desniveladas, Acceso a Tiuquilemu y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietaria do&#xF1;a Marta del Carmen Fuentes Acu&#xF1;a, ascendente a la cantidad de $ 35.466.554. </div></div>", "i": 6112764}, {"t": "<div><div class=\"p\">- Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6112765}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "123", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-123"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "IQUEN", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-13", "doble_articulado": false, "id_norma": "99915", "numero_fuente": "36078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-01", "vigencias": [{"desde": "1998-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-06-18", "fecha_version": "1998-06-01", "fecha_actualizacion_texto": "1998-06-01", "tipo_tratado": ""}, "alertas": [], "al