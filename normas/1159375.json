{"html": [{"t": "<div><div class=\"p\">Donativos patri&#xF3;ticos</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Diciembre 18 de 1817.</div></div>", "i": 10228405}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;nse las gracias a don Domingo Jos&#xE9; Toro por su jenerosa oblacion que consta de su memorial, que se imprimir&#xE1; con este decreto para su satisfaccion i del p&#xFA;blico. Pasen los 42 marcos 3 onzas de plata de chafalon&#xED;a a la tesorer&#xED;a jeneral, i las 25 mulas de carga i 7 caballos de buen estado al comisario jeneral de Chile y se tome razon.</div></div>", "i": 10228406}, {"t": "<div><br><br><div class=\"p\"> - Cruz. - Dr. Villegas.</div></div>", "i": 10228407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Donativos patrióticos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-12-18", "doble_articulado": false, "id_norma": "1159375", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-12-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ingreso": "2021-05-20", "fecha_version": "1817-12-18", "fecha_actualizacion_texto": "2021-05-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado"