{"html": [{"t": "<div><div class=\"p\">EXTRACTO </div></div>", "i": 6138764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta No. 7.118 de fecha 23 de Noviembre de 1988, Partido &quot;Avanzada Nacional&quot; comunica designaci&#xF3;n como miembro de su Directiva Central del se&#xF1;or Alvaro Julio Corbal&#xE1;n Castilla, en calidad de Director.</div><br><div class=\"p\">&nbsp; &nbsp;  Directiva Central queda constituida con:</div><br><div class=\"p\">&nbsp; &nbsp;  Presidente: Sergio Miranda Carrington Secretario: Sara M. Fornes Llona Tesorero: Patricio Vild&#xF3;sola Formas Directores: Jos&#xE9; Ram&#xF3;n Molina Fuenzalida, Jorge Arturo Prat Alemparte, Carlos Portales Astorga, Alvaro Julio Corbal&#xE1;n Castilla.</div><br></div>", "i": 6138765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Noviembre de 1988.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6138766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7118 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7118 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-11-23", "doble_articulado": false, "id_norma": "127019", "numero_fuente": "33231", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-11-26", "vigencias": [{"desde": "1988-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-11-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-11-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend