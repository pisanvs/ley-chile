{"html": [{"t": "<div><div class=\"p\">PARTIDO DEMOCRATA CRISTIANO</div><br><br></div>", "i": 6279510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ricardo Hormaz&#xE1;bal S&#xE1;nchez, Presidente de la Directiva Central, y don Jos&#xE9; Ar&#xE9;valo Medina, Presidente del Tribunal Supremo del Partido Dem&#xF3;crata Cristiano, informan la nueva composici&#xF3;n de la Directiva Central del partido.</div><br><div class=\"p\">DIRECTIVA CENTRAL:</div><div class=\"p\">Presidente&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Ricardo Hormaz&#xE1;bal S&#xE1;nchez</div><div class=\"p\">Primer Vicepresidente&nbsp; : Carmen Frei Ruiz-Tagle Segundo Vicepresidente : Gast&#xF3;n Luis Pareto Gonz&#xE1;lez Tercer Vicepresidente&nbsp; : Marcelo Rodr&#xED;guez Concha</div><div class=\"p\">Secretario Nacional&nbsp; &nbsp; : Edgardo Riveros Mar&#xED;n</div><div class=\"p\">Tesorero&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Diego M&#xE9;ndez Amor</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O N&#xBA;0190, de fecha 29 de mayo de 2000.</div><br></div>", "i": 6279511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6279512}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "190", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-190"}, {"tipo": "3", "numero": "O-0190", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-0190"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO DEMOCRATA CRISTIANO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO DEMOCRATA CRISTIANO", "PRESIDENTE", "RICARDO HORMAZABAL SANCHEZ", "DIRECTIVA CENTRAL", "NOMBRAMIE