{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 685, de 12 de mayo de 1997, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n; decl&#xE1;rase la caducidad de la</div><div class=\"p\">Resoluci&#xF3;n N&#xBA; 1.719, de 1989, de esta Subsecretar&#xED;a que</div><div class=\"p\">autoriz&#xF3; a don SERGIO ALARCON MEDEL, para iniciar</div><div class=\"p\">actividades pesqueras extractivas con la nave &quot;Do&#xF1;a</div><div class=\"p\">Norma&quot;, por haberse configurado la causal prevista en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8303125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de mayo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303126}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "685", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-685"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "SERGIO ALARCON MEDEL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-05-12", "doble_articulado": false, "id_norma": "71489", "numero_fuente": "35770", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-20", "vigencias": [{"desde": "1997-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-20"