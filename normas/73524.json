{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 759, de 3 de junio de 1997, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por CULTIVOS MARINOS</div><div class=\"p\">PLAYA GRANDE LIMITADA, para un centro de cultivo ubicado</div><div class=\"p\">en Bah&#xED;a de Tongoy, comuna de Coquimbo, Provincia de</div><div class=\"p\">Elqui, IV Regi&#xF3;n, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 14&#xBA; del D.S. N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><div class=\"p\">D&#xE9;jase sin efecto las Resoluciones N&#xBA; 336 y N&#xBA; 1.188, ambas de 1989, de esta Subsecretar&#xED;a, en virtud de lo se&#xF1;alado precedentemente.</div><br></div>", "i": 8303773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de junio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303774}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "759", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-759"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "CULTIVOS MARINOS PLAYA GRANDE LIMITADA", "AUTORIZACION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-03", "doble_articulado": false, "id_norma": "73524", "numero_fuent