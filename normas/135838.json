{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 49 EXENTO, DE 1999</div><br><br></div>", "i": 6166791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 49 de fecha 1 de marzo de 1999 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica INACAP, para impartir planes y programas de estudios aprobados para la instituci&#xF3;n, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se indican, a contar del a&#xF1;o 1998: Sede N&#xBA; 21 - Punta Arenas</div><br><br><div class=\"p\">Carrera&nbsp;  : Cocina Internacional</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; : T&#xE9;cnico en Cocina Internacional</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Decreto exento N&#xBA; 226 del 02.05.95)</div><br><div class=\"p\">Carrera&nbsp;  : Dise&#xF1;o Gr&#xE1;fico</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; : T&#xE9;cnico en Dise&#xF1;o Gr&#xE1;fico</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; (Decreto exento N&#xBA; 538 del 07.11.94)</div><br></div>", "i": 6166792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de abril&nbsp; de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6166793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "49 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-49 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 49 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-01", "doble_articulado": false, "id_norma": "135838",