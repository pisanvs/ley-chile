{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6745708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 696, de 31 de octubre de 2007, se autoriz&#xF3; el convenio Ad-Refer&#xE9;ndum Directo de Precio del lote N&#xBA; 41-F, y se expropi&#xF3; el lote de terreno N&#xBA; 41-C, superficie 385 m2, rol N&#xBA; 175-113, comuna de Curepto, VII Regi&#xF3;n, para la obra &quot;Camino Ruta K-16, sector: Curepto - Puente Lautaro, Tramo Km.</div><div class=\"p\">73,30000 al Km. 81,91430&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Luisa Ema Hern&#xE1;ndez Rojas y Otros, ascendente a la cantidad de $554.217. </div></div>", "i": 6745709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6745710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "696 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-696 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-31", "doble_articulado": false, "id_norma": "267190", "numero_fuente": "38926", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-01", "vigencias": [{"desde": "2007-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-12-04", "fecha_ve