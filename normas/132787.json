{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6157140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 451 de 29 de Marzo de 1988, conforme Art. 5&#xB0; Transitorio C&#xF3;digo Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Derechos de Adquisici&#xF3;n y Sectores Expropiados predios &quot;San Antonio&quot; y &quot;Santa Ana&quot; de la comuna de Nancagua, VI Regi&#xF3;n y Derechos Aprovechamiento Aguas que corresponden a las parcelas N&#xB0;s. 1 a la 16, sitios N&#xB0;s. 1 al 15 y Reserva CORA No. 1 del Proyecto de Parcelaci&#xF3;n &quot;San Antonio&quot;, formado por predios se&#xF1;alados. Los derechos de aguas se extraen de los canales Las Vi&#xF1;as, Zamorano y Polloni, derivados del r&#xED;o Tinguiririca. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.-</div><br></div>", "i": 6157141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6157142}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "451 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-451 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-29", "doble_articulado": false, "id_norma": "132787", "numero_fuente": "33036", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-04", "vigencias": [{"desde": "1988-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-04", "fin_vigencia": ""