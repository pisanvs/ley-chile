{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6282645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.481, de 17 de abril del 2000, se expropiaron los lotes de terrenos N&#xBA;s. 8, 9 y 11, superficies 50, 80 y 114 m2., respectivamente, rol de aval&#xFA;o 42-5, comuna de Monte Patria, para la obra Camino Ruta D-597, Monte Patria - Car&#xE9;n, Sector Juntas - Car&#xE9;n, Tramo Km. 8.260,00 a Km. 30.065,19, y se acord&#xF3; precio de las indemnizaciones con sus propietarios Feliciana del Rosario Hidalgo Hidalgo y Neville Enrique Guillermo Blanc Renard y Otra, ascendentes a las cantidades de $203.190, lote N&#xBA;8, y $315.934, lotes N&#xBA;s 9 y 11.- </div></div>", "i": 6282646}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6282647}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1481", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1481"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-17", "doble_articulado": false, "id_norma": "171097", "numero_fuente": "36690", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-15", "vigencias": [{"desde": "2000-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "2000-06-20", "fecha