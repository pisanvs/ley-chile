{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10226521}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 825, de 5 de mayo de 2021, aprueba procedimiento acelerado de postulaci&#xF3;n al registro de fabricantes e importadores de elementos de protecci&#xF3;n personal, en el contexto de la emergencia sanitaria decretada en el pa&#xED;s.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10226522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S), Instituto de&nbsp; Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10226523}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "825 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-825 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1942482", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-05-05", "doble_articulado": false, "id_norma": "1159472", "numero_fuente": "42953", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-05-13", "vigencias": [{"desde": "2021-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-05-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr