{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6215802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto N&#xBA; 278, de 23 de Octubre de 1986, se expropiaron los lotes N&#xBA;s. 5, 82, 83, 83-A y 83-B, cuyas superficies son 159,1 m2., 198 m2., 97,89 m2., 75,6 m2. y 97,23 m2., roles de aval&#xFA;o 44-139, 48-6, 48-5 y 48-3, Comuna de Peumo, para Ruta H-66-G. Pelequ&#xE9;n Cruce Las Ara&#xF1;as, sector Codao-Las Cabras y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios don Luis Adr&#xED;an Olave, Luis A. Osorio Alarc&#xF3;n, Heriberto Flores Pino, Margarita Flores Orellana y Luis Heriberto Flores Orellana, ascendentes a $ 100.808, $ 246.477, $ 207.144, $ 200.887 y. $ 83.439, respectivamente.-</div><br></div>", "i": 6215803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><div class=\"p\">(1&#xBA;) </div></div>", "i": 6215804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "278", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-278"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-10-23", "doble_articulado": false, "id_norma": "150305", "numero_fuente": "32636", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-12-01", "vigencias": [{"desde": "1986-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion