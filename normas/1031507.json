{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 808 EXENTO, DE 2011</div></div>", "i": 9198125}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 985, de 19 de octubre de 2011, de este Ministerio, modif&#xED;case el art&#xED;culo 2&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1029496&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 808 de 2011, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, que estableci&#xF3; cuota anual de captura del recurso pulpo a ser extra&#xED;da en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 42&#xB0;11&apos; Latitud Sur, y el l&#xED;mite sur de la X Regi&#xF3;n, a&#xF1;o 2011, en el sentido de incrementar en 30 toneladas la cuota anual de captura sobre el citado recurso.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y del Servicio Nacional de Pesca.</div></div>", "i": 9198126}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de octubre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9198127}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "985 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-985 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA DECRETO Nº 808 EXENTO, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-19", "doble_articulado": false, "id_norma": "1031507", "numero_fuente": "40092", "tipo_version": "3", "tipo_version