{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.092 EXENTA, DE 2006 </div></div>", "i": 6572071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.092, de 29 de mayo de 2006, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se revoca la inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n, a la entidad que se indica, por incumplimiento grave o reiterado de las normas de la ley citada, de conformidad con lo dispuesto en la letra b) del art&#xED;culo 77 de la ley N&#xBA; 19.518, se indica.</div><br><div class=\"p\">69.240.200-6 Ilustre Municipalidad de Cisnes Regi&#xF3;n </div></div>", "i": 6572072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Ays&#xE9;n</div><div class=\"p\">&nbsp; &nbsp;  Sergio Escobar Jofr&#xE9;, Director Nacional Servicio Nacional de Capacitaci&#xF3;n y Empleo (Sence).</div><br></div>", "i": 6572073}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1092 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1092 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.092 EXENTA, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-29", "doble_articulado": false, "id_norma": "250277", "numero_fuente": "38484", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-08", "vigencias": [{"desde": "2006-06-08", "hasta": "", "tipo_version": "3", "tipo_version_s":