{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION No. 2.894 EXENTA, DE 1986 </div><br><br></div>", "i": 6190164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 2.894 de fecha 28 de Octubre de 1986, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas al siguiente plan y programas de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Chileno Brit&#xE1;nico de Cultura de Vi&#xF1;a del Mar, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para aplicarse a contar de 1985:</div><div class=\"p\">Carrera: Secretariado Ejecutivo Biling&#xFC;e con conocimiento en Computaci&#xF3;n.</div><div class=\"p\">T&#xED;tulo: Secretario(a) Ejecutivo(a) Biling&#xFC;e con conocimiento en Computaci&#xF3;n.</div><br></div>", "i": 6190165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica, </div></div>", "i": 6190166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2894 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2894 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION No. 2.894 EXENTA, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-10-28", "fecha_derogacion": "2001-05-29", "doble_articulado": false, "id_norma": "143029", "numero_fuente": "32667", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-01-09", "vigencias": [{"desde": "2001-05-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desd