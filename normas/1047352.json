{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9321453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.238, de 11 de diciembre de 2012, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1022164&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 8 de 2011</a>, s&#xF3;lo en cuanto autoriz&#xF3; a Pesquera El Golfo S.A., hoy BLUMAR S.A., para realizar actividades pesqueras extractivas con una nave en construcci&#xF3;n en el &#xE1;rea mar&#xED;tima comprendida entre la V a VII y IX a X Regiones, sobre el recurso hidrobiol&#xF3;gico Jibia o Calamar rojo, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante memor&#xE1;ndum t&#xE9;cnico citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9321454}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9321455}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3238 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3238 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-11", "doble_articulado": false, "id_norma": "1047352", "numero_fuente": "40438", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-12-19", "vigencias": [{"desde": "2012-12-19", "hasta": "", "tipo_ver