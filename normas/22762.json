{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que concede fondos para combatir la viruela en Antofagasta</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274428}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de diez mil pesos ($ 10,000) a fin de combatir la viruela en la provincia de Antofagasta.</div><br></div>", "i": 8274429}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 17 de Enero de 1903.- JERMAN RIESCO.-</div><div class=\"p\">El&#xED;as Fern&#xE1;ndez A.</div><br></div>", "i": 8274430}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1580", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1580"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "QUE CONCEDE FONDOS PARA COMBATIR LA VIRUELA EN ANTOFAGASTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ANTOFAGASTA", "VIRUELA", "PREVENCION", "FONDOS", "CONCESION", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-01-17", "doble_articulado": false, "id_norma": "22762", "numero_fuente": "7487", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-01-20", "vigencias": [{"desde": "1903-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-01-20", "fin_vigencia": "