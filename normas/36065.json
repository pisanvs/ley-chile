{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.028, de 14 de agosto de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a ALGAS MULTIEXPORT S.A., R.U.T. N&#xB0; 96.518.040-0, para ampliar actividades pesqueras en orden a instalar y operar una planta ubicada en Obispito Km. 920, Caldera, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n de Secado natural y Molienda de algas, los recursos Chasc&#xF3;n Lessonia nigrescens, Huiro Macrocystis spp. y Palo palo Lessonia trabeculata.</div><br></div>", "i": 8295310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 14 de agosto de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295311}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1028", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1028"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "ALGAS MULTIEXPORT S.A.", "PESCA", "CALDERA", "TERCERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-08-14", "doble_articulado": false, "id_norma": "36065", "numero_fuente": "35263", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-09-07", "vigencias": [{"desde": "1995-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-09-07", "fin_vigencia": "", "tipo_ver