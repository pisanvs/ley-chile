{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6256278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 4, de fecha 20 de Junio de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o; se autoriza a don Leonel Guzm&#xE1;n Acu&#xF1;a, para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.700 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en calle Ej&#xE9;rcito Chileno N&#xB0; 346, de la comuna de Chill&#xE1;n.</div><br></div>", "i": 6256279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Francisco Navarro Ruiz, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6256280}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-20", "doble_articulado": false, "id_norma": "162747", "numero_fuente": "32239", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-03", "vigencias": [{"desde": "1985-08-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen