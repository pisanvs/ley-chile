{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10285169}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 2.462, de 25 de octubre de 2021, de esta Secretar&#xED;a Regional Ministerial, se modific&#xF3; la resoluci&#xF3;n exenta N&#xB0; 766 de 5 de noviembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Valpara&#xED;so, en el sentido de modificar la direcci&#xF3;n de funcionamiento de la Escuela de Conductores Clase B o No Profesional, Autom&#xF3;vil Club de Chile Ltda., conducente a la obtenci&#xF3;n de licencia de conductor Clase B. Su lugar de funcionamiento ser&#xE1; en la sede ubicada en calle Uno Oriente N&#xB0; 1078, comuna de Vi&#xF1;a del Mar.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10285170}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Emilio Guzm&#xE1;n Cepeda, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Valpara&#xED;so.</div><br></div>", "i": 10285171}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2462 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2462 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2040102", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-10-25", "doble_articulado": false, "id_norma": "1168399", "numero_fuente": "43104", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-11-16", "vigencias": [{"desde": "202