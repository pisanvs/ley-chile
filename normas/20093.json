{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA DECRETO N&#xB0; 1.230, DE 1989</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 86 exento.- Santiago, 11 de Mayo de 1993.- Vistos: El Oficio Ordinario del Sr. Director Nacional de Aduanas.</div><div class=\"p\">&nbsp; &nbsp; Teniendo presente: Lo dispuesto en los art&#xED;culos 2, 4, 5 y 6 de la Ordenanza de Aduanas; en el Decreto de Interior N&#xB0; 1.407, de 1991; y en la Resoluci&#xF3;n N&#xB0; 55, de 1992 de la Contralor&#xED;a General de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 8969029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: Sustit&#xFA;yese en el art&#xED;culo 3&#xB0; letra M N&#xB0; 3, del Decreto Supremo N&#xB0; 1.230, de 1989, del Ministerio de Hacienda, la expresi&#xF3;n &quot;Portezuelo de Puyehue&quot; por &quot;Paso Cardenal Samor&#xE9;&quot;.</div><br><br></div>", "i": 8969030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Por orden del Presidente de la Rep&#xFA;blica.- Alejandro Foxley Rioseco, Ministro de Hacienda.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Jorge Rodr&#xED;guez Grossi, Subsecretario de Hacienda.</div><br></div>", "i": 8969031}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "86 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-86 EXENTO"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA DECRETO N° 1.230, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERVICIO NACIONAL ADUANAS", "ADUANAS", "PORTEZUELO", "PUYEHUE", "ADUANA PUERTO MONTT", "PASO CARDENAL SAMORE", "PASOS FRONTERIZOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "dero