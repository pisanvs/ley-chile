{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 14.115 EXENTA, DE 2002 </div><br></div>", "i": 6409008}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 14.115, de 27 de noviembre del a&#xF1;o 2002, se ha aprobado al Colegio Internacional SEK-Chile, comuna de Las Condes, de Santiago, un plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores de Formaci&#xF3;n General y Formaci&#xF3;n Diferenciada que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6409009}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de diciembre de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6409010}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14115 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14115 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 14.115 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-27", "doble_articulado": false, "id_norma": "206433", "numero_fuente": "37450", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-04", "vigencias": [{"desde": "2003-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_