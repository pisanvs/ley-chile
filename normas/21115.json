{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 383, DE 1990 </div></div>", "i": 5944204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 383 de 28 de diciembre de 1990 se ha aprobado, a partir del a&#xF1;o escolar 1991, un plan especial de estudio al Colegio &quot;San Ignacio&quot;, Alonso Ovalle, de Santiago, para Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica.</div><br></div>", "i": 5944205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio de la asignatura Orientaci&#xF3;n y Formaci&#xF3;n Cristiana para 1&#xB0;, 2&#xB0;, 3&#xB0; y 4&#xB0; a&#xF1;o.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de Junio de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de educaci&#xF3;n.</div><br></div>", "i": 5944206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "383 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-383 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 383, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO SAN IGNACIO ALONSO OVALLE", "SANTIAGO", "PLAN", "ESTUDIO", "PROGRAMA ESTUDIO", "APROBACION."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "21115", "numero_fuente": "33997", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-20", "vigencias": [{"desde": "1991-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-06-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-06-20", "fin_vigenci