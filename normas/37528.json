{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.897, de 8 de noviembre de 1996,</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la</div><div class=\"p\">solicitud de concesi&#xF3;n de acuicultura presentada por</div><div class=\"p\">JOSE LUIS CHARPENTIER ALVAREZ, para un sector ubicado en</div><div class=\"p\">Canal Caica&#xE9;n, Comuna de Calbuco, Provincia de</div><div class=\"p\">Llanquihue, X Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 76&#xB0;, 77&#xB0;, 78&#xB0; y 5&#xB0; transitorio, inciso 6&#xB0; de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 1124, de 1988, de esta Subsecretar&#xED;a, en virtud de lo se&#xF1;alado precedentemente.</div><br></div>", "i": 8298514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de noviembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298515}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1897", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1897"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "DENEGACION", "DECIMA REGION", "JOSE LUIS CHARPENTIER ALVAREZ", "CALBUCO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": []