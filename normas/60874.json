{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 183, de 31 de enero de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 820, de 1996, de esta Subsecretar&#xED;a, que deneg&#xF3; la solicitud de concesi&#xF3;n de acuicultura presentada por&nbsp;  ELADIO ANTONIO SALDIVIA GUENTELICAN, en virtud de los antecedentes aportados por el peticionario.</div><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase, en consecuencia, plenamente vigente la Resoluci&#xF3;n N&#xBA; 1.633, de 1989, de esta Subsecretar&#xED;a, conforme lo se&#xF1;alado precedentemente.</div><br></div>", "i": 8301214}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 31 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301215}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "183", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-183"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "SOLICITUD", "ELADIO ANTONIO SALDIVIA GUENTELICAN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-31", "doble_articulado": false, "id_norma": "60874", "numero_fuente": "35689", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-02-11", "vigencias": [{"desde": "1997-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-02-11", "fin_vigencia": ""}, "vigenci