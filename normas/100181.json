{"html": [{"t": "<div><div class=\"p\">DEROGA DECRETO No. 239, DE 1988</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 290.- Santiago, 01 de Junio de 1989. Vistos: El art&#xED;culo 32&#xB0;. No. 12 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile; y la Resoluci&#xF3;n No. 600 de 1977, y sus modificaciones posteriores, de la Contralor&#xED;a General de la Rep&#xFA;blica,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 7233534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1. Der&#xF3;gase el Decreto Supremo de Educaci&#xF3;n No. 239, de 18 de Mayo de 1988.</div><br></div>", "i": 7233535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, reg&#xED;strese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- AUGUSTO PINOCHET UGARTE General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Ren&#xE9; Salam&#xE9; Martin, Ministro de Educaci&#xF3;n P&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a US. para su conocimiento.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7233536}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "290", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-290"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DEROGA DECRETO No. 239, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-06-01", "doble_articulado": false, "id_norma": "100181", "numero_fuente": "33421", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-13", "vigencias": [{"desde": "1989-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s"