{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.149, de 08 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xBA; 936, de 1997, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Merluza com&#xFA;n, en el litoral de la IV Regi&#xF3;n al paralelo 41&#xB0;28,6&apos;, se&#xF1;alada en el Art&#xED;culo 1&#xBA; letra e), del D.S. N&#xBA; 354 de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, en el sentido de incorporar en el numeral 1&#xBA; lo siguiente: &quot;Pesquera Desa Ltda.: Puma I&quot;.</div><br></div>", "i": 8305699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 08 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305700}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1149", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1149"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "NOMINA DE ARMADORES", "MERLUZA COMUN", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-08-08", "fecha_derogacion": "1998-01-24", "doble_articulado": false, "id_norma": "75045", "numero_fuente": "35846", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_pu