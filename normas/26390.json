{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REEMPLAZA EL INCISO SEGUNDO DEL ARTICULO 602 (523) DEL CODIGO DEL TRABAJO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5968342}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase el inciso segundo del</div><div class=\"p\">art&#xED;culo 602 (523) del C&#xF3;digo del Trabajo, por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;Las Asociaciones de patrones o empleadores con personalidad jur&#xED;dica tendr&#xE1;n derecho a presentar listas en igualdad de condiciones que los sindicatos patronales&quot;.</div><br></div>", "i": 5968343}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago.- veintinueve de Julio de mil novecientos cincuenta y dos.- GABRIEL GONZALES VIDELA.- Alejandro Serani B.</div><br></div>", "i": 5968344}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10391", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10391"}], "organismos": ["MINISTERIO DEL TRABAJO"], "titulo_norma": "REEMPLAZA EL INCISO SEGUNDO DEL ARTICULO 602 (523)\nDEL CODIGO DEL TRABAJO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "CODIGO TRABAJO", "JUNTAS PERMANENTES CONCILIACION", "MIEMBROS", "ASOCIACIONES PATRONALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-07-29", "doble_articulado": false, "id_norma": "26390", "numero_fuente": "22339", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-08-30", "vigencias": [{"desde": "1952-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-08-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1952-08-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1952-08-30", "fecha_actualizacion_texto": "1952-08-30", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5968342}, {"n": "Artículo UNICO", "i": 5968343, "t": 6}, {"n": "Promulgación", "i": 5968344}]}