{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 74 SOBRE NUEVO FORMULARIO 29 </div></div>", "i": 6488174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 62 del 13 de julio de 2004 que resuelve reemplazar los anexos N&#xBA; 1 y 2 de la resoluci&#xF3;n exenta SII N&#xBA; 74 de 16 de diciembre del 2003, por los de igual numeraci&#xF3;n que se anexan a esta resoluci&#xF3;n, los cuales para todos los efectos legales forman parte integrante de la misma.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en julio de 2004.</div><br></div>", "i": 6488175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "62 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-62 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCION Nº 74 SOBRE NUEVO FORMULARIO 29", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "FORMULARIO 29", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-13", "doble_articulado": false, "id_norma": "227794", "numero_fuente": "37912", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-17", "vigencias": [{"desde": "2004-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-07-17", "fin_vigenci