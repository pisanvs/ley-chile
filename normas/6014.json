{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 359.- Santiago, 17 de marzo de 1925.-</div><div class=\"p\">&nbsp; &nbsp; La Junta de Gobierno, de acuerdo con el Consejo de Secretarios de Estado, dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; DECRETO-LEI:</div><br></div>", "i": 5872653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Agr&#xE9;gase a continuacion del &#xED;tem 294 del Presupuesto de Instruccion P&#xFA;blica vijente, el siguiente &#xED;tem:</div><div class=\"p\"> &quot;Para pagar al astr&#xF3;nomo a cargo del anteojo ubicado en la Quinta Normal, la asignacion para oficina correspondiente a los a&#xF1;os 1924 y 1925____ $ 6,000&quot;</div><br></div>", "i": 5872654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes y Decretos del Gobierno.- Emilio Bello C.- C. A. Ward.- Pedro P. Dartnell E.- Jos&#xE9; Maza. </div></div>", "i": 5872655}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "359", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-359"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GASTOS NACION", "A O", "1925", "MODIFICACION", "MINISTERIO INSTRUCCION PUBLICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-03-17", "doble_articulado": false, "id_norma": "6014", "numero_fuente": "14130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-03-18", "vigencias": [{"desde": "1925-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1925-03-18", "fin_vigencia": ""}, "vigencias_versi