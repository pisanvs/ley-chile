{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 36 EXENTA, DE 5 DE ENERO DE 2017</div></div>", "i": 9779240}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=1059815&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.389, de 2014, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xB0; a 4&#xB0; a&#xF1;o de educaci&#xF3;n media, al Colegio Saint Gabriel&apos;s School, Comuna de Providencia, Provincia de Santiago, Regi&#xF3;n Metropolitana, en el sentido de sustituir su plan de estudio de 1&#xB0; y 2&#xB0; a&#xF1;o medio por el que se indica en la presente resoluci&#xF3;n exenta y aprobar el programa de estudio de la asignatura de &quot;&#xC9;tica y Valores&quot; para 1&#xB0; y 2&#xB0; a&#xF1;o de educaci&#xF3;n media.- </div></div>", "i": 9779241}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valentina Karina Quiroga Canahuate, Subsecretaria de Educaci&#xF3;n.</div></div>", "i": 9779242}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "36 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-36 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 36 EXENTA, DE 5 DE ENERO DE 2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; CVE 1191026"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-01-05", "doble_articulado": false, "id_norma": "1100876", "numero_fuente": "41705", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-03-10", "vigencias": [{"desde": "2017