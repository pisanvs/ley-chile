{"html": [{"t": "<div><br><div class=\"p\">DESAFILIA DEL SISTEMA DE FACTURACI&#xD3;N ELECTR&#xD3;NICA</div></div>", "i": 8870147}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 25, de 5 de febrero de 2010, que desafilia autorizaci&#xF3;n otorgada a contribuyentes que se&#xF1;ala con el fin de incorporarse al sistema de facturaci&#xF3;n electr&#xF3;nica Portal MIPYME.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase por desafiliados del Sistema de Facturaci&#xF3;n Electr&#xF3;nica, a los contribuyentes RUT N&#xBA; 80.151.700-5 y RUT N&#xBA; 96.514.460-9.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de febrero de 2010.</div></div>", "i": 8870148}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "25 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-25 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESAFILIA DEL SISTEMA DE FACTURACIÓN ELECTRÓNICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-02-05", "doble_articulado": false, "id_norma": "1010950", "numero_fuente": "39584", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-02-11", "vigencias": [{"desde": "2010-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-02-11", "fin_vigencia": ""}, "vigen