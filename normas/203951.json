{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7294930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.212, de 11 de octubre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA QUINTERO S.A., para ampliar las actividades pesqueras extractivas con la nave &quot;Crusoe I&quot;, autorizada por las resoluciones N&#xBA; 364 de 1984, N&#xBA; 196 de 1985, N&#xBA; 132 de 1986, N&#xBA; 564 y N&#xBA; 1.066, ambas de 1987, N&#xBA; 1.157 de 1991, N&#xBA; 722 de 1993, N&#xBA; 2.703 de 2000, y N&#xBA; 20 de 2002, todas de esta Subsecretar&#xED;a, en orden a realizar actividades pesqueras con la nave individualizada precedentemente, en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 24&#xBA; L.S. y 28&#xBA; L.S., donde podr&#xE1; capturar, con arte de arrastre, el recurso hidrobiol&#xF3;gico Gamba.</div><br></div>", "i": 7294931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de octubre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7294932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2212", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2212"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-11", "doble_articulado": false, "id_norma": "203951", "numero_fuente": "37394", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-28", "vigencias": [{"desde": "2002-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia