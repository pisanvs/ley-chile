{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8750541}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.487 de 15 de julio de 2009 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3 de la resoluci&#xF3;n exenta N&#xB0; 1.211 de 2009, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la CORPORACI&#xD3;N PARA EDUCACI&#xD3;N, DESARROLLO E INVESTIGACI&#xD3;N DE LA PESCA ARTESANAL DE CHILE para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto &quot;Caracterizaci&#xF3;n de la pesca con cerco del recurso Mote (Normanichthys crockeri) en la Regi&#xF3;n del B&#xED;o B&#xED;o&quot;, en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la presente pesca de investigaci&#xF3;n hasta el d&#xED;a 9 de diciembre de 2009, inclusive.</div></div>", "i": 8750542}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de julio de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca</div><br></div>", "i": 8750543}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2487 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2487 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-07-15", "doble_articulado": false, "id_norma": "1004548", "numero_fuente": "39421", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-07-27", "vigencias": [{"desde": "2009-07-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"