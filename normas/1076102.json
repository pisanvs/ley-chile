{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N EXENTA N&#xBA;3.510 DE 2014</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9588002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 908, de 2 de abril de 2015, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1072944&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.510, de 2014</a>, que estableci&#xF3; las toneladas asignadas a los Titulares de Licencias Transables de Pesca Clase A, inscritas en el Registro P&#xFA;blico que lleva esta Subsecretar&#xED;a, a ser extra&#xED;das durante el a&#xF1;o 2015, en las unidades de pesquer&#xED;a de Jurel, seg&#xFA;n se indica:</div><br><div class=\"p\">&nbsp; &nbsp;  Jurel XV-II regiones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/48540.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Jurel III-IV Regiones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/48541.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Jurel V-IX Regiones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/48542.jpg\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/48543.jpg\"> </div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Jurel XIV-X Regiones</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/48544.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9588003, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de abril de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9588004}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "908 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-908 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN EXENTA Nº3.510 DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-04-02", "doble_articulado": false, "id_norma": "1076102", "numero_fuente": "41128", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-04-10", "vigencias": [{"desde": "2015-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-04-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2015-04-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1795", "fecha_ingreso": "2015-04-10", "fecha_version": "2015-04-10", "fecha_actualizacion_texto": "2015-04-10", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9588002}, {"n": "Artículo", "i": 9588003, "t": 6}, {"n": "Promulgación", "i": 9588004}]}