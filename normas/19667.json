{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 16 EXENTO, DE 1995 </div></div>", "i": 7160030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 16 de 5 de enero de 1995, se ha modificado el Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 386 de 1990 que aprob&#xF3; un plan especial de estudio al Colegio &quot;Villa Mar&#xED;a Academy&quot; de Las Condes, Regi&#xF3;n Metropolitana, en el sentido de sustituir el plan de estudio para el Area de Secretariado en 3&#xB0; y 4&#xB0; a&#xF1;o de Ense&#xF1;anza Media, por el que se se&#xF1;ala en el presente decreto.- Santiago, 23 de enero de 1995.-</div><br></div>", "i": 7160031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "16 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-16 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 16 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO VILLA MARIA ACADEMY", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION", "LAS CONDES", "REGION", "METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-01-05", "doble_articulado": false, "id_norma": "19667", "numero_fuente": "35112", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-08", "vigencias": [{"desde": "1995-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1