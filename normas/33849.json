{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXPROPIATORIA</div><br><br></div>", "i": 6008112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n n&#xFA;mero 229, de 13 de marzo de 1996 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xB0; 2.186 de 1978, de parte del inmueble ubicado en convergencia calles Trebulco y Monse&#xF1;or Larra&#xED;n, presunto rol de aval&#xFA;os N&#xB0; 513-99, comuna de Talagante, de aparente dominio de Parroquia Inmaculada Concepci&#xF3;n de Talagante. Comisi&#xF3;n integrada por peritos Sres. Ren&#xE9; Ureta Koster, arquitecto, Ram&#xF3;n Undurraga Montes, ingeniero civil y Jos&#xE9; M. Haltenhoff Aenishanslin, seg&#xFA;n informe de 20 de diciembre de 1995, fij&#xF3; monto provisional de indemnizaci&#xF3;n en $1.976.000.- pagadera al contado.-</div><br></div>", "i": 6008113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Serviu Metropolitano.</div><br></div>", "i": 6008114}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "229", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-229"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXPROPIATORIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "TALAGANTE", "REGION", "METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-13", "doble_articulado": false, "id_norma": "33849", "numero_fuente": "35432-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-01", "vigencias": [{"desde": "1996-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única