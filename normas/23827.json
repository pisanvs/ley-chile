{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede fondos para pago de material de herraje del Ej&#xE9;rcito</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,225.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7166460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de setenta mil pesos ($ 70,000) en el pago del material de herraje para el Ej&#xE9;rcito adquirido durante el segundo semestre del a&#xF1;o 1916.</div><br></div>", "i": 7166461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 7 de Febrero de 1917.- JUAN LUIS SANFUENTES.- Oscar Urz&#xFA;a.</div><br></div>", "i": 7166462}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3225", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3225"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "CONCEDE FONDOS PARA PAGO DE MATERIAL DE HERRAJE DEL EJERCITO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO CHILE", "MATERIAL HERRAJE", "PAGO", "FONDOS", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-02-07", "doble_articulado": false, "id_norma": "23827", "numero_fuente": "11694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-02-08", "vigencias": [{"desde": "1917-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi