{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 809.- Santiago, 19 de Abril de 1929.- Vistos estos antecedentes, </div><div class=\"p\">&nbsp; &nbsp;  Decreto: </div><br></div>", "i": 7376025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Apruebanse las reformas de los estatutos porque se rige la corporaci&#xF3;n denominada &quot;Federaci&#xF3;n de Box de Chile&quot;, con domicilio en esta ciudad, en los t&#xE9;rminos de que da testimonio la escritura p&#xFA;blica adjunta, otorgada ante el Notario de Santiago don Humberto&nbsp; Valenzuela Vargas, el 7 de Diciembre &#xFA;ltimo.</div></div>", "i": 10116216}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- C. Ib&#xE1;&#xF1;ez C.- Osvaldo Koch.</div></div>", "i": 10116217}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "809", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-809"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["PF"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-04-19", "doble_articulado": false, "id_norma": "274611", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-07-19", "vigencias": [{"desde": "1929-07-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-07-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-07-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GGV", "fecha_ingreso": "2008-07-22", "fecha_version": "1929-07-19"