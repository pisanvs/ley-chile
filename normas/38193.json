{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; COMPLEMENTA RESOLUCION EXENTA N&#xB0; 1.213, DE 1992 N&#xFA;m. 67 exenta.- Santiago, 14 de Enero de 1993.- Visto: El Decreto Ley N&#xB0; 2.136 de 1978 en su texto fijado por el art&#xED;culo 83 de la Ley N&#xB0; 18.768.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 7200994}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Complem&#xE9;ntase la Resoluci&#xF3;n Exenta N&#xB0; 1.213/92, de la Subsecretar&#xED;a de Transportes, en el sentido de agregar la siguiente letra f) a su numeral 1.-:</div><div class=\"p\">&nbsp; &nbsp; &quot;f) Talonarios de 100 Formularios de Certificaci&#xF3;n de Servicio Especial.&quot;.</div><div class=\"p\">&nbsp; &nbsp; $ 1.540 </div></div>", "i": 7200995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda a Ud.- Elizabeth Silva Cid, Jefe Administrativo Subrogante.</div><br></div>", "i": 7200996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "67", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-67"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "COMPLEMENTA RESOLUCION EXENTA N° 1.213, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALOR", "DOCUMENTOS", "CERTIFICADOS", "SUBSECRETARIA TRANSPORTES", "MINISTERIO TRANSPORTES TELECOMUNICACIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-01-14", "doble_articulado": false, "id_norma": "38193", "numero_fuente": "34473", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":