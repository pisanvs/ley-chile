{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Modifica la lei n&#xFA;mero 980 Lei n&#xFA;m. 1782.- Santiago, a 20 de Diciembre de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7164422}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Los derechos establecidos en el art&#xED;culo 3.&#xB0; de la lei n&#xFA;mero 980, de 23 de Diciembre de 1897, se har&#xE1;n estensivos a los catres de fierro, de bronce, de fierro con bronce i de cualquier otro metal. </div></div>", "i": 7164423, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Belfor Fernandez.</div><br></div>", "i": 7164424}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1782", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1782"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEI NÚMERO 980", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS IMPORTACION", "CATRES", "FIERRO", "BRONCE", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-12-20", "doble_articulado": false, "id_norma": "22911", "numero_fuente": "8389", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publica