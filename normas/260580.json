{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISOR DE BOLETAS ELECTRONICAS </div></div>", "i": 6609237}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de Resoluci&#xF3;n Exenta del Servicio de Impuestos Internos N&#xBA; 49 de 27 de abril de 2007, que autoriza a contribuyente como emisor de boletas electr&#xF3;nicas.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boletas electr&#xF3;nicas al contribuyente RUT N&#xBA; 88.670.700-2, a contar del mes de abril de 2007.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta Resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril, de 2007.</div><br></div>", "i": 6609238}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "49 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-49 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR DE BOLETAS ELECTRONICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-27", "doble_articulado": false, "id_norma": "260580", "numero_fuente": "38754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-04", "vigencias": [{"desde": "2007-05-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-05-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul