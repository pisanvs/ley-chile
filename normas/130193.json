{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 596 DE 1998</div><br><br></div>", "i": 6149288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 596, de 9 de noviembre de 1998, se ha aprobado el convenio de fecha 13 de octubre de 1998, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Valdivia, que rescilia Convenio de Traspaso de la Escuela B&#xE1;sica E N&#xBA; 8, de Valdivia traspasada a dicha Corporaci&#xF3;n, por Convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 1.342 de 26 de noviembre de 1986.</div><br></div>", "i": 6149289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6149290}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "596", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-596"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 596 DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-09", "doble_articulado": false, "id_norma": "130193", "numero_fuente": "36267", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-19", "vigencias": [{"desde": "1999-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-01-19", "fecha_version": "1999-01-19", "fecha_actualizacion_texto": "1999-01-