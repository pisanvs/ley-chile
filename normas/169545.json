{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL QUE INDICA </div></div>", "i": 6278031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 118 del 02.11.87, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n Gremial Nacional de Establecimientos de Ense&#xF1;anza Particular&quot;, inscrita bajo el n&#xFA;mero 317 del Registro de Asociaciones Gremiales que lleva este Ministerio, por haberse configurado respecto de ella la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18 N&#xB0; 2 letra D., del DL 2.757.</div><br></div>", "i": 6278032}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Norman Bull de la Jara, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6278033}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "118", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-118"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE\nASOCIACION GREMIAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-02", "doble_articulado": false, "id_norma": "169545", "numero_fuente": "32933", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-30", "vigencias": [{"desde": "1987-11-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-30", "fin_vigencia": ""}, "vigencias_version_norma