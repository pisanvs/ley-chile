{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION ESPECIAL N&#xBA; 1379E </div></div>", "i": 6632879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n Especial N&#xBA; 1379E, celebrada el 13 de diciembre de 2007, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">1379E-01-071213 -&nbsp; Designa Vicepresidente del Consejo</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  y del Banco Central de Chile.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; designar al Consejero don Jorge Desormeaux Jim&#xE9;nez en el cargo de Vicepresidente del Consejo y del Banco Central de Chile, a contar del 13 de diciembre de 2007 y hasta el d&#xED;a 7 de diciembre de 2009, inclusive.</div><div class=\"p\">Santiago, 13 de diciembre de 2007.</div><br></div>", "i": 6632880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe. </div></div>", "i": 6632881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1379", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1379"}, {"tipo": "5", "numero": "1379-071213", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1379-071213"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION ESPECIAL Nº 1379E", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-13", "doble_articulado": false, "id_norma": "267449", "numero_fuente": "38936", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-14", "vigencias": [{"desde": "2007-12-14",