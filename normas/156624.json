{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION NUMERO 64, DE 1999</div><br><br></div>", "i": 6236255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n ministerial N&#xBA; 64, de fecha 10 de</div><div class=\"p\">agosto de 1999, del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, se cancel&#xF3; la Personalidad Jur&#xED;dica de</div><div class=\"p\">la &apos;&apos;Asociaci&#xF3;n Gremial de Empresarios de Microbuses Los</div><div class=\"p\">Leones&apos;&apos;, inscrita bajo el N&#xBA; 96, en el Registro de</div><div class=\"p\">Asociaciones Gremiales, por haberse configurado respecto</div><div class=\"p\">de ella, la causal de cancelaci&#xF3;n contemplada en el</div><div class=\"p\">art&#xED;culo 18, N&#xBA; 2, letra d) del decreto ley N&#xBA; 2.757, de 1979.</div><br></div>", "i": 6236256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de febrero de 2000.- Luis S&#xE1;nchez Castell&#xF3;n, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6236257}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "64", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-64"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE RESOLUCION NUMERO 64, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-08-10", "doble_articulado": false, "id_norma": "156624", "numero_fuente": "36591", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-17", "vigencias": [{"desde": "2000-02-17", "hasta": "", "tipo_v