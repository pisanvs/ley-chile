{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6513903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de enero de 2005, fue de 3,84% anual.</div><br></div>", "i": 6513904}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, enero 18 de 2005.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6513905}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-01-18", "doble_articulado": false, "id_norma": "234892", "numero_fuente": "38065", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-20", "vigencias": [{"desde": "2005-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-01-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-01-20", "fecha_version": "2005-01-20", "fecha_actualizacion_texto": "2005-01-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6513903}, {"n": "Artículo", "i": 651390