{"html": [{"t": "<div><div class=\"p\">ACLARA DESLINDES EXPROPIACION </div></div>", "i": 8677316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Alcaldicio No. 764 de 9 de julio de 1987 se aclara el Decreto No. 1579 de diciembre 12 de 1986 que orden&#xF3; la expropiaci&#xF3;n de un terreno ubicado en la comuna de Renca necesario para la apertura y/o ensanche de la Avda. Domingo Santa Mar&#xED;a, entre las calles An&#xED;bal Pinto y Err&#xE1;zuriz, s&#xF3;lo en el sentido de agregar al final del punto No. 2 el deslinde particular del terreno expropiado se&#xF1;alado en el plano archivado en el Conservador de Bienes Ra&#xED;ces de Santiago, bajo el No. 28796 el cual es el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Norte&nbsp;  : 3,50 m. aprox. con calle An&#xED;bal Pinto y 1,40</div><div class=\"p\">m. parte expropiada a Juan B. P&#xE9;rez</div><div class=\"p\">&nbsp; &nbsp;  Sur&nbsp; &nbsp;  : 7,00 m. aprox. con resto de la misma</div><div class=\"p\">propiedad.</div><div class=\"p\">&nbsp; &nbsp;  Oriente : 4,00 m. aprox. con calle An&#xED;bal Pinto</div><div class=\"p\">&nbsp; &nbsp;  Poniente: 4,60 m. aprox. con parte expropiada a Juan B.</div><div class=\"p\">P&#xE9;rez.-</div><br></div>", "i": 8677317}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alcalde.</div><br></div>", "i": 8677318}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "764", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-764"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "ACLARA DESLINDES EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-09", "doble_articulado": false, "id_norma": "173270", "numero_fuente": "32820", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-15", "vigencias": [{"desde": "1987-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-07-24", "fecha_version": "1987-07-15", "fecha_actualizacion_texto": "1987-07-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8677316}, {"n": "Artículo", "i": 8677317, "t": 6}, {"n": "Promulgación", "i": 8677318}]}