{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 131, de 31 de enero de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 72, de 1982, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESQUERA CERNA ROSALES LIMITADA, para operar un centro de cultivo ubicado en la localidad de Teupa, Comuna de Castro, Provincia de Chilo&#xE9;, X Regi&#xF3;n, por no haberse renovado el respectivo decreto de concesi&#xF3;n de acuicultura por la Subsecretar&#xED;a de Marina del Ministerio de Defensa Nacional.</div><br></div>", "i": 8301223}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, </div><div class=\"p\">Subsecretario de Pesca.</div><br><br></div>", "i": 8301224}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "131", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-131"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESQUERA CERNA ROSALES LIMITADA", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-31", "doble_articulado": false, "id_norma": "60880", "numero_fuente": "35687", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-02-08", "vigencias": [{"desde": "1997-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-02-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"in