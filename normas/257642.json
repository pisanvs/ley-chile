{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6598105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.402, de 21 de diciembre de 2006, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 2.682 de 2006, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD CATOLICA DEL NORTE para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto FIP N&#xBA; 2006-11 denominado &quot;Evaluaci&#xF3;n directa de Camar&#xF3;n nailon entre la II y VIII Regiones, a&#xF1;o 2006&quot;, en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la citada pesca de investigaci&#xF3;n hasta el d&#xED;a 31 de diciembre de 2006, inclusive.</div><br></div>", "i": 6598106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de diciembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6598107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3402 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3402 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-21", "doble_articulado": false, "id_norma": "257642", "numero_fuente": "38667", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-19", "vigencias": [{"desde": "2007-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-19", "fin_vigencia": ""}, "vigencias_