{"html": [{"t": "<div><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N DE CONCESI&#xD3;N DE ACUICULTURA </div></div>", "i": 8164730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n (M) 1.580, de 10 de diciembre de 2008, Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, se resolvi&#xF3;:</div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n (M) 172, de 11 de febrero de 2008, Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, en la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase en el numeral I.- p&#xE1;rrafo 2.- y numeral II.- del p&#xE1;rrafo 1.-, en el v&#xE9;rtice D, lo siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Donde dice: 07&quot; Debe decir : 05&quot; </div></div>", "i": 8164731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de enero de 2009.- Por la Sra. Subsecretaria, Luis Eduardo Angulo Prado, Subjefe Subsecretar&#xED;a de Marina Subrogante.</div><br></div>", "i": 8164732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1580", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1580"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "RECTIFICA RESOLUCIÓN DE CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-10", "doble_articulado": false, "id_norma": "287649", "numero_fuente": "39300", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-28", "vigencias": [{"desde": "2009-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-02-28", "fin_vigencia": ""}, "vigenci