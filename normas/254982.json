{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7333851}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.953, de 23 de octubre de 2006, de esta Subsecretar&#xED;a, rev&#xF3;case la resoluci&#xF3;n N&#xBA; 1.680, de 2006, s&#xF3;lo en cuanto declar&#xF3; la caducidad de las resoluciones N&#xBA; 689, de 1999; N&#xBA; 284, de 2001, y N&#xBA; 351, de 2004, todas de esta Subsecretar&#xED;a, las que autorizaron a DAVID CRUZ LOPEZ para realizar actividades extractivas con la nave &quot;Marleen&quot;.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, rev&#xF3;case la resoluci&#xF3;n N&#xBA; 2.637, de 2006, citada en Visto, que rechaz&#xF3; la reclamaci&#xF3;n deducida por el armador antes individualizado, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 7333852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de octubre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7333853}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2953 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2953 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-23", "doble_articulado": false, "id_norma": "254982", "numero_fuente": "38609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-09", "vigencias": [{"desde": "2006-11-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-09", "fin_vigencia":