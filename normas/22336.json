{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Guardia especial del Congreso Lei n&#xFA;m. 1,001.- Santiago, a 22 de Enero de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274040}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para que pueda invertir, durante el a&#xF1;o 1898, hasta la suma de tres mil pesos en pagar sueldos a las personas que hagan la guardia especial del Congreso Nacional, pudiendo deducir dicha cantidad de la partida de imprevistos del presupuesto del Ministerio del Interior.</div><br><br></div>", "i": 8274041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Antonio Valdes C.</div><br></div>", "i": 8274042}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1001", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1001"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "GUARDIA ESPECIAL DEL CONGRESO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "GUARDIA ESPECIAL", "FONDOS", "DESTINACION", "REMUNERACIONES", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-22", "doble_articulado": false, "id_norma": "22336", "numero_fuente": "5909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-22", "vigencias": [{"desde": "1898-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio