{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 379, de 26 de febrero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la Resoluci&#xF3;n N&#xB0; 986, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don DAVID CRUZ LOPEZ, para operar la nave &quot;Linda Kay&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xB0; 18.892 y sus modificaciones, citadas en Visto.</div><br></div>", "i": 8292121}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292122}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "379", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-379"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DAVID CRUZ LOPEZ", "CADUCIDAD", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-26", "doble_articulado": false, "id_norma": "34523", "numero_fuente": "35408", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-04", "vigencias": [{"desde": "1996-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-03-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "m