{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION DE EMISOR ELECTRONICO </div></div>", "i": 7342971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 58, de 25 de mayo de 2007, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como emisor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  Se deroga autorizaci&#xF3;n otorgada a contribuyente RUT N&#xB0; 76.496.480-2, para operar como emisor de Documentos Tributarios Electr&#xF3;nicos, lo cual ha sido solicitado por el interesado con el fin de adherir al Sistema de Facturaci&#xF3;n Electr&#xF3;nica Portal Mipyme, dispuesto por este Servicio.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de mayo de 2007.</div><br></div>", "i": 7342972}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "58 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-58 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACION DE EMISOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-05-25", "doble_articulado": false, "id_norma": "261215", "numero_fuente": "327", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-30", "vigencias": [{"desde": "2007-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenci