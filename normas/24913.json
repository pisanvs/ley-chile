{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede abono tiempo de servicios a don David Or&#xF3;stegui</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Ab&#xF3;nase, por gracia y para los efectos de su jubilaci&#xF3;n, a don David Ar&#xF3;stegui Az&#xF3;car, los dieciocho a&#xF1;os y tres meses que sirvi&#xF3; en el puesto de mayordomo del Liceo de Hombres de Valpara&#xED;so. </div></div>", "i": 5960771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dieciocho de Enero de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Rodolfo Jaramillo B. </div></div>", "i": 5960772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4789", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4789"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE ABONO TIEMPO DE SERVICIOS A DON DAVID OROSTEGUI", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DAVID OROSTEGUI AZOCAR", "ABONO TIEMPO", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-01-18", "doble_articulado": false, "id_norma": "24913", "numero_fuente": "15579", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-01-23", "vigencias": [{"desde": "1930-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-01-23", "fin_vigen