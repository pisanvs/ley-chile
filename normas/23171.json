{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,168, que concede una gratificacion al Secretario de la Administracion del Impuesto sobre Alcoholes</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,168.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Acu&#xE9;rdase una gratificacion anual de dos mil pesos al Secretario de la Administracion del Impuesto sobre Alcoholes.</div><br></div>", "i": 5952944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de Febrero de 1909.- PEDRO MONTT.- Luis Devoto A.</div><br></div>", "i": 5952945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2168", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2168"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Lei núm. 2,168, que concede una gratificacion al;Secretario de la Administracion del Impuesto sobre;Alcoholes", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADMINISTRACION IMPUESTO ALCOHOLES", "SECRETARIO", "GRATIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-02-19", "doble_articulado": false, "id_norma": "23171", "numero_fuente": "9320", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-02-20", "vigencias": [{"desde": "1909-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],