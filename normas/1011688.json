{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8892265}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.043, de 9 de marzo de 2010, de esta Subsecretar&#xED;a, ot&#xF3;rgase traslado por un plazo de 10 d&#xED;as h&#xE1;biles, contados desde la publicaci&#xF3;n de la presente resoluci&#xF3;n, a PESQUERA AMANCAY LIMITADA, en el procedimiento administrativo iniciado mediante CI Subpesca N&#xBA; 12.600, seguido en contra del mencionado armador por infracci&#xF3;n al art&#xED;culo 12 inciso 4&#xBA; de la ley 19.713 en relaci&#xF3;n al art&#xED;culo 47 de la Ley General de Pesca y Reconstrucci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Dentro del t&#xE9;rmino antes se&#xF1;alado, el armador deber&#xE1; formular sus descargos y acompa&#xF1;ar los antecedentes en que se fundan sus alegaciones.</div></div>", "i": 8892266}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de marzo de 2010.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8892267}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1043 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1043 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-03-09", "doble_articulado": false, "id_norma": "1011688", "numero_fuente": "39610", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-13", "vigencias": [{"desde": "2010-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen