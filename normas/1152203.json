{"html": [{"t": "<div><br><div class=\"p\">&#xFEFF;CONSUL JENERAL DE LAS PROVINCIAS UNIDAS DEL RIO DE LA PLATA.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 6 de 1826.</div><br><div class=\"p\">&nbsp; &nbsp;  En consecuencia del diploma presentado al Gobierno por el Sr. D. Sebastian Lezica nombrado C&#xF3;nsul jeneral de las Provincias Unidas del Rio de la Plata.</div></div>", "i": 10215256}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Decl&#xE1;rasele el goce de todos los derechos y prerogativas que como a tal le pertenecen, con arreglo al derecho p&#xFA;blico.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Rej&#xED;strese el diploma en la Canciller&#xED;a de Relaciones Exteriores, y devu&#xE9;lvase: publ&#xED;quese este decreto en el Boletin y trascribase a quienes corresponda.</div></div>", "i": 10215257}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  EIZAGUIRRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Gandarillas.</div></div>", "i": 10215258}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "﻿CONSUL JENERAL DE LAS PROVINCIAS UNIDAS DEL RIO DE LA PLATA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1826-12-06", "doble_articulado": false, "id_norma": "1152203", "numero_fuente": "11826", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1826-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1826-12-06", "fin_vigencia": ""}, "vigencias_version_nor