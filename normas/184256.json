{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 125, DE 2001 </div></div>", "i": 6331148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 125, de 13 de marzo de 2001, se ha aprobado convenio de fecha quince de diciembre de 2000, celebrado entre Ministerio de Educaci&#xF3;n y la I. Municipalidad de Freire, que modifica el convenio de Traspaso de la Escuela B&#xE1;sica G N&#xBA; 589 de Freire, traspasada a dicha corporaci&#xF3;n por convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 5.259 de 19 de agosto de 1981.</div><br></div>", "i": 6331149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de abril de 2001.- Jos&#xE9; Weinsten Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6331150}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "125 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-125 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 125, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-13", "doble_articulado": false, "id_norma": "184256", "numero_fuente": "36940", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-18", "vigencias": [{"desde": "2001-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-04-18", "fecha_version": "2001-04-18",