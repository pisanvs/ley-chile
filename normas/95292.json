{"html": [{"t": "<div><div class=\"p\">DERECHOS DE APROVECHAMIENTO DE AGUAS EN LA COMUNA DE LOS ANGELES </div></div>", "i": 6099573}, {"t": "<div><div class=\"p\">Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No.1.343 de 9 de Agosto de 1989, conforme Art.5&#xBA; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas Nos.1 a 22 y 24 a 74; sitios Nos.1 al 38 y 40 al 46 del Proyecto de Parcelaci&#xF3;n &quot;Virquenco&quot;, de la comuna de Los Angeles, VIII Regi&#xF3;n, formado por predio &quot;Parte de la Hacienda Virquenco&quot;. Los Derechos de Agua se extraen del canal del Laja. Publicaci&#xF3;n hecha conforme Art.13 Ley No.18.377. </div></div>", "i": 6099574}, {"t": "<div><div class=\"p\">Director Ejecutivo.</div><br></div>", "i": 6099575}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1343 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1343 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DERECHOS DE APROVECHAMIENTO DE AGUAS EN LA COMUNA DE LOS ANGELES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-09", "doble_articulado": false, "id_norma": "95292", "numero_fuente": "33463", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-01", "vigencias": [{"desde": "1989-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v