{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 102 EXENTA, DE 2006 </div></div>", "i": 7329915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;102, de 27 de abril de 2006, de la Secretar&#xED;a Regional Ministerial de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se declar&#xF3; extinguida la Pr&#xF3;rroga de Contrato de Concesi&#xF3;n, de la Planta de Revisi&#xF3;n T&#xE9;cnica Clase B 0814, que practica revisi&#xF3;n t&#xE9;cnica de veh&#xED;culos Clase B, en la comuna de Mulch&#xE9;n, dispuesto y aprobado mediante la resoluci&#xF3;n N&#xBA;62 de 25 de agosto de 1997, de la SEREMI precitada, estableci&#xE9;ndose la siguiente fecha de cierre, 27 de abril de 2006.</div><br></div>", "i": 7329916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Claudio V&#xE1;squez Fern&#xE1;ndez, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 7329917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "102 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-102 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 102 EXENTA, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-27", "doble_articulado": false, "id_norma": "249786", "numero_fuente": "38467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-19", "vigencias": [{"desde": "2006-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen