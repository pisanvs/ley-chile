{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACLARA UNA DISPOSICION DE LA LEY N&#xB0; 9,894 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5968358}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Decl&#xE1;rase que la prohibici&#xF3;n establecida en el art&#xED;culo 3.o de la ley N.o 9.894, es por el plazo contemplado en el &#xFA;ltimo inciso del art&#xED;culo 2.o de la citada ley&quot;.</div><br></div>", "i": 5968359}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, doce de Agosto de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Juan Atala G.</div><br></div>", "i": 5968360}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10397", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10397"}], "organismos": ["MINISTERIO DEL TRABAJO"], "titulo_norma": "ACLARA UNA DISPOSICION DE LA LEY N° 9,894", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INTERPRETACION LEGAL", "LEY 9894", "PROHIBICION", "PLAZO", "CONSTRUCCION", "CASA ECONOMICA", "VIVIENDA ECONOMICA", "IQUIQUE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-08-12", "doble_articulado": false, "id_norma": "26395", "numero_fuente": "22348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-09-11", "vigencias": [{"desde": "1952-09-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-09-11", "fin_vigencia": ""}, "vigencias_version_n