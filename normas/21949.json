{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Asociacion de Artesanos de Valparaiso Lei n&#xFA;m. 78.- Santiago, a 16 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la corporacion denominada &quot;Asociacion de Artesanos de Valparaiso&quot; el permiso requerido por el art&#xED;culo 556 del C&#xF3;digo Civil para que pueda conservar por treinta a&#xF1;os la propiedad de un bien raiz que tiene adquirido en la calle del Hospital en la ciudad de Valparaiso.</div><br><br></div>", "i": 5946698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- J. Rodr&#xED;guez Rozas.</div><br></div>", "i": 5946699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "78", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-78"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "ASOCIACION DE ARTESANOS DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ASOCIACION ARTESANOS VALPARAISO", "BIEN RAIZ", "PROPIEDAD", "CONSERVACION", "PERMISO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-16", "doble_articulado": false, "id_norma": "21949", "numero_fuente": "4597", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-17", "vigencias": [{"desde": "1893-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"