{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CERTIFICADO</div><br><br></div>", "i": 6578656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 1,33% anual durante el mes de julio de 2006.</div><div class=\"p\">Asimismo, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de julio de 2006, fue de 0,81% anual. </div></div>", "i": 6578657}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de agosto de 2006.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6578658}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-08-03", "doble_articulado": false, "id_norma": "252021", "numero_fuente": "38532", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-05", "vigencias": [{"desde": "2006-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-08-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-08-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": 