{"html": [{"t": "<div><div class=\"p\">APRUEBA REGLAMENTO DE ADQUISICIONES</div><br><br></div>", "i": 6231129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por reglamento N&#xBA; 002 de 24.09.99, de la I. Municipalidad de Calbuco, se aprob&#xF3; el Reglamento sobre Adquisiciones de acuerdo con el Art. 58&#xBA; bis y 2&#xBA; transitorio de la ley 18.695, Org&#xE1;nica Constitucional de Municipalidades, modificada por la ley N&#xBA; 19.602 que en sus partes principales dispone:</div><br><div class=\"p\">&nbsp; &nbsp;  Las normas generales y uniformes sobre la adquisici&#xF3;n o compra, registro, almacenaje y distribuci&#xF3;n de los elementos necesarios para el funcionamiento de la Municipalidad y adem&#xE1;s aquellos que se requieran para la implementaci&#xF3;n de programas y proyectos financiados con fondos de terceros. </div></div>", "i": 6231130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Rub&#xE9;n R. C&#xE1;rdenas G&#xF3;mez, Alcalde de Calbuco.- Leonel Villarroel Villarroel, Secretario Municipal. </div></div>", "i": 6231131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MUNICIPALIDAD DE CALBUCO"], "titulo_norma": "APRUEBA REGLAMENTO DE ADQUISICIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-24", "doble_articulado": false, "id_norma": "155079", "numero_fuente": "36583", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-08", "vigencias": [{"desde": "2000-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-02-08", "fin_vigencia": "