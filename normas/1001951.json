{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br><div class=\"p\">En la edici&#xF3;n del Diario Oficial N&#xBA;39.345, de 24 de abril del 2009, se public&#xF3; decreto N&#xBA;85, que designa al Coronel de Ej&#xE9;rcito Don Ian Mackinnon Dalhlgren como representante del Ministerio de Defensa Nacional ante el Consejo de Monumentos Nacionales, con el error de transcripci&#xF3;n que se salva a continuaci&#xF3;n: p&#xE1;gina seis, tercera columna, donde dice: &quot; ... N&#xFA;m. 85.- Considerando: Que el Ministro de Defensa Nacional, ...&quot; debe decir &quot;... N&#xFA;m. 85.- Santiago, 17 de marzo de 2009.- Considerando: Que el Ministro de Defensa Nacional, ...&quot;.</div><br></div>", "i": 8591065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "28", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-28"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1001951", "numero_fuente": "39356", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-08", "vigencias": [{"desde": "2009-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-05-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part": "rectificacion"}], "ingresado_por": "362", "fecha_ingreso": "2009-05-08", "fecha_version": "2009-05-08", "actualizado_por": "362", "fecha_actualizacion_texto": "2009-05-08", "tipo_tratado": ""}