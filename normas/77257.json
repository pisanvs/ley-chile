{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8307758}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 878 de 10 de Septiembre de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n No. 628, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don JORGE ELIZARDO OJEDA ANDRADE, R.U.T. No. 5.765.200-4, domiciliado en la localidad de Lolcura, Comuna de Maull&#xED;n X Regi&#xF3;n, para operar un establecimiento de cultivo, en el Sector de Lolcura, Isla Elisa R&#xED;o Maull&#xED;n, Provincia de Llanquihue, X Regi&#xF3;n, por renuncia de su titular, ya individualizado. </div></div>", "i": 8307759}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 10 de Septiembre de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8307760}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "878", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-878"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-10", "doble_articulado": false, "id_norma": "77257", "numero_fuente": "34372", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-09-23", "vigencias": [{"desde": "1992-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-09-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-09-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":