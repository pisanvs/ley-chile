{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA DECRETO N&#xBA;2.798, DE 2007 </div></div>", "i": 8051455}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Completa publicaci&#xF3;n aparecida el d&#xED;a lunes 8 de</div><div class=\"p\">octubre de 2007, del decreto N&#xBA; 2.798/07 sobre</div><div class=\"p\">&quot;Ordenanza de Instalaci&#xF3;n de L&#xED;neas Distribuidoras de</div><div class=\"p\">Energ&#xED;a El&#xE9;ctrica y de Telecomunicaciones en la comuna</div><div class=\"p\">de Punta Arenas&quot;, en el sentido de agregar despu&#xE9;s del</div><div class=\"p\">art&#xED;culo 30, el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo 31: Las luminarias a instalar en la comuna de Punta Arenas deber&#xE1;n tener la potencia que a continuaci&#xF3;n se indica:</div><br><div class=\"p\">&nbsp; &nbsp;  Pasajes de un ancho hasta 3,5 metros de calzada, 70 watts.</div><div class=\"p\">&nbsp; &nbsp;  Calles de una calzada hasta 7 metros, 100 watts.</div><div class=\"p\">&nbsp; &nbsp;  Avenidas de una calzada hasta 7 metros, 250 watts.</div><div class=\"p\">&nbsp; &nbsp;  Avenidas de dos calzadas hasta 7,0 metros, 250 x 2&quot;.</div><br></div>", "i": 8051456}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MUNICIPALIDAD DE PUNTA ARENAS"], "titulo_norma": "COMPLEMENTA DECRETO Nº2.798, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ENERGIA ELECTRICA", "PUNTA ARENAS", "ALUMBRADO PUBLICO", "LUMINARIAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN FECHA DE PROMULGACIÓN", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "266357", "numero_fuente": "38908", "tipo_version"