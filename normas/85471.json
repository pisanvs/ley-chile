{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA </div><div class=\"p\">N&#xFA;m. 50.- Santiago, 20 de Marzo de 1992.- Vistos: Lo dispuesto en el art&#xED;culo 11 del Decreto Ley No. 2.974 de 1979.</div><br><div class=\"p\">Resuelvo:</div><br><br></div>", "i": 6070476}, {"t": "<div><div class=\"p\">Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley citado y en la Regi&#xF3;n Metropolitana al funcionario:</div><br><div class=\"p\">Ronald Walker Riesle.</div><br><br></div>", "i": 6070477}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Alfonso Jasmen Correa Director Nacional (S), INDAP.</div><br></div>", "i": 6070478}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "50", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-50"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-20", "doble_articulado": false, "id_norma": "85471", "numero_fuente": "34249", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-04-23", "vigencias": [{"desde": "1992-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-04-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-04-23",