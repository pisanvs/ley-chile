{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10276068}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 925, de 7 septiembre 2021, prohibi&#xF3; circulaci&#xF3;n de veh&#xED;culos que indica en condiciones que se&#xF1;ala, relativas a Campa&#xF1;a Coreset Fiestas Patrias 2021 en la ciudad de Coyhaique, y autoriz&#xF3; a Comisi&#xF3;n Regional de Seguridad de Tr&#xE1;nsito Coreset para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - corte total de calle Plaza entre las calles Lord Cochrane y Dussen, entre las 11:00 y las 12:30 hrs. del d&#xED;a martes 7 de septiembre de 2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10276069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Jimena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10276070}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "925 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-925 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2024038", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-07", "doble_articulado": false, "id_norma": "1166406", "numero_fuente": "43077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-14", "vigencias": [{"desde": "2021-10-14", "hasta": "", "tipo_versi