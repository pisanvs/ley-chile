{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292789}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 499 de 24 de Mayo de 1994 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, sustit&#xFA;yese el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 1364, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA COLOSO S.A., R.U.T. N&#xB0; 93.065.000-5, para realizar actividades pesqueras, en orden a operar la nave individualizada en el numeral precedente, en el litoral de las Regiones I a IV, donde podr&#xE1; extraer, mediante cerco, los siguientes recursos hidrobiol&#xF3;gicos: Anchoa, Caballa, Jurel y Sardina. </div></div>", "i": 8292790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 24 de Mayo de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292791}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "499", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-499"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "AUTORIZACION", "SOCIEDAD PESQUERA COLOSO S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-05-24", "fecha_derogacion": "1999-10-30", "doble_articulado": false, "id_norma": "34962", "numero_fuente": "34884", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1994-06-08", "vigencias": [{"desde": "1999-10-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1994-06-08", "hasta": "1999-10-29", "tipo_version": "0", "tipo_version_s