{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION No. 2.675 EXENTA, DE 1989 </div></div>", "i": 6066766}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 2.675 de fecha 11 de octubre de 1989, de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, subrogante se autoriz&#xF3; a la Sede Central del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Comercio Exterior ESCE de Valpara&#xED;so, para impartir plan y programas de estudio aprobado para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico que se se&#xF1;ala a partir del a&#xF1;o 1988:</div><div class=\"p\">Carrera: T&#xE9;cnico Agropecuario</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico Agropecuario </div></div>", "i": 6066767}, {"t": "<div><div class=\"p\">Santiago, 27 de Diciembre de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6066768}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2675 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2675 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION No. 2.675 EXENTA, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-11", "doble_articulado": false, "id_norma": "83974", "numero_fuente": "33572", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-17", "vigencias": [{"desde": "1990-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-17", "fin_vigencia": ""}, "vigencias_version_norma