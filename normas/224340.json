{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6475746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 941, de 6 de abril de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Gardar&quot;, en las &#xE1;reas que a continuaci&#xF3;n se indican, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos:</div><div class=\"p\">a) En el &#xE1;rea mar&#xED;tima comprendida desde la III a la X Regiones, con arte de cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima de la III Regi&#xF3;n, con arrastre de media agua: Jibia; c) En el &#xE1;rea mar&#xED;tima comprendida desde la IV a la X Regiones, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia.</div><br></div>", "i": 6475747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6475748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "941", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-941"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-04-06", "fecha_derogacion": "2006-08-07", "doble_articulado": false, "id_norma": "224340", "numero_fuente": "37849", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-30", "vigencias": [{"desde": "2006-08-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Últim