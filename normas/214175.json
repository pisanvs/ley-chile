{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;717 de fecha 31 de julio de 2003, se expropi&#xF3; el lote de terreno N&#xBA;14-J, superficie 2.265 m&#xB2;, rol N&#xBA;217-65, comuna de Curepto, VII Regi&#xF3;n, para la obra &quot;Camino Ruta K-60 y K-16 Sector Mejoramiento Gualleco-Curepto-Puente Lautaro Tramo Km.</div><div class=\"p\">46,180 a Km. 83,91430&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Germ&#xE1;n Antonio Rojas Concha, ascendente a la cantidad de $493.162. </div></div>", "i": 6437639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6437640}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "717 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-717 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-31", "doble_articulado": false, "id_norma": "214175", "numero_fuente": "37649", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-01", "vigencias": [{"desde": "2003-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-09-01", "fecha_version": "2003-09-01", "fecha_actualizacion_texto": "2003-09-01", "tipo_trat