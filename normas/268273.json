{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6746511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.771, de 28 de diciembre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CISNE S.A. para ampliar actividades extractivas con la nave f&#xE1;brica &quot;Cisne Verde&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 47&#xB0; y 57&#xB0; L.S., por fuera de las l&#xED;neas de base recta y hasta el l&#xED;mite oeste correspondiente a la l&#xED;nea imaginaria trazada a una distancia de 80 millas marinas, con palangre, sobre el recurso Pejerrata Coelorhynchus fasciatus, en calidad de fauna acompa&#xF1;ante de los recursos Merluza del sur y Congrio dorado.</div><br></div>", "i": 6746512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de diciembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6746513}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3771 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3771 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-28", "doble_articulado": false, "id_norma": "268273", "numero_fuente": "38957", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-01-10", "vigencias": [{"desde": "2008-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-0