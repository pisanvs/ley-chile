{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DE REGIMEN DE CAMBIO DE SUJE-TO DE IVA A FORESTAL TESALA LTDA.</div><br></div>", "i": 6460220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08.N&#xBA; Ex- 2.631, de fecha 31 de diciembre de 2003, excepciona, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, a Forestal Tesala Ltda., RUT N&#xBA; 77.674.750-5, del r&#xE9;gimen de cambio de sujeto de IVA, en las ventas de madera, establecido en la resoluci&#xF3;n N&#xBA; Ex-4.916 31/10/00, de la Direcci&#xF3;n Nacional. Consecuencialmente, la peticionaria excepcionada pasa a tener la calidad de agente retenedor del Impuesto al Valor Agregado en sus operaciones de compras de madera. </div></div>", "i": 6460221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Concepci&#xF3;n, 31 de diciembre de 2003.- Ram&#xF3;n Ram&#xED;rez Toledo, Director Regional (S).</div><br></div>", "i": 6460222}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2631 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-2631 EXENTA"}, {"tipo": "3", "numero": "DRE-08-2631 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-2631 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "EXCEPCIONA DE REGIMEN DE CAMBIO DE SUJETO DE IVA A FORESTAL TESALA LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-31", "doble_articulado": false, "id_norma": "220333", "numero_fuente": "37764", "tipo_version": "3", "tipo_version_s": "