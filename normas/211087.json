{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6426423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.078, de 27 de mayo de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ITATA S.A. para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Barrio Industrial s/n, Caldera, III Regi&#xF3;n, en las l&#xED;neas de proceso de harina y aceite el recurso hidrobiol&#xF3;gico Krill.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, la peticionaria podr&#xE1; utilizar en las l&#xED;neas de proceso antes indicadas los desechos de recursos hidrobiol&#xF3;gicos que provengan de otras l&#xED;neas de elaboraci&#xF3;n.</div><br></div>", "i": 6426424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de mayo de 2003.-&nbsp; Felipe Sandoval Precht, Subsecretar&#xED;a de Pesca.</div><br></div>", "i": 6426425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1078", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1078"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-27", "doble_articulado": false, "id_norma": "211087", "numero_fuente": "37583", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-13", "vigencias": [{"desde": "2003-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-06-13", "fin_vigencia": "", "tipo_version": "