{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 602, de 29 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rectif&#xED;quese el numeral 3&#xBA; letra a) de la resoluci&#xF3;n N&#xBA; 1.444, de 1997 de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA BIO BIO LIMITADA, hoy Pesquera B&#xED;o B&#xED;o S.A., para ampliar actividades pesqueras extractivas con la nave Biomar III, en el sentido que a continuaci&#xF3;n se indica:</div><div class=\"p\">a) Elim&#xED;nese la expresi&#xF3;n como fauna acompa&#xF1;ante de Merluza com&#xFA;n; b) Agr&#xE9;guese las siguientes especies, al &#xE1;rea de pesca autorizada: Anguila, Blanquillo, Pampanito y Tollo de cachos.</div><br></div>", "i": 8330101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330102}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "602", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-602"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA BIO BIO LIMITADA", "PESQUERA BIO BIO S.A.", "AMPLIACION", "RECTIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-04-29", "fecha_derogacion": "2014-01-04", "doble_articulado": false, "id_norma": "99240", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-05-18", "vigencias": [{"desde": "2014-01-04", "hasta": "", "tipo_version": "2", "