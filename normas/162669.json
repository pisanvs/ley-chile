{"html": [{"t": "<div><div class=\"p\">NOTIFICACION </div></div>", "i": 6256035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Expropiaci&#xF3;n: Por DS N&#xB0; 134, de 14 de Mayo de 1985, Ministerio Obras P&#xFA;blicas, se expropi&#xF3; para obras SENDOS, Parte predio rol 632-7 Molina, inscrito a fs. 236 N&#xB0; 193 Registro Propiedad 1982 Conservador Bienes Ra&#xED;ces Molina, a nombre de don Jorge Fernando Gonz&#xE1;lez Gonz&#xE1;lez. Parte expropiada tiene superficie de 30.000 metros cuadrados y deslinda: Norte, Sur y Oeste, Enrique Marchant; y Este, Camino Vecinal. En Tercer Juzgado Letras, Talca, se consignaron $ 232.920.- Conforme D.L.</div><div class=\"p\">N&#xB0; 2.186, se conmina a titulares derechos reales y acreedores, para efectos legales.</div><br><br></div>", "i": 6256036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Albina Rivas Reyes, secretaria titular. </div></div>", "i": 6256037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "134", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-134"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-14", "doble_articulado": false, "id_norma": "162669", "numero_fuente": "32237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-01", "vigencias": [{"desde": "1985-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu