{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO ALCALDICIO No. 876, DE 1987 </div></div>", "i": 6190397}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Alcaldicio No. 1 . 537 de 03 de Diciembre de 1987 la I. Municipalidad de Renca dispuso la modificaci&#xF3;n del Decreto No. 876 de 03.08.87 que orden&#xF3; la expropiaci&#xF3;n de una parte del terreno ubicado en la comuna de Renca y necesario para la apertura y/o ensanche de la calle Manuel Rodr&#xED;guez, entre las calles Arturo Prat, Seis y Jos&#xE9; Miguel Infante. Dicha modificaci&#xF3;n se refiere s&#xF3;lo al punto No. 4 del citado Decreto, aument&#xE1;ndose el valor de la indemnizaci&#xF3;n de $ 376.500.- a $ 1.056.500.- atendido el n&#xFA;mero de metros de cierro, terreno y construcci&#xF3;n lo que motiv&#xF3; una rectificaci&#xF3;n del informe de la Comisi&#xF3;n Tasadora de que da cuenta el Decreto Alcaldicio No. 42 de 10.01.87.- </div></div>", "i": 6190398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alcalde.</div><br></div>", "i": 6190399}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "876", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-876"}], "organismos": ["MUNICIPALIDAD DE RENCA"], "titulo_norma": "MODIFICA DECRETO ALCALDICIO No. 876, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-03", "doble_articulado": false, "id_norma": "143115", "numero_fuente": "32945", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-15", "vigencias": [{"desde": "1987-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-15", "fin_vigencia": ""}, "