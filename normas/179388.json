{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL&nbsp; IVA&nbsp; A SUPERMERCADOS MONTECARLO S.A.</div><br></div>", "i": 6313548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Santiago Poniente del SII, por resoluci&#xF3;n N&#xBA; 1.561 exenta, de 29 de noviembre de 2000, concede la calidad de agente retenedor del Impuesto al Valor Agregado en la adquisici&#xF3;n de especies hidrobiol&#xF3;gicas a Supermercados Montecarlo S.A., RUT 83.681.900-4, con vigencia a contar del d&#xED;a 1&#xBA; del mes siguiente al de su publicaci&#xF3;n en el Diario Oficial, y en forma indefinida, mientras se mantenga el fiel cumplimiento de la resoluci&#xF3;n N&#xBA; Ex. 3.311 (D.O.</div><div class=\"p\">03.07.2000).-</div><br></div>", "i": 6313549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge A. de Calisto Bravo, Director Regional. </div></div>", "i": 6313550}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1561 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1561 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA", "SANTIAGO PONIENTE"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A SUPERMERCADOS MONTECARLO S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-19", "doble_articulado": false, "id_norma": "179388", "numero_fuente": "36843", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-12-21", "vigencias": [{"desde": "2000-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-12-21", "fin