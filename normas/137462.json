{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,515.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a la viuda del ex-C&#xF3;nsul Jeneral de Chile en Roma, don Luis Santos Rodr&#xED;guez, una pension anual de tres mil seiscientos pesos ($ 3,600).</div><br></div>", "i": 6172186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, quince de julio de mil novecientos once.- Ramon Barros Luco.- Enrique A. Rodr&#xED;guez.</div><br></div>", "i": 6172187}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2515", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2515"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-07-15", "doble_articulado": false, "id_norma": "137462", "numero_fuente": "10052", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-08-09", "vigencias": [{"desde": "1911-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-08-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"