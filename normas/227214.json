{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 1137 </div></div>", "i": 6486205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1137, celebrada el 1 de julio de 2004, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">1137-01-040701 - Modifica Cap&#xED;tulo III.H.1 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el horario establecido en el tercer p&#xE1;rrafo del N&#xBA; 4 de las Disposiciones Transitorias contenidas en el Cap&#xED;tulo III.H.1 del Compendio de Normas Financieras, sustituyendo la expresi&#xF3;n &quot;16.00 horas&quot; por &quot; 17.00 horas&quot;.</div><br></div>", "i": 6486206}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de julio de 2004.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6486207}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1137", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1137"}, {"tipo": "5", "numero": "1137-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1137-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1137", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-01", "doble_articulado": false, "id_norma": "227214", "numero_fuente": "37902", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-06", "vigencias": [{"desde": "2004-07-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-06", "fin_