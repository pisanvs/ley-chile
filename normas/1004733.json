{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8761781}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. (exento) N&#xBA;952, de 30 de junio de 2009, se complement&#xF3; el decreto MOP N&#xB0;298, de 30 de abril de 2007, en sus cl&#xE1;usulas 3&#xB0; y 6&#xB0; en lo que respecta al monto de la indemnizaci&#xF3;n provisional y la imputaci&#xF3;n presupuestaria del lote N&#xB0;24. Agr&#xE9;ganse las sumas de $2.694.930 y $3.500.000, respectivamente, a las cl&#xE1;usulas anteriormente citadas.- </div><br></div>", "i": 8761782}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 8761783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "952 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-952 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-30", "doble_articulado": false, "id_norma": "1004733", "numero_fuente": "39426", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-08-01", "vigencias": [{"desde": "2009-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "906", "fecha_ingreso": "2009-08-03", "fecha_version": "2009-08-01", "actualizado_por": "906", "fecha_actualizacion_texto": "2009