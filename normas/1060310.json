{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9419383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 28, de 21 de febrero de 2014, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=1041062&amp;idParte=&amp;idVersion=\">Decreto MOP. (Exento) N&#xBA;996, de 31 de mayo de 2012</a>, a fin de individualizar correctamente el lote de terreno N&#xBA;3, ubicado en la comuna de Isla de Maipo, que figura a nombre de JOSE CELSI Y CIA LTDA, rol de aval&#xFA;o 25-7, superficie 434,5 m2., complementando el informe de tasaci&#xF3;n emitido el 19 de marzo de 2012, mediante acta emanada de la misma comisi&#xF3;n el 07 de enero de 2014, expropiado con motivo de la obra: &quot;Instalaci&#xF3;n de Servicio de Alcantarillado de Aguas Servidas de Isla de Maipo, Colectores Principales - 2&#xBA; Etapa, Planta Elevadora de Aguas Servidas Rosario&quot;, Comuna de Isla de Maipo, Provincia de Talagante, Regi&#xF3;n Metropolitana Santiago.</div><br></div>", "i": 9419384}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9419385}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "28 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-28 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-02-21", "doble_articulado": false, "id_norma": "1060310", "numero_fuente": "40808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-03-15", "vige