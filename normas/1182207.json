{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10369780}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA; 763 de 8 de septiembre de 2022, se tuvo por desistida la expropiaci&#xF3;n del lote de terreno N&#xBA; 5, ordenada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1139349&amp;idParte=&amp;idVersion=\">Decreto Exento MOP N&#xBA;1354 de 8 de noviembre de 2019</a>, para la obra &quot;Concesi&#xF3;n Internacional Ruta 5 Tramo Chill&#xE1;n Collipulli Facilidades Peatonales Sector San Luis&quot;, Regi&#xF3;n del Biob&#xED;o, comuna de Cabrero. En todo lo no modificado se mantiene plenamente vigente el Decreto Exento MOP N&#xBA;1354 de 8 de noviembre de 2019. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div></div>", "i": 10369781}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10369782}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "763 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-763 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2191879", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-09-08", "doble_articulado": false, "id_norma": "1182207", "numero_fuente": "43366", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-10-01", "vigencias": [{"desde": "2022-10-01", "hasta": "", "tipo_version": "3", "tipo_vers