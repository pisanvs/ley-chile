{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.222&nbsp; EXENTO, DE 1997 </div></div>", "i": 6104187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 1.222 de fecha 30 de diciembre de 1997 del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada al Instituto Profesional CEPECH, inscrito en el Registro de Institutos Profesionales bajo el N&#xBA; 99 del a&#xF1;o 1996, la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Inform&#xE1;tica (jornada diurna y vespertina) conducente al t&#xED;tulo profesional de Ingeniero de Ejecuci&#xF3;n en Inform&#xE1;tica, para ser impartida en la ciudad de Santiago, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6104188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de enero de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6104189}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1222 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1222 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.222 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROGRAMAS DE ESTUDIO", "PLANES DE ESTUDIO", "INSTITUTO PROFESIONAL CEPECH"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-30", "doble_articulado": false, "id_norma": "96794", "numero_fuente": "35995", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-19", "vigencias": [{"desde": "1998-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-02-19", "fin_vi