{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6225067}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n de la Fiscal&#xED;a del Ministerio de Obras P&#xFA;blicas F. No. 61, de 19 de Junio de 1986, se ha ordenado pagar la suma de $ 2.168.496 a don Guido Navarrete Almendra, o a quien acredite derecho como valor del 100% del aval&#xFA;o fijado por la Comisi&#xF3;n de Hombres Buenos, m s su reajuste, para el lote No. 2, de una superficie de 720 m2., Comuna de Concepci&#xF3;n, VIII Regi&#xF3;n, para la ejecuci&#xF3;n de la obra Doble V&#xED;a Concepci&#xF3;n a Coronel, sector acceso Sur a nuevo Puente B&#xED;oB&#xED;o. Se deja constancia que el plazo para reclamar judicialmente del aval&#xFA;o es de 30 d&#xED;as contados desde la fecha de la segunda publicaci&#xF3;n que se har&#xE1; en un peri&#xF3;dico de la VIII Regi&#xF3;n.</div><br></div>", "i": 6225068}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas.</div><div class=\"p\">(5) </div></div>", "i": 6225069}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-61"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-19", "doble_articulado": false, "id_norma": "153073", "numero_fuente": "32540", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-05", "vigencias": [{"desde": "1986-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-05", "fin_vigencia": ""}, "vigencias_ve