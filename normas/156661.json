{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 58, DE 1984 </div></div>", "i": 7262015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 146, de 17 de Febrero de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2&#xB0; de la Resoluci&#xF3;n 58, de 1984, de la misma Subsecretar&#xED;a, que autoriz&#xF3; a don Bernardino Bahamonde Bahamonde, para instalar y operar una planta de recursos hidrobiol&#xF3;gicos congelados en Punta Arenas, en orden a incluir entre las especies que puede utilizar como materia prima las siguientes: congrio dorado, merluza de cola, merluza de tres aletas, merluza espa&#xF1;ola, loco, almeja, picoroco, piure, navajuela y raya. </div></div>", "i": 7262016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de Febrero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7262017}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "146", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-146"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 58, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-17", "doble_articulado": false, "id_norma": "156661", "numero_fuente": "32414", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-05", "vigencias": [{"desde": "1986-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-05", "fin_vigencia": ""}, "vigencias_version_nor