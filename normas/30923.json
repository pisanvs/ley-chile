{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; INFORMA DICTACION DE ORDENANZAS </div></div>", "i": 5998627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Se comunica que la Ilustre Municipalidad de La Pintana ha dictado las Ordenanzas Municipales N&#xB0; 01 y 02 del a&#xF1;o 1996, de fechas 23 y 26 de diciembre respectivamente, sobre Derechos Municipales Varios y Tarifas de Aseo y sus Exenciones, las que entrar&#xE1;n en vigencia a contar del 1 de enero de 1997.</div><div class=\"p\">&nbsp; &nbsp; Los ejemplares pueden ser adquiridos en la Secretar&#xED;a Municipal de la Ilustre Municipalidad de La Pintana.</div><br></div>", "i": 5998628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Jaime Pavez Moreno, Alcalde.- Luis Ulloa Verdugo, Secretario Municipal (S).</div><br></div>", "i": 5998629}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "21", "numero": "1", "abreviacion": "ORZ", "descripcion": "Ordenanza", "compuesto": "ORZ-1"}], "organismos": ["MUNICIPALIDAD DE LA PINTANA"], "titulo_norma": "INFORMA DICTACION DE ORDENANZAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ORDENANZA MUNICIPAL", "DERECHOS MUNICIPALES", "ASEO DOMICILIARIO", "BASURA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-23", "doble_articulado": false, "id_norma": "30923", "numero_fuente": "35653", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-30", "vigencias": [{"desde": "1996-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-12-30", "fin_vigencia": "", "tipo_version": "3"}], "event