{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,947.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165874}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Enriqueta Carvallo, viuda de don Juan de Dios Merino Benavente, i a sus hijas solteras do&#xF1;a Luisa, do&#xF1;a Elena i do&#xF1;a Ana Merino Carvallo, la pension de tres mil pesos ($ 3,000) anuales, de la que gozar&#xE1;n con areglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6165875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veinticinco de junio de mil novecientos siete.- Pedro Montt.- Alejandro Lira.</div><br></div>", "i": 6165876}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1947", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1947"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-06-25", "doble_articulado": false, "id_norma": "135572", "numero_fuente": "8841", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-07-05", "vigencias": [{"desde": "1907-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-07-05", "fin_vigencia":