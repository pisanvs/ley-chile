{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6558921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.501, de 29 de diciembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a ERASMO DEL ROSARIO CHAVARRIA PUJADO para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Las Lizas, Km. 53, Comuna y Provincia de Cha&#xF1;aral, III Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Alga Seca y Picado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 3.852 de 2005, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6558922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de diciembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6558923}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4501 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4501 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-29", "doble_articulado": false, "id_norma": "246730", "numero_fuente": "38371", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-24", "vigencias": [{"desde": "2006-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-24", "fin_vigencia": ""}, "vigencias_