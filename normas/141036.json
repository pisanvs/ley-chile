{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.084 EXENTO, DE 1998 </div><br></div>", "i": 6184174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.084 de fecha 17 de diciembre de 1998 del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada a la Universidad de Vi&#xF1;a del Mar, la carrera de T&#xE9;cnico de Nivel Superior en Control Industrial, conducente al t&#xED;tulo de T&#xE9;cnico de Nivel Superior en Control Industrial, para ser impartida en jornada diurna, en su sede de San Felipe, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6184175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de diciembre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6184176}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1084 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1084 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.084 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-17", "doble_articulado": false, "id_norma": "141036", "numero_fuente": "36446", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-23", "vigencias": [{"desde": "1999-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-08-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "