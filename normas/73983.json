{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6040510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile en conformidad con lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de junio de 1997, fue de 6,36% anual.</div><br></div>", "i": 6040511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, junio 18 de 1997.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6040512}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA DE INTERES PROMEDIO", "CAPTACION", "OPERACIONES REAJUSTABLES", "BANCO CENTRAL DE CHILE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-18", "doble_articulado": false, "id_norma": "73983", "numero_fuente": "35795", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-20", "vigencias": [{"desde": "1997-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAV", "fecha_ingreso": "1997-07-10", "fecha_version": "1997-06-20", "fecha_actualizacion_texto": "1997-06-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "est