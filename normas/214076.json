{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437358}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.100, de 26 de agosto de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA LOTA VEDDE S.A. SANTA MARIA Y COMPA&#xD1;IA COMANDITA POR ACCIONES, para ampliar actividades pesqueras extractivas con la nave &quot;Santa Mar&#xED;a II&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la V a VII Regiones, y entre la IX a X Regiones, por fuera del &#xE1;rea de reserva artesanal, con cerco, sobre los siguientes recursos hidrobiol&#xF3;gicos: Sardina espa&#xF1;ola, Caballa, Agujilla, Cojinoba del norte, Machuelo o tritre, Anchoveta blanca, Bacaladillo o mote, Bonito, Cojinoba negra, Cojinoba moteada, Dorado, Palometa, Jurel fino, Jibia, Calamar, Sardina redonda.</div><br></div>", "i": 6437359}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6437360}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2100 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2100 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-26", "doble_articulado": false, "id_norma": "214076", "numero_fuente": "37647", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-29", "vigencias": [{"desde": "2003-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-29", "