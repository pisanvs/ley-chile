{"html": [{"t": "<div><br><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9874640}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 3.218, de 29 de agosto 2017, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en Sitio 15 Santa Olga Manzana C/11, Rol de Aval&#xFA;o N&#xB0; 611-6, comuna Constituci&#xF3;n, superficie 39,99 m2, deslindes seg&#xFA;n plano expropiaciones, propietario aparente H&#xE9;ctor D&#xED;az Figueroa. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, arquitecto, Rodrigo Antonio Silva Lazo, constructor civil, y Pedro Pablo Cruz Weston, arquitecto, seg&#xFA;n informe de 12 junio 2017, fij&#xF3; monto provisional indemnizaci&#xF3;n en $519.870.- pagados al contado.- </div></div>", "i": 9874641}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Omar Guti&#xE9;rrez Mesina, Director Serviu Regi&#xF3;n del Maule. </div><br></div>", "i": 9874642}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3218 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3218 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1332501", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-08-29", "doble_articulado": false, "id_norma": "1113633", "numero_fuente": "41957", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-01-15", "vigencias": [{"desde": "2018-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]