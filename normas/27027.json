{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 11,764 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5970991}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico: Agr&#xE9;gase al art&#xED;culo 44 de la ley N.o 11,764, reemplazando el punto final (.) por una coma (,), la siguiente frase: &quot;y del art&#xED;culo 2.o de la ley N.o 9,864&quot;.</div><div class=\"p\">&nbsp; &nbsp; Para este &#xFA;ltimo caso, esta equivalencia regir&#xE1; desde el 1.o de Enero de 1955&quot;.</div><br></div>", "i": 5970992}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, catorce de Julio de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Ren&#xE9; Vidal Merino.</div><br></div>", "i": 5970993}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12074", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12074"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "MODIFICA LA LEY N.o 11,764", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTOS COMERCIALES", "ESTUDIO", "COMERCIO", "EQUIVALENCIA", "HUMANIDADES", "INGRESO", "INSTITUCIONES FISCALES", "EMPLEADOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-07-14", "doble_articulado": false, "id_norma": "27027", "numero_fuente": "23509", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-07-27", "vigencias": [{"desde": "1956-07-27", "hasta": "", "tipo_version": "