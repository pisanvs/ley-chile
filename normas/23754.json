{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar a don Ricardo Ahumada Maturana</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,120.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5955043}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- En atencion a los servicios prestados en la guerra del Pac&#xED;fico por don Ricardo Ahumada Maturana, se le concede, por gracia, derecho a jubilar con una pension equivalente al setenta i cinco por ciento del sueldo asignado al empleo que actualmente desempe&#xF1;a.</div><br></div>", "i": 5955044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 7 de Setiembre de 1916.- JUAN LUIS SANFUENTES.- Alberto Romero.</div><br></div>", "i": 5955045}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3120", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3120"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE DERECHO A JUBILAR A DON RICARDO AHUMADA MATURANA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RICARDO AHUMADA MATURANA", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-09-07", "doble_articulado": false, "id_norma": "23754", "numero_fuente": "11572", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-09-12", "vigencias": [{"desde": "1916-09-12", "hasta": "", "tipo_version": "3",