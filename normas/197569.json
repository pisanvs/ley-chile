{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6379831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;449, de 28 de febrero de 2002, se expropi&#xF3; el lote de terreno N&#xBA;32, superficie 18.113 m&#xB2;, rol de aval&#xFA;o 104-33, comuna de Curacav&#xED;, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago - Valpara&#xED;so Vi&#xF1;a del Mar Tramo 6A1: Kms. 31.430,00 al 33.260,00. Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Ana Margarita Violeta Amaro Araya y otros, ascendente a la cantidad de $151.777.637.- para el lote N&#xBA;32.</div><br></div>", "i": 6379832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6379833}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "449", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-449"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-28", "doble_articulado": false, "id_norma": "197569", "numero_fuente": "37248", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-02", "vigencias": [{"desde": "2002-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-05-03", "fecha_version": "2002-05-02", "fecha_actualizacion_tex