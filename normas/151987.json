{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8357108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;85, de 13 de enero de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA;1.556 de 1998, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesca y Servicios Maritimos Limitada, para operar una nave en construcci&#xF3;n por sustituci&#xF3;n de la nave &apos;&apos;Sirius Star&apos;&apos;, en el &#xE1;rea mar&#xED;tima de la I y II Regiones, respecto de los recursos hidrobiol&#xF3;gicos Anchoveta, Sardina espa&#xF1;ola, Jurel, Agujilla, Bacaladillo o mote, Bonito, Caballa y Cojinoba del norte.</div><br></div>", "i": 8357109}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de enero de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8357110}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-85"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-13", "doble_articulado": false, "id_norma": "151987", "numero_fuente": "36569", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-22", "vigencias": [{"desde": "2000-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones"