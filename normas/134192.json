{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,128.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6161589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese a don Juan de la Fuente derecho de jubilar con arreglo a los a&#xF1;os de servicio que ten&#xED;a a la fecha de su separaci&#xF3;n del empleo de director de contabilidad de los Ferrocarriles del Estado i con el setenta i cinco por ciento del sueldo que entonces disfrutaba.</div><br></div>", "i": 6161590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a 30 de noviembre de 1898.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 6161591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1128", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1128"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-11-30", "doble_articulado": false, "id_norma": "134192", "numero_fuente": "6172", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-10", "vigencias": [{"desde": "1898-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-12-10", "fin_vigencia": "", "tipo_vers