{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9290912}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.262, de 14 de agosto de 2012, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xB0; 2.575, de 2011, de esta Subsecretar&#xED;a, correspondiente al &#xE1;rea de manejo Islas Huichas, Sector J, XI Regi&#xF3;n, del SINDICATO DE TRABAJADORES INDEPENDIENTES DE LA PESCA ARTESANAL NUEVO HORIZONTE DE PUERTO AGUIRRE, en virtud del art&#xED;culo 11 del DS N&#xB0; 355, de 1995, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n y lo dispuesto en la resoluci&#xF3;n extractada, cuyo texto &#xED;ntegro se encuentra publicado en la p&#xE1;gina web www.subpesca.cl.</div></div>", "i": 9290913}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de agosto de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9290914}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2262 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2262 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-08-14", "doble_articulado": false, "id_norma": "1043187", "numero_fuente": "40344", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-23", "vigencias": [{"desde": "2012-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci