{"html": [{"t": "<div><div class=\"p\">&#xA0;</div><div class=\"p\">EXTRACTO</div><br><br></div>", "i": 9685546}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 347, de fecha 24 de febrero de 2016, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; mediante un Permiso Complementario a la empresa de origen boliviano &quot;Camila S.R.L.&quot; para efectuar servicio de transporte terrestre internacional de pasajeros entre Bolivia y Chile, atendiendo el servicio de Oruro (Bolivia)/Iquique (Chile), utilizando el paso fronterizo Pisiga - Colchane y viceversa, con seis (6) frecuencias semanales de ida y vuelta. Los d&#xED;as lunes, martes, mi&#xE9;rcoles, jueves, viernes y domingo.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 9685547}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Enrique L. Arce Klein, Unidad de Permisos Internacionales, Subsecretar&#xED;a de Transportes.</div><br></div>", "i": 9685548}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "347 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-347 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1008605; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-02-24", "doble_articulado": false, "id_norma": "1088719", "numero_fuente": "41416", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-03-24", "vigencias": [{"desde": "2016-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "