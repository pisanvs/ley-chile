{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,066 que concede un suplemento al Presupuesto de Guerra</div><div class=\"p\">&nbsp; &nbsp; Lei num. 2,066.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de sesenta mil pesos ($ 60,000) al &#xED;tem 240 de la partida 8.a del Presupuesto de Guerra vijente.</div><br></div>", "i": 5952709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 23 de diciembre de 1907.- PEDRO MONTT.- Belisario Prats B.</div><br></div>", "i": 5952710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2066", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2066"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NUM. 2,066 QUE CONCEDE UN SUPLEMENTO AL PRESUPUESTO DE GUERRA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1907", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-12-23", "doble_articulado": false, "id_norma": "23103", "numero_fuente": "8983", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-12-24", "vigencias": [{"desde": "1907-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-12-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia