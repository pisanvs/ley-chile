{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 724, de 25 de mayo de 1998, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud presentada por CONSTRUCCIONES Y CARPINTERIA NAVAL S.A., para ampliar el plazo para realizar actividades pesqueras extractivas con la nave &apos;&apos;Antonio Lorenzo&apos;&apos;, autorizada por resoluci&#xF3;n N&#xBA; 291, de 1989, N&#xBA; 1.525, de 1991, y N&#xBA; 16, de 1998 todas de esta Subsecretar&#xED;a, en virtud de no haberse acreditado una circunstancia de fuerza mayor o caso fortuito.</div><br></div>", "i": 8330277}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330278}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "724", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-724"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "CONSTRUCCIONES Y CARPINTERIA NAVAL S.A.", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-25", "doble_articulado": false, "id_norma": "99527", "numero_fuente": "36078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-01", "vigencias": [{"desde": "1998-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-01