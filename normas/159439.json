{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 20, DE 2000</div><br><br></div>", "i": 6245057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA;20, de 17 de enero de 2000, se ha aprobado el convenio de fecha 20 de diciembre de 1999, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Ch&#xE9;pica, que rectifica el convenio de traspaso de la Escuela B&#xE1;sica G N&#xBA;321 de Ch&#xE9;pica, traspasada a dicha Corporaci&#xF3;n por convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA;5.475, de 19 de agosto de 1981.</div><br></div>", "i": 6245058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de febrero de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6245059}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "20", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-20"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 20, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-17", "doble_articulado": false, "id_norma": "159439", "numero_fuente": "36603", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-02", "vigencias": [{"desde": "2000-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-03-02", "fecha_version": "2000-