{"html": [{"t": "<div><br><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS A DCV REGISTROS S.A.</div><br></div>", "i": 8958496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico: Que, por escritura p&#xFA;blica de fecha 27 de julio de 2010, otorgada en la Notar&#xED;a de Santiago de don Ren&#xE9; Benavente Cash, domiciliado en calle Hu&#xE9;rfanos 979, 7&#xBA; piso, Santiago, se redujo el acta de la junta extraordinaria de accionistas de DCV Registros S.A., celebrada en la misma fecha.</div><div class=\"p\">&nbsp; &nbsp;  Que, por resoluci&#xF3;n exenta N&#xBA; 456 de fecha 30 de julio de 2010, de esta Superintendencia de Valores y Seguros, se aprob&#xF3; la reforma de estatutos sociales, consistente en:</div><div class=\"p\">&nbsp; &nbsp;  Aumentar el n&#xFA;mero de directores de 10 a 11 miembros.</div></div>", "i": 8958497}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de julio de 2010.- Carmen Undurraga Mart&#xED;nez, Secretario General.</div></div>", "i": 8958498}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "456 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-456 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS A DCV REGISTROS S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-07-30", "doble_articulado": false, "id_norma": "1015960", "numero_fuente": "39728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-08-05", "vigencias": [{"desde": "2010-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010