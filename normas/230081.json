{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6496142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 2.440, de 1 de septiembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a COYA SUR Y COMPA&#xD1;IA LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Costanera Sur, Playa Los Gringos s/n, Arica, I Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n de Cocido, Fresco-enfriado, Fresco-refrigerado, Congelado, Seco-salado, Ahumado, Harina, Aceite, Deshidratado, Salaz&#xF3;n o Salado-h&#xFA;medo y Semiconserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6496143}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6496144}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2440 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2440 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-01", "doble_articulado": false, "id_norma": "230081", "numero_fuente": "37958", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-09", "vigencias": [{"desde": "2004-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-09-