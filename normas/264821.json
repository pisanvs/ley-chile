{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7353791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n N&#xBA;345, de 22 de agosto de 2007, Serviu</div><div class=\"p\">Regi&#xF3;n del B&#xED;o B&#xED;o orden&#xF3; expropiaci&#xF3;n parcial del</div><div class=\"p\">inmueble ubicado en calle Paicav&#xED; N&#xBA;2555-2595, Rol de</div><div class=\"p\">aval&#xFA;o N&#xBA;7022-14, comuna de Concepci&#xF3;n, superficie</div><div class=\"p\">aproximada 228,375 metros cuadrados de terreno, dentro</div><div class=\"p\">pol&#xED;gono y linderos se&#xF1;alados en plano expropiaci&#xF3;n N&#xBA;</div><div class=\"p\">S8R-21.671, de aparente dominio de Bodegas del Sur</div><div class=\"p\">Limitada, para ejecuci&#xF3;n obras de pavimentaci&#xF3;n del</div><div class=\"p\">proyecto &quot;Mejoramiento Vial Eje Paicav&#xED;&quot;, conforme</div><div class=\"p\">art&#xED;culo 51 ley 16.391 y D.L. 2186. Comisi&#xF3;n peritos integrada por Iv&#xE1;n Cerda Espinoza, ingeniero civil;</div><div class=\"p\">H&#xE9;ctor Pe&#xF1;a R&#xED;os, constructor civil, y Mar&#xED;a Alejandra Guti&#xE9;rrez F., arquitecta, seg&#xFA;n informe de fecha 20 de agosto de 2007, fij&#xF3; monto provisional indemnizaci&#xF3;n en $22.643.838, pagadera de contado.</div><br></div>", "i": 7353792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Regi&#xF3;n del B&#xED;o B&#xED;o. </div></div>", "i": 7353793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "345", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-345"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGION DEL BIOBÍO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_