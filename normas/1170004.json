{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10292926}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xB0; 3.982, de fecha 06/12/2021, conforme al art&#xED;culo 51 ley 16.391, DL 2.186/1978 y DS 1.128/2012, de Vivienda y Urbanismo, para destinarlo al Proyecto &quot;Mejoramiento Avenida Pablo Neruda y Sim&#xF3;n Bol&#xED;var/Imperial, Temuco&quot;, Serviu Regi&#xF3;n de la Araucan&#xED;a orden&#xF3; la expropiaci&#xF3;n parcial del bien ra&#xED;z denominado Avenida Santa Teresa s/n, Poblaci&#xF3;n Dreves, sin Rol de aval&#xFA;o, comuna de Temuco. La superficie a expropiar aproximada es de 10,10 metros cuadrados, de aparente dominio de Fisco de Chile. Comisi&#xF3;n de Peritos integrada por don &#xCD;talo Ignacio Cort&#xE9;s Rocco, Eduardo Antonio Y&#xE1;&#xF1;ez Inzunza y Claudio Marcelo Pezo Mu&#xF1;oz, fij&#xF3; monto de Indemnizaci&#xF3;n Provisional en $2.000.000 seg&#xFA;n Informe N&#xB0; 24-1, de fecha 29.11.2021, pagadero Contado.- </div></div>", "i": 10292927}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director, Serviu Regi&#xF3;n de la Araucan&#xED;a.</div><br></div>", "i": 10292928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3982 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3982 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2054823", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-06", "doble_articulado": false, "id_norma"