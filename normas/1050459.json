{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA CERTIFICADO</div></div>", "i": 9348422}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Se rectifica certificado de la Superintendencia de Valores y Seguros que da cuenta de la existencia de Cruz Blanca Compa&#xF1;&#xED;a de Seguros de Vida S.A., autorizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1050367&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 122, de 18 de abril de 2013</a>, en el siguiente sentido:</div><br><div class=\"p\">1.-&nbsp; Donde dice &quot;Cruz Blanca Salud S.A.&quot;, debe decir &quot;Cruz Blanca Salud S.A., RUT N&#xBA; 76.005.001-6&quot;.</div><br><div class=\"p\">2.-&nbsp; Donde dice &quot;Inversiones CBS SpA&quot;, debe decir &quot;Inversiones CBS SpA, RUT N&#xB0; 76.117.164-K&quot;.</div><br></div>", "i": 9348423, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de abril de 2013.- Carmen Undurraga Mart&#xED;nez, Secretario General.</div></div>", "i": 9348424}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "RECTIFICA CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-04-25", "doble_articulado": false, "id_norma": "1050459", "numero_fuente": "40546", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-29", "vigencias": [{"desde": "2013-04-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-04-29", "fin_vigencia": ""}, "vigencias_ve