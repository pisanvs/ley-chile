{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,940 que da el car&#xE1;cter de sub-director al contador primero de la Direccion del Tesoro i le asigna un sobresueldo.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,940.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952458}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. El contador primero de la Direccion del Tesoro ser&#xE1; sub-director de dicha oficina i tendr&#xE1; un sobresueldo de tres mil pesos anuales.</div><br></div>", "i": 5952459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 24 de Junio de 1907.- PEDRO MONTT.- Guillermo Subercaseaux.</div><br></div>", "i": 5952460}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1940", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1940"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NUM. 1,940 QUE DA EL CARÁCTER DE SUB-DIRECTOR AL CONTADOR PRIMERO DE LA DIRECCION DEL TESORO I LE ASIGNA UN SOBRESUELDO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIRECCION DEL TESORO", "SUBDIRECTOR", "CATEGORIA", "ASIGNACION", "REMUNERACION", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-06-24", "doble_articulado": false, "id_norma": "23027", "numero_fuente": "8838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-07-02", "vigencias": [{"desde": "190