{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6465472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 391, de 11 de febrero de 2004, de</div><div class=\"p\">esta Subsecretar&#xED;a, autor&#xED;zase a SOUTHPACIFIC KORP S.A.</div><div class=\"p\">para ampliar actividades pesqueras extractivas con la</div><div class=\"p\">nave &quot;San Bosco&quot;, en las &#xE1;reas mar&#xED;timas que en cada</div><div class=\"p\">caso se indican, donde podr&#xE1; capturar los siguientes</div><div class=\"p\">recursos hidrobiol&#xF3;gicos: a) Litoral comprendido entre</div><div class=\"p\">las Regiones V y X, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, con cerco: Jibia; b) Litoral comprendido entre las Regiones V y X, por fuera de las 60 millas n&#xE1;uticas, con arrastre de media agua: Jibia. </div></div>", "i": 6465473}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de febrero de 2004.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6465474}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "391", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-391"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-11", "doble_articulado": false, "id_norma": "221463", "numero_fuente": "37792", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-21", "vigencias": [{"desde": "2004-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004