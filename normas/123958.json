{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8334172}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.199 de 13 de agosto de 1998 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA ANDINA S.A., para ampliar actividades pesqueras autorizadas por resoluciones N&#xBA; 271, de 1988, N&#xBA;250, de 1989 y N&#xBA; 396, de 1994, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en camino a Teguel S/N&#xBA;, Dalcahue, provincia de Chilo&#xE9;, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Congelado y Fresco Enfriado: Osti&#xF3;n del norte, Osti&#xF3;n del sur y Pulpo.</div><div class=\"p\">&nbsp; &nbsp;  El recurso Osti&#xF3;n del norte, deber&#xE1; provenir de centros de cultivo autorizados.</div><br></div>", "i": 8334173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de agosto de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8334174}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1199", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1199"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA ANDINA S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-08-13", "fecha_derogacion": "2006-07-14", "doble_articulado": false, "id_norma": "123958", "numero_fuente": "36160", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1