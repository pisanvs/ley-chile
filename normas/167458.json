{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6271382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 745, de 29 de febrero de 2000, se expropiaron los lotes de terreno N&#xBA;s. 13, 14 y 20, superficies 145,70; 164,50 y 241,50 m2, respectivamente, roles de aval&#xFA;os 3409-44, 3409-43 y 3409-37, comuna de Punta Arenas, obra Habilitaci&#xF3;n Costanera Estrecho de Magallanes I, sector Manantiales-Club H&#xED;pico y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Angela Aguila Z&#xFA;&#xF1;iga, Jos&#xE9; Guineo Guineo y Berta Paredes Mansilla, ascendente a las cantidades de $16.247.967;</div><div class=\"p\">$22.740.065 y $37.099.389.</div><br></div>", "i": 6271383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6271384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "745", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-745"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-29", "doble_articulado": false, "id_norma": "167458", "numero_fuente": "36652", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-02", "vigencias": [{"desde": "2000-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-05-02", "fe