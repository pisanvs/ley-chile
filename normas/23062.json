{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LEI NUM. 2,003 QUE CONCEDE UN SUPLEMENTO DE $ 90,000 AL PRESUPUESTO DEL MINISTERIO DEL INTERIOR.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,003.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese un suplemento de noventa mil pesos al &#xED;tem 3,622 de la partida 101 del presupuesto del Ministerio del Interior, para pagar el valor de especies postales.</div><br></div>", "i": 8274920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 4 de setiembre de 1907.-PEDRO MONTT.-Luis A. Vergara.</div><br></div>", "i": 8274921}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2003", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2003"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 2,003 QUE CONCEDE UN SUPLEMENTO DE $ 90,000 AL PRESUPUESTO DEL MINISTERIO DEL INTERIOR.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1907", "MODIFICACION", "MINISTERIO", "INTERIOR", "ESPECIES POSTALES", "PAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-09-04", "doble_articulado": false, "id_norma": "23062", "numero_fuente": "8895", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-09-07", "vigencias": [{"desde": "1907-09-07", "hasta": "", "tipo_