{"html": [{"t": "<div><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10120559}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.008, de fecha 7 de mayo de 2020, Serviu III Regi&#xF3;n de Atacama, conforme DL N&#xB0; 2.186 de 1978 y DS N&#xB0; 51/2019 (V. y U.), orden&#xF3; la expropiaci&#xF3;n parcial del inmueble denominado Lote 5, de la ciudad de Copiap&#xF3;, rol de aval&#xFA;o fiscal N&#xB0; 100-1, de aparente dominio de Sociedad Minera Papaprieto Limitada y Otro, para proyecto &quot;Construcci&#xF3;n Parque Urbano Kaukari, 3&#xB0; Etapa A&quot;. Comisi&#xF3;n tasadora integrada por Ximena Pe&#xF1;aloza Herrero, arquitecta, Norman Calder&#xF3;n Pontiggia, ingeniero agr&#xF3;nomo y Claudio Concha Grossi, ingeniero agr&#xF3;nomo, seg&#xFA;n informe de 5 de mayo de 2020, fij&#xF3; un monto provisional de indemnizaci&#xF3;n de $238.324.100.- pagadera al contado.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10120560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu III Regi&#xF3;n Atacama. </div><br></div>", "i": 10120561}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1008 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1008 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "III REGIÓN DE ATACAMA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1760114", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-05-07", "doble_articulado": false, "id_norma": "1145220", "numero_fuente": "42656", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020