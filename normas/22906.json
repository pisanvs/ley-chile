{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REHABILITA AL TENIENTE DON RICARDO ROJAS ANGULO PARA TRAMITAR SU ESPEDIENTE DE INVALIDEZ.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1776.-Santiago, a 24 de Noviembre de 1905.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5951158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.-Rehabil&#xED;tase, por gracia, al teniente de ej&#xE9;rcito don Ricardo Rojas Angulo para tramitar su espediente de invalidez, en conformidad a la lei de 22 de Diciembre de 1881.</div><br></div>", "i": 5951159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JERMAN RIESCO.-Manuel F&#xF3;ster R.</div><br></div>", "i": 5951160}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1776", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1776"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "REHABILITA AL TENIENTE DON RICARDO ROJAS ANGULO PARA TRAMITAR SU ESPEDIENTE DE INVALIDEZ.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RICARDO ROJAS ANGULO", "EXPEDIENTE INVALIDEZ", "TRAMITACION", "REHABILITACION POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-11-24", "doble_articulado": false, "id_norma": "22906", "numero_fuente": "8365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-11-25", "vigencias": [{"desde": "1905-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"