{"html": [{"t": "<div><div class=\"p\">MODIFICA EL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10081211}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 5.585, de 05.12.2019, del Director Nacional de Aduanas, se modific&#xF3; el contenido de las tablas de los Anexos 51-4 relativo a &quot;Agentes de Cabotaje y Exportaci&#xF3;n&quot;, 51-6 correspondiente a &quot;Consignantes y Consignatarios Especiales&quot;, y 51-3 que contiene la codificaci&#xF3;n de los &quot;Agentes de Aduana&quot;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><br></div>", "i": 10081212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10081213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5585 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5585 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1699136"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-05", "doble_articulado": false, "id_norma": "1140203", "numero_fuente": "42532", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-12-19", "vigencias": [{"desde": "2019-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s