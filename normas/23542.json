{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar a don Osvaldo Vial Lastra.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,850.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5954260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.-Conc&#xE9;dese al Secretario de la Corte de Apelaciones de Santiago don Osvaldo Vial Lastra derecho de jubilar con el sueldo &#xED;ntegro que corresponda al empleo de Juez Letrado del departamento de Santiago. </div></div>", "i": 5954261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de Enero de 1914.-RAMON BARROS LUCO.- Enrique A. Rodriguez.</div><br></div>", "i": 5954262}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2850", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2850"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE DERECHO A JUBILAR A DON OSVALDO VIAL LASTRA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["OSVALDO VIAL LASTRA", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-01-27", "doble_articulado": false, "id_norma": "23542", "numero_fuente": "10790", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-02-04", "vigencias": [{"desde": "1914-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-02-04", "fi