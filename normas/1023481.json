{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div><br></div>", "i": 9118241}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as fue de 0,92% anual durante el mes de febrero de 2011.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, de conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de febrero de 2011, fue de 0,96% anual.</div></div>", "i": 9118242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de marzo de 2011.- Juan Esteban Laval Zald&#xED;var, Ministro de Fe (S).</div></div>", "i": 9118243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-03-03", "doble_articulado": false, "id_norma": "1023481", "numero_fuente": "39902", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-03-05", "vigencias": [{"desde": "2011-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-03-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i