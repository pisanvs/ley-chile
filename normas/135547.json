{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,890.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se declaran de utilidad p&#xFA;blica los terrenos necesarios para la via, estaciones i demas dependencias de los ferrocarriles de Inca a Copiap&#xF3; i Rayado a Los Vilos i del t&#xFA;nel de la Gurupa, en conformidad a los planos aprobados por el Presidente de la Rep&#xFA;blica.</div><br></div>", "i": 6165762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a 5 de diciembre de 1906.- Pedro Montt.-</div><div class=\"p\">C&#xE1;rlos G. Avalos.</div><br></div>", "i": 6165763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1890", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1890"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-12-05", "doble_articulado": false, "id_norma": "135547", "numero_fuente": "8671", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1906-12-10", "vigencias": [{"desde": "1906-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1906-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1906-12-10", "fin_vigencia": "