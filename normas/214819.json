{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.966, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, modif&#xED;canse los numerales 1&#xBA; de las resoluciones N&#xBA; 1.891, de 1995, y N&#xBA; 1.758, de 2001, y el numeral N&#xBA; 2 de la resoluci&#xF3;n N&#xBA; 1.900, de 2001, todas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA ATITLAN S.A. para realizar actividades pesqueras extractivas con la nave &quot;Don Roberto I&quot;, en el sentido de incorporar la siguiente caracter&#xED;stica n&#xE1;utica en esta &#xFA;ltima:</div><br><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 10,40 m</div><br></div>", "i": 7303772}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7303773}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1966 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1966 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-08-21", "fecha_derogacion": "2012-06-23", "doble_articulado": false, "id_norma": "214819", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-09-16", "vigencias": [{"desde": "2012-06-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-09-16", "hasta": "2012-06-22", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2012-06-23", "fin