{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AUTORIZA EMISORES DE BOLETAS ELECTRONICAS </div></div>", "i": 6577064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 88, de 21 de julio de 2006, que autoriza a contribuyentes como emisores de boletas electr&#xF3;nicas.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de boletas electr&#xF3;nicas a los contribuyentes RUT 80.238.000-3 y RUT 76.303.510-7 a contar del mes de julio de 2006.</div><div class=\"p\">El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de julio de 2006.</div><br><br></div>", "i": 6577065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "88 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-88 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES DE BOLETAS ELECTRONICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "EMISORES DE BOLETAS ELECTRONICAS", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-21", "doble_articulado": false, "id_norma": "251621", "numero_fuente": "38523", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-07-26", "vigencias": [{"desde": "2006-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-07-2