{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9283495}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.020, de 18 de julio de 2012, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=244337&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.853, de 2005</a>, s&#xF3;lo en cuanto autoriz&#xF3; a INVERSIONES Y ALIMENTOS INTERMARK LIMITADA para realizar actividades pesqueras extractivas con una nave en construcci&#xF3;n en el &#xE1;rea mar&#xED;tima comprendida entre la III a VI Regi&#xF3;n y VIII Regi&#xF3;n al paralelo 41&#xB0;28,6&apos; L.S., sobre el recurso hidrobiol&#xF3;gico Jibia o Calamar rojo, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y lo informado mediante memor&#xE1;ndum t&#xE9;cnico citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9283496}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9283497}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2020 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2020 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-18", "doble_articulado": false, "id_norma": "1042200", "numero_fuente": "40322", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-27", "vigencias": [{"desde": "2012-07-27