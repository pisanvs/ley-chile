{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 996, de 23 de mayo de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por INVERSIONES Y ASESORIAS EL MANANTIAL LIMITADA, para un centro de cultivo ubicado en Farellones Marimeli, Estero Reloncav&#xED;, Comuna de Cocham&#xF3;, Provincia de Llanquihue, X Regi&#xF3;n, conforme lo dispuesto en el art&#xED;culo 78, inciso 2&#xB0;, de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8295151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 23 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295152}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "996", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-996"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "INVERSIONES ASESORIAS EL MANANTIAL LIMITADA", "COCHAMO", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-23", "doble_articulado": false, "id_norma": "35993", "numero_fuente": "35478", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-29", "vigencias": [{"desde": "1996-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-05-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-05-29", "fin_vigencia": "", "tipo_v