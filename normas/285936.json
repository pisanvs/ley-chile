{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><div class=\"p\">&#xA0;</div></div>", "i": 7418956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 192, del 21 de Diciembre de 1982, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Segunda Regi&#xF3;n, se autoriza a Dn. Patricio Barrios Andrade, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de la locomoci&#xF3;n colectiva de pasajeros.- </div><br></div>", "i": 10137891}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Guido M. Ram&#xED;rez Maturana, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Segunda Regi&#xF3;n.</div><br></div>", "i": 10137892}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "192", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-192"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["PF"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1982-12-21", "doble_articulado": false, "id_norma": "285936", "numero_fuente": "31513", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1983-03-10", "vigencias": [{"desde": "1983-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1983-03-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1983-03-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modifica