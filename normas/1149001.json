{"html": [{"t": "<div><br><div class=\"p\">\t</div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de Septiembre do 1892.- En uso de la atribuci&#xF3;n que me confiere la ley de 30 de Diciembre de 1886 y visto el oficio del Senado, de 9 del presente, </div><br><div class=\"p\">&nbsp; &nbsp;  Decreto: </div><br></div>", "i": 10155196}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Se declara infestado por la epidemia del c&#xF3;lera el puerto de Nueva York. </div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Los vapores, personas y carga procedentes de dicho puerto ser&#xE1;n sometidos a cuarentena &#xF3; &#xE1; medidas de desinfecci&#xF3;n.</div><br></div>", "i": 10155197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- MONTT.- R. Barros Luco.</div><br></div>", "i": 10155198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1886-12-30", "doble_articulado": false, "id_norma": "1149001", "numero_fuente": "4326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1892-09-17", "vigencias": [{"desde": "1892-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1892-09-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1892-09-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "1795", "fecha_ingreso": "2