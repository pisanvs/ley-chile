{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 121, DE 2000 </div></div>", "i": 6262482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 121, de 6 de marzo de 2000, se ha aprobado el convenio de fecha 16 de febrero de 2000, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Cerrillos, que modifica el Convenio de Traspaso del Liceo B N&#xBA; 069 de Cerrillos, traspasada a dicha Corporaci&#xF3;n por convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 509, de 4 de julio de 1986.</div><br></div>", "i": 6262483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de abril de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6262484}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "121", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-121"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 121, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-06", "doble_articulado": false, "id_norma": "164742", "numero_fuente": "36635", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-08", "vigencias": [{"desde": "2000-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "2000-04-10", "fecha_version": "2000-04-08", "fecha_actualizacion_tex