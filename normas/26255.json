{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DECLARA COMPRENDIDOS EN LAS LEYES NUMEROS 6,174 y 6,501 A LOS ALUMNOS DE LAS ESCUELAS MILITAR, NAVAL Y DE AVIACION</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5967626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Decl&#xE1;rase comprendidos en los beneficios de las leyes N.os 6,174, de 31 de Enero de 1938, y N&#xB0; 6,501, de 15 de Enero de 1940, a los alumnos de las Escuelas Militar, Naval y de Aviaci&#xF3;n. </div></div>", "i": 5967627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintitr&#xE9;s de Enero de mil novecientos cincuenta y uno.- GABRIEL GONZALEZ VIDELA.- Guillermo Barrios Tirado.</div><br></div>", "i": 5967628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9867", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9867"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "DECLARA COMPRENDIDOS EN LAS LEYES NUMEROS 6,174 y\n6,501 A LOS ALUMNOS DE LAS ESCUELAS MILITAR, NAVAL Y DE\nAVIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MEDICINA PREVENTIVA", "ESCUELAS", "MILITAR", "NAVAL", "AVIACION", "ALUMNOS", "BENEFICIOS", "INCORPORACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1951-01-23", "doble_articulado": false, "id_norma": "26255", "numero_fuente": "21867", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "195