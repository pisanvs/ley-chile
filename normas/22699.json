{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que autoriza la inversion de 50,000 pesos en la compra de &#xFA;tiles i mobiliario de instruccion primaria Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949332}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cincuenta mil pesos en la adquisicion de &#xFA;tiles i mobiliario para instruccion primaria.</div><br></div>", "i": 5949333}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 19 de Diciembre de 1901.- JERMAN RIESCO.- Rafael Balmaceda.</div><br></div>", "i": 5949334}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1503", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1503"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "QUE AUTORIZA LA INVERSION DE 50,000 PESOS EN LA COMPRA DE UTILES I MOBILIARIO DE INSTRUCCIÓN PRIMARIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTRUCCION PRIMARIA", "UTILES", "MUEBLES", "ADQUISICION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-19", "doble_articulado": false, "id_norma": "22699", "numero_fuente": "7102", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-20", "vigencias": [{"desde": "1901-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {