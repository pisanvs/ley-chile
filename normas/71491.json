{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8303130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 690, de 12 de mayo de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la Resoluci&#xF3;n N&#xBA; 2.205 de 1996, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones habilitados para operar en la unidad de pesquer&#xED;a de Anchoveta y Sardina espa&#xF1;ola, del art&#xED;culo 1&#xBA;, del D.S. N&#xBA; 493 de 1996 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el litoral de la III y IV Regiones, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, en el sentido de incorporar en el numeral 1&#xBA; lo siguiente: &quot;Arturo Molina Focacci&quot;:</div><div class=\"p\">&quot;Triton II&quot;.</div><br></div>", "i": 8303131}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de mayo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8303132}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "690", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-690"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "NOMINA", "ARMADORES INDUSTRIALES", "ANCHOVETA", "SARDINA ESPA OLA", "TERCERA REGION", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-05-12", "fecha_derogacion": "1997-07-17", "doble_articulado": false, "id_norma": "71491", "numero_fuente": "35770", "tipo_version": "2", "tipo_version_s": "Últim