{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6558341}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 167, de 12 de enero de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de las resoluciones N&#xBA; 230 y N&#xBA; 841, ambas de 1991, y N&#xBA; 1.084 de 1995, todas de esta Subsecretar&#xED;a, que autorizaron a SOCIEDAD PESQUERA BUENAVENTURA LTDA., para realizar actividades pesqueras extractivas con la nave &quot;Cahuel II&quot;, en las &#xE1;reas y respecto de los recursos autorizados en dichas resoluciones, todo ello en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y de lo dispuesto en la presente resoluci&#xF3;n.</div><br></div>", "i": 6558342}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6558343}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "167 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-167 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-12", "doble_articulado": false, "id_norma": "246605", "numero_fuente": "38368", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-20", "vigencias": [{"desde": "2006-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-01-20", "fin_v