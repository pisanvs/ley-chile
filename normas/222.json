{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xB0; 395 395-10-941222 - Tasa de inter&#xE9;s para pago diferido de derechos de Aduana.</div><br></div>", "i": 5843709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Se acord&#xF3;, en conformidad con lo establecido en la letra c) del Art. N&#xB0; 10 de la Ley N&#xB0; 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de Aduana durante el semestre que expira el 30 de junio de 1995, ser&#xE1; de 13,0% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.-</div><br></div>", "i": 5843710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jorge Carrasco V&#xE1;squez, Ministro de Fe (S). </div></div>", "i": 5843711}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "395", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-395"}, {"tipo": "5", "numero": "395-10", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-395-10"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N° 395 395-10-941222 - TASA DE INTERES PARA PAGO DIFERIDO DE DERECHOS DE ADUANA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA INTERES", "DERECHOS ADUANA", "PAGO DIFERIDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-22", "doble_articulado": false, "id_norma": "222", "numero_fuente": "35050", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-26", "vigencias": [{"desde": "1994-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci