{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 138, DE 1988 </div></div>", "i": 6147147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 138 de 11 de agosto de 1988 se ha aprobado a la Escuela Especial Diferencial F No. 528 de Concepci&#xF3;n, provincia de Concepci&#xF3;n, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, un plan y programas de estudio especiales de orientaci&#xF3;n laboral para alumnos con d&#xE9;ficit auditivo, que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de 4 a&#xF1;os, a contar desde el a&#xF1;o escolar 1989.</div><br></div>", "i": 6147148}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Agosto de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6147149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "138 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-138 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 138, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-11", "doble_articulado": false, "id_norma": "129489", "numero_fuente": "33160", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-31", "vigencias": [{"desde": "1988-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado