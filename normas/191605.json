{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6357284}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.470 de 28 de septiembre de 2001, se expropiaron los lotes de terrenos N&#xBA;s 72-A y 72-B, superficies 284 y 251 m2., respectivamente, rol de aval&#xFA;o 277-34, comuna de Algarrobo, para la obra Red Vial Litoral Central. Sector 2: Camino Algarrobo-Casablanca (Ruta F-90) Tramo Km. 0.000,00 al Km. 32.100,00, Quinta Regi&#xF3;n se acord&#xF3; el valor de las indemnizaciones con su propietaria Graciela del Carmen Cavieres Carvajal, ascendente a la cantidad de $3.441.933.</div><br></div>", "i": 6357285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6357286}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1470", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1470"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-28", "doble_articulado": false, "id_norma": "191605", "numero_fuente": "37111", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-15", "vigencias": [{"desde": "2001-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-11-15", "fecha_version": "2001-11-15", "fecha_actualizacion_texto": "2001-11-15", "tipo_tr