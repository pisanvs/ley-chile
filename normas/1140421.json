{"html": [{"t": "<div><div class=\"p\">CONDONACI&#xD3;N SOBRE INTERESES Y/O MULTAS</div></div>", "i": 10085916}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 140, de 20 de diciembre de 2019.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Otorga condonaci&#xF3;n sobre los intereses y/o multas infraccionales en los casos que se se&#xF1;alan, a ra&#xED;z de la situaci&#xF3;n del pa&#xED;s, hasta el d&#xED;a 10 de enero de 2020.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div><br></div>", "i": 10085917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "140 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-140 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CONDONACIÓN SOBRE INTERESES Y/O MULTAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1703204", "EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-12-20", "doble_articulado": false, "id_norma": "1140421", "numero_fuente": "42538", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-12-27", "vigencias": [{"desde": "2019-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-12-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-12-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],