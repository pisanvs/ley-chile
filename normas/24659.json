{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia al ex-guardi&#xE1;n de la Penitenciar&#xED;a de Santiago, Jos&#xE9; 2.o Pizarro Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 7168599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, al ex-guardi&#xE1;n de la Penitenciar&#xED;a de Santiago, don Jos&#xE9; 2.o Pizarro, una pensi&#xF3;n de 20 pesos al mes.</div><div class=\"p\">&nbsp; &nbsp; La pensi&#xF3;n otorgada por esta ley se disfrutar&#xE1; por el plazo de diez a&#xF1;os.</div><br></div>", "i": 7168600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinte de Febrero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Enrique Balmaceda. </div></div>", "i": 7168601}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4320", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4320"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE PENSION DE GRACIA AL EX GUARDIAN DE LA PENITENCIARIA DE SANTIAGO, JOSE SEGUNDO PIZARRO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JOSE SEGUNDO PIZARRO", "PENSION DE GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-20", "doble_articulado": false, "id_norma": "24659", "numero_fuente": "15026", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-03-16", "vigencias": [{"desde": "1928-03-16", "hasta": "", "tipo_version