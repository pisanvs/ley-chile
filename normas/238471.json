{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6527787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.606, de 26 de mayo de 2005, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la autorizaci&#xF3;n de acuicultura otorgada mediante resoluciones N&#xBA; 347 de 1982 y N&#xBA; 252 de 1987, ambas de esta Subsecretar&#xED;a, a SOCIEDAD AGRICOLA AGUAS CLARAS LTDA. para una piscicultura ubicada en Hijuela II del ex fundo &quot;El Guanaco&quot;, comuna de Pe&#xF1;aflor, Regi&#xF3;n Metropolitana, en virtud del art&#xED;culo 142 letra e) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6527788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de mayo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6527789}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1606", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1606"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-26", "doble_articulado": false, "id_norma": "238471", "numero_fuente": "38175", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-06-02", "vigencias": [{"desde": "2005-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-06-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modif