{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6458145}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 3.366 de 16 de diciembre de 2003 de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD ALIMENTICIA Y COMERCIAL BAUERLE S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Barros Arana 2440, Arica, donde podr&#xE1; procesar, en las l&#xED;neas&nbsp; de elaboraci&#xF3;n de Salaz&#xF3;n y Semi Conserva el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto las resoluciones N&#xBA; 31 de 1991 y N&#xBA; 263 de 1993, ambas de esta Subsecretar&#xED;a, en virtud de la carta presentada por Nova Mar S.A. y del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6458146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de diciembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6458147}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3366 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3366 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-12-16", "fecha_derogacion": "2006-10-06", "doble_articulado": false, "id_norma": "219928", "numero_fuente": "37755", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-01-09", "vigencias": [{"desde": "2006-10-06", "hasta": "", "tipo_version": "2", "tipo_versi