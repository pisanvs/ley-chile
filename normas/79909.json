{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 180 DE 1991</div><br><br></div>", "i": 7214860}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 180 de fecha 11 de Julio de 1991 del Ministerio de Educaci&#xF3;n, se sustituyeron los incisos 2&#xB0; y siguientes del Art&#xED;culo 2&#xB0; del Decreto Exento No. 121 de 1989, que autoriza el funcionamiento del Instituto Profesional Academia de Idiomas y Estudios Profesionales AIEP.</div><div class=\"p\">Por este mismo cuerpo legal, se aprobaron las modificaciones al reglamento a que se refiere el Art&#xED;culo 6&#xB0; del DFL No. 5 de 1981, sobre las condiciones para el otorgamiento de los t&#xED;tulos profesionales o t&#xE9;cnicos.</div><br></div>", "i": 7214861}, {"t": "<div><div class=\"p\">Santiago, 08 de Noviembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7214862}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "180 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-180 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 180 DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-11", "doble_articulado": false, "id_norma": "79909", "numero_fuente": "34126", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-26", "vigencias": [{"desde": "1991-11-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-26", "fin_vigencia": "", "tipo_versi