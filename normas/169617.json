{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7270495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 858 de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; PESQUERA ITATA S.A. para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 984 de 1986, N&#xBA; 671 de 1992 y N&#xBA; 1136 de 1999, todas de esta Subsecretar&#xED;a, en orden a procesar en su planta ubicada en Avenida Pedro Montt N&#xBA; 704, San Vicente, Talcahuano, VIII Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n de fresco-enfriado, el recurso hidrobiol&#xF3;gico jurel.</div><br></div>", "i": 7270496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de mayo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7270497}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "858", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-858"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-11", "doble_articulado": false, "id_norma": "169617", "numero_fuente": "36676", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-30", "vigencias": [{"desde": "2000-05-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modifi