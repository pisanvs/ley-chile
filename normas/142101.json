{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 310, DE 1986 </div></div>", "i": 7252940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 310 de 11 de diciembre de 1986 se ha aprobado, a la Fundaci&#xF3;n Educacional del Sur, un plan de estudio especial para la Ense&#xF1;anza B&#xE1;sica de Adultos que se aplicar&#xE1; a contar de 1987.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio especiales para las asignaturas de Orientaci&#xF3;n Familiar y Capacitaci&#xF3;n Laboral los que deber&#xE1;n cumplir objetivos que se se&#xF1;alan.</div><div class=\"p\">&nbsp; &nbsp;  Se dan normas especiales de evaluaci&#xF3;n y promoci&#xF3;n de las alumnas.</div><br></div>", "i": 7252941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Marzo de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7252942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "310 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-310 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 310, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-11", "doble_articulado": false, "id_norma": "142101", "numero_fuente": "32742", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-08", "vigencias": [{"desde": "1987-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-08", "fin_vigencia": ""}, "vigencias_version_norma