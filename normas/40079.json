{"html": [{"t": "<div><div class=\"p\">DELEGA EN EL JEFE DE LA OFICINA JURIDICA REGIONAL FACULTADES QUE INDICA</div><br><br></div>", "i": 6025798}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n N&#xB0; Ex. 2.103, de 30 de agosto de 1994, el suscrito deleg&#xF3; en el Jefe de la Oficina Jur&#xED;dica Regional las funciones descritas en los n&#xFA;meros 1 al 8 del dispositivo Primero de la Resoluci&#xF3;n N&#xB0; Ex.</div><div class=\"p\">2.482, de la Direcci&#xF3;n Nacional, de 3 de junio de 1994, publicada en extracto en el Diario Oficial del d&#xED;a 6 del mismo mes y a&#xF1;o, revoc&#xE1;ndose, adem&#xE1;s la resoluci&#xF3;n N&#xB0; Ex. 1.813, de fecha 28 de agosto de 1981, en lo pertinente.-</div><br></div>", "i": 6025799}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mario Valenzuela Ram&#xED;rez, Director Regional. </div></div>", "i": 6025800}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2103 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2103 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "DELEGA EN EL JEFE DE LA OFICINA JURIDICA REGIONAL;FACULTADES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["OFICINA JURIDICA REGIONAL", "JEFE", "DELEGACION", "FACULTAD", "DIRECCION REGIONAL", "SERVICIO IMPUESTOS", "INTERNOS", "NOVENA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-08-30", "doble_articulado": false, "id_norma": "40079", "numero_fuente": "34959", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-09-06", "vigencias": [{"desde": "1994-09-06", "hasta": "", "tipo_version": "3", "tipo_v