{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;187, DE 2005 </div></div>", "i": 6525430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 187, de 27 de abril de 2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se dispuso el inicio de la puesta en marcha definitiva de la planta Clase AB de la comuna de Litueche, parte de la Concesi&#xF3;n Dos, adjudicada a &quot;Revisiones T&#xE9;cnicas Serviden Limitada&quot;, dotada de una (1) l&#xED;nea de revisi&#xF3;n tipo liviana y una (1) l&#xED;nea de revisi&#xF3;n tipo pesada, a contar del 28 de abril de 2005.</div><br></div>", "i": 6525431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Pablo Pallamar Az&#xFA;a, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Sexta Regi&#xF3;n.</div><br></div>", "i": 6525432}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "187", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-187"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº187, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-27", "doble_articulado": false, "id_norma": "237801", "numero_fuente": "38158", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-11", "vigencias": [{"desde": "2005-05-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-11", "fin_vigencia": ""}, "vige