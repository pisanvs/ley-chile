{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6197590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA;1.426, de 31 de agosto de 1998, se expropiaron, los lotes de terreno N&#xBA;s.27 y 75, superficies 80 y 130m2. respectivamente, roles de aval&#xFA;os en tr&#xE1;mite y 221-2, comuna de Chimbarongo, para la obra Ruta I-85-j, sector Cruce Longitudinal (Chimbarongo) - Codegua, se acord&#xF3; precio de las indemnizaciones con sus propietarios Francisco Javier Celis Sandoval y otros y Obispado de Rancagua, ascendentes a las cantidades de $500.940.- para el lote N&#xBA;27 y $941.985.- para el lote N&#xBA;75.-</div><br></div>", "i": 6197591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6197592}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1426", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1426"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-31", "doble_articulado": false, "id_norma": "145486", "numero_fuente": "36489", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-10-15", "vigencias": [{"desde": "1999-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1999-10-15", "fecha_version": "1999-10-15", "fecha_actualizacion