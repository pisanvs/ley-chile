{"html": [{"t": "<div><div class=\"p\">NOTIFICACI&#xD3;N </div></div>", "i": 7375669}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.958 de 25 de junio de 2008 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme D.L. N&#xBA;2.186 de 1978, del inmueble ubicado en Av. Jos&#xE9; Mar&#xED;a Caro 3234 Sta. M&#xF3;nica, Rol de Aval&#xFA;o N&#xBA;5105-385, comuna de Recoleta, de aparente dominio de Soto Sedan Julia del Carmen;</div><div class=\"p\">correspondiente al Lote N&#xBA;43, del Proyecto Vial &quot;Habilitaci&#xF3;n de Corredor de Transporte P&#xFA;blico Avda. Dorsal&quot;. Comisi&#xF3;n integrada por peritos Mar&#xED;a Ang&#xE9;lica Hurtado Arranz, Arquitecto; Alfredo Irizarri Valderrama, Arquitecto; y Carmen P. R&#xED;os Marcuello, Ingeniero Civil, seg&#xFA;n informe de 19 de mayo de 2008, fij&#xF3; monto provisional indemnizaci&#xF3;n en $2.481.950, pagadera al contado.</div><br></div>", "i": 7375670}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Metropolitano(S).</div><br></div>", "i": 7375671}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3958 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3958 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "DISPONE EXPROPIACIÓN PARCIAL Y TOTAL DE INMUEBLES QUE INDICAN; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-25", "doble_articulado": false, "id_norma": "274312", "numero_fuente": "39113", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-07-