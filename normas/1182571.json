{"html": [{"t": "<div><div class=\"p\">MODIFICA COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10371268}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.530, de fecha 28.09.2022, de la Directora Nacional de Aduanas, se modifica el <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>, en sus Anexos 51-7 y 51-15, en el sentido de agregar el c&#xF3;digo de la empresa de env&#xED;os de entrega r&#xE1;pida Blue Express Log&#xED;stica S.A. en las tablas de correo r&#xE1;pido (Couriers) y almacenistas, respectivamente.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><br></div>", "i": 10371269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de septiembre de 2022.- Alejandra Arriaza Loeb, Directora Nacional de Aduanas.</div><br></div>", "i": 10371270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2530 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2530 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2198553", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-09-28", "doble_articulado": false, "id_norma": "1182571", "numero_fuente": "43372", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-10-08", "vigencias": [{"desde": "2022-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi