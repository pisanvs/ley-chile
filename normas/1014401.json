{"html": [{"t": "<div><br><div class=\"p\">DECLARA AMPLIADO PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 2.484, de fecha 28 de diciembre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8933105}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase ampliado, entre el 22 de noviembre de 2006 y el 22 de noviembre de 2007, ambas fechas inclusive, el plazo para iniciar actividades de acuicultura por fuerza mayor, autorizada mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=239332&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 862, de fecha 8 de abril de 2005, del Ministerio de Defensa Nacional, Subsecretaria de Marina</a>.</div><br></div>", "i": 8933106, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de mayo de 2010.- Saluda atentamente a Ud., por el Sr. Subsecretario, Felipe Garc&#xED;a-Huidobro Correa, Subjefe (M).</div><br></div>", "i": 8933107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2484", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2484"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "DECLARA AMPLIADO PLAZO PARA INICIAR ACTIVIDADES DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-28", "doble_articulado": false, "id_norma": "1014401", "numero_fuente": "39682", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-10", "vigencias": [{"desde": "2010-06-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "