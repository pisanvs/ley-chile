{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;315 EXENTO, DE 1999</div><br><br></div>", "i": 6204622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento n&#xFA;mero 315, de fecha 8 de octubre de 1999, del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobado a la Universidad Academia de Humanismo Cristiano, el Programa de Magister en Educaci&#xF3;n Intercultural Biling&#xFC;e, conducente al grado acad&#xE9;mico de Magister en Educaci&#xF3;n Intercultural con menci&#xF3;n en Pol&#xED;ticas de Educaci&#xF3;n Intercultural Biling&#xFC;e, de conformidad al Acuerdo adoptado por el Consejo Superior de Educaci&#xF3;n, quien llevar&#xE1; a efecto la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6204623}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de octubre de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6204624}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "315 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-315 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº315 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-08", "doble_articulado": false, "id_norma": "147486", "numero_fuente": "36512", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-12", "vigencias": [{"desde": "1999-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-11-12", "fin_vigencia": "", "tip