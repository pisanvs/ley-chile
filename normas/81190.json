{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8311994}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA;1.272, de 5 de Septiembre de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xBA; de las resoluciones N&#xBA;1097 y N&#xBA;1098, ambas de 1988, de esta Subsecretar&#xED;a, que autorizaron a don CARLOS RABY RODEWALD, R.U.T.</div><div class=\"p\">N&#xBA;1.137.656-8, domiciliado en calle Prat N&#xBA;827, Valpara&#xED;so, para ampliar actividades pesqueras de cultivo, en el sentido de incluir la autorizaci&#xF3;n para cultivar los recursos Salm&#xF3;n del atl&#xE1;ntico, salm&#xF3;n rey, salm&#xF3;n cereza, trucha arcoiris y trucha caf&#xE9;.</div><br></div>", "i": 8311995}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 5 de Septiembre de 1991.- Jorge Marshall Rivera, Subsecretario de Pesca Subrogante.</div><br></div>", "i": 8311996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1272", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1272"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-09-05", "doble_articulado": false, "id_norma": "81190", "numero_fuente": "34081", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-02", "vigencias": [{"desde": "1991-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-02", "fin