{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO MINISTRO DE FE A FUNCIONARIOS QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 299.- Santiago, 5 de diciembre de 1996.- Vistos: Lo dispuesto en el Art. 11 del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; R e s u e l v o:</div><br></div>", "i": 6009064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Ministro de Fe para actuar en las localidades ubicadas en la VIII Regi&#xF3;n, en que no hayan Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><div class=\"p\">&nbsp; &nbsp; - Rigoberto P&#xE9;rez Lara - Rodolfo Torres Gajardo </div></div>", "i": 6009065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Liliana Barr&#xED;a Iroume, Directora Nacional (S).</div><br></div>", "i": 6009066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "299", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-299"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIOS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTRO DE FE", "NOMBRAMIENTO", "OCTAVA REGION", "RIGOBERTO PEREZ LARA", "RODOLFO TORRES GAJARDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-05", "doble_articulado": false, "id_norma": "34229", "numero_fuente": "35651", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-27", "vigencias": [{"desde": "1996-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-27", "fin_vigencia": ""}, "vi