{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6267053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;565, de 28 de febrero de 2000, se expropiaron los lotes de terreno N&#xBA;s. 4-A, 5-H, 6-B y 9, superficies 192, 1880, 311 y 340 M2, respectivamente, roles de aval&#xFA;os 1226-31, 1228-44, 1228-55 y 1227-59, comuna de Cabrero, obra Camino Ruta 0-60, sector Monteaguila Yumbel y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Flor Cabezas Arroyo, Jos&#xE9; Abdala Valdebenito, Manuel Rodr&#xED;guez Berrocal y Omar Rodr&#xED;guez Berrocal, ascendente a las cantidades de $163.469, $2.769.901, $131.493 y $142.765. </div></div>", "i": 6267054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6267055}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "565", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-565"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-28", "doble_articulado": false, "id_norma": "166144", "numero_fuente": "36641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-15", "vigencias": [{"desde": "2000-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fecha_ingre