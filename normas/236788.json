{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6520778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 663, de 8 de marzo de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL LOW TRIVI&#xD1;O LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Barranco Amarillo N&#xBA; 8970, Parcela N&#xBA; 39, Punta Arenas, XII Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n de Fresco enfriado, Fresco refrigerado y Congelado, el recurso hidrobiol&#xF3;gico individualizado en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 3.616 de 2004, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6520779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de marzo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6520780}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "663 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-663 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-08", "doble_articulado": false, "id_norma": "236788", "numero_fuente": "38125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-02", "vigencias": [{"desde": "2005-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-