{"html": [{"t": "<div><br><div class=\"p\">&#xFEFF;Subdelegacion del Matadero en el departamento de Talca.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, diciembre 18 de 1878.</div><br><div class=\"p\">&nbsp; &nbsp;  Con lo espuesto en la nota que precede, decreto: </div></div>", "i": 9892389}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Cr&#xE9;ase en el departamento de Talca una nueva subdelegacion, que se denominar&#xE1; del Matadero i llevar&#xE1; el n&#xFA;m. 27. Comprender&#xE1; dos distritos, denominados del Matadero i de la Plaza de Abastos, los cuales tendr&#xE1;n por l&#xED;mites el recinto de estos mismos establecimientos.</div></div>", "i": 9892390}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes.</div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Belisario Prats.</div></div>", "i": 9892391}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "﻿Subdelegacion del Matadero en el departamento de Talca.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1878-12-18", "doble_articulado": false, "id_norma": "1112920", "numero_fuente": "1878", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1878-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1878-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1878-1