{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6302440}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.073, de 15 de septiembre de 2000,</div><div class=\"p\">de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 1.435 de 1996, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a SOCIEDAD PESQUERA LANDES S.A., para operar una</div><div class=\"p\">nave en construcci&#xF3;n, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6302441}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de septiembre de 2000.- Daniel Albarr&#xE1;n Ruiz Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6302442}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2073", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2073"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-15", "doble_articulado": false, "id_norma": "176047", "numero_fuente": "36771", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-25", "vigencias": [{"desde": "2000-09-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione