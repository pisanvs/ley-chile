{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6252806}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA; 507, de 19 de Abril de 1985, conforme art. 5&#xBA; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a reserva y sector expropiado del predio &quot;Parte de la Hijuela E del Plano de Divisi&#xF3;n del Fundo Los Hornos&quot; de la comuna de Colina, Regi&#xF3;n Metropolitana; y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xBA; s 1 a la 11, y sitio N&#xBA; 1 del Proyecto de Parcelaci&#xF3;n &quot;La Cantera&quot; formado por el predio se&#xF1;alado. Los derechos de agua se extraen del canal El Carmen. Publicaci&#xF3;n hecha conforme art. 13 Ley N&#xBA; 18.377.- </div></div>", "i": 6252807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6252808}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "507 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-507 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-19", "doble_articulado": false, "id_norma": "161631", "numero_fuente": "32185", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-01", "vigencias": [{"desde": "1985-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-01", "fin_vigencia": ""}, "vi