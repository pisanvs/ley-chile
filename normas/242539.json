{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6542233}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento M.O.P. N&#xBA; 855, de 31 de agosto</div><div class=\"p\">de 2005, y en base a la facultad otorgada por el</div><div class=\"p\">art&#xED;culo 105 del D.F.L. M.O.P. N&#xBA; 850 de 1997, que fij&#xF3; el texto actualizado de la Ley N&#xBA; 15.840, se dej&#xF3; sin efecto la expropiaci&#xF3;n del lote de terreno N&#xBA; 2, en consideraci&#xF3;n a que fue anulado por medio de Resoluci&#xF3;n Exenta S.R.M. X Regi&#xF3;n N&#xBA; 1382, de 9 de septiembre de 2004, modificada por Resoluci&#xF3;n Exenta S.R.M. X Regi&#xF3;n N&#xBA; 1059, de 13 de julio de 2005. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div><br></div>", "i": 6542234}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6542235}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "855 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-855 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-31", "doble_articulado": false, "id_norma": "242539", "numero_fuente": "38276", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-01", "vigencias": [{"desde": "2005-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-01", "fin