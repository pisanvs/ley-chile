{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESTRICCION VEHICULAR</div><br><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">N&#xFA;m. 08-91 exenta.- Iquique, 30 de enero 1991.- Visto: Lo dispuesto por los art&#xED;culos Nos. 113 y 118 de la Ley No.</div><div class=\"p\">18.290; la Resoluci&#xF3;n No. 59 de 1985, del Ministerio de Transportes y Telecomunicaciones; la Resoluci&#xF3;n Exenta No. 7 de fecha 18 de enero de 1991 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n.</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 7223343}, {"t": "<div><div class=\"p\">D&#xE9;jase sin efecto, a contar del 31 de enero de 1991, la restricci&#xF3;n a la circulaci&#xF3;n vehicular dispuesta por Resoluci&#xF3;n Exenta No. 7 de 18 de enero de 1991, de esta Secretar&#xED;a Regional Ministerial.</div><br></div>", "i": 7223344}, {"t": "<div><div class=\"p\">An&#xF3;tese y publ&#xED;quese.- Carlos Tassara del Castillo, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n.</div><br></div>", "i": 7223345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-8 EXENTA"}, {"tipo": "3", "numero": "08-91 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-08-91 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "DEJA SIN EFECTO RESTRICCION VEHICULAR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-30", "doble_articulado": false, "id_norma": "88636", "numero