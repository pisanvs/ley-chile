{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br></div>", "i": 8314480}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 611 de 09 de Mayo de 1990 de esta Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica las Resoluciones No. 105, de 1982 y No. 1135, de 1988, ambas de esta Subsecretaria, que autorizaron a Granja Marina Los Avellanos Limitada, R.U.T.</div><div class=\"p\">No. 88.407.200-K, domiciliada en la ciudad de Castro, para desarrollar actividades pesqueras de cultivo, en el sentido de sustituir en el numeral 2&#xB0; y en el numeral 1&#xB0;, respectivamente, la expresi&#xF3;n &quot;Queilen&quot; por &quot;Quell&#xF3;n&quot;. </div></div>", "i": 8314481}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 09 de mayo de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314482}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "611", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-611"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-05-09", "doble_articulado": false, "id_norma": "82950", "numero_fuente": "33692", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-06-11", "vigencias": [{"desde": "1990-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-06-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-06-11", "fin_vigencia": "", "tipo_ver