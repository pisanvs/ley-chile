{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION N&#xB0; 242, DE 1983 </div></div>", "i": 6237116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 784, de 29 de Noviembre de 1985, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga a petici&#xF3;n de Acuarnorte Limitada, domiciliada en Antofagasta la Resoluci&#xF3;n 242, de 08 de Junio de 1983, de la misma Subsecretaria, que la autoriz&#xF3; para instalar y operar un cultivo de algas Gracilaria en Caleta Cifuncho en una extensi&#xF3;n de 90.000 m2. de fondo de mar.</div><br></div>", "i": 6237117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so. 29 de Noviembre de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca </div></div>", "i": 6237118}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "784", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-784"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION N° 242, DE 1983", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-29", "doble_articulado": false, "id_norma": "156925", "numero_fuente": "32365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-07", "vigencias": [{"desde": "1986-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-01-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso