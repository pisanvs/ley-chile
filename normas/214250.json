{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6437995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 753 de fecha 31 de julio del 2003, se expropiaron los lotes de terreno N&#xBA;s.</div><div class=\"p\">3-A y 3-B, superficie 288,60 y 274,60 m&#xB2; respectivamente, rol N&#xBA; 70-28, comuna de Futrono, X Regi&#xF3;n para la obra &quot;Camino Ruta T-55, Sector Futrono - Llif&#xE9;n, Tramo Km. 55,300 al Km. 75,76384&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Rolando Monta&#xF1;a Carre&#xF1;o, ascendente a la cantidad de $4.761.244. </div></div>", "i": 6437996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6437997}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "753 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-753 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-31", "doble_articulado": false, "id_norma": "214250", "numero_fuente": "37649", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-01", "vigencias": [{"desde": "2003-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-09-02", "fecha_version": "2003-09-01", "fecha_actualizacion_texto": "2003-09-01",