{"html": [{"t": "<div><div class=\"p\">PARTIDO HUMANISTA</div><br><br><br></div>", "i": 6173864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Tom&#xE1;s Hirsch Goldschmidt y Jos&#xE9; Gabriel Feres Nazarala, Presidente y Secretario General del Partido Humanista, respectivamente, han solicitado la constituci&#xF3;n legal del partido en las Regiones VI del Libertador General Bernardo O&apos;Higgins y Metropolitana de Santiago, acompa&#xF1;ando 2.260 y 16.501 fichas de afiliaciones, respectivamente.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17 de la ley N&#xBA;18.603, por resoluci&#xF3;n O N&#xBA;640 de fecha 18 de junio de 1999. </div></div>", "i": 6173865}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de junio de 1999.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6173866}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "640", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-640"}, {"tipo": "3", "numero": "0-640", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-0-640"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO HUMANISTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-18", "doble_articulado": false, "id_norma": "138003", "numero_fuente": "36393", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-21", "vigencias": [{"desde": "1999-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-