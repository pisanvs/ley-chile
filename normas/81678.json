{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8312691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.043 de 28 de Agosto de 1991 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SOCIEDAD ABAROA Y GOMEZ LTDA., R.U.T. No. 79.820.710-5, domiciliada en la ciudad de Antofagasta, para continuar desarrollando actividades pesqueras autorizadas mediante resoluciones No. 188 de 1989 y No. 1127 de 1989, de esta Subsecretar&#xED;a.</div><div class=\"p\">&nbsp; &nbsp;  La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales o reglamentarias vigentes o que se establezcan.</div><br><br></div>", "i": 8312692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de Agosto de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br><br></div>", "i": 8312693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1043", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1043"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-08-28", "fecha_derogacion": "2001-11-20", "doble_articulado": false, "id_norma": "81678", "numero_fuente": "34068", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-09-14", "vigencias": [{"desde": "2001-11-20", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-09-14", "hasta": "2001-11-19", "tipo_version": "0", "tipo