{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,540, que suplementa el Presupuesto de Guerra.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,540.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7166766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de un millon seiscientos treinta i cuatro mil cuatrocientos once pesos, quince centavos ($ 1.634,411.15) al &#xED;tem 73 de la partida 3.a del Presupuesto de Guerra vijente. </div></div>", "i": 7166767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 1.&#xB0; de Setiembre de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Enrique Berm&#xFA;dez. </div></div>", "i": 7166768}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3540", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3540"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "Lei núm. 3,540, que suplementa el Presupuesto de;Guerra.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1919", "MODIFICACION", "MINISTERIO", "GUERRA SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-09-01", "doble_articulado": false, "id_norma": "24051", "numero_fuente": "12462", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-09-01", "vigencias": [{"desde": "1919-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici