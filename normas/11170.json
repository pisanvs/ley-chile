{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; NOMBRA SUBSECRETARIO DE HACIENDA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 221.- Santiago, 11 de marzo de 1994.- Vistos: lo dispuesto por el art&#xED;culo 32&#xB0; N&#xB0; 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica;</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 5901626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xF3;mbrase, a contar del 11 de marzo de 1994, a don Jos&#xE9; Manuel Marf&#xE1;n Lewis, R.U.T. N&#xB0; 5.123.841-9, en el cargo de Subsecretario de Hacienda, quien por razones impostergables de buen servicio deber&#xE1; asumir de inmediato sus funciones.</div><br></div>", "i": 5901627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Eduardo Aninat Ureta, Ministro de Hacienda.-</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud., Manuel Marf&#xE1;n Lewis, Subsecretario de Hacienda.</div><br></div>", "i": 5901628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "221", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-221"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "NOMBRA SUBSECRETARIO DE HACIENDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUBSECRETARIO", "MINISTERIO HACIENDA", "JOSE MANUEL MARFAN LEWIS", "NOMBRAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-11", "doble_articulado": false, "id_norma": "11170", "numero_fuente": "34832", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-04-06", "vigencias": [{"desde": "1994-04-06"