{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6327287}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 67, de 28 de enero de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Erardo B&#xE1;ez Ricouz para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 50 &quot;San Luis-Regional-Centro&quot; de Valdivia, cuyo trazado fue autorizado por Resoluci&#xF3;n Exenta No. 12, de 04 de enero de 1985 y modificado por Resoluci&#xF3;n Exenta No. 474, de 30 de octubre de 1985, de esta Secretar&#xED;a Regional. </div></div>", "i": 6327288}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6327289}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "67 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-67 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-01-28", "doble_articulado": false, "id_norma": "183083", "numero_fuente": "32414", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-05", "vigencias": [{"desde": "1986-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-03-05", "fin_vi