{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 865, de 20 de Julio de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por JUAN FERNANDO OYARZO VELASQUEZ, R.U.T. N&#xB0; 5.795.206-7, para un sector ubicado en la localidad de Piedra Azul, Comuna de Puerto Montt, Provincia de Llanquihue, X Regi&#xF3;n, por no darse cumplimiento al art&#xED;culo 77&#xB0; de la Ley General de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 370, de 1988, de esta Subsecretar&#xED;a, en virtud de lo dispuesto en la presente Resoluci&#xF3;n.</div><br></div>", "i": 8294629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 20 de Julio de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294630}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "865", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-865"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "CONCESION ACUICULTURA", "JUAN FERNANDO", "OYARZO VELASQUEZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-07-20", "doble_articulado": false, "id_norma": "35754", "numero_fuente": "35230", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-07-29", "vigencias": [{"desde": "1995-07-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"