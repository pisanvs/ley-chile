{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a do&#xF1;a Te&#xF3;dula Castro viuda de Cofr&#xE9;.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5961114}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese por gracia y por el plazo de diez a&#xF1;os, a do&#xF1;a Te&#xF3;dula Castro viuda de Cofr&#xE9;, una pensi&#xF3;n anual de un mil doscientos pesos ($ 1,200), de la que disfrutar&#xE1; a contar desde el 1.o de Enero de 1930.</div><br></div>", "i": 5961115}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecinueve de Febrero de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Mariano Navarrete C. </div></div>", "i": 5961116}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4836", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4836"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION DE GRACIA A DOÑA TEODULA CASTRO VIUDA DE COFRE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TEODULA CASTRO VIUDA DE COFRE", "PENSION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-02-19", "doble_articulado": false, "id_norma": "24949", "numero_fuente": "15608", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-02-25", "vigencias": [{"desde": "1930-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenci