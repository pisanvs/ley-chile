{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.075 EXENTA, DE 1999 </div><br></div>", "i": 6170346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.075, de 6 de mayo de 1999, se ha aprobado al&nbsp; Colegio Saint Gabriel&apos;s School de Santiago, un plan de estudio para los cursos de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1999, de acuerdo a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 220, de 1998.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio para los cursos y subsectores que se indican en la presente resoluci&#xF3;n, incluyendo los de Bachillerato Internacional. </div></div>", "i": 6170347}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de mayo de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6170348}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4075 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4075 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.075 EXENTA, DE 1999", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-05-06", "fecha_derogacion": "2014-02-28", "doble_articulado": false, "id_norma": "136930", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-05-26", "vigencias": [{"desde": "2014-02-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-05-26", "hasta": "2014-02-27", "tipo_version": "0", "tipo_version_s": "Text