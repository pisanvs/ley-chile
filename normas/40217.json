{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 11.489 EXENTA, DE 1992, SOBRE DELEGACION DE FACULTADES </div></div>", "i": 7202639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 2613, de 26 de Mayo de 1995, el Director Regional de la XV Direcci&#xF3;n Regional Metropolitana Santiago Oriente, ha procedido a modificar la parte resolutiva de la Resoluci&#xF3;n N&#xB0; Ex 11.489, de fecha 8 de Septiembre de 1992, de esta Direcci&#xF3;n Regional, reemplaz&#xE1;ndose en el n&#xFA;mero 2, la expresi&#xF3;n &quot;graves&quot; por la palabra &quot;complejas&quot;.</div><br><br></div>", "i": 7202640}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Bernardo Seaman Gonz&#xE1;lez, Director Regional.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento y dem&#xE1;s fines.- Saluda a Ud., Mirella P&#xE9;rez Rodr&#xED;guez, Secretaria Regional.</div><br></div>", "i": 7202641}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2613 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2613 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA RESOLUCION N° 11.489 EXENTA, DE 1992, SOBRE DELEGACION DE FACULTADES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "SERVICIO IMPUESTOS INTERNOS", "FUNCIONARIOS", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-26", "doble_articulado": false, "id_norma": "40217", "numero_fuente": "35185", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-05", "vigencias": [{"desde": "1995-06-05", "hasta": "", "tipo_versi