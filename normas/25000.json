{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente,</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5961256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Red&#xFA;cese en la suma de tres millones de pesos ($ 3.000,000) el &#xED;tem E-0601-h), del Presupuesto extraordinario para el a&#xF1;o en curso.</div><br></div>", "i": 5961257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Trasp&#xE1;sase la suma de tres millones de pesos ($ 3.000,000), indicada en el art&#xED;culo precedente, al &#xED;tem E-1403-u, (otras obras), del mismo Presupuesto. </div></div>", "i": 5961258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 3.o La presente ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5961259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, he tenido a bien aprobarlo y sancionarlo, por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiocho de Diciembre de mil novecientos treinta y uno.- JUAN E. MONTERO.- Herm&#xE1;n Echeverr&#xED;a.</div><br></div>", "i": 5961260}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5019", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5019"}], "organismos": ["MINISTERIO DE FOMENTO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-12-28", "doble_articulado": false, "id_norma": "25000", "numero_fuente": "16161", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicaci