{"html": [{"t": "<div><div class=\"p\">AUTORIZA AMPLIAR EL PLAZO PARA EL PAGO DE LAS &#xD3;RDENES DE INGRESO</div></div>", "i": 10164307}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n D.G.T.M. y M.M. Ordinario N&#xB0; 12100/70 Vrs., del 24 de septiembre de 2020, autoriza ampliar el plazo para el pago de las &#xF3;rdenes de ingreso.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10164308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de septiembre de 2020.- Por orden del Sr. Director General, Ren&#xE9; Rojas Cabrejos, Capit&#xE1;n de Nav&#xED;o, Subdirector.- Cristi&#xE1;n Pfeifer Rojas, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.</div><div class=\"p\"> </div><br></div>", "i": 10164309}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "70", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-70"}, {"tipo": "3", "numero": "12100/70", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12100/70"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "AUTORIZA AMPLIAR EL PLAZO PARA EL PAGO DE LAS ÓRDENES DE INGRESO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1824267", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-09-24", "doble_articulado": false, "id_norma": "1150285", "numero_fuen