{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,733.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a ciento cincuenta pesos ($ 150) la pension de montep&#xED;o militar que actualmente perciben las se&#xF1;oritas Digna, Atenais i Herminia Oliva, como hijas del sarjento-mayor graduado, servidor de la Independencia, don Joaquin Oliva.</div><br></div>", "i": 6173712}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cuatro de enero de mil novecientos trece.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S.</div><br></div>", "i": 6173713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2733", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2733"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-01-04", "doble_articulado": false, "id_norma": "137958", "numero_fuente": "10470", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-01-07", "vigencias": [{"desde": "1913-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1913-01-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendien