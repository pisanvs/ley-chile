{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACIONES</div></div>", "i": 9696256}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Res. Ex. N&#xBA; 1.027 de 21/12/15. Exp. N&#xBA;1501789. Vistos: Ley N&#xBA;18.755; Ley N&#xBA;18.575, resoluci&#xF3;n N&#xBA;1.600/2008 de la CGR. Considerando: ADC N&#xBA;097066, el cual el inspector se&#xF1;ala que al revisar el equipaje de la infractora se encuentran 2 unidades de manzanas que no fueron se&#xF1;aladas en la respectiva declaraci&#xF3;n jurada; 2.- Que, la infractora no formula descargos; 3.- Que, la infractora no registra denuncias anteriores. Resuelvo: Absu&#xE9;lvase por esta &#xFA;nica vez a do&#xF1;a Teresa Villca Condori, C&#xE9;dula de Identidad N&#xBA;3114806, nacionalidad boliviana, domicilio indeterminado. </div></div>", "i": 9696257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Firma: C&#xE9;sar Cardozo Rojas, Director Regional Regi&#xF3;n de Tarapac&#xE1; Servicio Agr&#xED;cola y Ganadero.</div></div>", "i": 9696258}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1027 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1027 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO REGIÓN DE TARAPACÁ"], "titulo_norma": "NOTIFICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1012408; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-21", "doble_articulado": false, "id_norma": "1089425", "numero_fuente": "41433", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-04-15", "vigencias": [{"desde": "2016-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-04-15"