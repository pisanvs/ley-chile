{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.273 EXENTO, DE 1997 </div></div>", "i": 7224703}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 1.273, de 31 de diciembre de 1997, se ha modificado, a partir del a&#xF1;o escolar 1997, el decreto supremo exento de Educaci&#xF3;n N&#xBA; 375 de 1990, que aprob&#xF3; planes y programas de estudio de educaci&#xF3;n b&#xE1;sica y media human&#xED;stico-cient&#xED;fica a los Colegios de los Hermanos Maristas.</div><br></div>", "i": 7224704}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 23 de enero de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7224705}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1273 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1273 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.273 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIOS DE LOS HERMANOS MARISTAS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-31", "doble_articulado": false, "id_norma": "90117", "numero_fuente": "35977", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-29", "vigencias": [{"desde": "1998-01-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modifi