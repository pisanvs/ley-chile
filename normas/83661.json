{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6065950}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Secc. 2da. No. 85, de fecha 12 de Enero de 1990, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n parcial conforme DS No. 458 de Vivienda y Urbanismo, Decreto Ley 2.186 y Ley 18.695, inmueble Agustinas No. 2449, Rol 333-5 Santiago, aparente dominio Mar&#xED;a Soledad Felicori Vergara, superficie aproximada a expropiar 912 m2. Deslindes: Norte, 24 mts. resto del predio; Sur, 24 mts. calle Agustinas; Oriente, 38 mts. otro propietario y Poniente, 38 mts. otro propietario. Indemnizaci&#xF3;n provisional $ 11.436.000.- pagadera contado.</div><br><br></div>", "i": 6065951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  M&#xE1;ximo Honorato Alamos. Alcalde Santiago.</div><br><br></div>", "i": 6065952}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "85", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-85"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "83661", "numero_fuente": "33585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-01", "vigencias": [{"desde": "1990-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-01-09", "fecha_version": "1990-02-