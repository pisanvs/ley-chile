{"html": [{"t": "<div><div class=\"p\">EXTRACTO </div></div>", "i": 6401071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA;45, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de fecha 6 de mayo del 2002, se aprob&#xF3; la disoluci&#xF3;n voluntaria de la Cooperativa de Vivienda y Servicios Habitacionales Villa El Roc&#xED;o Limitada, de Concepci&#xF3;n, que consta en la escritura p&#xFA;blica suscrita con fecha 5 de febrero del 2002, ante el Notario P&#xFA;blico de Concepci&#xF3;n don Enrique Acu&#xF1;a M&#xE9;ndez, suplente del titular don Jorge Condeza Vaccaro.</div><br></div>", "i": 6401072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Ra&#xFA;l Oliva Camadro, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6401073}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "45", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-45"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-06", "doble_articulado": false, "id_norma": "204002", "numero_fuente": "37396", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-30", "vigencias": [{"desde": "2002-10-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-10-