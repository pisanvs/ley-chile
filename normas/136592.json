{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 39, DE 1988 </div></div>", "i": 6169276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 39, de 15 de Marzo de 1988, se ha aprobado a contar del a&#xF1;o escolar 1988 y por un per&#xED;odo de 3 a&#xF1;os, con car cter experimental, un plan de estudio de&nbsp; Capacitaci&#xF3;n Laboral para ser aplicados en cursos talleres de digitaci&#xF3;n computacional de la Escuela Especial D No. 597 de La Cisterna, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Ademas, se aprueban programas de estudio correspondientes a las asignaturas que conforman el plan aprobado en el art&#xED;culo primero del presente decreto </div></div>", "i": 6169277}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Marzo de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6169278}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "39 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-39 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 39, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-15", "doble_articulado": false, "id_norma": "136592", "numero_fuente": "33034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-30", "vigencias": [{"desde": "1988-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-30", "fin_vigencia": ""}, "v