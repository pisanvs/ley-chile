{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6416493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 636, de 3 de marzo de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 2.125 de 1999, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA EL GOLFO S.A. para operar la nave &quot;Cobra&quot;, entre el paralelo 41&#xB0;28,6&apos; L.S. y el l&#xED;mite sur de la X Regi&#xF3;n, sobre el recurso Merluza de tres aletas, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura. </div></div>", "i": 6416494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de marzo de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6416495}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "636", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-636"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-03", "doble_articulado": false, "id_norma": "208225", "numero_fuente": "37503", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-07", "vigencias": [{"desde": "2003-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificac