{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8305692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.147, de 8 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 1.340, de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA ANDALIEN LTDA., para iniciar actividades pesqueras extractivas con la nave &quot;Lonconao&quot;, por no haberse incluido esta Resoluci&#xF3;n en la transferencia que su titular hiciera a Pesquera El Golfo S.A., seg&#xFA;n contrato.</div><br></div>", "i": 8305693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8305694}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1147", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1147"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEROGACION", "AUTORIZACION", "PESQUERA ANDALIEN LTDA.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-08", "doble_articulado": false, "id_norma": "75043", "numero_fuente": "35846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-20", "vigencias": [{"desde": "1997-08-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-08-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"