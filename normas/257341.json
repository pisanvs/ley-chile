{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISORES DE BOLETAS ELECTRONICAS</div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 5 de 8 de enero de 2007, que autoriza a contribuyentes como emisores de boletas electr&#xF3;nicas.</div><br></div>", "i": 6596894}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se autorizan como emisores de boletas electr&#xF3;nicas a contribuyentes RUT 76.645.030-K y RUT 76.348.900-0 a contar del mes de enero de 2007.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2007.</div><br></div>", "i": 6596895}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES DE BOLETAS ELECTRONICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-01-08", "doble_articulado": false, "id_norma": "257341", "numero_fuente": "38661", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-12", "vigencias": [{"desde": "2007-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-01-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],