{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8555830}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.153 de 30 de marzo de 2009 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA;1.838 de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don JAIME ROM&#xC1;N &#xC1;LVAREZ ARMIJO para desarrollar actividades pesqueras extractivas con la nave &quot;Cazador&quot;, en el sentido de actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas de la nave:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 737 del Puerto de San Antonio</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp;  15,76 m.</div><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; &nbsp; 45,73 m.</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  6,40 m.</div><div class=\"p\">Potencia total&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 360,00 Hp.</div></div>", "i": 8555831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de marzo de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8555832}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1153 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1153 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2009-03-30", "fecha_derogacion": "2015-05-12", "doble_articulado": false, "id_norma": "1001390", "tipo_version": "2", "tipo_version_s": "Últim