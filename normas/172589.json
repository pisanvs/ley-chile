{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6287987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.634, de fecha 28 de abril de 2000, se expropi&#xF3; los lotes de terreno N&#xBA;s. 1, 45, 47 y 48, superficie 379,70, 12.943,10, 5.470,10 y 4.646,35 m2. respectivamente, rol de aval&#xFA;o 176-65, 178-70, 178-72 y 178-51, comuna de Chonchi, para la obra &apos;&apos;Camino Ruta 5, sector Chonchi - Tara Kms. 1.205,160 al 1.215,004&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Guadalupe del C. Cayun Vera, H&#xE9;ctor Erico B&#xF3;rquez Andrade, Hilda del Carmen B&#xF3;rquez Arteaga y Camilo Delelis M&#xE1;rquez G&#xF3;mez y otra, ascendente a las cantidades de $356.674.- para el lote N&#xBA;1, $4.864.108.- para el lote N&#xBA;45, $1.876.825.- para el lote N&#xBA;47 y $1.861.515.- para el lote N&#xBA;48.</div><br></div>", "i": 6287988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6287989}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1634", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1634"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "172589", "numero_fuente": "36714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-15", "vigencias": [{"desde": "2000-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-15", "fin_vigencia": ""}, "vigencias_version_n