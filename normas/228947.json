{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6491902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 1.906, de 14 de julio de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CISNE S.A., para realizar actividades extractivas en aguas internacionales con la nave f&#xE1;brica &quot;Cisne Blanco&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-4108</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2615</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  45,55 m.</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 8,50 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  5,14 m.</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  536,85</div><br><br></div>", "i": 6491903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de julio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6491904}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1906 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1906 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-07-14", "fecha_derogacio