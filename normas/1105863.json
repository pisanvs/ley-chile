{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 9820439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xB0; 543, de 22 de junio de 2017, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xB0;, 5&#xB0; y 6&#xB0;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1093745&amp;idParte=0&amp;idVersion=\">Decreto Exento MOP N&#xB0; 465, de 22 de julio de 2016</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xB0; 63-C, expropiado con motivo de la obra: &quot;Construcci&#xF3;n Mejoramiento Interconexi&#xF3;n Vial P-20 P-40, Arauco&quot;, Comuna de Arauco, Provincia de Arauco, Regi&#xF3;n del Biob&#xED;o. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijada mediante tasaci&#xF3;n de 19 de enero de 2015, ascendente a la cantidad de $1.158.438.</div></div>", "i": 9820440}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "543 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-543 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1248662; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-06-22", "doble_articulado": false, "id_norma": "1105863", "numero_fuente": "41823", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-08-01", "vigencias": [{"desde": "2017-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic