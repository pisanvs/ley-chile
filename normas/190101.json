{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7286065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.928 de 11 de septiembre de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIAL MANANTIALES LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 820 de 1997, en orden a incorporar a la planta ubicada en Las Heras N&#xBA; 2241, Concepci&#xF3;n, VIII Regi&#xF3;n, en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Fresco-Enfriado y Congelado: Merluza del sur y Orange roughy.</div><div class=\"p\">&nbsp; &nbsp;  La materia prima deber&#xE1; provenir de pescadores artesanales e industriales, debidamente autorizados, seg&#xFA;n corresponda.</div><br></div>", "i": 7286066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de septiembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7286067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1928", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1928"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-11", "doble_articulado": false, "id_norma": "190101", "numero_fuente": "37075", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-02", "vigencias": [{"desde": "2001-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-02", "fin_vigencia": ""}, "vigencias_version_norma"