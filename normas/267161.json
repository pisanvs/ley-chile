{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6745621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 658, de fecha 29 de octubre de 2007, se expropiaron los lotes de terreno N&#xBA;s 1 y 2, superficies 407 y 862 m2 respectivamente, rol N&#xBA; 2219-217, comuna de San Juan de la Costa, para la obra:</div><div class=\"p\">&quot;Reconstrucci&#xF3;n Puente - Carrico, Camino Puaucho-Carrico, Ruta U-370&quot; X Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Alberto Baham&#xF3;ndez Asenjo o Bahamondes Asenjo, ascendente a la cantidad de $1.170.182.</div><br></div>", "i": 6745622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6745623}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "658 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-658 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-29", "doble_articulado": false, "id_norma": "267161", "numero_fuente": "38926", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-01", "vigencias": [{"desde": "2007-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-12-04", "fecha_version": "2007-12-01", "fecha_actualizacion_te