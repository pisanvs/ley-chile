{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N&#xB0; 257 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6237062}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico - Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1990, inclusive, para el Liceo Industrial &quot;A&quot; N&#xB0; 31, de Concepci&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  ESPECIALIDADES:</div><br><div class=\"p\">1.- Electromec&#xE1;nica.</div><div class=\"p\">2.- Instalaciones El&#xE9;ctricas.</div><div class=\"p\">3.- Mec&#xE1;nica de Mantenci&#xF3;n.</div><div class=\"p\">4.- Mec&#xE1;nica de M&#xE1;quinas Herramientas.</div><br></div>", "i": 6237063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  28 de Junio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica, subrogante.</div><br></div>", "i": 6237064}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "257 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-257 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION N° 257\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "156907", "numero_fuente": "32364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-06", "vigencias": [{"desde": "1986-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":