{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 2.195, de 31 de diciembre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESCA CHILE S.A., para realizar operaciones pesqueras, por el plazo de un a&#xF1;o calendario contado desde el 1&#xBA; de enero de 1997, con los barcos f&#xE1;brica denominados &quot;Faro de H&#xE9;rcules&quot;, &quot;Puerto Ballena&quot;, &quot;Chomapi Maru&quot;, &quot;Betanzos&quot; y &quot;Pedrosa&quot;, en aguas exteriores, por fuera de las l&#xED;neas de base recta, al Sur del paralelo 44&#xB0;30 de latitud sur, respecto de las &#xE1;reas y recursos y con las obligaciones establecidas en sus respectivas Resoluciones.</div><br></div>", "i": 8300577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 1996.-</div><br><div class=\"p\">&nbsp; &nbsp;  Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca. </div></div>", "i": 8300578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2195", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2195"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESCA CHILE S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-31", "doble_articulado": false, "id_norma": "60309", "numero_fuente": "35673", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-23", "vigencias": [{"desde": "1997-01-23", "hasta": "", "tipo_version": "3", "tip