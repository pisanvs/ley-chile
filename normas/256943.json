{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6595432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.420, de 22 de diciembre de 2006, de esta Subsecretar&#xED;a, rectif&#xED;case la resoluci&#xF3;n N&#xBA; 3.102 de 2006, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD CONTRACTUAL MINERA EL ABRA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Caracterizaci&#xF3;n de la fauna &#xED;ctica presente en el salar Escot&#xE1;n, II Regi&#xF3;n, a&#xF1;o 2006&quot;, en el sentido de entender que cada menci&#xF3;n que en ella se haga al &quot;salar de Escot&#xE1;n&quot;, debe entenderse hecha al &quot;salar de Ascot&#xE1;n&quot;.</div><br></div>", "i": 6595433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de diciembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6595434}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3420 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3420 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FAUNA ICTICA", "SALAR ASCOTAN", "SEGUNDA REGION", "RECTIFICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-22", "doble_articulado": false, "id_norma": "256943", "numero_fuente": "38650", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-29", "vigencias": [{"desde": "2006-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig