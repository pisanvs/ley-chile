{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SALMONES MAINSTREAM FISHERIES LTDA. PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6237340}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 21 de 08 de Enero de 1986 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Salmones Mainstream Fisheries Ltda., domiciliada en Santiago, para instalar y operar un establecimiento de cultivo de salm&#xF3;n plateado, en dos sectores de mar y un sector de terrenos en las localidades de Huillinco, Caleta Linlinao y Bah&#xED;a de Yal, Comuna de Chonchi, Chilo&#xE9;, X Regi&#xF3;n.</div><br></div>", "i": 6237341}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 08 de Enero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6237342}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "21", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-21"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A SALMONES MAINSTREAM FISHERIES LTDA. PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-01-08", "fecha_derogacion": "1988-11-16", "doble_articulado": false, "id_norma": "157001", "numero_fuente": "32370", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-01-13", "vigencias": [{"desde": "1988-11-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-01-13", "hasta": "1988-11-15", "tipo_version": "0", "tipo_version_s":