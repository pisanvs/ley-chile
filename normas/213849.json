{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6436350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.691, de 23 de julio de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a CULTIVOS MARINOS DEL SUR S.A.&nbsp; para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en la comuna de Calbuco, canal Quihua s/n&#xBA;, San Rafael, X Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Fresco-Enfriado, Congelado, Ahumado: Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n plateado, Trucha arcoiris, Merluza del sur y R&#xF3;balo.</div><br></div>", "i": 6436351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de julio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6436352}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1691 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1691 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-23", "doble_articulado": false, "id_norma": "213849", "numero_fuente": "37641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-08-22", "vigencias": [{"desde": "2003-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-08-22", "fin_vigencia": "", "tipo_version