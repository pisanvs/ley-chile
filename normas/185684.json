{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 5.122 EXENTA, DE 2001 </div></div>", "i": 6336226}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.122 de 25 de abril del a&#xF1;o 2001, se ha aprobado al Instituto Santa Mar&#xED;a de Santiago, comuna de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para Tercer a&#xF1;o de ense&#xF1;anza media human&#xED;stico-cient&#xED;fica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se se&#xF1;alan en la presente resoluci&#xF3;n. </div></div>", "i": 6336227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de mayo de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6336228}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5122 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5122 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.122 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-25", "doble_articulado": false, "id_norma": "185684", "numero_fuente": "36972", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-28", "vigencias": [{"desde": "2001-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac