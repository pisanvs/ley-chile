{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO CALIDAD DE AGENTE RETENEDOR DE IVA EN LAS ACTIVIDADES DE LA CONSTRUCCI&#xD3;N </div></div>", "i": 7357570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La II Direcci&#xF3;n Regional Antofagasta del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA; 2.160 de 29 de octubre de 2007, deja sin efecto el otorgamiento de la calidad de Agente Retenedor de IVA, en las actividades de la construcci&#xF3;n, conforme a lo dispuesto en resoluci&#xF3;n Ex. N&#xBA; 46, de 1 de septiembre de 2003, a la empresa Mazu y C&#xED;a. Ltda., RUT N&#xBA; 78.862.960-5, por haber dejado de cumplir los requisitos establecidos en dicha resoluci&#xF3;n, a contar de esta publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7357571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Oscar Urdanivia Noriega, Director Regional. </div></div>", "i": 7357572}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2160", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2160"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "II DIRECCIÓN REGIONAL ANTOFAGASTA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-29", "doble_articulado": false, "id_norma": "266248", "numero_fuente": "38904", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-11-06", "vigencias": [{"desde": "2007-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-11-06", "fin_vigencia": "", "tipo_version": "3"}