{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;. 356, DE 1990</div><br><br></div>", "i": 6103680}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 356 de 27 de diciembre de 1990 se ha modificado, a partir del a&#xF1;o escolar 1991, el decreto supremo exento de Educaci&#xF3;n No. 102, de 1983, que aprob&#xF3; planes y programas especiales de estudio al Colegio Windsor School, de Valdivia, sustituyendo el Plan de Estudio para la Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica. </div></div>", "i": 6103681}, {"t": "<div><div class=\"p\">Santiago, 24 de Enero de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6103682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "356 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-356 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº. 356, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-27", "doble_articulado": false, "id_norma": "96648", "numero_fuente": "33891", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-11", "vigencias": [{"desde": "1991-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-02-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-03-30", "fecha_version": "1991-02-11", "fecha_actualizacion_texto": "