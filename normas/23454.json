{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar a don Nicanor Zenteno Uribe</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,727.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7165994}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al Ministro de la Corte de Cuentas, don Nicanor Zenteno Uribe, el derecho de jubilar con una pension equivalente al sueldo &#xED;ntegro asignado al puesto que desempe&#xF1;a.</div><br></div>", "i": 7165995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto, en todas sus partes, como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 31 de Diciembre de 1912.- RAMON BARROS LUCO.- Manuel Rivas Vicu&#xF1;a.</div><br></div>", "i": 7165996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2727", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2727"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE DERECHO A JUBILAR A DON NICANOR ZENTENO URIBE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NICANOR ZENTENO URIBE", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-12-31", "doble_articulado": false, "id_norma": "23454", "numero_fuente": "10468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-01-03", "vigencias": [{"desde": "1913-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_