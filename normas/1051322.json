{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 2.130 EXENTA, DE 2013</div><br></div>", "i": 9354450}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.130, de fecha 20 de mayo de 2013, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1005315&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.904</a>, citada en Visto, que aprueba el programa de ense&#xF1;anza para la obtenci&#xF3;n de licencia de conductor Clase B, a la Escuela de Conductores No Profesionales o Clase B &quot;Manutara&quot;, RUT N&#xB0; 11.392.430-6, en el sentido de aprobar la nueva sede de la escuela ubicada en Avenida San Luis N&#xB0; 5396, comuna de Pe&#xF1;alol&#xE9;n, siendo su director el se&#xF1;or Fredy Osvaldo Sep&#xFA;lveda Grandi, RUT N&#xB0; 12.737.097-4.- </div></div>", "i": 9354451}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Sergio Stephan Orellana, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div></div>", "i": 9354452}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2130 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2130 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 2.130 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-05-20", "doble_articulado": false, "id_norma": "1051322",