{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.038 EXENTO, DE 1998 </div><br><br><br><br></div>", "i": 7242452}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 1.038, de 10 de noviembre de 1998, se ha modificado, a partir del a&#xF1;o escolar 1998, en la forma que se indica, el decreto supremo exento de Educaci&#xF3;n N&#xBA; 155 de 1992, que aprob&#xF3; planes y programas especiales de estudio para adultos, al Instituto de Formaci&#xF3;n y Capacitaci&#xF3;n Popular &apos;&apos;Infocap&apos;&apos;, de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 7242453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de noviembre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7242454}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1038 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1038 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.038 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EDUCACION DE ADULTOS", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "INSTITUTO DE FORMACION Y CAPACITACION POPULAR INFOCAP", "MODIFICACION", "REGION METROPILITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-10", "doble_articulado": false, "id_norma": "127947", "numero_fuente": "36231", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-12-04", "vigencias": [{"desde": "1998-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia