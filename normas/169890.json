{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6279311}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.154, de 30 de marzo de 2000, y en base a la facultad otorgada por el art&#xED;culo 105 del DFL.</div><div class=\"p\">N&#xBA;850, de 1997, que fij&#xF3; el texto actualizado de la Ley N&#xBA;15.840, se expropiaron los lotes de terreno N&#xBA;s. 1, 2, 3, 5, 8, 9, 10, 11, 12, 13, 14, 15, 16 y 17, para la ejecuci&#xF3;n de la obra Habilitaci&#xF3;n Nuevo Camino La P&#xF3;lvora Sector Puertas Negras - Calle San Mateo, que figuran a nombre de Fonasa y Corp. de la Vivienda, roles de aval&#xFA;o 9320-3 y 9320-13, comuna de Valpara&#xED;so, V Regi&#xF3;n. La indemnizaci&#xF3;n indicada en dicho decreto se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.- </div></div>", "i": 6279312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6279313}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1154", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1154"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-30", "doble_articulado": false, "id_norma": "169890", "numero_fuente": "36678", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-01", "vigencias": [{"desde": "2000-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-01", "fin_vigencia": ""}, "vig