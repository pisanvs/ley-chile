{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N LEGAL DEL PARTIDO ECOLOGISTA VERDE EN LA REGI&#xD3;N METROPOLITANA DE SANTIAGO</div></div>", "i": 9360805}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Los se&#xF1;ores Alejandro San Mart&#xED;n Bravo y Pablo Pe&#xF1;aloza Torres, Presidente y Secretario General, respectivamente, de la Directiva Central del Partido Ecologista Verde, han solicitado la constituci&#xF3;n legal del partido en la Regi&#xF3;n Metropolitana de Santiago. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de diecis&#xE9;is mil ciento diecis&#xE9;is (16.116) fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la ley N&#xB0; 18.603, por resoluci&#xF3;n O-N&#xB0; 10.419, de fecha 18 de junio de 2013.- </div></div>", "i": 9360806}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9360807}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10419", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-10419"}, {"tipo": "3", "numero": "O-10419", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-O-10419"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN LEGAL DEL PARTIDO ECOLOGISTA VERDE EN LA REGIÓN METROPOLITANA DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-06-18", "doble_articulado": false, "id_norma": "1052076", "numero_fuente": "40589", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-06-20", "vigencias":