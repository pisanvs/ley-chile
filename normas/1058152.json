{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9399515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.789, de 31 de diciembre de 2013, de esta Subsecretar&#xED;a, los Titulares de Licencias Transables de Pesca Clase A, inscritos en el registro p&#xFA;blico que lleva esta Subsecretar&#xED;a, podr&#xE1;n capturar durante el a&#xF1;o 2014, en las respectivas unidades de pesquer&#xED;a,</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/36593.jpg\">.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9399516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9399517}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3789 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3789 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-31", "doble_articulado": false, "id_norma": "1058152", "numero_fuente": "40754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-01-11", "vigencias": [{"desde":