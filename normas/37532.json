{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298525}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.899, de 8 de noviembre de 1996,</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la</div><div class=\"p\">solicitud de concesi&#xF3;n de acuicultura N&#xB0; 93103148,</div><div class=\"p\">presentada por OCEAN HORIZONS CHILE S.A., para un sector</div><div class=\"p\">ubicado en Canal Queil&#xE9;n, Comuna de Quell&#xF3;n, Provincia</div><div class=\"p\">de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los</div><div class=\"p\">art&#xED;culos N&#xB0; 14&#xB0;, del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n y N&#xB0; 78&#xB0; y N&#xB0; 87&#xB0;, de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8298526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de noviembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1899", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1899"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "DENEGACION", "OCEAN HORIZONS CHILE S.A", "QUELLON", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-11-08", "doble_articulado": false, "id_norma": "37532", "numero_fuente": "35619", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-11-19", "v