{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7353776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 738 de 30 de julio de 2007 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme D.L. N&#xBA; 2.186 de 1978, del inmueble ubicado en V. Mackenna N&#xBA; 8280, presunto Rol de Aval&#xFA;o N&#xBA; 2.180-10, comuna de La Florida, de aparente dominio de Banco Santiago; correspondiente al Lote N&#xBA;13, del Proyecto Vial &quot;Corredor Transporte P&#xFA;blico Vicu&#xF1;a Mackenna&quot;. Comisi&#xF3;n integrada por Mar&#xED;a Cristina Camus Palacios, Arquitecto, Mar&#xED;a In&#xE9;s M&#xE1;rquez Guti&#xE9;rrez, Ingeniero Civil y Teresa Sancho Pernas, Arquitecto, seg&#xFA;n informe de 21 de septiembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $20.231.500.- pagadera al contado. </div></div>", "i": 7353777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7353778}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "738", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-738"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-30", "doble_articulado": false, "id_norma": "264816", "numero_fuente": "38865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-15", "vigencias": [{"desde": "2007-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú