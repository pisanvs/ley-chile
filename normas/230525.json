{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6497765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.279, de 24 de agosto de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a ADOLFO GINES GARVISO OLIVARES, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Ruta B1, sector Playa Hueso a 51 kil&#xF3;metros al norte de Tocopilla, II Regi&#xF3;n, donde podr&#xE1; procesar, en la l&#xED;nea de elaboraci&#xF3;n de Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6497766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6497767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2279 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2279 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-24", "doble_articulado": false, "id_norma": "230525", "numero_fuente": "37966", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-21", "vigencias": [{"desde": "2004-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-09-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "200