{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.572 EXENTO, DE 2006 </div></div>", "i": 7338331}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA;1.572, fecha 11 de octubre de 2006, del Ministerio de Educaci&#xF3;n, se deja sin efecto, a contar del a&#xF1;o 2006, la aprobaci&#xF3;n del plan y programas de estudio de la carrera que se indica para el Centro de Formaci&#xF3;n T&#xE9;cnica Alpes, aprobada por el decreto exento de Educaci&#xF3;n que se se&#xF1;ala, a petici&#xF3;n de la propia entidad, dado que no se continuar&#xE1; impartiendo:</div><br><div class=\"p\">Carrera: Locuci&#xF3;n, Oratoria y Doblaje de Cine y TV (D.</div><div class=\"p\">Ex. N&#xBA;82, de 25.03.99).</div><br></div>", "i": 7338332}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de noviembre de 2006.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 7338333}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1572 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1572 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.572 EXENTO, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-11", "doble_articulado": false, "id_norma": "259407", "numero_fuente": "38722", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-03-24", "vigencias": [{"desde": "2007-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-03-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-03-24", "fin_vigencia": "", "tipo_versio