{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9308961}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.793 de 17 de octubre de 2012, de esta Subsecretar&#xED;a, rectif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1040861&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.490 de 2012</a> y de esta Subsecretar&#xED;a de Pesca y Acuicultura, que estableci&#xF3; la n&#xF3;mina definitiva de armadores artesanales y sus embarcaciones, que participaron de las pescas de investigaci&#xF3;n a que se refiere el art&#xED;culo 3&#xBA; de la ley N&#xBA; 20.560, en el sentido de incorporar en su numeral 4.- a las personas indicadas en resoluci&#xF3;n extractada.</div></div>", "i": 9308962}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de octubre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9308963}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2793 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2793 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-17", "doble_articulado": false, "id_norma": "1045060", "numero_fuente": "40393", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-24", "vigencias": [{"desde": "2012-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc