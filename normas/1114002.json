{"html": [{"t": "<div><br><div class=\"p\">DECLARA NO APTAS PLAYAS DE LA CAPITAN&#xCD;A DE PUERTO DE SAN VICENTE</div></div>", "i": 9878240}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n C.P. San Vicente Ord. N&#xB0; 12000/730, de fecha 29 de noviembre de 2017, declara apta y no aptas para el ba&#xF1;o las playas emplazadas en la jurisdicci&#xF3;n de la Capitan&#xED;a de Puerto de San Vicente, por el per&#xED;odo estival 2017/2018.</div><br><div class=\"p\">&nbsp; &nbsp;  Los textos &#xED;ntegros de estas resoluciones est&#xE1;n publicados en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante www.directemar.cl - usuario mar&#xED;timo - resoluciones locales.</div></div>", "i": 9878241}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Talcahuano, 17 de enero de 2018.- Rodrigo G&#xE1;rate Montoya, Capit&#xE1;n de Nav&#xED;o LT, Gobernador Mar&#xED;timo de Talcahuano.</div></div>", "i": 9878242}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "730", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-730"}, {"tipo": "3", "numero": "12000/730", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12000/730"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "DECLARA NO APTAS PLAYAS DE LA CAPITANÍA DE PUERTO DE SAN VICENTE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1340234; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-11-29", "doble_articulado": false, "id_norma": "1114002", "numero_fuente": "41965", "tipo_versio