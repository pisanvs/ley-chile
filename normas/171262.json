{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 169 EXENTO, DE 2000 </div></div>", "i": 7271036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 169 de 26 de mayo de 2000, se ha sustituido en el decreto supremo exento de Educaci&#xF3;n N&#xBA; 617 de 1993, que aprob&#xF3; plan especial de estudio al Colegio Apoquindo de Ni&#xF1;as de Santiago, el plan de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, por el que se indica en el presente decreto, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000. </div></div>", "i": 7271037}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de junio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7271038}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "169 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-169 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 169 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-26", "doble_articulado": false, "id_norma": "171262", "numero_fuente": "36694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-21", "vigencias": [{"desde": "2000-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fec