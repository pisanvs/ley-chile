{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8345413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.047, de 31 de mayo de 1999, de esta</div><div class=\"p\">Subsecretar&#xED;a, modif&#xED;case el N&#xBA; 2 de la resoluci&#xF3;n N&#xBA; 369 de</div><div class=\"p\">1999, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; SOCIEDAD</div><div class=\"p\">PESQUERA PACIFICO AUSTRAL LTDA., para ampliar actividades</div><div class=\"p\">pesqueras de transformaci&#xF3;n, en la planta ubicada en La</div><div class=\"p\">Ribera Sur N&#xBA; 300, sector Pudeto Bajo, Ancud, en el sentido</div><div class=\"p\">de indicar que el recurso Puye deber&#xE1; provenir de pescadores</div><div class=\"p\">artesanales debidamente autorizados y no como all&#xED; se se&#xF1;ala.</div><br></div>", "i": 8345414}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de mayo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8345415}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1047", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1047"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-31", "doble_articulado": false, "id_norma": "137441", "numero_fuente": "36382", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-08", "vigencias": [{"desde": "1999-06-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-08", "fin_vigencia": ""}, "vigen