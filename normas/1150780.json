{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 11</div></div>", "i": 10168620}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.228, de 15 de octubre de 2020, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1142690&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 313</a>, modificada por resoluciones N&#xBA; 1.167, N&#xBA; 1.562 y N&#xBA; 1.628, todas de 2020, y de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 11, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div><br></div>", "i": 10168621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de octubre de 2020.- Rom&#xE1;n Zelaya R&#xED;os, Subsecretario de Pesca y Acuicultura.</div><br></div>", "i": 10168622}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2228 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2228 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 11", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1832962", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-10-15", "doble_articulado": false, "id_norma": "1150780", "numero_fuente": "42785", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-10-21", "vigencia