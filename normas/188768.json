{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SALMONES MAINSTREAM FISHERIES PARA AMPLIAR ACTIVIDADES PESQUERAS </div></div>", "i": 7285224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 189, de 03 de Marzo de 1986, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Salmones Mainstream Fisheries, domiciliado en Santiago, para cultivar adem&#xE1;s, en el establecimiento de cultivo que tiene autorizado por la resoluci&#xF3;n 21, de 1985, de la Subsecretaria de Pesca, las especies salm&#xF3;n rey, salm&#xF3;n del atl&#xE1;ntico y trucha arco iris.</div><br></div>", "i": 7285225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 03 de Marzo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7285226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "189", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-189"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A SALMONES MAINSTREAM FISHERIES PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-03-03", "doble_articulado": false, "id_norma": "188768", "numero_fuente": "32420", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-03-12", "vigencias": [{"desde": "1986-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-03-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi