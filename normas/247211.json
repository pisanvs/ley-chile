{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6560791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;223 de 19 de enero de 2006 de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIAL, SERVICIOS, INGENIERIA Y EXPORTACIONES M2 LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Parcelaci&#xF3;n El Tr&#xE9;bol, Sitio N&#xBA;4, Cerrillos, Ovalle, IV Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga picada, el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6560792}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2006.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6560793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "223 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-223 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-19", "doble_articulado": false, "id_norma": "247211", "numero_fuente": "38386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-02-10", "vigencias": [{"desde": "2006-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-02-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-02-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2