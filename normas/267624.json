{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6745849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;758, de 24 de octubre de 2007, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP N&#xBA; 89, de 28 de febrero de 2007, en la parte que se refiere al Convenio Directo de Precio</div><div class=\"p\">Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n de los lotes N&#xBA; 3-A y 3-B. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n de los lotes N&#xBA;s 3-A y 3-B, fijada por la Comisi&#xF3;n de Peritos con fecha 2 de mayo y 29 de agosto de 2003, ascendente a la cantidad de $258.880 para el lote N&#xBA;3-A y $472.400 para el lote N&#xBA;3-B.</div><br></div>", "i": 6745850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6745851}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "758", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-758"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-24", "doble_articulado": false, "id_norma": "267624", "numero_fuente": "38937", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-15", "vigencias": [{"desde": "2007-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-15", "fin_vigencia": "", "t