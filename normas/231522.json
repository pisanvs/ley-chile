{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 588 EXENTO, DE 2004 </div></div>", "i": 6501503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 588, de fecha 4 de agosto de 2004, de Educaci&#xF3;n, se declara aprobada a la Universidad de Rancagua la modificaci&#xF3;n al Plan y a los Programas de Estudio de la carrera que se indica:</div><br><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Pedagog&#xED;a B&#xE1;sica.</div><div class=\"p\">T&#xED;tulo Profesional:&nbsp; Profesor de Educaci&#xF3;n B&#xE1;sica, con</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  menciones en Lenguaje y</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Comunicaci&#xF3;n, en Ciencias Sociales</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  y en Matem&#xE1;ticas.</div><div class=\"p\">Grado Acad&#xE9;mico:&nbsp; &nbsp;  Licenciado en Educaci&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera se imparte en jornada diurna en su sede de Rancagua.</div><br></div>", "i": 6501504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de octubre de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6501505}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "588 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-588 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 588 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-04",