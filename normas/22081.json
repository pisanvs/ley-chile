{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTOS Lei n&#xFA;m. 225.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947215}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dense los siguientes suplementos a los &#xED;tems del presupuesto del Ministerio de Justicia que se espresan a continuacion:</div><div class=\"p\">&nbsp; &nbsp; Partida 20.-Al &#xED;tem 1, para pago de empleados suplentes, quince mil pesos ($ 15,000);</div><div class=\"p\">&nbsp; &nbsp; Al &#xED;tem 11, para cubrir gastos pendientes de a&#xF1;os anteriores, diez mil pesos ($ 10,000); i</div><div class=\"p\">&nbsp; &nbsp; Al &#xED;tem 15, para imprevistos, quince mil pesos ($ 15,000).</div><br><br></div>", "i": 5947216}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de Diciembre de 1894.-JORJE MONTT.-O. Renjifo.</div><br></div>", "i": 5947217}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "225", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-225"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "SUPLEMENTOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1894", "MODIFICACION", "MINISTERIO", "JUSTICIA", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-26", "doble_articulado": false, "id_norma": "22081", "numero_fuente": "4998", "tipo_version": "3", "tip