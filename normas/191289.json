{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7287060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.278 de 30 de octubre de 2001 de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 721 de 1996 de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA FRIOSUR S.A., para realizar actividades pesqueras extractivas con la nave &quot;Friosur IX&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 41&#xB0;28,6&apos; L.S. a 47&#xB0; L.S. respecto del recurso hidrobiol&#xF3;gico Merluza de tres aletas, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7287061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de octubre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7287062}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2278", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2278"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-30", "doble_articulado": false, "id_norma": "191289", "numero_fuente": "37103", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-06", "vigencias": [{"desde": "2001-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-11-06", "fin_vigencia": "", "tipo_version": "3"}