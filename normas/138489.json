{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,090.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 7250196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Der&#xF3;ganse los incisos 2.&#xBA;, 3.&#xBA;, 4.&#xBA;, 5.&#xBA;, 6.&#xBA;, 7.&#xBA; i 8.&#xBA;, del art&#xED;culo 38 de la lei n&#xFA;mero 2,846, de 26 de enero de 1914, sobre administracion i servicios de los Ferrocarriles del Estado.</div><br></div>", "i": 7250197, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a once de abril de mil novecientos dieciseis.- Juan Luis Sanfuentes.- Anjel Guarello. </div></div>", "i": 7250198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3090", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3090"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-04-11", "doble_articulado": false, "id_norma": "138489", "numero_fuente": "11449", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-04-18", "vigencias": [{"desde": "1916-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-04-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1916-04-18", "fin_vigencia": "", "tipo_version": "3"}