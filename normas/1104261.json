{"html": [{"t": "<div><br><div class=\"p\">FIJA PLAZO PARA PRESENTACI&#xD3;N DE DECLARACI&#xD3;N JURADA</div></div>", "i": 9807038}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 55, del 13 de junio de 2017, que fija nuevo plazo para presentaci&#xF3;n de Declaraci&#xF3;n Jurada Formulario N&#xBA; 1925, denominada &quot;Declaraci&#xF3;n Jurada Anual de Fondo de Utilidades Tributables (FUT)&quot;, durante el a&#xF1;o 2017.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en el mes de junio de 2017.</div></div>", "i": 9807039}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "55 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-55 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "FIJA PLAZO PARA PRESENTACIÓN DE DECLARACIÓN JURADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1228952; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-06-13", "doble_articulado": false, "id_norma": "1104261", "numero_fuente": "41786", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-06-17", "vigencias": [{"desde": "2017-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-06-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-06-17", "fin_vigencia": "", "tipo_version": "3"}], "event