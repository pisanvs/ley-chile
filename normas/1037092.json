{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9235774}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 109, de 16 de enero de 2012, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1029563&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.226, de 2011</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a ECOTECNOS LIMITADA para efectuar una pesca de investigaci&#xF3;n, en el sentido de incorporar un nuevo sector de muestreo seg&#xFA;n lo se&#xF1;alado en la resoluci&#xF3;n extractada.</div></div>", "i": 9235775}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de enero de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9235776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "109 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-109 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-16", "doble_articulado": false, "id_norma": "1037092", "numero_fuente": "40182", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-02-08", "vigencias": [{"desde": "2012-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-02-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-02-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresad