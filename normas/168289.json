{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 371, DE 1990 </div></div>", "i": 6274199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Supremo exento de Educaci&#xF3;n No. 371 de 28 de Diciembre de 1990 se ha derogado el Decreto Supremo de Educaci&#xF3;n No. 2892, de 1954.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se ha aprobado plan especial de estudio transitorio para la especialidad de Contabilidad, para aquellos alumnos que hubieren aprobado el curso previo y el 1er. y 2do. a&#xF1;o contemplado en el decreto supremo de Educaci&#xF3;n No. 2892 de 1954.</div><br></div>", "i": 6274200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de Marzo de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6274201}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "371 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-371 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 371, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-28", "doble_articulado": false, "id_norma": "168289", "numero_fuente": "33937", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-08", "vigencias": [{"desde": "1991-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-05-09", "fecha_v