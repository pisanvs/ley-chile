{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Libera de derechos la internacion de la brea mineral destinada a la fabricacion de briquetes de carbon Lei n&#xFA;m. 2,919.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5954436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Decl&#xE1;rase libre de derechos la internacion de la brea mineral destinada a la fabricacion de briquetes o aglomerado de carbon de piedra.</div><br></div>", "i": 5954437}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 12 de Agosto de 1914.- RAMON BARROS LUCO.- Ricardo Salas Edwards.</div><br></div>", "i": 5954438}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2919", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2919"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LIBERA DE DERECHOS DE INTERNACION DE LA BREA MINERAL DESTINADA A LA FABRICACION DE BRIQUETES DE CARBON", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BREA MINERAL", "BRIQUETES CARBON", "FABRICACION", "DERECHOS INTERNACION", "LIBERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-08-12", "doble_articulado": fals