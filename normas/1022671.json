{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9106847}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 173, de 19 de enero de 2011, de esta Subsecretar&#xED;a, ac&#xF3;gense los descargos formulados y ampl&#xED;ese por 12 meses, a contar del 1&#xBA; de octubre de 2010, el plazo otorgado por el numeral 4&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1006556&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3087 de 2009</a>, de esta Subsecretar&#xED;a de Pesca, a PESQUERA BAH&#xCD;A CORONEL S.A. para iniciar actividades pesqueras extractivas con la nave &quot;Francisco&quot;, respecto de los recursos hidrobiol&#xF3;gicos Alfonsino y Besugo, en el &#xE1;rea mar&#xED;tima correspondiente a la V a VII y XIV a X Regiones.</div></div>", "i": 9106848}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de enero de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9106849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "173 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-173 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2011-01-19", "fecha_derogacion": "2011-08-25", "doble_articulado": false, "id_norma": "1022671", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2011-02-02", "vigencias": [{"desde": "2011-08-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2011-02-02", "hasta": "2011-08-24", "tipo_version": "0", "tipo_ver