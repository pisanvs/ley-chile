{"html": [{"t": "<div><div class=\"p\">DEROGASE UTORIZACION DE AGENTE RETENEDOR DE IVA A SOCIEDAD COMERCIAL ROGAR LTDA.</div><br></div>", "i": 7347164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del S.I.I., por Res./Dre.07/Ex. N&#xBA; 3.490 de fecha 29 de junio de 2007, deroga a contribuyente Sociedad Comercial Rogar Ltda., RUT. N&#xBA; 78.556.910-5, a contar de la fecha de esta publicaci&#xF3;n, la calidad de agente retenedor del Impuesto al Valor Agregado, de cambio de sujeto total de derecho del IVA en las ventas de chatarra, de acuerdo a lo establecido en la Resoluci&#xF3;n ex. N&#xBA; 7 del 28.01.2003, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 7347165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Talca, 29 de junio de 2007.- Mirtha Barra Paredes, Directora Regional.</div><br></div>", "i": 7347166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3490 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-3490 EXENTA"}, {"tipo": "3", "numero": "DRE-07-00-3490 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-07-00-3490 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "DEROGASE UTORIZACION DE AGENTE RETENEDOR DE IVA A SOCIEDAD COMERCIAL ROGAR LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-29", "doble_articulado": false, "id_norma": "262506", "numero_fuente": "38807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-07", "vigencias": [{"desde": "2007-07-07", "hasta": "", "tipo_version": "3", "