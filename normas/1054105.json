{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 6.640 EXENTA, DE 2013</div></div>", "i": 9373836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 6.640, de 26 de agosto de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Fundaci&#xF3;n de Capacitaci&#xF3;n Cerro Navia Joven (Fundaci&#xF3;n de Capacitaci&#xF3;n Cerro Navia Joven)&quot;, RUT 65.791.700-1 contenida en la resoluci&#xF3;n exenta N&#xBA; 6.910, de 2 de noviembre de 2007, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9373837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9373838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6640 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6640 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 6.640 EXENTA, DE 2013", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-08-26", "fecha_derogacion": "2013-10-17", "doble_articulado": false, "id_norma": "1054105", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-09-10", "vigencias": [{"desde": "2013-10-17", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2013-09-10", "hasta": "2013-10-16", "tipo_version": "0", "tipo_ve