{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 222, DE 1991 </div></div>", "i": 7215323}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 222 de fecha 05 de Agosto de 1991 del Ministerio de Educaci&#xF3;n, se insert&#xF3; en la Resoluci&#xF3;n Exenta No. 1016 de 1985 del Centro de Formaci&#xF3;n T&#xE9;cnica Cenafom, las adecuaciones introducidas a la carrera de Contabilidad General y en la Resoluci&#xF3;n Exenta No. 1 de 1985, las adecuaciones introducidas a las carreras de Programaci&#xF3;n de Aplicaciones Computacionales, T&#xE9;cnico en Auditor&#xED;a y An&#xE1;lisis de Sistemas.</div><br></div>", "i": 7215324}, {"t": "<div><div class=\"p\">Santiago, 8 de Noviembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.-</div><br></div>", "i": 7215325}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "222 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-222 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº. 222, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-05", "doble_articulado": false, "id_norma": "80418", "numero_fuente": "34132", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-03", "vigencias": [{"desde": "1991-12-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-12-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-12-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "