{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 1.443, de 3 de julio de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8783824}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;case <a href=\"https://www.leychile.cl/Navegar?idNorma=223459&amp;idParte=0&amp;idVersion=\">la resoluci&#xF3;n 141, de 2 de enero de 2004</a>, autorizada transferir por <a href=\"https://www.leychile.cl/Navegar?idNorma=245557&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 1.481, de 27 de octubre de 2005</a>, ambas del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, en el sentido de reemplazar el p&#xE1;rrafo 4.- y el p&#xE1;rrafo 3.-, de ambas resoluciones respectivamente, por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n exenta 2.608, de 28 de octubre de 2003, modificada por resoluci&#xF3;n exenta 2.142, de 20 de julio de 2007, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;</div><br></div>", "i": 8783825, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de julio de 2009.- Por la Sra. Subsecretaria, Humberto Ram&#xED;rez Navarro, Subjefe Subsecretar&#xED;a de Marina.</div><br></div>", "i": 8783826}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1443", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1443"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [