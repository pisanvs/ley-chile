{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0;451, DE 1993 </div></div>", "i": 5944631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0;451 de 27 de agosto de 1993 se ha aprobado al Colegio Calasanz, de Santiago, un plan especial de estudio para 3er. y 4to.</div><div class=\"p\">a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, para ser aplicado a partir del a&#xF1;o escolar 1993.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas que se indican en el presente decreto. </div></div>", "i": 5944632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de septiembre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944633}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "451 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-451 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°451, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO CALASANZ", "PLANES ESTUDIOS", "PROGRAMAS", "ESTUDIOS", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-08-27", "doble_articulado": false, "id_norma": "21269", "numero_fuente": "34672", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-09-22", "vigencias": [{"desde": "1993-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-09-22", "fin_vigencia": "", "tipo_version