{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO APLICACI&#xD3;N DE REAJUSTES E INTERESES PENALES EN CASOS QUE SE INDICAN</div></div>", "i": 10374330}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 98, del 18 de octubre de 2022, deja sin efecto aplicaci&#xF3;n de reajustes e intereses penales correspondientes a la tercera cuota de contribuciones con vencimiento el 30 de septiembre de 2022 y dispone la imputaci&#xF3;n de las sumas pagadas indebidamente por los contribuyentes en casos que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento est&#xE1; publicado en &quot;www.sii.cl&quot;.- </div></div>", "i": 10374331}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Carolina Saravia Morales, Subdirectora de Fiscalizaci&#xF3;n.</div><div class=\"p\"> </div></div>", "i": 10374332}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "98 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-98 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEJA SIN EFECTO APLICACIÓN DE REAJUSTES E INTERESES PENALES EN CASOS QUE SE INDICAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2205158", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-10-18", "doble_articulado": false, "id_norma": "1183303", "numero_fuente": "43383", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-10-22", "vigencias": [{"desde": "2022-10-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in