{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.000, de 23 de mayo de 1996, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por SALMONES UNIMARC</div><div class=\"p\">S.A., para un centro de cultivo ubicado al oeste de</div><div class=\"p\">Punta Calen, Paso Tenaun, comuna de Dalcahue, provincia</div><div class=\"p\">de Chilo&#xE9;, X Regi&#xF3;n, por no dar cumplimiento el</div><div class=\"p\">respectivo proyecto t&#xE9;cnico a lo dispuesto en los</div><div class=\"p\">art&#xED;culos 78&#xB0; y 87&#xB0; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8295172}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 23 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295173}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1000", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1000"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION ACUICULTURA", "DENEGACION", "SALMONES UNIMARC S.A.", "DALCAHUE", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-23", "doble_articulado": false, "id_norma": "36000", "numero_fuente": "35479", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-30", "vigencias": [{"desde": "1996-05-30", "hasta": "", "tipo_version": "3", "ti