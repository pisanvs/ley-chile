{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6269526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.301, de 29 de septiembre de 1987, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes se modifica la resoluci&#xF3;n No. 190, de 1987, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, publicada en el Diario Oficial de 13 de febrero de 1987, en el sentido que la Empresa de origen argentino &quot;El R&#xE1;pido S.R.L.&quot; est&#xE1; autorizada para atender el servicio internacional de transporte terrestre de pasajeros entre Mendoza (Argentina) y Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar (Chile), por Paso Caracoles (T&#xFA;nel Cristo Redentor), efectuando dos (2) frecuencias diarias.</div><br></div>", "i": 6269527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos Villegas Lorca, Subsecretario de Transportes subrogante.</div><br></div>", "i": 6269528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1301", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1301"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-29", "doble_articulado": false, "id_norma": "166903", "numero_fuente": "32890", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-10-09", "vigencias": [{"desde": "1987-10-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-10-09", "fin_vigencia": ""