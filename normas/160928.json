{"html": [{"t": "<div><div class=\"p\">EXTRACTO DEL DECRETO ALCALDICIO N&#xB0; 57 DE FECHA 19 DE MARZO DE 1985 </div></div>", "i": 6250443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modifica la Ordenanza Local sobre Derechos Municipales por Concesiones, Permisos y Servicios para 1985, en el sentido de que se suspende por un plazo de 90 d&#xED;as el cobro de Derechos Municipales a las obras de construcci&#xF3;n y otros, sin perjuicio de las correspondientes aprobaciones y permisos que debe otorgar la Direcci&#xF3;n de Obras y Urbanismos de la I. Municipalidad.-</div><br></div>", "i": 6250444}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Patricio Rom&#xE1;n Herrera, TCL. Ejto., Alcalde de Melipilla Interino.- Jorge Felipe Garc&#xED;a Rioseco, Secretario Municipal, Abogado.</div><br></div>", "i": 6250445}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "57", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-57"}], "organismos": ["MUNICIPALIDAD DE MELIPILLA"], "titulo_norma": "EXTRACTO DEL DECRETO ALCALDICIO N° 57 DE FECHA 19 DE MARZO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-03-19", "doble_articulado": false, "id_norma": "160928", "numero_fuente": "32128", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-22", "vigencias": [{"desde": "1985-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso":