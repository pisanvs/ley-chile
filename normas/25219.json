{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA EL D.F.L. N.o 247, DE 21 DE JULIO DE 1932, QUE CONCEDE PERSONALIDAD JURIDICA A LA LINEA AEREA NACIONAL</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5962430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1.o Reempl&#xE1;zase la palabra &quot;particulares&quot; por la palabra &quot;privados&quot; en el art&#xED;culo 8.o, letra b) del D.F.L. N.o 247, de 21 de Julio de 1932.</div><br></div>", "i": 5962431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2.o Esta Ley empezar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial&quot;. </div></div>", "i": 5962432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, quince de Julio de mil novecientos treinta y seis.- ARTURO ALESSANDRI.- Emilio Bello C.</div><br></div>", "i": 5962433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5851", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5851"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "MODIFICA EL D.F.L. N.o 247, DE 21 DE JULIO DE 1932,\nQUE CONCEDE PERSONALIDAD JURIDICA A LA LINEA AEREA\nNACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LINEA AEREA NACIONAL", "CAPITAL", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1936-07-15", "doble_articulado": false, "id_norma": "25219", "numero_fuente": "17531", "tipo_version":