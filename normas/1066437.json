{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9505791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (EXENTO) N&#xBA; 712 de 29 de agosto de 2014, se desisti&#xF3; de la expropiaci&#xF3;n del lote N&#xBA;2, ordenada por el <a href=\"https://www.leychile.cl/Navegar?idNorma=1041921&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xBA;1158 de 27 de junio de 2012</a>, debido a que el lote expropiado N&#xBA;2, no resulta necesario para la obra &quot;Habilitaci&#xF3;n Sondajes Cerro Negro Aducci&#xF3;n Lo Blanco - El Mariscal&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div></div>", "i": 9505792}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9505793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "712 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-712 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-08-29", "doble_articulado": false, "id_norma": "1066437", "numero_fuente": "40959", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-09-15", "vigencias": [{"desde": "2014-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part"