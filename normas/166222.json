{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 953, DE 1984, QUE APRUEBA MODIFICACION DE CONVENIO DE TRASPASO DE LA ESCUELA BASICA D-163 DE TALCA </div></div>", "i": 6267336}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto N&#xB0; 953, de 1984, se aprob&#xF3; una modificaci&#xF3;n al convenio de traspaso de la Escuela B&#xE1;sica D-163, de Talca, aprobado por decreto N&#xB0; 1.898, de 1981, que incide en la cl&#xE1;usula sexta.</div><br></div>", "i": 6267337}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 09 de enero de 1985.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica, subrogante. </div></div>", "i": 6267338}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "953", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-953"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO N° 953, DE 1984, QUE APRUEBA\nMODIFICACION DE CONVENIO DE TRASPASO DE LA ESCUELA\nBASICA D-163 DE TALCA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-09", "doble_articulado": false, "id_norma": "166222", "numero_fuente": "32081", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-26", "vigencias": [{"desde": "1985-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "2000-04-19", "fecha_version": "1985-01-26", "fech