{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Malecon de Vaparaiso Lei n&#xFA;m. 1,289.- Santiago, a 2 de Diciembre de 1899.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948781}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta la suma de cuatrocientos veinte mil pesos en la instalacion del alumbrado el&#xE9;ctrico i reparacion de los deterioros sufridos en el malecon de Valparaiso.</div><br><br></div>", "i": 5948782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Manuel Salinas.</div><br></div>", "i": 5948783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1289", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1289"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MALECON DE VALPARAISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALPARAISO", "MALECON", "PRESIDENTE REPUBLICA", "AUTORIZACION", "FONDOS", "DESTINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-12-02", "doble_articulado": false, "id_norma": "22531", "numero_fuente": "6464", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-12-04", "vigencias": [{"desde": "1899-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-12-04", "fin_vigencia": "", "tipo_version": "3"}