{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 310, DE 1984</div><br><br><br><br></div>", "i": 7264955}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 160, de 22 de Marzo de 1985, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 310, de 1984, que autoriz&#xF3; a Sociedad Pesquera Guanaye Ltda., domiciliada en la comuna de Providencia, para instalar y operar un establecimiento de cultivo de Osti&#xF3;n del Norte en seis sectores ubicados en Bah&#xED;a de Mejillones del Sur, II Regi&#xF3;n, en orden a fijar nuevas superficies y deslindes a los sectores indicados. </div></div>", "i": 7264956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago 22 de Marzo de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca </div></div>", "i": 7264957}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "160", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-160"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 310, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-03-22", "fecha_derogacion": "1993-05-12", "doble_articulado": false, "id_norma": "160618", "numero_fuente": "32142", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-04-10", "vigencias": [{"desde": "1993-05-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-04-10", "hasta": "1993-05-11", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "