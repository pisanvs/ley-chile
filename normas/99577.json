{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6112180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto Secc. 2&#xAA; N&#xBA; 438, 05/06/1998, Alcalde Municipalidad Santiago dispone expropiaci&#xF3;n parcial, conforme art. 85 decreto 458 Ministerio Vivienda y Urbanismo inmueble San Isidro 379-387 Rol N&#xBA; 520-010-011, comuna Santiago, dominio aparente Puerto Fuy S.A., superficie aproximada 49,84 metros cuadrados. Deslindes: Norte, 0,90 mts. otro propietario; Sur, 2,75 mts. otro propietario; Oriente, 27,35 mts. calle San Isidro y Poniente, 27,27 mts. resto predio. Indemnizaci&#xF3;n $10.675.728.- pagadera contado. </div></div>", "i": 6112181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime Ravinet de la Fuente, Alcalde Santiago. </div></div>", "i": 6112182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "438", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-438"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-05", "doble_articulado": false, "id_norma": "99577", "numero_fuente": "36089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-15", "vigencias": [{"desde": "1998-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-06-16", "fecha_ve