{"html": [{"t": "<div><div class=\"p\">LEY NUM. 14,747</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DON VIVIANO MU&#xD1;OZ ARANDA </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6569699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a don Viviano Mu&#xF1;oz Aranda, una pensi&#xF3;n de E&#xBA; 30 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande este ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.&quot; </div></div>", "i": 6569700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a siete de Diciembre de mil novecientos sesenta y uno.- JORGE ALESSANDRI RODRIGUEZ.- Luis Mackenna S.</div><br></div>", "i": 6569701}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14747", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14747"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DON VIVIANO MUÑOZ ARANDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1961-12-07", "doble_articulado": false, "id_norma": "249580", "numero_fuente": "25127", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1961-12-23", "vigencias": [{"desde": "1961-12-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia