{"html": [{"t": "<div><div class=\"p\">&amp;#160;</div></div>", "i": 8468851}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">Por decreto (exento) MOP N&#xBA;424 de fecha 27 de febrero del 2009, se expropi&#xF3; el lote de terreno N&#xBA;1-D, superficie 5.583 m2, Rol N&#xBA;158-230, comuna de Cocham&#xF3;, X Regi&#xF3;n para la obra &quot;Camino Puelo - Paso El Bols&#xF3;n, sector Llanada Grande - R&#xED;o Mapocho, Km. 32,50000 a Km. 37,40000&quot;, Provincia de Llanquihue, X Regi&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria PERTA DEL CARMEN VERA AGUILA, ascendente a la cantidad de $2.045.847.- para el lote N&#xBA;1-D. </div></div>", "i": 8468852}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8468853}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "424 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-424 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-02-27", "doble_articulado": false, "id_norma": "288536", "numero_fuente": "39327", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-04-01", "vigencias": [{"desde": "2009-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "114", "fecha_ingreso": "2009-04-01", "fecha_version": "2009-04-01", "actualizad