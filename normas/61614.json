{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6032247}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 101, de 31 de enero de 1997, se expropiaron los lotes de terreno N&#xBA;s. 86, 89, 89-A, 90-G y 116 superficies 3.027 m2, 2.309 m2, 786 m2, 277 m2 y 988 m2, respectivamente, roles de aval&#xFA;o 2224-544, 2224-522, 2224-543, 2235-16 y 2224-48, comuna de Chill&#xE1;n, para la obra Camino Acceso Norte a Concepci&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Carlos Alfonso Bast&#xED;as Fuentes, Segundo Laureno Cires, Francisco Gonz&#xE1;lez Hern&#xE1;ndez y V&#xED;ctor Carrasco de la Hoz, ascendente a las cantidades de $1.569.735.-, $2.990.954.-, $725.999.-, $311.826.- y $895.279.- </div></div>", "i": 6032248}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6032249}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "101", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-101"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "CHILLAN", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-31", "doble_articulado": false, "id_norma": "61614", "numero_fuente": "35717", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-15", "vigencias": [{"desde": "1997-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-03-15", "fin_vigencia": "", "tipo_version"