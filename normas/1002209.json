{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 790 EXENTA, DE 2009</div></div>", "i": 8597275}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 790, de 20 de abril de 2009, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xBA; 5 de la resoluci&#xF3;n N&#xBA; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza para adecuar veh&#xED;culos al uso de gas natural comprimido como combustible:</div><br><div class=\"p\">Empresa&nbsp; &nbsp;  Nombre del&nbsp; &nbsp; &nbsp; Direcci&#xF3;n del&nbsp; &nbsp; &nbsp;  Ciudad</div><div class=\"p\">Habilitada&nbsp; Taller&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Taller </div><br><div class=\"p\">Futurgas </div><div class=\"p\">Ltda.&nbsp; &nbsp; &nbsp; Automotive Gas&nbsp; Avda. Eduardo Frei&nbsp;  Punta</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Systems S.A.&nbsp; &nbsp; N&#xBA; 314&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Arenas</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.- </div></div>", "i": 8597276}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Erazo Torricelli, Subsecretario de Transportes.</div></div>", "i": 8597277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "790 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-790 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 790 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacio