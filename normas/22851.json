{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Monumento a los se&#xF1;ores Manuel Montt i Antonio Varas Lei n&#xFA;m. 1692.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cinco mil pesos ($ 5 000), en las fiestas de inauguracion del monumento a don Manuel Montt i a don Antonio Varas.</div><br></div>", "i": 8274619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 21 de Setiembre de 1904.- JERMAN RIESCO.- M. E. Ballesteros.</div><br></div>", "i": 8274620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1692", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1692"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MONUMENTO A LOS SEÑORES MANUEL MONTT I ANTONIO VARAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANUEL MONTT", "ANTONIO VARAS", "PRESIDENTE REPUBLICA", "MONUMENTO", "INAUGURACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-09-21", "doble_articulado": false, "id_norma": "22851", "numero_fuente": "8011", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-09-21", "vigencias": [{"desde": "1904-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-09