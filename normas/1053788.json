{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 1.341 EXENTO, DE 2012</div></div>", "i": 9371621}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento 832, de 21 de agosto de 2013, de este Ministerio, modif&#xED;case el inciso 1&#xBA; del art&#xED;culo 1&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1047889&amp;idParte=&amp;idVersion=\">decreto exento N&#xBA; 1.341, de 2012, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, que fij&#xF3; para el a&#xF1;o 2013 una cuota anual de captura para el recurso Sardina austral, en el sentido de reemplazar la frase &quot;4.000 toneladas para la XI Regi&#xF3;n de Ays&#xE9;n&quot;, por la expresi&#xF3;n &quot;7.000 toneladas para la XI Regi&#xF3;n de Ays&#xE9;n&quot;.</div><br><div class=\"p\">&nbsp; &nbsp;  EL texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9371622}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9371623}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "832 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-832 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 1.341 EXENTO, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-08-21", "doble_articulado