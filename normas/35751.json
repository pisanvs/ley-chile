{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 864 de 20 de Julio de 1995, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por LUIS RAMIREZ</div><div class=\"p\">ROSALES, R.U.T. N&#xB0; 7.973.804-2, para un centro de</div><div class=\"p\">cultivo ubicado en la localidad de Changuitad, Comuna de</div><div class=\"p\">Curaco de V&#xE9;lez, Isla Quinchao, Provincia de Chilo&#xE9;, X</div><div class=\"p\">Regi&#xF3;n, por no darse cumplimiento a lo dispuesto en el</div><div class=\"p\">art&#xED;culo 77&#xB0; de la Ley General de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; D&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 1238, de 1989, de esta Subsecretar&#xED;a, en virtud de lo dispuesto en la presente Resoluci&#xF3;n.</div><br></div>", "i": 8294623}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 20 de Julio de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294624}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "864", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-864"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "CONCESION ACUICULTURA", "LUIS RAMIREZ", "ROSALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-07-20", "doble_articulado": false, "id_norma": "35751", "numero_fuente":