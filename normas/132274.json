{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 871, DE 1988 </div></div>", "i": 6155770}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 871 de fecha 13 de abril de 1988, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas al siguiente plan y programas de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Educaci&#xF3;n de Computaci&#xF3;n CEC de Santiago, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar del a&#xF1;o 1988, con la siguiente denominaci&#xF3;n.</div><div class=\"p\">Carrera: An&#xE1;lisis y Programaci&#xF3;n de Computadores.</div><div class=\"p\">T&#xED;tulo: Programador de Computadores (4 semestres).</div><div class=\"p\">T&#xE9;cnico Analista Programador de Computadores (2 semestres adicionales).</div><br></div>", "i": 6155771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6155772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "871 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-871 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 871, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-13", "doble_articulado": false, "id_norma": "132274", "numero_fuente": "33101", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-21", "vigencias": [{"desde": "1988-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic