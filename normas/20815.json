{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 253 EXENTO, DE 1995 </div></div>", "i": 5943202}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 253, de 26 de Abril de 1995, se ha aprobado un plan especial de estudio para Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica al &quot;Kingston College&quot; de Concepci&#xF3;n, el que ser&#xE1; aplicado progresivamente a partir del a&#xF1;o escolar 1997 en 1&#xB0; y 2&#xB0; a&#xF1;o medio y en el a&#xF1;o escolar 1998 en 3&#xB0; y 4&#xB0; a&#xF1;o medio. </div></div>", "i": 5943203}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 9 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943204}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "253", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-253"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 253 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["KINGSTON COLLEGE", "CONCEPCION", "OCTAVA REGION", "PROGRAMAS ESTUDIO", "PLANES ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-26", "doble_articulado": false, "id_norma": "20815", "numero_fuente": "35173", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-22", "vigencias": [{"desde": "1995-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":