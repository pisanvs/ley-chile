{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div><br></div>", "i": 8860562}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Estimado se&#xF1;or Director:</div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n de ese diario del d&#xED;a 28 de enero en curso, se public&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1010482&amp;idParte=&amp;idVersion=2010-02-02\">ley N&#xBA; 20.418</a>, que fija normas sobre informaci&#xF3;n, orientaci&#xF3;n y prestaciones en materia de regulaci&#xF3;n de la fertilidad. La certificaci&#xF3;n de la Secretaria de este Tribunal Constitucional, en relaci&#xF3;n al control de constitucionalidad ejercido, contiene un error que se salva a continuaci&#xF3;n: donde dice &quot;de 29 de diciembre de 2009&quot;, en p&#xE1;gina 3, segunda columna, reemplazar por &quot;de 14 de enero de 2010&quot;. Solicito a Ud. tenga a bien publicar la rectificaci&#xF3;n referida.</div><br><br></div>", "i": 8860563, "v": ["RECTIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lo saluda atentamente, Marta de la Fuente Olgu&#xED;n, Secretaria.</div><br></div>", "i": 8860564}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["TRIBUNAL CONSTITUCIONAL"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1010643", "numero_fuente": "39576", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-02-02", "vigencias": [{"desde": "2010-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-