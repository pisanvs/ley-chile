{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA;774 EXENTA, DE 2013</div></div>", "i": 9333568}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta que se indica del Ministerio de Educaci&#xF3;n, se ampl&#xED;a el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica Educap, otorgado por <a href=\"https://www.leychile.cl/Navegar?idNorma=84582&amp;idParte=&amp;idVersion=\">decreto exento de Educaci&#xF3;n N&#xBA; 75, de 1 de marzo de 1990</a>, en el sentido de aprobar el plan y programas de estudio de la carrera que se indica conducente al t&#xED;tulo T&#xE9;cnico de Nivel Superior que se se&#xF1;ala, para ser impartida en Sede Central de Quillota, a contar del a&#xF1;o 2013.</div><div class=\"p\">&nbsp; &nbsp;  Carrera: T&#xE9;cnico en Gesti&#xF3;n Financiera</div><div class=\"p\">&nbsp; &nbsp;  T&#xED;tulo: T&#xE9;cnico de Nivel Superior en Gesti&#xF3;n Financiera</div><br></div>", "i": 9333569}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de febrero de 2013.- Fernando Rojas Ochagav&#xED;a, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9333570}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "774 EXENTA", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-774 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº774 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-02-07", "doble_articulado": false, "id_norma": "1048846", "numero_fuente": "40485", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-14", "vigencias": [{"desde": "2013-02-14",