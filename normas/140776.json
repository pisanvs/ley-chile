{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8348082}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.519, de 11 de agosto de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA COLOSO S.A., Santiago, para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Tongoy&apos;&apos;, en orden a que la interesada podr&#xE1; realizar actividades pesqueras con la nave se&#xF1;alada precedentemente, en el litoral de la I y II Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con red de arrastre los recursos hidrobiol&#xF3;gicos Jurel fino y Sardina redonda. </div></div>", "i": 8348083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de agosto de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8348084}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1519", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1519"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-08-11", "fecha_derogacion": "2000-02-01", "doble_articulado": false, "id_norma": "140776", "numero_fuente": "36443", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-08-19", "vigencias": [{"desde": "2000-02-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-08-19", "hasta": "2000-01-31", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2000-02-01", "fin_vigencia": ""}, "vigenci