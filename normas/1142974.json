{"html": [{"t": "<div><div class=\"p\">Suspension de la apertura de la Convencion</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 16 de 1822.</div><br></div>", "i": 10111151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se suspende la apertura de la Convencion preparatoria, por impedirlo el tiempo lluvioso; i se anunciar&#xE1; por Gaceta Estraordinaria que se publicar&#xE1; un dia &#xE1;ntes, el en que debe solemizarse dicho acto, con la comodidad i decoro correspondientes.-</div></div>", "i": 10111152}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  O&apos;Higgins.- Echeverr&#xED;a.</div></div>", "i": 10111153}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Suspension de la apertura de la Convencion", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1822-07-16", "doble_articulado": false, "id_norma": "1142974", "numero_fuente": "1822", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1822-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1822-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1822-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2020-03-30", "fecha_version": "1822-07-16", "fecha_actualizacion_texto": "2020-03-30", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10111151}, {"n": "Artículo", "i": 10111152, "t": 6}, {"n": "Pr