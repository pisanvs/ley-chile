{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div></div>", "i": 9868038}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por resoluci&#xF3;n exenta N&#xB0; 5.900, de fecha 4 de diciembre de 2017, esta Superintendencia de Valores y Seguros aprob&#xF3; reforma de estatutos de ACE Seguros de Vida S.A., acordada en junta extraordinaria de accionistas celebrada el 7 de noviembre de 2017, reducida a escritura p&#xFA;blica el 8 de noviembre de 2017, en la Notar&#xED;a de Santiago de don Iv&#xE1;n Torrealba Acevedo, domiciliado en Hu&#xE9;rfanos 979, oficina 501, Santiago.</div><div class=\"p\">&nbsp; &nbsp;  La reforma consiste en cambiar el nombre de la sociedad que pasa a llamarse Chubb Seguros de Vida Chile S.A. Se modifica art&#xED;culo primero de los estatutos.</div><br></div>", "i": 9868039}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de diciembre de 2017.- Gerardo Bravo Riquelme, Jefe Divisi&#xF3;n Jur&#xED;dica y Secretar&#xED;a General. </div></div>", "i": 9868040}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5900", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5900"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1322174; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-12-04", "doble_articulado": false, "id_norma": "1112782", "numero_fuente": "41938", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-12-21", "vigencias": [{"desde": "2017-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-12-21",