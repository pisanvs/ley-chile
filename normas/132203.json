{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6155590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 834 de 13 de Mayo de 1988, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 11, sitios N&#xB0;s. 1 al 3 del Proyecto de Parcelaci&#xF3;n &quot;San Rafael&quot; de la comuna de Yumbel, VIII Regi&#xF3;n, formado por predio &quot;Resto del predio denominado Hijuelas Regadas, Tres, Cuatro y Cinco conocido como San Rafael&quot;. Los Derechos de Agua se extraen del R&#xED;o Laja conducidos por canal La Mancha. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.</div><br></div>", "i": 6155591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6155592}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "834 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-834 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-13", "doble_articulado": false, "id_norma": "132203", "numero_fuente": "33085", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-01", "vigencias": [{"desde": "1988-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-01", "fin_vigencia": "", "ti