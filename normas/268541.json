{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE RECEPTOR ELECTR&#xD3;NICO </div></div>", "i": 7361995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 8 de 10 de enero de 2008, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como receptor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n de la representante legal del contribuyente RUT N&#xBA; 76.365.720-5, se deroga autorizaci&#xF3;n otorgada como receptor de Documentos Tributarios Electr&#xF3;nicos.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2008.</div><br></div>", "i": 7361996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACIÓN DE RECEPTOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-01-10", "doble_articulado": false, "id_norma": "268541", "numero_fuente": "38962", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-01-16", "vigencias": [{"desde": "2008-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"