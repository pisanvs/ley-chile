{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 80 EXENTA, DE 1999</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 176 exenta.- Coyhaique, 16 de noviembre de 2001.- Visto: El art&#xED;culo 45&#xBA; del decreto supremo N&#xBA; 212 de 1992 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, y la resoluci&#xF3;n exenta N&#xBA; 80/99 de esta Secretar&#xED;a Regional Ministerial, publicada en el Diario Oficial de 27 de mayo de 1999,</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6358600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 80/99 citada en Visto, en el sentido de sustituir la fecha &quot;01 de diciembre de 2001&quot; por &quot;1 de diciembre de 2005&quot;.</div><br></div>", "i": 6358601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese.- Alejandro B&#xF3;rquez Riquelme, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Ays&#xE9;n.</div><br></div>", "i": 6358602}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "176 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-176 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XI REGIÓN DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "MODIFICA RESOLUCION Nº 80 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-16", "doble_articulado": false, "id_norma": "191951", "numero_fuente": "37118", "tipo_version": "3", "tipo_version_s"