{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6068820}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 41 de 12.01.90, se adjudica a &quot;Carlos Acu&#xF1;a Mellado&quot;, la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar del 15 de Febrero de 1990, un establecimiento ubicado en calle Las Dalias, No. 2248, Macul, destinado a la Revisi&#xF3;n T&#xE9;cnica y Verificaci&#xF3;n de Emisi&#xF3;n de Contaminantes de Autom&#xF3;viles, Station Wagons, Motocicletas, Veh&#xED;culos de Carga de menos de 1.750 kg. de capacidad de carga &#xFA;til y sus Remolques de la Regi&#xF3;n Metropolitana, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6068821}, {"t": "<div><div class=\"p\">Carlos Silva Echiburu, Ministro de Transportes y Telecomunicaciones.</div><br></div>", "i": 6068822}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-41 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-12", "doble_articulado": false, "id_norma": "84787", "numero_fuente": "33583", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-30", "vigencias": [{"desde": "1990-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-01-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []