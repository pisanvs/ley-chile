{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 7.391 EXENTA,DE 2007 </div></div>", "i": 6631730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 7.391, de 22 de noviembre de 2007, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se cancel&#xF3; del Registro de Organismos T&#xE9;cnicos Intermedios para Capacitaci&#xF3;n al &quot;Organismo T&#xE9;cnico Intermedio para Capacitaci&#xF3;n de los Taxistas del Norte&quot;, RUT N&#xBA; 65.072.060-1, y, por ende, qued&#xF3; sin efecto su correspondiente personalidad jur&#xED;dica, en virtud de lo dispuesto en el art&#xED;culo 78 letra c) de la ley N&#xBA; 19.518.</div><br></div>", "i": 6631731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fernando Rouliez Fleck, Director Nacional. </div></div>", "i": 6631732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7391 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7391 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 7.391 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-22", "doble_articulado": false, "id_norma": "267084", "numero_fuente": "38927", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-03", "vigencias": [{"desde": "2007-12-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_