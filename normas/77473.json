{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6050618}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 34, del 20 de marzo de 1992, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la I Regi&#xF3;n, se adjudic&#xF3; a Jorge Francisco Javier Araya Manieu, la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la fecha de publicaci&#xF3;n del presente extracto, un establecimiento ubicado en Calle 18 de Septiembre 2037, de Arica, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de los veh&#xED;culos que se se&#xF1;alen en el inciso segundo del art&#xED;culo 7&#xB0; del DS 156/90 del Ministerio, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.- </div></div>", "i": 6050619}, {"t": "<div><div class=\"p\">Yerki Luksic Sandoval, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n.</div><br></div>", "i": 6050620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "34", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-34"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-20", "doble_articulado": false, "id_norma": "77473", "numero_fuente": "34365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-09-12", "vigencias": [{"desde": "1992-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"