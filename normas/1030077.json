{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9185177}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.163, de 12 de agosto de 2011, de esta Subsecretar&#xED;a, modif&#xED;quese el numeral 3.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1022845&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 128 de 2011</a>, que autoriz&#xF3; a LEONARDO MIRANDA &#xC1;VILA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Monitoreo de fauna acu&#xE1;tica en aguas continentales de las Regiones V, VII, VIII y IX&quot;, en el sentido de extender a cursos y cuerpos de agua ubicados en la VI y X Regiones el &#xE1;rea geogr&#xE1;fica en la que se desarrollar&#xE1; la citada pesca de investigaci&#xF3;n.</div></div>", "i": 9185178}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de agosto de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9185179}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2163 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2163 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-08-12", "doble_articulado": false, "id_norma": "1030077", "numero_fuente": "40063", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-16", "vigencias": [{"desde": "2011-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_