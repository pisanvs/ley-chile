{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 15.672 EXENTA, DE 2002 </div></div>", "i": 6412229}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 15.672, de 30 de diciembre del a&#xF1;o 2002, se ha agregado, a contar del a&#xF1;o escolar 2003, a la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 783, de 2001, que aprob&#xF3; plan y programas especiales de estudio para 3&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Colegio Villa Mar&#xED;a Academy, comuna de Las Condes, de Santiago, el Subsector de Antropolog&#xED;a Teol&#xF3;gica al listado de Subsectores Electivos de 3&#xBA; a&#xF1;o medio, con 2 clases semanales, cuyo programa se aprueba por la presente resoluci&#xF3;n.</div><br></div>", "i": 6412230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de enero de 2003.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6412231}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "15672 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-15672 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 15.672 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-30", "doble_articulado": false, "id_norma": "207196", "numero_fuente": "37473", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-31", "vigencias": [{"desde": "2003-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20