{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div><br></div>", "i": 10334050}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 540, del 22 de abril de 2022, del Serviu Regi&#xF3;n de &#xD1;uble, orden&#xF3; expropiaci&#xF3;n de inmueble ubicado en Huambaly 707, comuna de Chill&#xE1;n, Rol de aval&#xFA;o N&#xB0; 001 776-00002, de aparente dominio de Ortega Villalobos Mar&#xED;a, la cual fue rectificada mediante resoluci&#xF3;n exenta N&#xB0; 600, de fecha 4 de mayo de 2022. Rectif&#xED;case la publicaci&#xF3;n de fecha 2 de mayo de 2022, que corresponde a la <a href=\"https://www.leychile.cl/Navegar?idNorma=1175518&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 540, de fecha 22.04.2022</a>, en cuanto a la expropiaci&#xF3;n de inmueble ubicado en Huambaly 707, comuna de Chillan, Rol de aval&#xFA;o N&#xB0; 001766-00002, de aparente dominio de Ortega Villalobos Mar&#xED;a, debiendo reemplazarse el Rol de aval&#xFA;o N&#xB0; 001766-00002, por el Rol de aval&#xFA;o N&#xB0; 001776-00002.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10334051}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Regi&#xF3;n de &#xD1;uble.</div><div class=\"p\"> </div><br></div>", "i": 10334052}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "540 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-540 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE ÑUBLE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2125761"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-04-22",