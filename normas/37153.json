{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 1.547, de 16 de Agosto de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por CARLOS AUGUSTO BECKER ALVEAR, para un centro de cultivo ubicado en Isla Aul&#xED;n, comuna de Quemchi, Provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los art&#xED;culos 78&#xB0;, 87&#xB0; y 14&#xB0; del D.S. N&#xB0; 290 de 1993, modificado por el D.S. N&#xB0; 604, de 1994, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8297719}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 16 de Agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297720}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1547", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1547"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "CARLOS AUGUSTO BECKER ALVEAR", "QUEMCHI", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-08-16", "doble_articulado": false, "id_norma": "37153", "numero_fuente": "35549", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-08-23", "vigencias": [{"desde": "1996-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"in