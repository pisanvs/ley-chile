{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7298139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 378, de 31 de enero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Vikingo&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><div class=\"p\"> Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2706</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp;  CB-4535</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp;  55,49 m</div><div class=\"p\">T.R.G. (Internacional) 1.110</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; 1284,60 m3</div><br></div>", "i": 7298140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 2003.- Felipe&nbsp; Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7298141}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "378", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-378"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-01-31", "fecha_derogacion": "2005-03-30", "doble_articulado": false, "id_norma": "207766", "numero_fuente": "37484", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-02-13", "vigencias": [{"desde": "2005-03-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-02-13", "hasta": "2005-03-29", "tipo_version": "0", "tip