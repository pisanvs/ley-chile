{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 917 de 26 de Julio de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a CONSUELO DEL CARMEN FREIRE SAAVEDRA, R.U.T. N&#xB0; 6.450.307-3, domiciliada en Taltal, para ampliar actividades pesqueras, en orden a incorporar a la planta ubicada en calle Atacama N&#xB0; 73, Taltal, en las l&#xED;neas de elaboraci&#xF3;n de Congelado y Fresco-refrigerado, los siguientes recursos hidrobiol&#xF3;gicos: Anchoveta, At&#xFA;n aleta amarilla, At&#xFA;n aleta larga, Bonito, Caballa, Marrajo o tibur&#xF3;n, Sardina espa&#xF1;ola, Sardina com&#xFA;n, Culengue.</div><br><br></div>", "i": 8294836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Julio de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294837}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "917", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-917"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "CONSUELO DEL CARMEN FREIRE", "SAAVEDRA", "TALTAL", "ANTOFAGASTA", "SEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-07-26", "fecha_derogacion": "1997-03-19", "doble_articulado": false, "id_norma": "35861", "numero_fuente": "35260", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1995-09-04", "vigencias": [{"desde": "1997-03-19", "hasta": "", "tipo_version": "2", "tipo_