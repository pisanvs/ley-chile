{"html": [{"t": "<div><div class=\"p\">DECLARA &#xC1;REA DE PLAGA Y DE RIESGO DE PLAGA QUE INDICA EN CUERPOS DE AGUA QUE SE&#xD1;ALA</div></div>", "i": 10209755}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 719, de 10 de marzo de 2021, de esta Subsecretar&#xED;a, declara, por el plazo de dos a&#xF1;os, &#xE1;rea de plaga y riesgo de plaga de la especie Didymosphenia geminata, en los sectores de cuerpos de agua terrestres que se indican en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en la p&#xE1;gina web www.subpesca.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10209756}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de marzo de 2021.- Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10209757}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "719 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-719 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DECLARA ÁREA DE PLAGA Y DE RIESGO DE PLAGA QUE INDICA EN CUERPOS DE AGUA QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1910007", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-03-10", "doble_articulado": false, "id_norma": "1157009", "numero_fuente": "42906", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-03-16", "vigencias": [{"desde": "2021-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v