{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6502561}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.886 de 14 de octubre de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;&#xCD;A PESQUERA CAMANCHACA S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Collen&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la I y II Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar, con cerco, los recursos: Jurel fino, Machuelo o tritre, Anchoa blanca, Sardina redonda, Vinciguerria y Jibia. </div></div>", "i": 6502562}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de octubre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6502563}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2886", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2886"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-10-14", "fecha_derogacion": "2021-11-09", "doble_articulado": false, "id_norma": "231828", "numero_fuente": "37996", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-10-27", "vigencias": [{"desde": "2021-11-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-10-27", "hasta": "2021-11-08", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2021-11-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-27", "fin_vigencia": "2