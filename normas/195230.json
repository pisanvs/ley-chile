{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 127 EXENTA, DE 2002 </div><br></div>", "i": 6371643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 127, de fecha 5 de febrero de 2002, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; complementariamente a la empresa de origen boliviano &quot;Trans Salvador S.R.L.&quot;, para efectuar transporte terrestre internacional de pasajeros entre Oruro (Bolivia) y Arica (Chile), y viceversa, con cuatro (4) frecuencias semanales de ida y vuelta, utlizando el paso fronterizo de Tambo Quemado.</div><br></div>", "i": 6371644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Patricio Tombolini V&#xE9;liz, Subsecretario de Transportes.</div><br></div>", "i": 6371645}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "127 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-127 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 127 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-05", "doble_articulado": false, "id_norma": "195230", "numero_fuente": "37202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-05", "vigencias": [{"desde": "2002-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-03-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones