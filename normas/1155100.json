{"html": [{"t": "<div><div class=\"p\">Creacion del grado de sarjento-mayor</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Junio 20 de 1814.</div></div>", "i": 10210450}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Deseando esta Suprema Direccion premiar a los benem&#xE9;ritos oficiales, que se han distinguido en las diversas acciones militares, que ha sostenido el Ej&#xE9;rcito de Chile, i a los que en lo sucesivo se hagan acreedores por sus servicios; he venido en declarar grado intermedio entre el de Capitan i Teniente Coronel, que ha estado en uso hasta la fecha, el de Sarjento Mayor, que deber&#xE1; concederse a los que tengan el de capitan; transcr&#xED;base en El Monitor, i comun&#xED;quese en la &#xF3;rden del d&#xED;a.-</div></div>", "i": 10210451}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lastra.-Orjera, Secretario.</div></div>", "i": 10210452}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Creacion del grado de sarjento-mayor", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-06-20", "doble_articulado": false, "id_norma": "1155100", "numero_fuente": "1814", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-06-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-06-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "202