{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8332830}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 969, de 10 de julio de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a JUAN DOMINGO RIVERA ITURRA&nbsp; para ampliar actividades pesqueras autorizadas por resoluciones N&#xBA; 1.160 y N&#xBA; 1.617, ambas de 1996, y N&#xBA; 701, de 1997, todas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Estero Quell&#xF3;n s/n&#xBA;, Quell&#xF3;n, provincia de Chilo&#xE9;, X Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n de Deshidratado en Alcohol, el recurso hidrobiol&#xF3;gico Erizo.</div><br></div>", "i": 8332831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de julio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8332832}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "969", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-969"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "JUAN DOMINGO RIVERA ITURRA", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-10", "doble_articulado": false, "id_norma": "122650", "numero_fuente": "36131", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-08-04", "vigencias": [{"desde": "1998-08-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-08-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc