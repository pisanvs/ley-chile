{"html": [{"t": "<div><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DON LUIS CORNEJO GALARCE </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley </div></div>", "i": 6433751}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a don Luis Cornejo Galarce una pensi&#xF3;n de $ 20.000 mensuales.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; El gasto que demande esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6433752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a treinta y uno de Octubre de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Eduardo Urz&#xFA;a Merino.</div><br></div>", "i": 6433753}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13255", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13255"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DON LUIS CORNEJO GALARCE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-10-31", "doble_articulado": false, "id_norma": "213104", "numero_fuente": "24202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-11-23", "vigencias": [{"desde": "1958-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1958-11-23", "fin_vigencia": ""}, "vigen