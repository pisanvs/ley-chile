{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N DEL PARTIDO PROGRESISTA EN LA XI REGI&#xD3;N</div><br></div>", "i": 9180584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Marco Enr&#xED;quez-Ominami Gumucio y Cristian Warner Villagr&#xE1;n, Presidente y Secretario General, respectivamente, del Partido Progresista, han solicitado la constituci&#xF3;n legal del partido en la XI Regi&#xF3;n de Ais&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 238 fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 2.104, de fecha 2 de septiembre de 2011.- </div></div>", "i": 9180585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 9180586}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2104", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2104"}, {"tipo": "3", "numero": "O-2104", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-2104"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN DEL PARTIDO PROGRESISTA EN LA XI REGIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-09-02", "doble_articulado": false, "id_norma": "1029586", "numero_fuente": "40061", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-14", "vigencias": [{"desde": "2011-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_