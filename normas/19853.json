{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO NUMERO 38 EXENTO, DE 1996 </div></div>", "i": 7160191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 38 de 24 de enero de 1996, se ha aprobado al Colegio &quot;Nuestra Se&#xF1;ora&quot; de Graneros, un plan especial de estudio para los cursos de Educaci&#xF3;n Media, el cual se comenzar&#xE1; a aplicar a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio de la asignatura de Computaci&#xF3;n.</div><br></div>", "i": 7160192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 21 de Febrero de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "38 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-38 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 38 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO NUESTRA SE ORA DE GRANEROS", "PLANES ESTUDIO", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-24", "doble_articulado": false, "id_norma": "19853", "numero_fuente": "35402", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-26", "vigencias": [{"desde": "1996-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-02-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "