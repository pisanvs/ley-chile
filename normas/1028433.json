{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 6.228 EXENTA, DE 2011</div></div>", "i": 9163781}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 6.228, de 22 de julio de 2011, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Asesor&#xED;a, Capacitaci&#xF3;n y Desarrollo Humano Limitada (Grandir Limitada)&quot; RUT 76.050.002-K, contenida en la resoluci&#xF3;n exenta N&#xBA; 11.810, de 17 de noviembre de 2010, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del Art. 21 de la ley 19.518.-</div></div>", "i": 9163782}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Miguel Bergu&#xF1;o Ca&#xF1;as, Director Nacional.</div></div>", "i": 9163783}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6228 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6228 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 6.228 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-22", "doble_articulado": false, "id_norma": "1028433", "numero_fuente": "40029", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-08-06", "vigencias": [{"desde": "2011-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-08-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-08-06", "fin_vigencia": "", "tipo_vers