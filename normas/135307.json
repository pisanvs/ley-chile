{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,690.- Santiago, 10 de setiembre de 1904.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6164994}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase a ciento cuarenta pesos ($ 140) al mes la pension de gracia otorgada por la lei de 2 de agosto de 1883 a favor de do&#xF1;a Avelina Ech&#xE1;nez, viuda de Orella, i de sus hijas solteras do&#xF1;a Celmira i do&#xF1;a Celia Orella.</div><br></div>", "i": 6164995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.-</div><div class=\"p\">A. Bascu&#xF1;an S. M.</div><br></div>", "i": 6164996}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1690", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1690"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-09-10", "doble_articulado": false, "id_norma": "135307", "numero_fuente": "8004", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-09-12", "vigencias": [{"desde": "1904-09-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-09-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1904-09-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH"