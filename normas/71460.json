{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 377 EXENTO, DE 1997 </div></div>", "i": 6037074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 377, de fecha 3 de abril de 1997, del Ministerio de Educaci&#xF3;n, se declar&#xF3; aprobada a la Universidad del Mar, la carrera de Acuicultura, conducente al T&#xED;tulo de T&#xE9;cnico de Nivel Superior en Cultivos Acu&#xED;colas, para ser impartida a contar de 1997, en su sede de la ciudad de Valpara&#xED;so, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6037075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de abril de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6037076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "377 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-377 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 377 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD DEL MAR", "PROGRAMAS DE ESTUDIO", "PLANES DE ESTUDIO", "VALPARAISO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-03", "doble_articulado": false, "id_norma": "71460", "numero_fuente": "35769", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-19", "vigencias": [{"desde": "1997-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p