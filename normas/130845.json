{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  EXTRACTO DE DECRETO EXENTO No. 141, DE 1988</div><br></div>", "i": 7244889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por DS exento de Educaci&#xF3;n No. 141 de 12 de agosto de 1988, se ha rectificado en la forma que se indica el DS exento de Educaci&#xF3;n No. 118, de 1988, que modific&#xF3; el DS exento de Educaci&#xF3;n No. 147, de 1984, que aprob&#xF3; planes y programas especiales de estudio para el 3&#xB0; y 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica al Colegio Saint Gabriel&apos;s English School, de Santiago.-</div><br></div>", "i": 7244890}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salame Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7244891}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "141 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-141 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 141, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-12", "doble_articulado": false, "id_norma": "130845", "numero_fuente": "33172", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-14", "vigencias": [{"desde": "1988-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-09-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION"