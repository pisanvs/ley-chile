{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,810, que declara feriado el dia 12 de Octubre</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8779616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO._ Decl&#xE1;rase feriado el dia 12 de Octubre, aniversario del Descubrimiento de Am&#xE9;rica. </div></div>", "i": 8779617, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 14 de Noviembre de 1921.- ARTURO ALESSANDRI.- Ismael Tocornal.</div><br></div>", "i": 8779618}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3810", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3810"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,810, QUE DECLARA FERIADO EL DIA 12 DE OCTUBRE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMERICA", "DESCUBRIMIENTO", "FERIADO LEGAL", "ANIVERSARIO", "DECLARACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-11-14", "doble_articulado": false, "id_norma": "24262", "numero_fuente": "13133", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-11-24", "vigencias": [{"desde": "1921-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1921-11-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1921-11-24", "fin_vigencia": "", "tipo_version": "3"}]