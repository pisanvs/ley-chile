{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 7 EXENTA, DE 2014</div></div>", "i": 9536615}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.255, de 28 de noviembre de 2014, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 7.- de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1058134&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 7, de 2014</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; la distribuci&#xF3;n para el recurso Merluza del sur en la X Regi&#xF3;n de Los Lagos, en el sentido de modificar la expresi&#xF3;n &quot;28 de Noviembre&quot; por la frase &quot;5 de Diciembre&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n extractada se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9536616}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de noviembre de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9536617}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3255 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3255 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 7 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-11-28", "doble_articulado": false, "id_norma": "1071451", "numero_fuente": "41025", "tipo_version": "3", "tipo_version_s": "