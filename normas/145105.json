{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6196438}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta No. 170 de 24 de febrero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Julio Wolff Dose para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 50 &quot;San Luis - Regional - Centro&quot; de Valdivia, cuyo trazado fue autorizado por resoluci&#xF3;n exenta No. 12 de 04 de enero de 1985 y modificado por resoluci&#xF3;n exenta No. 474 de 30 de octubre de 1985, de esta Secretar&#xED;a Regional. </div></div>", "i": 6196439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 6196440}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "170 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-170 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-24", "doble_articulado": false, "id_norma": "145105", "numero_fuente": "32712", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-03-03", "vigencias": [{"desde": "1987-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-03-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-03-03", "f