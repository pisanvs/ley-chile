{"html": [{"t": "<div><br><div class=\"p\">DEJA SIN EFECTO RESOLUCI&#xD3;N EXPROPIATORIA</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9722536}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 3.808, de fecha 3 de agosto de 2016, de la Direcci&#xF3;n del Serviu Metropolitano, se deja sin efecto <a href=\"https://www.leychile.cl/Navegar?idNorma=1085238&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 7.166, de fecha 7 de diciembre de 2015</a>, de la Direcci&#xF3;n del Serviu Metropolitano, que dispuso la expropiaci&#xF3;n del inmueble ubicado en Av. Independencia 1050, Rol 1537-89, de la comuna de Independencia, individualizado en el Plano de Expropiaci&#xF3;n como Lote N&#xB0; 46, de aparente dominio de Inmobiliaria Alto Hip&#xF3;dromo S.A., por no resultar indispensable para la materializaci&#xF3;n del Proyecto &quot;Habilitaci&#xF3;n Corredor de Transporte P&#xFA;blico Independencia&quot;.- </div><br></div>", "i": 9722537, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div></div>", "i": 9722538}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3808 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3808 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN METROPOLITANA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIÓN EXPROPIATORIA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1051126", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-08-03", "doble_articulado": false, "id_norma": "1093628", "numero_fuente": "415