{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 2.364 DE 2014, QUE FIJ&#xD3; N&#xD3;MINA DE ESPECIES HIDROBIOL&#xD3;GICAS VIVAS DE IMPORTACI&#xD3;N AUTORIZADA</div><br></div>", "i": 9592045}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.084, de 22 de abril de 2015, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1066842&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.364 de 2014</a>, en el sentido de eliminar las especies ornamentales pertenecientes al grupo de anfibios y reptiles, se&#xF1;aladas en la resoluci&#xF3;n extractada, y publicada &#xED;ntegramente en las p&#xE1;ginas web www.subpesca.cl y www.sernapesca.cl.</div><br></div>", "i": 9592046}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9592047}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1084 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1084 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 2.364 DE 2014, QUE FIJÓ NÓMINA DE ESPECIES HIDROBIOLÓGICAS VIVAS DE IMPORTACIÓN AUTORIZADA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 899241", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-04-22", "doble_articulado": false, "id_norma": "1076676", "numero_fuente": "41144", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-04-29", "vigencias": [{"desde": "2015-04-29", "hasta": "", "tipo_version": "3", "t