{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6164708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 61 del 01 de Marzo de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Primera Regi&#xF3;n Tarapac&#xE1;, se autoriza a Berta Mutis Vega para efectuar todo tipo de servicio de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6164709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6164710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-61 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-01", "doble_articulado": false, "id_norma": "135207", "numero_fuente": "33020", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-14", "vigencias": [{"desde": "1988-03-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-03-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones