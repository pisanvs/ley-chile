{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6389398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.355 de 2 de julio de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EL GOLFO S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 774 de 1999 y N&#xBA; 137 de 2001, ambas de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Lote 8, Sector de la Usina y Muelle Franc&#xE9;s, Corral, X Regi&#xF3;n, en las l&#xED;neas de proceso que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Harina y Aceite: Bacaladillo o mote, Jurel fino, Machuelo o tritre, Anchoveta blanca, Sardina redonda, Vinciguerria.</div><br></div>", "i": 6389399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de julio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6389400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1355", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1355"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-07-02", "doble_articulado": false, "id_norma": "200603", "numero_fuente": "37312", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-19", "vigencias": [{"desde": "2002-07-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-19", "fin_vigencia": "", "tipo_v