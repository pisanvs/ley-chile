{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  MODIFICA CONCESION DE RADIODIFUSION SONORA</div><div class=\"p\">&nbsp;  Santiago, 09 de Junio de 1994.- Con esta fecha se ha decretado lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 187.- Vistos:</div><div class=\"p\"> _______________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 34.941 DE 16 DE AGOSTO&nbsp; |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  DE 1994, PAGINAS 6 y 7.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  |</div><div class=\"p\"> |_____________________________________________________|</div><br></div>", "i": 7140606}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese, notif&#xED;quese al interesado y publ&#xED;quese en el Diario Oficial.- Por orden del Presidente de la Rep&#xFA;blica, Narciso Irureta Aburto, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda atentamente a Ud., Jorge Rosenblut Ratinoff, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 7140607}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "187", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-187"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "MODIFICA CONCESION DE RADIODIFUSION SONORA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION RADIO DIFUSION SONORA", "FRECUENCIA MODULADA", "QUILLOTA", "QUINTA REGION", "LUIS ALBERTO CAVIERES SANHUEZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-06-09", "doble_articulado": false, "id_norma": "10668", "nume