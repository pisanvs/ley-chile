{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REASUME MANDO DEL ESTADO Santiago, 16 de Marzo de 1990.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 265.- Visto: Lo dispuesto en los art&#xED;culos 29 y 32 N&#xB0; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica, Decreto:</div><br></div>", "i": 8261000}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: D&#xE9;jase constancia que a contar de esta fecha, S.E. el Presidente de la Rep&#xFA;blica, don Patricio Aylwin Az&#xF3;car, ha reasumido el mando del Estado, con motivo de su retorno al pa&#xED;s.</div><br></div>", "i": 8261001}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Enrique Krauss Rusque, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8261002}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "265", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-265"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE DE LA REPUBLICA", "PATRICIO AYLWIN AZOCAR", "MANDO DE LA NACION", "REASUME."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-16", "doble_articulado": false, "id_norma": "11711", "numero_fuente": "33634", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-30", "vigencias": [{"desde": "1990-03-30", "hasta": "", "tipo_version": "3", "tipo_versi