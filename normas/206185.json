{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6408026}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.832, de 11 de diciembre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a ALIMENTOS MARINOS S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Ogri&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2393</div><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CB-2943</div><div class=\"p\">Eslora arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  28,14 m</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  6,87 m</div><div class=\"p\">TRG (Internacional)&nbsp; &nbsp; &nbsp; &nbsp;  208,18</div><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; &nbsp;  250,00 m3</div><div class=\"p\">Potencia motor principal&nbsp; &nbsp; 580,00 HP</div><div class=\"p\">Potencia motor auxiliar&nbsp; &nbsp;  93,50 HP</div><br></div>", "i": 6408027}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6408028}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2832", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2832"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-11", "doble_articulado": false, "id_norma": "