{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6257631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xB0; 454, de 19 de Diciembre de 1984, se expropi&#xF3; el lote de terreno N&#xB0; 3, para agua potable de Galvarino, que figura a nombre de don Alfredo Kehr F., rol de aval&#xFA;o 70-20, superficie 6.860,75 m2 , comuna de Galvarino, IX Regi&#xF3;n. La Comisi&#xF3;n de Peritos compuesta por los se&#xF1;ores Roberto Gesche Robert, Mario Guti&#xE9;rrez Truan y Mario Molina Ramwell, fij&#xF3; con fecha 31 de Marzo de 1983, el valor provisional de la indemnizaci&#xF3;n en la cantidad de $ 54.886, la indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplmiento a lo dispuesto en el art&#xED;culo 7&#xB0; del decreto ley N&#xB0; 2.186, de 1978.- </div></div>", "i": 6257632}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6257633}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "454", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-454"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-19", "doble_articulado": false, "id_norma": "163183", "numero_fuente": "32086", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-01", "vigencias": [{"desde": "1985-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-01", "fin_vigencia": "", "tipo_vers