{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6237966}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n</div><div class=\"p\">Exenta N&#xB0; 1.689 de 18 de Diciembre de 1985, conforme</div><div class=\"p\">Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a Sector Reserva y Sector Expropiado Predio &quot;El Colorado&quot; de la comuna de R&#xED;o Claro, VII Regi&#xF3;n; y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s. 1 y 2 del proyecto de parcelaci&#xF3;n &quot;El Colorado&quot; formado por predio se&#xF1;alado. Los derechos de agua se extraen del canal San Luis o Bascu&#xF1;&#xE1;n. Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377. </div></div>", "i": 6237967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6237968}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1689 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1689 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHO DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-18", "doble_articulado": false, "id_norma": "157254", "numero_fuente": "32372", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-15", "vigencias": [{"desde": "1986-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-01-15", "fin_vigencia": ""}, "vig