{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 411 EXENTO, DE 1995 </div></div>", "i": 5944382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 411 de fecha 13 de julio de 1995 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Administraci&#xF3;n, las adecuaciones introducidas al plan y programas de estudio de la carrera Administraci&#xF3;n de Empresas, las que se insertaron en la Resoluci&#xF3;n Exenta del Ministerio de Educaci&#xF3;n N&#xB0; 1970 de 1987. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1995.</div><br></div>", "i": 5944383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de Agosto de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944384}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "411", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-411"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 411 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "CENTRO FORMACION TECNICA ESCUELA ADMINISTRACION", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-07-13", "doble_articulado": false, "id_norma": "21178", "numero_fuente": "35247", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-08-19", "vigencias": [{"desde": "1995-08-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-08-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-08-19", "fin_vigencia": "", "tipo_version": "3"}], "even