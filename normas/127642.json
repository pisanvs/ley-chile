{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.904</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.904, celebrada el 28 de diciembre de 1988, adopt&#xF3; los siguientes acuerdos: </div></div>", "i": 6140798}, {"t": "<div><div class=\"p\">1904-12-881228 - Modifica Cap&#xED;tulo XV del Compendio de Normas de Importaci&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar en el inciso segundo del N&#xBA; 4 del Cap&#xED;tulo XV &quot;Cobertura para Operaciones de Importaci&#xF3;n&quot; del Compendio de Normas de Importaci&#xF3;n, la cifra &quot;US$ 5.000.-&quot; por &quot;US$ 20.000.-&quot;.</div><br></div>", "i": 6140799}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de diciembre de 1988.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6140800}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1904", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1904"}, {"tipo": "5", "numero": "1904-12", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1904-12"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.904", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-28", "doble_articulado": false, "id_norma": "127642", "numero_fuente": "33259", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-12-30", "vigencias": [{"desde": "1988-12-30", "hasta": "", "tipo_version": "3", "tip