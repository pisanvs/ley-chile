{"html": [{"t": "<div><br><div class=\"p\">DISPOSICIONES DE SEGURIDAD EN ACTIVIDADES DE BUCEO PROFESIONAL</div><div class=\"p\"> </div></div>", "i": 9760316}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n D.G.T.M. y M.M. Ord. N&#xBA; 8.330/11 Vrs., de fecha 15 de diciembre de 2016, que &quot;Establece disposiciones especiales de seguridad en las actividades de buceo profesional, relacionado con las condiciones de viento, ola y corriente&quot;.</div><br><div class=\"p\">&nbsp; &nbsp;  Los textos &#xED;ntegros de estas resoluciones y circular, est&#xE1;n publicados en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><div class=\"p\"> </div></div>", "i": 9760317}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de diciembre de 2016.- Osvaldo Schwarzenberg Ashton, Vicealmirante, Director General.- Rodrigo Ram&#xED;rez Daneri, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.</div></div>", "i": 9760318}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-11"}, {"tipo": "3", "numero": "8330/11", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8330/11"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "DISPOSICIONES DE SEGURIDAD EN ACTIVIDADES DE BUCEO PROFESIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1164353; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-12-15", "doble_articulado": false, "id_nor