{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.246 EXENTO, DE 2002 </div><br></div>", "i": 6411410}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.244 de fecha 11 de diciembre de 2002, de Educaci&#xF3;n, se declara aprobada a la Universidad Iberoamericana de Ciencias y Tecnolog&#xED;a la modificaci&#xF3;n al Plan y a los Programas de estudio de la carrera de Ingenier&#xED;a Forestal.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera se imparte en jornada diurna en su sede de la ciudad de Santiago.</div><br><div class=\"p\">&nbsp; &nbsp;  Las modificaciones se har&#xE1;n efectivas a contar del primer semestre del a&#xF1;o 2003.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xE9;ngase presente para todos los efectos legales y administrativos.</div><br></div>", "i": 6411411}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de diciembre de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6411412}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1246 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1246 EXENTO"}, {"tipo": "2", "numero": "1244 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1244 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.246 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-11", "doble_articulado": false, "id_norma": "207048", "numero_fuente": "37468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-25", "vigencias": [{"desde": "2003-01-25", "hasta": "", "tipo_ve