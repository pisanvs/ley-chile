{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6519648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 650 exenta, de 8 de marzo de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a BRACPESCA S.A. para ampliar actividades pesqueras extractivas con la nave en construcci&#xF3;n autorizada por las resoluciones N&#xBA; 3.013 de 2003 y N&#xBA; 2.504 de 2004, ambas de esta Subsecretar&#xED;a, en orden a realizar actividades pesqueras con la nave antes individualizada, en el &#xE1;rea mar&#xED;tima comprendida entre la I y XII Regiones, con potera por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar el recurso hidrobiol&#xF3;gico Jibia.</div><br></div>", "i": 6519649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 08 de marzo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6519650}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "650 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-650 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-03-08", "fecha_derogacion": "2014-10-14", "doble_articulado": false, "id_norma": "236458", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-03-19", "vigencias": [{"desde": "2014-10-14", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-03-19", "hasta": "2014-10-13", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-10-14", "fin_vigencia": ""}, "vige