{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6191029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0;13, de 15 de enero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a Jorge Cort&#xE9;s Olmedo, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6191030}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 6191031}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-13 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-15", "doble_articulado": false, "id_norma": "143341", "numero_fuente": "32681", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-26", "vigencias": [{"desde": "1987-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-01-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin