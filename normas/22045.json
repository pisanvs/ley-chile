{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; AMNISTIA Lei n&#xFA;m. 186-Santiago, a 8 de Agosto de 1894.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273827}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Quedan amnistiadas todas las personas responsables de hechos de car&#xE1;cter pol&#xED;tico o consecuenciales del estado pol&#xED;tico, acaecidos hasta el 28 de Agosto de 1891, i todos los paisanos responsables de actos contra la seguridad interior del Estado, ejecutados desde el 29 de Agosto del mismo a&#xF1;o.</div><br><br></div>", "i": 8273828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORGE MONTT.-Enrique Mac-Iver.</div><br></div>", "i": 8273829}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "186", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-186"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AMNISTIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SEGURIDAD INTERIOR ESTADO", "ESTADO POLITICO", "ACTOS", "POLITICOS", "AMNISTIA", "INVOLUCRADOS", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-08", "doble_articulado": false, "id_norma": "22045", "numero_fuente": "4836", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-08-08", "vigencias": [{"desde": "1894-08-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-08-08", "fin_vigencia": ""}, "vigencias_vers