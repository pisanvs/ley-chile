{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 14.117 EXENTA, DE 2002 </div><br></div>", "i": 6407936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;14.117 de 27 de noviembre del a&#xF1;o 2002, se ha aprobado al Colegio del Sagrado Coraz&#xF3;n, comuna de Las Condes, de Santiago, un plan de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2003.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para el Subsector de Ciencias Religiosas de 1&#xBA; a 4&#xBA; a&#xF1;o medio. </div></div>", "i": 6407937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de diciembre de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6407938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14117 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14117 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 14.117 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-27", "doble_articulado": false, "id_norma": "206170", "numero_fuente": "37443", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-26", "vigencias": [{"desde": "2002-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "