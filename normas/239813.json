{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6531873}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.765, de 8 de junio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD FERRANDO Y SUAREZ LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Huitauque s/n, Chonchi, Chilo&#xE9;, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco enfriado, Fresco refrigerado, Congelado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6531874}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de junio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6531875}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1765 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1765 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-06-08", "fecha_derogacion": "2006-10-14", "doble_articulado": false, "id_norma": "239813", "numero_fuente": "38200", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-07-02", "vigencias": [{"desde": "2006-10-14", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-07-02", "hasta": "2006-10-13", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2006-10-14", "fin_vigencia": ""}, "vigencias_version_norma