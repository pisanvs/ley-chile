{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6152268}, {"t": "<div><div class=\"p\">Por decreto MOP N&#xBA; 2.474, de 30 de noviembre de 1998, se expropiaron los lotes de terreno N&#xBA;s. 7 y 19, superficies 190 y 200 m2., respectivamente, roles de aval&#xFA;o 12-2 y 13-24, comuna de Navidad, para la obra Camino Ruta G-880, Sector Rapel-Navidad-La Boca y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Agustina Navia Riveros y otros y Gerardo Rojas Ram&#xED;rez, ascendentes a las cantidades de $ 528.395.- para el lote 7 y $ 531.650.- para el lote 19.</div><br></div>", "i": 6152269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal de Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6152270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2474", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2474"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-30", "doble_articulado": false, "id_norma": "131159", "numero_fuente": "36278", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-02-01", "vigencias": [{"desde": "1999-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-02-03", "fecha_version": "1999-02-01", "fecha_actualizacion_texto": "1999-02-01", "tipo_tratado": ""}, "alertas": [