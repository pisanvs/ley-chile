{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291866}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 335, de 19 de febrero de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase, por 90 d&#xED;as, a contar del 10 de febrero de 1996, el plazo otorgado a MARCELO RENE ELUCHANS OLIVARES, para publicar el extracto de la Resoluci&#xF3;n N&#xB0; 1.584, de 1995, de esta Subsecretar&#xED;a, que le otorg&#xF3; una autorizaci&#xF3;n de acuicultura para un Sector ubicado en Fundo Los Chilcos, Comuna de La Uni&#xF3;n, Provincia de Valdivia, X Regi&#xF3;n, por haberse acreditado la existencia de una causal de fuerza mayor.</div><br></div>", "i": 8291867, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 19 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "335", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-335"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION ACUICULTURA", "MARCELO RENE ELUCHANS", "OLIVARES", "AMPLIACION", "PLAZO", "LA UNION", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-19", "doble_articulado": false, "id_norma": "34361", "numero_fuente": "35402", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-26", "vigencias": [{"desde": "1996-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-2