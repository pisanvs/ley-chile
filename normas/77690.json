{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8308098}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 766 de 10 de Agosto de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto las Resoluciones No. 35, de 1990 y No. 358, de 1991, ambas de esta Subsecretar&#xED;a, que autorizaron a don JOSE RICARDO PEREZ CARCAMO, RUT No.</div><div class=\"p\">4.782.739-6, domiciliado en Carampagne No. 642, Valdivia, para operar un establecimiento de cultivo del recurso alga del g&#xE9;nero Gracilaria, en Sector Ensenada de San Juan, Comuna de Corral, Provincia de Valdivia, X Regi&#xF3;n, por renuncia total de su titular ya individualizado. </div></div>", "i": 8308099}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 10 de Agosto de 1992. Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8308100}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "766", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-766"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-08-10", "doble_articulado": false, "id_norma": "77690", "numero_fuente": "34348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-22", "vigencias": [{"desde": "1992-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-08-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_