{"html": [{"t": "<div><br><br><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;137, DE 1992 </div></div>", "i": 6050084}, {"t": "<div><br><div class=\"p\">Por decreto exento N&#xBA;137 de fecha 22 de Mayo de 1992 del Ministerio de Educaci&#xF3;n, se derog&#xF3; el decreto exento de Educaci&#xF3;n N&#xBA;101 de fecha 07 de Marzo de 1990, que autoriz&#xF3; el funcionamiento al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Formaci&#xF3;n y Capacitaci&#xF3;n Tecnol&#xF3;gica -INFOCAT de Antofagasta. organizado por la Sociedad lnstituto de Formaci&#xF3;n y Capacitaci&#xF3;n Tecnol&#xF3;gica Compa&#xF1;&#xED;a Limitada y se elimin&#xF3; del Libro de Registros de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xBA;206, correspondiente a la instituci&#xF3;n antes se&#xF1;alada.</div><br></div>", "i": 6050085}, {"t": "<div><br><div class=\"p\">Santiago, 04 de Septiembre de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6050086}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "137 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-137 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº137, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-05-22", "doble_articulado": false, "id_norma": "77193", "numero_fuente": "34374", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-09-25", "vigencias": [{"desde": "1992-09-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-09-25", "fin_vigencia": ""}, "vigencias_versio