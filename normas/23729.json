{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aprueba el Presupuesto de entradas i gastos del Ferrocarril del Puente Alto al Volcan</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,089.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5954960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Apru&#xE9;base el adjunto Presupuesto de entradas i gastos del Ferrocarril de Puente Alto al Volcan, calculado para el a&#xF1;o de 1916.</div><br></div>", "i": 5954961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 5 de Abril de 1916.- JUAN LUIS SANFUENTES.- Cornelio Saavedra.</div><br></div>", "i": 5954962}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3089", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3089"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "APRUEBA EL PRESUPUESTO DE ENTRADAS I GASTOS DEL FERROCARRIL DEL PUENTE ALTO AL VOLCAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FERROCARRIL", "PUENTE ALTO", "VOLCAN", "PRESUPUESTO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1916-04-05", "doble_articulado": false, "id_norma": "23729", "numero_fuente": "11555", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1916-08-23", "vigencias": [{"desde": "1916-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1916-08-23", "fin_vigencia": ""}, "vigencias_v