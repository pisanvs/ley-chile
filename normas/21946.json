{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Jubilacion Lei n&#xFA;m. 75.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a don C&#xE1;rlos Downes derecho para jubilarse, con arreglo a la lei jeneral de 20 de Agosto de 1857 i con relacion al sueldo de que hubiere disfrutado como caminero mayor en los Ferrocarriles del Estado..</div><br><br></div>", "i": 5946689}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- Santiago, a 8 de Agosto de 1893.- JORJE MONTT.- Vicente D&#xE1;vila Larrain.</div><br></div>", "i": 5946690}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "75", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-75"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "JUBILACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARLOS DOWNES", "JUBILACION", "FERROCARRILES ESTADO", "DERECHO POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-08", "doble_articulado": false, "id_norma": "21946", "numero_fuente": "4590", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-08", "vigencias": [{"desde": "1893-08-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-08", "fin_vig