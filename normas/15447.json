{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SEPARACION DE CARGOS EN PUTAENDO Santiago, 7 de Julio de 1993.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 759.- Vistos: Estos antecedentes, lo establecido en el art&#xED;culo 32 N&#xB0; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica y lo dispuesto en el art&#xED;culo 470 inciso 2&#xB0; del C&#xF3;digo Org&#xE1;nico de Tribunales, Decreto:</div><br></div>", "i": 5921922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Sep&#xE1;ranse los cargos de Secretario Judicial y de Notario Conservador de la comuna de Putaendo, actualmente servidos por una misma persona.</div><br></div>", "i": 5921923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- Por orden del Presidente de la Rep&#xFA;blica, Francisco Cumplido Cereceda, Ministro de Justicia.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Le saluda atentamente.- Marcos S&#xE1;nchez Edwards, Subsecretario de Justicia.</div><br></div>", "i": 5921924}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "759", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-759"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "SEPARACION DE CARGOS EN PUTAENDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARGOS JUDICIALES", "SECRETARIO JUDICIAL", "NOTARIO", "CONSERVADOR", "PUTAENDO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-07", "doble_articulado": false, "id_norma": "15447", "numero_fuente": "34636", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-08-09", "vigencias": [{"desde": "1993-08-09", "ha