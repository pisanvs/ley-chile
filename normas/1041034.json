{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9267065}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA;955 de 31 de mayo de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;48, superficie 1.699 m2, rol de Aval&#xFA;o N&#xBA;246-74, comuna de Pur&#xE9;n, para la obra &quot;MEJORAMIENTO RUTA R-42, SECTOR PUR&#xC9;N-LUMACO, KM. 1,80000 AL KM. 9,32000&quot;. La Comisi&#xF3;n de peritos, integrada por ENEDINA DEL CARMEN CID RAMI&#xC9;REZ, PAULA ANDREA LAGOS CARRASCO Y PATRICIO FERNANDO CASAGRANDE ULLOA, fij&#xF3; el valor de tasaci&#xF3;n con fecha 16 de mayo de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietaria JACINTA DEL CARMEN MELIN PAILLAL, en la cantidad de $3.450.269.-, suma que se pagar&#xE1; al contado.</div></div>", "i": 9267066}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9267067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "955 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-955 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-31", "doble_articulado": false, "id_norma": "1041034", "numero_fuente": "40288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-15", "vigencias": [{"desde": "2012-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici