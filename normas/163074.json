{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.666</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.666, celebrada el 19 de Julio de 1985, adopt&#xF3; el siguiente acuerdo: </div></div>", "i": 6257323}, {"t": "<div><div class=\"p\">1666-02-850719 - Modifica Acuerdo No. 1657-12-850627.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el Acuerdo No. 1657-12-850627, reemplazando en el n&#xFA;mero l, la frase &quot;dentro de un plazo no superior a 15 d&#xED;as h&#xE1;biles bancarios contados desde el 3 de Julio de 1985&quot; por &quot;hasta el 14 de Agosto de 1985&quot;.</div><br></div>", "i": 6257324}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de Julio de 1985.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6257325}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1666", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1666"}, {"tipo": "5", "numero": "1666-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1666-02"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.666", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-19", "doble_articulado": false, "id_norma": "163074", "numero_fuente": "32229", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-23", "vigencias": [{"desde": "1985-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s"