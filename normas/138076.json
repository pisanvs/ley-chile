{"html": [{"t": "<div><div class=\"p\">LEY NUM. 16.660</div><br><div class=\"p\">DENOMINA PARQUE FORESTAL RUBEN DARIO AL PARQUE FORESTAL DE SANTIAGO</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">Proyecto de ley:</div><br></div>", "i": 8345821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Denom&#xED;nase Parque Forestal Rub&#xE9;n Dar&#xED;o, en toda su extensi&#xF3;n, al actual Parque Forestal de Santiago.&quot; </div></div>", "i": 8345822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a dieciocho de Agosto de mil novecientos sesenta y siete.- EDUARDO FREI MONTALVA.- Bernardo Leighton G.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a U. para su conocimiento.- Dios gue. a U.- Enrique Krauss Rusque, Subsecretario del Interior. </div></div>", "i": 8345823}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16660", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16660"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DENOMINA PARQUE FORESTAL RUBEN DARIO AL PARQUE FORESTAL DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1967-08-18", "doble_articulado": false, "id_norma": "138076", "numero_fuente": "26834", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1967-09-02", "vigencias": [{"desde": "1967-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"