{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,997</div><br><div class=\"p\">RECONOCE EL TIEMPO QUE INDICA EN LA HOJA DE SERVICIOS DE DON JOSE M. GODOY S.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7337940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Recon&#xF3;cense para todos los efectos legales y ab&#xF3;nanse en su hoja de servicios, a don Jos&#xE9; Manuel Godoy Soto, 13 a&#xF1;os, 9 meses y 6 d&#xED;as. </div></div>", "i": 7337941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a treinta de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 7337942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10997", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10997"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "RECONOCE EL TIEMPO QUE INDICA EN LA HOJA DE SERVICIOS DE\nDON JOSE M. GODOY S.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-30", "doble_articulado": false, "id_norma": "258985", "numero_fuente": "22411", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-28", "vigencias": [{"desde": "1952-11-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-11-28", "fin_vigencia": ""}, "vigencias_version_norm