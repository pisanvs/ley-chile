{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9502921}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.274, de 29 de agosto de 2014, de esta Subsecretar&#xED;a, establece que los centros de cultivo integrantes de la agrupaci&#xF3;n de concesiones 28 C deber&#xE1;n someterse a la densidad de cultivo establecida por <a href=\"https://www.leychile.cl/Navegar?idNorma=1006063&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.449,de 2009, del Servicio Nacional de Pesca y Acuicultura</a>, o la resoluci&#xF3;n que la reemplace, en virtud del art&#xED;culo 5&#xBA; transitorio del D.S. N&#xBA; 4, de 2013, de este Ministerio.</div></div>", "i": 9502922}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de agosto de 2014.- Paolo Trejo Carmona, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9502923}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2274 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2274 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-08-29", "doble_articulado": false, "id_norma": "1066217", "numero_fuente": "40950", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-09-04", "vigencias": [{"desde": "2014-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-09-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-09-04", "fin_vigencia": "", "tipo_version": "3