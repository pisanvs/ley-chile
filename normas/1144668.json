{"html": [{"t": "<div><div class=\"p\">APRUEBA INSTRUCCIONES PARA DIFERIR EL IMPUESTO AL VALOR AGREGADO CAUSADO POR LAS IMPORTACIONES</div></div>", "i": 10116770}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.559, de 17 de abril de 2020, del Director Nacional de Aduanas, se aprueban instrucciones para diferir el IVA a las importaciones, cuya declaraci&#xF3;n de importaci&#xF3;n se efect&#xFA;e durante los meses de abril, mayo y junio del a&#xF1;o en curso, a contar de la fecha de entrada en vigencia de esta resoluci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servido Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10116771}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de abril de 2020.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10116772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1559 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1559 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "APRUEBA INSTRUCCIONES PARA DIFERIR EL IMPUESTO AL VALOR AGREGADO CAUSADO POR LAS IMPORTACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1755243", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-04-17", "doble_articulado": false, "id_norma": "1144668", "numero_fuente": "42642", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-04-28", "vigencias": [{"desde": "2020-04-28", "hasta": "", "tipo_v