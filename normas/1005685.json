{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8776323}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto (Exento) MOP N&#xBA;1142 de fecha 31 de julio del 2009, se expropi&#xF3; el lote de terreno N&#xBA;120-A, superficie 108 m2, Rol N&#xBA;3350-63, comuna de Puerto Montt, X Regi&#xF3;n para la obra &quot;Mejoramiento Ruta 7, sector Quillaipe - La Arena, tramo Km. 15,84700 a Km. 40,41746, Provincia de Llanquihue, X Regi&#xF3;n&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario MIGUEL SEGUNDO VIVAR VALDERAS, ascendente a la cantidad de $573.584.- para el lote N&#xBA;120-A. </div></div>", "i": 8776324}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8776325}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1142 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1142 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-07-31", "doble_articulado": false, "id_norma": "1005685", "numero_fuente": "39451", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-09-01", "vigencias": [{"desde": "2009-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2009-09-03", "fecha_version": "2009-09-01", "actualizado_por": "