{"html": [{"t": "<div><div class=\"p\">ESTABLECE ZONIFICACIONES QUE INDICA</div></div>", "i": 10148793}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.431, de 22 de julio de 2020, el Servicio Nacional de Pesca y Acuicultura, estableci&#xF3; zonificaciones que indica conforme PSEVC de ISA en relaci&#xF3;n al centro de cultivo Navarro 3 C&#xF3;digo n&#xFA;mero 120215, perteneciente a la ACS n&#xFA;mero 50 B de titularidad de Trusal S.A. y operada por Nova Austral S.A.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina de dominio electr&#xF3;nico del Servicio y de la Subsecretar&#xED;a de Pesca y Acuicultura.</div><br></div>", "i": 10148794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En Valpara&#xED;so, a 22 de julio de 2020.- Alicia Gallardo Lagno, Directora Nacional del Servicio Nacional de Pesca y Acuicultura. </div><br></div>", "i": 10148795}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1431", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1431"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE ZONIFICACIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1796721", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-07-22", "doble_articulado": false, "id_norma": "1148203", "numero_fuente": "42728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-08-11", "vigencias": [{"desde": "2020-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}],