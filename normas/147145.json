{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8353028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.199, de 22 de octubre de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a ASOCIACION GREMIAL DE TRABAJADORES DEL MAR INDEPENDIENTES DE CALETA PUNTA DE CHOROS, IV Regi&#xF3;n, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en Los Corrales s/n&#xBA;, Caleta Punta Choros, comuna de La Higuera, IV Regi&#xF3;n, donde podr&#xE1; procesar en la l&#xED;nea de elaboraci&#xF3;n que se indica los siguientes recursos hidrobiol&#xF3;gicos: Fresco-Enfriado: Almeja o taca, Lapa y Loco.</div><br></div>", "i": 8353029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8353030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2199", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2199"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-22", "doble_articulado": false, "id_norma": "147145", "numero_fuente": "36509", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-09", "vigencias": [{"desde": "1999-11-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-11-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacio