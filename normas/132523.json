{"html": [{"t": "<div><div class=\"p\">NOTIFICA SOBRE DECRETO ALCALDICIO No. 185, DE 1988 </div></div>", "i": 6156491}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La I. Municipalidad de San Joaqu&#xED;n, informa que por Decreto Alcaldicio No. 185 de fecha 31 de Mayo de 1988, se ha dictado la Ordenanza Local sobre funcionamiento de Juegos Electr&#xF3;nicos, Sal&#xF3;n de Pool, Billares y Singulares.</div><div class=\"p\">&nbsp; &nbsp;  Los interesados en conocer la mencionada Ordenanza, podr&#xE1;n concurrir al Departamento de Inspecci&#xF3;n, ubicado en Avda. Santa Rosa No. 2606, 1er. piso, lugar donde se exhibir&#xE1; para conocimiento de todos los contribuyentes involucrados.-</div><br></div>", "i": 6156492}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div><br></div>", "i": 6156493}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "185", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-185"}], "organismos": ["MUNICIPALIDAD DE SAN JOAQUÍN"], "titulo_norma": "NOTIFICA SOBRE DECRETO ALCALDICIO No. 185, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-31", "doble_articulado": false, "id_norma": "132523", "numero_fuente": "33092", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-10", "vigencias": [{"desde": "1988-06-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1999-02-26", "fecha_version": "