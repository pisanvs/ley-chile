{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 9375957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 40.666, de 25 de septiembre de 2013, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1054441&amp;idParte=&amp;idVersion=\">decreto exento N&#xBA; 404</a> que &quot;FIJA PRECIOS DE REFERENCIA PARA COMBUSTIBLES DERIVADOS DEL PETR&#xD3;LEO Y DETERMINA EL COMPONENTE VARIABLE PARA EL C&#xC1;LCULO DE LOS IMPUESTOS ESPEC&#xCD;FICOS ESTABLECIDOS EN LA LEY N&#xBA; 18.502&quot;,&nbsp; con el error que se salva a continuaci&#xF3;n: Cuerpo I, p&#xE1;gina 12, donde dice &quot;... N&#xFA;m. 401 exento.- Santiago, ...&quot; debe decir &quot;... N&#xFA;m. 404 exento.- Santiago, ...&quot;.</div><br></div>", "i": 9375958, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "272", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-272"}], "organismos": ["MINISTERIO DE ENERGÍA"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1054628", "numero_fuente": "40671", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-10-01", "vigencias": [{"desde": "2013-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por"