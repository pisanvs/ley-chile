{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOLICITA CONSTITUCION DEL &quot;PARTIDO SOCIAL DEMOCRACIA CHILENA&quot;, EN LA VII REGION </div></div>", "i": 6001655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Roberto Mu&#xF1;oz Barra y Jorge Ib&#xE1;&#xF1;ez Vergara, en representaci&#xF3;n del Partido Social Democracia Chilena, han solicitado la constituci&#xF3;n legal del Partido en la VII Regi&#xF3;n del Maule, acompa&#xF1;ando 2.884 fichas de afiliaciones.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n N&#xB0; O-847 de fecha 17 de marzo de 1992.</div><br><br></div>", "i": 6001656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 17 de marzo de 1992.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 6001657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "847", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-847"}, {"tipo": "3", "numero": "O-847", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-847"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCION DEL PARTIDO SOCIAL DEMOCRACIA;CHILENA, EN LA VII REGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONSTITUCION LEGAL", "PARTIDO SOCIAL DEMOCRACIA", "CHILENA", "VII REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-17", "doble_articulado": false, "id_norma": "31689", "numero_fuente": "34226", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-03-24", "vigencias": [{"desde": "1992-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}