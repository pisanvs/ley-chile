{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6191146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 755 de 09 de Diciembre de 1986. de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a don Jos&#xE9; Faustino Gonz&#xE1;lez Mu&#xF1;oz para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva ele pasajeros.</div><br></div>", "i": 6191147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Colorea Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6191148}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "755 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-755 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-09", "doble_articulado": false, "id_norma": "143382", "numero_fuente": "32685", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-30", "vigencias": [{"desde": "1987-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-01-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []