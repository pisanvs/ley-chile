{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 517 EXENTO, DE 1993 </div></div>", "i": 5945016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 517 de 4 de Octubre de 1993 se ha autorizado al Colegio Horizontes de Vitacura, Regi&#xF3;n Metropolitana, para incorporar la asignatura de Sicolog&#xED;a y para aumentar la carga horaria de la asignatura de Ciencias Naturales en una clase, en el plan de estudio de 1&#xB0; y 2&#xB0; a&#xF1;o medio, a partir del a&#xF1;o escolar 1993.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa especial de estudio para la asignatura de Sicolog&#xED;a.</div><br></div>", "i": 5945017}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Octubre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945018}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "517", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-517"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 517 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "SANTIAGO", "COLEGIO HORIZONTES VITACURA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-10-04", "doble_articulado": false, "id_norma": "21397", "numero_fuente": "34707", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-04", "vigencias": [{"desde": "1993-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-11-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc