{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7419449}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 400, de 29 de enero de 2009, de esta Subsecretar&#xED;a, decl&#xE1;rase que con fecha 20 de octubre de 2008 han quedado sin efecto las resoluciones exentas N&#xBA; 1.003 de 1998, N&#xBA; 2.576 de 1999 y N&#xBA; 1.655 de 2001, todas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA PAC&#xCD;FICO SUR S.A. para desarrollar actividades extractivas con la nave &quot;Vi&#xF1;a del Mar&quot;, matr&#xED;cula 1.673, en virtud de lo dispuesto en el art&#xED;culo 9&#xBA; de la ley N&#xBA; 19.713 y en la escritura p&#xFA;blica citada en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 7419450}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de enero de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7419451}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "400", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-400"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-29", "doble_articulado": false, "id_norma": "287010", "numero_fuente": "39282", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-07", "vigencias": [{"desde": "2009-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-02-07", "fin_vigencia": "", "tipo_versi