{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.026, de 11 de agosto de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;guese por el t&#xE9;rmino de 5 meses a contar de la fecha de publicaci&#xF3;n de la presente Resoluci&#xF3;n el plazo otorgado al INSTITUTO DE FOMENTO PESQUERO, R.U.T. N&#xB0; 61.310.000-8, para efectuar una pesca de investigaci&#xF3;n dirigida al recurso Raya (Raja spp.), autorizada mediante Resoluci&#xF3;n N&#xB0; 12, de 1995, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la existencia de fuerza mayor.</div><br></div>", "i": 8295298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 11 de agosto de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295299}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1026", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1026"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO FOMENTO PESQUERO", "PESCA INVESTIGACION", "RAYA", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-08-11", "doble_articulado": false, "id_norma": "36058", "numero_fuente": "35249", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-08-22", "vigencias": [{"desde": "1995-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-08-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-08-22", "fin_vigencia": ""