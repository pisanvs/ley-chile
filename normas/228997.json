{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA N&#xFA;m. 369.- Santiago, 13 de julio de 2004.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xBA; 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; R e s u e l v o:</div><br></div>", "i": 6492052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, VIII Regi&#xF3;n, al siguiente funcionario:</div><br><div class=\"p\">- Claudio Mu&#xF1;oz Acu&#xF1;a&nbsp; &nbsp; &nbsp;  RUT.10.547.097-5.</div><br><br></div>", "i": 6492053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Halab&#xED; Caffena, Director Nacional.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud., Encargado Oficina de Partes.</div><br></div>", "i": 6492054}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "369", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-369"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO DE DESARROLLO AGROPECUARIO", "RECEPTOR JUDICIAL", "DESIGNACION", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-13", "doble_articulado": false, "id_norma": "228997", "numero_fuente": "37936", "tipo_version": "3", "tipo_version_s": "Única", "fe