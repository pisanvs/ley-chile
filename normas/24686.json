{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7168720}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Trasp&#xE1;sase la suma de cincuenta mil pesos ($ 50,000), del &#xED;tem 12/03/02/m/1 al &#xED;tem 12/01/02/m/4 del Ministerio de Bienestar Social. </div></div>", "i": 7168721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticuatro de Julio de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez del Campo.- Luis Carvajal L. </div></div>", "i": 7168722}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4359", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4359"}], "organismos": ["MINISTERIO DE BIENESTAR SOCIAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "A O", "1928", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-07-24", "doble_articulado": false, "id_norma": "24686", "numero_fuente": "15146", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-08-10", "vigencias": [{"desde": "1928-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-08-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-08-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacio