{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 514 EXENTO, DE 2000</div><br><br></div>", "i": 6313892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 514 de 15 de noviembre de 2000, se ha aprobado, a partir del a&#xF1;o escolar 2001, un programa de Religi&#xF3;n de la Iglesia Evang&#xE9;lica Pentecostal, para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o de ense&#xF1;anza b&#xE1;sica y de 1&#xBA; a 4&#xBA; a&#xF1;o de ense&#xF1;anza media, los que podr&#xE1;n aplicarse conforme a la gradualidad establecida en los decretos supremos de Educaci&#xF3;n N&#xBA;s 40 de 1996 y 220 de 1998 con sus modificaciones y seg&#xFA;n lo establecido en el decreto supremo de Educaci&#xF3;n N&#xBA; 924 de 1983.</div><br></div>", "i": 6313893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de diciembre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6313894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "514 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-514 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 514 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-15", "doble_articulado": false, "id_norma": "179473", "numero_fuente": "36846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-12-26", "vigencias": [{"desde": "2000-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20