{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 59 EXENTO, DE 31.01.2019, DEL MINISTERIO DE EDUCACI&#xD3;N</div></div>", "i": 9997581}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por el presente decreto exento se rescilia el convenio de 2 de noviembre de 1981, celebrado entre el Ministerio de Educaci&#xF3;n P&#xFA;blica y la Ilustre Municipalidad de Villarrica, sobre Traspaso del Servicio Educacional y sus Bases, que prestaba la Escuela B&#xE1;sica G-755, de Villarrica, aprobado por <a href=\"https://www.leychile.cl/Navegar?idNorma=256662&amp;idParte=&amp;idVersion=\">decreto supremo N&#xBA; 8.859, de 1981, del Ministerio de Educaci&#xF3;n P&#xFA;blica</a>, que incide en la cl&#xE1;usula sexta del referido convenio, en lo relativo a la propiedad ra&#xED;z, con el objeto de volver el inmueble al dominio del Fisco de Chile.-</div></div>", "i": 9997582}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9997583}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "59 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-59 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 59 EXENTO, DE 31.01.2019, DEL MINISTERIO DE EDUCACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1541262", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-01-31", "doble_articulado": false, "id_norma": "1128561", "numero_fuente": "42273", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-02-06", "vigencias": [{"desde": "2019-02-06", "hasta": "", "tipo_version": "3", "tipo_versi