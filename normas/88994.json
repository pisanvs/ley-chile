{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION EXENTA No. 431, DE 1990</div><br><div class=\"p\">N&#xFA;m. 607 exenta.- Santiago, 12 de Septiembre de 1990.- Vistos: Lo dispuesto por los art&#xED;culos N&#xB0;s. 113 y 118 de la Ley No. 18.290 y por la resoluci&#xF3;n No. 59 de 1985, del Ministerio de Transportes y Telecomunicaciones;</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 6081234}, {"t": "<div><div class=\"p\">1&#xB0;.- Modif&#xED;case la resoluci&#xF3;n exenta No. 431/90, publicada en el Diario Oficial del 07 de julio del presente, en el sentido de sustituir la fecha &quot;01 de Noviembre&quot; por &quot;30 de Noviembre&quot;.</div><br></div>", "i": 6081235}, {"t": "<div><div class=\"p\">An&#xF3;tese y publ&#xED;quese.- H&#xE9;ctor Pe&#xF1;a V&#xE9;liz, Secretario Regional Ministerial Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><div class=\"p\">Lo que transcribo para su conocimiento saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 6081236}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "607 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-607 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA RESOLUCION EXENTA No. 431, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-09-12", "doble_articulado": false, "id_norma": "88994", "numero_fuente": "33773", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-09-20", "vigencias": [{"desde": "1990-09-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni