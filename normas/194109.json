{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DEL REGIMEN DE CAMBIO DE SUJETO DEL IVA A VICTOR HERNAN CARMINE ZU&#xD1;IGA </div></div>", "i": 6367254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n DRE09.00 N&#xBA; Ex 17, de fecha 16 de enero de 2002, excepciona, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n a V&#xED;ctor Hern&#xE1;n Carmine Z&#xFA;&#xF1;iga, RUT N&#xBA; 03.217.579-1, del r&#xE9;gimen de cambio de sujeto del Impuesto al Valor Agregado, en las ventas de trigo, establecido en la resoluci&#xF3;n N&#xBA; Ex 5.281 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del 04/12/2000. El peticionario excepcionado pasa a tener la calidad de retenedor del Impuesto al Valor Agregado en sus operaciones de compra de trigo.-</div><br></div>", "i": 6367255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Cornejo C&#xE1;ceres, Director Regional. </div></div>", "i": 6367256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "17 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-17 EXENTA"}, {"tipo": "3", "numero": "DRE-09-00-17 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-09-00-17 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "EXCEPCIONA DEL REGIMEN DE CAMBIO DE SUJETO DEL IVA A VICTOR HERNAN CARMINE ZUÑIGA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-16", "doble_articulado": false, "id_norma": "194109", "numero_fuente": "37170", "tipo_version": "3", "tipo_version_s": "Única