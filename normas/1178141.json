{"html": [{"t": "<div><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10345983}, {"t": "<div><div class=\"p\"> </div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.953, de 17 de junio de 2022, Serviu Regi&#xF3;n de Valpara&#xED;so, Rectifica la <a href=\"https://www.leychile.cl/Navegar?idNorma=1148982&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 4.058 de fecha 21 de agosto de 2020</a>, que dispuso expropiaci&#xF3;n conforme al art&#xED;culo 51 ley 16.391 y decreto ley 2.186 de 1978, del inmueble signado como lote 25, en el plano &quot;Proyecto de Expropiaciones DRS-P N&#xBA; 12624&quot; L&#xE1;mina 12 de 16, comuna de Conc&#xF3;n, para la Ejecuci&#xF3;n del Proyecto &quot;Mejoramiento Costero Re&#xF1;aca-Conc&#xF3;n Etapa I, Comuna de Conc&#xF3;n&quot;, de Presunto Dominio de Sociedad Constructora N&#xF3;rdica y Hern&#xE1;n Grez Olivares, rectificando el rol aval&#xFA;o fiscal del inmueble objeto de expropiaci&#xF3;n, indicando que el rol de Aval&#xFA;o Fiscal del denominado Lote 25 corresponde efectivamente al 3451-5.-</div></div>", "i": 10345984}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu.</div><div class=\"p\"> </div><br></div>", "i": 10345985}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2953 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-2953 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE VALPARAÍSO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2149331", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-06-17", "doble_articulado":