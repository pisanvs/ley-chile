{"html": [{"t": "<div><br><div class=\"p\">PANTEON</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 13 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto: </div></div>", "i": 10235587}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1&#xB0; Se guardar&#xE1;n exactamente las disposiciones prevenidas en el decreto Supremo de 21 de Julio del a&#xF1;o pasado, inserto con el n&#xFA;m. 113 en el Boletin n&#xFA;m. 13.</div></div>", "i": 10235588}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  2&#xB0; El administrador del Panteon es responsable de la infraccion de cualquiera de dichas disposiciones; y dar&#xE1; cuenta al Gobierno de hallarse actualmente en observancia. Trascr&#xED;basele este decreto, ins&#xE9;rtese en el Boletin. </div><br></div>", "i": 10235589}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ.</div><br><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.</div></div>", "i": 10235590}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["DEPARTAMENTO DE GOBIERNO Y RELACIONES EXTERIORES"], "titulo_norma": "PANTEON", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-03-13", "doble_articulado": false, "id_norma": "1158126", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-03-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-03-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi