{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7270734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 990, de 1 de junio de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 1.319, de 1996, y N&#xBA; 972, de 1998, ambas de esta Subsecretar&#xED;a, en cuanto autorizaron a PESQUERA SAN JOSE S.A., para operar la nave</div><div class=\"p\">&apos;&apos;Conquistador&apos;&apos;, s&#xF3;lo en lo relativo a los recursos Anchoveta y Sardina espa&#xF1;ola, en el litoral de la III y IV Regiones, con el arte de pesca cerco y arrastre de media agua, respectivamente, de conformidad con lo establecido en la letra b) del art&#xED;culo 143 del D.S. N&#xBA; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 7270735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de junio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7270736}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "990", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-990"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-01", "doble_articulado": false, "id_norma": "170335", "numero_fuente": "36683", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-07", "vigencias": [{"desde": "2000-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-07", "fin_vigencia": ""},