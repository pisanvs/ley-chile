{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,964.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a do&#xF1;a Adela de las Mercedes, do&#xF1;a Ana Mar&#xED;a de Jesus i do&#xF1;a Sof&#xED;a del C&#xE1;rmen Benavides Cerda, hijas del teniente coronel de Ej&#xE9;rcito, don Maximiano Benavides, el goce de montep&#xED;o correspondiente al empleo de coronel. </div></div>", "i": 6165968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, once de julio de mil novecientos siete.- Pedro Montt.- Alejandro Lira.</div><br></div>", "i": 6165969}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1964", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1964"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-07-11", "doble_articulado": false, "id_norma": "135603", "numero_fuente": "8847", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-07-12", "vigencias": [{"desde": "1907-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-07-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1907-07-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p