{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 270 EXENTA, DE 2003 </div><br></div>", "i": 6411104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 270, de fecha 3 de enero de 2003, del Ministerio de Educaci&#xF3;n, se declara que no se concedi&#xF3; el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica La Araucana, organizado por la Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica La Araucana S.A., ubicado en calle Ej&#xE9;rcito N&#xBA; 171 de la ciudad de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Se elimina del libro de Registro de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xBA; 309 de fecha 7 de junio de 2002, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica La Araucana de la ciudad de Santiago.</div><br></div>", "i": 6411105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de enero de 2003.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6411106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "270 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-270 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 270 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-03", "doble_articulado": false, "id_norma": "206979", "numero_fuente": "37465", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-22", "vigencias": [{"desde": "2003-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-22", "fin_vigencia": ""}, "vigencias_version_norma":