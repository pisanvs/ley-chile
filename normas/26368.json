{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY SOBRE SOCIEDADES COOPERATIVAS Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente:</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7173168}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Modif&#xED;case el inciso segundo del</div><div class=\"p\">art&#xED;culo 61 de la ley sobre Sociedades Cooperativas, refundidas por decreto N.o 596, de 14 de Noviembre de 1932, en la siguiente forma:</div><div class=\"p\">&nbsp; &nbsp; Cambiar la expresi&#xF3;n &quot;hasta doscientos pesos&quot; por &quot;hasta cinco mil pesos&quot;.</div><br></div>", "i": 7173169, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lgase y ll&#xE9;vase a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, cinco de Junio de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Pablo Larra&#xED;n.</div><br></div>", "i": 7173170}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10352", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10352"}], "organismos": ["MINISTERIO DE ECONOMÍA Y COMERCIO"], "titulo_norma": "MODIFICA LA LEY SOBRE SOCIEDADES COOPERATIVAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY SOCIEDADES COOPERATIVAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-06-05", "doble_articulado": false, "id_norma": "26368", "numero_fuente": "22334", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-08-25", "vigencias": [{"desde": "1952-08-25", "hasta": "", "tipo_version": "3", "tipo