{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7326889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.344, de 16 de diciembre de 2005, de esta Subsecretar&#xED;a, rev&#xF3;case la resoluci&#xF3;n N&#xBA; 4.019 de 2005, s&#xF3;lo en cuanto declar&#xF3; la caducidad de las resoluciones N&#xBA; 689 de 1999, N&#xBA; 284 de 2001, N&#xBA; 351 y N&#xBA; 352, ambas de 2004, todas de esta Subsecretar&#xED;a, las que autorizaron a DAVID CRUZ LOPEZ para realizar actividades extractivas con la nave &quot;Marleen&quot;. </div></div>", "i": 7326890}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de diciembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7326891}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4344 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4344 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-16", "doble_articulado": false, "id_norma": "246139", "numero_fuente": "38360", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-11", "vigencias": [{"desde": "2006-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-01-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso":