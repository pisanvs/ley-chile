{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,540.- Santiago, 22 de julio de 1902.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6165698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por el se&#xF1;or don Tadeo Izquierdo, as&#xED;gnase a su viuda, do&#xF1;a Remedios Varas, una pension anual de mil quinientos pesos.</div><br></div>", "i": 6165699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Guillermo Barros.</div><br></div>", "i": 6165700}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1540", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1540"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1902-07-22", "doble_articulado": false, "id_norma": "135529", "numero_fuente": "7307", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1902-07-31", "vigencias": [{"desde": "1902-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1902-07-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1902-07-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-27", "fecha_version": "1902-07-31", "fecha_actualizacion_texto": "1902-07-31", "t