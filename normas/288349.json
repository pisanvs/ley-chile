{"html": [{"t": "<div><div class=\"p\">@@</div></div>", "i": 8908474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.073, de 19 de marzo de 2009, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de las resoluciones exentas N&#xBA; 572, de 1994; N&#xBA; 1.540 y N&#xBA; 1.906, ambas de 1995, y N&#xBA; 1.502, de 1997, que autorizaron a PESQUERA POLAR S.A. para desarrollar actividades pesqueras extractivas con la nave &quot;Polar Mist&quot;, matr&#xED;cula 2220, por haber incurrido en la causal de caducidad prevista en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, de conformidad con los informes t&#xE9;cnicos citados en Visto.</div><br></div>", "i": 8908475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de marzo de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8908476}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1073 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1073 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-03-19", "doble_articulado": false, "id_norma": "288349", "numero_fuente": "39322", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-03-26", "vigencias": [{"desde": "2009-03-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-03-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-03-26", "fin_vigencia": "", "tipo_version":