{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6412720}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la Sede de Antofagasta del Instituto Profesional Santo Tom&#xE1;s, autorizada por decreto exento N&#xBA; 414 de 1990, podr&#xE1; impartir a contar del a&#xF1;o 1991 la carrera de Relaciones P&#xFA;blicas, conducente al t&#xED;tulo profesional de Relacionador P&#xFA;blico.</div><div class=\"p\">&nbsp; &nbsp;  Dicha Instituci&#xF3;n se encuentra liberada de la obligaci&#xF3;n de someter sus planes y programas de estudios de la mencionada carrera a una entidad examinadora y de rendir ex&#xE1;menes finales ante comisiones mixtas paritarias en virtud de lo dispuesto en el art&#xED;culo 14&#xBA; y 15&#xBA; del DFL N&#xBA; 5/81 y DS. N&#xBA; 1.076/86.</div><br></div>", "i": 6412721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6412722}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "207356", "numero_fuente": "33911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-06", "vigencias": [{"desde": "1991-03-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-06"