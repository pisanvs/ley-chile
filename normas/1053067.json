{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.195 EXENTA, DE 2013</div></div>", "i": 9366385}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 5.195, de 9 de julio de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Visi&#xF3;n y Desarrollo Capacitaci&#xF3;n Limitada (V &amp; D Cap Ltda.)&quot;, RUT 76.115.404-4, contenida en la resoluci&#xF3;n exenta N&#xBA; 6.848, de 1 de agosto de 2011, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9366386}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9366387}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5195 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5195 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.195 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-07-09", "doble_articulado": false, "id_norma": "1053067", "numero_fuente": "40615", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-07-23", "vigencias": [{"desde": "2013-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-07-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi