{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 100, DE 1988 </div></div>", "i": 6156545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 100 de 12 de mayo de 1988 se ha aprobado para el Complejo Educacional Pedro Prado, comuna Lo Prado, Regi&#xF3;n Metropolitana, un plan y programa especial de estudio para la Educaci&#xF3;n Media, Modalidad. T&#xE9;cnico-Profesional, que se aplicar&#xE1; gradualmente a contar del a&#xF1;o escolar de 1988 y hasta el a&#xF1;o escolar de 1989, en la Rama Comercial, Especialidad Programaci&#xF3;n en Computaci&#xF3;n. </div></div>", "i": 6156546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 03 de Junio de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6156547}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "100 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-100 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 100, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-12", "doble_articulado": false, "id_norma": "132549", "numero_fuente": "33094", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-13", "vigencias": [{"desde": "1988-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"