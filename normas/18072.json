{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REASUME MANDO DEL ESTADO Santiago, 11 de Septiembre de 1994.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 1.557.- Visto: Lo dispuesto en los art&#xED;culos 29&#xB0; y 32&#xB0;, N&#xB0; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 8267799}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Con ocasi&#xF3;n de mi regreso al pa&#xED;s a contar de esta fecha, reasumo el mando del Estado.</div><br></div>", "i": 8267800}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Germ&#xE1;n Correa D&#xED;az, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8267801}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1557", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1557"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANDO NACION", "PRESIDENTE REPUBLICA", "EDUARDO FREI RUIZ-TAGLE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-11", "doble_articulado": false, "id_norma": "18072", "numero_fuente": "34973", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-09-23", "vigencias": [{"desde": "1994-09-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-09-23", "fin_vi