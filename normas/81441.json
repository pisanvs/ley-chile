{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8312398}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.282 de 26 de Octubre de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 12 meses a contar de esta fecha, el plazo otorgado a COMPA&#xD1;IA SALMONIFERA DALCAHUE LIMITADA, RUT 79.777.030-2, domiciliada en la ciudad de Dalcahue y Valpara&#xED;so, en el numeral 5&#xB0; de la resoluci&#xF3;n No.</div><div class=\"p\">1.026, de 1989, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor. </div></div>", "i": 8312399}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 26 de Octubre de 1990. Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8312400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1282", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1282"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-26", "doble_articulado": false, "id_norma": "81441", "numero_fuente": "33821", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-11-17", "vigencias": [{"desde": "1990-11-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-11-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-11-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1997-12-26", "fe