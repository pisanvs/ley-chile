{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N EXENTA QUE INDICA</div></div>", "i": 9114633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 26, de 17 de febrero de 2011, que se&#xF1;ala:</div><div class=\"p\">&nbsp; &nbsp;  Modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1003003&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta SII N&#xBA; 75, de 27 de mayo de 2009</a>, que suprime el Departamento Tribunal Tributario y Oficina Jur&#xED;dica, y crea Departamento Jur&#xED;dico y Oficina de Procedimientos Administrativos Tributarios en la XII Direcci&#xF3;n Regional Punta Arenas; delega facultad que se&#xF1;ala y autoriza delegaci&#xF3;n de facultades que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio Web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en febrero de 2011.</div><br></div>", "i": 9114634}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "26 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-26 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN EXENTA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-02-17", "doble_articulado": false, "id_norma": "1023248", "numero_fuente": "39892", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-22", "vigencias": [{"desde": "2011-02-22", "hasta": "", "tipo_version": "3", "tipo_v