{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 1.336 EXENTO, DE 2012</div></div>", "i": 9351404}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xB0; 427, de 29 de abril de 2013, de este Ministerio, modif&#xED;case la letra a) del art&#xED;culo 2&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1047817&amp;idParte=&amp;idVersion=\">decreto exento N&#xB0; 1.336, de 2012, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, que estableci&#xF3; las cuotas globales anuales de captura en las unidades de pesquer&#xED;a declaradas en estado y r&#xE9;gimen de plena explotaci&#xF3;n, en el sentido de reemplazar la tabla ah&#xED; indicada por la siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/32799.jpg\"></div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9351405}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de abril de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9351406}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "427 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-427 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 1.336 EXENTO, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-04-29", "doble_articulado":