{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N O N&#xB0; 2.978, DE 18 DE MAYO DE 2017</div></div>", "i": 9800968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Determ&#xED;nase que la impresi&#xF3;n de los datos que contendr&#xE1;n las c&#xE9;dulas de votaci&#xF3;n en las Elecciones Primarias de 2 de julio de 2017, se efectuar&#xE1; con tipograf&#xED;a Arial y las siguientes caracter&#xED;sticas:</div><br><div class=\"p\"><img class=\"img-responsive\" src=\"Navegar/imagen/JPG/67386.jpg\">.</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada por resoluci&#xF3;n O N&#xBA; 2.978, de fecha 18 de mayo de 2017, seg&#xFA;n lo dispuesto en el <a href=\"https://www.leychile.cl/Navegar?idNorma=30082&amp;idParte=8602157&amp;idVersion=\">art&#xED;culo 27</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=30082&amp;idParte=&amp;idVersion=\">Ley N&#xBA; 18.700</a>.- </div><br></div>", "i": 9800969}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Garc&#xED;a Aspillaga, Director Servicio Electoral.</div></div>", "i": 9800970}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2978", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-2978"}, {"tipo": "3", "numero": "O-2978", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-O-2978"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN O N° 2.978, DE 18 DE MAYO DE 2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; CVE 1218147"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-05-18", "doble_articulado": false, "id_norma": "1103426", "numero_fuente": "41772", "tipo_version": "3", "tipo_version_s": "Única", "fecha_pub