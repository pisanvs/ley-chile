{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7346702}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.929, de 26 de junio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIALIZADORA Y EXPORTADORA DE PRODUCTOS DEL MAR SEA FISH LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Ruta 68, N&#xBA; 1240, sala 3, Placilla de Pe&#xF1;uelas, Valpara&#xED;so, V Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco-Enfriado, Fresco-Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 7346703}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de junio de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7346704}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1929 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1929 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-26", "doble_articulado": false, "id_norma": "262363", "numero_fuente": "38804", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-04", "vigencias": [{"desde": "2007-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-07-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente