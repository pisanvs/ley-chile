{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6399195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.028, de 25 de septiembre de 2002, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 1.595 de 2002, modificada mediante resoluci&#xF3;n N&#xBA; 1.860 de 2002, ambas de esta Subsecretar&#xED;a, que autorizaron a la UNIVERSIDAD CATOLICA DE VALPARAISO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Evaluaci&#xF3;n directa de langostino amarillo y langostino colorado, entre las regiones V y VIII, 2002&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se realizar&#xE1; entre el 1 de agosto y el 16 de noviembre de 2002, ambas fechas inclusive.</div><br></div>", "i": 6399196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de septiembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6399197}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2028", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2028"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-09-25", "doble_articulado": false, "id_norma": "203411", "numero_fuente": "37381", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-11", "vigencias": [{"desde": "2002-10-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-