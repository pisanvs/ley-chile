{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 713.- Santiago, 17 de octubre de 1925.-</div><div class=\"p\">&nbsp; &nbsp; El Vice-Presidente de la Rep&#xFA;blica, de acuerdo con el Consejo de Ministros del Estado, dicta el siguiente DECRETO-LEI:</div><br></div>", "i": 5875090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Reempl&#xE1;zase al ayudante de la Seccion de Ni&#xF1;os de la Biblioteca Nacional, empleo consultado en el decreto-lei n&#xFA;mero 282, de 28 de febrero &#xFA;ltimo, por un jefe de seccion.</div><br></div>", "i": 5875091}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese como Lei de la Rep&#xFA;blica, e ins&#xE9;rtese en el Boletin respectivo.- Luis Barros Borgo&#xF1;o.- Oscar Fenner.</div><br></div>", "i": 5875092}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "713", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-713"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BIBLIOTECA NACIONAL", "PERSONAL", "PLANTA", "MODIFICACION", "SECCION NI OS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-10-17", "doble_articulado": false, "id_norma": "6300", "numero_fuente": "14319", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-11-11", "vigencias": [{"desde": "1925-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1925-11-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1925-11-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1925-11-11", "fecha_actual