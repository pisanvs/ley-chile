{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6387549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n&nbsp; N&#xBA; 1.295 de 20 de junio de 2002 de esta Subsecretar&#xED;a, autor&#xED;zase a SOUTHPACIFIC KORP S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Lonco&quot;, autorizada por las resoluciones N&#xBA; 832 y N&#xBA; 1.919, ambas de 2001, ambas de esta Subsecretar&#xED;a, en orden a realizar actividades pesqueras con la nave individualizada precedentemente, en el &#xE1;rea mar&#xED;tima comprendida entre la V a X Regiones, por fuera del &#xE1;rea de reserva artesanal, con arte de cerco, sobre los recursos hidrobiol&#xF3;gicos Jurel fino, Anchoa blanca o Samasa, Sardina redonda y Vinciguerria.</div><br></div>", "i": 6387550}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de junio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6387551}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1295", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1295"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-20", "doble_articulado": false, "id_norma": "200022", "numero_fuente": "37299", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-04", "vigencias": [{"desde": "2002-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-04