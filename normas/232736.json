{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6505833}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 3.174, de 4 de noviembre de 2004,&nbsp; de&nbsp; esta&nbsp; Subsecretar&#xED;a, autor&#xED;zase&nbsp; a ALEXANDRE AFANASSIEV para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Ciriaco Alvarez N&#xBA; 242, Chonchi, X Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n de Seco-Salado, Ahumado y Conserva, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.306 de 2004, de esta Subsecretar&#xED;a,&nbsp; en&nbsp; virtud&nbsp; del&nbsp; contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6505834}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6505835}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3174 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3174 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-04", "doble_articulado": false, "id_norma": "232736", "numero_fuente": "38016", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-20", "vigencias": [{"desde": "2004-11-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-