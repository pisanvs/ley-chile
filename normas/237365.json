{"html": [{"t": "<div><div class=\"p\">MODIFICA CONCESION DE ACUICULTURA </div></div>", "i": 6523261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n (M) 442, de 16 de febrero de 2005, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div><br><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;canse las resoluciones (M) N&#xBA;s 1.449 y 1.450, ambas de fecha 25 de julio de 2003, en la siguiente forma:</div><br><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase en su texto &#xED;ntegro lo siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Donde dice: &quot;Empresa Pesquera Apiao Limitada&quot; Debe decir: &quot;Empresa Pesquera Apiao S.A.&quot; </div></div>", "i": 6523262}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de abril de 2005.- Por el Subsecretario, Jos&#xE9; Pelayo Castro, Subjefe Subsecretar&#xED;a de Marina.</div><br></div>", "i": 6523263}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "442", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-442"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "MODIFICA CONCESION DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-02-16", "doble_articulado": false, "id_norma": "237365", "numero_fuente": "38145", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-04-26", "vigencias": [{"desde": "2005-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-04-26", "fin_vigencia": "", "tipo_vers