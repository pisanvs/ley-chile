{"html": [{"t": "<div><div class=\"p\">&quot;PARTIDO COMUNISTA DE CHILE&quot; </div></div>", "i": 6080553}, {"t": "<div><div class=\"p\">Volodia Teitelboim Volosky y Germ&#xE1;n Gonz&#xE1;lez Garc&#xE9;s, Presidente y Secretario del Partido Comunista de Chile, respectivamente, han solicitado la constituci&#xF3;n legal de la entidad en la IX Regi&#xF3;n de la Araucan&#xED;a, completando la cantidad de 2.215 afiliaciones, en conformidad a lo establecido en el art&#xED;culo 17&#xB0; de la Ley No. 18.603 y resoluci&#xF3;n exenta No. 08 de 09 de Febrero de 1990, publicada en el Diario Oficial el 19 de Febrero del mismo a&#xF1;o. Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley No. 18.603; por resoluci&#xF3;n exenta No. 0-335 de fecha 22 de Febrero de 1991.</div><br></div>", "i": 6080554}, {"t": "<div><div class=\"p\">Santiago, 22 de Febrero de 1991.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6080555}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "335 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-335 EXENTA"}, {"tipo": "3", "numero": "O-335 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-335 EXENTA"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO COMUNISTA DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-02-22", "doble_articulado": false, "id_norma": "88778", "numero_fuente": "33906", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-28", "vigencias": [{"desde": "1991-02-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni