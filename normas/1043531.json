{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9293710}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.396, de 30 de agosto de 2012, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xB0; de la resoluci&#xF3;n exenta N&#xB0; 2.271, de 2012, de esta Subsecretar&#xED;a, que autoriz&#xF3; a CAMANCHACA PESCA SUR S.A., para continuar desarrollando actividades pesqueras extractivas, en el sentido de se&#xF1;alar que el nombre de la nave corresponde a &quot;Antares&quot; y no al que all&#xED; se indica.</div></div>", "i": 9293711}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de agosto de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9293712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2396 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2396 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-08-30", "doble_articulado": false, "id_norma": "1043531", "numero_fuente": "40355", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-05", "vigencias": [{"desde": "2012-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-09-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "20652", "fecha_ingreso": "2012-09-05", "fecha_versi