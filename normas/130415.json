{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.464, DE 1988 </div></div>", "i": 6149871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 1.464 de fecha 03 de junio de 1988, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas a las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Secretariado INSEC de Santiago, las que podr&#xE1;n aplicarse a contar del primer semestre acad&#xE9;mico 1988, en la casa central y en todas las sedes autorizadas por este Ministerio.</div><br></div>", "i": 6149872}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 05 de Julio de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6149873}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1464 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1464 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.464, DE 1988", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-06-03", "fecha_derogacion": "2017-07-05", "doble_articulado": false, "id_norma": "130415", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-07-18", "vigencias": [{"desde": "2017-07-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1988-07-18", "hasta": "2017-07-04", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2017-07-05", "fin_vigencia": ""}, "vigencias_ver