{"html": [{"t": "<div><br><div class=\"p\">FIJA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESI&#xD3;N DE SALM&#xD3;NIDOS 47 A, XII REGI&#xD3;N</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9682808}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 725, de 8 de marzo de 2016, de esta Subsecretar&#xED;a, establece que los centros de cultivo integrantes de la Agrupaci&#xF3;n de Concesiones 47 A deber&#xE1;n someterse a la densidad de cultivo establecida por <a href=\"https://www.leychile.cl/Navegar?idNorma=1003741&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.449 de 2009, del Servicio Nacional de Pesca y Acuicultura</a>, o la resoluci&#xF3;n que la reemplace, en virtud de art&#xED;culos 58 R del DS N&#xBA; 319, de 2001 y 5&#xBA; transitorio del DS N&#xBA; 4, de 2013, de este Ministerio.</div><br></div>", "i": 9682809}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de marzo de 2016.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9682810}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "725 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-725 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "FIJA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIÓN DE SALMÓNIDOS 47 A, XII REGIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1005887; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-03-08", "doble_articulado": false, "id_norma": "1088433", "numero_fuente": "41409", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacio