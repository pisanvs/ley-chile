{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 182, DE 1988</div><br><br></div>", "i": 6093430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 182 de 25 de noviembre de 1988 se ha aprobado al Centro de Capacitaci&#xF3;n Laboral de Paine, de la Regi&#xF3;n Metropolitana, un plan de estudio especial de orientaci&#xF3;n laboral para alumnos con deficiencia mental, que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de 4 a&#xF1;os. a contar desde el a&#xF1;o escolar 1989.</div><br><br></div>", "i": 6093431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 20 de Diciembre de 1988.- Paulina Dittborn Cordua, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica.</div><br><br></div>", "i": 6093432}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "182 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-182 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 182. DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-11-25", "doble_articulado": false, "id_norma": "93127", "numero_fuente": "33261", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-01-02", "vigencias": [{"desde": "1989-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-03-03", "fecha