{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 808 EXENTO, DE 2001 </div></div>", "i": 6356254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 808 de fecha 22 de octubre de 2001 se declara aprobada a la Universidad Francisco de Aguirre la siguiente carrera conducente a t&#xED;tulo profesional que se indica:</div><div class=\"p\"> Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Ingenier&#xED;a de Ejecuci&#xF3;n en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Administraci&#xF3;n de Agronegocios.</div><div class=\"p\">T&#xED;tulo Profesional : Ingeniero de Ejecuci&#xF3;n en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Administraci&#xF3;n de Agronegocios.</div><div class=\"p\"> Dicha carrera podr&#xE1; ser impartida en jornada diurna en su sede de la ciudad de La Serena, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6356255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de octubre de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6356256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "808 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-808 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 808 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-22", "doble_articulado": false, "id_norma": "191371", "numero_fuente": "37106", "tipo_version": "3", "tipo_version_s": "Únic