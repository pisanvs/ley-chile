{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.267 EXENTA, DE 19 DE OCTUBRE DE 2018</div></div>", "i": 9960403}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se han modificado las resoluciones exentas Nos <a href=\"https://www.leychile.cl/Navegar?idNorma=141161&amp;idParte=&amp;idVersion=\">4.098</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=164845&amp;idParte=&amp;idVersion=\">12.877</a>, ambas de 1999 y <a href=\"https://www.leychile.cl/Navegar?idNorma=199167&amp;idParte=&amp;idVersion=\">5.937, de 2002</a>, todas del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Compa&#xF1;&#xED;a de Mar&#xED;a de Apoquindo, comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana.- </div></div>", "i": 9960404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 9960405}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5267 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5267 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.267 EXENTA, DE 19 DE OCTUBRE DE 2018", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1487092", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-10-19", "doble_articulado": false, "id_norma": "1124777", "numero_fuente": "42194", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-10-31", "vigencias": [{"desde": "2018-10-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}