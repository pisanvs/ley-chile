{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8353127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.225, de 29 de octubre de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 172 de 1982, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESQUERA MARBELLA LIMITADA, hoy Pesquera Marbella S.A., para operar la nave &apos;&apos;Costa Grande 2&apos;&apos;, en el litoral de la XI y XII Regiones, respecto de los recursos hidrobiol&#xF3;gicos Jurel, Sardina espa&#xF1;ola, Caballa, Anchoa, Agujilla, Cojinoba del norte y Bonito.</div><br></div>", "i": 8353128}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8353129}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2225", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2225"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-29", "doble_articulado": false, "id_norma": "147344", "numero_fuente": "36511", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-11", "vigencias": [{"desde": "1999-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-11-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modi