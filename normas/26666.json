{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N&#xB0; 9,877, DE MARZO DE 1951.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5969377}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase en el art&#xED;culo 3&#xB0; de la ley N&#xB0; 9,877, de 27 de Marzo de 1951, la frase que dice:</div><div class=\"p\">&quot;Fuerza A&#xE9;rea de Chile&quot;, por la siguiente: &quot;Club A&#xE9;reo de San Fernando&quot;.</div><br></div>", "i": 5969378}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, seis de Enero de mil novecientos cincuenta y cuatro.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Abd&#xF3;n Parra U. </div></div>", "i": 5969379}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11484", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11484"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "MODIFICA LA LEY N° 9,877, DE MARZO DE 1951.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 9877", "MUNICIPALIDAD SAN FERNANDO", "TRANSFERENCIA GRATUITA", "TERRENO", "INMUEBLE", "BIEN RAIZ", "CLUB AEREO SAN FERNANDO", "AEROPUERTO", "CANCHA ATERRIZAJE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1954-01-06", "doble_articulado": false, "id_norma": "26666", "numero_fuente": "22759", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1954-01-28", "vigencias": [{"desde": "1