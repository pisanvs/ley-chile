{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 1.410 EXENTO, DE 2013</div></div>", "i": 9399314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.469, de 31 de diciembre de 2013, de este Ministerio, modif&#xED;case el art&#xED;culo 3&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1057670&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 1.410, de 2013, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, que estableci&#xF3; la cuota global de captura de la Merluza del sur para el a&#xF1;o 2014, en la Unidad de Pesquer&#xED;a Norte (41&#xBA;28,6&apos; LS - 47&#xBA; LS) y en la Unidad de Pesquer&#xED;a Sur (47&#xBA; LS - 57&#xBA; LS), en el sentido de modificar la distribuci&#xF3;n temporal de la fracci&#xF3;n industrial de dicha cuota por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/36563.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  En el resto del a&#xF1;o 2014 podr&#xE1;n capturarse los saldos no capturados en los per&#xED;odos antes se&#xF1;alados.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9399315}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9399316}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1469 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1469 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO Nº 1.410 EXENTO, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-31", "doble_articulado": false, "id_norma": "1058095", "numero_fuente": "40753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-01-10", "vigencias": [{"desde": "2014-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-01-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1289", "fecha_ingreso": "2014-01-10", "fecha_version": "2014-01-10", "fecha_actualizacion_texto": "2014-01-10", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9399314}, {"n": "Artículo", "i": 9399315, "t": 6}, {"n": "Promulgación", "i": 9399316}]}