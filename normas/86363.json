{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8317930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 7, de 6 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 1.348 de 1996, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; PESCA CHILE S.A., para operar la nave &quot;Boston Beverly&quot;, matr&#xED;cula 2246, en virtud de no haberse publicado el extracto de dicha Resoluci&#xF3;n dentro del plazo de 30 d&#xED;as contados desde su fecha, de conformidad con lo dispuesto en el Art&#xED;culo 15 del D.S.</div><div class=\"p\">N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8317931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8317932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESCA CHILE S.A.", "AUTORIZACION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-06", "doble_articulado": false, "id_norma": "86363", "numero_fuente": "35963", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-13", "vigencias": [{"desde": "1998-01-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-13", "fin_vigencia"