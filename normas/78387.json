{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6052417}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 31 de 15 de abril de 1992 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; a la sociedad chilena EMPRESA DE TRANSPORTES RURALES LIMITADA, cuyo nombre de fantas&#xED;a es TUR BUS LIMITADA para efectuar transporte internacional terrestre de pasajeros entre Santiago Vi&#xF1;a del Mar Valpara&#xED;so (Chile) y Mendoza (Argentina) por Paso Los Libertadores (T&#xFA;nel Cristo Redentor) y alternativa Puyehue efectuando 3 frecuencias diarias de ida y vuelta. </div></div>", "i": 6052418}, {"t": "<div><div class=\"p\">Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 6052419}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "31", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-31"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-04-15", "doble_articulado": false, "id_norma": "78387", "numero_fuente": "34309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-07", "vigencias": [{"desde": "1992-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PGA", "fecha_ingreso": "1997-12-03", "fecha_version": "1992-07-07", "fe