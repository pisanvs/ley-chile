{"html": [{"t": "<div><div class=\"p\">MODIFICA EL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10380420}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 2.944, de 14.11.2022, de la Directora Nacional de Aduanas, se reemplaza el numeral 2.5 y el p&#xE1;rrafo segundo del numeral 2.7 del Cap&#xED;tulo III del <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp;  La presente resoluci&#xF3;n comenzar&#xE1; a partir de la fecha de publicaci&#xF3;n en Diario Oficial.</div><br></div>", "i": 10380421}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de noviembre de 2022.- Alejandra Arriaza Loeb, Directora Nacional de Aduanas.</div><br></div>", "i": 10380422}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2944 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2944 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA EL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2219917", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-11-14", "doble_articulado": false, "id_norma": "1184609", "numero_fuente": "43407", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-11-22", "vigencias": [{"desde": "2022-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"