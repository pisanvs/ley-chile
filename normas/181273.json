{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 13.489</div><br><div class=\"p\">MODIFICA LA LEY N.o 12.693, DE 15 DE NOVIEMBRE DE 1957 </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 9052194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Agr&#xE9;gase al art&#xED;culo &#xFA;nico de la ley N.o 12.693, de 15 de Diciembre de 1957, el siguente inciso:</div><div class=\"p\">&nbsp; &nbsp;  &quot;El gasto que importe la aplicaci&#xF3;n de la presente ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.&quot;</div><br><br></div>", "i": 9052195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticuatro de Septiembre de mil novecientos cincuenta y nueve. JORGE ALESSANDRI RODRIGUEZ.- Roberto Vergara H.</div><br></div>", "i": 9052196}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13489", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13489"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY N.o 12.693, DE 15 DE NOVIEMBRE DE 1957", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-10-24", "doble_articulado": false, "id_norma": "181273", "numero_fuente": "24466", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-10-14", "vigencias": [{"desde": "1959-10-14", "hasta": "", "tipo_version": "