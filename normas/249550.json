{"html": [{"t": "<div><div class=\"p\">DESIGNA SUBSECRETARIO DE TELECOMUNICACIONES</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 131.- Santiago, 11 de marzo de 2006.- Visto: Lo dispueto en el art&#xED;culo 32, N&#xBA; 10 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile.</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br></div>", "i": 6569611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico: Des&#xED;gnase a contar del 11 de marzo de 2006 a don Pablo Bello Arellano, RUN 13.039.655-0, en el cargo de Subsecretario de Telecomunicaciones, quien por razones impostergables de buen servicio asumir&#xE1; de inmediato sus funciones.</div><br></div>", "i": 6569612}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n, comun&#xED;quese y publ&#xED;quese.- MICHELLE BACHELET JERIA, Presidenta de la Rep&#xFA;blica.- Sergio Espejo Yaksic, Ministro de Transportes y Telecomunicaciones.</div><br></div>", "i": 6569613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "131", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-131"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "DESIGNA SUBSECRETARIO DE TELECOMUNICACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUBSECRETARIO DE TELECOMUNICACIONES", "PABLO BELLO ARELLANO", "DESIGNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-11", "doble_articulado": false, "id_norma": "249550", "numero_fuente": "38461", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-12", "vigencias": [{"desde": "2006-05-12", "hasta": "", "tipo_version": "3", "tipo_ver