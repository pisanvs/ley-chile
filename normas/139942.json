{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,300.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6180219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Se concede, por gracia, una pension anual de seis mil pesos ($ 6,000), a las hijas del ex - Ministro de la Corte Suprema, don Luis Vial Ugarte, de que gozar&#xE1;n con arreglo a la lei de montep&#xED;o militar&quot;. </div></div>", "i": 6180220}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticuatro de setiembre de mil novecientos diecisiete.- Juan Luis Sanfuentes.- Anjel Guarello.</div><br></div>", "i": 6180221}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3300", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3300"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-09-24", "doble_articulado": false, "id_norma": "139942", "numero_fuente": "11881", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-09-27", "vigencias": [{"desde": "1917-09-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1917-09-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1917-09-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":