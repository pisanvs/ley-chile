{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.016 EXENTO, DE 1997 </div></div>", "i": 7212200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 1.016, de fecha 9 de octubre de 1997, del Ministerio de Educaci&#xF3;n, se reemplazaron a contar del a&#xF1;o 1997 las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica ICCE, que fueron aprobadas por Decreto exento de Educaci&#xF3;n N&#xBA; 400 del 13 de diciembre de 1992.</div><div class=\"p\">Santiago, 12 de agosto de 1997.-</div><br></div>", "i": 7212201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7212202}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1016 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1016 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.016 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "EVALUACION", "PROGRAMAS DE ESTUDIO", "PLANES DE ESTUDIO", "CENTRO DE FORMACION TECNICA ICCE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-09", "doble_articulado": false, "id_norma": "76880", "numero_fuente": "35912", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-11-10", "vigencias": [{"desde": "1997-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-11-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-11-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICA