{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 11, DE 1987</div><br><br></div>", "i": 6213635}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 11 de 15 de enero de 1987 se ha aprobado las Escuelas Especiales N&#xB0;s. 254 y 236, de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana, un plan complementario de formaci&#xF3;n laboral para menores deficientes mentales egresados del curso multitaller, que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de 4 a&#xF1;os, a contar desde 1987.</div><br></div>", "i": 6213636}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de Enero de 1987.- Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 6213637}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "11 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-11 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 11, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-15", "doble_articulado": false, "id_norma": "149760", "numero_fuente": "32689", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-04", "vigencias": [{"desde": "1987-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "199