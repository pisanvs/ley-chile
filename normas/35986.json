{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 992, de 9 de agosto de 1995, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por JORGE ALEJANDRO</div><div class=\"p\">CARLOS JOSE OSSA ARANGUA, R.U.T. N&#xB0; 4.905.546-3, para un</div><div class=\"p\">centro de cultivo ubicado en Isla Tr&#xE1;nsito, Comuna y</div><div class=\"p\">Provincia de Ays&#xE9;n, XI Regi&#xF3;n, por no dar cumplimiento</div><div class=\"p\">el respectivo proyecto t&#xE9;cnico a lo dispuesto en el</div><div class=\"p\">art&#xED;culo 12&#xB0; del D.S. N&#xB0; 175, de 1980, modificado por el D.S. N&#xB0; 427, de 1989, ambos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8295130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 9 de agosto de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "992", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-992"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JORGE OSSA ARANGUA", "CONCESION ACUICULTURA", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-08-09", "doble_articulado": false, "id_norma": "35986", "numero_fuente": "35247", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-08-19"