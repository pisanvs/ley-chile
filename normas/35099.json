{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 554 de 2 de Agosto de 1993 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1&#xB0; de la resoluci&#xF3;n N&#xB0; 1284, de 1992, de esta Subsecretar&#xED;a, que otorg&#xF3; a PESCA CHILE S.A., R.U.T. N&#xB0; 95.023.000-2, un plazo de 9 meses para reiniciar actividades pesqueras con la nave &quot;Corfo I&quot;, en el sentido de precisar dicho plazo debe contarse desde el 2 de enero de 1993, de conformidad con lo establecido en el Art. 143 letra b), del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8293108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 2 de Agosto de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.-</div><br></div>", "i": 8293109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "554", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-554"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PESCA", "AUTORIZACION", "PESCA CHILE S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-08-02", "doble_articulado": false, "id_norma": "35099", "numero_fuente": "34636", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-08-09", "vigencias": [{"desde": "1993-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-08-09", "fin_vigencia": ""}, "vigenci