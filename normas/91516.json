{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8320330}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.850 de 29 de Noviembre de 1989 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorrogase por un a&#xF1;o a contar del 06 de diciembre de 1989, el plazo otorgado a la Compa&#xF1;&#xED;a Salmon&#xED;fera Dalcahue Limitada, R.U.T. No. 79.777.030-2, domiciliada en las localidades de Dalcahue y Valpara&#xED;so, para empezar a operar el establecimiento de cultivo autorizado por la resoluci&#xF3;n No. 1.218, de 1988, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de un caso fortuito.</div><br></div>", "i": 8320331}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 29 de Noviembre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8320332}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1850", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1850"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-29", "doble_articulado": false, "id_norma": "91516", "numero_fuente": "33548", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-18", "vigencias": [{"desde": "1989-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-18", "fin_vigencia": "", "tip