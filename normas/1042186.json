{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xB0; 1.549, DE 2012</div></div>", "i": 9283492}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.003, de 18 de julio de 2012, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1041267&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.549, de 2012</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; macro-zonas en la Regi&#xF3;n de Ays&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo, reemplazando coordenadas geogr&#xE1;ficas de las macro-zonas se&#xF1;aladas en resoluci&#xF3;n extractada, publicada &#xED;ntegramente en www.subpesca.cl y www.sernapesca.cl.</div></div>", "i": 9283493}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9283494}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2003 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2003 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCIÓN N° 1.549, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-18", "doble_articulado": false, "id_norma": "1042186", "numero_fuente": "40322", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-27", "vigencias": [{"desde": "2012-07-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-07-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012