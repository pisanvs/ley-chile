{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 455 EXENTA, DE 2001 </div><br></div>", "i": 6325598}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 455, de 17 de enero del a&#xF1;o 2001, se ha aprobado al Colegio Tabancura, comuna de Vitacura, de Santiago, un plan de estudio para 3&#xBA; a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n, excepto en los Sectores de Artes Visuales o Artes Musicales, cuyos programas ser&#xE1;n los oficiales aprobados por el Ministerio de Educaci&#xF3;n.</div><br></div>", "i": 6325599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de enero de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6325600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "455 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-455 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 455 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-17", "doble_articulado": false, "id_norma": "182652", "numero_fuente": "36906", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-07", "vigencias": [{"desde": "2001-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-07",