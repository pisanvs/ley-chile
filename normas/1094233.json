{"html": [{"t": "<div><br><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9726204}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.684, de 8 de agosto 2016 de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en Freire 150, Rol Aval&#xFA;o N&#xB0; 283-92, Comuna Curic&#xF3;, superficie 37,52 metros cuadrados, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Gamboa Cavieres Mar&#xED;a del Carmen. Comisi&#xF3;n integrada por peritos Mar&#xED;a Carolina Letelier Bopp, Arquitecto; Marianela Araya Flores, Arquitecto y Claudia Poblete Ram&#xED;rez, Arquitecto, seg&#xFA;n informe de 2 de agosto de 2016, fij&#xF3; monto provisional indemnizaci&#xF3;n en $10.412.633.-, pagados al contado.- </div></div>", "i": 9726205}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Omar Guti&#xE9;rrez Mesina, Director Serviu Regi&#xF3;n del Maule. </div><br></div>", "i": 9726206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2684 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2684 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1104288", "CVE 1104288", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-08-08", "doble_articulado": false, "id_norma": "1094233", "numero_fuente": "41548", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-09-01", "vigencias": [{"desde": "2016-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "