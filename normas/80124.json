{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8310636}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.336 de 22 de Octubre de 1991 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 30 d&#xED;as a contar de esta fecha, el plazo otorgado a SAR-PESCA S.A., R.U.T. No.</div><div class=\"p\">96.539.160-6, domiciliada en la ciudad de Santiago, en el numeral 2&#xB0; de la Resoluci&#xF3;n No. 870, de 1991, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8310637}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 20 de Octubre de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8310638}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1336", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1336"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-22", "doble_articulado": false, "id_norma": "80124", "numero_fuente": "34109", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-06", "vigencias": [{"desde": "1991-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fecha_ingres