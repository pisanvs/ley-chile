{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA PORCENTAJE DE COINCIDENCIA ENTRE EL TRAZADO TRONCAL Y EL CONJUNTO DE TRAZADOS DENOMINADOS VARIANTES N&#xFA;m. 35 exenta.- Puerto Montt, 1&#xB0; de Diciembre de 1992.- Visto: El decreto supremo N&#xB0; 212 de 1992, art&#xED;culo 9&#xB0; inciso segundo, y la resoluci&#xF3;n exenta N&#xB0; 023 de 1991.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 7200886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Sustit&#xFA;yase para todas las ciudades de la X Regi&#xF3;n, el porcentaje de coincidencia entre el trazado troncal y las variantes definidas en la resoluci&#xF3;n exenta N&#xB0; 023/91, por 50%.</div><br></div>", "i": 7200887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Adri&#xE1;n Pe&#xF1;a Jara, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n subrogante.</div><br></div>", "i": 7200888}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "35 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-35 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "MODIFICA PORCENTAJE DE COINCIDENCIA ENTRE EL TRAZADO TRONCAL Y EL CONJUNTO DE TRAZADOS DENOMINADOS VARIANTES", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "TRAZADO TRONCAL", "VARIANTES", "DECIMA", "REGION", "LOCOMOCION COLECTIVA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1992-12-01", "fecha_derogacion": "2017-01-27", "doble_articulado": false, "id_norma": "38030", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_