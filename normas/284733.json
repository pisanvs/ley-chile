{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA;3.369 EXENTA, DE 2008 </div></div>", "i": 6912493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.369, de fecha 8 de mayo de 2008 del Ministerio de Educaci&#xF3;n, se aprueba el plan y programas de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Jorge &#xC1;lvarez Echeverr&#xED;a, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartido en la Sede Central de La Serena, a contar del a&#xF1;o 2008:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; :&nbsp; &nbsp;  Administraci&#xF3;n y Gesti&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Empresarial.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp;  :&nbsp; &nbsp;  T&#xE9;cnico de Nivel Superior en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Administraci&#xF3;n y Gesti&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Empresarial.</div><br><br></div>", "i": 6912494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de diciembre de 2008.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6912495}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3369 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3369 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº3.369 EXENTA, DE 2008", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2008-05-08", "fecha_derogacion": "2013-12-10", "doble_articulado": false, "id_norma": "28