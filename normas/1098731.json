{"html": [{"t": "<div><br><div class=\"p\">ART&#xCD;CULO 41 E DE LA LEY SOBRE IMPUESTO A LA RENTA</div></div>", "i": 9759515}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xB0; 126, del 27 de diciembre de 2016, deroga y refunde lo dispuesto en la <a href=\"https://www.leychile.cl/Navegar?idNorma=1048634&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n del Servicio de Impuestos Internos ex. N&#xB0; 14, de 2013</a>, que establece la obligaci&#xF3;n de presentar declaraci&#xF3;n jurada anual informativa de precios de transferencia en la presente resoluci&#xF3;n y adem&#xE1;s establece obligaci&#xF3;n de presentar declaraci&#xF3;n jurada anual denominada &quot;Reporte Pa&#xED;s por Pa&#xED;s&quot; a contribuyentes que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2016.</div><br></div>", "i": 9759516, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "126 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-126 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ARTÍCULO 41 E DE LA LEY SOBRE IMPUESTO A LA RENTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1162302", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-12-27", "refunde_a": "Resolución-14 EXENTA", "doble_articulado": false, "id_norma": "1098731", "numero_fuente": "41650", "t