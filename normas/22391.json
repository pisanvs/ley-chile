{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Maquinaria i cierros de la F&#xE1;brica de Cartuchos Lei n&#xFA;m. 1,066.- Santiago, a 31 de Agosto de 1898.- Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7162892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de cien mil pesos en la adquisici&#xF3;n de maquinarias i cierros de la F&#xE1;brica de Cartuchos.</div><br><br></div>", "i": 7162893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- V. Blanco.</div><br></div>", "i": 7162894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1066", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1066"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "MAQUINARIA I CIERROS DE LA FÁBRICA DE CARTUCHOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FABRICA CARTUCHOS", "MAQUINARIA", "CIERROS", "INVERSION", "AUTORIZACION", "PRESIDENTE REPUBLICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-08-31", "doble_articulado": false, "id_norma": "22391", "numero_fuente": "6093", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-09-03", "vigencias": [{"desde": "1898-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-09-03", "fin_vigencia"