{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DEROGA INCISO FINAL DEL ARTICULO 323&#xB0; DEL CODIGO DEL TRABAJO</div><div class=\"p\">&nbsp; &nbsp; Y por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5979257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Der&#xF3;gase el inciso final del art&#xED;culo 323&#xB0; del C&#xF3;digo del Trabajo.</div><br></div>", "i": 5979258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido ha bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintiuno de Marzo de mil novecientos sesenta y ocho.- EDUARDO FREI MONTALVA.- Eduardo Le&#xF3;n Villarreal.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a U. para su conocimiento.- Saluda a U.- Ernesto Y&#xE1;var Castro, Subsecretario del Trabajo. </div></div>", "i": 5979259}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16772", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16772"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL"], "titulo_norma": "DEROGA INCISO FINAL DEL ARTICULO 323° DEL CODIGO DEL\nTRABAJO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CODIGO TRABAJO", "SALARIO BASE", "SABADO Y DOMINGO", "OBRERO", "SUELDO", "REMUNERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-03-21", "doble_articulado": false, "id_norma": "28659", "numero_fuente": "27043", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-05-15", "vigencias": [{"desde": "1968-05-15", "hasta": "", "tipo_version": "3