{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7289653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 330, de 6 de febrero de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 721 de 1993, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA QUINTERO S.A., domiciliada en Avenida 21 de Mayo N&#xBA; 1057, Quintero, para operar la nave &quot;Eldom&quot;, matr&#xED;cula 2070, respecto del recurso Raya en toda el &#xE1;rea a ella autorizada en la citada resoluci&#xF3;n, como tambi&#xE9;n sobre todos los recursos se&#xF1;alados en el numeral 3&#xBA; letra b), pero s&#xF3;lo respecto del &#xE1;rea mar&#xED;tima de la IX Regi&#xF3;n, en ambos casos por incurrir en la causal de caducidad del art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura. </div></div>", "i": 7289654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de febrero de 2002.- Edith Saa Collantes, Subsecretario de Pesca&nbsp; (S).</div><br></div>", "i": 7289655}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "330", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-330"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-06", "doble_articulado": false, "id_norma": "194563", "numero_fuente": "37185", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-13", "vigencias": [{"desde": "2002-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"