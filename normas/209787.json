{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 4,677</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6422165}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Der&#xF3;gase el art&#xED;culo 22 del decreto-ley n&#xFA;mero 415, de 19 de Marzo de 1925, sobre impuesto a los espec&#xED;ficos.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 6422166}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por tanto, publ&#xED;quese y ll&#xE9;vese a efecto en todas sus partes como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, siete de Noviembre de mil novecientos veintinueve.- Carlos Ib&#xE1;&#xF1;ez C.- Luis Carvajal L. </div></div>", "i": 6422167}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4677", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4677"}], "organismos": ["MINISTERIO DE BIENESTAR SOCIAL", "SUBSECRETARIA DE BIENESTAR SOCIAL"], "titulo_norma": "LEY NUM. 4,677", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-11-07", "doble_articulado": false, "id_norma": "209787", "numero_fuente": "15524", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-11-16", "vigencias": [{"desde": "1929-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-11-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-11-16", "fin_vigencia": "", "tipo_version": "3"}