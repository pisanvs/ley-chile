{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6158187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 133, del 29 de Marzo de 1988, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones, de la IV Regi&#xF3;n de Coquimbo, se autoriza a don Fidel Orestes Alcayaga Ram&#xED;rez para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva.-</div><br></div>", "i": 6158188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge Vargas Borcosky, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6158189}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "133 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-133 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-29", "doble_articulado": false, "id_norma": "133155", "numero_fuente": "33053", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-23", "vigencias": [{"desde": "1988-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "C