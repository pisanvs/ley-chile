{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6306576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;752, de 31 de julio de 1997, se orden&#xF3; la expropiaci&#xF3;n y aprob&#xF3; el plano y cuadro de expropiaci&#xF3;n del lote de terreno N&#xBA;86, y por decreto MOP, N&#xBA;3.097, de 31 de julio de 2000, se autoriz&#xF3; el valor de la consignaci&#xF3;n provisional de la expropiaci&#xF3;n por la v&#xED;a judicial, en la cantidad de $270.000.- necesario para la ejecuci&#xF3;n de la obra Ruta 1-85-J, Sector Cruce Longitudinal (Chimbarongo) - Codegua, Tramo Km. 0.000 a Km. 12.543,68, el pago de la indemnizaci&#xF3;n se efectuar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreo ley N&#xBA;2.186, de 1978.-</div><br></div>", "i": 6306577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6306578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "752", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-752"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-31", "doble_articulado": false, "id_norma": "177101", "numero_fuente": "36802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-02", "vigencias": [{"desde": "2000-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-02", "fin_vigencia": "", "t