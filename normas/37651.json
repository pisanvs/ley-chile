{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 2.037, de 4 de diciembre de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura presentada por ILSE KOCH GEISSE, para un sector ubicado en la desembocadura del R&#xED;o San Pedro Nolasco, Comuna de Maull&#xED;n, Provincia de Llanquihue, X Regi&#xF3;n, en virtud de lo dispuesto en los art&#xED;culos 10&#xB0; y 12&#xB0;, del D.S. N&#xB0; 290, de 1993, modificado por el D.S. N&#xB0; 604, de 1994, ambos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8298826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 4 de diciembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298827}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2037", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2037"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION DE ACUICULTURA", "ILSE KOCH GEISSE", "MAULLIN", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-04", "doble_articulado": false, "id_norma": "37651", "numero_fuente": "35640", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-13", "vigencias": [{"desde": "1996-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-13", "fin_vigencia": ""}, "vigencias_ver