{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION N&#xBA; 45 EXENTA, DE 2001</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 87 exenta.- Talca, 1 de junio de 2001.- Visto: El decreto supremo N&#xBA; 1/94, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, la resoluci&#xF3;n exenta N&#xBA; 45/2001 del Secretario Regional Ministerial, VII Regi&#xF3;n, </div><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6338605}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Der&#xF3;gase la resoluci&#xF3;n exenta N&#xBA; 45, del 28 de marzo de 2001, dictada por el Seremitt, Regi&#xF3;n del Maule, publicada en el Diario Oficial el 12 de abril de 2001.</div><br></div>", "i": 6338606}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese y publ&#xED;quese.- Rodrigo Claramunt Jaramillo, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n del Maule.</div><br></div>", "i": 6338607}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "87 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-87 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "DEROGA RESOLUCION Nº 45 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-06-01", "doble_articulado": false, "id_norma": "186390", "numero_fuente": "36987", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-15", "vigencias": [{"desde": "2001-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio