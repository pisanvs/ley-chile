{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9332005}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 260, de 31 de enero de 2013, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CHILE S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Puerto Williams&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 47&#xB0; L.S. y 57&#xB0; L.S., por fuera de las l&#xED;neas de base recta, con palangre, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: Cabrilla com&#xFA;n, Cabrilla y Pejerrata o Granadero.</div><br></div>", "i": 9332006}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div><br></div>", "i": 9332007}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "260 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-260 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-01-31", "fecha_derogacion": "2014-12-06", "doble_articulado": false, "id_norma": "1048703", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-02-07", "vigencias": [{"desde": "2014-12-06", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2013-02-07", "hasta": "2014-12-05", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-02-07