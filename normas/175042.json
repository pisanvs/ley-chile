{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6299231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.749, de 28 de abril de 2000, se expropiaron los lotes de terreno N&#xBA;s 1, 5, 12 y 14, superficies 417, 15.210, 9.124 y 2.573,74 M2. respectivamente, roles de aval&#xFA;os 516-3, 516-52, y 511-41, comuna de Carahue, para la obra Camino Costero Tir&#xFA;a - Carahue, Sector Puyanhue - Tranapuente, Km.</div><div class=\"p\">45.303,00 a Km. 53.335,00 y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Mario Antonio Alvarez Lara, Lorenzo del Carmen Burgos Gonz&#xE1;lez, Miguel G&#xF3;mez Aburto y Tirsa Olivia G&#xF3;mez Aburto en las cantidades de $146.821, lote N&#xBA;1; $2.738.467, lote N&#xBA;5; $933.691, lote N&#xBA;12 y $507.875, lote N&#xBA;14.</div><br></div>", "i": 6299232}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6299233}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1749", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1749"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "175042", "numero_fuente": "36754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-01", "vigencias": [{"desde": "2000-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-01", "fin_vigencia": "", "tipo_ver