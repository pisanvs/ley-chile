{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6225969}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 52 de fecha 29.07.86 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la XI Regi&#xF3;n, se autoriza a don Ricardo Tolmo Pardo para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 1 Circunvalaci&#xF3;n, cuyo trazado que a continuaci&#xF3;n se indica fue autorizado por resoluci&#xF3;n No. 12 de Enero 21.06.84, de esta Secretar&#xED;a Regional.</div><br><div class=\"p\">&nbsp; &nbsp;  Ida y Regreso: A. Prat, Simpson, Victoria, Baquedano, General Parra, Magallanes, Bilbao. </div></div>", "i": 6225970}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Coyhaique, 29 de Julio de 1986.- Ra&#xFA;l Castillo Ceardi, Secretario Regional Ministerial de Transportes y Telecomunicaciones XI Regi&#xF3;n.</div><br></div>", "i": 6225971}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "52", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-52"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XI REGIÓN DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-29", "doble_articulado": false, "id_norma": "153446", "numero_fuente": "32541", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-06", "vigencias": [{"desde": "1986-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-0