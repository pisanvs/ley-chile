{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6452071}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.983 de 20 de noviembre de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n&nbsp; N&#xBA; 837 de&nbsp; 2001&nbsp; y&nbsp; el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 484 de 2003, ambas de esta Subsecretar&#xED;a, que autorizaron a SOUTHPACIFIC KORP S.A., RUT N&#xBA; 96.929.960-7, con domicilio en Avenida El Golf N&#xBA; 150, piso 15, comuna de Las Condes, Santiago, para realizar actividades pesqueras extractivas con la nave &quot;Guanaye 2&quot;, en el sentido de incorporar y actualizar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; 820,74 m3.</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp;  43,08 m.</div><div class=\"p\">Potencia principal&nbsp; &nbsp; &nbsp;  2175,00 Hp.</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp; &nbsp; 535,00 Hp.</div><br><br></div>", "i": 6452072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6452073}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2983 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2983 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-11-20", "fecha_derogacion": "2008-11-13", "doble_ar