{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;1.036 EXENTO, DE 2006</div><br><br></div>", "i": 6609494}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.036, de fecha 21 de julio de 2006, del Ministerio de Educaci&#xF3;n, se deja sin efecto, a contar del a&#xF1;o 2006, la aprobaci&#xF3;n del plan y programas de estudio de la carrera de T&#xE9;cnico en Construcci&#xF3;n en Edificaci&#xF3;n, aprobada para el Centro de Formaci&#xF3;n T&#xE9;cnica Chileno Norteamericano, mediante decreto exento de Educaci&#xF3;n N&#xBA; 372, del 19 de junio de 2001, a petici&#xF3;n de la propia entidad.</div><br></div>", "i": 6609495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de agosto de 2006.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6609496}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1036 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1036 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº1.036 EXENTO, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA CHILENO NORTEAMERICANO", "DEJA SIN EFECTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-21", "doble_articulado": false, "id_norma": "260658", "numero_fuente": "38757", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-08", "vigencias": [{"desde": "2007-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-05-08", "fin_vige