{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 919, de 16 de Noviembre de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xB0; 740, de 1989, de esta Subsecretar&#xED;a que autoriz&#xF3; a don JAIME GUIDO SURBER WILLER, R.U.T. N&#xB0; 6.268.195-0, para operar un centro de cultivo del recurso alga del g&#xE9;nero Gracilaria spp., en sector Chuyaqu&#xE9;n, R&#xED;o Maull&#xED;n, Comuna de Maull&#xED;n, X Regi&#xF3;n, por haberse caducado el decreto de concesi&#xF3;n mar&#xED;tima. </div></div>", "i": 8294848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 16 de Noviembre de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8294849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "919", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-919"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ACUICULTURA", "AUTORIZACION", "JAMIE GUIDO SURBER", "WILLER", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-11-16", "doble_articulado": false, "id_norma": "35867", "numero_fuente": "34725", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-25", "vigencias": [{"desde": "1993-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-11-25", "fin_vigenc