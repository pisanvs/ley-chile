{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6330212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA; 131, de 28 de febrero de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 49-C, superficie 624 m&#xB2;, Rol de aval&#xFA;o 293-54, comuna de Frutillar, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: R&#xED;o Bueno-Puerto Montt. Sector: Variante Casma, D&#xE9;cima Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Mar&#xED;a Yeanette Pino Vargas, ascendente a la cantidad de $554.801.-</div><br></div>", "i": 6330213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6330214}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "131 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-131 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-28", "doble_articulado": false, "id_norma": "183963", "numero_fuente": "36938", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-16", "vigencias": [{"desde": "2001-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-04-16", "fecha_version": "2001-04-16", "fecha_actualizacion_texto": "2001-04-16", "tipo_tratado": ""}, "alertas": [], "ale