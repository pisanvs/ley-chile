{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6350096}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.889, de 11 de septiembre de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A., para ampliar las actividades pesqueras extractivas con la nave &quot;Biomar IV&quot;, matr&#xED;cula 2846, en orden a realizar actividades pesqueras con la nave se&#xF1;alada precedentemente, en el litoral de las Islas Oce&#xE1;nicas y su Zona Econ&#xF3;mica Exclusiva, por fuera del &#xE1;rea de reserva artesanal, con red de arrastre, donde podr&#xE1; capturar el recurso hidrobiol&#xF3;gico Alfonsino. </div></div>", "i": 6350097}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de septiembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6350098}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1889", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1889"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-09-11", "fecha_derogacion": "2016-11-23", "doble_articulado": false, "id_norma": "189629", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-09-22", "vigencias": [{"desde": "2016-11-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2001-09-22", "hasta": "2016-11-22", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2016-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-09-