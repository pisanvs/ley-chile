{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 718 EXENTO, DE 1993 </div></div>", "i": 8667412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 718 de 31 de diciembre de 1993 se ha aprobado, a contar del a&#xF1;o escolar 1993, un plan especial de estudio para Educaci&#xF3;n B&#xE1;sica al Colegio &quot;The Angel&apos;s School&quot; de Santiago, el que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas de: Filosof&#xED;a, Arte, Artes Pl&#xE1;sticas, T&#xE9;cnico Manual, Orientaci&#xF3;n y Salud y Franc&#xE9;s. </div></div>", "i": 8667413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 22 de Febrero de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8667414}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "718 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-718 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 718 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO ANGEL'S SCHOOL", "SANTIAGO", "PLAN ESTUDIO", "PROGRAMA ESTUDIO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-12-31", "doble_articulado": false, "id_norma": "21736", "numero_fuente": "34807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-05", "vigencias": [{"desde": "1994-03-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-03-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"i