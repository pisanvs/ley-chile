{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 3.596 EXENTA, DE 2014</div></div>", "i": 9570364}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 487, de 17 de febrero de 2015, de esta Subsecretar&#xED;a, modif&#xED;quese la <a href=\"https://www.leychile.cl/Navegar?idNorma=1073302&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3596 de 2014</a>, que estableci&#xF3; la distribuci&#xF3;n de la fracci&#xF3;n artesanal de la pesquer&#xED;a artesanal Merluza com&#xFA;n de la IV, V, VI, VII y VIII Regiones, en el sentido de se&#xF1;alar que la distribuci&#xF3;n enero-diciembre de 2015, en el &#xC1;rea Sur de la V Regi&#xF3;n, se efectuar&#xE1; de la siguiente manera:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/47830.jpg\">.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura. </div></div>", "i": 9570365}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de febrero de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9570366}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "487 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-487 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 3.596 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_