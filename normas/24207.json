{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,728, que concede derecho a jubilar a don Luis Martiniano Rodr&#xED;guez.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,728.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276667}, {"t": "<div><div class=\"p\">Art&#xED;cul o &#xFA;ni co.- Conc&#xE9;dese, por de OHig gins,&nbsp; don Luis Martniano con una&nbsp; rent a anual de doce mil </div></div>", "i": 8276668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a dieciseis de Febrero de mil novecientos veintiuno.- ARTURO ALESSANDRI.- Pedro Aguirre Cerda. </div></div>", "i": 8276669}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3728", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3728"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Lei núm. 3,728, que concede derecho a jubilar a don;Luis Martiniano Rodríguez.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LUIS MARTINIANO RODRIGUEZ", "JUBILACION POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-02-16", "doble_articulado": false, "id_norma": "24207", "numero_fuente": "12907", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-02-25", "vigencias": [{"desde": "1921-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1921-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia