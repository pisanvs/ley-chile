{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7268218}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;601, de 23 de marzo de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a don HUGO ANTONIO QUEZADA CERDA para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Puerto Alcudia&apos;&apos;, matr&#xED;cula 1871 Valpara&#xED;so, autorizada por la resoluci&#xF3;n N&#xBA;1.469 de 1997, de esta Subsecretar&#xED;a, en orden a realizar actividades pesqueras extractivas con la nave &apos;&apos;Puerto Alcudia&apos;&apos;, con arte de Espinel en el litoral de la V Regi&#xF3;n por fuera del &#xE1;rea de reserva artesanal, sobre el recurso hidrobiol&#xF3;gico Reineta.</div><br></div>", "i": 7268219}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de marzo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7268220}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "601", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-601"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-03-23", "fecha_derogacion": "2001-01-31", "doble_articulado": false, "id_norma": "166691", "numero_fuente": "36645", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-04-20", "vigencias": [{"desde": "2001-01-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-04-20", "hasta": "2001-01-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vig