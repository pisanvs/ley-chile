{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,031.- Santiago, 25 de enero de 1898.- Por cuanto el Congreso Nacional ha tenido a bien aprobar el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese al teniente-coronel don Juan Pablo Bustamante, para los efectos de su retiro, el abono de cinco a&#xF1;os once meses un d&#xED;a.</div><br></div>", "i": 6161476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Patricio Larrain A.</div><br></div>", "i": 6161477}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1031", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1031"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-25", "doble_articulado": false, "id_norma": "134150", "numero_fuente": "5914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-28", "vigencias": [{"desde": "1898-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-01-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-03-30", "fecha_version": "1898-01-28", "fecha_actualizacion_texto": "1898-01-28", "tipo_tra