{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA CERTIFICADO</div></div>", "i": 9568117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Se rectifica certificado de la Superintendencia de Valores y Seguros que da cuenta de la existencia de BTG Pactual Chile S.A. Compa&#xF1;&#xED;a de Seguros de Vida, autorizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1072917&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 319, de 19 de diciembre de 2014</a>, en el siguiente sentido:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- Donde dice &quot;22 de agosto de 2013&quot;, debe decir &quot;22 de agosto de 2014&quot;.</div><div class=\"p\">&nbsp; &nbsp;  2.- Donde dice &quot;BTG PACTUAL CHILE SERVICIOS FINANCIEROS S.A.&quot;, debe decir &quot;BTG PACTUAL CHILE SERVICIOS FINANCIEROS S.A. Rut. N&#xBA; 79.884.170-K&quot;.</div><div class=\"p\">&nbsp; &nbsp;  3.- Donde dice &quot;Comuna y Ciudad de Santiago&quot;, debe decir &quot;Ciudad de Santiago&quot;.</div><br></div>", "i": 9568118, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de diciembre de 2014.- Carmen Undurraga Mart&#xED;nez, Secretaria General.</div></div>", "i": 9568119}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "RECTIFICA CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-12-23", "doble_articulado": false, "id_norma": "1074889", "numero_fuente": "41086", "tipo_