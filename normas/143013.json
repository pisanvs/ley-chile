{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6190108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 576 de 20 de Noviembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Leonel Vera Calder&#xF3;n para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 1 &quot;Franke - Centro - Rahue Alto&quot; de Osorno, cuyo trazado fue autorizado por resoluci&#xF3;n No. 90 de 12 de junio de 1984 y modificado por resoluci&#xF3;n No. 464 de 16 de Septiembre de 1986, de esta Secretar&#xED;a Regional. </div></div>", "i": 6190109}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 6190110}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "576 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-576 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 2.893, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-11-20", "doble_articulado": false, "id_norma": "143013", "numero_fuente": "32665", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-01-07", "vigencias": [{"desde": "1987-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1