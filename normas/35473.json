{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293962}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 743, de 25 de abril de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1&#xB0; de las Resoluciones N&#xB0; 1.824, N&#xB0; 1.825, N&#xB0; 1.826 y N&#xB0; 1.827, todas de 1995, de esta Subsecretar&#xED;a, en el sentido de indicar que donde dice &quot;Empresa de Desarrollo Pesquero S.A.&quot; debe decir &quot;Empresa de Desarrollo Pesquero de Chile S.A.&quot;.</div><br></div>", "i": 8293963}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 25 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293964}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "743", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-743"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMPRESA DESARROLLO PESQUERO S.A.", "PESCA", "AUTORIZACION", "EMPRESA DESARROLLO PESQUERO CHILE S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-04-25", "fecha_derogacion": "1996-07-02", "doble_articulado": false, "id_norma": "35473", "numero_fuente": "35458", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-05-04", "vigencias": [{"desde": "1996-07-02", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-05-04", "hasta": "1996-07-01", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1996-07-02", "fin_vi