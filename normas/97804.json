{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 226, de 17 de febrero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 718 de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a JOSE ANDRES MEDEL RIVAS, para instalar y operar un centro de cultivo ubicado en un sector del r&#xED;o San Pedro Nolasco, comuna de Maull&#xED;n, provincia de Llanquihue, X Regi&#xF3;n, por haber vencido el plazo del D.S. (M) N&#xBA; 610 de 1988, del Ministerio de Defesa Nacional que otorg&#xF3; la concesi&#xF3;n de acuicultura. </div></div>", "i": 8329066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de febrero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329067}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "226", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-226"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "JOSE ANDRES MEDEL RIVAS", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-17", "doble_articulado": false, "id_norma": "97804", "numero_fuente": "35999", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-24", "vigencias": [{"desde": "1998-02-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-02-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-02-