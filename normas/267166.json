{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6745636}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 663, de fecha 29 de octubre de 2007, se expropiaron los lotes de terreno N&#xBA;s. 15, 16, 17, 18 y 19, superficies 361, 370, 355, 241 y 76 m2, rol N&#xBA; 1502-53, comuna de Los &#xC1;ngeles, VIII Regi&#xF3;n, para la obra &quot;Camino Ruta Q-15, Sector Los &#xC1;ngeles - Santa Clara, Km. 0,00000 al Km. 10,35968&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario N&#xE9;stor Hugo Hermosilla Catal&#xE1;n y Otros, ascendente a la cantidad de $4.407.448.- para los lotes N&#xBA;s 15, 16, 17, 18 y 19.</div><br></div>", "i": 6745637}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6745638}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "663 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-663 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-29", "doble_articulado": false, "id_norma": "267166", "numero_fuente": "38926", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-01", "vigencias": [{"desde": "2007-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-12-04", "fecha_vers