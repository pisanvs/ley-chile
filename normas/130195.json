{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 619 DE 1998</div><br><br></div>", "i": 6149294}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 619 de 13 de noviembre de 1998, se ha aprobado el convenio de fecha 30 de septiembre de 1998, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Santiago, que modifica el convenio de traspaso del Liceo &apos;&apos;Juan Antonio R&#xED;os&apos;&apos; (Ex A N&#xBA; 31) de Santiago, traspasada a dicha Corporaci&#xF3;n por convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 460, de 24 de junio de 1986. </div></div>", "i": 6149295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6149296}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "619", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-619"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 619 DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-13", "doble_articulado": false, "id_norma": "130195", "numero_fuente": "36267", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-19", "vigencias": [{"desde": "1999-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-01-19", "fecha_version": "1999-01-19", "fec