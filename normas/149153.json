{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 11.355 EXENTA, DE 1999 </div><br></div>", "i": 6211289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 11.355, de 22 de noviembre de 1999, se ha aprobado al Instituto Nacional &apos;&apos;General Jos&#xE9; Miguel Carrera&apos;&apos;, comuna de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para primero y segundo a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000, de acuerdo a la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 220 de 1998.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 6211290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de diciembre de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6211291}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11355 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11355 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 11.355 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-11-22", "doble_articulado": false, "id_norma": "149153", "numero_fuente": "36535", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-10", "vigencias": [{"desde": "1999-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-10", "fin_vigencia": ""},