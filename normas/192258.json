{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6360187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 98, de fecha 2 de noviembre del a&#xF1;o 2001, se autoriz&#xF3; la existencia y se aprob&#xF3; el estatuto de la Cooperativa de Abastecimiento de Energ&#xED;a El&#xE9;ctrica San Pedro de Atacama, de San Pedro de Atacama, en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica suscrita con fecha 22 de junio de 2001, ante el Notario de Arica, don Juan Hugo Silva Pe&#xF1;ailillo, suplente del titular, don V&#xED;ctor Warner Sarria, repertorio N&#xBA; 1.794; rectificada mediante acta complementaria reducida a escritura p&#xFA;blica con fecha 12 de octubre de 2001, ante el Notario de Arica, don V&#xED;ctor Warner Sarria.</div><div class=\"p\">Repertorio N&#xBA; 3.200.</div><br></div>", "i": 6360188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6360189}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "98", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-98"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-02", "doble_articulado": false, "id_norma": "192258", "numero_fuente": "37127", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-12-04", "vigencias": [{"desde": "2001