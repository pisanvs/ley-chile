{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6025171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 1.589 de 14 de Diciembre de 1994, se autoriz&#xF3; a la sociedad Empresa de Transportes G&#xE9;minis Limitada (G&#xE9;minis Limitada), para efectuar transporte internacional terrestre de pasajeros entre Iquique (Chile) y Asunci&#xF3;n (Paraguay) en tr&#xE0;nsito por territorio argentino, utilizando los pasos fronterizos de Sico o Jama, con una frecuencia semanal de ida y vuelta.-</div><br></div>", "i": 6025172}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Claudio Hohmann Barrientos, Subsecretario de Transportes.</div><br></div>", "i": 6025173}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1589 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1589 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TRANSPORTES VIA GEMINIS LIMITADA", "TRANSPORTE", "INTERNACIONAL", "TRANSPORTE PASAJEROS", "IQUIQUE", "ASUNCION", "CHILE", "PARAGUAY"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-14", "doble_articulado": false, "id_norma": "39855", "numero_fuente": "35104", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-02-27", "vigencias": [{"desde": "1995-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-02-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "19