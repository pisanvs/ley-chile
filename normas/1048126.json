{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9327964}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;3063, de 04 de diciembre de 2012, se modific&#xF3; el <a href=\"https://www.leychile.cl/Navegar?idNorma=1044377&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xBA;1997, de 31 de agosto de 2012</a>, que orden&#xF3; la expropiaci&#xF3;n del lote de terreno N&#xBA;55L6, en el sentido que se modific&#xF3; el numeral 1&#xB0;, en cuanto a que dicho lote se expropia para la EMPRESA DE TRANSPORTE DE PASAJEROS METRO S.A. y no para el Fisco como se indic&#xF3; inicialmente. </div></div>", "i": 9327965}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9327966}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3063 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3063 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-04", "doble_articulado": false, "id_norma": "1048126", "numero_fuente": "40459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-15", "vigencias": [{"desde": "2013-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1289", "fecha_ingreso": "2013-01-15", "