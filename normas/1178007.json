{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10345433}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xBA; 29, del 24 de junio de 2022, que establece &quot;Instruye sobre sanciones del N&#xBA; 6 del <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=9298702&amp;idVersion=\">art&#xED;culo 41 E</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=&amp;idVersion=\">Ley sobre Impuesto a la Renta</a> (LIR), por la no presentaci&#xF3;n de las declaraciones juradas a que se refiere dicha norma, o su presentaci&#xF3;n err&#xF3;nea, incompleta, extempor&#xE1;nea, o maliciosamente falsa. Deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=1160129&amp;idVersion=2022-06-30\">circular N&#xBA; 32 de 2021</a>.&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div><br></div>", "i": 10345434, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Andr&#xE9;s Frigolett C&#xF3;rdova, Director.</div><div class=\"p\"> </div><br></div>", "i": 10345435}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "29", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-29"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2149530", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-06-24", "doble