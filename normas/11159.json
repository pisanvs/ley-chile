{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACEPTA RENUNCIA VOLUNTARIA A SUBSECRETARIO DE HACIENDA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 220.- Santiago, 11 de Marzo de 1994.- Vistos: Lo dispuesto por el art&#xED;culo 32&#xB0; N&#xB0; 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica;</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 5901596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ac&#xE9;ptase, a contar del 11 de Marzo de 1994, la renuncia voluntaria presentada por don Jos&#xE9; Pablo Arellano Mar&#xED;n, a su cargo de Subsecretario de Hacienda. </div></div>", "i": 5901597}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Alejandro Foxley Rioseco, Ministro de Hacienda.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Jos&#xE9; Pablo Arellano Mar&#xED;n, Subsecretario de Hacienda.</div><br></div>", "i": 5901598}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "220", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-220"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ACEPTA RENUNCIA VOLUNTARIA A SUBSECRETARIO DE\nHACIENDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RENUNCIA VOLUNTARIA", "JOSE PABLO ARELLANO MARIN", "SUBSECRETARIO", "MINISTERIO HACIENDA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-11", "doble_articulado": false, "id_norma": "11159", "numero_fuente": "34826", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-28", "vigencias": [{"desde": "1994-03-28", "hasta": "", "tipo_versi