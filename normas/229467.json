{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6493576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.219, de 18 de agosto de 2004, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.904, de 2004, de esta Subsecretar&#xED;a, que declar&#xF3; la caducidad de la resoluci&#xF3;n N&#xBA; 2.665, de 1999, que otorg&#xF3; a PESQUERA GRIMAR S.A. un permiso extraordinario de pesca para la unidad de pesquer&#xED;a de Bacalao de profundidad, por haber sido dictado en virtud de error de hecho.</div><br></div>", "i": 6493577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6493578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2219 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2219 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-18", "doble_articulado": false, "id_norma": "229467", "numero_fuente": "37944", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-24", "vigencias": [{"desde": "2004-08-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-08-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-08-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingres