{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE QUE LA ESCUELA N&#xB0; 72 DE LA ISLA DE PASCUA SE DENOMINARA &quot;ESCUELA LORENZO BAEZA VEGA&quot;</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5971257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La Escuela N&#xB0; 72 de la Isla de Pascua se denominar&#xE1; &quot;Escuela Lorenzo Baeza Vega&quot;. </div></div>", "i": 5971258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintis&#xE9;is de Septiembre de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Francisco B&#xF3;rquez Jopia.</div><br></div>", "i": 5971259}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12145", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12145"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DISPONE QUE LA ESCUELA N° 72 DE LA ISLA DE PASCUA SE DENOMINARA ESCUELA LORENZO BAEZA VEGA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "ESCUELA LORENZO BAEZA VEGA", "ISLA PASCUA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-09-26", "doble_articulado": false, "id_norma": "27045", "numero_fuente": "23570", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-10-10", "vigencias": [{"desde": "1956-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1956-10-10", "fin