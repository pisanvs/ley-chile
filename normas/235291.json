{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;1.352 EXENTA, DE 2004 </div></div>", "i": 6515307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Res. (E) N&#xBA; 1.352, de 28.12.2004, modific&#xF3; Res. (E) N&#xBA; 1.219, de 06.12.2004, siguientes aspectos:</div><br><div class=\"p\">-&nbsp; &nbsp; Resuelvos 3 y 5, reemplaz&#xF3;se alocuci&#xF3;n &quot;30 de noviembre de 2004&quot; por &quot;30 de diciembre de 2004&quot;.</div><div class=\"p\">-&nbsp; &nbsp; Resuelvo 4, reemplaz&#xF3;se alocuci&#xF3;n &quot;1 al 17 de diciembre de 2004&quot; por &quot;3 al 7 de enero de 2005&quot;.</div><div class=\"p\">-&nbsp; &nbsp; Resuelvo 6, reemplaz&#xF3;se alocuci&#xF3;n &quot;20 de diciembre de 2004&quot; por &quot;10 de enero de 2005&quot;.</div><br></div>", "i": 6515308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Secretario Regional Ministerial Vivienda y Urbanismo Regi&#xF3;n de Los Lagos.</div><br></div>", "i": 6515309}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1352 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1352 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº1.352 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-28", "doble_articulado": false, "id_norma": "235291", "numero_fuente": "38079", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-02-05", "vigencias": [{"desde": "2005-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-02-05", "fin_vigencia": ""