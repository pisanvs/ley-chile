{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 681 EXENTO, DE 1995 </div></div>", "i": 7162214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 681 de 20 de diciembre de 1995, se ha modificado, a partir del a&#xF1;o escolar 1995, el art&#xED;culo 1&#xB0; del decreto supremo exento de Educaci&#xF3;n N&#xB0; 13 de 1992, que aprob&#xF3; planes y programas especiales de estudio al &quot;Grange School&quot; de Santiago.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas especiales de estudio para las asignaturas de Teatro y Estudio del Desarrollo Econ&#xF3;mico y Social para el 1&#xB0; y 2&#xB0; a&#xF1;o de educaci&#xF3;n media.</div><br></div>", "i": 7162215, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de diciembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162216}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "681 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-681 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 681 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GRANGE SCHOOL", "SANTIAGO", "REGION METROPOLITANA", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-12-20", "doble_articulado": false, "id_norma": "21681", "numero_fuente": "35365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-01-13", "vigencias": [{"desde": "1996-01-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996