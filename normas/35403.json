{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 702, de 12 de abril de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la autorizaci&#xF3;n concedida por el D.S. N&#xB0; 114, de 1978, del Ministerio de Agricultura, que autoriz&#xF3; a la SOCIEDAD PESQUERA NUEVA AURORA LTDA. para desarrollar actividades pesqueras con la nave &quot;Tuc&#xE1;n&quot;, en virtud de lo dispuesto en el art&#xED;culo 143, letra b) del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8293768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "702", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-702"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD PESQUERA NUEVA AURORA LTDA", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-12", "doble_articulado": false, "id_norma": "35403", "numero_fuente": "35447", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-20", "vigencias": [{"desde": "1996-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-04-20", "fin_vigencia": "", "tipo_version": "