{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA;513 EXENTA, DE 2008 </div></div>", "i": 7367279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 513, de 14 de marzo de 2008, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xBA;5 de la resoluci&#xF3;n N&#xBA;65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo como combustible:</div><br><div class=\"p\">Empresa&nbsp; &nbsp; &nbsp; Nombre del&nbsp;  Direcci&#xF3;n del&nbsp; &nbsp;  Ciudad</div><div class=\"p\">Habilitada&nbsp;  Taller&nbsp; &nbsp; &nbsp;  Taller</div><br><div class=\"p\">Italgas&nbsp; &nbsp; &nbsp; Garage&nbsp; &nbsp; &nbsp;  Patricio Lynch&nbsp; &nbsp; Osorno</div><div class=\"p\">S.A.&nbsp; &nbsp; &nbsp; &nbsp;  Guillmos&nbsp; &nbsp;  N&#xBA;1948</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.</div><br><br></div>", "i": 7367280}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Elinett Wolff Rioseco, Subsecretaria de Transportes.</div><br></div>", "i": 7367281}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "513 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-513 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº513 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-03-14", "doble_articulado": false, "id_norma": "270296",