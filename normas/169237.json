{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6277103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 203 de 17 de marzo de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Xa. Regi&#xF3;n, se autoriza a Jos&#xE9; Matamala Arriagada para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xB0; 1 &quot;Francke Centro - Rahue Alto&quot; de Osorno, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xB0; 090 de 12 de junio de 1984 y modificado por resoluci&#xF3;n exenta N&#xB0; 464 de 16 de septiembre de 1986, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6277104}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones Xa. Regi&#xF3;n.</div><br><br></div>", "i": 6277105}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "203 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-203 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-03-17", "doble_articulado": false, "id_norma": "169237", "numero_fuente": "32918", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-12", "vigencias": [{"desde": "1987-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc