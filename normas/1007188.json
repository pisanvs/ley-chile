{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8789774}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA; 1576 de fecha 30 de septiembre de 2009, se expropi&#xF3; el lote de terreno N&#xBA; 13, superficie 6.820 m2, rol N&#xBA; 183-1, comuna de Quilicura, para la obra &quot;Mejoramiento del Cauce del Estero Las Cruces&quot;, Comunas de Quilicura y Pudahuel, Provincia de Santiago, Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario BANCO DEL DESARROLLO, ascendente a la cantidad de $286.976.000. </div></div>", "i": 8789775}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 8789776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1576 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1576 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-09-30", "doble_articulado": false, "id_norma": "1007188", "numero_fuente": "39486", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-10-15", "vigencias": [{"desde": "2009-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-10-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2009-10-15", "fecha_version": "2009-10-15", "actualizado_por": "1289", "fecha_actualizacion_texto": "20