{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 470 EXENTA, DE 16 DE ENERO DE 2020</div></div>", "i": 10154040}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=277455&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 4.748, de 2008, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Colegio San Ignacio El Bosque, RBD 8996-6, comuna de Providencia, Regi&#xF3;n Metropolitana, en el sentido de sustituir los planes de estudio de 3&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10154041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de enero de 2020.- Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10154042}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "470 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-470 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 470 EXENTA, DE 16 DE ENERO DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1806081", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-16", "doble_articulado": false, "id_norma": "1148767", "numero_fuente": "42741", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-08-27", "vigencias": [{"desde": "2020-08-27", "hasta": "", "tipo_version