{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.692</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.692, celebrada el 27 de noviembre de 1985, adopt&#xF3; los siguientes acuerdos: </div></div>", "i": 6268582}, {"t": "<div><div class=\"p\">1692-09-851127- Modifica Acuerdo No. 1555-07-840209 relacionado con compra de cartera a instituciones financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar, en el inciso tercero del n&#xFA;mero 3 del Acuerdo No. 1555-07-840209 y sus modificaciones, la fecha &quot;30 de septiembre de 1985&quot; por &quot;30 de junio de 1986&quot;.</div><br></div>", "i": 6268583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de noviembre de 1985.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6268584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1692", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1692"}, {"tipo": "5", "numero": "1692-09", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1692-09"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL COMITE EJECUTIVO DEL BANCO\nCENTRAL DE CHILE EN SU SESION No. 1.692", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-27", "doble_articulado": false, "id_norma": "166601", "numero_fuente": "32333", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-11-28", "vigencias": [{"desde": "1985-11-28", "hasta": "", "tipo_version": "3", "