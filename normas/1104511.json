{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xBA; 1.485 EXENTA, DE 29 DE MAYO DE 2017</div></div>", "i": 9808604}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.485, de 29 mayo de 2017, de la Subsecretar&#xED;a de Transportes, se modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1053791&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.587 de 2013</a>, de la Subsecretar&#xED;a de Transportes, en el sentido de reemplazar el texto que se extiende en el literal d) punto i), por el texto que establece &quot;Procedimiento de Ajuste seg&#xFA;n porcentaje de cumplimiento de Frecuencias&quot;. Texto &#xED;ntegro de la resoluci&#xF3;n exenta N&#xBA; 1.485, de 2017, estar&#xE1; disponible para ser consultada en la p&#xE1;gina web www.mtt.cl.</div></div>", "i": 9808605}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Carlos Melo Riquelme, Subsecretario de Transportes.</div></div>", "i": 9808606}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1485 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1485 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO RESOLUCIÓN Nº 1.485 EXENTA, DE 29 DE MAYO DE 2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; CVE 1231327"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-05-29", "doble_articulado": false, "id_norma": "1104511", "numero_fuente": "41791", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-06-23", "vigencias": [{"desde": "2017-06-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici