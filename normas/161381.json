{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6251921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 206, de 31 de enero de 2000, se expropiaron los lotes de terreno N&#xBA;s. 42-B y 42-C, superficies 11.509 m&#xB2; y 11.346 m&#xB2;, rol de aval&#xFA;o 1547-219, comuna de Los Angeles, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Chill&#xE1;n-Collipulli, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Clotilde del Carmen Novoa Pe&#xF1;a, ascendente a la cantidad total de $28.368.757.</div><br></div>", "i": 6251922}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6251923}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "206", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-206"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-31", "doble_articulado": false, "id_norma": "161381", "numero_fuente": "36614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-15", "vigencias": [{"desde": "2000-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-03-17", "fecha_version": "2000-03-15", "fecha_actualizacion_texto": "2000-03-15", "tipo_tratado": ""}, "alertas": [], "alerta_glob