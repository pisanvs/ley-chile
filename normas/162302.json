{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6254917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0; 240, de 23 de Agosto de 1985, se expropi&#xF3; el lote N&#xB0; 1 y se constituy&#xF3; servidumbre de acueducto en los lotes N&#xB0;s. 2 y 3, rol de aval&#xFA;o 289-30, Comuna de San Fernando, VI Regi&#xF3;n, cuyas superficies son 33.660, 2.840 y 1.750 m2. respectivamente, para Mejoramiento del Sistema de Abastecimiento de Agua Potable de San Fernando, captaci&#xF3;n con drenes y aducci&#xF3;n y se acord&#xF3; el precio de indemnizaci&#xF3;n total con su propietario don Bruno Margozzini Cella, ascendente a $ 7.431.976.-</div><br></div>", "i": 6254918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6254919}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "240", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-240"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-08-23", "doble_articulado": false, "id_norma": "162302", "numero_fuente": "32285", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-01", "vigencias": [{"desde": "1985-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-03-23", "fecha_version": "1985-10-01", "f