{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6422450}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 153 de 31 de marzo de 2003, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del decreto exento MOP N&#xBA; 742, de 31 de mayo de 2001, en la parte que se refiere al Convenio Directo de Precio Ad-Referendum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 1, fijada por la Comisi&#xF3;n de Peritos, con fecha 3 de agosto de 1999, ascendente a la cantidad de $886.500.</div><br></div>", "i": 6422451}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6422452}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "153 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-153 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-31", "doble_articulado": false, "id_norma": "209867", "numero_fuente": "37548", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-02", "vigencias": [{"desde": "2003-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-05-0