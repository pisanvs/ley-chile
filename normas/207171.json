{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6412154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 92, de 14 de enero de 2003, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.964 de 1992, de esta Subsecretar&#xED;a, que declar&#xF3; la caducidad parcial de la resoluci&#xF3;n N&#xBA; 168 de 1997, modificada por resoluci&#xF3;n N&#xBA; 550 de 1999, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autorizaron a ALIMENTOS MARINOS S.A. para operar la nave &quot;Santa Irene&quot;, en la V a la VII y X Regiones, sobre el recurso Sardina com&#xFA;n, Anchoveta y Merluza de cola.</div><br></div>", "i": 6412155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de enero de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6412156}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "92", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-92"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-14", "doble_articulado": false, "id_norma": "207171", "numero_fuente": "37473", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-31", "vigencias": [{"desde": "2003-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":