{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6376579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;655, de 27 de marzo de 2002, modif&#xED;case el n&#xFA;meral 5&#xBA; inciso 1&#xBA; de la resoluci&#xF3;n N&#xBA;579 de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD CATOLICA DE VALPARAISO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto de Investigaci&#xF3;n denominado &quot;Evaluaci&#xF3;n directa de Langostino colorado (Pleuroncodes monodon) en la IV Regi&#xF3;n&quot;, en el sentido de se&#xF1;alar que las embarcaciones participantes podr&#xE1;n extraer las siguientes cantidades de las especies en estudio: Langostino colorado 25 toneladas, Langostino amarillo 20 toneladas, Camar&#xF3;n nailon 6,5 toneladas. </div></div>", "i": 6376580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de marzo de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6376581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "655", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-655"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-27", "doble_articulado": false, "id_norma": "196634", "numero_fuente": "37233", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-12", "vigencias": [{"desde": "2002-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "20