{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 107.- Santiago, 14 de Mayo de 1993.- Visto: Lo dispuesto en el art&#xED;culo 4&#xB0; del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br><br></div>", "i": 8938292}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Ministros de Fe para actuar en las<div class=\"n rnp\" id=\"rnp0\"><a href=\"#np0\">NOTA:</a></div> localidades ubicadas en la Regi&#xF3;n Metropolitana, en que no hayan Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><div class=\"p\">&nbsp; &nbsp;  - Mauricio Campos Morales</div><div class=\"p\">&nbsp; &nbsp;  - Ronald Walker Riesle</div><div class=\"p\">&nbsp; &nbsp;  - Sergio D&#xED;az Concha</div><br><div class=\"np\" id=\"np0\"><a href=\"#rnp0\">NOTA:</a> <br>&nbsp; &nbsp;  La RES 220, Agricultura, publicada el 07.08.1999 modific&#xF3; la presente resoluci&#xF3;n en el sentido de eliminar en la Regi&#xF3;n Metropolitana al se&#xF1;or Mauricio Campos Morales como Ministro de Fe.<br></div></div>", "i": 8938293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional.</div><br></div>", "i": 8938294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "107", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-107"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTRO FE", "REGION METROPOLITANA", "MAURICIO CAMPOS MORALES", "RONALD WALKER RIESLE", "SERGIO DIAZ CONCHA"], "categorias_norma": [], "nombres_uso_comun": [], "pa