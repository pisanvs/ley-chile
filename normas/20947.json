{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 302 EXENTO, DE 1996 </div></div>", "i": 5943657}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 302, de fecha 28 de mayo de 1996, del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura Cidec, para impartir planes y programas de estudios aprobados para la instituci&#xF3;n, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se se&#xF1;alan, a partir del a&#xF1;o 1996:</div><div class=\"p\"> Sede N&#xB0; 2 :&nbsp; La Serena</div><div class=\"p\"> Carrera&nbsp;  :&nbsp; Asistente Judicial</div><div class=\"p\"> T&#xED;tulo&nbsp; &nbsp; :&nbsp; T&#xE9;cnico Asistente Judicial</div><div class=\"p\"> Carrera&nbsp;  :&nbsp; T&#xE9;cnico en Bienestar Social</div><div class=\"p\"> T&#xED;tulo&nbsp; &nbsp; :&nbsp; T&#xE9;cnico en Bienestar Social</div><br></div>", "i": 5943658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 2 de julio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943659}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "302", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-302"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 302 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO INTERAMERICANO EDUCACION CULTURA CIDEC", "AUTORIZACION", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "LA SERENA", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-28", "doble_articulado": false, "id_norma": "20947", "nu