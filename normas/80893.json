{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6058383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 1.073, de 31 de octubre de 1997, se expropiaron los lotes de terreno N&#xBA;s. 7, 8, 9, 13, 14, 15, 16, 17, 18 y 19, superficies 1.313; 553; 104; 200; 574; 276; 302; 223; 339 y 1.096 m&#xB2;, respectivamente, roles de aval&#xFA;os 1006-48, 1006-66 y 1021-61, comuna de Ais&#xE9;n, obra Reposici&#xF3;n Ruta X-50, sector Cruce Ruta 7 (Ma&#xF1;ihuales) -Cruce Ruta 240 Ch-Ays&#xE9;n, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Claudio Bambs Bambs y V&#xED;ctor Hugo Yubano Schwerter, ascendente a las cantidades de $533.806 y $372.850.</div><br></div>", "i": 6058384}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6058385}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1073", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1073"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "AYSEN", "DECIMOPRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-31", "doble_articulado": false, "id_norma": "80893", "numero_fuente": "35930", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-01", "vigencias": [{"desde": "1997-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione