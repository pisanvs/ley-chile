{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA </div><div class=\"p\">N&#xFA;m. 55.- Santiago, 1&#xBA; de Marzo de 1991.- Vistos: Lo dispuesto en el Art&#xED;culo 4&#xBA; del Decreto Ley No.2.974, de 1979</div><br><div class=\"p\">Resuelvo:</div><br><br></div>", "i": 8949770}, {"t": "<div><br><div class=\"p\">Des&#xED;gnanse como Ministros de Fe para actuar en las<div class=\"n rnp\" id=\"rnp0\"><a href=\"#np0\">NOTA:</a></div> localidades ubicadas en la Regi&#xF3;n Metropolitana, en que no hayan Notarios ni Oficiales del Registro Civil, a los siguientes funcionarios:</div><br><div class=\"p\"> - Angel Rogelio Vilches Ubeda</div><div class=\"p\"> - Aurelio Ram&#xF3;n Mallea Santib&#xE1;&#xF1;ez</div><br><div class=\"np\" id=\"np0\"><a href=\"#rnp0\">NOTA:</a> <br>&nbsp; &nbsp;  La RES 219, Agricultura, publicada el 07.08.1999 modific&#xF3; la presente resoluci&#xF3;n en el sentido de eliminar en la Regi&#xF3;n Metropolitana al se&#xF1;or Angel Rogelio Vilches Ubeda como Ministro de Fe.<br></div></div>", "i": 8949771}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional. </div></div>", "i": 8949772}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "55", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-55"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-01", "doble_articulado": false, "id_norma": "8823