{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 1,387.- Santiago, a 21 de Noviembre de 1900.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de trescientos cincuenta mil pesos al &#xED;tem 16 de la partida 13 del presupuesto de Guerra, &quot;para construcciones, reparaciones, aseo i conservacion de los fuertes de Talcahuano&quot;.</div><br></div>", "i": 5949042}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Arturo Besa.</div><br></div>", "i": 5949043}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1387", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1387"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1900", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-11-21", "doble_articulado": false, "id_norma": "22608", "numero_fuente": "6753", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-11-27", "vigencias": [{"desde": "1900-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-11-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-11-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"