{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; EXPROPIACION</div><br></div>", "i": 6494954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Decreto secci&#xF3;n 2&#xAA; N&#xBA; 106 de 18-08-2004, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n total, conforme art&#xED;culo 85 decreto 458 Ministerio Vivienda y Urbanismo, inmueble Lord Cochrane 499, Rol 648-6, comuna Santiago, dominio aparente do&#xF1;a Laura L&#xF3;pez Toledo. Superficie aproximada y deslindes 508,70 metros cuadrados. Norte, 35,70 metros Parque Almagro. Sur, igual dimensi&#xF3;n Avda. Santa Isabel. Oriente, 14,50 metros calle Lord Cochrane. Poniente, igual dimensi&#xF3;n otros propietarios. Indemnizaci&#xF3;n $86.479.000.- pagadera al contado.</div><br></div>", "i": 6494955}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Joaqu&#xED;n Lav&#xED;n I. Alcalde de Santiago. </div></div>", "i": 6494956}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "106", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-106"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-18", "doble_articulado": false, "id_norma": "229758", "numero_fuente": "37951", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-01", "vigencias": [{"desde": "2004-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente