{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 1.271, de 16 de junio de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8793476}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=242092&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 1.111, de 21 de junio de 2005</a> y autorizada transferir por <a href=\"https://www.leychile.cl/Navegar?idNorma=264585&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 1.412, de 5 de julio de 2007</a>, ambas del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, en el sentido de reemplazar el p&#xE1;rrafo 4.- y el p&#xE1;rrafo 3.-, de ambas resoluciones, respectivamente, por el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n exenta 796, de 30 de marzo de 2005, modificada por resoluci&#xF3;n exenta 63, de 8 de enero de 2009, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;</div><br></div>", "i": 8793477}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de octubre de 2009.- Por la Sra. Subsecretaria, Humberto Ram&#xED;rez Navarro, Subjefe Subsecretar&#xED;a de Marina.</div></div>", "i": 8793478}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1271", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1271"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": []