{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 233 de 8 de Marzo de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deneg&#xF3; la solicitud de concesi&#xF3;n de acuicultura presentada por don EDELBERTO LUIS HALLER VOLCKE, para un sector ubicado en el Sector de Chanque, R&#xED;o Maull&#xED;n, Provincia de Llanquihue, X Regi&#xF3;n, en virtud de lo dispuesto en los art&#xED;culos 76&#xB0;, 77&#xB0;, 78&#xB0; y 5&#xB0; transitorio inciso 6&#xB0;, de la Ley General de Pesca y Acuicultura y el art&#xED;culo 14&#xB0; del D.S. N&#xB0; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. Asimismo, se dej&#xF3; sin efecto las Resoluciones N&#xB0; 1357, de 1989 y N&#xB0; 39, de 1992, ambas de esta Subsecretar&#xED;a.</div><br></div>", "i": 8291254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 8 de Marzo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "233", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-233"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION ACUICULTURA", "DENEGACION", "DECIMA REGION", "EDELBERTO HALLER VOLCKE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-03-08", "fecha_derogacion": "2000-02-01", "doble_articulado": false, "id_norma": "33867", "numero_fuente": "35120", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1995-03-17", "vigencias":