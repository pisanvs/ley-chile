{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 202, DE 2011</div><br></div>", "i": 9131123}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 202, de 15 de marzo de 2011, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la III Regi&#xF3;n de Atacama, se dispuso el cierre de la Planta de Revisi&#xF3;n T&#xE9;cnica Clase A 0305, que practica revisi&#xF3;n t&#xE9;cnica de veh&#xED;culos Clase A, en la comuna de Copiap&#xF3;, Tercera Regi&#xF3;n de Atacama, concesionada a do&#xF1;a Silvia Vivanco Lepe, a contar del 15 de marzo de 2011, y se declara la extinci&#xF3;n de la Pr&#xF3;rroga del Contrato de Concesi&#xF3;n de la misma Planta Revisora.- </div></div>", "i": 9131124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alberto Fernando Barrionuevo Pinto, Secretario Regional Ministerial de Transportes y Telecomunicaciones Tercera Regi&#xF3;n de Atacama.</div></div>", "i": 9131125}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "202", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-202"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 202, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-03-15", "doble_articulado": false, "id_norma": "1024354", "numero_fuente": "39931", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-04-08", "vigencias": [{"desde": "2011-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"