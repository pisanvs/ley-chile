{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 377, de 14 de marzo de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud presentada por PESCA SURIBERICA S.A., para ampliaci&#xF3;n de &#xE1;rea de actividad pesquera en zona de la Convenci&#xF3;n para la Conservaci&#xF3;n de los Recursos Vivos Marinos Ant&#xE1;rticos (CCRVMA), sobre los recursos Dissostichus eleginoides y Dissostichus mawsoni con las naves &quot;Isla Sof&#xED;a&quot;, &quot;Isla Isabel&quot; e &quot;Isla Camila&quot;, en virtud de lo establecido en la medida de conservaci&#xF3;n 31/X de la CCRVMA. </div></div>", "i": 8301916}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de marzo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "377", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-377"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA SURIBERICA S.A.", "PESCA", "DENEGACION", "SOLICITUD", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-14", "doble_articulado": false, "id_norma": "70073", "numero_fuente": "35723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-22", "vigencias": [{"desde": "1997-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-03-22", "fin_vigencia": ""}, "