{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6505943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.249, de 11 de noviembre</div><div class=\"p\">de 2004 de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de</div><div class=\"p\">la autorizaci&#xF3;n de acuicultura y d&#xE9;jase sin efecto la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 903 de 1995, de esta Subsecretar&#xED;a,</div><div class=\"p\">otorgada a CARLOS HERNAN SALGADO FUENTES, para una</div><div class=\"p\">piscicultura ubicada en un sector de Hijuela La Capilla,</div><div class=\"p\">localidad de Bajo Perqu&#xED;n, VII Regi&#xF3;n, en virtud de los</div><div class=\"p\">art&#xED;culos 82 y 142 letra f) de la Ley General de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp;  Rech&#xE1;zase la solicitud presentada por Mar&#xED;a Eugenia Pe&#xF1;ailillo Gonz&#xE1;lez, para continuar operando la piscicultura ya individualizada y modificar su proyecto t&#xE9;cnico.</div><br></div>", "i": 6505944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6505945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3249 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3249 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-11", "doble_articulado": false, "id_norma": "232773", "numero_fuente": "38016", "tipo_version": "3", "tipo_version_s": "Única", "fech