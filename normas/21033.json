{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0;341, DE 1993 </div></div>", "i": 7161654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0;341 de fecha 01 de Julio de 1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el art&#xED;culo 1&#xB0; del Decreto Exento de Educaci&#xF3;n N&#xB0;235 de 24.11.87 correspondiente al Instituto Profesional VIPRO, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo 1&#xB0;: Autor&#xED;zase el funcionamiento del Instituto Profesional que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala:</div><div class=\"p\"> Nombre de la instituci&#xF3;n: Instituto Profesional VIPRO.</div><div class=\"p\"> Domicilio:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Santiago.</div><div class=\"p\"> Organizador:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Sociedad Instituto</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Profesional Vicente P&#xE9;rez</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Rosales Limitada o I.P.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  VIPRO Limitada S.A.&quot;.</div><br></div>", "i": 7161655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7161656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "341 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-341 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°341, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL VIPRO", "SANT