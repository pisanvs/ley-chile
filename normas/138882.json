{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 167 EXENTO, DE 1999</div><br><br></div>", "i": 6176825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 167 de fecha 1&#xBA; de julio de</div><div class=\"p\">1999 del Ministerio de Educaci&#xF3;n, se rectific&#xF3; el</div><div class=\"p\">art&#xED;culo 1&#xBA; del decreto exento N&#xBA; 118 del 30 de abril de 1999, correspondiente al cambio de nombre de la Universidad Alonso de Ovalle, en el siguiente sentido:</div><br><div class=\"p\">Dice: Corporaci&#xF3;n Universidad Alonso de Ovalle. Debe decir: Universidad Alonso de Ovalle.</div><div class=\"p\">Dice: Corporaci&#xF3;n Universidad Francisco de Vitoria. Debe decir: Universidad Francisco de Vitoria. </div></div>", "i": 6176826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de julio de 1999.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6176827}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "167 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-167 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 167 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-07-01", "fecha_derogacion": "2001-07-19", "doble_articulado": false, "id_norma": "138882", "numero_fuente": "36410", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-07-12", "vigencias": [{"desde": "2001-07-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-07-12", "hasta": "2001-07-18", "tipo_version": "0", "tipo_version_s": "T