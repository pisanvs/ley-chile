{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9296491}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;1794, de 30 de agosto de 2012, y de conformidad a lo dispuesto en el art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;54, superficie 273 m2., Rol N&#xBA;62-533, para la obra &quot;MEJORAMIENTO RUTA T-85, VARIOS TRAMOS EN LAGO RANCO - CALCURRUPE&quot;, comuna de Lago Ranco, Regi&#xF3;n de Los R&#xED;os. La comisi&#xF3;n de peritos integrada por Patricio Fernando Casagrande Ulloa, Karin Alicia Ernst Elizalde y Mar&#xED;a Soledad N&#xFA;&#xF1;ez Arroyo, fij&#xF3; el valor de tasaci&#xF3;n con fecha 26 de mayo de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario ANTONIO LEANDRO OJEDA DELGADO, en la cantidad de $1.373.062.- suma que se pagar&#xE1; al contado. </div></div>", "i": 9296492}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9296493}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1794 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1794 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-08-30", "doble_articulado": false, "id_norma": "1043962", "numero_fuente": "40364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-15", "vigencias": [{"desde": "2012-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-15", "fin_vigencia": ""}, "vigencias_version_norm