{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 118.- Santiago, a 24 de Noviembre de 1893.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de ocho mil pesos ($ 8,000) al &#xED;tem 5 de la partida 3.a del presupuesto del Ministerio del Interior para publicaciones de &#xE1;mbas C&#xE1;maras.</div><br><br></div>", "i": 8273735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 8273736}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "118", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-118"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1893", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-11-24", "doble_articulado": false, "id_norma": "21983", "numero_fuente": "4677", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-11-24", "vigencias": [{"desde": "1893-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-11-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-11-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-06", "f