{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8326667}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 803, de 13 de Julio de 1989, de esta Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 719, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a do&#xF1;a Marianela Soto Risco, R.U.T. No. 9.235.406-7, domiciliada en Isla del Rey, Correo Central de Corral, X Regi&#xF3;n, para desarrollar actividades pesqueras de cultivo, en el sentido de sustituir en su numeral 2&#xB0; la expresi&#xF3;n &quot;fondo de mar&quot; por &quot;fondo de r&#xED;o&quot;.</div><br></div>", "i": 8326668}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 13 de Julio de 1989.- Roberto Cabezas Bello Subsecretario de Pesca.</div><br></div>", "i": 8326669}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "803", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-803"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-13", "doble_articulado": false, "id_norma": "95760", "numero_fuente": "33431", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-25", "vigencias": [{"desde": "1989-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-07-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac