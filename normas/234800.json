{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION O N&#xBA; 5, DE 2005 </div></div>", "i": 6513598}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n O N&#xBA; 0005 de esta fecha del Servicio Electoral, se ha dispuesto que las caracter&#xED;sticas de impresi&#xF3;n de la c&#xE9;dula oficial que se utilizar&#xE1; en la elecci&#xF3;n de Alcalde en la comuna de Talcahuano, que se realizar&#xE1; el domingo 23 de enero de 2005, ser&#xE1;n las establecidas en la Resoluci&#xF3;n O N&#xBA; 1.493, de fecha 10 de agosto de 2004, publicada en extracto en el Diario Oficial del 16 del mismo mes y a&#xF1;o, con excepci&#xF3;n del guarismo &quot;2004&quot; que ser&#xE1; sustituido por el guarismo &quot;2005&quot;.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se hace en virtud de lo contemplado en el art&#xED;culo 27 de la ley N&#xBA; 18.700.</div><br></div>", "i": 6513599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de enero de 2005.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6513600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-5"}, {"tipo": "3", "numero": "O-5", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-5"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "EXTRACTO DE RESOLUCION O Nº 5, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELECCIONES MUNICIPALES", "23-ENE-2005", "ELECCION DE ALCALDE", "TALCAHUANO", "CEDULA OFICIAL DE VOTACION", "CARACTERISTICAS", "VOTO ELECTORAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-01-03", "doble_articulado": false, "id_norma": "234800", "nume