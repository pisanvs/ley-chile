{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291502}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 272, de 9 de Marzo de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto las Resoluciones N&#xB0; 1.181 y N&#xB0; 1.182, ambas de 1992, de esta Subsecretar&#xED;a, que autorizaron a ACTIVIDADES INTEGRADAS S.A., R.U.T. N&#xB0; 96.606.260-6, para operar las naves &quot;Isla Buamblin&quot; e &quot;Isla Guafo&quot;, respectivamente, en el &#xE1;rea de pesca correspondiente a la sub-&#xE1;rea estad&#xED;stica Georgia del Sur, por renuncia de su titular.</div><br></div>", "i": 8291503}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 9 de Marzo de 1994.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8291504}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "272", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-272"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "ACTIVIDADES INTEGRADAS S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-09", "doble_articulado": false, "id_norma": "34097", "numero_fuente": "34821", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-22", "vigencias": [{"desde": "1994-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-03-22", "fin_vigencia": "", "tipo_version": "