{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,141.- Santiago, 7 de diciembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6161586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- El&#xE9;vase, por gracia, a cien pesos mensuales la pensi&#xF3;n de montep&#xED;o militar de que actualmente disfruta do&#xF1;a Eloisa Silva, viuda del capit&#xE1;n de nav&#xED;o don Ram&#xF3;n Cabieses.</div><br></div>", "i": 6161587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Ventura Blanco.</div><br></div>", "i": 6161588}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1141", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1141"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-07", "doble_articulado": false, "id_norma": "134191", "numero_fuente": "6172", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-10", "vigencias": [{"desde": "1898-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-12-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-03-30", "fecha_version": "1898-12-10", "fecha_actualiza