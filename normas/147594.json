{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7256452}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 77, de 06 de mayo de 1987, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a don Benjam&#xED;n Ren&#xE9; Malebr&#xE1;n Castro y Otros. para efectuar el servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros que se indica a continuaci&#xF3;n:</div><br><div class=\"p\">LINEA No. 3 &quot;PLACILLA MORALES - U.D.A.&quot; Ida: Placilla Morales, Los Carrera, Alameda, Juan Mart&#xED;nez, Cancha Rayada.</div><div class=\"p\">Regreso: Cancha Rayada, Freire, R&#xF3;mulo J. Pedro, Las Heras, Juan Godoy, Rancagua, Cha&#xF1;arcillo, Copayapu. Vicu&#xF1;a, Los Carrera, Placilla Morales.</div><br></div>", "i": 7256453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 7256454}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-77 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-06", "doble_articulado": false, "id_norma": "147594", "numero_fuente": "32765", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-05-08", "vigencias": [{"desde": "1987-05-08",