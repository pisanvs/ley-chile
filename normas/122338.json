{"html": [{"t": "<div><br><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A DON JOSE MIGUEL QUERA PALACIOS</div><br></div>", "i": 6122943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del SII, por resoluci&#xF3;n N&#xBA;Ex. 1.047, de 21 de julio de 1998 otorga, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n y hasta el 31 de julio de 1999 a Jos&#xE9; Miguel Quera Palacios, RUT.</div><div class=\"p\">N&#xBA;8.297.717-1, la calidad de agente retenedor del Impuesto al Valor Agregado en las operaciones de ganado vivo, establecido en la Res. N&#xBA;Ex.2.379/98 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 24.04.98, modificada por Res. N&#xBA;Ex.3.785/98 publicada en el Diario Oficial del 30.06.98.</div><br></div>", "i": 6122944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jos&#xE9; A. Moretti Soto, Director Regional. </div></div>", "i": 6122945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1047 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1047 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A DON JOSE MIGUEL\nQUERA PALACIOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTE RETENEDOR", "IMPUESTO AL VALOR AGREGADO", "JOSE MIGUEL QUERA PALACIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-21", "doble_articulado": false, "id_norma": "122338", "numero_fuente": "36127", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-30", "vigencias": [{"desde": "1998-07-30", "hasta": "", "ti