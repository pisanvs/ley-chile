{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6505637}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.246, de esta Subsecretar&#xED;a, autor&#xED;zase a EMPRESA DE DESARROLLO PESQUERO DE CHILE S.A. para realizar actividades extractivas en aguas internacionales con la nave &quot;Unionsur I&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CBUS</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  3087</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 97,62 m</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  17,80 m</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 10,30 m</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp; &nbsp; 4991,00</div><div class=\"p\">Potencia Motor Principal&nbsp; &nbsp; 7.493,60 HP</div><div class=\"p\">Potencia Motor Auxiliar&nbsp; &nbsp;  3.758,60 HP</div><br></div>", "i": 6505638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6505639}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3246 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3246 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-