{"html": [{"t": "<div><div class=\"p\">DESIGNA SENADOR A PERSONA QUE INDICA</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de diciembre de 1997.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 3.138.- Visto: La facultad que me otorga el art&#xED;culo 32 N&#xBA; 6 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica y lo dispuesto en el art&#xED;culo 45 incisos tercero, letra f), y quinto de la misma Carta Fundamental;</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br></div>", "i": 8318216}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Senador a don Edgardo Boeninger Kausel, Rol Unico Nacional N&#xBA; 1.779.646-1, en su calidad de ex Ministro de Estado.</div><br></div>", "i": 8318217}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Carlos Figueroa Serrano, Ministro del Interior.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud., Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8318218}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3138", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3138"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "DESIGNA SENADOR A PERSONA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SENADOR DESIGNADO", "EDGARDO BOENINGER KAUSEL", "EX MINISTRO DE ESTADO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-23", "doble_articulado": false, "id_norma": "86879", "numero_fuente": "35961", "tipo_version": "3", "tipo_