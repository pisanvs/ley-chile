{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 43.- Santiago, 28 de Abril de 1988.- Vistos: Lo dispuesto en el art&#xED;culo 4&#xB0; del Decreto Ley No. 2.974 de 1979.</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 6156006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Ministro de Fe para actuar en las localidades de la IX Regi&#xF3;n en que no haya Notario ni Oficiales del Registro Civil, al funcionario del Instituto de Desarrollo Agropecuario, don Sergio Reyes Tatin, T&#xE9;cnico Agr&#xED;cola, grado 20 EUR., con residencia en la IX Regi&#xF3;n.</div><br></div>", "i": 6156007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Sergio Retamal Iglesias, Vicepresidente Ejecutivo.</div><br></div>", "i": 6156008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "43", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-43"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-28", "doble_articulado": false, "id_norma": "132355", "numero_fuente": "33087", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-06-04", "vigencias": [{"desde": "1988-06-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-06-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc