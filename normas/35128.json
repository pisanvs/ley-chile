{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 573, de 18 de Mayo de 1995, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, se caduc&#xF3;, conforme al</div><div class=\"p\">art&#xED;culo 6&#xB0; del D.S. N&#xB0; 175 de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, la Resoluci&#xF3;n N&#xB0; 132, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a JOSE ADOLFO TORRES RISCO, para operar un centro de cultivo ubicado en R&#xED;o Tornagaleones, Nor-Weste de Punta El Toro, comuna de Corral, Provincia de Valdivia, X Regi&#xF3;n. Adem&#xE1;s se dej&#xF3; sin efecto la Resoluci&#xF3;n N&#xB0; 321, de 1991 de esta Subsecretar&#xED;a, que prorrog&#xF3; el plazo otorgado para publicar en el Diario Oficial, el extracto de la Resoluci&#xF3;n N&#xB0; 132, de 1991.</div><br></div>", "i": 8293174}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 18 de Mayo de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "573", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-573"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "JOSE ADOLFO TORRES", "RISCO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-05-18", "fecha_derogacion": "1997-10-22", "doble_articulado": false, "id_norma": "35128", "numero_fuente": "35178", "t