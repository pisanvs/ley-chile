{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente,</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5961295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se deroga el art&#xED;culo 563, del decreto con fuerza de ley N.o 178, de 13 de Mayo de 1931, que contiene el texto de las leyes del trabajo.</div><div class=\"p\">&nbsp; &nbsp; Igualmente se derogan todas las disposiciones del mencionado decreto con fuerza de ley, que denominan a la Inspecci&#xF3;n General del Trabajo, Subsecretar&#xED;a del Trabajo.</div><br><br></div>", "i": 5961296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintisiete de Enero de mil novecientos treinta y dos.- JUAN E. MONTERO.- S. del R&#xED;o. </div></div>", "i": 5961297}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5042", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5042"}], "organismos": ["MINISTERIO DE BIENESTAR SOCIAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CODIGO TRABAJO", "MODIFICACION", "INSPECTOR GENERAL TRABAJO", "CARGO", "DEROGACION", "SUBSECRETARIO TRABAJO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-01-27", "doble_articulado": false, "id_norma": "25011", "numero_fuente": "16197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-02-11", "vigencias": [{"desde": "1932-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici