{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6545633}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.317, de 3 de octubre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a INVERSIONES PATAGONIA S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Avenida Ecuador N&#xBA; 2155, bodega N&#xBA; 5 Interior, Valdivia, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Alga Seca, Extracto L&#xED;quido de Algas y Extracto en Polvo de Algas, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6545634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de octubre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6545635}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3317 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3317 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-10-03", "doble_articulado": false, "id_norma": "243347", "numero_fuente": "38299", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-29", "vigencias": [{"desde": "2005-10-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "i