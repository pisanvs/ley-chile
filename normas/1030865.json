{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA; 2.408 EXENTA, DE 2011</div></div>", "i": 9193678}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.585, de 30 de septiembre de 2011, de esta Subsecretar&#xED;a, rectif&#xED;case el numeral 6.- de <a href=\"https://www.leychile.cl/Navegar?idNorma=1030052&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.408, de 2011</a>, de esta Subsecretar&#xED;a, que suspendi&#xF3; transitoriamente inscripci&#xF3;n en Registro Pesquero Artesanal de la X Regi&#xF3;n de Los Lagos, en todas sus categor&#xED;as, secci&#xF3;n de pesquer&#xED;a del recurso Juliana Tawera Gayi, en el sentido de se&#xF1;alar que la citada suspensi&#xF3;n regir&#xE1; por el t&#xE9;rmino de un a&#xF1;o contado a partir de la fecha de publicaci&#xF3;n de la citada resoluci&#xF3;n de conformidad con la Ley General de Pesca y Acuicultura.</div></div>", "i": 9193679}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de septiembre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9193680}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2585 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2585 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº 2.408 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-09-30", "doble_articulado": false, "id_norma": "1030865", "numero_fuente": "40084", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-10-13", "v