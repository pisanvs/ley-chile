{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6407285}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.850,&nbsp; de esta Subsecretar&#xED;a, rectif&#xED;case la letra d) del numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 2.817 de 2002, que modific&#xF3; la resoluci&#xF3;n N&#xBA;2.318 de 2002, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD AUSTRAL DE CHILE, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Monitoreo de la pesquer&#xED;a artesanal de anchoveta y sardina com&#xFA;n X Regi&#xF3;n Exterior (Valdivia)&quot;, en el sentido de se&#xF1;alar que las naves excluidas de la pesca de investigaci&#xF3;n corresponden a las siguientes: Don Joaqu&#xED;n, Eben Ezer, Nelly, Elizabeth II y Samaritano II.</div><br></div>", "i": 6407286}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6407287}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2850", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2850"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-11", "doble_articulado": false, "id_norma": "206026", "numero_fuente": "37437", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-18", "vigencias": [{"desde": "2002-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici