{"html": [{"t": "<div><br><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A PRIME HARVEST S.A.</div></div>", "i": 9161005}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca del S.I.I., por resoluci&#xF3;n exenta N&#xBA; 4.298, de fecha 11 de julio de 2011, concede a la contribuyente Prime Harvest S.A., RUT N&#xBA; 76.099.752-8, a contar del d&#xED;a primero del mes siguiente, de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las Ventas de Berries, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 15 de la resoluci&#xF3;n exenta N&#xBA; 55/2005, de la Direcci&#xF3;n Nacional.-</div></div>", "i": 9161006}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Talca, 11 de julio de 2011.- Luis Aguirre P&#xE9;rez, Director Regional.</div></div>", "i": 9161007}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4298 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4298 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA A PRIME HARVEST S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-11", "doble_articulado": false, "id_norma": "1028074", "numero_fuente": "40020", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-07-27", "vigencias": [{"desde": "2011-07-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-07-27", "fin_vigencia": ""}, "vigencias_version_norm