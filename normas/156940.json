{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6237163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P., No. 146, de 27 de Mayo de 1985, se expropi&#xF3; el lote de terreno No. 1, para Agua Potable de Arauco, que figura a nombre de do&#xF1;a Paulina Salgado Toledo, rol de aval&#xFA;o 163-32, superficie 11.065 m2., comuna de Arauco. La Comisi&#xF3;n de Peritos compuesta por los se&#xF1;ores Manuel Concha Rojas, Jos&#xE9; Manuel G&#xE1;lvez Alegr&#xED;a y C&#xE9;sar Burotto Manetti, fij&#xF3; con fecha 9 de Abril de 1984, el valor provisional de la indemnizaci&#xF3;n en la cantidad de $ 243.430. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del decreto ley No 2.186, de 1978.-</div><br></div>", "i": 6237164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6237165}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "146", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-146"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-27", "doble_articulado": false, "id_norma": "156940", "numero_fuente": "32210", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-01", "vigencias": [{"desde": "1985-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-01", "fin_vigencia": "", "tipo_version"