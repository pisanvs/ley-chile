{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6238405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta N&#xB0; 669, de 02 de Diciembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n se autoriza a Don Luis Flavio Pavez Gonz&#xE1;lez para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6238406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Manuel Coloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule.</div><br></div>", "i": 6238407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "669 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-669 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-02", "doble_articulado": false, "id_norma": "157408", "numero_fuente": "32378", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-01-22", "vigencias": [{"desde": "1986-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-01-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul