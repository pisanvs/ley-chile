{"html": [{"t": "<div><br><div class=\"p\">PARTIDO TODOS</div></div>", "i": 9699660}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Nicol&#xE1;s Shea Carey y Carla Fuentes Vicu&#xF1;a, Presidente y Secretaria General, respectivamente, de la Directiva Central Provisional del Partido Todos, en formaci&#xF3;n, con fecha 14 de abril de 2016, han solicitado la Constituci&#xF3;n Legal del Partido en la Regi&#xF3;n XI de Ais&#xE9;n del General Carlos Ib&#xE1;&#xF1;ez del Campo. La Solicitud de Inscripci&#xF3;n se&#xF1;ala acompa&#xF1;ar la cantidad de 126 afiliados.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el<a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=8285857&amp;idVersion=\"> art&#xED;culo 17&#xBA;</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=&amp;idVersion=\">ley N&#xBA; 18.603</a>, por resoluci&#xF3;n O-N&#xBA; 113 de fecha 15 de abril de 2016.- </div><br></div>", "i": 9699661}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9699662}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "113", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-113"}, {"tipo": "3", "numero": "O-113", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-113"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO TODOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1020255; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-04-15", "doble_articulado": false, "id_norma": "1090009", "numero_fuente": "41448", "tipo_version": "3", "tipo_version_s": "Única", "fecha_p