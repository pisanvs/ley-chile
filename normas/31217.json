{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; COMPLEMENTA RESOLUCION N&#xB0; 36, DE 1991</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 10.- Santiago, 31 de Enero de 1992.- Visto: Los art&#xED;culos 3&#xB0; de la Ley N&#xB0; 18.696 y 43, incisos primero y segundo, de la Ley N&#xB0; 18.575 y la Resoluci&#xF3;n N&#xB0; 36 de 31 de Mayo de 1991, de este Ministerio,</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 7193017}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Complem&#xE9;ntase la resoluci&#xF3;n N&#xB0; 36 antes referida, en el sentido que los Secretarios Regionales de Transportes y Telecomunicaciones, antes de hacer uso de la facultad que all&#xED; se les delega, deber&#xE1;n consultar la opini&#xF3;n de la o las municipalidades involucradas en la medida proyectada de incorporaci&#xF3;n o eliminaci&#xF3;n de v&#xED;as para la circulaci&#xF3;n de veh&#xED;culos de servicios de locomoci&#xF3;n colectiva urbana de pasajeros.</div><br><br></div>", "i": 7193018}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- V. Germ&#xE1;n Correa D&#xED;az, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda a Ud.- Elizabeth Silva Cid, Jefe Administrativo Subrogante.</div><br></div>", "i": 7193019}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "COMPLEMENTA RESOLUCION N° 36, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["OBLIGACION", "SECRETARIOS REGIONALES MINISTERIALES", "MINISTERIO TRANSPORTES TELECOMUNICACIONES", "VIAS CIRCULACION", "VEHICULOS LOCOMOCION COLECTIVA URBANA", "FACULTAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-31", "doble_articulado": false, "id_norma": "31217", "numero_fuente": "34216", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-03-12", "vigencias": [{"desde": "1992-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-03-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}, {"text": "CONCORDANCIA", "url_part": "concordancia"}], "fecha_version": "1992-03-12", "fecha_actualizacion_texto": "1992-03-12", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 7193017}, {"n": "Artículo", "i": 7193018, "t": 6}, {"n": "Promulgación", "i": 7193019}]}