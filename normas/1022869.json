{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9108814}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 327, de 3 de febrero de 2011, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=205268&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.595, de 2002</a>, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a LEYLA IBET LAMA ORTIZ para iniciar actividades pesqueras extractivas con la nave &quot;Luc&#xED;a&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la I a III Regiones, sobre el recurso hidrobiol&#xF3;gico Reineta, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9108815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de febrero de 2011.- Maximiliano Alarma Carrasco, Subsecretario de Pesca (S).</div></div>", "i": 9108816}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "327 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-327 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-02-03", "doble_articulado": false, "id_norma": "1022869", "numero_fuente": "39881", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-02-09", "vigencias": [{"desde": "2011-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v