{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9541662}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.292, de 2 de diciembre de 2014, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1046028&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.929, de 2012</a>, s&#xF3;lo en cuanto autoriz&#xF3; a PESCA CHILE S.A., para realizar actividades pesqueras extractivas con la nave &quot;Puerto Williams&quot;, respecto del recurso hidrobiol&#xF3;gico Reineta en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 47&#xBA;L.S, y el paralelo 57&#xBA;L.S., en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y lo informado mediante memor&#xE1;ndum citado en Visto de la resoluci&#xF3;n extractada.</div></div>", "i": 9541663}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de diciembre de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9541664}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3292 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3292 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-12-02", "doble_articulado": false, "id_norma": "1072725", "numero_fuente": "41034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-12-17", "vigencias": [{"desde": "2014-12-17", "hasta": "", "tipo_ver