{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6526345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP exento N&#xBA;411 de fecha 29 de abril de 2005, se expropi&#xF3; el lote de terreno N&#xBA;4, superficie 2.486 m2, rol de aval&#xFA;o N&#xBA;249-300, comuna de Salamanca, para la obra &quot;Readecuaci&#xF3;n Entrega Final Canal Panguesillo, Sistema Regad&#xED;o Valle del Choapa&quot;, Obras:</div><div class=\"p\">&quot;Primera Entrega&quot; y &quot;Segunda Entrega&quot;. comuna de Salamanca, provincia de Choapa, Regi&#xF3;n de Coquimbo&quot;, IV Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Marta del Carmen Vega Villalobos, ascendente a la cantidad de $2.966.813.</div><br></div>", "i": 6526346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6526347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "411 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-411 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-04-29", "doble_articulado": false, "id_norma": "238025", "numero_fuente": "38162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-16", "vigencias": [{"desde": "2005-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-05-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ing