{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Cuerpo de Bomberos de Antofagasta Lei n&#xFA;m. 1,009.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese al Cuerpo de Bomberos de Antofagasta el permiso requerido por el art&#xED;culo 556 del C&#xF3;digo Civil para poder conservar durante 30 a&#xF1;os la propiedad del bien raiz que posee en dicha ciudad </div></div>", "i": 5948155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 22 de Enero de 1898.- FEDERICO ERRAZURIZ.- J. D. Amun&#xE1;tegui Rivera.</div><br></div>", "i": 5948156}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1009", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1009"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "CUERPO DE BOMBEROS DE ANTOFAGASTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CUERPO BOMBEROS ANTOFAGASTA", "BIEN RAIZ", "DERECHO", "PROPIEDAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-22", "doble_articulado": false, "id_norma": "22343", "numero_fuente": "5918", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-02-02", "vigencias": [{"desde": "1898-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-02-02", "fin_vigencia": ""}, "vigencias