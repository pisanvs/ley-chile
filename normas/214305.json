{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.070, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 604 de 1986, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA SAN MIGUEL LIMITADA, hoy Pesquera El Golfo S.A., para operar la nave &quot;Westport&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre el paralelo 41&#xBA; 28,6&apos; L.S. y el l&#xED;mite sur de la X Regi&#xF3;n, con cerco, sobre el recurso hidrobiol&#xF3;gico Merluza de tres aletas, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) De la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7303181}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7303182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2070 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2070 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-21", "doble_articulado": false, "id_norma": "214305", "numero_fuente": "37650", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-02", "vigencias": [{"desde": "2003-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":