{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 82</div><br><div class=\"p\">Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n No. 82, celebrada el 13 de diciembre de 1990, adopt&#xF3; los siguientes acuerdos:</div><br><div class=\"p\">82-08-901213 Modifica Anexo No. 1 del Cap&#xED;tulo III.F.1 del Compendio de Normas Financieras.</div><br></div>", "i": 7222936}, {"t": "<div><div class=\"p\">Se acord&#xF3; reemplazar en el No. 3 del Anexo No. 1 &quot;Tarifas por Custodia de T&#xED;tulos de las A.F.P.&quot; del Cap&#xED;tulo III.F.1 del Compendio de Normas Financieras, la expresi&#xF3;n &quot;31 de diciembre de 1990&quot; por &quot;30 de junio de 1991&quot;. </div></div>", "i": 7222937}, {"t": "<div><div class=\"p\">Santiago, 13 de diciembre de 1990.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino.</div><br></div>", "i": 7222938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "82", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-82"}, {"tipo": "5", "numero": "82-08", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-82-08"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N° 82", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-13", "doble_articulado": false, "id_norma": "88436", "numero_fuente": "33844", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-12-15", "vigencias": [{"desde": "1990-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"