{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7352307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 630, de 23 de julio de 2007, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme DL N&#xBA; 2.186 de 1978, del Lote N&#xBA; 6, correspondiente a parte del inmueble ubicado en Los Pajaritos 215, Rol de aval&#xFA;o N&#xBA; 151-8, comuna de Maip&#xFA;, aparente dominio de Sindicato Ind. Insa. Comisi&#xF3;n integrada por peritos se&#xF1;ores Carmen Pilar R&#xED;os Marcuello, ingeniero civil; Carmen Gloria Gatica Villarroel, arquitecto y Ram&#xF3;n Rovira Baro, constructor civil. Seg&#xFA;n informe de 12 de septiembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $11.050.500.-, pagadera al contado.</div><br></div>", "i": 7352308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 7352309}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "630", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-630"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-23", "doble_articulado": false, "id_norma": "264289", "numero_fuente": "38853", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-01", "vigencias": [{"desde": "2007-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v