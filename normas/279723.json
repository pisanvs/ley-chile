{"html": [{"t": "<div><div class=\"p\">AUTORIZA A EMISORES DE BOLETAS ELECTR&#xD3;NICAS</div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 124 de 10 de octubre de 2008, que autoriza a contribuyentes como emisores de boletas electr&#xF3;nicas.</div><br></div>", "i": 6662349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de boletas electr&#xF3;nicas, a contar del mes de octubre de 2008, a contribuyentes RUT 70.011.730-8 y RUT 76.351.260-6.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2008.</div><br></div>", "i": 6662350}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "124 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-124 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A EMISORES DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-10", "doble_articulado": false, "id_norma": "279723", "numero_fuente": "39189", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-10-16", "vigencias": [{"desde": "2008-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-10-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-10-16", "fin_vigencia": "", "tipo_version": "3"}], "e