{"html": [{"t": "<div><br><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9874862}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 4.959, de 28 diciembre 2017, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n total, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en 3 Sur 698, Rol de Aval&#xFA;o N&#xB0; 582-12, comuna Talca, superficie 334 metros cuadrados, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Suc Albornoz Miranda Olga Doraliza. Comisi&#xF3;n integrada por peritos Patricio Dur&#xE1;n Marcos, arquitecto, Rodrigo Silva Lazo, constructor civil, y Pedro Pablo Cruz Weston, arquitecto, seg&#xFA;n informe tasaci&#xF3;n de 27 diciembre 2017, fij&#xF3; monto provisional indemnizaci&#xF3;n m&#xE1;s reajustes legales en $73.480.000.- pagados al contado.- </div></div>", "i": 9874863}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Omar Guti&#xE9;rrez Mesina, Director Serviu Regi&#xF3;n del Maule. </div><br></div>", "i": 9874864}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4959 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4959 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1332490"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2017-12-28", "fecha_derogacion": "2019-06-15", "doble_articulado": false, "id_norma": "1113707", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2018-01-15", "vigencias": [{"desde": "2019-06-15", "hasta": "", "tipo_version": "2", "tipo_version_s": "Últim