{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Rehabilitacion del Sarjento Mayor don C&#xE9;sar Leon Luco</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m.1,152.- Santiago, a 29 de Diciembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 7162910}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Rehabil&#xED;tase al sarjento mayor de Ej&#xE9;rcito, don C&#xE9;sar Le&#xF3;n Luco, para que tramite su espediente de invalidez en conformidad a lo dispuesto en la lei de 22 de Diciembre de 1881.</div><br><br></div>", "i": 7162911}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 7162912}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1152", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1152"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "REHABILITACION DEL SARJENTO MAYOR DON CÉSAR LEON LUCO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CESAR LEON LUCO", "REHABILITACION", "EXPEDIENTE", "TRAMITACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-29", "doble_articulado": false, "id_norma": "22433", "numero_fuente": "6190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-31", "vigencias": [{"desde": "1898-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig