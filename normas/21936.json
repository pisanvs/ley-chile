{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Montep&#xED;o Lei n&#xFA;m. 64.- Santiago, a 7 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a do&#xF1;a Melchora Duran v. de Madrid el goce de la pension de montep&#xED;o que le corresponderia si su marido don Daniel Madrid hubiese obtenido el permiso necesario para contraer matrimonio.</div><br><br></div>", "i": 5946653}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- V. D&#xE1;vila Larrain.</div><br></div>", "i": 5946654}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "64", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-64"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MELCHORA DURAN", "MONTEPIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-07", "doble_articulado": false, "id_norma": "21936", "numero_fuente": "4594", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-12", "vigencias": [{"desde": "1893-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-08-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fe