{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7289822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 444, de 21 de febrero de 2002, de</div><div class=\"p\">esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 127 de 1997, modificada por resoluci&#xF3;n N&#xBA;</div><div class=\"p\">841 de 2000, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto</div><div class=\"p\">autoriz&#xF3; a PESQUERA LANDES S.A. para realizar</div><div class=\"p\">actividades con la nave Don Boris, en el &#xE1;rea mar&#xED;tima</div><div class=\"p\">de la III y IV Regiones, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7289823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de febrero de 2002.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 7289824}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "444", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-444"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-21", "doble_articulado": false, "id_norma": "194891", "numero_fuente": "37197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-27", "vigencias": [{"desde": "2002-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio