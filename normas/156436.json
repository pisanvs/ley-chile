{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6235531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 44, de 17 de Enero de 1985, de la Secretar&#xED;a Regional, Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n, se autoriza a las personas que se individualizan para efectuar el servicio de taxis colectivos urbano que se indica.</div><br><div class=\"p\">LINEA N&#xB0; 2. &quot;LINEA DE AUTOS COLECTIVOS BARRIO NORTE&quot; </div><div class=\"p\">&nbsp; &nbsp;  Ida: Terminal Osorno N&#xB0; 153, Calle N&#xB0; 3, Ainavillo, Calle N&#xB0; 2 Ainavillo, Brasil, Paicav&#xED;, Freire, Prat.</div><div class=\"p\">&nbsp; &nbsp;  Regreso: Prat, Maip&#xFA;, Janequeo, Carreras, Paicav&#xED;, Brasil, Ainavillo, Calle N&#xB0; 2, Ainavillo, Calle N&#xB0; 3, Osorno.-</div><br></div>", "i": 6235532}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones, VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6235533}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "44 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-44 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-17", "doble_articulado": false, "id_norma": "156436", "numero_fuente": "32.085", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-31", "vigenc