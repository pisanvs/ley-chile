{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 897 EXENTA, DE 2001 </div></div>", "i": 6327195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 897, de 9 de febrero del a&#xF1;o 2001, se ha aprobado al Instituto Alonso de Ercilla (Hermanos Maristas), comuna y provincia de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para 3&#xBA; a&#xF1;o de ense&#xF1;anza media human&#xED;stico-cient&#xED;fica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se se&#xF1;alan en la presente resoluci&#xF3;n. </div></div>", "i": 6327196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de febrero de 2001.- Javier San Miguel Bertr&#xE1;n, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 6327197}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "897 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-897 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 897 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-09", "doble_articulado": false, "id_norma": "183052", "numero_fuente": "36918", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-21", "vigencias": [{"desde": "2001-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-21", "fin_vigencia": "", "tipo_version": "3"