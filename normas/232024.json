{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6503248}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n 591, de 23 de septiembre de 2004, Serviu Regi&#xF3;n del B&#xED;o B&#xED;o orden&#xF3; expropiaci&#xF3;n total inmueble ubicado en calle Manuel Rodr&#xED;guez N&#xBA; 438, Rol de aval&#xFA;o 2770-2, comuna Chiguayante, superficie 185,40 m2. de terreno y 213,77 metros cuadrados de edificaci&#xF3;n, dentro pol&#xED;gono y linderos se&#xF1;alados plano expropiaci&#xF3;n S8R-19.072, de aparente dominio de Luis Poncell Trenit, para ejecuci&#xF3;n programa &quot;Mejoramiento Vial Eje O&apos;Higgins de Chiguayante&quot;, conforme art&#xED;culo 51 ley 16.391 y DL 2.186. Comisi&#xF3;n peritos integrada por Gabriel Fern&#xE1;ndez de la Maza, ingeniero civil; Sergio Labarca Garrido, constructor civil, y Boris Aptecar Gonz&#xE1;lez, arquitecto, seg&#xFA;n informe de fecha 28 de agosto de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $27.439.550, pagadera de contado.-</div><br></div>", "i": 6503249}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Director Serviu Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6503250}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "591", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-591"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANIZACIÓN", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGION DEL BIOBÍO"], "titulo_norma": "DISPONE EXPROPIACIONES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-23", "doble_articulado": false, "id_norma": "23202