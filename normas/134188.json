{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,115.- Santiago, 28 de octubre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6161577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a don M. Enrique Reynolds, el abono de diez a&#xF1;os de servicios para los efectos de su retiro.</div><br></div>", "i": 6161578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- V. Blanco.</div><br></div>", "i": 6161579}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1115", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1115"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-10-28", "doble_articulado": false, "id_norma": "134188", "numero_fuente": "6142", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-11-04", "vigencias": [{"desde": "1898-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-11-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-11-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-03-30", "fecha_version": "1898-11-04", "fecha_actualizacion_texto": "1898-11-04", "tipo_tratado": ""}, "alertas": [], "alerta_global": "