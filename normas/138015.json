{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD COMERCIAL LIQUI&#xD1;E LTDA.</div><br><br></div>", "i": 6173897}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n, del S.I.I., por resoluci&#xF3;n DRE 08/N&#xBA;Ex.755, de fecha 9 de junio de 1999, otorga a contar del 1 del mes siguiente al de esta publicaci&#xF3;n a Sociedad Comercial Liqui&#xF1;e Ltda., Rut. N&#xBA; 88.481.500-2, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las ventas de Legumbres, establecido en la resoluci&#xF3;n N&#xBA; 5.380/97,&nbsp; prorrogada&nbsp; y&nbsp; modificada&nbsp; por&nbsp; Res. Ex. N&#xBA; 7.033, de 27-11-98, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6173898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 9 de junio de 1999.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6173899}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "755 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-755 EXENTA"}, {"tipo": "3", "numero": "DRE-08-755 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-755 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOCIEDAD COMERCIAL LIQUIÑE LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-09", "doble_articulado": false, "id_norma": "138015", "numero_fuente": "36393", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1