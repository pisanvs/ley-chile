{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10306242}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;7, de 13 de enero de 2022, se desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xBA;65L7, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1157668&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xBA;20, de 25 de febrero de 2021</a>, en cuanto a reducir la superficie de dicho lote a 29,85 m2., quedando como a continuaci&#xF3;n se indica: lote N&#xBA;65L7, propietario seg&#xFA;n rol de aval&#xFA;o Escobillana Riquelme Miguel, de la comuna de Las Condes, superficie de terreno (M2) 29,85, expropiado para la ejecuci&#xF3;n de obra &quot;Proyecto L&#xED;nea 7 Metro S.A., Comuna de Las Condes, Regi&#xF3;n Metropolitana de Santiago. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en los art&#xED;culos 7&#xBA; y 32&#xBA; del Decreto Ley N&#xBA;2186, de 1978.</div></div>", "i": 10306243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10306244}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "7 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-7 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2078429", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-13", "doble_articulado": false, "id_norma": "1172024", "numero_fuente": "43167", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-02-01", "vigencias": [{"