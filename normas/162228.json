{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 9051636}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 22 de fecha 22.06.85, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones XI Regi&#xF3;n, se autoriza a la Sra. Lutgarda Cancino L. para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 9051637}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Coyhaique, 10 de Junio de 1985.- Eliecer Aedo Rivera, Secretario Regional Ministerial de Transportes y Telecomunicaciones XI Regi&#xF3;n.</div><br></div>", "i": 9051638}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "22", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-22"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL XI REGIÓN DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-22", "doble_articulado": false, "id_norma": "162228", "numero_fuente": "32200", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-06-19", "vigencias": [{"desde": "1985-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-06-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-06-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula