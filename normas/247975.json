{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE CABILDO </div></div>", "i": 6563888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 1.044 del 28 de febrero de 2006, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, aprob&#xF3; el Estudio T&#xE9;cnico de Regularizaci&#xF3;n de los derechos de aprovechamiento de aguas de la Cooperativa de reforma agraria asignataria &quot;San Lorenzo Limitada&quot;, de la comuna de Cabildo, V Regi&#xF3;n, en el sentido de establecer que los derechos de aprovechamiento de aguas que se extraen de 9 pozos tieneN la equivalencia que se indica, expresada en unidad de volumen por unidad de tiempo, y que dichos derechos son consuntivos, de ejercicio permanente y continuos. Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; ley N&#xBA; 18.377.-</div><br></div>", "i": 6563889}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 6563890}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1044 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1044 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE CABILDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS DE APROVECHAMIENTO DE AGUAS", "CABILDO", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-28", "doble_articulado": false, "id_norma": "247975", "numero_fuente": "38414", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-15", "vige