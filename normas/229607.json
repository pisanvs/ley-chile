{"html": [{"t": "<div><div class=\"p\">AUMENTA, POR GRACIA, A LA PENSION DE DON LUIS FLORES AVALOS</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6494242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Aum&#xE9;ntase, por gracia, a ciento cincuenta escudos mensuales la pensi&#xF3;n que percibe don Luis Flores Avalos.</div><div class=\"p\">&nbsp; &nbsp;  El mayor gasto que demande la aplicaci&#xF3;n de la presente ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.</div><br></div>", "i": 6494243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiuno de Junio de mil novecientos sesenta y ocho.- EDUARDO FREI MONTALVA.- Andr&#xE9;s Zald&#xED;var Larra&#xED;n.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a U. para su conocimiento.- Dios guarde a U.- Jos&#xE9; F. Guzm&#xE1;n C., Subsecretario de Hacienda.</div><br></div>", "i": 6494244}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16862", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16862"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "AUMENTA, POR GRACIA, A LA PENSION DE DON LUIS FLORES\nAVALOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1968-06-21", "doble_articulado": false, "id_norma": "229607", "numero_fuente": "27079", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1968-06-28", "vigencias": [{"desde": "1968-06-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi