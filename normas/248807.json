{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A MIGUEL VIVANCO SANHUEZA </div></div>", "i": 6566555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/Ex. N&#xBA;1.875, de fecha 3 de abril de 2006, revoca a Miguel Vivanco Sanhueza, RUT 5.954.781-K a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las ventas de Harina de Trigo y Trigo de acuerdo con lo dispuesto en el dispositivo N&#xBA; 17 de la Res. Ex. N&#xBA; 5282 de fecha 30-11-2000, y dispositivo N&#xBA; 18 de la Res. Ex. N&#xBA; 5281 de 30-11-2000 respectivamente, ambas de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6566556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 3 de abril de 2006.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6566557}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1875 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1875 EXENTA"}, {"tipo": "3", "numero": "DRE-08-1875 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-1875 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A MIGUEL VIVANCO SANHUEZA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-03", "doble_articulado": false, "id_norma": "248807", "numero_fuente": "38435", "tipo_version": "3", "tipo_version_s": "Úni