{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 2.129 EXENTO, DE 2008 </div></div>", "i": 7379809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 2.129, de 16 de junio de 2008, se ha modificado el decreto exento de Educaci&#xF3;n N&#xBA; 338 de 1998, que aprob&#xF3; planes y programas de estudio biling&#xFC;e para los cursos de 5&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, al Colegio &quot;The Mackay School&quot;, de Vi&#xF1;a del Mar, a partir del a&#xF1;o escolar 2008.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para los cursos de 5&#xBA; a 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica del Subsector de Aprendizaje Tecnolog&#xED;a de la Informaci&#xF3;n y de las Comunicaciones del Sector de Tecnolog&#xED;a.</div><br></div>", "i": 7379810}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de octubre de 2008.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7379811}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2129 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2129 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 2.129 EXENTO, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-16", "doble_articulado": false, "id_norma": "279865", "numero_fuente": "39192", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-10-20", "vigencias": [{"desde": "2008-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-10-20",