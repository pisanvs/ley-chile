{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOCIEDAD MUSICAL DE OVALLE Lei n&#xFA;m. 243.-Santiago, a 11 de Enero de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la Sociedad Musical de Ovalle el permiso requerido por el art&#xED;culo 556 del C&#xF3;digo Civil, para que pueda conservar por treinta a&#xF1;os la propiedad de un bien raiz que posee en la calle Vicu&#xF1;a Mackenna de dicha ciudad.</div><br><br></div>", "i": 5947261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-O. Renjifo.</div><br></div>", "i": 5947262}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "243", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-243"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "SOCIEDAD MUSICAL DE OVALLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD MUSICAL OVALLE", "BIEN RAIZ", "PROPIEDAD", "CONSERVACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-01-11", "doble_articulado": false, "id_norma": "22097", "numero_fuente": "5013", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-01-14", "vigencias": [{"desde": "1895-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-01-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen