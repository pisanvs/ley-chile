{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6518530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 491, de 23 de febrero de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PROCESADORA Y EXPORTADORA DE PESCADOS SOUTH TIDE LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Phillippi N&#xBA; 311, sector Caleta Portales, Valpara&#xED;so, V Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n Fresco enfriado, Fresco refrigerado y Congelado, el recurso hidrobiol&#xF3;gico individualizado en la resoluci&#xF3;n extractada. </div></div>", "i": 6518531}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de febrero de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6518532}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "491 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-491 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-02-23", "doble_articulado": false, "id_norma": "236222", "numero_fuente": "38108", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-11", "vigencias": [{"desde": "2005-03-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-03-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-03-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG