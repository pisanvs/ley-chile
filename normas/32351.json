{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE REFORMA DE ESTATUTOS DEL BANCO BHIF </div></div>", "i": 6003710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico que por resoluci&#xF3;n N&#xB0; 30 de 14 de abril de 1993, se aprobaron las reformas introducidas a los estatutos del Banco BHIF, en la Junta Extraordinaria de Accionistas celebrada en Santiago el 8 de marzo de 1993, cuya acta se redujo a escritura p&#xFA;blica el d&#xED;a 19 de marzo de 1993, otorgada en la Notar&#xED;a de Santiago de don Jos&#xE9; Musalem S.</div><div class=\"p\">&nbsp; &nbsp; Extracto de la reforma:</div><div class=\"p\">&nbsp; &nbsp; Se disminuy&#xF3; el n&#xFA;mero de directores de once a nueve.</div><br></div>", "i": 6003711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 14 abril 1993, Jos&#xE9; Florencio Guzm&#xE1;n C., Superintendente.</div><br></div>", "i": 6003712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "30", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-30"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "EXTRACTO DE REFORMA DE ESTATUTOS DEL BANCO BHIF", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REFORMA ESTATUTARIA", "ESTATUTOS", "BANCO HIPOTECARIO FOMENTO", "BHIF"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-04-14", "doble_articulado": false, "id_norma": "32351", "numero_fuente": "34555", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-05-03", "vigencias": [{"desde": "1993-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-05-03", "fin_vigencia": ""