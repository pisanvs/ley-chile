{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 5.632 EXENTA, DE 2011</div><br></div>", "i": 9180599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo se&#xF1;alado en el art&#xED;culo 48 de la ley N&#xBA; 19.880, el Servicio Nacional de Capacitaci&#xF3;n y Empleo cumple con informar que mediante resoluci&#xF3;n exenta N&#xBA; 5.632 de 1 de julio de 2011, se aprobaron las instrucciones para la Ejecuci&#xF3;n del &quot;Programa Bono de Capacitaci&#xF3;n para Trabajadores Activos&quot;.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio, www.sence.cl.- </div></div>", "i": 9180600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Miguel Bergu&#xF1;o Ca&#xF1;as, Director Nacional.</div></div>", "i": 9180601}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5632 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5632 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 5.632 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-01", "doble_articulado": false, "id_norma": "1029587", "numero_fuente": "40061", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-14", "vigencias": [{"desde": "2011-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-09-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-09-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul