{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6273392}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP No. 35, de 28 de febrero de 1991, se expropiaron los lotes No. s. 4, 8 y 12, superficies 2.460 M2., 3.042 M2. y 6.780 M2., roles de aval&#xFA;o 14-03, 13-40 y 13-40, respectivamente, Comuna San Pedro, para la obra Camino San Fernando-San Antonio, sector Bifurcaci&#xF3;n San Pedro-San Pedro, Km. 0.000 al 3.731,23 y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios do&#xF1;a Melania del Carmen Valdenegro N&#xFA;&#xF1;ez y don V&#xED;ctor Antonio Carrasco Fr&#xED;as, ascendente a las cantidades de $ 594.139, $ 536.945 y $ 1.055.086.-</div><br></div>", "i": 6273393}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6273394}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "35", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-35"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-02-28", "doble_articulado": false, "id_norma": "168075", "numero_fuente": "33931", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-04-01", "vigencias": [{"desde": "1991-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2000-05-05", "fecha_version":