{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 132 EXENTO, DE 1990 </div></div>", "i": 6064643}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 132 de 16 de abril de 1990 se ha modificado, a contar del a&#xF1;o escolar 1990, el decreto supremo exento de Educaci&#xF3;n No. 120, de 1982, que aprueba al Colegio &quot;El Patrocinio de San Jos&#xE9;&quot;, de Santiago, un plan de estudio especial de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica, en la forma que se indica. </div></div>", "i": 6064644}, {"t": "<div><div class=\"p\">Santiago, 20 de Abril de 1990.-</div><div class=\"p\">Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6064645}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "132 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-132 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO No. 132 EXENTO, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-16", "doble_articulado": false, "id_norma": "83189", "numero_fuente": "33671", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-16", "vigencias": [{"desde": "1990-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1998-01-07", "fecha_version": "1990-05-16", "fecha_actualizacion_texto