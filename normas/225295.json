{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6479582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 280 de fecha 31 de marzo del 2004, se expropi&#xF3; el lote de terreno N&#xBA; 122-A, superficie 744 m2, Rol N&#xBA; 601-551, comuna de Nueva Imperial, IX Regi&#xF3;n para la obra &quot;Camino Ruta S-16, sector Chol Chol - Nueva Imperial Tramo Km. 24,30269 al 43,5000, Sub - Tramo III Km. 35,380 al 43,50000&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Sergio Orlando Leal Leal, ascendente a la cantidad de $5.271.488.- para el lote N&#xBA; 122-A.</div><br></div>", "i": 6479583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6479584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "280", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-280"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-31", "doble_articulado": false, "id_norma": "225295", "numero_fuente": "37861", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-15", "vigencias": [{"desde": "2004-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-05-17", "fecha_version": "2004-05-15", "fecha_actualizacion_texto": "2004-05-15", "tipo_tra