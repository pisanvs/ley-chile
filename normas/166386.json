{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 103 EXENTO, DE 2000 </div></div>", "i": 6267822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;103, de fecha 4 de abril de 2000, del Ministerio de Educaci&#xF3;n, se revoc&#xF3; el reconocimiento oficial del Instituto Profesional de Computaci&#xF3;n, organizado por la Sociedad Instituto Profesional de Computaci&#xF3;n y se elimin&#xF3; a dicha entidad del Registro de Institutos Profesionales en que se<span class=\"n\" id=\"n_0\">DTO 370, EDUCACION<br>D.O. 12.10.2000</span> encuentra inscrito con el N&#xBA;55. Por este mismo documento, se derog&#xF3; el decreto exento de Educaci&#xF3;n N&#xBA;191 de fecha 4 de diciembre de 1989, que reconoci&#xF3; oficialmente al Instituto Profesional de Computaci&#xF3;n. </div></div>", "i": 6267823, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de abril de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6267824}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "2", "numero": "103 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-103 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 103 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-04", "doble_articulado": false, "id_norma": "166386", "numero_fuente": "36644", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-04-19", "vigencias": [{"desde": "2000-10-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-04-19", "hasta": "2000-10-11",