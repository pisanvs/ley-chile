{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 642 EXENTO, DE 2003 </div></div>", "i": 6441241}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 642 de fecha 20 de agosto de 2003, del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Umbrales de Santiago, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar de agosto del a&#xF1;o 2003, en la Casa Central de Santiago, con la siguiente denominaci&#xF3;n:</div><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; :&nbsp;  Biotecnolog&#xED;a Dental, cambia por:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; :&nbsp;  Laboratorista Dental</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp;  :&nbsp;  T&#xE9;cnico Laboratorista Dental</div><br><br></div>", "i": 6441242}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de septiembre de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6441243}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "642 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-642 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 642 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-08-20", "doble_articulado": false, "id_norma": "215121", "numero_fuente": "37671", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-29", "vigencias": [{"desde": "2003-09-29", "hasta": "", "tipo_version": "3", "tipo_v