{"html": [{"t": "<div><div class=\"p\">PRADEL (D. NICOLAS) DECLARADO FALSO CALUMNIANTE.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional con 19 del corriente ha declarado lo que sigue:</div></div>", "i": 10237383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico. Se declara a D. Nicolas Pradel por falso calumniante, con solo la pena de quedar separado de la Representacion nacional; ll&#xE1;mese en consecuencia a su suplente.</div><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se ejecute, se tome razon donde corresponda y se publique en el Bolet&#xED;n. Dado en la Sala de Gobierno en Santiago de Chile a 21 de junio de 1828.</div></div>", "i": 10237384}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PINTO</div><div class=\"p\">&nbsp; &nbsp;  Rodr&#xED;guez.</div></div>", "i": 10237385}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "PRADEL (D. NICOLAS) DECLARADO FALSO CALUMNIANTE.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-06-21", "doble_articulado": false, "id_norma": "1157107", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-06-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "17616", "fecha_ingreso": "2021-06-03", "fecha_version