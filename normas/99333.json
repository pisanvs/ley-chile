{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 18, DE 1997</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 33.- Santiago, 24 de abril de 1998.- Vistos: Lo dispuesto en los art&#xED;culos 56, 88 y 89, de la ley 18.290, de Tr&#xE1;nsito, y el art&#xED;culo 3&#xBA; de la ley 18.696, </div><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br><br><br></div>", "i": 6111505}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n N&#xBA; 18 de 1997, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, en los siguientes t&#xE9;rminos:</div><div class=\"p\">&nbsp; &nbsp;  En el art&#xED;culo 4&#xBA;, interc&#xE1;lase el siguiente inciso segundo, pasando el actual a ser tercero:</div><div class=\"p\">&apos;&apos;Asimismo, en la luneta trasera de los buses, se podr&#xE1; instalar un letrero exterior con publicidad, siempre que el material que en &#xE9;l se utilice permita la visi&#xF3;n desde el interior del veh&#xED;culo.&apos;&apos;.</div><br></div>", "i": 6111506, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- Claudio Hohmann Barrientos, Ministro de Transportes y Telecomunicaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda a Ud., Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 6111507}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "33", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-33"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA RESOLUCION Nº 18, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LOCOMOCION COLECTIVA", "BUSES", "COLORES", "AVISOS PUBLICITARIOS", "LETREROS", "SIMBOLOS", "CARACTERISTICAS", "REGLAMENTO", "CIRCULACION VEHICULAR", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-24", "doble_articulado": false, "id_norma": "99333", "numero_fuente": "36069", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-20", "vigencias": [{"desde": "1998-05-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-05-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-05-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "ALV", "fecha_ingreso": "1998-06-15", "fecha_version": "1998-05-20", "fecha_actualizacion_texto": "1998-05-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6111505}, {"n": "Artículo", "i": 6111506, "t": 6}, {"n": "Promulgación", "i": 6111507}]}