{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6596580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.473, de 27 de diciembre de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;1838 de 1997, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a JAIME ROMAN ALVAREZ ARMIJO, para desarrollar actividades pesqueras extractivas con la nave &quot;Cazador&quot;, sobre el recurso Bacalao de profundidad, en el &#xE1;rea mar&#xED;tima comprendida entre Punta Liles y el paralelo 47&#xB0; L.S., en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado en Informes T&#xE9;cnicos citados en Visto.</div><br></div>", "i": 6596581}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6596582}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3473 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3473 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-27", "doble_articulado": false, "id_norma": "257239", "numero_fuente": "38659", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-10", "vigencias": [{"desde": "2007-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen