{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta la pensi&#xF3;n de retiro de que goza don Luis A. Pardo</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7168708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Aum&#xE9;ntase desde el 1.o de Enero de 1928, a veinticuatro mil pesos ($ 24,000) anuales, la pensi&#xF3;n de retiro de que goza el piloto don Luis A. Pardo, siendo de cargo fiscal el aumento que significa esta ley en el monto de la pensi&#xF3;n y del montep&#xED;o correspondiente.</div><br></div>", "i": 7168709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, cinco de Julio de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- C. O. Froedden. </div></div>", "i": 7168710}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4344", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4344"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "AUMENTA LA PENSION DE RETIRO DE QUE GOZA DON LUIS A. PARDO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LUIS A PARDO", "PENSION", "INCREMENTO", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-07-05", "doble_articulado": false, "id_norma": "24675", "numero_fuente": "15130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-07-23", "vigencias": [{"desde": "1928-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {