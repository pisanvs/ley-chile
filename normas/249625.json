{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6569832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.038, de 6 de abril de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a MERCEDES MERCINA CARRASCO PINTO, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Panamericana Norte Km. 839, Copiap&#xF3;, III Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Picado de Alga los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6569833}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6569834}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1038 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1038 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-06", "doble_articulado": false, "id_norma": "249625", "numero_fuente": "38462", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-13", "vigencias": [{"desde": "2006-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-05-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2006-05-15", "fecha_version": "2