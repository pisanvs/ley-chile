{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,679</div><br><div class=\"p\">ABONA EL TIEMPO QUE INDICA EN LA HOJA DE SERVICIOS DE DO&#xD1;A SABINA FLORES RUIZ</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6600197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Ab&#xF3;nanse, por gracia, y para todos los efectos legales, en la hoja de servicios de do&#xF1;a Sabina Flores Ruiz, 3 a&#xF1;os, 3 meses y 10 d&#xED;as, que sirvi&#xF3; en la Caja de Seguro Obligatorio.</div><br></div>", "i": 6600198}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a seis de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 6600199}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10679", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10679"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "ABONA EL TIEMPO QUE INDICA EN LA HOJA DE SERVICIOS DE\nDOÑA SABINA FLORES RUIZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-06", "doble_articulado": false, "id_norma": "258077", "numero_fuente": "22375", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-10-15", "vigencias": [{"desde": "1952-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-10