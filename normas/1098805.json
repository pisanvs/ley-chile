{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 131 EXENTA, DE 30 DE DICIEMBRE DE 2016</div></div>", "i": 9759862}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 131, del 30 de diciembre de 2016 que se&#xF1;ala:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Establece forma y plazo para que las entidades relacionadas informen a la empresa o sociedad respectiva, el monto total de los ingresos de su giro percibidos o devengados en el ejercicio respectivo, para determinar si se cumplen los l&#xED;mites de ingresos para efectos de acogerse y/o permanecer en el r&#xE9;gimen simplificado de la letra A., del <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=8656200&amp;idVersion=\">art&#xED;culo 14 ter</a> o en el r&#xE9;gimen de renta presunta del <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=8656064&amp;idVersion=\">art&#xED;culo 34</a>, ambos de la <a href=\"https://www.leychile.cl/Navegar?idNorma=6368\">Ley sobre Impuesto a la Renta</a>.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2016.</div></div>", "i": 9759863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "131 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-131 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 131 EXENTA, DE 30 DE DICIEMBRE DE 2016", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN; CVE 1163775"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2016-12-30", "fecha_derogacion": "2020-07-28", "doble_articulado": false, "id_norma": "1098805", "numero_fuente": "41652", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2017-01-07", "vigencias": [{"desde": "2020-07-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2017-01-07", "hasta": "2020-07-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2020-07-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-01-07", "fin_vigencia": "2020-07-27", "tipo_version": "0"}, {"inicio_vigencia": "2020-07-28", "fin_vigencia": "", "tipo_version": "2"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}, {"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "2932", "fecha_ingreso": "2017-01-09", "fecha_version": "2020-07-28", "actualizado_por": "10418", "fecha_actualizacion_texto": "2020-07-28", "tipo_tratado": ""}, "alertas": [{"clase": "derogado", "texto": "Derogado", "mensaje": "Esta norma ha sido derogada el 28-JUL-2020"}], "alerta_global": {"m": ["Esta norma ha sido derogada el 28-JUL-2020"], "e": {"i": "", "p": "", "f": "", "t": ""}}, "estructura": [{"n": "Encabezado", "i": 9759862}, {"n": "Artículo", "i": 9759863, "t": 6}]}