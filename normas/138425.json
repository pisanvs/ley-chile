{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,833.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 7250110}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al ex soldado del Batallon Movilizado Valpara&#xED;so, don Jos&#xE9; Miguel Blanco Avaria, derecho a gozar de la pension que, como inv&#xE1;lido relativo, acuerda a los individuos de tropa la lei de 22 de diciembre de 1881, pension&nbsp; que disfrutar&#xE1; con arreglo a dicha lei i a las leyes de 7 de febrero de 1895 i 9 de setiembre de 1907.</div><br></div>", "i": 7250111, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintidos de diciembre de mil novecientos trece.- Ramon Barros Luco.- Ramon Corbalan Melgarejo. </div></div>", "i": 7250112}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2833", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2833"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-12-22", "doble_articulado": false, "id_norma": "138425", "numero_fuente": "10802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-02-18", "vigencias": [{"desde": "1914-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-02-18", "fin_vigenci