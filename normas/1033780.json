{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9209936}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.104, de 25 de noviembre de 2011, de esta Subsecretar&#xED;a, modif&#xED;case <a href=\"https://www.leychile.cl/Navegar?idNorma=1027884&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA;1.896, de 2011</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; agrupaciones de concesiones de acuicultura de salm&#xF3;nidos en X y XI Regiones, reemplazando coordenadas geogr&#xE1;ficas de las agrupaciones 3A y 3B, por aquellas contenidas en la resoluci&#xF3;n extractada, publicada &#xED;ntegramente en www.subpesca.cl y www.sernapesca.cl.</div></div>", "i": 9209937}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de noviembre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9209938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3104 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3104 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-25", "doble_articulado": false, "id_norma": "1033780", "numero_fuente": "40125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-02", "vigencias": [{"desde": "2011-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-12-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend