{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Cobro del almacenaje comun</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 20 de 1821.</div></div>", "i": 9927233}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  De acuerdo con el Excmo. Senado i por el m&#xE9;rito que ha fundado el Tribunal de la Contadur&#xED;a Jeneral, se declara que el ramo de almacenaje comun, debe arreglarse en su exaccion i cobro, desde el 29 de Setiembre de &#xFA;ltimo a lo declarado por los art&#xED;culos ochenta i tres i ochenta i cuatro del reglamento de libre comercio de mil ochocientos trece i para que tenga su efecto.</div></div>", "i": 9927234}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, publ&#xED;quese e impr&#xED;mase.- O&apos;Higgins.- Dr. Rodr&#xED;guez.</div></div>", "i": 9927235}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Cobro del almacenaje comun", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1821-02-20", "doble_articulado": false, "id_norma": "1117674", "numero_fuente": "1821", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1821-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1821-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1821-02-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1096974", "fecha_ingreso": "2018-06-29", "fecha_version": "1821-02-20", "fecha_actualizacion