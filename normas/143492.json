{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 204 EXENTO, DE 1999</div><br><br></div>", "i": 6191490}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 204 de fecha 20 de julio de 1999 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; la nueva denominaci&#xF3;n del Instituto Profesional que se indica y de la persona jur&#xED;dica organizadora de la instituci&#xF3;n quedando como a continuaci&#xF3;n se se&#xF1;ala:</div><br><br><div class=\"p\">Nombre de</div><div class=\"p\">la Instituci&#xF3;n :&nbsp;  Instituto Profesional DUOC UC.</div><div class=\"p\">Domicilio&nbsp; &nbsp; &nbsp; :&nbsp;  Santiago</div><div class=\"p\">Organizador&nbsp; &nbsp; :&nbsp;  &apos;&apos;Fundaci&#xF3;n Instituto Profesional DUOC UC&apos;&apos;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  o &apos;&apos;DUOC UC&apos;&apos;.</div><br></div>", "i": 6191491}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de agosto de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6191492}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "204 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-204 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 204 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-07-20", "doble_articulado": false, "id_norma": "143492", "numero_fuente": "36467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-17", "vigencias": [{"desde": "1999-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic