{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.626, de 28 de agosto de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deniega la solicitud de concesi&#xF3;n de acuicultura presentada por BLANCA HERMINIA BAHAMONDE BARRIENTOS, para un centro de cultivo ubicado en Estero El Dique, comuna de Ancud, provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en el art&#xED;culo 78, inciso 2&#xB0;, de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8297935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297936}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1626", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1626"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION ACUICULTURA", "BLANCA HERMINIA BAHAMONDE BARRIENTOS", "ANCUD", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-08-28", "doble_articulado": false, "id_norma": "37266", "numero_fuente": "35562", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-07", "vigencias": [{"desde": "1996-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-09-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin