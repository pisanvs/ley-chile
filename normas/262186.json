{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7346484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.839, de 20 de junio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ISLA QUIHUA S.A., para realizar actividades extractivas en alta mar con la nave &quot;Terranova&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes.</div><br><div class=\"p\">&nbsp; &nbsp;  Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-4956</div><div class=\"p\">&nbsp; &nbsp;  Puerto de Matr&#xED;cula&nbsp; &nbsp;  Valpara&#xED;so</div><div class=\"p\">&nbsp; &nbsp;  Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2795</div><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  42,74 m.</div><div class=\"p\">&nbsp; &nbsp;  T.R.G. (Internacional)&nbsp; &nbsp; &nbsp; 748,00</div><div class=\"p\">&nbsp; &nbsp;  Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 10,20 m.</div><div class=\"p\">&nbsp; &nbsp;  Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 6,20 m.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2346 de 2006, de esta Subsecretar&#xED;a.</div><br></div>", "i": 7346485}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de junio de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7346486}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1839 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1839 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma":