{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6400589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.200 de esta Subsecretar&#xED;a modif&#xED;case el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA;1.760 de 2002, de esta Subsecretar&#xED;a que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO y a LA UNIVERSIDAD CATOLICA DE VALPARAISO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia de los Proyectos FIP N&#xBA;2002-05 y FIP N&#xBA;2002-06 denominados &quot;Evaluaci&#xF3;n directa de Camar&#xF3;n Nailon entre la II y la VIII Regiones, a&#xF1;o 2002&quot; y &quot;Evaluaci&#xF3;n directa de Langostino Colorado y Langostino Amarillo, entre la II y VIII Regiones, a&#xF1;o 2002&quot;, en el sentido de se&#xF1;alar que la pesca de investigaci&#xF3;n se realizar&#xE1; entre los d&#xED;as 16 de agosto y 31 de octubre de 2002, ambas fechas inclusive.</div><br></div>", "i": 6400590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de octubre de 2002. Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6400591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2200", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2200"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-10-11", "doble_articulado": false, "id_norma": "203850", "numero_fuente": "37391", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-24", "vigencias": [{"desde": "2002-10-24"