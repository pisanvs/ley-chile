{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10300984}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 1.619, de 17 de diciembre de 2021, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativas a actividad denominada &quot;Entrega de Juguetes&quot; en la ciudad de Coyhaique, y autoriz&#xF3; a Comunidad de Vecinos Calle R&#xED;o &#xD1;irehuao, para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  &#x2013;Corte total de v&#xED;a en calle R&#xED;o &#xD1;irehuao, entre Avenida Divisadero y calle Coraceros de la ciudad de Coyhaique, el d&#xED;a s&#xE1;bado 18 de diciembre de 2021, entre las 15:00 y las 18:00 hrs.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10300985}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesor Jur&#xED;dico, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10300986}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1619 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1619 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2070542", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-17", "doble_articulado": false, "id_norma": "1171277", "numero_fuente": "43151", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-01-13", "vigencia