{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306272}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.177, de 25 de agosto de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n N&#xBA; 471, de 1992, de esta Subsecretar&#xED;a, que modific&#xF3; la Resoluci&#xF3;n N&#xBA; 125, de 1986, que autoriz&#xF3; a INDUSTRIA PESQUERA TIMONEL S.A., a ampliar actividades pesqueras extractivas, con la nave &quot;Talism&#xE1;n&quot;, en virtud de haberse transferido esta nave a favor de Pesquera Qurbosa S.A.</div><br></div>", "i": 8306273}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de agosto de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306274}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1177", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1177"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AMPLIACION", "PESCA", "AUTORIZACION", "INDUSTRIA PESQUERA TIMOTEL S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-08-25", "doble_articulado": false, "id_norma": "75486", "numero_fuente": "35858", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-09-03", "vigencias": [{"desde": "1997-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-09-03", "fin_vigencia": "", "tipo_version": "3