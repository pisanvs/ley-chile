{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA;. 4</div><br><div class=\"p\">Certifico que el Consejo de este Banco Central de Chile en su Sesi&#xF3;n No. 04, celebrada el 29 de diciembre de 1989, adopt&#xF3; los siguientes acuerdos:</div><br></div>", "i": 6093654}, {"t": "<div><div class=\"p\">04-01-891229 - Compendios del Banco Central de Chile. Se acord&#xF3; establecer que las disposiciones que hagan referencia al &quot;Comit&#xE9; Ejecutivo&quot; en los Compendios de Normas de Importaci&#xF3;n, Normas de Exportaci&#xF3;n, Normas de Cambios Internacionales y Normas Financieras, deber&#xE1;n entenderse referidas al &quot;Consejo&quot;.</div><br></div>", "i": 6093655}, {"t": "<div><div class=\"p\">Santiago, 29 de diciembre de 1989.- V&#xED;ctor Vial del R&#xED;o, Secretario General Interino.</div><br></div>", "i": 6093656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "04", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-04"}, {"tipo": "5", "numero": "04-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-04-01"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION Nº. 4", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-29", "doble_articulado": false, "id_norma": "93215", "numero_fuente": "33558", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-30", "vigencias": [{"desde": "1989-12-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-3