{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7417191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.124, de 1 de diciembre de 2008, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la resoluci&#xF3;n exenta N&#xBA; 3.613, de 2007 que autoriz&#xF3; a la UNIVERSIDAD CAT&#xD3;LICA DEL NORTE para efectuar una pesca de investigaci&#xF3;n, conforme T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto &quot;Caracterizaci&#xF3;n de la pesquer&#xED;a de Algas Pardas de las Regiones XIV a IV&quot;, en el siguiente sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la presente pesca de investigaci&#xF3;n hasta el 30 de abril de 2009.</div><br></div>", "i": 7417192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de diciembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7417193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3124 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3124 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-01", "doble_articulado": false, "id_norma": "283977", "numero_fuente": "39246", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-26", "vigencias": [{"desde": "2008-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-26", "fin_vigencia": "", "tipo_v