{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,424.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8348649}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por don Luis Bascu&#xF1;an Santa Mar&#xED;a, como agregado a la polic&#xED;a de Valparriso, con ocasi&#xF3;n de la cat&#xE1;strofe de 16 de agosto de 1916, se le abonan, por gracia, y para los efectos de su retiro, cinco a&#xF1;os de servicios.</div><br></div>", "i": 8348650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, trece de noviembre de mil novecientos dieciocho.- Juan Luis Sanfuentes.- Pedro Garc&#xED;a de la Huerta.</div><br></div>", "i": 8348651}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3424", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3424"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-11-13", "doble_articulado": false, "id_norma": "141361", "numero_fuente": "12230", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-11-27", "vigencias": [{"desde": "1918-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-11-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-11-27", "fin_vigencia