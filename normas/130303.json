{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6149575}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xB0;2.563, de 11 de diciembre de 1998, se modific&#xF3; la cl&#xE1;usula N&#xB0;3, del decreto MOP N&#xB0;1.871, de 15 de octubre de 1998, que expropi&#xF3; los lotes N&#xB0;s 645, 661, 664, 669, 670, 671 y 673, para la obra Dise&#xF1;o Definitivo Regad&#xED;o Faja Maisan Canal Matriz, en el sentido que uno de los peritos que actu&#xF3; en la tasaci&#xF3;n es don Pablo Alex Mansilla Aravena y no don Miguel Hermindo Alegre Roco, como se indici&#xF3; en dicho decreto.</div><br></div>", "i": 6149576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6149577}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2563", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2563"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-12-11", "doble_articulado": false, "id_norma": "130303", "numero_fuente": "36264", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-15", "vigencias": [{"desde": "1999-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "1999-01-19", "fecha_version": "1999-01-15", "fecha_actualizacion_texto": "1999-01-15", "tipo_tratado": ""}