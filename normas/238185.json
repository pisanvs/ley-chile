{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6526819}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.381, de 5 de mayo de</div><div class=\"p\">2005, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EL</div><div class=\"p\">GOLFO S.A. para ampliar actividades pesqueras</div><div class=\"p\">extractivas con la nave &quot;Leopardo&quot;, en las &#xE1;reas</div><div class=\"p\">mar&#xED;timas que en cada caso se indican, donde podr&#xE1;</div><div class=\"p\">capturar los recursos hidrobiol&#xF3;gicos que a continuaci&#xF3;n</div><div class=\"p\">se se&#xF1;alan: a) En el &#xE1;rea mar&#xED;tima comprendida entre la</div><div class=\"p\">III a X Regionas, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, con cerco: Jibia, Caballa y Agujilla; b) En el &#xE1;rea mar&#xED;tima de la VIII Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con arrastre: Jibia, Caballa y Agujilla.</div><br></div>", "i": 6526820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de mayo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca </div></div>", "i": 6526821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1381 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1381 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-05-05", "fecha_derogacion": "2014-09-30", "doble_articulado": false, "id_norma": "238185", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-05-20", "vigencias": [{"desde"