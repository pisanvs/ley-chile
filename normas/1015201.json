{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8945599}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.026, de 6 de julio de 2010, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad total de las resoluciones exentas N&#xBA; 4.030, de 2005, y <a href=\"https://www.leychile.cl/Navegar?idNorma=270649&amp;idParte=0&amp;idVersion=\">N&#xBA; 820, de 2008</a>, ambas de esta Subsecretar&#xED;a de Pesca que autorizaron a Giovanni Francisco Arancibia Fuentes para continuar desarrollando actividades pesqueras extractivas con la nave &quot;Isla Tabon&quot;, en virtud de lo dispuesto en el art&#xED;culo 143 letra d) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8945600, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de julio de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div><br></div>", "i": 8945601}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2026 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2026 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-07-06", "fecha_derogacion": "2010-12-10", "doble_articulado": false, "id_norma": "1015201", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2010-07-12", "vigencias": [{"desde": "2010-12-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2010-07-12", "hasta": "2010-12-09", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inici