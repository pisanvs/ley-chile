{"html": [{"t": "<div><br><div class=\"p\">MODIFICA PAGO DE PRIMERA ANUALIDAD PARA TITULARES DE LICENCIAS TRANSABLES DE PESCA CLASE B</div></div>", "i": 9711028}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.959, de 17 de junio de 2016, modif&#xED;quese el valor de pago de la primera anualidad correspondiente a Langostino colorado XV-IV Regi&#xF3;n, de conformidad con la parte considerativa de la presente resoluci&#xF3;n, el <a href=\"https://www.leychile.cl/Navegar?idNorma=1088591&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 147 de 2016, del Ministerio de Econom&#xED;a, Fomento y Turismo</a> y la <a href=\"https://www.leychile.cl/Navegar?idNorma=1089558&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.054 de 2016</a>, respecto de los titulares de Licencias Transables de Pesca Clase B y en la forma que se indica en la siguiente tabla:</div><br><div class=\"p\">&nbsp; &nbsp; <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/58753.jpg\">.</div></div>", "i": 9711029}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de junio de 2016.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9711030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1959 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1959 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA PAGO DE PRIMERA ANUALIDAD PARA TITULARES DE LICENCIAS TRANSABLES DE PESCA CLASE B", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1036870; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion"