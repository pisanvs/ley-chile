{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 91 EXENTO, DE 1994 </div></div>", "i": 7160460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 91 de fecha 4 de Marzo de 1994 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericana de Educaci&#xF3;n y Cultura CIDEC, las adecuaciones introducidas al plan y programas de estudios de la carrera de Administraci&#xF3;n de Empresas, las que se insertaron en la Resoluci&#xF3;n Exenta N&#xB0; 2.875 de 1988. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1994.-</div><br></div>", "i": 7160461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160462}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "91 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-91 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 91 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "CENTRO INTERAMERICANO", "EDUCACION CULTURA", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-04", "doble_articulado": false, "id_norma": "20114", "numero_fuente": "34887", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-11", "vigencias": [{"desde": "1994-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-06-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-06-11", "fin_vigencia": "", "tipo_version":