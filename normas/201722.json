{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 8.943 EXENTA, DE 2002 </div></div>", "i": 6393386}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;8.943 de 2 de agosto del a&#xF1;o 2002, se han modificado las resoluciones exentas de Educaci&#xF3;n N&#xBA;s. 4.098 de 1999, 12.877 de 1999 y 5.937 de 2002, que aprobaron planes y programas especiales de estudio para todos los cursos de ense&#xF1;anza media, al Colegio Compa&#xF1;&#xED;a de Mar&#xED;a de Apoquindo, comuna de Las Condes, de Santiago.</div><br></div>", "i": 6393387}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de agosto de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6393388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8943 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8943 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 8.943 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-08-02", "doble_articulado": false, "id_norma": "201722", "numero_fuente": "37337", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-19", "vigencias": [{"desde": "2002-08-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_in