{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 939.- Santiago, a 6 de Setiembre de 1897.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de ciento cincuenta mil pesos ($ 150,000) al &#xED;tem 2 de la partida 48 del presupuesto del Ministerio del Interior para la continuacion de los trabajos del edificio del Congreso Nacional.</div><br><br></div>", "i": 8274013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica. FEDERICO ERRAZURIZ.- Antonio Valdes C.</div><br></div>", "i": 8274014}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "939", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-939"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1897", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-09-06", "doble_articulado": false, "id_norma": "22286", "numero_fuente": "5798", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-09-06", "vigencias": [{"desde": "1897-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1897-09-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresa