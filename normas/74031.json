{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 499 EXENTO,&nbsp; DE 1997 </div></div>", "i": 6040650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 499 de fecha 6 de mayo de 1997 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a la Sede que se indica del Centro de Formaci&#xF3;n T&#xE9;cnica Inacap, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 1997:</div><br><br><div class=\"p\">Sede N&#xBA; 9 - Valdivia</div><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; : Cocina Internacional.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; &nbsp;  : T&#xE9;cnico en Cocina Internacional.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (Decreto Exento N&#xBA; 266 del 02.05.95).</div><br></div>", "i": 6040651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de junio de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6040652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "499 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-499 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 499 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "CENTRO DE FORMACION TECNICA", "INACAP", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "VALDIVIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-05-06", "doble_articulado": false, "id_norma": "74031", "numero_fuente": "35803", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-30",