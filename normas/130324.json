{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6149625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta</div><div class=\"p\">No. 1.059 de 22.06.88, conforme Art. 5&#xB0; Transitorio C&#xF3;digo</div><div class=\"p\">de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas</div><div class=\"p\">proporcionales que corresponden a parcelas Nos. 1 a la 9 y</div><div class=\"p\">sitios N&#xB0;s. 1, 2, 4 y 5 del Proyecto de Parcelaci&#xF3;n &quot;Santa</div><div class=\"p\">Matilde&quot; de la comuna de Los Angeles, VIII Regi&#xF3;n, formado</div><div class=\"p\">por predio &quot;Santa Matilde de Curanad&#xFA;&quot;. Los Derechos de Agua</div><div class=\"p\">se extraen del r&#xED;o o estero Curanad&#xFA; y de derrames</div><div class=\"p\">originados en el mismo predio. Publicaci&#xF3;n hecha conforme</div><div class=\"p\">Art. 13 Ley No. 18.377.</div><br></div>", "i": 6149626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6149627}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1059", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1059"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-06-22", "doble_articulado": false, "id_norma": "130324", "numero_fuente": "33109", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-07-01", "vigencias": [{"desde": "1988-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"