{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6392527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;872, de 30 de abril de 2002, se expropiaron los lotes de terreno N&#xBA;s 44 y 45, superficies 1.597 y 1.599 m2, roles de aval&#xFA;o N&#xBA;9093-7 y 9093-6, comuna de Pe&#xF1;alol&#xE9;n, para la obra Proyecto Sistema Am&#xE9;rico Vespucio Sur. Ruta 78-Av. Grecia. Sector 5: Av. Vicu&#xF1;a Mackenna - Av. Grecia, Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Alfredo y Mar&#xED;a Luisa Dunner Martin, ascendente a la cantidad de $386.351.062.- para los lotes N&#xBA;s 44 y 45.</div><br></div>", "i": 6392528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6392529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "872", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-872"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-30", "doble_articulado": false, "id_norma": "201471", "numero_fuente": "37335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-08-16", "vigencias": [{"desde": "2002-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-08-16", "fecha_version": "2002-08-16", "fe