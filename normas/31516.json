{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 8923931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 546, de 13 de Mayo de 1991, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, se modifica numeral 3&#xB0; de la</div><div class=\"p\">Resoluci&#xF3;n N&#xB0; 1.354, de 1990, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a don ERNET SILVA SANHUEZA, R.U.T. N&#xB0;</div><div class=\"p\">4.918.995-8, domiciliado en Talcahuano, para iniciar</div><div class=\"p\">actividades pesqueras, en el sentido de incluir la</div><div class=\"p\">captura del recurso Albacora o pez espada (Xiphias</div><div class=\"p\">gladius), en el litoral de las Regiones I a X, con el</div><div class=\"p\">arte de pesca enmalle.</div><br></div>", "i": 8923932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 13 de Mayo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8923933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "546", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-546"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ERNET SILVA SANHUEZA", "PESCA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-05-13", "doble_articulado": false, "id_norma": "31516", "numero_fuente": "33979", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-05-29", "vigencias": [{"desde": "1991-05-29", "hasta": "", "tipo_vers