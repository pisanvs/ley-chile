{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;52 EXENTO, DE 2001 </div></div>", "i": 7281741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;52, de fecha 23 de enero de 2001 del Ministerio de Educaci&#xF3;n, se reemplazan a contar del a&#xF1;o 2001, las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Contabilidad y Administraci&#xF3;n, Centro de Estudios Contables Ecacec, que fueran aprobadas por decreto exento N&#xBA;179, del 11 de julio de 1991.</div><br></div>", "i": 7281742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de marzo de 2001.- Patricio Vilaplana Barberis, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 7281743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "52 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-52 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº52 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-01-23", "doble_articulado": false, "id_norma": "183175", "numero_fuente": "36920", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-23", "vigencias": [{"desde": "2001-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fecha_ingreso": "2001-03-23", "