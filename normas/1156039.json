{"html": [{"t": "<div><div class=\"p\">Donativo</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, i Diciembre 2 de 1820</div></div>", "i": 10214996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se acepta la oblacion voluntaria i graciosa que hace don Jos&#xE9; Vicente Ovalle de seiscientas fanegas de harina en hoja para ausilio de los patriotas concentrados en Talcahuano, cuya generosidad reconoce al Supremo Gobierno a nombre del Estado; d&#xE9;nsele las gracias por el Ministro de Hacienda.-Trascr&#xED;base al Gobernador de Valparaiso con insercion de este decreto para que recoja i reciba de don Carlos Ovalle las harinas aceptadas e impr&#xED;mase en la Ministerial.-</div></div>", "i": 10214997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; O&apos;Higgins.-Dr. Rodr&#xED;guez. </div></div>", "i": 10214998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Donativo", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1820-12-02", "doble_articulado": false, "id_norma": "1156039", "numero_fuente": "1820", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1820-12-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1820-12-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1820-12-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-04-08", "fecha_version": "1820-12-02", "fecha_actualizacion_texto": "2021-04-0