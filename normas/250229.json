{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA </div></div>", "i": 6571914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/N&#xBA; Ex-3.125, de fecha 22 de mayo de 2006, otorga a Agr&#xED;cola y Ganadera Sta. Victoria Ltda., RUT N&#xBA; 77.762.260-9, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de Sujeto en las ventas de Ganado Vivo, establecido en la resoluci&#xF3;n N&#xBA; Ex-3.721, de 28-07-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 6571915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 22 de mayo de 2006.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6571916}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3125 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-3125 EXENTA"}, {"tipo": "3", "numero": "DRE-08-3125 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-3125 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-22", "doble_articulado": false, "id_norma": "250229", "numero_fuente": "38482", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-06