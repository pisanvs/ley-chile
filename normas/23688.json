{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la ereccion de un monumento en Iquique en honor de Eleuterio Ram&#xED;rez</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,043.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se autoriza la ereccion, en la plaza Montt de Iquique, de un monumento en honor del Coronel don Eleuterio Ram&#xED;rez, que ser&#xE1; costeado con erogaciones populares.</div><br></div>", "i": 8275904}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 27 de Diciembre de 1915.- JUAN LUIS SANFUENTES.- J. Elias Balmaceda </div></div>", "i": 8275905}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3043", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3043"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA LA ERECCION DE UN MONUMENTO EN IQUIQUE EN HONOR DE ELEUTERIO RAMIREZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELEUTERIO RAMIREZ", "MONUMENTO", "ERECCION", "AUTORIZACION", "IQUIQUE", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-12-27", "doble_articulado": false, "id_norma": "23688", "numero_fuente": "11355", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1915-12-29", "vigencias": [{"desde": "1915-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ún