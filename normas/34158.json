{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 283, de 9 de febrero de 1996 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a MANUEL RICARDO ESCANDON ORELLANA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Ecuador N&#xB0; 1700, Valdivia, X Regi&#xF3;n, en la l&#xED;nea de elaboraci&#xF3;n de Congelado, el recurso Loco (Concholepas concholepas).</div><div class=\"p\">&nbsp; &nbsp; La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales y reglamentarias vigentes o que se establezcan.</div><br></div>", "i": 8291584}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 9 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291585}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "283", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-283"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMPLIACION", "PESCA", "AUTORIZACION", "MANUEL RICARDO", "ESCANDON ORELLANA", "VALDIVIA", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-09", "doble_articulado": false, "id_norma": "34158", "numero_fuente": "35402", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-26", "vigencias": [{"desde": "1996-02-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia