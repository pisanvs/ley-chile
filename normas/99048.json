{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330034}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 572, de 24 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a CORNELIO RIVERA MORALES, para iniciar actividades&nbsp; pesqueras&nbsp; de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en sitio 1, sector Norte Taltal, II Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Picado y Secado de Algas: Cochayuyo, Cotoni, Chasca, Chasc&#xF3;n, Chicorea de mar, Huiro, Luche, Luga-Luga y Pelillo.</div><br></div>", "i": 8330035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330036}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "572", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-572"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "CORNELIO RIVERA MORALES", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-24", "doble_articulado": false, "id_norma": "99048", "numero_fuente": "36064", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-14", "vigencias": [{"desde": "1998-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig