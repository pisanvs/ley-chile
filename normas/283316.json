{"html": [{"t": "<div><div class=\"p\">AUTORIZA A EMISOR DE BOLETAS ELECTR&#xD3;NICAS </div></div>", "i": 6701673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 157, de 2 de diciembre de 2008, autoriza a contribuyente como emisor de boletas electr&#xF3;nicas.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boletas electr&#xF3;nicas, a contar del mes de diciembre de 2008, al contribuyente RUT N&#xBA;89.862.200-5.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2008.</div><br></div>", "i": 6701674}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "157 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-157 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-02", "doble_articulado": false, "id_norma": "283316", "numero_fuente": "39230", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-05", "vigencias": [{"desde": "2008-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul