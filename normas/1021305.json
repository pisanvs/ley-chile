{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9080250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.716, de 10 de diciembre de 2010, de esta Subsecretar&#xED;a de Pesca, decl&#xE1;rase la caducidad total de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1006519&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 3.083 de 2009</a>, de esta Subsecretar&#xED;a, que autoriz&#xF3; a LOTA PROTEIN S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Santa Mar&#xED;a II&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la V a VII y IX a X Regiones, sobre los recursos hidrobiol&#xF3;gicos Alfonsino y Besugo, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado mediante Informe T&#xE9;cnico citado en Visto de la resoluci&#xF3;n extractada.</div><br></div>", "i": 9080251, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de diciembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9080252}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3716 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3716 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-10", "doble_articulado": false, "id_norma": "1021305", "numero_fuente": "39837", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-12-17", "vigencias": [{"desde": "2010-12-17", "hasta": "", "tipo_version": "3