{"html": [{"t": "<div><div class=\"p\">FIJA NUEVO HORARIO DE FUNCIONAMIENTO DE JUNTAS INSCRIPTORAS</div><br><br></div>", "i": 6480836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  A contar del d&#xED;a martes 1 de junio y hasta el cierre del per&#xED;odo extraordinario de inscripciones electorales de 2004, las Juntas Inscriptoras de todo el pa&#xED;s funcionar&#xE1;n en horario de 9:00 a 14:00 horas. Sin embargo, si al t&#xE9;rmino del horario se&#xF1;alado se encontraren a&#xFA;n presentes personas que requieran su inscripci&#xF3;n, las Juntas Inscriptoras continuar&#xE1;n su funcionamiento, pero no m&#xE1;s all&#xE1; de las 20 horas, salvo el d&#xED;a s&#xE1;bado, en que no actuar&#xE1;n m&#xE1;s all&#xE1; de las 14 horas.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada por resoluci&#xF3;n O - N&#xBA; 912, del 24 de mayo de 2004.</div><br></div>", "i": 6480837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de mayo de 2004.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 6480838}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "912", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-912"}, {"tipo": "3", "numero": "O-912", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-912"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "FIJA NUEVO HORARIO DE FUNCIONAMIENTO DE JUNTAS\nINSCRIPTORAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUNTAS INSCRIPTORAS", "FUNCIONAMIENTO", "INSCRIPCIONES ELECTORALES", "HORARIO DE ATENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-24", "doble_articulado": false, "id_norma": "225668", "numero_fuente": "37871", "t