{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LIBERA A LOS CUERPOS DE BOMBEROS DEL IMPUESTO QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5969794}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Lib&#xE9;rase a los Cuerpos de Bomberos</div><div class=\"p\">del impuesto de $ 15 por d&#xF3;lar establecido en el</div><div class=\"p\">art&#xED;culo 9&#xB0; transitorio de la ley N&#xB0; 11,575, respecto de las importaciones que efect&#xFA;en para sus fines espec&#xED;ficos.</div><div class=\"p\">&nbsp; &nbsp; Esta liberaci&#xF3;n regir&#xE1; desde el 14 de Agosto de 1954, fecha de vigencia de la ley N&#xB0; 11,575&quot;. </div></div>", "i": 5969795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, trece de Octubre de mil novecientos cincuenta y cuatro.- CARLOS IBA&#xD1;EZ DEL CAMPO.- J. Prat E.</div><br></div>", "i": 5969796}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11688", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11688"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LIBERA A LOS CUERPOS DE BOMBEROS DEL IMPUESTO QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CUERPOS BOMBEROS", "IMPUESTO", "EXENCION", "IMPORTACION", "FRANQUICIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1954-10-13", "doble_articulado": false, "id_norma": "26760", "numero_fuente": "22979", "tipo_version": "3