{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 6.456 EXENTA, DE 17 DE DICIEMBRE DE 2019</div></div>", "i": 10107908}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se han modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=1073393&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 9.310, de 2014</a>, del Ministerio de Educaci&#xF3;n, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Colegio del Sagrado Coraz&#xF3;n - Apoquindo, RBD 8878-1, comuna de Las Condes, Regi&#xF3;n Metropolitana, en el sentido de sustituir los planes de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div></div>", "i": 10107909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de enero de 2020.- Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10107910}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6456 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6456 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 6.456 EXENTA, DE 17 DE DICIEMBRE DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1737341", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-01-08", "doble_articulado": false, "id_norma": "1143352", "numero_fuente": "42601", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-03-11", "vigencias": [{"desde": "2020-03-11", "hasta": "", "tipo_version": "3