{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 668 EXENTO, DE 2006 </div></div>", "i": 7332918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 668, de fecha 25 de mayo de 2006, del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Jorge Alvarez Echeverr&#xED;a, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 2006, en la Sede Central de La Serena, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; : Secretariado Ejecutivo en Espa&#xF1;ol con</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  menci&#xF3;n en Computaci&#xF3;n o Ingl&#xE9;s, cambia</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  por:</div><div class=\"p\">Carrera&nbsp; &nbsp; : Asistente Ejecutivo Computacional</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp;  : Asistente Ejecutivo Computacional (Decreto</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  exento N&#xBA;275 del 25.10.90)</div><br></div>", "i": 7332919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de julio de 2006.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 7332920}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "668 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-668 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 668 EXENTO, DE 2006", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-05-25", "fecha_derogacion": "2013-12-10