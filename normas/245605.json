{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7326576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 4.046, de 23 de noviembre de 2005, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto parcialmente la resoluci&#xF3;n N&#xBA; 1.502, de 1997, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA POLAR S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Polar Mist&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a la X Regi&#xF3;n, sobre el recurso Jurel Trachurus Murphyi, en virtud de la carta de renuncia CI. Subpesca N&#xBA; 7.615, de 2005, complementada con ingreso CI. Subpesca N&#xBA; 10.294, de 2005, y de lo informado en Informe T&#xE9;cnico citados en Visto.</div><br></div>", "i": 7326577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de noviembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7326578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4046 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4046 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-11-23", "fecha_derogacion": "2007-04-12", "doble_articulado": false, "id_norma": "245605", "numero_fuente": "38349", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-12-29", "vigencias": [{"desde": "2007-04-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-12-29", "hasta": "2007-04-11", "tipo_version