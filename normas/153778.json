{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7412892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 1.901 de 09 de Septiembre de 1987, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a Sector Excluldo y Sector Expropiado Predio &quot;Santa Mar&#xED;a de Colina&quot; de las comunas de Colina y Lampa, Regi&#xF3;n Metropolitana y Derechos Aprovechamiento Aguas que corresponden a parcelas N&#xB0;s. 1 a la 22, sitios N&#xB0;s. 1 al 12 del Proyecto de Parcelaci&#xF3;n &quot;La Copa&quot; formado por predio se&#xF1;alado. Los Derechos de Agua se extraen del Canal &quot;El Carmen&quot; derivado del R&#xED;o Maipo.</div><div class=\"p\">Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.- </div></div>", "i": 7412893}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 7412894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1901 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1901 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SUBSECRETARÍA DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-09", "doble_articulado": false, "id_norma": "153778", "numero_fuente": "32871", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-15", "vigencias": [{"desde": "1987-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc