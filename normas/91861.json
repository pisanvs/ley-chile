{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8320862}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.925 de 07 de Diciembre de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por seis meses a contar del 26 de Septiembre de 1989, el plazo otorgado a Pesquera Mares de Chile S.A. RUT No. 96.534.020-3, domiciliada en Santiago. para empezar a operar el establecimiento de cultivo autorizado por la resoluci&#xF3;n No. 1.093, de 1988, de esta Subsecretar&#xED;a. en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor </div></div>", "i": 8320863}, {"t": "<div><div class=\"p\">Valpara&#xED;so. 07 de Diciembre de 1989.- Roberto Cabezas Bello. Subsecretario de Pesca.</div><br></div>", "i": 8320864}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1925", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1925"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-07", "doble_articulado": false, "id_norma": "91861", "numero_fuente": "33551", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-21", "vigencias": [{"desde": "1989-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "