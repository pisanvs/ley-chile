{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6543014}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.286, de 29 de septiembre de 2005, de esta Subsecretar&#xED;a, rech&#xE1;zase la solicitud de concesi&#xF3;n de acuicultura N&#xBA; 201104023 presentada por JUAN ENRIQUE FARIAS RUBIO, para instalar y operar un centro de cultivo ubicado en Bah&#xED;a Pargua, al noroeste de Punta Tique, X Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Rech&#xE1;zase solicitud CI Subpesca N&#xBA; 6.472 de 2003, para ampliar el plazo para someter el proyecto N&#xBA; 201104023 al Sistema de Evaluaci&#xF3;n de Impacto Ambiental. </div></div>", "i": 6543015}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de septiembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6543016}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3286 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3286 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-29", "doble_articulado": false, "id_norma": "242674", "numero_fuente": "38281", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-07", "vigencias": [{"desde": "2005-10-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci