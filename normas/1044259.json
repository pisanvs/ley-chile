{"html": [{"t": "<div><br><div class=\"p\">ORDENAN EXPROPIACIONES QUE INDICAN</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9299247}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 754, de fecha 7 de septiembre de 2012, del Serviu IV Regi&#xF3;n de Coquimbo, se orden&#xF3; expropiar, conforme al art&#xED;culo 51 ley 16.391 y DL 2.186/78, el inmueble denominado Lote 8 de superficie aproximada de 152,70 m&#xB2;, Rol N&#xBA; 36-021, de aparente dominio de Susana Patricia Ram&#xED;rez Carrasco; ubicado en calle Juan Antonio R&#xED;os N&#xBA; 292, comuna de Coquimbo. Comisi&#xF3;n de Peritos conformada por profesionales Marcia Aqueveque Mart&#xED;nez, Juan Manuel Gantes Mel&#xE9;ndez y Miguel Rubio Vega, seg&#xFA;n informe de 5 de junio de 2012, fij&#xF3; indemnizaci&#xF3;n provisional en $66.285.114.- pagadero al contado.- </div></div>", "i": 9299248}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director Serviu IV Regi&#xF3;n Coquimbo.</div></div>", "i": 9299249}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "754", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-754"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN IV REGIÓN DE COQUIMBO"], "titulo_norma": "ORDENAN EXPROPIACIONES QUE INDICAN; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-07", "doble_articulado": false, "id_norma": "1044259", "numero_fuente": "40374", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-01", "vigencias": [{"desde": "2012-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ún