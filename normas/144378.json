{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6194006}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 114, de fecha 04.02.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n, se autoriza a la se&#xF1;ora Marcia de la Cruz Filippi Fern&#xE1;ndez para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6194007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 04.02.87.- H&#xE9;ctor Soto Miranda, Secretario Regional Ministerial de Transportes y Telecomunicaciones subrogante.- V Regi&#xF3;n.</div><br></div>", "i": 6194008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "114 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-114 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-04", "doble_articulado": false, "id_norma": "144378", "numero_fuente": "32697", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-13", "vigencias": [{"desde": "1987-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-13", "fin_vigencia": "", "tipo