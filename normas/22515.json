{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Escuela Militar Lei n&#xFA;m. 1,264.- Santiago, a 6 de Setiembre de 1899.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948729}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Dest&#xED;nase hasta la suma de dieziocho mil pesos para las reparaciones i arreglos que es necesario hacer en el edificio de la Escuela Militar.</div><br><br></div>", "i": 5948730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Concha.</div><br></div>", "i": 5948731}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1264", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1264"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "ESCUELA MILITAR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESCUELA MILITAR", "REPARACION", "FONDOS", "DESTINACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-09-06", "doble_articulado": false, "id_norma": "22515", "numero_fuente": "6394", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-09-07", "vigencias": [{"desde": "1899-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-09-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-01-29", "fecha_versio