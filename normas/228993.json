{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6492040}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 425 de 16 de julio de 2004 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme DL N&#xBA; 2.186 de 1978, del Lote N&#xBA; 14 correspondiente al inmueble ubicado en Avenida Suiza N&#xBA; 295, presunto rol de aval&#xFA;o N&#xBA; 556-14, comuna de Cerrillos, aparente dominio de C&#xED;a. Agric. y Veterinari Agrovet. Comisi&#xF3;n integradas por peritos Paola Domingo Porcella, constructor civil, Claudio Correa Barahona, arquitecto y Pedro Almonacid Colin, ingeniero civil. Seg&#xFA;n informe de fecha 2 de junio de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $57.404.747.- pagadera al contado. </div></div>", "i": 6492041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6492042}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "425", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-425"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-16", "doble_articulado": false, "id_norma": "228993", "numero_fuente": "37937", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-16", "vigencias": [{"desde": "2004-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia