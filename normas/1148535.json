{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCI&#xD3;N N&#xBA; 778 EXENTA, 31 DE ENERO DE 2019</div></div>", "i": 10151988}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha rectificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=1102342&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.767, de 2017, del Ministerio de Educaci&#xF3;n</a>, que modific&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al Colegio Cordillera, comuna de Las Condes, provincia de Santiago, Regi&#xF3;n Metropolitana.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del Sector de Computaci&#xF3;n para 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10151989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de enero de 2019.- Ra&#xFA;l Figueroa Salas, Subsecretario de Educaci&#xF3;n.</div><div class=\"p\"> </div><br></div>", "i": 10151990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "778 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-778 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO RESOLUCIÓN Nº 778 EXENTA, 31 DE ENERO DE 2019", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1801157", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-01-31", "doble_articulado": false, "id_norma": "1148535", "numero_fuente": "42734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-08-19", "vigencias": [{"desde": "2020-08-19", "hasta": "", "tipo_version