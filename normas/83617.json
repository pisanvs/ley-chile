{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8315386}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 45 de fecha 27 de febrero de 1990 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la Asociaci&#xF3;n Gremial de Comerciantes del Mercado Seminario de &#xD1;u&#xF1;oa inscrita bajo el n&#xFA;mero 807 del registro que lleva este ministerio por haberse configurado respecto de ella la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18 No. 2 letra c) del Decreto Ley 2.757.-</div><br></div>", "i": 8315387}, {"t": "<div><br><div class=\"p\">Jorge Marshall Rivera, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8315388}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "45", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-45"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-02-27", "doble_articulado": false, "id_norma": "83617", "numero_fuente": "33638", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-04", "vigencias": [{"desde": "1990-04-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-04-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-04-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1998-01-08", "fecha_version": "1990-04-04", "fe