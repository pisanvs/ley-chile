{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7267978}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;682, de 5 de abril de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a Compa&#xF1;Ia Pesquera Camanchaca S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA;11, de 1980, de esta Subsecretar&#xED;a, en orden a incorporar a la planta ubicada en Manuel Montt N&#xBA;1941, comuna de Tom&#xE9;, provincia de Concepci&#xF3;n, VIII Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Fresco-enfriado y Congelado, el recurso Reineta.</div><br></div>", "i": 7267979}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de abril de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7267980}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "682", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-682"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-05", "doble_articulado": false, "id_norma": "166350", "numero_fuente": "36644", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-19", "vigencias": [{"desde": "2000-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacio