{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6570367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.121, de 24 de abril de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a FWP S.A. para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Ruta 68 N&#xBA; 1240, Placilla de Pe&#xF1;uelas, Valpara&#xED;so, V Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Fresco-enfriado, Fresco-refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6570368}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de abril de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6570369}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1121 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1121 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-24", "doble_articulado": false, "id_norma": "249783", "numero_fuente": "38467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-19", "vigencias": [{"desde": "2006-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-05-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso":