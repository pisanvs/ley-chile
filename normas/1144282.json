{"html": [{"t": "<div><div class=\"p\">RESUELVE RECURSO QUE INDICA</div></div>", "i": 10114623}, {"t": "<div><br><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por R.M. Ex. N&#xB0;94 de este Ministerio, ac&#xF3;gese el recurso de reposici&#xF3;n, interpuesto por don Mart&#xED;n Manterola Urz&#xFA;a, en representaci&#xF3;n de Gabriel Ramos L&#xF3;pez, en contra del <a href=\"https://www.leychile.cl/Navegar?idNorma=1139176&amp;idParte=&amp;idVersion=\">Dcto. Ex. N&#xB0;260, de 2019</a>, del Ministerio de Econom&#xED;a, Fomento y Turismo, s&#xF3;lo en tanto se deja sin efecto el acto impugnado, retrotray&#xE9;ndose el procedimiento al estado de consultar al Consejo Zonal de Pesca respectivo, esta vez remitiendo todos los antecedentes que resultan pertinentes.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10114624}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de marzo de 2020.- Lucas Palacios Covarrubias, Ministro de Econom&#xED;a, Fomento y Turismo.</div><div class=\"p\"> </div><br></div>", "i": 10114625}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "94 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-94 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE ECONOMÍA Y EMPRESAS DE MENOR TAMAÑO"], "titulo_norma": "RESUELVE RECURSO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1748444; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-03-17", "doble_articulado": false, "id_norma": "1144282", "numero_fuente": "42631", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-04-15", "vigencias": [{"desde": "2020-04-15", "hasta": "