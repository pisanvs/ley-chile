{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON ORLANDO DEL CARMEN CERDA ALAMOS PARA DESARROLLAR ACTIVIDADES PESQUERAS </div></div>", "i": 6258268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 309, de 04 de Junio de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Orlando del Carmen Cerda Alamos, RUT. 7.093.515-5 domiciliado en Tongoy, calle La Serena N&#xBA; 057, para instalar y operar un establecimiento de cultivo de alga Gracilaria spp., en un sector del muelle de la Bah&#xED;a de Tongoy, de una superficie total de 12.672 m2. de fondo de mar. </div></div>", "i": 6258269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 04 de Junio de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6258270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "309", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-309"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A DON ORLANDO DEL CARMEN CERDA ALAMOS PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-06-04", "fecha_derogacion": "1986-03-04", "doble_articulado": false, "id_norma": "163389", "numero_fuente": "32208", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-06-28", "vigencias": [{"desde": "1986-03-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-06-28", "hasta": "1986-03-03", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"