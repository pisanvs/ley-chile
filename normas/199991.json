{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6387465}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;540, de fecha 28 de marzo de 2002, se expropi&#xF3; el lote de terreno N&#xBA;13-A, superficie 2.669 m&#xB2;, rol de aval&#xFA;o N&#xBA;225-116, comuna de Olmu&#xE9;, V Regi&#xF3;n, para la obra &apos;&apos;Ruta F-10-G, Cuesta La Dormida, Etapa 2, Km. 10.984 al 34,500&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario don Norberto Renato Hidalgo Pezoa, ascendente a la cantidad de $3.078.688.- </div></div>", "i": 6387466}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6387467}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "540", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-540"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-28", "doble_articulado": false, "id_norma": "199991", "numero_fuente": "37296", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-01", "vigencias": [{"desde": "2002-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-07-03", "fecha_version": "2002-07-01", "fecha_actualizacion_texto": "2002-07-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructur