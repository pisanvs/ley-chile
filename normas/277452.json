{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISORES DE BOLETAS ELECTR&#xD3;NICAS </div></div>", "i": 7029646}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;101, de 2 de septiembre de 2008, que autoriza a contribuyentes como emisores de boletas electr&#xF3;nicas.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de boletas electr&#xF3;nicas a contar del mes de agosto de 2008 a contribuyentes RUT 93.910.000-8, RUT 96.503.680-6, RUT 96.872.100-3 y RUT 96.969.060-8.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2008.</div><br></div>", "i": 7029647}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "101 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-101 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-09-02", "doble_articulado": false, "id_norma": "277452", "numero_fuente": "39157", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-09-06", "vigencias": [{"desde": "2008-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-09-06", "fin_vigencia": "", "tipo_version": "3