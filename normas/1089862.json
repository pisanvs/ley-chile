{"html": [{"t": "<div><br><div class=\"p\">DEJA SIN EFECTO RESOLUCIONES EXENTAS QUE INDICA</div></div>", "i": 9699117}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.158, de 19 de abril de 2016, de esta Subsecretar&#xED;a, d&#xE9;jese sin efecto las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=265455&amp;idParte=&amp;idVersion=\">N&#xBA; 2.814</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=265458&amp;idParte=&amp;idVersion=\">N&#xBA; 2.817</a>, ambas de 2007, que autorizaron a Compa&#xF1;&#xED;a Pesquera Camanchaca S.A., para realizar actividades extractivas en alta mar, con las naves &quot;Oficina Vigo&quot;, inscrita bajo el N&#xBA; 2.325 y &quot;Esturi&#xF3;n&quot;, inscrita bajo el N&#xBA; 2409, ambos del Registro de Matr&#xED;cula de Naves Mayores por configurarse la causal establecida en el art&#xED;culo 11.- letra a) del decreto supremo N&#xBA; 360, de 2005, del actual Ministerio de Econom&#xED;a, Fomento y Turismo.</div><br><br></div>", "i": 9699118, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de abril de 2016.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9699119}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1158 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1158 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIONES EXENTAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1019044"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-04-