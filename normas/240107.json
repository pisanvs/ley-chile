{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6533052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 451, de fecha 31 de mayo de 2005, se expropiaron los lotes de terreno N&#xBA;s 57-C y 58-F, superficies 899 y 1.212 m&#xB2;, rol N&#xBA; 278-48, comuna de Pelluhue, para la obra &quot;Camino Chovellen - Cobquecura, Sector Chovellen - L&#xED;mite Regional, tramo Km. 18,260.00 a Km. 35,158.60&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Roberto Cruz Suazo V&#xE1;squez, ascendente a la cantidad de $5.761.560.- para los lotes N&#xBA;s. 57-C y 58-F.</div><br></div>", "i": 6533053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6533054}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "451", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-451"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-31", "doble_articulado": false, "id_norma": "240107", "numero_fuente": "38211", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-15", "vigencias": [{"desde": "2005-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-07-15", "fecha_version": "2005-07-15", "fecha_actualizacion_texto": "2005-07-15", "tipo_tr