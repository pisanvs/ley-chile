{"html": [{"t": "<div><div class=\"p\">CANCELA PERSONALIDAD JUR&#xCD;DICA A &quot;ASOCIACI&#xD3;N DE EXPORTADORES DE JUGOS CONCENTRADOS DE CHILE, ASOCIACI&#xD3;N GREMIAL&quot; </div></div>", "i": 7367614}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ministerial N&#xBA; 162, de fecha 31 de diciembre de 2007, se cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n de Exportadores de Jugos Concentrados de Chile, Asociaci&#xF3;n Gremial&quot;, inscrita bajo el N&#xBA; 2.031, por haberse configurado la causal contemplada en las letras b), c) y d) del n&#xFA;mero 2) del art&#xED;culo 18 del decreto ley N&#xBA; 2.757, de 1979.</div><br></div>", "i": 7367615}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rodrigo Hern&#xE1;ndez Ben&#xED;tez, Jefe Unidad Asociaciones Gremiales y Martilleros.</div><br></div>", "i": 7367616}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "162", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-162"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "CANCELA PERSONALIDAD JURÍDICA A \"ASOCIACIÓN DE\nEXPORTADORES DE JUGOS CONCENTRADOS DE CHILE, ASOCIACIÓN\nGREMIAL\"", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-31", "doble_articulado": false, "id_norma": "270412", "numero_fuente": "39034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-04-11", "vigencias": [{"desde": "2008-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-04-11", "fin_vigencia": ""}, "vigencias_version_