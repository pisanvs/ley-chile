{"html": [{"t": "<div><div class=\"p\">RECTIFICAN RESOLUCIONES EXPROPIATORIAS QUE INDICAN</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9299687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.780, de 10 de septiembre de 2012, de Serviu Regi&#xF3;n del Maule, rectifico <a href=\"https://www.leychile.cl/Navegar?idNorma=1032400&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 3.889, de 3 de noviembre de 2011</a>, ambas de Serviu Regi&#xF3;n del Maule, en el sentido que se corrige error de referencia de resolutivo 1&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 3.889, de 3 de noviembre de 2011, debiendo decir que la superficie de terreno expropiado es de 4.020 m&#xB2; y no 2.020 m&#xB2; como err&#xF3;neamente se indic&#xF3;.- </div></div>", "i": 9299688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Clarisa Ayala Arenas, Directora Serviu Regi&#xF3;n del Maule.</div></div>", "i": 9299689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3780 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3780 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN VII REGIÓN DEL MAULE"], "titulo_norma": "RECTIFICAN RESOLUCIONES EXPROPIATORIAS QUE INDICAN; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-10", "doble_articulado": false, "id_norma": "1044261", "numero_fuente": "40374", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-01", "vigencias": [{"desde": "2012-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-