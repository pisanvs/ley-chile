{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE I.V.A. A CONTRIBUYENTES QUE INDICA</div><br></div>", "i": 8970827}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La XI Direcci&#xF3;n Regional Coyhaique del Servicio de Impuestos Internos revoca la calidad de agente retenedor del Impuesto al Valor Agregado en la actividad que se indica, de los contribuyentes que se se&#xF1;alan.</div><br><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/12952.jpg\">. </div><br><div class=\"p\">&nbsp; &nbsp;  A contar de la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial, conforme a la facultad delegada en la resoluci&#xF3;n exenta N&#xBA; 142, de fecha 26/12/2005, emanada de la Direcci&#xF3;n Nacional de este Servicio.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos (www. sii.cl).</div></div>", "i": 8970828}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "690", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-690"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "XI DIRECCIÓN REGIONAL DE COYHAIQUE"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE I.V.A. A CONTRIBUYENTES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-08-12", "doble_articulado": false, "id_norma": "1016619", "numero_fuente": "39747", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-08-27", "vigencias": [{"desde": "2010-08-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"