{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar a don Maximiliano Aldunate.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,783.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- En atencion a los servicios prestados en la Secretaria del Senado por el portero, Maximiliano Aldunate, conc&#xE9;desele, por gracia, el derecho de jubilar con la pension anual de mil ochocientos pesos.</div><br></div>", "i": 8275591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 23 de Julio de 1913.- Ramon Barros Luco.- Manuel Rivas Vicu&#xF1;a.</div><br></div>", "i": 8275592}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2783", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2783"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE DERECHO A JUBILAR A DON  MAXIMILIANO ALDUNATE.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MAXIMILIANO ALDUNATE", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-07-23", "doble_articulado": false, "id_norma": "23494", "numero_fuente": "10637", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-07-29", "vigencias": [{"desde": "1913-07-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-07-