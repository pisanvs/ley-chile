{"html": [{"t": "<div><div class=\"p\">AUTORIZA A EMISOR DE BOLETAS ELECTR&#xD3;NICAS</div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 58 de 9 de mayo de 2008, que autoriza a contribuyente como emisor de boletas electr&#xF3;nicas.</div><br></div>", "i": 7369398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boletas electr&#xF3;nicas, a contar del mes de mayo 2008, al contribuyente RUT N&#xBA; 96.903.620-7.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de mayo de 2008.</div><br></div>", "i": 7369399}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "58 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-58 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A EMISOR DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-05-09", "doble_articulado": false, "id_norma": "271156", "numero_fuente": "39061", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-14", "vigencias": [{"desde": "2008-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-05-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion