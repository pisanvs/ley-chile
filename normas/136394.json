{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 108.- Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168687}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de veinte mil pesos ($ 20,000) al &#xED;tem 5 de la partida 20 del presupuesto del Ministerio de Industria y Obras P&#xFA;blicas &#xE1; fin de atender &#xE1; los gastos que demande la instalaci&#xF3;n definitiva de la Escuela de Artes y Oficios en su nuevo local. </div></div>", "i": 6168688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, o&#xED;do el Consejo de Estado, he tenido &#xE1; bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese &#xE1; efecto como ley de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, &#xE1; 12 de Septiembre de 1893.- JORGE MONTT.- V.</div><div class=\"p\">D&#xE1;vila Larrain.</div><br><br></div>", "i": 6168689}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "108", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-108"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-09-12", "doble_articulado": false, "id_norma": "136394", "numero_fuente": "4619", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-09-13", "vigencias": [{"desde": "1893-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vige