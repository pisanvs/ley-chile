{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8966447}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.466, de 11 de agosto de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase la distribuci&#xF3;n de 10.390 toneladas de Jurel con cargo a la fracci&#xF3;n establecida en la letra c) del art&#xED;culo 4&#xBA; del decreto exento N&#xBA; 442, de 2010, modificado mediante decreto exento N&#xBA; 866 de 2010, ambos del Ministerio de Econom&#xED;a, Fomento y Turismo, entre las organizaciones de pescadores artesanales y embarcaciones artesanales que se indica en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la presente resoluci&#xF3;n se encuentra publicado en www.subpesca.cl</div></div>", "i": 8966448}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de agosto de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 8966449}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2466 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2466 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-08-11", "doble_articulado": false, "id_norma": "1016333", "numero_fuente": "39738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-08-17", "vigencias": [{"desde": "2010-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig