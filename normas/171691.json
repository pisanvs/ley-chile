{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO&nbsp; EN SU SESION N&#xBA;849 </div><br></div>", "i": 6284668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 849, celebrada el 29 de junio de 2000, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">849-04-000629 - Tasa de inter&#xE9;s para pago diferido de derechos de Aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3;, en conformidad con lo establecido en la letra c) del art. N&#xBA; 10 de la ley N&#xBA; 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que expira el 31 de diciembre de 2000, ser&#xE1; de 12,25% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div><br></div>", "i": 6284669}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de junio de 2000.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6284670}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "849", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-849"}, {"tipo": "5", "numero": "849-04-000629", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-849-04-000629"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº849", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-29", "doble_articulado": false, "id_norma": "171691", "numero_fuente": "36702", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-01", "vigencias": [{"desde": "2000-07-01", "hasta": "", "tipo_version": "3", "t