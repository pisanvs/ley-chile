{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Cambia el nombre de la Avenida que indica, en las comunas de Santiago y &#xD1;u&#xF1;oa, por el que se&#xF1;ala.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8280397}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La actual Avenida Sur, en las comunas de Santiago y &#xD1;u&#xF1;oa, llevar&#xE1; en lo sucesivo el nombre de &quot;Avenida Grecia&quot;, </div></div>", "i": 8280398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, primero de Abril de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Eduardo Urz&#xFA;a.</div><br></div>", "i": 8280399}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12883", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12883"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA EL NOMBRE DE LA AVENIDA QUE INDICA, EN LAS COMUNAS DE SANTIAGO Y ÑUÑOA, POR EL QUE SEÑALA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "AVENIDA GRECIA", "SANTIAGO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-04-01", "doble_articulado": false, "id_norma": "27257", "numero_fuente": "24019", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-04-12", "vigencias": [{"desde": "1958-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1958-04-12",