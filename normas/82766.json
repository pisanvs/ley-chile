{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO&nbsp; N&#xBA; 1.164&nbsp; EXENTO, DE 1997</div><br></div>", "i": 6063190}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Supremo exento de Educaci&#xF3;n N&#xBA; 1.164, de 26 de noviembre de 1997, se ha aprobado a contar del a&#xF1;o 1997, el plan y programa especial de estudio de educaci&#xF3;n media human&#xED;stico-cient&#xED;fica para adultos, al &quot;Instituto Norel Gavac&quot;, de Santiago, Regi&#xF3;n Metropolitana, que se desarrollar&#xE1; en cuatro semestres. </div></div>", "i": 6063191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de diciembre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6063192}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1164 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1164 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.164 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "INSTITUTO NOREL GAVAC", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-26", "doble_articulado": false, "id_norma": "82766", "numero_fuente": "35941", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-16", "vigencias": [{"desde": "1997-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-12-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por":