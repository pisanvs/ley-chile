{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 508, DE 1985 </div></div>", "i": 7260208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 573 de 04 de Agosto de 1986 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 508, de 1985, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a don Ignacio Arturo Prado Ben&#xED;tez, RUT No. 486.911-7, domiciliado en sector rural de la Comuna de Quemchi, Km. 4 &quot;Playa Eliana&quot;, para instalar y operar un establecimiento de cultivo de Chorito y de Ostra en el Estero Tubildad, en orden a reemplazar en el numeral 2&#xB0; de dicha resoluci&#xF3;n las coordenadas geogr&#xE1;ficas que en ella se se&#xF1;alan.</div><br><br></div>", "i": 7260209}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 04 de Agosto de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7260210}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "573", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-573"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 508, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-04", "doble_articulado": false, "id_norma": "153710", "numero_fuente": "32549", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-16", "vigencias": [{"desde": "1986-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-16", "fin_vigencia": ""}, "vigencias_v