{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede abono de tiempo a don Antonio B&#xF3;rquez Solar Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a don Antonio B&#xF3;rquez Solar, para los efectos de su jubilaci&#xF3;n, un abono de seis a&#xF1;os de servicios.</div><br></div>", "i": 5960367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, nueve de Septiembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Rodolfo Jaramillo B. </div></div>", "i": 5960368}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4650", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4650"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE ABONO DE TIEMPO A DON ANTONIO BORQUEZ SOLAR", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ANTONIO BORQUEZ SOLAR", "TIEMPO SERVIDO", "ABONO", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-09-09", "doble_articulado": false, "id_norma": "24804", "numero_fuente": "15471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-09-11", "vigencias": [{"desde": "1929-09-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-09-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-09-11", "fin_vigencia": "", "tipo_version": "