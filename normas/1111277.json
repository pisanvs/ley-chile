{"html": [{"t": "<div><br><br><div class=\"p\">Beneficio del salitre</div></div>", "i": 9854965}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 17 de 1817.</div><br><div class=\"p\">&nbsp; &nbsp;  Vista la solicitud del tribunal de miner&#xED;a, i de conformidad con lo espuesto por el ministerio fiscal; los hacendados del Estado no pondr&#xE1;n embarazo alguno en franquear las tierras que necesiten de las haciendas los sujetos que quieran emplearse en beneficiar salitre por ser &#xE9;ste uno de los ajentes principales para el interesante laboreo de las minas, quedando los empresarios en la obligacion de satisfacer los perjuicios. Cont&#xE9;stese al tribunal de miner&#xED;a, e impr&#xED;mase.- </div></div>", "i": 9854966}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  P&#xE9;rez.-Cruz.-Astorga.-Za&#xF1;artu.</div></div>", "i": 9854967}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Beneficio del salitre", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-11-17", "doble_articulado": false, "id_norma": "1111277", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-11-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-11-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-11-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2017-11-28", "fec