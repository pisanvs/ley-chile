{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10216519}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.336, de 1 de abril de 2021, Serviu Regi&#xF3;n de Valpara&#xED;so dispueso expropiaci&#xF3;n parcial conforme al art&#xED;culo 51 ley 16.391 y decreto ley 2.186 de 1978, del lote signado con el n&#xFA;mero 20, ubicado en 18 Norte Cs 44, Pob. Gratry, de la comuna de Vi&#xF1;a del Mar, en el plano DRS-P N&#xB0; 12164 y DRS-P N&#xB0; 10639 &quot;Proyecto Prolongaci&#xF3;n 6 Oriente entre 11 y 13 Norte y Avenida Alessandri&quot;, de presunto dominio de Suc. Garrido Marta Luisa, rol aval&#xFA;o 243-37. Comisi&#xF3;n tasadora integrada por Guillermo Parra Silva, Julia Venegas Escalante y Jaime Jurgens Bittner, seg&#xFA;n informe de diciembre de 2019, se fij&#xF3; monto indemnizaci&#xF3;n provisional en $2.310.537, que ser&#xE1; pagado al contado.- </div></div>", "i": 10216520}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Sarviu.</div><br></div>", "i": 10216521}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1336 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1336 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DE VALPARAÍSO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1925471", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-04-01", "doble_articulado": false, "id_norma": "1158364", "numero_fuente": "42930", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-04-15", "