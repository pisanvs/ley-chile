{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8310705}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.402 de 08 de Noviembre de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 1.243, de 1991, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA DEL CABO S.A., RUT No. 96.520.580-2, domiciliado en Concepci&#xF3;n, calle San Mart&#xED;n No. 45, de la siguiente manera:</div><div class=\"p\">a) En el numeral 1&#xB0; se deja constancia que el RUT de la solicitante es el No. 96.520.580-2</div><div class=\"p\">b) En el numeral 2&#xB0; se agregan las Regiones VI, VII y IX donde la interesada podr&#xE1; capturar con cerco el recurso Merluza de cola, Macruronus magellanicus.</div><br></div>", "i": 8310706}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 08 de Noviembre de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8310707}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1402", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1402"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-11-08", "fecha_derogacion": "2004-07-16", "doble_articulado": false, "id_norma": "80189", "numero_fuente": "34121", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-11-20", "vigencias": [{"desde": "2004-07-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-11-20", "hasta": "2004-07-15", "tipo_ver