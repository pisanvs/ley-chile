{"html": [{"t": "<div><div class=\"p\">AUTORIZA A INDUSTRIAS MARINAS LIMITADA PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br><br></div>", "i": 7285227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 196, de 05 de Marzo de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Industrias Marinas Limitada &quot;Imasa Limitada&quot;, domiciliaria en Valpara&#xED;so, para instalar y operar un establecimiento de cultivo de alga Gracilaria spp. en dos sectores de La Ligua, Provincia de Petorca, V Regi&#xF3;n, uno ubicado en Caleta Ligua, de 89.300 m2 y el otro en R&#xED;o Ligua, de 110.000 m2.</div><br></div>", "i": 7285228}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 05 de Marzo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7285229}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "196", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-196"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A INDUSTRIAS MARINAS LIMITADA PARA DESARROLLAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-03-05", "fecha_derogacion": "1999-02-01", "doble_articulado": false, "id_norma": "188769", "numero_fuente": "32420", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-03-12", "vigencias": [{"desde": "1999-02-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-03-12", "hasta": "1999-01-31", "tipo_version": "0", "tipo_version_