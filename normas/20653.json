{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 207 EXENTO, DE 1994 </div></div>", "i": 7161118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 207 de fecha 5 de mayo de 1994 del Ministerio de Educaci&#xF3;n, se ampli&#xF3; la autorizaci&#xF3;n de funcionamiento del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto AIEP de Santiago, autorizado por Decreto Exento de Educaci&#xF3;n N&#xB0; 27 de 1982, a la Sede N&#xB0; 9 que los organizadores mantienen en calle Argomedo N&#xB0; 268 de la ciudad de Curic&#xF3;. Dicha Sede estar&#xE1; destinada para el funcionamiento de Biblioteca, Laboratorios y Talleres. </div></div>", "i": 7161119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 3 de Junio de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161120}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "207 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-207 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 207 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA AIEP", "AUTORIZACION", "AMPLIACION", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-05-05", "doble_articulado": false, "id_norma": "20653", "numero_fuente": "34895", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-21", "vigencias": [{"desde": "1994-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-06-21", "fin_vigencia"