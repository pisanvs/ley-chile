{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTO Lei n&#xFA;m. 165.-Santiago, a 19 de Enero de 1894.-Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273795}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de doce mil pesos al &#xED;tem 1 de la partida 3.a del presupuesto del Interior, destinado a gastos jenerales de la Secretar&#xED;a del Senado.</div><br><br></div>", "i": 8273796}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.-Pedro Montt.</div><br></div>", "i": 8273797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "165", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-165"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1894", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-19", "doble_articulado": false, "id_norma": "22026", "numero_fuente": "4721", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-01-19", "vigencias": [{"desde": "1894-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-01-25", "fecha_version": "