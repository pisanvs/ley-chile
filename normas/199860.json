{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 11, DE 1980</div><br><br></div>", "i": 7292471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 403, de 8 de Noviembre de 1983, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n N&#xB0; 11, de 1980, de la misma Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Camanchaca S.A., entre otras actividades pesqueras para operar las embarcaciones &quot;TOME&quot;, &quot;VILOS II&quot;, &quot;BARLOVENTO&quot;, &quot;ANTARES&quot; y &quot;RIEGEL&quot;, en el sentido de que adem&#xE1;s podr&#xE1;n utilizar el sistema de cerco para realizar labores de extracci&#xF3;n de anchoveta, sardina com&#xFA;n, sardina espa&#xF1;ola y jurel. </div></div>", "i": 7292472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de Noviembre de 1983.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7292473}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "403", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-403"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 11, DE 1980", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1983-11-08", "doble_articulado": false, "id_norma": "199860", "numero_fuente": "31729", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1983-11-25", "vigencias": [{"desde": "1983-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1983-11-25", "fin_vigencia": ""}, "vi