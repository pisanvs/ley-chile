{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional, ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7168751}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Substit&#xFA;yese por la siguiente la glosa del rubro 11|01|02, secretar&#xED;a z) 3) del Presupuesto del Ministerio de Fomento para el presente a&#xF1;o:</div><div class=\"p\">&nbsp; &nbsp; &quot;Para los trabajos de ensanche del edificio del Ministerio de Fomento, reparaciones en el local actual, y demolici&#xF3;n de la casa ubicada en el sitio en que se construir&#xE1; el nuevo pabell&#xF3;n&quot;.</div><br></div>", "i": 7168752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiocho de Agosto de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez del Campo.- Luis Schmidt. </div></div>", "i": 7168753}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4398", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4398"}], "organismos": ["MINISTERIO DE FOMENTO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1928", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-08-28", "doble_articulado": false, "id_norma": "24709", "numero_fuente": "15167", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-09-05", "vigencias": [{"desde": "1928-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig