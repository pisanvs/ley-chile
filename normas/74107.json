{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 924, de 1 de julio de 1997, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de</div><div class=\"p\">acuicultura, solicitud N&#xBA; 95122010, presentada por SALMONES</div><div class=\"p\">SANTA BARBARA LIMITADA, para el centro de cultivo ubicado en</div><div class=\"p\">Punta Jam&#xF3;n, Comuna de Natales, Provincia de Ultima</div><div class=\"p\">Esperanza, XII Regi&#xF3;n, conforme lo dispuesto en los</div><div class=\"p\">art&#xED;culos N&#xBA; 78&#xBA; y N&#xBA; 87&#xBA;, de la Ley General de Pesca y Acuicultura y el art&#xED;culo N&#xBA; 14&#xBA;, del D.S. N&#xBA; 290, de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8304425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "924", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-924"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION DE ACUICULTURA", "SALMONES SANTA BARBARA LIMITADA", "NATALES", "DECIMOSEGUNDA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-01", "doble_articulado": false, "id_norma": "74107", "numero_fuente": "35810", "tipo_version": "3", "tipo