{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6275746}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 24, de 18 de Diciembre de 1984 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n se autoriza a don Ricardo Moraga Maldonado para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blico urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6275747}, {"t": "<div><div class=\"p\">Rigoberto G&#xF3;mez Lav&#xED;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n. </div></div>", "i": 6275748}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "24", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-24"}], "organismos": ["MINISTERIO DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-12-18", "doble_articulado": false, "id_norma": "168813", "numero_fuente": "32106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-25", "vigencias": [{"desde": "1985-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAL", "fecha_ingreso": "2000-05-16", "fecha_version": "1985-02-25", "fecha_actualizacion_texto": "1985-02-25", "tip