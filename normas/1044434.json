{"html": [{"t": "<div><br><div class=\"p\">MODIFICA ANEXO N&#xBA;1 DE LA RESOLUCI&#xD3;N N&#xBA; 89 EXENTA, DE 2012</div><br></div>", "i": 9303818}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 104, del 24 de septiembre de 2012, que:</div><div class=\"p\">&nbsp; &nbsp;  Modifica anexo N&#xBA;1 de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1043096&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n Ex. SII N&#xBA; 89, de 16 de agosto de 2012</a>, que autoriza excepcionalmente reemplazo de boleta de ventas y servicios por el comprobante emitido por la empresa Transbank S.A.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre de 2012.</div></div>", "i": 9303819}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "104 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-104 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA ANEXO Nº1 DE LA RESOLUCIÓN Nº 89 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-24", "doble_articulado": false, "id_norma": "1044434", "numero_fuente": "40377", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-04", "vigencias": [{"desde": "2012-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici