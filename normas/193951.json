{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.013 EXENTO, DE 2001 </div></div>", "i": 6366570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.013, de fecha 4 de diciembre de 2001, del Ministerio de Educaci&#xF3;n, se aprueba el plan y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura Cidec, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en las sedes que se se&#xF1;alan, a contar del a&#xF1;o 2002:</div><br><div class=\"p\">Sede N&#xBA; 8 - Arica y Sede N&#xBA; 13 de Punta Arenas</div><div class=\"p\">Carrera&nbsp; : T&#xE9;cnico en Sistemas Inform&#xE1;ticos.</div><div class=\"p\">T&#xED;tulo&nbsp;  : T&#xE9;cnico de Nivel Superior en Sistemas</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Inform&#xE1;ticos.</div><br></div>", "i": 6366571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6366572}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1013 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1013 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.013 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-04", "doble_articulado": false, "id_norma": "193951", "numero_fuente": "37165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-21", "vigencias": [{"desde": "2002-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":