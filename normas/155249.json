{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON MARIO KOTESKY LEAL PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6231638}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 41, de 13 de Enero de 1986 de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, pronunci&#xE1;ndose sobre solicitud de fecha 10 de Octubre de 1985, se autoriza a Don Mario Kotesky Leal, domiciliado en Arica para operar embarcaci&#xF3;n &quot;Mauricio I&quot; en el litoral comprendido entre la I y la II Regi&#xF3;n en actividades extractivas de sardina, jurel, anchoa y caballa.</div><br></div>", "i": 6231639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de Enero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca </div></div>", "i": 6231640}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-41"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A DON MARIO KOTESKY LEAL PARA DESARROLLAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-01-13", "fecha_derogacion": "1987-07-22", "doble_articulado": false, "id_norma": "155249", "numero_fuente": "32340", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-02-05", "vigencias": [{"desde": "1987-07-22", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-02-05", "hasta": "1987-07-21", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia":