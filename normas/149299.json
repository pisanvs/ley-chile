{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 4,576</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 7257514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.&nbsp; Agr&#xE9;gase al inciso segundo del art&#xED;culo 58 de la ley N.o 4,536, la siguiente frase: &quot;no obstante, el champagne importado estar&#xE1; sujeto s&#xF3;lo al impuesto que dicho art&#xED;culo determina.</div><br></div>", "i": 7257515, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta y uno de Enero de mil novecientos veintinueve.-&nbsp; Carlos Ib&#xE1;&#xF1;ez del Campo.-&nbsp; Pablo Ram&#xED;rez.</div><br></div>", "i": 7257516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4576", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4576"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-01-31", "doble_articulado": false, "id_norma": "149299", "numero_fuente": "15295", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-02-09", "vigencias": [{"desde": "1929-02-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-02-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-02-09", "fin_vigencia": "", "tipo_versi