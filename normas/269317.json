{"html": [{"t": "<div><div class=\"p\">AVISO </div></div>", "i": 7364171}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto alcaldicio N&#xBA; 284 de fecha 8 de febrero</div><div class=\"p\">de 2008, la I. Municipalidad de Macul aprob&#xF3; la</div><div class=\"p\">modificaci&#xF3;n del art&#xED;culo 40, letra c), de la Ordenanza</div><div class=\"p\">sobre Actividad Comercial, Industrial y de Servicios</div><div class=\"p\">cuyo texto es el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo 40: letra c): Deber&#xE1;n instalarse obligatoriamente los d&#xED;as y horas de ferias, en caso de enfermedad deber&#xE1; comunicarse a la Inspecci&#xF3;n Municipal dentro de 48 horas de producida la inasistencia. </div></div>", "i": 7364172}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis G&#xF3;mez Mu&#xF1;oz, Alcalde Subrogante.</div><br></div>", "i": 7364173}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "284", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-284"}], "organismos": ["MUNICIPALIDAD DE MACUL"], "titulo_norma": "AVISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-02-08", "doble_articulado": false, "id_norma": "269317", "numero_fuente": "38990", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-02-18", "vigencias": [{"desde": "2008-02-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-02-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-02-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingres