{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6518312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 338, de 9 de febrero de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD DE INVERSIONES ALIZE CHILE LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Ruta 226, kil&#xF3;metro 13,7, camino Las Quemas, Puerto Montt, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Fresco enfriado, congelado, seco salado y ahumado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto las resoluciones N&#xBA; 840 de 1996 y N&#xBA; 1.042 de 1999, ambas de esta Subsecretar&#xED;a, en virtud de la carta renuncia citada en Visto y del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 6518313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de febrero de 2005.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6518314}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "338 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-338 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-02-09", "doble_articulado": false, "id_norma": "236177", "numero_fuente": "38106", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-09", "vigencias": [{"desde": "2005-03-09", "hasta": "", "tipo_version": "3", "t