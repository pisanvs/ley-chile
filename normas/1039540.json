{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9253505}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.103, de 23 de abril de 2012, de esta Subsecretar&#xED;a, d&#xE9;janse sin efecto las resoluciones N&#xB0; 1.783 de 2006 y N&#xBA; 3.718 de 2009, ambas de esta Subsecretar&#xED;a, correspondientes al &#xE1;rea de manejo Sur Piedra Fusil, XIV Regi&#xF3;n, de la ASOCIACI&#xD3;N IND&#xCD;GENA DE PESCADORES IND&#xCD;GENAS, NOMELOLEN DE MAIQUILLAHUE, en virtud del art&#xED;culo 21 del DS N&#xB0; 355 de 1995, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n y lo dispuesto en la resoluci&#xF3;n extractada, cuyo texto &#xED;ntegro se encuentra publicado en la p&#xE1;gina web www.subpesca.cl.</div><br></div>", "i": 9253506}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de abril de 2012.- Felipe Palacio Rives, Subsecretario de Pesca (S).</div><br></div>", "i": 9253507}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1103 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1103 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-04-23", "doble_articulado": false, "id_norma": "1039540", "numero_fuente": "40250", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-30", "vigencias": [{"desde": "2012-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc