{"html": [{"t": "<div><br><div class=\"p\">VIGENCIA Y TRANSICI&#xD3;N DE LAS NORMAS CONTENIDAS EN LA LEY 20.899</div></div>", "i": 9698300}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xB0; 21, de fecha 19 de abril de 2016, que imparte instrucciones sobre vigencia y transici&#xF3;n de las normas contenidas en la <a href=\"https://www.leychile.cl/Navegar?idNorma=1087342&amp;idParte=0&amp;idVersion=\">ley N&#xB0; 20.899</a>, que simplifica el sistema de tributaci&#xF3;n a la renta y perfecciona otras disposiciones legales tributarias.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en el mes de abril de 2016.</div><br></div>", "i": 9698301}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "21", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-21"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "VIGENCIA Y TRANSICIÓN DE LAS NORMAS CONTENIDAS EN LA LEY 20.899", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1017742; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-04-19", "doble_articulado": false, "id_norma": "1089727", "numero_fuente": "41440", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-04-23", "vigencias": [{"desde": "2016-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2016-04-23", "fin_vigencia": ""}, "