{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.009 EXENTA, DE 2012</div></div>", "i": 9296937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 8.009, de 4 de septiembre de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Strizzi &amp; Asociados Chile S.A. (Door Training Chile)&quot;, RUT 96.872.630-7 contenida en la resoluci&#xF3;n exenta N&#xBA; 3.185 de 12 de octubre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.- </div><br></div>", "i": 9296938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9296939}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8009 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8009 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.009 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-04", "doble_articulado": false, "id_norma": "1044021", "numero_fuente": "40365", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-20", "vigencias": [{"desde": "2012-09-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-09-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul