{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,147.- Santiago, 29 de diciembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161604}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Delmira Ram&#xED;rez, hermana del teniente coronel don Eleuterio Ram&#xED;rez, una pensi&#xF3;n mensual de cuarenta pesos, de la cual disfrutar&#xE1; con arreglo a la lei de montep&#xED;o militar.</div><br></div>", "i": 6161605}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERR&#xC1;ZURIZ.- Carlos Concha.</div><br></div>", "i": 6161606}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1147", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1147"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-29", "doble_articulado": false, "id_norma": "134197", "numero_fuente": "6190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-31", "vigencias": [{"desde": "1898-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-12-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso":