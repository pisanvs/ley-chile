{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6007663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 198 de 13 de marzo de 1995 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xB0; 2.186 de 1978, de los inmuebles ubicados en Avda. Tobalaba y calle Palena, denominados Lotes 1 y 2, presuntos roles de aval&#xFA;os N&#xB0; 6100-10 y s/n&#xB0;, respectivamente, comuna de La Florida, aparente domino de Empresa Metropolitana de Obras Sanitarias S.A. Comisi&#xF3;n integrada por peritos Sres. Fernando C&#xE1;diz Bouch y Ren&#xE9; Ureta Koster, arquitectos y Patricia Zavala Contreras, seg&#xFA;n informe de 23 de noviembre de 1994, fij&#xF3; monto provisional indemnizaci&#xF3;n en $3.894.000.- para el Lote 1 y $1.080.000.- para el lote 2, pagaderas al contado.</div><br></div>", "i": 6007664}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director SERVIU Metropolitano.</div><br></div>", "i": 6007665}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "198", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-198"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LA FLORIDA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-13", "doble_articulado": false, "id_norma": "33698", "numero_fuente": "35133-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-04-01", "vigencias": [{"desde": "1995-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici