{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5961338}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art1iculo &#xFA;nico. Agr&#xE9;gase al art&#xED;culo 6.o de la ley n&#xFA;mero 5,005, de 24 de Noviembre del a&#xF1;o pr&#xF3;ximo pasado, la siguiente letra:</div><div class=\"p\">&nbsp; &nbsp; g) Las de los empleados del servicio de la Inspecci&#xF3;n General del Trabajo, de la Direcci&#xF3;n General de Sanidad y de la Subsecretar&#xED;a del Ministerio de Bienestar Social.</div><br><br></div>", "i": 5961339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.- Santiago, veinticinco de febrero de mil novecientos treinta y dos.- JUAN E. MONTERO.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 5961340}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5071", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5071"}], "organismos": ["MINISTERIO DE BIENESTAR SOCIAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADMINISTRACION PUBLICA", "INSPECCION GENERAL TRABAJO", "DIRECCION GENERAL SANIDAD", "MINISTERIO BIENESTAR SOCIAL", "VACANTES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-02-25", "doble_articulado": false, "id_norma": "25021", "numero_fuente": "16216", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-03-04", "vigencias": [{"desde": "1932-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci