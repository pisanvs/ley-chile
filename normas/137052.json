{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,476.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a don Eduardo Arrau Ojeda, para los efectos de su jubilacion, un abono de diez a&#xF1;os de servicios.</div><br></div>", "i": 6170736}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, primero de febrero de mil novecientos once.- Ramon Barros Luco.- Ramon Leon Luco.</div><br></div>", "i": 6170737}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2476", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2476"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-02-01", "doble_articulado": false, "id_norma": "137052", "numero_fuente": "9904", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-02-10", "vigencias": [{"desde": "1911-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-02-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-02-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-05-31", "fecha_version": "1911-02-10", "fecha_actualizaci