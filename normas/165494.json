{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;100 EXENTO, DE&nbsp; 2000 </div></div>", "i": 7267599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;100, de fecha 24 de marzo de 2000, del Ministerio de Educaci&#xF3;n, se aprobaron las adecuaciones al plan y programas de estudios de la carrera de Int&#xE9;rprete e Instructor en Danza Espect&#xE1;culo del Centro de Formaci&#xF3;n T&#xE9;cnica Estudio Profesor Valero. Modif&#xED;case en consecuencia, la resoluci&#xF3;n exenta del Ministerio de Educaci&#xF3;n N&#xBA;1.549 del 15 de junio de 1988, en el sentido de incorporar dichas adecuaciones. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 2000.- </div></div>", "i": 7267600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 7267601}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "100 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-100 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº100 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-03-24", "fecha_derogacion": "2021-06-30", "doble_articulado": false, "id_norma": "165494", "numero_fuente": "36640", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-04-14", "vigencias": [{"desde": "2021-06-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-04-14", "hasta": "2021-06-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2021-06-30", "fin_vigencia": ""}, "v