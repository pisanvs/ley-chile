{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.971, de 21 de agosto de</div><div class=\"p\">2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO</div><div class=\"p\">BIO S.A. para ampliar actividades pesqueras extractivas</div><div class=\"p\">con la nave &quot;Mar&#xED;a Bernardita&quot;, en el Archipi&#xE9;lago de</div><div class=\"p\">Juan Fern&#xE1;ndez, Isla de Pascua, Islas Desventuradas e</div><div class=\"p\">Islas Sala y G&#xF3;mez, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar, con arrastre, los recursos hidrobiol&#xF3;gicos Alfonsino, Besugo, Besugo de Juan Fern&#xE1;ndez, Quimera, Camar&#xF3;n de profundidad, Camar&#xF3;n acorazado, Raya volant&#xED;n, Raya espinuda, Raya manchas blancas, Tollo narig&#xF3;n Apristurus nasatus, Tollo narig&#xF3;n Centroscymnus crepidater, Tollo negro Centroscyllium granulosum.</div><br></div>", "i": 7303775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7303776}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1971 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1971 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-08-21", "fecha_derogacion": "2007-12-04", "doble_articulado": false, "id_norma": "214821", "numero_fuente": "37662", "tipo_version": "2", "tip