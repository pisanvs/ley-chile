{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,720, que concede derecho a jubilar a don Manuel A. Calvo.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,720.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 5956775}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese al Director de la Biblioteca P&#xFA;blica de Valparaiso, don Manuel A. Calvo, el derecho a jubilar con una pension de seis mil pesos ($ 6,000) anuales.</div><br></div>", "i": 5956776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a ocho de Febrero de mil novecientos veintiuno.- ARTURO ALESSANDRI.- Armando Jaramillo V. </div></div>", "i": 5956777}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3720", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3720"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "LEI NUM. 3,720, QUE CONCEDE DERECHO A JUBILAR A DON MANUEL A. CALVO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANUEL CALVO", "JUBILACION POR GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-02-08", "doble_articulado": false, "id_norma": "24200", "numero_fuente": "12906", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-02-24", "vigencias": [{"desde": "1921-02-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1921-02-24", "fin_vigencia":