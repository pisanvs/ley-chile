{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,296.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; En atencion a los importantes servicios prestados a la Nacion por el contra-almirante don Galvarino Riveros, el&#xE9;vese a seis mil pesos anuales la pension de que actualmente disfruta su viuda, la se&#xF1;ora do&#xF1;a Domitila Ram&#xED;rez de Riveros.</div><br></div>", "i": 6170535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, cinco de marzo de mil novecientos diez.- Pedro Montt.-&nbsp; An&#xED;bal Rodr&#xED;guez H.</div><br></div>", "i": 6170536}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2296", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2296"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-03-05", "doble_articulado": false, "id_norma": "136995", "numero_fuente": "9635", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-03-08", "vigencias": [{"desde": "1910-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-03-08", "fin_vigencia": "", "tipo_version": "3"}], "even