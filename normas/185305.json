{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7283011}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 875 de 14 de mayo de 2001 de esta</div><div class=\"p\">Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la</div><div class=\"p\">resoluci&#xF3;n N&#xBA; 1.792 de 1989, de esta Subsecretar&#xED;a, s&#xF3;lo</div><div class=\"p\">en cuanto autoriz&#xF3; a PESQUERA QURBOSA S.A., para</div><div class=\"p\">realizar actividades con la nave &quot;Tranoi&quot;, sobre el</div><div class=\"p\">recurso Merluza com&#xFA;n, en el &#xE1;rea mar&#xED;tima de la V a VII</div><div class=\"p\">Regiones, y entre el l&#xED;mite norte de la IX Regi&#xF3;n y el</div><div class=\"p\">paralelo 43&#xB0; L.S., en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7283012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de mayo de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7283013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "875", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-875"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-14", "doble_articulado": false, "id_norma": "185305", "numero_fuente": "36965", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-18", "vigencias": [{"desde": "2001-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":