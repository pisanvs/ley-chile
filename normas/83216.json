{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 7218509}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 233 de 11 de abril de 1990, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; a Transportes Cruz del Sur Limitada, para efectuar transporte terrestre de pasajeros entre Osorno y Punta Arenas, en tr&#xE1;nsito por territorio argentino, por los Pasos Puyehue y Monte Aymond, con cuatro frecuencias semanales, las que se efectuar&#xE1;n en los siguientes d&#xED;as:</div><br><div class=\"p\">Osorno-Punta Arenas: lunes - mi&#xE9;rcoles - viernes - domingo Punta Arenas-Osorno: lunes - mi&#xE9;rcoles - viernes - domingo.</div><br><br></div>", "i": 7218510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes.</div><br><br></div>", "i": 7218511}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "233", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-233"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-04-11", "fecha_derogacion": "1991-01-09", "doble_articulado": false, "id_norma": "83216", "numero_fuente": "33664", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1990-05-08", "vigencias": [{"desde": "1991-01-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1990-05-08", "hasta": "1991-01-08", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigenci