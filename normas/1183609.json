{"html": [{"t": "<div><div class=\"p\">MODIFICA COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10375916}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.704, de fecha 18 de octubre de 2022, de la Directora Nacional de Aduanas, se ha dispuesto modificar el <a href=\"https://www.leychile.cl/Navegar?idNorma=248540&amp;idParte=&amp;idVersion=\">Compendio de Normas Aduaneras</a> en lo siguiente:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Se modifican los numerales 11.3 y 11.10 de los apartados I y II del Anexo 18, y el numeral 13.12 del apartado II-B del mismo Anexo; y se agrega el numeral 10.1 del Cap&#xED;tulo III, una nueva letra &#xF1;&#xF1;) para el caso de importaciones de tabaco de la partida 24.03 que cumpla las condiciones que se indican.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp;  La resoluci&#xF3;n entrar&#xE1; en vigencia transcurridos 30 d&#xED;as corridos contados desde la publicaci&#xF3;n del presente extracto en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10375917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de octubre de 2022.- Alejandra Arriaza Loeb, Directora Nacional de Aduanas.</div><br></div>", "i": 10375918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2704 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2704 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2208878", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-10-18", "doble_articulado": false, "id_norma": "1183609", "numero_fuente": "43388", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-10-28", "vigencias": [{"desde": "2022-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2022-10-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2022-10-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1795", "fecha_ingreso": "2022-10-28", "fecha_version": "2022-10-28", "fecha_actualizacion_texto": "2022-10-28", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10375916}, {"n": "Artículo", "i": 10375917, "t": 6}, {"n": "Promulgación", "i": 10375918}]}