{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6128405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 759, de 29 de mayo de 1998, se expropiaron los lotes de terreno No. s. 38, y 54, superficies 327,98 m2. y 534,38 m2., roles de aval&#xFA;o 3210-14, comuna La Florida y 3400-53, comuna Puente Alto, obra Mejoramiento Eje La Florida, sector Los Ararios Las Vizcachas, sector II y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Luis M&#xE1;rquez Amado y otros y Sebasti&#xE1;n P&#xED;o Gilbert Ceballos, ascendente a las cantidades de $ 84.138.176, para el lote No. 38 y $ 29.759.342, lote 54.</div><br></div>", "i": 6128406}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6128407}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "759", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-759"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LA FLORIDA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-29", "doble_articulado": false, "id_norma": "123862", "numero_fuente": "36154", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-01", "vigencias": [{"desde": "1998-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1