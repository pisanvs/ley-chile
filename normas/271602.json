{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA </div></div>", "i": 6648970}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluciones que se consignan en la siguiente n&#xF3;mina, revoca, a contar de la fecha de esta publicaci&#xF3;n, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto, otorgada en su oportunidad en las adquisiciones de productos que se se&#xF1;alan, de acuerdo a la facultad establecida en cada una de las resoluciones pertinentes de la Direcci&#xF3;n Nacional, a los contribuyentes que a continuaci&#xF3;n se indica:</div><br><div class=\"p\">NOTA: VER DIARIO OFICIAL DE 31.05.2008, PAGINA 20 </div></div>", "i": 6648971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 26 de mayo de 2008.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6648972}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4958 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4958 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-05-26", "doble_articulado": false, "id_norma": "271602", "numero_fuente": "39075", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-31", "vigencias": [{"desde": "2008-05-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-05-31", "fin_vigencia": ""}, "vigenc