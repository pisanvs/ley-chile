{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 168 EXENTO, DE 1995</div><br><br></div>", "i": 7160937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 168 de fecha 9 de Marzo de</div><div class=\"p\">1995, del Ministerio de Educaci&#xF3;n, se modific&#xF3; el</div><div class=\"p\">Art&#xED;culo Primero del Decreto Exento de Educaci&#xF3;n N&#xB0; 10 de 1993, que reconoce oficialmente al Instituto Profesional EPSON, organizado por la Sociedad Estudios y Proyectos EPSON S.A., en el sentido que dicha Instituci&#xF3;n pasa a denominarse, a contar de esta fecha, como se indica:</div><br><div class=\"p\">&nbsp; &nbsp; Instituto Profesional: &quot;Instituto de Formaci&#xF3;n Empresarial&quot;.</div><div class=\"p\">&nbsp; &nbsp; Organizador: Sociedad &quot;Estudios y Proyectos Asicom S.A.&quot;.</div><br><br></div>", "i": 7160938}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de marzo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160939}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "168 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-168 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 168 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "INSTITUTO DE FORMACION EMPRESARIAL", "INSTITUTO PROFESIONAL EPSON", "SANTIAGO", "REGION", "METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-09", "doble_articulado": false, "id_norma": "20514", "numero_fuente": "35138", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-04-07", "vigencias": [{"des