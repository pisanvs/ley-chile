{"html": [{"t": "<div><br><div class=\"p\">OTORGA CONDONACI&#xD3;N QUE SE SE&#xD1;ALA</div></div>", "i": 10002031}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 25, de 15 de febrero de 2019.</div><div class=\"p\">&nbsp; &nbsp;  Otorga condonaci&#xF3;n sobre los intereses y/o multas infraccionales en los casos que se se&#xF1;alan, por estado de excepci&#xF3;n constitucional de cat&#xE1;strofe declarado en las zonas que se indican.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de febrero de 2019.</div></div>", "i": 10002032}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "25 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-25 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "OTORGA CONDONACIÓN QUE SE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1548887; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-02-15", "doble_articulado": false, "id_norma": "1129127", "numero_fuente": "42285", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-02-20", "vigencias": [{"desde": "2019-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-02-20", "fin_vigencia": "", "tipo_versio