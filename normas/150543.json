{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7258229}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 465, de 18.05.87, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se renueva la concesi&#xF3;n otorgada a la Sociedad Gonz&#xE1;lez y Compa&#xF1;&#xED;a Limitada (Transportes Aconcagua Santiago T.A.S. Choapa Limitada o T.A.S. Choapa Limitada, por resoluci&#xF3;n No. 415/82, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, para efectuar servicio internacional de transporte terrestre de pasajeros entre Valdivia (Chile) y San Carlos de Bariloche (Argentina), por paso Puyehue, efectuando tres frecuencias semanales. </div></div>", "i": 7258230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago de Chile.- Enrique Y&#xE1;var Martin, Coronel de Ej&#xE9;rcito, Subsecretario de Transportes.</div><br></div>", "i": 7258231}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "465 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-465 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-18", "doble_articulado": false, "id_norma": "150543", "numero_fuente": "32786", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-03", "vigencias": [{"desde": "1987-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-03", "fin_vigencia": ""}, "vigencias_versi