{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;912 EXENTA, DE 2000 </div></div>", "i": 7276598}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;912 de fecha 7 de junio de 2000, de la Subsecretar&#xED;a de Transportes, se renov&#xF3; autorizaci&#xF3;n complementaria otorgada por resoluci&#xF3;n exenta N&#xBA;705/95, a la empresa de origen peruano Expreso Internacional Orme&#xF1;o S.A., para efectuar servicio internacional de transporte terrestre de pasajeros entre Lima (Per&#xFA;) y Santiago (Chile), utilizando el paso fronterizo de Concordia, con dos (2) frecuencias semanales de ida y vuelta.-</div><br></div>", "i": 7276599}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Patricio Tombolini V&#xE9;liz, Subsecretario de Transportes.</div><br></div>", "i": 7276600}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "912 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-912 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº912 EXENTA, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-07", "doble_articulado": false, "id_norma": "175352", "numero_fuente": "36763", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-13", "vigencias": [{"desde": "2000-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac