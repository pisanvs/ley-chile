{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; OTORGA CONCESION DE RADIODIFUSION SONORA Santiago, 10 de Marzo de 1994.- Con esta fecha se ha decretado lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 105.- Vistos:</div><div class=\"p\">&nbsp; _____________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 34.855 DEL DIA 03 DE&nbsp; &nbsp; |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  MAYO DE 1994, PAGINA 7.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  |</div><div class=\"p\"> |_____________________________________________________|</div><br></div>", "i": 7137862}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n, notif&#xED;quese y publ&#xED;quese en el Diario Oficial.- Por orden del Presidente de la Rep&#xFA;blica, Germ&#xE1;n Molina Valdivieso, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda atentamente a Ud.- Jorge Rosenblut Ratinoff, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 7137863}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "105", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-105"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "OTORGA CONCESION DE RADIODIFUSION SONORA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION RADIODIFUSION SONORA", "FRECUENCIA MODULADA", "DOMINGO ANTONIO SANDOVAL LIRA", "SERENA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-10", "doble_articulado": false, "id_norma": "9333", "numero_fuente": "34855", "tipo_version": "3", "tipo_version_s": "Única", "fec