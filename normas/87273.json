{"html": [{"t": "<div><br><div class=\"p\">DESIGNASE COMO RECEPTORES JUDICIALES A LOS FUNCIONARIOS QUE</div><div class=\"p\">INDICA</div><br><div class=\"p\">N&#xFA;m. 247.- Santiago, 30 de Septiembre de 1991.- Vistos: Lo dispuesto en el art&#xED;culo 11 del decreto ley No. 2.974 de 1979.</div><br><div class=\"p\">Resuelvo:</div><br></div>", "i": 8957634}, {"t": "<div><div class=\"p\">Des&#xED;gnase como Receptores Judiciales para que permanentemente practiquen las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado en la D&#xE9;cima Regi&#xF3;n, a los siguientes funcionarios:</div><div class=\"p\">- Claudio Albornoz N&#xFA;&#xF1;ez</div><div class=\"p\">- V&#xED;ctor Benavente Fuentealba</div><div class=\"p\">- Carlos Novoa Mu&#xF1;oz</div><div class=\"p\">- Carlos Turra Guti&#xE9;rrez</div><div class=\"p\">- ELIMINADO<span class=\"n\" id=\"n_0\">RES 250<br>AGRICULTURA<br>D.O. 23.09.1999</span></div><div class=\"p\">- H&#xE9;ctor Aedo Gonz&#xE1;lez</div><br></div>", "i": 8957635}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional. </div></div>", "i": 8957636}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "247", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-247"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNASE COMO RECEPTORES JUDICIALES A LOS FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-09-30", "dob