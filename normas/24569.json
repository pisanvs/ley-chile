{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza erecci&#xF3;n monumento a don Carlos Walker Mart&#xED;nez</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8277306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase la erecci&#xF3;n en la ciudad de Santiago de un monumento a la memoria del ciudadano don Carlos Walker Mart&#xED;nez, costeado por subscripci&#xF3;n popular.</div><br></div>", "i": 8277307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticuatro de Noviembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez C.- Enrique Balmaceda.</div><br></div>", "i": 8277308}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4212", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4212"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AUTORIZA ERECCION MONUMENTO A DON CARLOS WALKER MARTINEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARLOS WALKER MARTINEZ", "MONUMENTO", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-11-24", "doble_articulado": false, "id_norma": "24569", "numero_fuente": "14939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1927-12-05", "vigencias": [{"desde": "1927-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1927-12-05", "fin_vigencia": ""}, "vigencias_ver