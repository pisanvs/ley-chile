{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE EXPROPIACION </div></div>", "i": 7110716}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Decreto Alcaldicio N&#xB0; 0769 de fecha 19 de mayo de 1993 se expropi&#xF3; terreno ubicado Sector Poniente de Talca, en la continuaci&#xF3;n de la calle 8 Sur hasta empalmar con el camino que une a San Miguel con Palmira, superficie 2.586 m2, Rol de Aval&#xFA;o N&#xB0; 3727-50, Comuna de Talca. Se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios la Comunidad Hereditaria Leoncio Abaca Mej&#xED;as y Otros, representada por don Leoncio Abaca Mej&#xED;as ascendente a la cantidad de $ 2.653.236.- </div></div>", "i": 7110717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Alcalde I. Municipalidad Talca.</div><br></div>", "i": 7110718}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "769", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-769"}], "organismos": ["MUNICIPALIDAD DE TALCA"], "titulo_norma": "EXTRACTO DE EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BIEN RAIZ", "BIEN INMUEBLE", "EXPROPIACION", "SEPTIMA", "REGION", "TALCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-05-19", "doble_articulado": false, "id_norma": "2607", "numero_fuente": "34590", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-06-15", "vigencias": [{"desde": "1993-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "RECTIFICACION", "url_part":