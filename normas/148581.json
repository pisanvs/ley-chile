{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8354053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.348, de 25 de noviembre de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.179 de 1994, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; SERVICIOS MARINOS S.A., para operar la nave &apos;&apos;Bucanero&apos;&apos;, s&#xF3;lo en lo relativo a la operaci&#xF3;n respecto de los recursos Anchoveta, Sardina espa&#xF1;ola, Jurel, Apa&#xF1;ado, Ayanque, Bonito, Caballa, Cabinza, Barrilete o Cachurreta, Cojinoba del norte, Dorado, Palometa, Rollizo, Roncacho y Sardina com&#xFA;n, en la III y IV regiones, conforme lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8354054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de noviembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8354055}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2348", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2348"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-11-25", "fecha_derogacion": "2000-03-13", "doble_articulado": false, "id_norma": "148581", "numero_fuente": "36530", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-12-03", "vigencias": [{"desde": "2000-03-13", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-12-03", "ha