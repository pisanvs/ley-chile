{"html": [{"t": "<div><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 1.259, de 16 de junio de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8770423}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I.- Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=225037&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 493, de 11 de febrero de 2004</a>, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina, en el sentido de reemplazar el p&#xE1;rrafo 4 por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;4.- El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n 2.581, de 28 de octubre de 2003, modificada por la resoluci&#xF3;n exenta 2.531, de 27 de agosto de 2007, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;</div></div>", "i": 8770424}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de julio de 2009.- Por la Sra. Subsecretaria, Humberto Ram&#xED;rez Navarro, Subjefe Subsecretar&#xED;a de Marina.</div></div>", "i": 8770425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1259", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1259"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-16", "doble_articulado": false, "id_norma": "1005149", "numero_fuente": "39439