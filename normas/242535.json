{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6542221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.106, de 16 de septiembre de 2005 de esta Subsecretar&#xED;a, autor&#xED;zase a SANTANA Y COMPA&#xD1;IA LIMITADA para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Serrano N&#xBA; 365, Mejillones, Antofagasta, II Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Fresco- Enfriado, Fresco-Refrigerado, Congelado, Seco-Salado, Ahumado, Conserva y Deshidratado el recurso hidrobiol&#xF3;gico indicado en la resoluci&#xF3;n extractada. </div></div>", "i": 6542222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de septiembre de 2005.- Edith Saa Collantes, Subsecretario de Pesca (S).</div><br></div>", "i": 6542223}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3106 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3106 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-16", "doble_articulado": false, "id_norma": "242535", "numero_fuente": "38277", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-03", "vigencias": [{"desde": "2005-10-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po