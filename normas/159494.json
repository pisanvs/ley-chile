{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6245321}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;285, de 24 de febrero de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la N&#xBA;1.506 de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA CONFISH S.A. para ampliar actividades pesqueras extractivas con una nave en construcci&#xF3;n en el litoral de la X Regi&#xF3;n, respecto de los recursos Agujilla, Anchoveta, Caballa, Cojinoba del norte, Jurel, Merluza de cola y Sardina com&#xFA;n, por haber incurrido en la causal de caducidad del art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6245322}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de febrero de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 6245323}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "285", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-285"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA CONFISH S.A.", "ACTIVIDADES PESQUERAS EXTRACTIVAS", "DECIMA REGION", "AUTORIZA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-24", "doble_articulado": false, "id_norma": "159494", "numero_fuente": "36604", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-03", "vigencias": [{"desde": "2000-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci