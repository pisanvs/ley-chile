{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESTINA FONDOS PARA LOS CUERPOS DE BOMBEROS DE VALLENAR Y CHA&#xD1;ARAL</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281042}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Del mayor rendimiento de las Cuentas C-11 y D-2-a del C&#xE1;lculo de Entradas del Presupuesto de 1959, dest&#xED;nase la suma de $ 20.000.000 para el Cuerpo de Bomberos de Vallenar y de $ 4.000.000 para el Cuerpo de Bomberos de Cha&#xF1;aral.&quot; </div></div>", "i": 8281043}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintid&#xF3;s de diciembre de mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 8281044}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13909", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13909"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DESTINA FONDOS PARA LOS CUERPOS DE BOMBEROS DE\nVALLENAR Y CHAÑARAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["APORTE FISCAL", "CUERPO BOMBEROS VALLENAR", "CUERPO BOMBEROS CHA ARAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-12-22", "doble_articulado": false, "id_norma": "27551", "numero_fuente": "24526", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-12-24", "vigencias": [{"desde": "1959-12-24", "hasta": "", "tipo_versio