{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6112775}, {"t": "<div><div class=\"p\">Por decreto MOP. No. 394, de 31 de marzo de 1998, se expropi&#xF3; el lote de terreno No. 4, superficie 928 m.., Rol de Aval&#xFA;o 153-87, comuna de Llay-Llay, para la obra Camino Ruta 5 Norte Tramo Santiago - Los Vilos, sector km.</div><div class=\"p\">79.150,00 a km. 80.450,00, y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietario Donoso Sanzana V&#xED;ctor Mario, ascendente a la cantidad de $ 6.437.106. </div></div>", "i": 6112776}, {"t": "<div><div class=\"p\">- Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6112777}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "394", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-394"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LLAY LLAY", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-03-31", "doble_articulado": false, "id_norma": "99922", "numero_fuente": "36078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-01", "vigencias": [{"desde": "1998-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1998-06-18", "fecha_version": "1998-06-01", "fecha_actualizacion_texto": "1998-06-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "