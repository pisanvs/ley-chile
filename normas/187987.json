{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 304 EXENTO, DE 2001</div><br><br></div>", "i": 6344063}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 304 de fecha 29 de mayo de 2001, se declara aprobada a la Universidad Alberto Hurtado la siguiente carrera y grado acad&#xE9;mico que se indica, de conformidad al certificado de aprobaci&#xF3;n del plan y los programas de estudio emitido por el Consejo Superior de Educaci&#xF3;n:</div><br><div class=\"p\">&nbsp; &nbsp;  Carrera: Educaci&#xF3;n B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp;  Grado acad&#xE9;mico: Licenciado en Educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  T&#xED;tulo Profesional: Profesor de Educaci&#xF3;n B&#xE1;sica con menciones en Primer Ciclo B&#xE1;sico, Educaci&#xF3;n de Adultos, Matem&#xE1;ticas y Ciencias Sociales.</div><br></div>", "i": 6344064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de junio de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6344065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "304 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-304 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 304 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-29", "doble_articulado": false, "id_norma": "187987", "numero_fuente": "37021", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-26", "vigencias": [{"desde": "2001-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "200