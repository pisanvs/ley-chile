{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6452002}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.031, de 21 de noviembre de 2003, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 1.097 de 1999, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a MAESTRANZA TALCAHUANO LIMITADA para operar la nave &quot;Pigargo&quot;, respecto de los recursos hidrobiol&#xF3;gicos Besugo, en el litoral de la VIII Regi&#xF3;n, con arrastre, y Bacalao de profundidad, en el litoral comprendido entre Punta Liles y el paralelo 47&#xBA; L.S., con espinel, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6452003}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6452004}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3031 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3031 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-21", "doble_articulado": false, "id_norma": "218241", "numero_fuente": "37727", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-04", "vigencias": [{"desde": "2003-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-1