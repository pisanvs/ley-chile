{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 550, de 21 de marzo de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a don ERASMO ANTONIO MU&#xD1;OZ FLORES, R.U.T. N&#xB0; 8.584.657-4, para continuar desarrollando las actividades pesqueras autorizadas por Resoluci&#xF3;n N&#xB0; 322, de 1990, de esta Subsecretar&#xED;a, a don Luis Enrique Rom&#xE1;n Flores, R.U.T.</div><div class=\"p\">N&#xB0; 5.188.831-6 y a don Erasmo Antonio Mu&#xF1;oz Flores, R.U.T. N&#xB0; 8.584.657-4, en virtud del Contrato de cesi&#xF3;n de derechos y disposiciones legales citadas en Visto. </div></div>", "i": 8293081}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 21 de marzo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293082}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "550", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-550"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "ERASMO ANTONIO MUÑOZ FLORES", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-03-21", "fecha_derogacion": "2001-05-28", "doble_articulado": false, "id_norma": "35089", "numero_fuente": "35441", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-04-13", "vigencias": [{"desde": "2001-05-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1996-04-13", "hasta": "2001-05-27", "tipo_v