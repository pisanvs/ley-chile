{"html": [{"t": "<div><br><div class=\"p\">CONDONACI&#xD3;N DE INTERESES Y MULTAS QUE SE INDICAN</div><br></div>", "i": 9220425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 150, de 19 de diciembre de 2011, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Cond&#xF3;nase el 100% de los intereses y sanciones de los contribuyentes de todo el territorio del pa&#xED;s que hubieren presentado y pagado, v&#xED;a internet, hasta la medianoche del mi&#xE9;rcoles 14 de diciembre de 2011, el formulario F29, de declaraci&#xF3;n mensual y pago simult&#xE1;neo de impuestos, con vencimiento el d&#xED;a 12 del mismo mes.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div></div>", "i": 9220426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "150 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-150 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CONDONACIÓN DE INTERESES Y MULTAS QUE SE INDICAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-19", "doble_articulado": false, "id_norma": "1035354", "numero_fuente": "40142", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-12-23", "vigencias": [{"desde": "2011-12-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-12-23", "fin_vigencia": ""}, "vigencias_version