{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6138224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.591, de 21 de septiembre de 1998, se dej&#xF3; sin efecto el decreto de dicho Ministerio N&#xBA;895, de 30 de junio de 1998, que orden&#xF3; la expropiaci&#xF3;n y aprob&#xF3; los Planos y Cuadro de Expropiaci&#xF3;n de los lotes de terreno N&#xBA;s. 4, 9, 11, 12-A, 12-B, 13, 15, 19, 31, 34, 36, 37-A, 37-B, 38, 43 y 45, necesarios para la ejecuci&#xF3;n de la obra Camino Autopista Santiago-San Antonio, sector Enlace Malloco.- </div></div>", "i": 6138225}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6138226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1591", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1591"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "PE AFLOR", "REGION METROPOLITANA", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-09-21", "doble_articulado": false, "id_norma": "126845", "numero_fuente": "36203", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-11-02", "vigencias": [{"desde": "1998-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1998-11-06", "fecha_version": "1998-11-02", "fecha_actualizacio