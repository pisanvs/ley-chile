{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION </div></div>", "i": 7194407}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 43 de 24 de junio de 1993, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se adjudic&#xF3; a Importadora Comercial Chilo&#xE9; Ltda., la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la publicaci&#xF3;n del presente extracto, un establecimiento ubicado en Panamericana Norte S/N, Rol de Propiedad 1120-03 de la comuna de Castro, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 7194408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Arturo Hern&#xE1;ndez Orellana, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 7194409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "43", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-43"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "PLANTA REVISION TECNICA", "IMPORTADORA COMERCIAL CHILOE LTDA.", "CASTRO", "DECIMA REGION", "VEHICULOS MOTORIZADOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-24", "doble_articulado": false, "id_norma": "32546", "numero_fuente": "34689", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-10-13", "vigencias": [{"desde": "1993-10-