{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO DE EDUCACION No. 329, DE 1991 </div></div>", "i": 9049442}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 329 de 29 de noviembre de 1991 se ha aprobado a la Escuela F-176 &quot;Las Mariposas&quot; de la comuna de San Clemente, VII Regi&#xF3;n del Maule, un plan de estudio especial para ser aplicado desde el 5&#xB0; al 8&#xB0; a&#xF1;o b&#xE1;sico simult&#xE1;neamente a partir del a&#xF1;o escolar 1992.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas para el Area de Complementaci&#xF3;n T&#xE9;cnica.-</div><br></div>", "i": 9049443}, {"t": "<div><div class=\"p\">Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 9049444}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "329 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-329 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO DE EDUCACION No. 329, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-11-29", "doble_articulado": false, "id_norma": "86183", "numero_fuente": "34159", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-01-06", "vigencias": [{"desde": "1992-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-01-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-01-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1998-01-23", "fecha_vers