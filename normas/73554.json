{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 487 EXENTO, DE 1997 </div></div>", "i": 7208229}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 487 de fecha 29 de Abril de 1997 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica INACAP, las adecuaciones al plan y programas de estudios de la carrera de Turismo, modific&#xE1;ndose, en consecuencia, el Decreto exento N&#xBA; 418 de 1990. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1997.</div><br></div>", "i": 7208230}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de mayo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7208231}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "487 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-487 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 487 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA INACAP"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-29", "doble_articulado": false, "id_norma": "73554", "numero_fuente": "35789", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-13", "vigencias": [{"desde": "1997-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part":