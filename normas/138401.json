{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6175256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 132, de 26 de Enero de 1988, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se modifica la resoluci&#xF3;n No. 1.557/84 publicada en el Diario Oficial de 11 de Diciembre de 1984, en el sentido de sustituir los cuatrocientos (400) cupos diarios con que la empresa de origen chileno &quot;Compa&#xF1;&#xED;a de Turismo en Autom&#xF3;viles Nueva O&apos;Higgins San Mart&#xED;n&quot;, efect&#xFA;a el servicio regular de transporte internacional terrestre de pasajeros entre Santiago - Valpara&#xED;so Vi&#xF1;a del Mar Mendoza, por cuatro (4) frecuencias diarias de ida y vuelta.</div><div class=\"p\">La empresa antes individualizada est&#xE1; autorizada para reforzar las frecuencias hasta en un cien por ciento (100).-</div><br></div>", "i": 6175257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Patricio Figueroa Cruz, Subsecretario de Transportes subrogante.</div><br></div>", "i": 6175258}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "132", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-132"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-26", "doble_articulado": false, "id_norma": "138401", "numero_fuente": "32993", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-11", "vigencias": [{"desde": "1988-02-11", "hasta": "", "tipo_version": "3", "ti