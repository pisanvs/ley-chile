{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10004866}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 652, de 21 de febrero de 2019, de este Servicio, se aprueba procedimiento de inscripci&#xF3;n de la pesquer&#xED;a de la Vidriola, Palometa, Dorado o Toremo con Bolinche, para las regiones de Atacama, Coquimbo y Valpara&#xED;so.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de resoluci&#xF3;n indicada y su respectivo informe t&#xE9;cnico, se encuentran publicados con esta fecha en el dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y en el de la Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 10004867}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En Valpara&#xED;so, a 21 de febrero de 2019.- Jessica Fuentes Olmos, Directora Nacional (S), Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 10004868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "652 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-652 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1556481", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-02-21", "doble_articulado": false, "id_norma": "1129505", "numero_fuente": "42298", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-03-07", "vigencias": [{"desde": "2019-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-03-07", "fin_vi