{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 127, DE 1990 </div></div>", "i": 7218582}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 127 de 09 de abril de 1990 se ha agregado, a contar del a&#xF1;o escolar 1990, en el art&#xED;culo 1&#xB0; del decreto supremo exento de Educaci&#xF3;n No. 163 de 1982, que aprob&#xF3; un plan especial de estudio para la Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica al Colegio Compa&#xF1;&#xED;a de Mar&#xED;a - Apoquindo, de Santiago, en la parte correspondiente al Plan Electivo para 3&#xB0; y 4&#xB0; a&#xF1;o medio, la Opci&#xF3;n de Orientaci&#xF3;n Integrada.</div><br></div>", "i": 7218583}, {"t": "<div><div class=\"p\">Santiago, 20 de Abril de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7218584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "127 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-127 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°  127, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-09", "doble_articulado": false, "id_norma": "83282", "numero_fuente": "33660", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-03", "vigencias": [{"desde": "1990-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci