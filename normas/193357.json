{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6364564}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.574 de 27 de diciembre de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA YELCHO S.A., para realizar operaciones pesqueras, a contar del 1&#xBA; de enero del 2002 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con el barco f&#xE1;brica denominado Gualas, en aguas exteriores, por fuera de las l&#xED;neas de base recta, al Sur del paralelo 44&#xB0;30 de latitud sur, respecto de las &#xE1;reas y recursos y con las obligaciones establecidas en su autorizaci&#xF3;n.</div><br></div>", "i": 6364565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6364566}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2574", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2574"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-27", "doble_articulado": false, "id_norma": "193357", "numero_fuente": "37153", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-07", "vigencias": [{"desde": "2002-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "