{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Deja sin efecto la nueva pensi&#xF3;n de retiro del se&#xF1;or Guillermo M. Ba&#xF1;ados</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 635.- Santiago, 13 de Septiembre de 1932.-</div><div class=\"p\">&nbsp; &nbsp; El Presidente Provisional de la Rep&#xFA;blica, de acuerdo con el Consejo de Ministros del despacho, dicta el siguiente,</div><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br></div>", "i": 5874669}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. D&#xE9;jase sin efecto el decreto-ley N.o 366 bis, de 3 de Agosto ppdo., del Ministerio de Marina, por el cual se conced&#xED;a una nueva pensi&#xF3;n de retiro al capit&#xE1;n de corbeta contador en retiro, se&#xF1;or Guillermo M. Ba&#xF1;ados H.</div><br></div>", "i": 5874670}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- CARLOS DAVILA.- J. M. Montalva B.</div><br></div>", "i": 5874671}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "635", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-635"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "DEJA SIN EFECTO LA NUEVA PENSION DE RETIRO DEL SEÑOR GUILLERMO M. BAÑADOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PENSION RETIRO", "GUILLERMO BA ADOS", "DEJA SIN EFECTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-09-13", "doble_articulado": false, "id_norma": "6242", "numero_fuente": "16381", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-09-23", "vigencias": [{