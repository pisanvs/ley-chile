{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 753 EXENTA, DE 2009</div></div>", "i": 8722381}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 753, de fecha 15 de abril de 2009, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; complementariamente a la empresa peruana Transportes Cruz del Sur S.A.C., para efectuar servicio de transporte terrestre internacional de pasajeros entre Per&#xFA; y Argentina en tr&#xE1;nsito por territorio chileno y viceversa, atendiendo el servicio Lima (Per&#xFA;) / Buenos Aires (Argentina), utilizando los pasos fronterizos Concordia y Sistema Cristo Redentor con tres (3) frecuencias semanales de ida y vuelta.- </div></div>", "i": 8722382}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Erazo Torricelli, Subsecretario de Transportes.</div></div>", "i": 8722383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "753 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-753 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 753 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-04-15", "doble_articulado": false, "id_norma": "1003859", "numero_fuente": "39399", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-06-30", "vigencias": [{"desde": "2009-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-06-30", "fin_vigencia": ""}, "vigencias_version_norma":