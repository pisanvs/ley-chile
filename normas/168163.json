{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7269243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 315, de 19 de Marzo de 1991, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, se modifica el numeral 3 de la Resoluci&#xF3;n</div><div class=\"p\">No. 1157 de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la</div><div class=\"p\">Sociedad Ventura Hermanos Ltda., R.U.T. No. 87.688.900 5,</div><div class=\"p\">domiciliado en San Antonio, para iniciar actividades</div><div class=\"p\">pesqueras, en el sentido de incluir entre los recursos que</div><div class=\"p\">puede capturar en el litoral de la I a la X Regi&#xF3;n, con el</div><div class=\"p\">arte de pesca enmalle, el denominado Albacora o Pez espada, (Xiphias gladius).</div><br></div>", "i": 7269244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de Marzo de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7269245}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "315", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-315"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-03-19", "fecha_derogacion": "1999-07-05", "doble_articulado": false, "id_norma": "168163", "numero_fuente": "33934", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-04-04", "vigencias": [{"desde": "1999-07-05", "hasta": "", "tipo_version": "2", "t