{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 60 EXENTO, DE 1988 </div></div>", "i": 6156443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 60, de 29 de marzo de 1988, se ha aprobado para el Liceo C-10 &quot;Jorge Alessandri Rodr&#xED;guez&quot;, de la Comuna de Tierra Amarilla, Provincia de Copiap&#xF3;, III Regi&#xF3;n de Atacama, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico-Profesional, Rama Industrial, Especialidades: Minas, Mineralurgia y Mantenci&#xF3;n de M&#xE1;quinas Mineras, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1988 y hasta el a&#xF1;o escolar 1989.</div><br></div>", "i": 6156444}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 04 de Abril de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6156445}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "60 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-60 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO No. 60 EXENTO, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-29", "doble_articulado": false, "id_norma": "132507", "numero_fuente": "33046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-15", "vigencias": [{"desde": "1988-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04-15", "fin_vige