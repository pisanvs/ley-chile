{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.885 EXENTA, DE 2012</div></div>", "i": 9247180}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.885, de 23 de marzo de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Centro de Capacitaci&#xF3;n V&#xED;ctor Gonz&#xE1;lez Rodr&#xED;guez E.I.R.L. (Centro de Capacitaci&#xF3;n Sermar E.I.R.L.)&quot;, RUT 76.020.961-9, contenida en la resoluci&#xF3;n exenta N&#xBA; 4.685, de 2 de julio de 2009, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.-</div><br></div>", "i": 9247181}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Francisco Ag&#xFC;ero Larrondo, Director Nacional Subrogante.</div></div>", "i": 9247182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2885 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2885 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.885 EXENTA, DE 2012", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2012-03-23", "fecha_derogacion": "2012-07-25", "doble_articulado": false, "id_norma": "1038769", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2012-04-05", "vigencias": [{"desde": "2012-07-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2012-04-05", "hasta": "2012-07-24", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia