{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295237}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.015, de 10 de agosto de 1995, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la Resoluci&#xF3;n N&#xB0; 882, de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA FAMSO S.A., R.U.T. N&#xB0; 95.344.000-8, para desarrollar actividades pesqueras extractivas con la nave &quot;Don Orlando&quot;, en lo relativo a las especies Agujilla, Anchoveta, Caballa, Jurel y Sardina espa&#xF1;ola, en el litoral de las I y II Regiones, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b), de la Ley N&#xB0; 18.892 citada en Visto.</div><br></div>", "i": 8295238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 10 de agosto de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295239}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1015", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1015"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD PARCIAL", "AUTORIZACION", "PESQUERA FAMSO S.A", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-08-10", "doble_articulado": false, "id_norma": "36026", "numero_fuente": "35248", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-08-21", "vigencias": [{"desde": "1995-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-0