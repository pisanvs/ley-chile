{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6101310}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 549, de 30 de mayo de 1989, de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186 de 1978 inmueble ubicado en calle Ricardo Santa Cruz No. 769, presunto rol aval&#xFA;os No. 596-18 comuna de Santiago, aparentemente dominio de do&#xF1;a Eva Labb&#xE9; Catal&#xE1;n. Comisi&#xF3;n integrada por peritos Sres. Ricardo Carvallo Rodr&#xED;guez y Luis del Pozo Concha arquitectos, y Ra&#xFA;l Varela Hern&#xE1;ndez, ingeniero civil, seg&#xFA;n informe de 2 de diciembre de 1988, aj&#xF3; monto provisional indemnizaci&#xF3;n en $1.733.760, pagadera al contado.</div><br></div>", "i": 6101311}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6101312}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "549", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-549"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANIZACIÓN REGIÓN METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-30", "doble_articulado": false, "id_norma": "95912", "numero_fuente": "33411", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-01", "vigencias": [{"desde": "1989-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMB", "fecha_ingreso": "1998-03-17", "fecha_version": "