{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6431715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;550 de fecha 30 de mayo de 2003, se expropi&#xF3; el lote de terreno N&#xBA;5, superficie 633,00 m2, rol de Aval&#xFA;o N&#xBA;532-7, comuna de La Uni&#xF3;n, para la obra &quot;Camino Conexi&#xF3;n La Uni&#xF3;n - Corral, Sector Bifurcaci&#xF3;n La Uni&#xF3;n, Empalme Ruta T-60, Km. 7,100 a Km.</div><div class=\"p\">8,500&quot;, X Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario V&#xED;ctor Marcial Cea Lavoz y Otra, ascendente a la cantidad de $9.971.251. </div></div>", "i": 6431716}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6431717}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "550", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-550"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-30", "doble_articulado": false, "id_norma": "212528", "numero_fuente": "37609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-15", "vigencias": [{"desde": "2003-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-07-15", "fecha_version": "2003-07-15", "fecha_actualizacion_texto": "2003-07-15