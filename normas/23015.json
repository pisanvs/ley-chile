{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,924 que consulta fondos para combatir la viruela</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,924.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274847}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de doscientos mil pesos en la adopcion de medidas destinadas a combatir las enfermedades infecciosas i en los gastos ocasionados por las mismas.</div><br></div>", "i": 8274848}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de enero de 1907.- PEDRO MONTT.- V. Santa Cruz.</div><br></div>", "i": 8274849}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1924", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1924"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NÚM. 1,924 QUE CONSULTA FONDOS PARA COMBATIR LA VIRUELA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDENTE REPUBLICA", "INVERSION", "AUTORIZACION", "ENFERMEDADES INFECCIOSAS", "PROFILAXIS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-01-26", "doble_articulado": false, "id_norma": "23015", "numero_fuente": "8711", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-01-26", "vigencias": [{"desde": "1907-01-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {