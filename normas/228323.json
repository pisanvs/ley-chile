{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6489905}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;408 de 13 de julio de 2004 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA;2.186 de 1978, del lote N&#xBA;5 correspondiente al inmueble ubicado en Calle Suiza N&#xBA;45, presunto Rol de Aval&#xFA;o N&#xBA;556-1, comuna de Cerrillos, aparente dominio de Inver Cuevas y Ossand&#xF3;n. Comisi&#xF3;n integrada por peritos Armando Pinochet Landero, Constructor Civil; Carmen R&#xED;os Marcuello, Ingeniero Civil, y Alfredo Irrizarri Valderrama, Arquitecto. Seg&#xFA;n informe de fecha 26 de marzo de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $136.251.026.- pagadera al contado.</div><br></div>", "i": 6489906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6489907}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "408", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-408"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA EN INMUEBLES QUE SEÑALA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-13", "doble_articulado": false, "id_norma": "228323", "numero_fuente": "37925", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-02", "vigencias": [{"desde": "2004-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi