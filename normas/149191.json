{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8354529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.393, de&nbsp; 6 de diciembre de 1999, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 359 de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA COLOSO S.A., para operar la nave &apos;&apos;Audaz&apos;&apos;, s&#xF3;lo en lo relativo al recurso Jurel, en el litoral de la III a la IV Regiones, configur&#xE1;ndose la causal prevista en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8354530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de diciembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8354531}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2393", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2393"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-06", "doble_articulado": false, "id_norma": "149191", "numero_fuente": "36537", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-13", "vigencias": [{"desde": "1999-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-12-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "J