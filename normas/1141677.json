{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  PASAPORTES.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Noviembre 23 de 1824.</div><br><div class=\"p\">&nbsp; &nbsp;  He acordado y decreto:</div></div>", "i": 10098912}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Los pasaportes y licencias para los particulares que quieran viajar fuera del territorio de la Rep&#xFA;blica, que antes se concedian por el Supremo Gobierno, se despachar&#xE1;n en lo sucesivo por el Gobernador Intendente.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; El Gobierno Supremo solo expedir&#xE1; los pasaportes para los individuos del Cuerpo Diplom&#xE1;tico. Comun&#xED;quese e ins&#xE9;rtese en el Boletin.</div><br></div>", "i": 10098913}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  F. A. Pinto.</div></div>", "i": 10098914}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "PASAPORTES.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-11-23", "doble_articulado": false, "id_norma": "1141677", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-11-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso"