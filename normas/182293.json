{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 836 EXENTA, DE 2001 </div></div>", "i": 6324404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 836 de 7 de febrero del a&#xF1;o 2001, se ha aprobado al Colegio &quot;The British School&quot;, comuna de Punta Arenas, XII Regi&#xF3;n, un plan de estudio para 3er. a&#xF1;o de ense&#xF1;anza media human&#xED;stico-cient&#xED;fica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se se&#xF1;alan en la presente resoluci&#xF3;n. </div></div>", "i": 6324405}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de febrero de 2001.- Javier San Miguel Beltr&#xE1;n, Jefe Divisi&#xF3;n de Educaci&#xF3;n General (S). </div></div>", "i": 6324406}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "836 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-836 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 836 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-02-07", "doble_articulado": false, "id_norma": "182293", "numero_fuente": "36899", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-27", "vigencias": [{"desde": "2001-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-02-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []