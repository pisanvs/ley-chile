{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 316, DE 1986 </div></div>", "i": 6188617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 316, de 11 de diciembre de 1986, se ha derogado, a contar del a&#xF1;o escolar 1987, el decreto supremo exento de Educaci&#xF3;n No. 327 de 1985 que aprob&#xF3; plan de estudio especial para la Educaci&#xF3;n B&#xE1;sica de Adultos, a la Escuela Particular Padre Luis Amig&#xF3;. de Tom&#xE9;.</div><div class=\"p\">&nbsp; &nbsp;  La citada Escuela aplicar&#xE1;, a contar de la misma fecha, el plan y los programas de estudio aprobados para la Ense&#xF1;anza General B&#xE1;sica por decreto supremo de Educaci&#xF3;n No. 4.002, de 1980 y sus modificaciones. </div></div>", "i": 6188618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Marzo de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6188619}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "316 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-316 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 316, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-12-11", "doble_articulado": false, "id_norma": "142529", "numero_fuente": "32752", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-22", "vigencias": [{"desde": "1987-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-22", "fin_vigencia": ""}, "vigencias_ver