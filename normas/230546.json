{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6497857}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.304 de 25 de agosto de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a GILBERTO JAVIER CORREA BRAVO para ampliar actividades pesqueras de transformaci&#xF3;n en orden a incorporar a la planta ubicada en Duao s/n, Licant&#xE9;n, VII Regi&#xF3;n, en las l&#xED;neas de proceso de Cocido, Fresco-Enfriado, Fresco-Refrigerado, Congelado y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6497858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6497859}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2304 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2304 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-25", "doble_articulado": false, "id_norma": "230546", "numero_fuente": "37967", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-22", "vigencias": [{"desde": "2004-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-09-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2004-09-22", "fecha_version": "2004-09