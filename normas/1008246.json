{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div></div>", "i": 8802269}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de noviembre de 2009, fue de 1,89% anual.</div></div>", "i": 8802270}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de noviembre de 2009.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 8802271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-11-17", "doble_articulado": false, "id_norma": "1008246", "numero_fuente": "39515", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-11-19", "vigencias": [{"desde": "2009-11-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-11-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-11-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2009-11-19", "fecha_version": "2009-11-19", "actualizado_por": "1289", "fecha_actualizacion_texto": "2009-11-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabez