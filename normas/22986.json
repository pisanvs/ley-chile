{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,891 que dispone que el Fiscal de la Corte Suprema lo ser&#xE1; tambien del Consejo de Estado Lei n&#xFA;m. 1,891.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7165407}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico . El Fiscal de la Corte Suprema ser&#xE1; tambien Fiscal del Consejo de Estado.</div><br></div>", "i": 7165408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 13 de diciembre de 1906.- PEDRO MONTT.- Oscar Viel.</div><br></div>", "i": 7165409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1891", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1891"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "LEI NÚM. 1.891 QUE DISPONE QUE EL FISCAL DE LA CORTE SUPREMA LO SERÁ TAMBIÉN DEL CONSEJO DE ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CORTE SUPREMA", "FISCAL", "CONSEJO ESTADO", "FUNCIONES", "DESEMPE O"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-12-13", "doble_articulado": false, "id_norma": "22986", "numero_fuente": "8818", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-06-07", "vigencias": [{"desde": "1907-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-06-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici