{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.343 EXENTA, DE 2007 </div></div>", "i": 6620797}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.343, de 26 de julio de 2007, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xBA;5 de la resoluci&#xF3;n N&#xBA;65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo como combustible:</div><br><div class=\"p\">Empresa&nbsp; &nbsp; &nbsp; &nbsp; Nombre del&nbsp; &nbsp; &nbsp;  Direcci&#xF3;n&nbsp; &nbsp; &nbsp; Ciudad</div><div class=\"p\">Habilitada&nbsp; &nbsp; &nbsp;  Taller&nbsp; &nbsp; &nbsp; &nbsp; del Taller</div><div class=\"p\">GLP Motor&nbsp;  Antonio Castillo&nbsp; Angol N&#xBA; 828&nbsp;  Concepci&#xF3;n</div><div class=\"p\">Ltda.&nbsp; &nbsp; &nbsp;  S.A.</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.</div><br></div>", "i": 6620798}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Danilo N&#xFA;&#xF1;ez Izquierdo, Subsecretario de Transportes.</div><br></div>", "i": 6620799}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1343 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1343 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.343 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-26", "doble_articulado": false, "id_norma": "