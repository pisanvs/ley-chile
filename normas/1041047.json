{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9266945}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA;975 de 31 de mayo de 2012, de conformidad a lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;2, superficie 218 m2, rol de Aval&#xFA;o N&#xBA;1114-21, comuna de Osorno, para la obra &quot;REPARACI&#xD3;N PUENTE BULNES EN OSORNO&quot;. La Comisi&#xF3;n de peritos, integrada por Nelson Bernardo Turra Turra, Christian Emil Rauch Y&#xE1;&#xF1;ez y Nelson Fabi&#xE1;n Igor Flores, fij&#xF3; el valor de tasaci&#xF3;n con fecha 10 de junio de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con el CLUB ATL&#xC9;TICO LLANQUIHUE, en la cantidad de $3.804.780.- suma que se pagar&#xE1; al contado. </div></div>", "i": 9266946}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9266947}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "975 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-975 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-31", "doble_articulado": false, "id_norma": "1041047", "numero_fuente": "40288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-15", "vigencias": [{"desde": "2012-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-06-15", "fin_vigencia": "", "tipo_version"