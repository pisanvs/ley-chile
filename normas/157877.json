{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6239788}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 3, de fecha 30 de Mayo de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se autoriza a don Juan Segundo P&#xE1;ez L&#xF3;pez para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transportes de personas de m&#xE1;s de nueve (9) asientos incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en Avenida 11 de Septiembre No. 2559, de la ciudad de Tocopilla.-</div><br></div>", "i": 6239789}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Guido M. Ram&#xED;rez Maturana, Secretario Regional Ministerial de Transportes y Telecomunicaciones II Regi&#xF3;n.</div><br></div>", "i": 6239790}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-30", "doble_articulado": false, "id_norma": "157877", "numero_fuente": "32219", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-11", "vigencias": [{"desde": "1985-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-11", "fin_vigencia": ""}, "vigencias_version_norma"