{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7280035}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 399, de 8 de marzo de 2001, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 656, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA BIO BIO S.A., para realizar actividades con la nave &apos;&apos;Gardar&apos;&apos;, sobre los recursos Anchoveta y Sardina espa&#xF1;ola, en el &#xE1;rea mar&#xED;tima de la IV Regi&#xF3;n, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura. </div></div>", "i": 7280036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de marzo de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7280037}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "399", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-399"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-08", "doble_articulado": false, "id_norma": "181463", "numero_fuente": "36914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-16", "vigencias": [{"desde": "2001-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "mod