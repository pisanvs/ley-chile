{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 59 EXENTO, DE 1988 </div></div>", "i": 6156440}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 59, de 28 de marzo de 1988 se ha aprobado para el &quot;Colegio Saint Orland No. 2&quot;, de la Comuna de La Cisterna, Provincia de Santiago, Regi&#xF3;n Metropolitana, un plan y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico-Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar de 1988 y hasta el a&#xF1;o escolar de 1989, en la Rama Industrial, Especialidad Mec&#xE1;nica Automotriz.</div><br></div>", "i": 6156441}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 07 de Abril de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6156442}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "59 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-59 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO No. 59 EXENTO, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-28", "doble_articulado": false, "id_norma": "132506", "numero_fuente": "33046", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-15", "vigencias": [{"desde": "1988-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"