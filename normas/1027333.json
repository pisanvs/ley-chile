{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9155585}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la publicaci&#xF3;n del extracto efectuada en la edici&#xF3;n del 1&#xBA; de junio de 2011, correspondiente al <a href=\"https://www.leychile.cl/Navegar?idNorma=1026131&amp;idParte=0&amp;idVersion=\">Decreto M.O.P. (Exento) N&#xBA;862, de 24 de mayo de 2011</a>, en el sentido que el a&#xF1;o correspondiente al Decreto MOP N&#xBA;822, es 2010 y no 2011, como se indic&#xF3; en dicho extracto. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA;2.186, de 1978. </div><br></div>", "i": 9155586, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 9155587}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "Aviso-S/N"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. NORMA SIN FECHA DE PROMULGACIÓN."], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1027333", "numero_fuente": "39999", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-07-01", "vigencias": [{"desde": "2011-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-07-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado