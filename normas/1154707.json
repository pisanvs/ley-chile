{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Administraci&#xF3;n de Temporalidades</div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de Marzo de 1814</div></div>", "i": 10198303}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por este decreto queda suprimida la Administraci&#xF3;n de Temporalidades i agregado el conocimiento i manejo de sus ramos a los Ministros de Hacienda del Estado, quienes se recibir&#xE1;n de ellos en la intelijencia de que los individuos meritorios de la renta suprimida ser&#xE1;n empleados en otras oficinas segun sus servicios i patriotismo. -</div></div>", "i": 10198304}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Irisarri. &#x2013; Ega&#xF1;a, secretario.</div></div>", "i": 10198305}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTRO", "descripcion": "Otro", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "ADMINISTRACIÓN DE TEMPORALIDADES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-03-09", "doble_articulado": false, "id_norma": "1154707", "numero_fuente": "1814", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-03-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-03-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-03-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2021-02-02", "fecha_version": "1814-03-09", "fecha_actualizacion_texto": "1814-03-09", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "est