{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6062075}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 536, de 14.08.90, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza en forma complementaria a la empresa de origen argentino Cooperativa Andina de Transporte Automotor Limitada de Trabajo (C.A.T.A.) para efectuar servicio internacional de transporte terrestre de pasajeros entre Mendoza (Argentina) y Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar (Chile) utilizando el paso fronterizo T&#xFA;nel Cristo Redentor, realizando diez frecuencias diarias de ida y vuelta, con las siguientes caracter&#xED;sticas de prestaci&#xF3;n:</div><div class=\"p\"> a) Mendoza - Santiago.</div><div class=\"p\"> b) Mendoza - Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar.</div><div class=\"p\"> c) Mendoza - Vi&#xF1;a del Mar - Valpara&#xED;so.</div><br></div>", "i": 6062076}, {"t": "<div><div class=\"p\"> Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 6062077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "536", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-536"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-08-14", "doble_articulado": false, "id_norma": "82370", "numero_fuente": "33762", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-09-04", "vigencias": [{"desde": "1990-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "