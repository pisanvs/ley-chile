{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE SE&#xD1;ALA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 46.- Santiago, 4 de Marzo de 1994.- Vistos: Lo dispuesto en el Art. 11 del decreto ley N&#xB0; 2.974, de 1979.</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6004375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Receptor Judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado, en la X Regi&#xF3;n al se&#xF1;or:</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; - Franklin Linz Linz.</div><br></div>", "i": 6004376}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Encargada Oficina de Partes.</div><br></div>", "i": 6004377}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "46", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-46"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE\nSEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECEPTOR JUDICIAL", "CARGOS JUDICIALES", "FRANKLIN LINZ LINZ"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-04", "doble_articulado": false, "id_norma": "32577", "numero_fuente": "34825", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-26", "vigencias": [{"desde": "1994-03-2