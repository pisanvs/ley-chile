{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; RUDECINDO VALENZUELA Lei n&#xFA;m. 268.-Santiago, a 6 de Febrero de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Consid&#xE9;rase, por gracia, para los efectos de la lei de 22 de Diciembre de 1881, que el contra-maestre de la Armada Nacional, don Rudecindo Valenzuela, fu&#xE9; muerto en accion de guerra.</div><br><br></div>", "i": 5947353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-</div><div class=\"p\">C&#xE1;rlos Rivera Jofr&#xE9;.</div><br></div>", "i": 5947354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "268", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-268"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "RUDECINDO VALENZUELA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RUDECINDO VALENZUELA", "FAMILIA", "BENEFICIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-02-06", "doble_articulado": false, "id_norma": "22122", "numero_fuente": "5034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-02-07", "vigencias": [{"desde": "1895-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-02-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_