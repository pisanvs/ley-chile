{"html": [{"t": "<div><div class=\"p\">NOMBRAMIENTO DE MINISTROS PARA TODOS LOS DEPARTAMENTOS DEL DESPACHO.</div><br><div class=\"p\">&nbsp; &nbsp;  DECRETO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 8 de 1825.</div></div>", "i": 10182093}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Hall&#xE1;ndose vacante en el Departamento de Relaciones Exteriores y del Interior por dimision de el que lo obtenia; y siendo preciso elejir para su desempe&#xF1;o un ciudadano de aptitud, patriotismo y buena comportacion; concurriendo estas circunstancias en D. Joaquin Campino, he venido en nombrarle por tal Ministro de Relaciones Exteriores y del Interior.</div></div>", "i": 10182094}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, comun&#xED;quese e ins&#xE9;rtese en el Boletin.</div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE&nbsp;  </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; ------&nbsp;  Astorga</div></div>", "i": 10182095}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE INTERIOR"], "titulo_norma": "NOMBRAMIENTO DE MINISTROS PARA TODOS LOS DEPARTAMENTOS DEL DESPACHO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-10-08", "doble_articulado": false, "id_norma": "1151478", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"