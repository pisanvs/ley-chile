{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO&nbsp; N&#xBA; 991 EXENTO, DE 1998</div><br><br><br></div>", "i": 6139757}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 991, de 15 de octubre de 1998, se ha autorizado al Colegio &apos;&apos;Tabancura&apos;&apos; de la comuna de Vitacura, de Santiago, para incorporar en el plan de estudio de 3&#xBA; a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, aprobado por decreto supremo exento de Educaci&#xF3;n N&#xBA; 525, de 1997, la asignatura de Etica, con dos clases semanales, a contar desde el a&#xF1;o escolar 1999, aumentando el n&#xFA;mero total de clases de este curso de 46 a 48 horas.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Etica de 3&#xBA; a&#xF1;o de&nbsp; Ense&#xF1;anza&nbsp; Media Human&#xED;stico-Cient&#xED;fica.</div><br></div>", "i": 6139758}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de octubre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6139759}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "991 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-991 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 991 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO TABANCURA", "VITACURA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-10-15", "doble_articulado": false, "id_norma": "127330", "numero_fuente": "36218", "tipo_version": "3", "tipo_version_s": "Única", "fec