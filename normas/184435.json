{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6331705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 518, de 28 de marzo de 2001,</div><div class=\"p\">de esta Subsecretar&#xED;a, autor&#xED;zase a FABIOLA ALEXANDRA</div><div class=\"p\">JARA ORDO&#xD1;EZ para ampliar actividades pesqueras de</div><div class=\"p\">transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 2.522</div><div class=\"p\">de 2000, en orden a operar una planta ubicada en Bajo</div><div class=\"p\">Molle Km. 10, Iquique, I Regi&#xF3;n, donde podr&#xE1; procesar</div><div class=\"p\">en las l&#xED;neas de proceso Congelado, Fresco-enfriado,</div><div class=\"p\">Precocido, el recurso hidrobiol&#xF3;gico Pulpo.</div><div class=\"p\">&nbsp; &nbsp;  La materia prima deber&#xE1; provenir de pescadores</div><div class=\"p\">artesanales, debidamente autorizados.</div><br></div>", "i": 6331706}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de marzo de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6331707}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "518", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-518"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-28", "doble_articulado": false, "id_norma": "184435", "numero_fuente": "36942", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-20", "vigencias": [{"desde": "2001-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni