{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA RESOLUCI&#xD3;N N&#xBA; 4, DE 2012, QUE FIJA TABLAS DE VALORES DE VEH&#xCD;CULOS QUE INDICA</div></div>", "i": 9228634}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 6 del 17 de enero de 2012, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Rectifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1036545&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 4, de 13.01.2012</a>, que fija tablas de valores de trolebuses, microbuses, camiones, taxis, taxis colectivos, taxibuses, autom&#xF3;viles, station wagons, furgones, camionetas, incluyendo el de sus acoplados o carros de arrastre.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en enero de 2012.</div></div>", "i": 9228635}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "RECTIFICA RESOLUCIÓN Nº 4, DE 2012, QUE FIJA TABLAS DE VALORES DE VEHÍCULOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-17", "doble_articulado": false, "id_norma": "1036585", "numero_fuente": "40166", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-01-20", "vigencias": [{"desde": "2012-01-20", "h