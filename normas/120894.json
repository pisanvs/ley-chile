{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 905, de 30 de junio de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rectif&#xED;case de la resoluci&#xF3;n N&#xBA; 170 de 1997 de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a&nbsp; ALIMENTOS MARINOS S.A., para operar por sustituci&#xF3;n la nave &apos;&apos;Alcones&apos;&apos;, en el sentido de agregar el siguiente inciso 2&#xBA; a la letra a) del numeral 2&#xBA;: &apos;&apos;Adem&#xE1;s la interesada podr&#xE1; capturar en el litoral de la III y IV Regiones, por fuera del &#xE1;rea de reserva artesanal, con red de cerco, los siguientes recursos&nbsp; hidrobiol&#xF3;gicos: Agujilla, Bonito, Caballa, Cabinza, Cojinoba del norte, Jurel, Machuelo o tritre y Sardina com&#xFA;n&apos;&apos;.</div><br></div>", "i": 8331590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "905", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-905"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ALIMENTOS MARINOS S.A.", "RECTIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-06-30", "fecha_derogacion": "2007-12-31", "doble_articulado": false, "id_norma": "120894", "numero_fuente": "36108", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "