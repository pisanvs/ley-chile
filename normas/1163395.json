{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10257444}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n exenta N&#xB0; 1.465, de 30 de julio de 2021, aprueba gu&#xED;a t&#xE9;cnica que describe el formato de prestaciones de las solicitudes de registro sanitario de productos farmac&#xE9;uticos (FPS)-edificada.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se encuentra disponible en la p&#xE1;gina web del Instituto de Salud P&#xFA;blica de Chile, www.ispch.cl.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10257445}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Heriberto Garc&#xED;a Escorza, Director (S) Instituto de Salud P&#xFA;blica de Chile.</div><br></div>", "i": 10257446}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1465 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1465 EXENTA"}], "organismos": ["MINISTERIO DE SALUD", "INSTITUTO DE SALUD PÚBLICA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1989319", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-07-30", "doble_articulado": false, "id_norma": "1163395", "numero_fuente": "43021", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-08-06", "vigencias": [{"desde": "2021-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-08-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-08-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fech