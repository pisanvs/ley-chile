{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9237674}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 256, de 3 de febrero de 2012, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1036572&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 83 de 2012</a>, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a PESCA CHILE para operar por sustituci&#xF3;n la nave f&#xE1;brica &quot;Saint Pierre&quot;, en el sentido de reemplazar en su numeral 1&#xB0; y en el extracto de la se&#xF1;alada resoluci&#xF3;n la expresi&#xF3;n &quot;BEC 2299/10&quot; por &quot;BEC 2291/11&quot;.</div><br></div>", "i": 9237675}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de febrero de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9237676}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "256 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-256 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2012-02-03", "fecha_derogacion": "2014-10-28", "doble_articulado": false, "id_norma": "1037384", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2012-02-17", "vigencias": [{"desde": "2014-10-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2012-02-17", "hasta": "2014-10-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-10-28", "fin_vigencia": ""}, "vigencias_ver