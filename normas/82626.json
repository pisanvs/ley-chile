{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION QUE INDICA </div></div>", "i": 8313934}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 867 de 16 de Julio de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n se deroga la Resoluci&#xF3;n No. 946, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Nicanor Segundo D&#xED;az Bustamante, R.U.T. No. 5.970.402-8, domiciliado en calle 19 de Junio No. 01788, Villa El Golf, Punta Arenas, para instalar y operar un establecimiento de cultivo de especies salmonideas en dos sectores ubicados en el Lago Tapehuico, Comuna de Chonchi, Provincia de Chilo&#xE9;, X Regi&#xF3;n, por renuncia de su titular.</div><br></div>", "i": 8313935}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 16 de Julio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8313936}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "867", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-867"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DEROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-16", "doble_articulado": false, "id_norma": "82626", "numero_fuente": "33725", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-07-21", "vigencias": [{"desde": "1990-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-07-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-07-21", "fin_vigencia": "", "tipo_