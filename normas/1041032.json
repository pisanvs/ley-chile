{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9267059}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;953 de fecha 31 de mayo de 2012, y de conformidad a lo dispuesto en el Art. 105 del DFL. MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;25, superficie 2.295 m2, rol N&#xBA;152-25, para la obra &quot;Camino Ruta U-775, Sector Cruce Ruta U-99-V (Nochaco) - Rupanquito, Tramo Km. 0,00000 a Km. 22,26000&quot;, Comuna de Puerto Octay, X Regi&#xF3;n. La Comisi&#xF3;n de Peritos integrada por Nelson Bernardo Turra Turra, Juan Samuel Barrientos Bahamonde y Leopoldo Ram&#xF3;n Schumacher Guarda, fij&#xF3; valor de tasaci&#xF3;n con fecha 08 de octubre de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JUAN ANTONIO MARTABIT SCAFF, en la cantidad de $3.048.778, suma que se pagar&#xE1; al contado. </div></div>", "i": 9267060}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9267061}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "953 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-953 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-05-31", "doble_articulado": false, "id_norma": "1041032", "numero_fuente": "40288", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-15", "vigencias": [{"desde": "2012-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-15", "fin_vigencia": ""}, "vigen