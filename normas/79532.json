{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6055123}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No.283 de 09 de Octubre de 1991 se ha derogado el decreto supremo exento de Educaci&#xF3;n No.16 de 1989, que aprob&#xF3; planes especiales de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, para el Colegio Clerc de Santiago, a contar del a&#xF1;o escolar 1992.</div><div class=\"p\">Adem&#xE1;s, se declara que el citado Colegio aplicar&#xE1; en los cursos se&#xF1;alados, a contar del a&#xF1;o escolar 1992, los planes y programas oficiales generales vigentes.</div><br></div>", "i": 6055124}, {"t": "<div><div class=\"p\">Santiago, 14 de Noviembre de 1991. Ra&#xFA;l Allard Neumman, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6055125}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "283 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-283 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-10-09", "doble_articulado": false, "id_norma": "79532", "numero_fuente": "34224", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-03-21", "vigencias": [{"desde": "1992-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-03-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "