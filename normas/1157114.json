{"html": [{"t": "<div><div class=\"p\">AJENTE CONSULAR FRANCES EN VALPARAISO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 8 de 1828.</div></div>", "i": 10237722}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el C&#xF3;nsul jeneral de Francia en Chile se ha servido nombrar a Mr. Eugene Rabusson, ajente consular frances, residente en el puerto de Valpara&#xED;so, para que atienda a todo lo relativo a la provision y demas necesario a la marina de nacion: por tanto se reconocer&#xE1; al expresado Mr. Rabusson con tal ajente consular frances residente en el puerto de Valparaiso. Devuelvase al C&#xF3;nsul jeneral el despacho que ha manifestado sobre este nombramiento, comun&#xED;quese el presente decreto a quienes corresponda e impr&#xED;mase.</div></div>", "i": 10237723}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  R&#xFA;brica de S.E.</div><br><div class=\"p\">&nbsp; &nbsp;  Rodriguez.</div></div>", "i": 10237724}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES"], "titulo_norma": "AJENTE CONSULAR FRANCES EN VALPARAISO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-04-08", "doble_articulado": false, "id_norma": "1157114", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-04-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-04-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-04-08", "fin_vigencia": "", "