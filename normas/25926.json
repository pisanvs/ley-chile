{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CONCEDE AMNISTIA A DON ISAIAS CARRASCO VIDAL Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5966350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese amnist&#xED;a a don Isa&#xED;as Carrasco Vidal por el delito de hurto a que fu&#xE9; condenado por el Segundo Juzgado Militar de Santiago, con fecha 13 de Enero de 1939.</div><div class=\"p\">&nbsp; &nbsp; Esta ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5966351}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, dos de Octubre de mil novecientos cuarenta y ocho.- GABRIEL GONZALEZ VIDELA.- Luis F. Letelier. </div></div>", "i": 5966352}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9115", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9115"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE AMNISTIA A DON ISAIAS CARRASCO VIDAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AMNISTIA", "ISAIAS CARRASCO VIDAL", "DELITO", "HURTO", "JUZGADO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1948-10-02", "doble_articulado": false, "id_norma": "25926", "numero_fuente": "21182", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1948-10-20", "vigencias": [{"desde": "1948-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia":