{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 4,583</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 8354618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; Elim&#xED;nase el inciso 2.o del art&#xED;culo 3.o de la ley n&#xFA;mero 4,559, sobre contrataci&#xF3;n de un empr&#xE9;stito destinado a la transformaci&#xF3;n de la ciudad de Talca.</div><br></div>", "i": 8354619, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, ocho de Febrero de mil novecientos veintinueve.-&nbsp; Carlos Ib&#xE1;&#xF1;ez C.-&nbsp; Guillermo Edwards Matte.</div><br><br></div>", "i": 8354620}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4583", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4583"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-02-08", "doble_articulado": false, "id_norma": "149307", "numero_fuente": "15299", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-02-14", "vigencias": [{"desde": "1929-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-02-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-02-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul