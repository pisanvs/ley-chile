{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a do&#xF1;a Filomena Mart&#xED;nez v. de Poblete</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277410}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Filomena Mart&#xED;nez viuda de Poblete, madre del guardi&#xE1;n de la Polic&#xED;a de Temuco, don Clodomiro Poblete, muerto en acto del servicio, el goce de una pensi&#xF3;n mensual de treinta pesos ($ 30), de que disfrutar&#xE1; por el espacio de diez a&#xF1;os.</div><br></div>", "i": 8277411}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, quince de Febrero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Enrique Balmaceda. </div></div>", "i": 8277412}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4315", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4315"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE PENSION DE GRACIA A DOÑA FILOMENA MARTINEZ V. DE POBLETE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FILOMENA MARTINEZ DE POBLETE", "PENSION GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-02-15", "doble_articulado": false, "id_norma": "24654", "numero_fuente": "15005", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-21", "vigencias": [{"desde": "1928-02-21", "hasta": "", "t