{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6494760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 533 de 30 de junio de 2004, se dej&#xF3; sin efecto los numerales 3&#xBA; , 4&#xBA; , 5&#xBA; , 6&#xBA; y 7&#xBA; del decreto MOP N&#xBA; 4.542 de 29 de septiembre de 2000, en la parte que se refiere al Convenio Directo de Precio Ad-Referendum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 45, fijada por la Comisi&#xF3;n de Peritos, con fecha 25 de enero de 1999, ascendente a la cantidad de $991.900.</div><br></div>", "i": 6494761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6494762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "533", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-533"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-30", "doble_articulado": false, "id_norma": "229709", "numero_fuente": "37951", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-01", "vigencias": [{"desde": "2004-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresa