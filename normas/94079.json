{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 1.409, DE 1989 </div></div>", "i": 7228415}, {"t": "<div><br><div class=\"p\">Por resoluci&#xF3;n exenta No. 1.409 de fecha 11 de mayo de 1989 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se reemplazaron las normas de evaluaci&#xF3;n promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica CEDECOM de Quillota, aprobadas por Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 1.020 de 1985 y No. 274 de 1987, las que podr&#xE1;n aplicarse a contar del a&#xF1;o acad&#xE9;mico 1989.</div><br></div>", "i": 7228416}, {"t": "<div><br><div class=\"p\">Santiago, 9 de Junio de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7228417}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1409 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1409 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 1.409, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-11", "doble_articulado": false, "id_norma": "94079", "numero_fuente": "33412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-03", "vigencias": [{"desde": "1989-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-07-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "mo