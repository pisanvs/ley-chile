{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8345978}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.201, de 18 de junio de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 1.606 de 1989, que autoriz&#xF3; a JOSE ENRIQUE ESQUIVEL CAMPA&#xD1;A, para ampliar actividades pesqueras extractivas con la nave &apos;&apos;Coyote&apos;&apos;, por haberse configurado la causal de caducidad contenida en la letra d) del art&#xED;culo 143 de la Ley General de Pesca y Acuicultura citada en Visto, esto es, el no pago de la patente &#xFA;nica pesquera.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto las resoluciones N&#xBA; 988 de 1989 y N&#xBA; 1.168 de 1991, por no haber sido publicadas oportunamente en el Diario Oficial.</div><br></div>", "i": 8345979}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de junio de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8345980}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1201", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1201"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-18", "doble_articulado": false, "id_norma": "138164", "numero_fuente": "36397", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-25", "vigencias": [{"desde": "1999-06-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-25", "fin_vigencia": ""