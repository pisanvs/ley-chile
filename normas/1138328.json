{"html": [{"t": "<div><div class=\"p\">CUARTO MINISTRO DE LA CORTE DE APELACIONES.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 17 de 1824:</div></div>", "i": 10068661}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Oido el acuerdo de mi Consejo de Estado he venido en nombrar a D. Vicente Aguirre para el destino de cuarto Ministro de la Corte de Apelaciones vacante por renuncia de D. Silvestre Lazo: entendi&#xE9;ndole este nombramiento hasta la primera reunion de las Asambleas electorales con arreglo a la Constitucion. Expidase el correspondiente t&#xED;tulo: comun&#xED;quese a la Suprema Corte de Justicia donde ha de prestar el juramento el nombrado, e ins&#xE9;rtese en el Boletin.</div></div>", "i": 10068662}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ. </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Ega&#xF1;a.</div></div>", "i": 10068663}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "CUARTO MINISTRO DE LA CORTE DE APELACIONES.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-02-17", "doble_articulado": false, "id_norma": "1138328", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-02-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc