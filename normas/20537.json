{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 173 EXENTO, DE 1996 </div></div>", "i": 5942306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 173 de 27 de marzo de 1996, se ha aprobado, al Colegio &quot;San Lorenzo&quot; de Copiap&#xF3;, un plan especial de estudio para los cursos de 1&#xB0; a 8&#xB0; a&#xF1;o de Educaci&#xF3;n B&#xE1;sica y de 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, para ser aplicado a partir del a&#xF1;o lectivo 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Teconolog&#xED;a Computacional en 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica. </div></div>", "i": 5942307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 09 de Abril de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5942308}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "173", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-173"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 173 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO SAN LORENZO", "COPIAPO", "PROGRAMAS ESTUDIO", "TERCERA REGION", "PLANES ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-03-27", "doble_articulado": false, "id_norma": "20537", "numero_fuente": "35445", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-18", "vigencias": [{"desde": "1996-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vige