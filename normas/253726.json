{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6584520}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 642 de fecha 31 de julio de 2006, se expropi&#xF3; el lote de terreno N&#xBA; 23, superficie 3.450 m2., rol N&#xBA; 3281-169, comuna de Temuco, IX Regi&#xF3;n para la obra &quot;Ampliaci&#xF3;n Reposici&#xF3;n, Pavimentaci&#xF3;n Ruta 5 Sur, Sector Acceso Norte a Temuco, Km. 0,50000 al Km.</div><div class=\"p\">8,66000, comunas de Vilc&#xFA;n y Temuco, provincia de Caut&#xED;n, IX Regi&#xF3;n&quot; y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Ren&#xE9; Echavarri Oti&#xF1;ano, ascendente a la cantidad de $66.459.400.</div><br></div>", "i": 6584521}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6584522}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "642", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-642"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-31", "doble_articulado": false, "id_norma": "253726", "numero_fuente": "38578", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-10-02", "vigencias": [{"desde": "2006-10-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-10-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-10-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-10-02", "fecha_version