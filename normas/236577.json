{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6520073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0; 109, de 29 de febrero de 1996, se expropiaron los lotes de terreno N&#xB0;s. 23, 119, 121, 122 y 123, superficies 1.290, 615, 16, 618, 731 y 205 m2, respectivamente, roles de aval&#xFA;o N&#xB0;s.1093-01 y 164-1, comunas de Cartagena y Casablanca, para la obra Camino Malvilla - Orrego Abajo, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios, Jos&#xE9; Agust&#xED;n Vel&#xE1;sques Alvarez y Jos&#xE9; Ebel Vial, ascendente a las cantidades de $1.796.742.- para el lote 23 y $6.040.217. - para los lotes N&#xB0;s. 119, 121, 122 y 123.</div><br></div>", "i": 6520074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6520075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "109", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-109"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-29", "doble_articulado": false, "id_norma": "236577", "numero_fuente": "35432", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-01", "vigencias": [{"desde": "1996-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-03-24", "fecha