{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO&nbsp; N&#xBA; 52&nbsp; EXENTO,&nbsp; DE 1999</div><br></div>", "i": 6160933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 52, de 3 de marzo de 1999, se ha autorizado a los establecimientos educacionales &apos;&apos;Pumahue-Huechuraba&apos;&apos; y &apos;&apos;Pumahue-Pe&#xF1;alol&#xE9;n&apos;&apos; de Santiago y &apos;&apos;Colegio Maitenes&apos;&apos; de Melipilla, para suprimir la asignatura de Idioma Extranjero 2, Franc&#xE9;s, en los cursos de 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, a partir del a&#xF1;o escolar 1999. </div></div>", "i": 6160934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6160935}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "52 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-52 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 52 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-03", "doble_articulado": false, "id_norma": "134008", "numero_fuente": "36322", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-24", "vigencias": [{"desde": "1999-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-03-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in