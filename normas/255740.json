{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6591460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;668 de fecha 29 de septiembre del 2006, se expropiaron los lotes de terreno N&#xBA;s. 4 y 5, superficies 957,8 y 243 m&#xB2;, Rol N&#xBA;153-127, comuna de Chonchi, Regi&#xF3;n para la obra &quot;Reposici&#xF3;n Puente Milildeo, Camino Huillinco-Cucao, W-850&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Margarita Luz Altamirano M&#xE1;rquez, ascendente a la cantidad de $1.538.458.- para los lotes N&#xBA;s. 4 y 5. </div></div>", "i": 6591461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6591462}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "668 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-668 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-09-29", "doble_articulado": false, "id_norma": "255740", "numero_fuente": "38628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-01", "vigencias": [{"desde": "2006-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-12-01", "fecha_version": "2006-12-01", "fecha_actualizacion_texto": "2006-12-01", "tipo_tratado": ""}, "al