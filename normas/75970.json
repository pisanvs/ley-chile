{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7210930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 736, de 31 de julio de 1997, se expropiaron los lotes de terreno N&#xBA;s 2-B y 2-F, superficies 180 y 192 M2 respectivamente, roles de aval&#xFA;o 160-106 y 160-109 comuna de Pemuco, para la obra Proyecto Laja Diguill&#xED;n, Area de Riego Pemuco Canal San Miguel Pal Pal Bajo Ramal N&#xBA; 4-B y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Ferm&#xED;n Salazar Pavez y Manuel Arcadio Mardones Mardones y otra, ascendentes a las cantidades de $99.014 y $200.306 respectivamente.- </div></div>", "i": 7210931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal de Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7210932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "736", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-736"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "PEMUCO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-31", "doble_articulado": false, "id_norma": "75970", "numero_fuente": "35867", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-09-15", "vigencias": [{"desde": "1997-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingres