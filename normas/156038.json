{"html": [{"t": "<div><div class=\"p\">RECTIFICA DECRETO N&#xBA; 48, DE 2000</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 56.- Santiago, 9 de febrero de 2000.- Visto: El decreto N&#xBA; 48 de 19 de enero de 2000 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes,</div><br><div class=\"p\">&nbsp; &nbsp;  D e c r e t o:</div><br></div>", "i": 6234182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rectif&#xED;case el art&#xED;culo 2&#xBA; del decreto N&#xBA; 48 de 2000 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, en el sentido de sustituir la referencia que se hace a la Norma Chilena Oficial &apos;&apos;NCh21139.Of89&apos;&apos; por &apos;&apos;NCh2139.Of89&apos;&apos;.</div><br></div>", "i": 6234183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Por orden del Presidente de la Rep&#xFA;blica, Jos&#xE9; Andr&#xE9;s Wallis Garc&#xE9;s, Ministro de Transportes y Telecomunicaciones Subrogante.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda a Ud., Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 6234184}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "56", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-56"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "RECTIFICA DECRETO Nº 48, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-09", "doble_articulado": false, "id_norma": "156038", "numero_fuente": "36588", "tipo_version": "3", "tipo_version_s": "Única"