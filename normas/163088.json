{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6257366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 604, de 23 de marzo de 2000, de</div><div class=\"p\">esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SAN JOSE S.A.</div><div class=\"p\">para ampliar actividades pesqueras extractivas con la</div><div class=\"p\">nave &apos;&apos;Antares&apos;&apos;, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar con trampa los siguientes recursos hidrobiol&#xF3;gicos, en el litoral de la I a la X Regiones: Centolla del norte Lithodes wiracocha, Centolla del norte, Lithodes panamencis, Centoll&#xF3;n Paralomis papillata, Centoll&#xF3;n del norte Paralomis longipes, Centolla Neolithodes diomedae, Camar&#xF3;n de profundidad Pandalopsis sp.</div><br></div>", "i": 6257367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de marzo de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6257368}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "604", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-604"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-03-23", "fecha_derogacion": "2000-07-19", "doble_articulado": false, "id_norma": "163088", "numero_fuente": "36627", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-03-30", "vigencias": [{"desde": "2000-07-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"des