{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6394816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP exento N&#xBA; 1.094, de 31 de julio de 2001, se orden&#xF3; la expropiaci&#xF3;n y aprob&#xF3; Plano y Cuadro de expropiaci&#xF3;n del lote de terreno N&#xBA; 12, y por decreto MOP exento N&#xBA; 1.164, de 31 de julio de 2002, se autoriz&#xF3; el valor de la consignaci&#xF3;n provisional de la expropiaci&#xF3;n v&#xED;a judicial, en la cantidad de $197.000.-, necesario para la ejecuci&#xF3;n de la obra: Camino Ruta L-75 sector: El Ajial - Las Camelias Tramo Km. 6,320.00 a Km.</div><div class=\"p\">23,400.00, el pago de la indemnizaci&#xF3;n se efectuar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br><br></div>", "i": 6394817}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6394818}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1094 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1094 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-31", "doble_articulado": false, "id_norma": "202156", "numero_fuente": "37349", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-09-02", "vigencias": [{"desde": "2002-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc