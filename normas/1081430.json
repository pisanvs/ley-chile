{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.518, DE 2015</div></div>", "i": 9635147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA;3.518 de 24 de agosto de 2015, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Profesionales Mega Chile Limitada&quot; (Mega Chile Ltda.), RUT 77.969.810-6 contenida en la resoluci&#xF3;n exenta N&#xBA; 3.644 de fecha 02 de noviembre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.</div></div>", "i": 9635148}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de agosto de 2015.- Vicente Rampoldi Di Castri (S) Jefe del Departamento de Desarrollo y Regulaci&#xF3;n de Mercado, Servicio de Capacitaci&#xF3;n y Empleo.</div></div>", "i": 9635149}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3518 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3518 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SERVICIO NACIONAL DE CAPACITACIÓN DE EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.518, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 943375", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-08-24", "doble_articulado": false, "id_norma": "1081430", "numero_fuente": "41255", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-09-10", "vigencias": [{"desde": "2015-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Únic