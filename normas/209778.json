{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 4,653</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 7299415}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Der&#xF3;gase el art&#xED;culo 86 del decreto-ley N.o 342, org&#xE1;nico de Ferrocarriles, de fecha 13 de Marzo de 1925.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley empezar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7299416, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago,&nbsp; a 16 de Septiembre&nbsp; de&nbsp; mil novecientos veintinueve.- Carlos Ib&#xE1;&#xF1;ez del C.-&nbsp; Emiliano Bustos.</div><br></div>", "i": 7299417}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4653", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4653"}], "organismos": ["MINISTERIO DE FOMENTO", "SUBSECRETARÍA DE FOMENTO"], "titulo_norma": "LEY NUM. 4653", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-09-16", "doble_articulado": false, "id_norma": "209778", "numero_fuente": "15481", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-09-25", "vigencias": [{"desde": "1929-09-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-09-25", "fin_vigencia": ""}, "vigencias_version_norma": [