{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 485 EXENTO, DE 1998</div><br><br></div>", "i": 6109700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 485 de fecha 1&#xBA; de abril de 1998 del Ministerio de Educaci&#xF3;n, se aprobaron las adecuaciones al plan y programas de estudios de la carrera de Dise&#xF1;o de Vestuario del Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Ense&#xF1;anza de Alta Costura Paulina Diard, modific&#xE1;ndose en consecuencia, la resoluci&#xF3;n exenta del Ministerio de Educaci&#xF3;n N&#xBA; 2.223 del 29 de septiembre de 1982. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1998. </div></div>", "i": 6109701}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de abril de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6109702}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "485 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-485 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 485 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "CENTRO DE FORMACION TECNICA CENTRO DE ENSE ANZA DE ALTA COSTURA PAULINA DIARD", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-04-01", "fecha_derogacion": "2022-12-31", "doble_articulado": false, "id_norma": "98629", "numero_fuente": "36055", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-05-04", "vigencias": [{"desde": "2022-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-05-04", "hasta"