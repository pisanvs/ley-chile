{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0;. 136, DE 1990 </div></div>", "i": 6064857}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 136 de 18 de abril de 1990, se ha aprobado, a contar del a&#xF1;o escolar 1990, a la Escuela F No. 60 de Desarrollo Art&#xED;stico de Antofagasta, un plan especial de estudio para el 1er. y 2&#xB0; ciclo de Educaci&#xF3;n General B&#xE1;sica, el que se aplicar&#xE1; en todos los cursos simult&#xE1;neamente.</div><div class=\"p\">Adem&#xE1;s, se aprueban programa de estudio para las asignaturas que se se&#xF1;alan y cursos que se indican del Plan Complementario y del Plan Optativo.</div><br></div>", "i": 6064858}, {"t": "<div><div class=\"p\">Santiago, 27 de Abril de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6064859}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "136 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-136 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°. 136, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-04-18", "doble_articulado": false, "id_norma": "83270", "numero_fuente": "33662", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-05-05", "vigencias": [{"desde": "1990-05-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-05-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-05-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_