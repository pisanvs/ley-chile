{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,637.- Santiago, 16 de enero de 1904.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6166016}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por el paisano don Clemente Olivares, que gui&#xF3; al Ej&#xE9;rcito chileno al interior del Per&#xFA;, se eleva a sesenta pesos mensuales la pension de que actualmente disfruta.</div><br></div>", "i": 6166017}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- An&#xED;bal Cruz D.</div><br></div>", "i": 6166018}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1637", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1637"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-01-16", "doble_articulado": false, "id_norma": "135619", "numero_fuente": "7806", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-01-18", "vigencias": [{"desde": "1904-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-01-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1904-01-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-04-28", "fecha_version": "1904-01-18", "fe