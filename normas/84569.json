{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6068173}, {"t": "<div><div class=\"p\">El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 5,61% anual durante el mes de septiembre de 1992.</div><div class=\"p\">Asimismo, en conformidad con lo dispuesto en el No.5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de septiembre de 1992, fue de 5,61% anual.</div><br></div>", "i": 6068174}, {"t": "<div><div class=\"p\">Santiago, 5 de octubre de 1992.- V&#xED;ctor Vial del R&#xED;o, Fiscal.</div><br></div>", "i": 6068175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-05", "doble_articulado": false, "id_norma": "84569", "numero_fuente": "34383", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-10-06", "vigencias": [{"desde": "1992-10-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-10-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-10-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1998-01-13", "fecha_version": "1992-10-06", "fe