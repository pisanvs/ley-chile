{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7262033}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 215, de 31 de enero de 2000, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 1.176 de 1994, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA BIO BIO S.A., para operar la nave &apos;&apos;Oceanic II&apos;&apos;, en el sentido de reemplazar en el inciso 2&#xBA; de su numeral 2&#xBA; la oraci&#xF3;n: &apos;&apos;y la fauna acompa&#xF1;ante que se detalla a continuaci&#xF3;n&apos;&apos; por lo siguiente: &apos;&apos;Asimismo, la peticionaria podr&#xE1; capturar con cerco, en la misma &#xE1;rea de pesca, por fuera del &#xE1;rea de reserva artesanal, los siguientes recursos hidrobiol&#xF3;gicos&apos;&apos;.</div><br></div>", "i": 7262034}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de enero de 2000.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 7262035}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "215", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-215"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-01-31", "fecha_derogacion": "2004-12-07", "doble_articulado": false, "id_norma": "156727", "numero_fuente": "36592", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-02-18", "vigencias": [{"desde": "2004-12-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-02-18", "hasta": "2004-12-06", "tip