{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6070612}, {"t": "<div><div class=\"p\">Por Decreto M.O.P. No. 264, de fecha 24 de septiembre de 1992, se expropiaron los lotes de terreno No. s. 1 y 4, superficies 93 M2. y 4.124 M2., respectivamente, roles de aval&#xFA;os 328-143 y 328-141, Comuna de Villarrica, para la obra Camino Villarrica-Co&#xF1;aripe, sector Villarrica-Licanray, Acceso y Variante Puente Chesque y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Indalicio Javier Nu&#xF1;ez Reyes y Jos&#xE9; Antonio Huilipan Lagos, ascendente a las cantidades de $ 384.758 y $ 579.360.</div><br></div>", "i": 6070613}, {"t": "<div><div class=\"p\">- Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6070614}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "264", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-264"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-24", "doble_articulado": false, "id_norma": "85538", "numero_fuente": "34405", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-02", "vigencias": [{"desde": "1992-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-01-19", "fecha_version": "1992-11-02", "fecha_actualizacion_texto": "1992-11-02", "tipo_tratad