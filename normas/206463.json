{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6409149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 3.045, de 31 de diciembre de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a la EMPRESA DE DESARROLLO PESQUERO DE CHILE S.A., para realizar operaciones pesqueras a contar del 1 de enero y hasta el 31 de diciembre del a&#xF1;o 2003, ambas fechas inclusive, con los barcos f&#xE1;brica denominados &quot;Unzen&quot; y &quot;Unionsur&quot;, en aguas exteriores, por fuera de las l&#xED;neas de base recta, al sur del paralelo 44&#xB0;30&apos; L.S., respecto de las &#xE1;reas y recursos y con las obligaciones establecidas en sus respectivas autorizaciones.</div><br></div>", "i": 6409150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6409151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3045", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3045"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-31", "doble_articulado": false, "id_norma": "206463", "numero_fuente": "37452", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-01-07", "vigencias": [{"desde": "2003-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-01-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe