{"html": [{"t": "<div><div class=\"p\">PARTIDO REGIONALISTA DE LOS INDEPENDIENTES</div><br><br></div>", "i": 7370559}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Carlos Moraga Duque y Ricardo Fern&#xE1;ndez Sanhueza, Presidente y Secretario General del Partido Regionalista de los Independientes, respectivamente, han solicitado la constituci&#xF3;n legal del partido en las Regiones VII del Maule y XII de Magallanes y la Ant&#xE1;rtica Chilena, acompa&#xF1;ando 3.627 y 436 fichas de afiliaciones, respectivamente.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 734 de fecha 15 de mayo de 2008. </div></div>", "i": 7370560}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 7370561}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "734", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-734"}, {"tipo": "3", "numero": "O-734", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-734"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO REGIONALISTA DE LOS INDEPENDIENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO REGIONALISTA DE LOS INDEPENDIENTES", "SEPTIMA REGION", "DECIMOSEGUNDA REGION", "CONSTITUCION LEGAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-05-15", "doble_articulado": false, "id_norma": "271418", "numero_fuente": "39069", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-24", "vigencias": [{"desde": "2008-05-24", "hasta": "", "tipo_version": "3", "t