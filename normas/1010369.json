{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 9.692 EXENTA, DE 2009</div></div>", "i": 8847456}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por la presente se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=195650&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA;1.219, de 2002</a>, modificada por la resoluci&#xF3;n exenta N&#xBA;15.255, de 2004, ambas del Ministerio de Educaci&#xF3;n, que aprobaron planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de educaci&#xF3;n media, al Instituto O&#x2019;Higgins (Hermanos Maristas), de Rancagua.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio del sector de cultura religiosa para 1&#xBA; a 4&#xBA; a&#xF1;o de educaci&#xF3;n media.</div><br></div>", "i": 8847457}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de diciembre de 2009.- Jaime Veas S&#xE1;nchez, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 8847458}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1219 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1219 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 9.692 EXENTA, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-29", "doble_articulado": false, "id_norma": "1010369", "numero_fuente": "39566", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-01-21", "vigencias": [{"desde": "2010-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-01-21", "fin_vig