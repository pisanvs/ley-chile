{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6091790}, {"t": "<div><br><div class=\"p\">El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 8,84% anual durante el mes de diciembre de 1989. Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de diciembre de 1989, fue de 9,28% anual.</div><br></div>", "i": 6091791}, {"t": "<div><div class=\"p\">Santiago, 04 de enero de 1990.- Mar&#xED;a Eliana Torres Contreras, Secretario General Subrogante.</div><br></div>", "i": 6091792}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-04", "doble_articulado": false, "id_norma": "92539", "numero_fuente": "33562", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-05", "vigencias": [{"desde": "1990-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-01-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-02-27", "fecha