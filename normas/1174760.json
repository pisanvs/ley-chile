{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10327373}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta DN N&#xBA; 653, de 30 de marzo de 2022, se modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1094904&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta n&#xFA;mero 7.269, de 2016</a>, del Servicio Nacional de Pesca y Acuicultura que fija per&#xED;odo de descanso sanitario para las concesiones de acuicultura ubicadas en el r&#xED;o Valdivia.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n, se publicar&#xE1; en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10327374}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, a 30 de marzo de 2022.- Claudio B&#xE1;ez Beltr&#xE1;n, Director Nacional del Servicio Nacional de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10327375}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "653 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-653 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2114232", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-03-30", "doble_articulado": false, "id_norma": "1174760", "numero_fuente": "43230", "tipo_version": "3", "tipo_version_s": "Única", "fecha_public