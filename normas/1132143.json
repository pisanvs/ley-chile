{"html": [{"t": "<div><div class=\"p\">MODIFICA EL ARTICULO 19.o DEL DECRETO CON FUERZA DE LEY 343, DE AGOSTO DEL PRESENTE A&#xD1;O</div><br><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div></div>", "i": 10028224}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Substit&#xFA;yese en el art&#xED;culo 19.o del decreto con fuerza de ley N.o 343, de 5 de Agosto de 1953, la palabra &quot;transporte&quot; por la palabra &quot;cabotaje&quot;.</div></div>", "i": 10028225}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto he tenido a bien aprobarlo y sancionarlo: por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinte de Octubre de mil novecientos cincuenta y tres.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Guillermo del Pedregal.</div></div>", "i": 10028226}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11345", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-11345"}], "organismos": ["MINISTERIO DE ECONOMÍA Y COMERCIO"], "titulo_norma": "MODIFICA EL ARTICULO 19.o DEL DECRETO CON FUERZA DE LEY 343, DE AGOSTO DEL PRESENTE AÑO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1953-10-20", "doble_articulado": false, "id_norma": "1132143", "numero_fuente": "22694", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1953-11-10", "vigencias": [{"desde": "1953-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1953-11-10", "fin_vigenci