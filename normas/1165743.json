{"html": [{"t": "<div><div class=\"p\">&#xFEFF;PRECIO DE METALES.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 23 de 1832.</div><br><div class=\"p\">&nbsp; &nbsp;  EL PRESIDENTE DE LA REP&#xDA;BLICA DE CHILE, &amp;c.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso nacional ha dictado la siguiente lei:</div></div>", "i": 10273498}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. &#xFA;nico. La casa de Moneda pagar&#xE1; a los introductores de plata y oro a razon de 8 pesos 17 maravedises el marco de plata en lei de 11 dineros, y el oro de 22 quilates y 136 pesos el marco.</div></div>", "i": 10273499}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por tanto, ordeno y mando se publique por lei, rejistr&#xE1;ndose en las oficinas que corresponda.</div><br><br><div class=\"p\">&nbsp; &nbsp;  JOAQUIN PRIETO.</div><br><div class=\"p\">&nbsp; &nbsp;  Manuel Rengifo. </div></div>", "i": 10273500}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "33", "numero": "S/N", "abreviacion": "LEI", "descripcion": "Lei", "compuesto": "Lei-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "PRECIO DE METALES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-08-23", "doble_articulado": false, "id_norma": "1165743", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-08-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-08-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "