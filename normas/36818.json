{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;PARTIDO SOCIALISTA DE CHILE&quot; </div></div>", "i": 6016289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Camilo Escalona Medina e Isabel Allende Bussi, Presidente y Secretario General, respectivamente, en representaci&#xF3;n del &quot;Partido Socialista de Chile&quot;, han solicitado la constituci&#xF3;n legal del Partido en la V Regi&#xF3;n de Valpara&#xED;so, acompa&#xF1;ando 4.369 fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la Ley N&#xB0; 18.603, por Resoluci&#xF3;n O-N&#xB0; 1372 de fecha 10 de mayo de 1996. </div></div>", "i": 6016290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 10 de mayo de 1996.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6016291}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1372", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1372"}, {"tipo": "3", "numero": "O-1372", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-1372"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO SOCIALISTA DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDO SOCIALISTA CHILE", "PARTIDOS POLITICOS", "CONSTITUCION LEGAL", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-10", "doble_articulado": false, "id_norma": "36818", "numero_fuente": "35469", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-17", "vigencias": [{"desde": "1996-05-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-05-17", "fin_vi