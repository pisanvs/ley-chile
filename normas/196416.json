{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6375616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA;18, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de fecha 15 de febrero de 2002, se aprob&#xF3; la disoluci&#xF3;n de la Cooperativa de Vivienda y Servicios Habitacionales Jardines de Bah&#xED;a Limitada, que consta en la escritura p&#xFA;blica suscrita con fecha 19 de octubre de 2001, ante al Notario P&#xFA;blico de Valpara&#xED;so, do&#xF1;a Sonia Ravanal Toro.</div><br></div>", "i": 6375617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6375618}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-18"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-15", "doble_articulado": false, "id_norma": "196416", "numero_fuente": "37227", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-04-05", "vigencias": [{"desde": "2002-04-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-04-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-04-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingres