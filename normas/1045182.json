{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xB0; 669 EXENTO, DE 2012</div></div>", "i": 9309825}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.048, de 26 de octubre de 2012, de este Ministerio, modif&#xED;case el art&#xED;culo 2&#xB0; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1041592&amp;idParte=&amp;idVersion=\">decreto exento N&#xBA; 669, de 2012, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, en el sentido de eliminar su inciso 2&#xB0; incorporado por el decreto exento N&#xBA; 1.031, de 2012.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y del Servicio Nacional de Pesca.</div></div>", "i": 9309826}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de octubre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9309827}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1048 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1048 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO N° 669 EXENTO, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-26", "doble_articulado": false, "id_norma": "1045182", "numero_fuente": "40399", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-31", "vigencias": [{"desde": "2012-10-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "201