{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,227.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6162790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados por el jefe de la estaci&#xF3;n del Mercado de Santiago, don Amador Ram&#xED;rez, se le concede, por gracia, derecho de jubilar con arreglo a la lei de 20 de agosto de 1857, tomando por base el setenta i cinco por ciento del sueldo de que disfruta.</div><br></div>", "i": 6162791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prum&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, a 6 de julio de 1899.- FEDERICO ERRAZURIZ.-</div><div class=\"p\">D. Rioseco.</div><br></div>", "i": 6162792}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1227", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1227"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-07-06", "doble_articulado": false, "id_norma": "134567", "numero_fuente": "6345", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-07-11", "vigencias": [{"desde": "1899-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-07-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1899-07-11", "fin_vigencia": "", "tip