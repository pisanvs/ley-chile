{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9486870}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.728, de 2 de julio de 2014, de esta Subsecretar&#xED;a, modif&#xED;case <a href=\"https://www.leychile.cl/Navegar?idNorma=1061562&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.064 de 2014</a>, de esta Subsecretar&#xED;a, que estableci&#xF3; agrupaciones de concesiones de acuicultura de salm&#xF3;nidos en X, XI y XII Regi&#xF3;n, reemplazando ACS 49 y 50, por ACS 49 A, 49 B, 50 A y 50 B, en la forma indicada en la resoluci&#xF3;n extractada y publicada &#xED;ntegramente en www.subpesca.cl y www.sernapesca.cl.</div></div>", "i": 9486871}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de julio de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9486872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1728 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1728 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2014-07-02", "fecha_derogacion": "2014-08-12", "doble_articulado": false, "id_norma": "1064221", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2014-07-10", "vigencias": [{"desde": "2014-08-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2014-07-10", "hasta": "2014-08-11", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-08-12", "fin_vigenci