{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 914 de 30 de junio de 1998 de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 350 de 1984, y de la resoluci&#xF3;n N&#xBA; 1.372, de 1992, ambas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA IQUIQUE GUANAYE S.A., para desarrollar actividades pesqueras extractivas con la nave &apos;&apos;Halc&#xF3;n&apos;&apos;, en el litoral de las regiones III y IV, respectivamente, en lo relativo a las especies: Anchoveta, Caballa, Jurel, Machuelo o tritre, Roncacho, Sardina espa&#xF1;ola y Sardina com&#xFA;n. </div></div>", "i": 8331602}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331603}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "914", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-914"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA IQUIQUE GUANAYE S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-06-30", "fecha_derogacion": "2000-02-01", "doble_articulado": false, "id_norma": "120898", "numero_fuente": "36108", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-07-08", "vigencias": [{"desde": "2000-02-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "199