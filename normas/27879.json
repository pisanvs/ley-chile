{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REEMPLAZA EL ARTICULO 516&#xB0; DEL CODIGO DEL TRABAJO.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5974639}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase el art&#xED;culo 516&#xB0; del C&#xF3;digo del Trabajo por el siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 516&#xB0; El Juzgado de La Serena tendr&#xE1; jurisdicci&#xF3;n en el departamento de Coquimbo; el de Concepci&#xF3;n en el de Talcahuano; el de Osorno, en el de R&#xED;o Negro, y el de Puerto Montt, en el de Puerto Varas&quot;. </div></div>", "i": 5974640}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintis&#xE9;is de octubre de mil novecientos sesenta y uno.-</div><div class=\"p\">&nbsp; &nbsp; JORGE ALESSANDRI RODRIGUEZ.- Enrique Ort&#xFA;zar. </div></div>", "i": 5974641}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14692", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14692"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "REEMPLAZA EL ARTICULO 516° DEL CODIGO DEL TRABAJO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TERRITORIO JURISDICCIONAL", "COMPETENCIA", "JUZGADO SERENA", "JUZGADO CONCEPCION", "JUZGADO OSORNO", "JUZGADO PUERTO MONTT", "MODIFICACION", "CODIGO TRABAJO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1961-10-26", "doble_articulado": fa