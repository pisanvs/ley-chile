{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede derecho a jubilar a don Horacio Pinto Ag&#xFC;ero.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,728.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al Ministro de la Corte de Apelaciones de Santiago, don Horacio Pinto Ag&#xFC;ero, derecho de jubilar con el sueldo integro asignado a su empleo.</div><br></div>", "i": 5953988}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 2 de Enero de 1913.- RAMON BARROS LUCO.-</div><div class=\"p\">E. Villegas E.</div><br></div>", "i": 5953989}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2728", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2728"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE DERECHO A JUBILAR A DON HORACIO PINTO AGÜERO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["HORACIO PINTO AGUERO", "JUBILACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-01-02", "doble_articulado": false, "id_norma": "23455", "numero_fuente": "10471", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-01-08", "vigencias": [{"desde": "1913-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-01-08", "fin_vigenci