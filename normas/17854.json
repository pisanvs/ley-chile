{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; REASUME MANDO DEL ESTADO Santiago, 23 de Noviembre de 1992.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 1.451.- Visto: Lo dispuesto en los art&#xED;culos 29&#xB0; y 32&#xB0;, N&#xB0; 8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile,</div><div class=\"p\">&nbsp; &nbsp; Decreto:</div><br></div>", "i": 8267595}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Con ocasi&#xF3;n de mi regreso al pa&#xED;s, a contar de esta fecha, reasumo el mando del Estado.</div><br></div>", "i": 8267596}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Enrique Krauss Rusque, Ministro del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud., para su conocimiento.- Saluda a Ud.- Belisario Velasco Baraona, Subsecretario del Interior.</div><br></div>", "i": 8267597}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1451", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1451"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MANDO NACION", "PRESIDENTE REPUBLICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-11-23", "doble_articulado": false, "id_norma": "17854", "numero_fuente": "34434", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-12-05", "vigencias": [{"desde": "1992-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-12-05", "fin_vigencia": ""}, "vigencias_version_no