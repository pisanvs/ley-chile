{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 810 EXENTO, DE 2000 </div></div>", "i": 6389815}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 810 de fecha 22 de octubre de 2000 se declaran aprobadas al Instituto Profesional de las Comunicaciones Procom las modificaciones al plan y a los programas de estudio de la carrera de Direcci&#xF3;n y Producci&#xF3;n de Televisi&#xF3;n que se imparte en jornada diurna. Dichas modificaciones tendr&#xE1;n vigencia a contar del primer semestre del a&#xF1;o 2002.</div><br></div>", "i": 6389816}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6389817}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "810 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-810 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 810 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-22", "doble_articulado": false, "id_norma": "200721", "numero_fuente": "37316", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-24", "vigencias": [{"desde": "2002-07-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-07-24", "fecha_version": "2002-07-24", "fecha_actualizacion_texto": "2002-07-24", "tipo_tratado": ""},