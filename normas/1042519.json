{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9286498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (Exento) N&#xBA;1323 de 19 de julio de 2012, se dej&#xF3; sin efecto la expropiaci&#xF3;n del lote de terreno N&#xB0;1, ordenado mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=1026498&amp;idParte=0&amp;idVersion=\">Decreto MOP. (Exento) N&#xB0;875 de 24 de mayo de 2011</a>, para la obra &quot;Dise&#xF1;o de Alcantarillado y Factibilidad de Planta Tratamiento Aguas Servidas para el saneamiento de la localidad de Coya&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xB0; del Decreto Ley N&#xBA;2186, de 1978. </div><br></div>", "i": 9286499, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9286500}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1323 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1323 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-19", "doble_articulado": false, "id_norma": "1042519", "numero_fuente": "40326", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-01", "vigencias": [{"desde": "2012-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text":