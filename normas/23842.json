{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,255, que concede derecho a jubilar a don C&#xE1;rlos Sudy</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,255.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al Pro-Secretario de Comisiones de la C&#xE1;mara de Senadores, don C&#xE1;rlos Sudy, el derecho de jubilar con una pension equivalente al sueldo &#xED;ntegro del empleo que actualmente desempe&#xF1;a.</div><br></div>", "i": 8276125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiocho de Agosto de mil novecientos diecisiete.- JUAN LUIS SANFUENTES.- Ismael Tocornal. </div></div>", "i": 8276126}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3255", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3255"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,255, QUE CONCEDE DERECHO A JUBILAR A DON CARLOS SUDY", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CARLOS SUDY", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-08-28", "doble_articulado": false, "id_norma": "23842", "numero_fuente": "11868", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-09-08", "vigencias": [{"desde": "1917-09-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"