{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,548.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 7249435}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se aumenta a seis mil pesos la pension anual concedida por lei de 3 de febrero de 1910 a do&#xF1;a Emilia Goycolea, viuda del teniente de la Armada don Ignacio Serrano M.</div><br></div>", "i": 7249436, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, treinta de agosto de mil novecientos once.- Ramon Barros Luco.- Alejandro Huneeus G. H. </div></div>", "i": 7249437}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2548", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2548"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-08-30", "doble_articulado": false, "id_norma": "137480", "numero_fuente": "10074", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-09-05", "vigencias": [{"desde": "1911-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-09-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "mo