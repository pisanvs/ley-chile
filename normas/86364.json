{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8317933}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 8, de&nbsp; 6 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la autorizaci&#xF3;n solicitada por PESCA CHILE S.A., para ampliar sus actividades pesqueras, con las naves &quot;Boston Blenheim&quot; matr&#xED;cula 2247, &quot;Boston Beverly&quot; matr&#xED;cula 2246 y &quot;Cote Saint Jacques&quot; matr&#xED;cula 2787, en la captura del recurso hidrobiol&#xF3;gico Orange roughy, por encontrarse su acceso transitoriamente cerrado, en virtud de lo dispuesto en el Art&#xED;culo 1&#xBA; del D.S. N&#xBA; 500 de 1997, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8317934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8317935}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESCA CHILE S.A.", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-06", "doble_articulado": false, "id_norma": "86364", "numero_fuente": "35963", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-13", "vigencias": [{"desde": "1998-01-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-1