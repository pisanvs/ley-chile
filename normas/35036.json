{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 529 de 23 de Julio de 1993 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 10&#xB0; de la Resoluci&#xF3;n N&#xB0; 1408, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA SANTA BERNARDITA LTDA., R.U.T.</div><div class=\"p\">N&#xB0; 79.577.700-8, para realizar actividades pesqueras extractivas, en el sentido de se&#xF1;alar que se deja sin efecto la Resoluci&#xF3;n N&#xB0; 547, de 1988, ampliada y modificada por Resoluciones N&#xB0; 1517, de 1989, N&#xB0; 119 y N&#xB0; 1277, de 1992, todas de esta Subsecretar&#xED;a, en cuanto ella se refiere a la nave &quot;Colomba I&quot;.</div><br></div>", "i": 8292952, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 23 Julio 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8292953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "529", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-529"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA SANTA BERNARDITA LTDA.", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-23", "doble_articulado": false, "id_norma": "35036", "numero_fuente": "34634", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-08-06", "vigencias": [{"desde": "1993-08-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"