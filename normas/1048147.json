{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9328316}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 41, de 9 de enero de 2013, de esta Subsecretar&#xED;a, rectif&#xED;canse las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1040877&amp;idParte=0&amp;idVersion=\">N&#xBA; 1.491</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1044515&amp;idParte=&amp;idVersion=\">N&#xBA; 2.601</a>, ambas de 2012 y de esta Subsecretar&#xED;a, que estableci&#xF3; la n&#xF3;mina definitiva de armadores artesanales y sus embarcaciones, que participaron de las pescas de investigaci&#xF3;n a que se refiere el art&#xED;culo 3&#xBA; de la ley N&#xBA; 20.560, en el sentido de modificar sus numerales 2, 8 y 12, de conformidad a lo indicado en resoluci&#xF3;n extractada.</div></div>", "i": 9328317}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de enero de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9328318}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-41 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-01-09", "doble_articulado": false, "id_norma": "1048147", "numero_fuente": "40460", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-16", "vigencias": [{"desde": "2013-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio