{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6158085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 471 y 472, ambas del 24 de noviembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IV Regi&#xF3;n de Coquimbo, se autoriza a don Misael Tapia Campusano y a Herrera Ahumada Adriana Evangelina y otro para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6158086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 11 de abril de 1988.- Jorge Vargas Borcosky, Secretario Regional- Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo. </div></div>", "i": 6158087}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "472 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-472 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-24", "doble_articulado": false, "id_norma": "133120", "numero_fuente": "33050", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-20", "vigencias": [{"desde": "1988-04-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-04-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-04-20", "fin_vigencia