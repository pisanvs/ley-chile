{"html": [{"t": "<div><div class=\"p\">AUTORIZA A ORGANISMO P&#xDA;BLICO COMO RECEPTOR ELECTR&#xD3;NICO </div></div>", "i": 6651201}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 77 de 16 de junio de 2008, que autoriza a Organismo P&#xFA;blico como receptor electr&#xF3;nico Se autoriza como receptor de documentos tributarios electr&#xF3;nicos, a contar del mes de junio de 2008, al organismo p&#xFA;blico RUT 61.936.500-3.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el bolet&#xED;n del SII del mes de junio de 2008.</div><br></div>", "i": 6651202}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-77 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A ORGANISMO PÚBLICO COMO RECEPTOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-16", "doble_articulado": false, "id_norma": "272555", "numero_fuente": "39092", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-06-20", "vigencias": [{"desde": "2008-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-06-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-06-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "