{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; BIBLIOTECA DEL CONGRESO NACIONAL Lei n&#xFA;m. 311.- Santiago, a 15 de Noviembre de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273905}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase la inversion de seis mil pesos ($ 6,000) en cubrir gastos de la Biblioteca del Congreso Nacional.</div><br><br></div>", "i": 8273906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobalo i sancionarlo por tanto, ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Manuel Recab&#xE1;rren.</div><br></div>", "i": 8273907}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "311", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-311"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "BIBLIOTECA DEL CONGRESO NACIONAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BIBLIOTECA CONGRESO NACIONAL", "FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-11-15", "doble_articulado": false, "id_norma": "22162", "numero_fuente": "5260", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-11-15", "vigencias": [{"desde": "1895-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1895-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1895-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-25", "fecha_vers