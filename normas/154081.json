{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 258, DE 1986</div><br><br></div>", "i": 7260313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 628, de 20 de Agosto de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, pronunci&#xE1;ndose respecto solicitud de reconsideraci&#xF3;n presentada por Sociedad de Alimentos Marinos y Frigor&#xED;fico Sol y Mar Sociedad An&#xF3;nima, domiciliada en Avda. Bustamante No. 32, de Santiago, se modifica resoluci&#xF3;n No. 258, de 17 de Marzo de 1986, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la referida Sociedad para ampliar actividades pesqueras, en orden a reemplazar en el numeral 4&#xB0; la zona de operaci&#xF3;n de la embarcaci&#xF3;n &quot;Peter Scott&quot; al litoral de las regiones I, II y VIII.</div><br></div>", "i": 7260314}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de Agosto de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 7260315}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "628", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-628"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 258, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-08-20", "fecha_derogacion": "1990-12-26", "doble_articulado": false, "id_norma": "154081", "numero_fuente": "32559", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-08-28", "vigencias": [{"desde": "1990-12-26", "hasta": "", "tipo_version"