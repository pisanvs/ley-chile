{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD CORMORAN S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6225019}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 543 de 23 de Julio de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Sociedad CORMORAN S.A., domiciliada en Santiago para instalar y operar una planta elaboradora de recursos hidrobiol&#xF3;gicos en la l&#xED;nea de harina y aceite de pescado en Iquique, Recinto Zona Franca I Regi&#xF3;n, en la que podr&#xE1; utilizar como materia prima los siguientes recursos: anchoa, sardina espa&#xF1;ola, sardina com&#xFA;n y jurel.</div><br></div>", "i": 6225020}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Julio de 1986.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 6225021}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "543", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-543"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD CORMORAN S.A. PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-07-23", "fecha_derogacion": "1986-10-30", "doble_articulado": false, "id_norma": "153057", "numero_fuente": "32539", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-08-04", "vigencias": [{"desde": "1986-10-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-08-04", "hasta": "1986-10-29", "tipo_version": "0", "t