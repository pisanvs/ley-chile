{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 9102060}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.841 de 22 de diciembre del 2010, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1021437&amp;idParte=0&amp;idVersion=\">Resoluci&#xF3;n N&#xB0;1.144 exenta</a>, que MODIFICA RESOLUCI&#xD3;N N&#xB0; 1.099 EXENTA, QUE ESTABLECE &#xC1;REA REGULADA POR POLILLA DEL RACIMO DE LA VID (Lobesia botrana) EN LA COMUNA DE COPIAP&#xD3; DE LA REGI&#xD3;N DE ATACAMA, con el error que se salva a continuaci&#xF3;n: cuerpo I, p&#xE1;gina ocho, primera columna, donde dice &quot;... Servicio Agr&#xED;cola y Ganadero - Direcci&#xF3;n Regional II Regi&#xF3;n de Atacama - MODIFICA RESOLUCI&#xD3;N N&#xB0; 1.099 EXENTA, ...&quot; debe decir &quot;... Servicio Agr&#xED;cola y Ganadero - Direcci&#xF3;n Regional III Regi&#xF3;n de Atacama - MODIFICA RESOLUCI&#xD3;N N&#xB0; 1.099 EXENTA, ...&quot;.</div><br></div>", "i": 9102061, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "148", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-148"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRÍCOLA Y GANADERO III REGIÓN DE ATACAMA"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1022218", "numero_fuente": "39864", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-20", "vigencias": [{"desde": "2011-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-01-20", "fin_vigencia": "