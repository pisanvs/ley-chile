{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 823 EXENTO, DE 2002 </div></div>", "i": 6399283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 823 de fecha 6 de septiembre de 2002, de Educaci&#xF3;n, se revoca el reconocimiento oficial del Instituto Profesional Jos&#xE9; Santos Ossa, organizado por la Sociedad Educacional del Desierto Limitada y elim&#xED;nase a dicha entidad del Registro de Institutos Profesionales en que se encuentra inscrita con el N&#xBA; 36.</div><div class=\"p\">&nbsp; &nbsp;  Se deroga el decreto exento de Educaci&#xF3;n N&#xBA; 25 del 8 de marzo de 1989, que autoriz&#xF3; el funcionamiento al Instituto Profesional Jos&#xE9; Santos Ossa.</div><br></div>", "i": 6399284}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de octubre de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6399285}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "823 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-823 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 823 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-09-06", "doble_articulado": false, "id_norma": "203440", "numero_fuente": "37383", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-15", "vigencias": [{"desde": "2002-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-10-15", "fin_vigencia": "", "tipo_version": "3"}], 