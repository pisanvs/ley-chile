{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 197 EXENTO, DE 2002 </div></div>", "i": 7292843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 197 de fecha 14 de marzo de 2002 del Ministerio de Educaci&#xF3;n, se aprueba el plan y programas de estudios al Centro de Formaci&#xF3;n T&#xE9;cnica Diego Portales, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en las Sedes que se se&#xF1;alan, a contar del a&#xF1;o 2002:</div><br><div class=\"p\">Sede N&#xBA; 6 - Santiago, Sede N&#xBA; 2 - Vi&#xF1;a del Mar, Sede N&#xBA; 3 - Chill&#xE1;n y Sede N&#xBA; 5 - Concepci&#xF3;n</div><br><div class=\"p\">Carrera : Gastronom&#xED;a y Pasteler&#xED;a Internacional</div><div class=\"p\">T&#xED;tulo&nbsp; : T&#xE9;cnico de Nivel Superior en Gastronom&#xED;a</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  y Pasteler&#xED;a Internacional.</div><br></div>", "i": 7292844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de abril de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7292845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "197 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-197 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 197 EXENTO, DE 2002", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-03-14", "fecha_derogacion": "2015-06-25", "doble_articulado": false, "id_norma": "200596", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-07-18", "vigencias": [{"desde": "2015-06-25", "hasta": "", "tipo_version": "2",