{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,613.- Santiago, 22 de setiembre de 1903.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6165989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Ab&#xF3;nase, por gracia, al ministro de la Corte Suprema de Justicia don Gabriel Palma Guzman, para los efectos de su jubilacion, nueve a&#xF1;os diez meses durante los cuales desempe&#xF1;&#xF3; el cargo de defensor de obras p&#xED;as en Santiago.</div><br></div>", "i": 6165990}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JERMAN RIESCO.- Francisco J. Concha.</div><br></div>", "i": 6165991}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1613", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1613"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-09-22", "doble_articulado": false, "id_norma": "135610", "numero_fuente": "7714", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-09-29", "vigencias": [{"desde": "1903-09-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1903-09-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1903-09-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1999-04