{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302984}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 582 de 22 de abril de 1997 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a JUAN CARLOS MU&#xD1;OZ CHIA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Loteo Sector Punta Blanca de Tocopilla, Kil&#xF3;metro 8 de la ruta 1, Camino Costero, tramo Tocopilla-Antofagasta, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n de Secado natural y Molienda de algas, los siguientes recursos hidrobiol&#xF3;gicos: Chasc&#xF3;n y Huiro.</div><br></div>", "i": 8302985}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302986}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "582", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-582"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "JUAN CARLOS MU OZ CHIA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-22", "doble_articulado": false, "id_norma": "71289", "numero_fuente": "35765", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-14", "vigencias": [{"desde": "1997-05-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05