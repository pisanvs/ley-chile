{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplementos Lei n&#xFA;m. 52.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 9072105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dense los siguientes suplementos a los &#xED;tems de la partida 132 del Presupuesto de Instruccion P&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; Al &#xED;tem. 1.- Para construccion de edificios para establecimientos de instruccion secundaria, superior, especial i primaria i adquisicion de locales para los mismos, cien mil pesos.</div><div class=\"p\">&nbsp; &nbsp; Al &#xED;tem 2. Para conservacion i reparacion de edificios, diez mil pesos.</div><br><br></div>", "i": 9072106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 31 de Julio de 1893.-JORJE MONTT.- V. J. Rodr&#xED;guez Rozas </div></div>", "i": 9072107}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "52", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-52"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "SUPLEMENTOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1893", "MODIFICACION INSTRUCCION", "PUBLICA", "SUPLEMENTO", "ESTABLECIMIENTOS EDUCACIONALES", "CONSTRUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-07-31", "doble_articulado": false, "id_norma": "21925", "numero_fuente": "4587", "tipo_version"