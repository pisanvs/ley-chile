{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8311203}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No.907, de 12 de Agosto de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o desde la fecha de la presente Resoluci&#xF3;n, el plazo otorgado a CULTIVOS MARINOS CHILOE S.A., R.U.T. No.79.784.980-4, domiciliada en la ciudad de Santiago, para empezar a operar el establecimiento de cultivo autorizado por Resoluci&#xF3;n No. 920, de 1988, de esta Subsecretar&#xED;a, por haberse acreditado la ocurrencia de una fuerza mayor.</div><br><br></div>", "i": 8311204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de Agosto de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br><br></div>", "i": 8311205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "907", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-907"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-12", "doble_articulado": false, "id_norma": "80631", "numero_fuente": "34054", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-28", "vigencias": [{"desde": "1991-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-08-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACI