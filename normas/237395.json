{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6523389}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 767, de 23 de marzo de</div><div class=\"p\">2005, de esta Subsecretar&#xED;a, apru&#xE9;base el proyecto de</div><div class=\"p\">manejo y explotaci&#xF3;n de recursos bent&#xF3;nicos del &#xE1;rea de</div><div class=\"p\">manejo correspondiente al sector denominado Islas</div><div class=\"p\">Huichas, Sector N, XI Regi&#xF3;n, individualizada en el</div><div class=\"p\">art&#xED;culo 1&#xBA; N&#xBA; 12 del decreto exento N&#xBA; 637 de 2002, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, presentado por el SINDICATO TRABAJADORES INDEPENDIENTES DE PESCADORES ARTESANALES, BUZOS MARISCADORES Y ALGUEROS &quot;MARES DEL SUR&quot; DE ISLAS HUICHAS.</div><br></div>", "i": 6523390}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de marzo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6523391}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "767 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-767 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-03-23", "fecha_derogacion": "2010-11-10", "doble_articulado": false, "id_norma": "237395", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-04-27", "vigencias": [{"desde": "2010-11-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-04-27", "hasta": "2010-11-09", "tipo_versi