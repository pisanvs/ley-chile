{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8791627}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.381, de 13 de octubre de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD DE INVERSIONES CABOMA LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar planta ubicada en Guacolda S/N&#xBA;, Tir&#xFA;a, VIII Regi&#xF3;n, para elaborar en las l&#xED;neas de Cocido, Fresco enfriado, Congelado, Seco Salado, Salado H&#xFA;medo, Ahumado, Conserva, Alga seca, Deshidratado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div></div>", "i": 8791628}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de octubre de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8791629}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3381 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3381 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-13", "doble_articulado": false, "id_norma": "1007359", "numero_fuente": "39492", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-10-22", "vigencias": [{"desde": "2009-10-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-10-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-10-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi