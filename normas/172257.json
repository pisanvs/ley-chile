{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 174 EXENTO, DE 2000</div><br><br></div>", "i": 6286960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 174 de 26 de mayo de 2000, se ha aprobado al &apos;&apos;Antofagasta International School&apos;&apos;, de Antofagasta, un plan de estudio para los cursos de 6&#xBA;, 7&#xBA; y 8&#xBA; a&#xF1;o (NB.4, NB.5 y NB.6) de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; a contar del a&#xF1;o escolar 2000, seg&#xFA;n la gradualidad establecida en el decreto supremo de Educaci&#xF3;n N&#xBA; 40 de 1996 y sus modificaciones.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores de los se&#xF1;alados cursos.</div><br></div>", "i": 6286961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de junio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6286962}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "174 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-174 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 174 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-26", "doble_articulado": false, "id_norma": "172257", "numero_fuente": "36711", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-12", "vigencias": [{"desde": "2000-07-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci