{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 188, DE 1994 </div></div>", "i": 8969053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 188 de 25 de abril de 1994, se ha aprobado un plan especial de estudio para Ense&#xF1;anza B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica para el Colegio &quot;Hans Christian Andersen&quot; de San Fernando, VI Regi&#xF3;n, que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos de ense&#xF1;anza b&#xE1;sica y en 1&#xB0; y 2&#xB0; a&#xF1;o de ense&#xF1;anza media en el a&#xF1;o escolar 1994; en 3er. a&#xF1;o en el a&#xF1;o escolar 1995 y en 4&#xB0; a&#xF1;o en el a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueba programa especial de estudio para la asignatura de Computaci&#xF3;n.</div><br></div>", "i": 8969054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 20 de Mayo de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8969055}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "188", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-188"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 188, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO HANS CHRISTIAN ANDERSEN", "SAN FERNANDO", "SEXTA REGION", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-04-25", "doble_articulado": false, "id_norma": "20609", "numero_fuente": "34879-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-01", "vigencias": [{"desde": "1994-06-01", "hast