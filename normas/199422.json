{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6385714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;843, de 30 de abril del 2002, se expropi&#xF3; el lote de terreno N&#xBA;10-1, superficie 1.356 m2., rol de aval&#xFA;o 868-1, comuna de Villa Alemana, para la obra Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago Valpara&#xED;so Vi&#xF1;a del Mar. Troncal Sur. Enlace Pe&#xF1;ablanca Kms. 86.440,00 al 87.860,00, Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Inmobiliaria Pulmahue S.A., ascendente a la cantidad de $13.376.115.- para el lote N&#xBA;10-1.</div><br></div>", "i": 6385715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas&nbsp; . </div></div>", "i": 6385716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "843", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-843"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-30", "doble_articulado": false, "id_norma": "199422", "numero_fuente": "37284", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-15", "vigencias": [{"desde": "2002-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-06-18", "fecha_version": "2002-06-15", "fecha_actualiz