{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6496565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.513 de 6 de septiembre</div><div class=\"p\">de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA</div><div class=\"p\">ITATA S.A. para ampliar actividades pesqueras</div><div class=\"p\">extractivas con la nave &quot;Don Edmundo&quot;, en las &#xE1;reas que</div><div class=\"p\">en cada caso se indica, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones V, VI, VII, IX y X, con cerco: Jivia, Calamar y Pota del Atl&#xE1;ntico; b) En el &#xE1;rea mar&#xED;tima correspondiente a las Regiones V, VI, VII, IX y X, con arrastre de media agua, por fuera de las 60 millas n&#xE1;uticas contadas desde las l&#xED;neas de base recta o normales, seg&#xFA;n corresponda: Jibia, Calamar, y Pota del Atl&#xE1;ntico.</div><br></div>", "i": 6496566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de septiembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6496567}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2513 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2513 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-09-06", "fecha_derogacion": "2011-12-13", "doble_articulado": false, "id_norma": "230192", "tipo_version": "2", "tipo_version_s": "Última Vers