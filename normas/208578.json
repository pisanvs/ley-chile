{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 1.497 EXENTA, DE 2003 </div></div>", "i": 6417798}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 1.497 de 22 de enero del a&#xF1;o 2003, se han modificado las resoluciones exentas de Educaci&#xF3;n N&#xBA;s. 5.122 de 2001 y 3.227 de 2002, que aprobaron planes y programas especiales de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, respectivamente, al Instituto Santa Mar&#xED;a, de la comuna de &#xD1;u&#xF1;oa, provincia de Santiago, en el sentido de sustituir los planes de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, por los que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6417799}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de enero de 2003.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6417800}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1497 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1497 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 1.497 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-22", "doble_articulado": false, "id_norma": "208578", "numero_fuente": "37512", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-18", "vigencias": [{"desde": "2003-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-03-18", "fin_vig