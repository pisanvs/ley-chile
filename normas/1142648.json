{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 784 EXENTA, DE 11.02.2020</div></div>", "i": 10102537}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente, se ha modificado, a contar del a&#xF1;o escolar 2020, la <a href=\"https://www.leychile.cl/Navegar?idNorma=1072886&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 8.733, de 2014, del Ministerio de Educaci&#xF3;n</a>, que aprob&#xF3; planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media, al establecimiento educacional Colegio La Maisonnette, RBD 8894-3, comuna de Vitacura, Regi&#xF3;n Metropolitana, en el sentido de sustituir el plan de estudio de 1&#xBA;, 2&#xBA; y 3&#xBA; a&#xF1;o de Educaci&#xF3;n Media.- </div><br></div>", "i": 10102538, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Le&#xF3;n Paul Castro, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 10102539}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "784 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-784 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 784 EXENTA, DE 11.02.2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1729540", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-02-11", "doble_articulado": false, "id_norma": "1142648", "numero_fuente": "42587", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-02-24", "vigencias": [{"desde": "2020-02-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-02-24"