{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8301991}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 361, de 11 de marzo de 1997, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rectif&#xED;quese la Resoluci&#xF3;n N&#xBA; 40, de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la SOCIEDAD PESQUERA RALUN LIMITADA&nbsp; para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a dejar sin efecto la disposici&#xF3;n contenida en el numeral 12&#xBA;, de la Resoluci&#xF3;n se&#xF1;alada precedentemente, en virtud de haberse dictado con error de hecho.</div><br><div class=\"p\">&nbsp; &nbsp;  Decl&#xE1;rase, en consecuencia, plenamente vigente la Resoluci&#xF3;n N&#xBA; 193, de 1983, de esta Subsecretar&#xED;a. </div></div>", "i": 8301992}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de marzo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8301993}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "361", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-361"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "SOCIEDAD PESQUERA RALUN LIMITADA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-11", "doble_articulado": false, "id_norma": "70124", "numero_fuente": "35721", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-03-20", "vigencias": [{"desde": "1997-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vige