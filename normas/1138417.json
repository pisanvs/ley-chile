{"html": [{"t": "<div><br><div class=\"p\">Pueblo de Requ&#xED;noa.-Se le concede el t&#xED;tulo de villa</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Noviembre de 1898.</div><br><div class=\"p\">&nbsp; &nbsp;  Vista la solicitud de la Municipalidad de Requ&#xED;noa, en la que pide se conceda a dicha poblacion el t&#xED;tulo de &#xAB;villa&#xBB;;</div><div class=\"p\">&nbsp; &nbsp;  Teniendo presente el desarrollo alcanzado por el mencionado pueblo i lo informado por el jefe de la Seccion de Jeograf&#xED;a de la Direccion Jeneral de Obras P&#xFA;blicas,</div><br><div class=\"p\">&nbsp; &nbsp;  Decreto:</div></div>", "i": 10070461}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Conc&#xE9;dese al pueblo de Requ&#xED;noa el t&#xED;tulo de &#xAB;villa&#xBB;, cabecera del territorio municipal del mismo nombre, ubicado en el departamento de Caupolican.</div></div>", "i": 10070462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese i publ&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ.</div><br><div class=\"p\">&nbsp; &nbsp;  C. Walker Mart&#xED;nez.</div></div>", "i": 10070463}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Pueblo de Requínoa.-Se le concede el título de villa", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-11-26", "doble_articulado": false, "id_norma": "1138417", "numero_fuente": "1898", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1898-11-26", "hasta": "", "tipo_version": "3", "tipo_ve