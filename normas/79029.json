{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309477}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 420 de 14 de Mayo de 1992 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la Resoluci&#xF3;n No. 252, de 1986, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a don EDUARDO SALOMON ATALA ATALA, R.U.T. No. 7.221.892-2, domiciliado en Balmaceda 205, Maull&#xED;n, para operar un centro de cultivo del recurso alga del g&#xE9;nero Gracilaria, en la comuna de Maull&#xED;n, provincia de Llanquihue, X Regi&#xF3;n, por renuncia total de su titular, ya individualizado. </div></div>", "i": 8309478}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 14 de Mayo de 1992.- Jorge Marshall Rivera, Subsecretario de Pesca Subrogante.</div><br></div>", "i": 8309479}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "420", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-420"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-05-14", "doble_articulado": false, "id_norma": "79029", "numero_fuente": "34275", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-05-26", "vigencias": [{"desde": "1992-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-05-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIF