{"html": [{"t": "<div><div class=\"p\">FIJA VIGENCIA DE RESOLUCION N&#xBA; 5.007 EXENTA, DE 2000 </div></div>", "i": 6309423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xBA; 5.137 del 17.11.2000, el Servicio de Impuestos Internos, ha fijado vigencia para la aplicaci&#xF3;n de la resoluci&#xF3;n Ex. N&#xBA; 5.007 del 08.11.2000, publicada en Diario Oficial del 14.11.2000, a contar del 1 de enero de 2001.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra incluido en la p&#xE1;gina Web del Servicio en Internet, cuya direcci&#xF3;n es http://www.sii.cl y adem&#xE1;s, se publicar&#xE1; en la edici&#xF3;n del Bolet&#xED;n del Servicio del mes de noviembre de 2000.-</div><br></div>", "i": 6309424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alfredo Echeverr&#xED;a Herrera, Director (S). </div></div>", "i": 6309425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5137 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5137 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS"], "titulo_norma": "FIJA VIGENCIA DE RESOLUCION Nº 5.007 EXENTA, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-17", "doble_articulado": false, "id_norma": "178086", "numero_fuente": "36819", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-22", "vigencias": [{"desde": "2000-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-22", "fin_vigencia": ""