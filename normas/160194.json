{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 349, DE 1990 </div></div>", "i": 6247763}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 349 de 21 de Diciembre de 1990 se han aprobado programas especiales de estudio de orientaci&#xF3;n laboral a la Escuela Especial Particular No. 196 &quot;Nuestro Mundo&quot;, de la comuna de San Ram&#xF3;n, Regi&#xF3;n Metropolitana, por un per&#xED;odo de 4 a&#xF1;os, a contar de Marzo de 1991, en Jugueter&#xED;a en G&#xE9;nero y Confecci&#xF3;n de Art&#xED;culos de Fiestas en Papeles y Cartones.</div><br></div>", "i": 6247764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 08 de Enero de 1991.- Ra&#xFA;l Allard Neumann Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6247765}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "349 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-349 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 349, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-21", "doble_articulado": false, "id_norma": "160194", "numero_fuente": "33876", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-24", "vigencias": [{"desde": "1991-01-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-01-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingr