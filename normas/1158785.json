{"html": [{"t": "<div><br><div class=\"p\">GOBERNADOR DEL PUERTO CONSTITUCION.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 20 de 1828.</div></div>", "i": 10237955}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En uso de la facultad concedida al Gobierno por el Congreso jeneral en su acuerdo de 4 de agosto del presente a&#xF1;o, y estando satisfecho de la probidad y conocimientos del capitan de navio D. Roberto Forster, vengo en nombrarle gobernador del puerto Constitucion, con el sueldo perteneciente a su empleo mar&#xED;timo en actual servicio, que deber&#xE1; abon&#xE1;rsele por la Tesorer&#xED;a jeneral, mediante a no existir todavia en dicho puerto la oficina que deber&#xED;a hacerlo.</div></div>", "i": 10237956}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Refr&#xE9;ndese, t&#xF3;mese razon y comun&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  PINTO.</div><div class=\"p\">&nbsp; &nbsp;  Rodr&#xED;guez.</div></div>", "i": 10237957}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "GOBERNADOR DEL PUERTO CONSTITUCION.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-10-20", "doble_articulado": false, "id_norma": "1158785", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-10-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-10-20", "fin_vigencia": "", "tipo_