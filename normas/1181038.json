{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA&nbsp; LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 46</div></div>", "i": 10363432}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.807, de 31 de agosto de 2022, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1162364&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 1.951, de 2021</a>, y de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 46, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para el centro de cultivo que indica en la resoluci&#xF3;n extractada.</div></div>", "i": 10363433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de agosto de 2022.- Benjam&#xED;n Eyzaguirre del Real, Jefe Divisi&#xF3;n de Acuicultura, Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 10363434}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1807 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1807 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 46", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2182987", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-08-31", "doble_articulado": false, "id_norma": "1181038", "numero_fuente": "43347", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-09-07", "vigencias": [{"desde"