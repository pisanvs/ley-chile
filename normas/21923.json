{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 50.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 9072099}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de ciento viente mil pesos a la partida 37 del Presupuesto de Hacienda con el fin de atender a los gastos que demanda el servicio de la Delegacion Fiscal de Salitreras.</div><br><br></div>", "i": 9072100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 17 de Julio de 1893.- JORJE MONTT.- Alejandro Vial.</div><br></div>", "i": 9072101}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "50", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-50"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1893", "MODIFICACION MINISTERIO", "HACIENDA", "SUPLEMENTO DELEGACION FISCAL SALITRERAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-07-17", "doble_articulado": false, "id_norma": "21923", "numero_fuente": "4572", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-07-18", "vigencias": [{"desde": "1893-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-07-18", "fin_vigenci