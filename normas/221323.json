{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 32 EXENTA, DE 2004 </div></div>", "i": 7309012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de</div><div class=\"p\">Impuestos Internos N&#xBA; 32, del 12 de febrero de 2004, que</div><div class=\"p\">modifica resoluci&#xF3;n Ex. N&#xBA; 4.847, D.O. 17.10.95,</div><div class=\"p\">respecto del Formulario N&#xBA; 1891, sobre Compra y Venta de</div><div class=\"p\">Acciones de S.A. y dem&#xE1;s t&#xED;tulos efectuadas por</div><div class=\"p\">intermedio de los Corredores de Bolsa y Agentes de</div><div class=\"p\">Valores no acogidas a las normas de la letra A) del</div><div class=\"p\">art&#xED;culo 57 bis de la Ley sobre Impuesto a la Renta.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en febrero de 2004.</div><br></div>", "i": 7309013}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "32 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-32 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 32 EXENTA, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "FORMULARIO 1891", "COMPRA Y VENTA DE ACCIONES DE SOCIEDADES ANONIMAS", "CORREDORES DE BOLSA", "AGENTES DE VALORES", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO. SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-12", "doble_articulado": false, "id_norma": "221323", "numero_fuente": "37789", "ti