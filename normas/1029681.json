{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9184538}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;1601 de fecha 29 de julio de 2011, se expropi&#xF3; el lote de terreno N&#xBA;126-B, superficie 434 m2, rol N&#xBA;276-41, para la obra &quot;Camino Mejoramiento Ruta 126, Los Conquistadores, Sector 1 Cruce Ruta L-30-M- Carrizal, Tramo Km. 0,50000 a Km. 17,34000&quot;, Comunas de San Javier y Cauquenes, Provincias de Linares y Cauquenes, Regi&#xF3;n del Maule y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario JUAN ANTONIO GONZ&#xC1;LEZ REVECO, ascendente a la cantidad de $1.577.260.-</div></div>", "i": 9184539}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9184540}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1601 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1601 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-29", "doble_articulado": false, "id_norma": "1029681", "numero_fuente": "40062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-15", "vigencias": [{"desde": "2011-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ingreso": "2011-09-15", "fecha_version":