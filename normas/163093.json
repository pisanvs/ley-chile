{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6257381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 621, de 24 de marzo de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones N&#xBA; 2.215, N&#xBA; 2.218, N&#xBA; 2.225 y N&#xBA; 2.230, de 1996, y N&#xBA; 650, de 1999, todas de esta Subsecretar&#xED;a, que otorgaron a EMPACADORA DEL PACIFICO LIMITADA, permisos extraordinarios de pesca para la unidad de pesquer&#xED;a del recurso hidrobiol&#xF3;gico Langostino amarillo fijada en el art&#xED;culo 1&#xBA; del D.S. N&#xBA; 787, de 1996, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de conformidad con el art&#xED;culo 143 letra h) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6257382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de marzo de 2000.- Daniel Alabarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6257383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "621", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-621"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-24", "doble_articulado": false, "id_norma": "163093", "numero_fuente": "36627", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-03-30", "vigencias": [{"desde": "2000-03-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-03-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia"