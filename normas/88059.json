{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA No. 3, DE 1981</div><div class=\"p\">N&#xFA;m. 19.- Santiago, 14 de marzo de 1991.-</div><br><div class=\"p\">Decreto:</div><br></div>", "i": 6077962}, {"t": "<div><div class=\"p\">1.- Modif&#xED;case el Art&#xED;culo 40&#xB0; de la Ordenanza No. 3, de Propaganda, de fecha 12 de febrero de 1981, en el sentido que se incorpora a la aplicaci&#xF3;n de ella, la Avenida Libertador Bernardo O&apos;Higgins en toda su extensi&#xF3;n.</div><div class=\"p\">2.- El presente Decreto regir&#xE1; a partir de su publicaci&#xF3;n en el Diario Oficial.</div><div class=\"p\">3.- Los letreros de publicidad y marquesinas instaladas con autorizaci&#xF3;n de la Direcci&#xF3;n de Obras Municipales, tendr&#xE1;n plazo de (120) ciento veinte d&#xED;as, a contar de la publicaci&#xF3;n se&#xF1;alada precedentemente, para cumplir con las normas establecidas en la Ordenanza No. 3, de Propaganda, art&#xED;culo 40&#xB0;.</div><br></div>", "i": 6077963}, {"t": "<div><div class=\"p\">El Alcalde.-</div><br></div>", "i": 6077964}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "19", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-19"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "MODIFICA ORDENANZA No. 3, DE 1981", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-14", "doble_articulado": false, "id_norma": "88059", "numero_fuente": "33925", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-22", "vigencias": [{"desde": "1991-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-03-22", "fin_vige