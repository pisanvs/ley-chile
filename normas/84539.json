{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 98, DE 1990 </div></div>", "i": 6068091}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 98 de 07 de marzo de 1990 se ha aprobado a partir del a&#xF1;o escolar 1990, un plan especial de estudio al Colegio Apoquindo, Hombres, de Santiago, para la Educaci&#xF3;n General B&#xE1;sica y la Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica el que se aplicar&#xE1; simult&#xE1;neamente en todos los cursos de los referidos niveles.</div><br></div>", "i": 6068092}, {"t": "<div><div class=\"p\">Santiago, 09 de Marzo de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n Primaria. </div></div>", "i": 6068093}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "98 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-98 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 98, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-07", "doble_articulado": false, "id_norma": "84539", "numero_fuente": "33628", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-23", "vigencias": [{"desde": "1990-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-01-13", "fecha_version": "1990-03-23", "fecha_actualizacion