{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 8276760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Prorr&#xF3;ganse los efectos de la lei n&#xFA;mero 3,657, de 6 de setiembre de 1920, hasta que se reorganice la planta de empleados del Congreso Nacional. </div></div>", "i": 8276761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de diciembre de mil novecientos veintiuno.- Arturo Alessandri.- Ismael Tocornal. </div></div>", "i": 8276762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3827", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3827"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "PERSONAL", "GRATIFICACION", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-12-30", "doble_articulado": false, "id_norma": "24277", "numero_fuente": "13182", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1922-01-23", "vigencias": [{"desde": "1922-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1922-01-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1922-01-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ing