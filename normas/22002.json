{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Gastos de los Establecimientos Penales Lei n&#xFA;m. 140.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto del Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946897}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cincuenta mil pesos, en cubrir el exceso que ocasionar&#xE1; el servicio de varios establecimientos penales hasta el 31 de Diciembre del presente a&#xF1;o.</div><br><br></div>", "i": 5946898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 27 de Diciembre de 1893.- JORJE MONTT.- Francisco A. Pinto.</div><br></div>", "i": 5946899}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "140", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-140"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "GASTOS DE LOS ESTABLECIMIENTOS PENALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESTABLECIMIENTOS PENALES", "FINANCIAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-12-27", "doble_articulado": false, "id_norma": "22002", "numero_fuente": "4703", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-12-27", "vigencias": [{"desde": "1893-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-12-27", "fin_vigencia": ""}, "vigenci