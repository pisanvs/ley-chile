{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.081 EXENTA, DE 1999 </div><br><br></div>", "i": 7250731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.081, de 6 de mayo de 1999, se ha aprobado al Colegio Suizo de<span class=\"n\" id=\"n_0\">RECTIFICACION<br>D.O. 29.07.1999</span> Santiago, un plan de estudio para primer a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 1999. Adem&#xE1;s, se aprueban programas de estudio para primer a&#xF1;o de ense&#xF1;anza media de los subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 7250732}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de julio de 1999.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 7250733}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "4081 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4081 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.081 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-06", "doble_articulado": false, "id_norma": "139668", "numero_fuente": "36423", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-07-27", "vigencias": [{"desde": "1999-07-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-07-27", "hasta": "1999-07-28", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1999-07-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini