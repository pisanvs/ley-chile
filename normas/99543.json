{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6112077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xBA; 572, de 29 de abril de 1998, se expropiaron los lotes de terreno N&#xBA;s 14 y 17, superficies 2.127 y 354 M2., roles de aval&#xFA;o 4427-2 y 4505-72, comuna de San Bernardo, respectivamente, para la obra Estudio de Anteproyecto e Ingenier&#xED;a, para el Sistema Norte - Sur, sector Ruta 5 Sur-Departamental y sector Eje General Vel&#xE1;squez y se acord&#xF3; precio de indemnizaci&#xF3;n con los propietarios Inversiones Valladolid S.A. e Irarr&#xE1;zaval Montes Gustavo, ascendentes a las cantidades de $56.366,160, para el lote N&#xBA;14, y $9.727.920, para el lote N&#xBA; 17. </div></div>", "i": 6112078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6112079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "572", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-572"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SAN BERNARDO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-29", "doble_articulado": false, "id_norma": "99543", "numero_fuente": "36089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-15", "vigencias": [{"desde": "1998-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p