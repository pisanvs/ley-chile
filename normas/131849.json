{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8341098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 90, de 21 de enero de 1999, de esta Subsecretar&#xED;a, ampl&#xED;ase por un a&#xF1;o, a contar de la fecha de la presente resoluci&#xF3;n, el plazo otorgado a COMERCIALIZADORA Y DISTRIBUIDORA SALMONYTRUCHA LIMITADA, para iniciar operaciones respecto de la planta autorizada por la resoluci&#xF3;n N&#xBA; 835, de 1998, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor. </div></div>", "i": 8341099}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de enero de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8341100}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "90", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-90"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-01-21", "doble_articulado": false, "id_norma": "131849", "numero_fuente": "36294", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-02-19", "vigencias": [{"desde": "1999-02-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-02-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-02-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-02-19", "fecha_version": "1999-02-19", "fecha