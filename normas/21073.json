{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 364 EXENTO, DE 1995 </div></div>", "i": 7161690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 364 de fecha 9 de junio de 1995 del Ministerio de Educaci&#xF3;n, se ampli&#xF3; la autorizaci&#xF3;n de funcionamiento al Instituto Profesional Instituto de Estudios Bancarios Guillermo Subercaseaux, otorgada por Decreto Exento de Educaci&#xF3;n N&#xB0; 6 de 1982, a la Sede que los organizadores mantienen en la ciudad de La Serena. En dicha Sede se impartir&#xE1; la carrera de Contador Auditor, conducente al t&#xED;tulo profesional de Contador Auditor y al T&#xED;tulo T&#xE9;cnico de Nivel Superior de T&#xE9;cnico Financiero, como salida intermedia.</div><br><br></div>", "i": 7161691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de julio de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "364 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-364 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 364 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL INSTITUTO ESTUDIOS GUILLERMO", "SUBERCASEAUX", "AUTORIZACION", "CARRERA PROFESIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-06-09", "doble_articulado": false, "id_norma": "21073", "numero_fuente": "35239", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-08-09", "vigencias": [{"desde": "1995-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio