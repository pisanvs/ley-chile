{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6410475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, que suscribe, certifica que la Sede de Antofagasta del Instituto Profesional Academia de Idiomas y Estudios Profesionales AIEP, autorizada por Decreto Exento N&#xBA; 85 de 1990, podr&#xE1; impartir a contar del a&#xF1;o 1991, la carrera de Comunicaci&#xF3;n social conducente al t&#xED;tulo profesional de Comunicador Social con menci&#xF3;n en Relaciones P&#xFA;blicas.</div><div class=\"p\">&nbsp; &nbsp;  Dicha instituci&#xF3;n se encuentra liberada de la obligaci&#xF3;n de someter sus planes y programas de estudios de la mencionada carrera a una entidad examinadora y de rendir ex&#xE1;menes finales ante comisiones mixtas paritarias en virtud de lo dispuesto en el art&#xED;culo 14 y 15 del DFL N&#xBA; 5/81 y DS N&#xBA; 1076/86.</div><br></div>", "i": 6410476}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de Enero de 1991.</div><div class=\"p\">&nbsp; &nbsp;  RAUL ALLARD NEUMANN Subsecretario de Educaci&#xF3;n </div></div>", "i": 6410477}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "DIVISIÓN DE EDUCACION SUPERIOR"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-01-31", "doble_articulado": false, "id_norma": "206803", "numero_fuente": "33899", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-20", "vigencias": [{"desde": "1991-02-20", "hasta": "", "tipo_version": "3", "ti