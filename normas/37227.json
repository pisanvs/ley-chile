{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.590, de 27 de agosto de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la autorizaci&#xF3;n solicitada por PESQUERA YELCHO S.A., en orden a sustituir las naves &quot;Jing Yang N&#xB0; 1&quot;, &quot;Gualas&quot; y &quot;San Rafael&quot; por la nave en construcci&#xF3;n &quot;American Monarch&quot;, por no dar cumplimiento a los requisitos establecidos en los art&#xED;culos 2&#xB0; y 6&#xB0; del Decreto Supremo N&#xB0; 64, de 1992, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en relaci&#xF3;n al art&#xED;culo 19 letra e) de la Ley N&#xB0; 18.892 y sus modificaciones.</div><br></div>", "i": 8297839}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 27 de agosto de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297840}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1590", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1590"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "AUTORIZACION", "PESCA", "PESQUERA YELCHO S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-08-27", "doble_articulado": false, "id_norma": "37227", "numero_fuente": "35558", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-03", "vigencias": [{"desde": "1996-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "