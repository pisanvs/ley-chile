{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xBA; 1169 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1169, celebrada el 16 de diciembre de 2004, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6509887}, {"t": "<div><div class=\"p\">1169-01-041216 - Modifica Anexo del Cap&#xED;tulo I del Compendio de Normas de Cambios Internacionales.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el Anexo del Cap&#xED;tulo I del Compendio de Normas de Cambios Internacionales, reemplazando la letra a), por la siguiente:</div><br><div class=\"p\">&quot;a)&nbsp; El valor de la CRM antes indicado se corregir&#xE1;, diariamente, en 0,008099% entre el 10 de enero del 2005 y el 9 de enero del 2006, ambas fechas incluidas&quot;.</div><br></div>", "i": 6509888}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de diciembre de 2004.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6509889}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1169", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1169"}, {"tipo": "5", "numero": "1169-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1169-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION Nº 1169", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-16", "doble_articulado": false, "id_norma": "233876", "numero_fuente": "38041", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-21", "vigencias": [{"desde": "2004-12-21", "hasta": "",