{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.390 EXENTA, DE 2013</div></div>", "i": 9382827}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 8.390, de 22 de octubre&nbsp; de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Capacitaci&#xF3;n en Control de Riesgos Operacionales Limitada (CRO Limitada o Ltda.)&quot;, RUT 76.343.760-4 contenida en la resoluci&#xF3;n exenta N&#xBA; 3.005, de 15 de mayo de 2007, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del Art. 21 de la ley 19.518.-</div></div>", "i": 9382828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9382829}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8390 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8390 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.390 EXENTA, DE 2013", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-10-22", "fecha_derogacion": "2013-12-19", "doble_articulado": false, "id_norma": "1055883", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-11-06", "vigencias": [{"desde": "2013-12-19", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2013-11-06", "hasta": "2013-12-18", "tipo_version": "0", "tipo_version_s": "Texto O