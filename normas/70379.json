{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302190}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 433, de 27 de marzo de 1997, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, decl&#xE1;rese la caducidad parcial</div><div class=\"p\">de las Resoluciones N&#xBA; 656 de 1989 y N&#xBA; 244, de 1990,</div><div class=\"p\">ambas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA</div><div class=\"p\">BIO BIO LIMITADA, R.U.T. N&#xBA; 84.902.900-2, domiciliada en</div><div class=\"p\">la ciudad de Talcahuano, Col&#xF3;n N&#xBA; 2450, para realizar</div><div class=\"p\">actividades pesqueras extractivas con la nave &quot;Gardar&quot;,</div><div class=\"p\">en lo relativo a la especie Merluza com&#xFA;n, en virtud del</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8302191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de marzo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302192}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "433", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-433"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "AUTORIZACION", "PESQUERA BIO BIO LIMITADA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-27", "doble_articulado": false, "id_norma": "70379", "numero_fuente": "35734", "tipo_version": "3", "tipo_version_s": "Únic