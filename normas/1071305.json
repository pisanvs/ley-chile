{"html": [{"t": "<div><br><div class=\"p\">CIRCULAR</div><div class=\"p\">Bancos N&#xB0; 3.543</div><div class=\"p\">Santiago, 23 de octubre de 2012.-</div><br><div class=\"p\">RECOPILACI&#xD3;N ACTUALIZADA DE NORMAS. Cap&#xED;tulo 18-6.</div><br><div class=\"p\">Deroga instrucciones.</div></div>", "i": 9577980}, {"t": "<div><br><div class=\"p\">Mediante la presente Circular se deroga el Cap&#xED;tulo 18-6 de la Recopilaci&#xF3;n Actualizada de Normas, debido a que actualmente ya no es necesario el env&#xED;o de la informaci&#xF3;n a que se refiere dicho Cap&#xED;tulo.</div><br><div class=\"p\">Como consecuencia de lo anterior, se remplaza la hoja N&#xB0; 4 del &#xED;ndice de Cap&#xED;tulos y las hojas N&#xB0;s. 6 y 11 del &#xED;ndice por Materias</div><br><br></div>", "i": 9577981, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">Saludo atentamente a Ud.,</div><br><div class=\"p\">RAPHAEL BERGOEING VELA</div><div class=\"p\">superintendente de Bancos e</div><div class=\"p\">Instituciones Financieras</div></div>", "i": 9577982}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "Bancos 3543", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-Bancos 3543"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE BANCOS E INSTITUCIONES FINANCIERAS"], "titulo_norma": "RECOPILACIÓN ACTUALIZADA DE NORMAS. Capítulo 18-6. Deroga instrucciones", "fuente": "Recopilación de instrucciones SBIF", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-23", "doble_articulado": false, "id_norma": "1071305", "numero_fuente": "0", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "2012-10-23", "hasta": "", "tipo_version": "3", "t