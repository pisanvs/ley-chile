{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6380116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA;317 de fecha 28 de marzo de 2002, se expropi&#xF3; el lote de terreno N&#xBA;8-b, superficie 1.831 m2, rol de aval&#xFA;o 212-35, comuna de Teodoro Schmidt, para la obra &quot;Camino Costero Sur, sector Tranapuente - Puerto Saavedra - Porma, Tramo Chelle - Hualp&#xED;n - Puente Puele, Km. 48.292,74 al Km.</div><div class=\"p\">68.030,40, correspondiente al Subtramo II Km. 54.260,00 al Km. 59.552.949&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Jos&#xE9; Israel Narv&#xE1;ez Ar&#xE9;valo, ascendente a la cantidad de $764.455.-</div><br></div>", "i": 6380117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6380118}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "317 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-317 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-28", "doble_articulado": false, "id_norma": "197684", "numero_fuente": "37248", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-02", "vigencias": [{"desde": "2002-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingr