{"html": [{"t": "<div><div class=\"p\">COMPLEMENTA DECRETO No. 802, DE 1990,</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 746.- Santiago, 15 de Noviembre de 1990.- Visto: Lo dispuesto en el art&#xED;culo 16&#xB0; de la Ley No. 18.956, y en los art&#xED;culos 3a No. 8 y 35 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile, </div><div class=\"p\">&nbsp; &nbsp;  Decreto:</div><br><br></div>", "i": 7222380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Complem&#xE9;ntase el decreto supremo de Educaci&#xF3;n No. 602, de 1990 que modifica el decreto supremo de Educaci&#xF3;n No. 3.245, de 1982, en el sentido de agregar como comuna de la provincia de Llanquihue:</div><div class=\"p\">&quot;Calbuco&quot;.</div><br><br></div>", "i": 7222381, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Ricardo Lagos Escobar, Ministro de Educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br><br></div>", "i": 7222382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "746", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-746"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "COMPLEMENTA DECRETO No. 802, DE 1990,", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-11-15", "doble_articulado": false, "id_norma": "87784", "numero_fuente": "33883", "tipo_version": "3", "tipo_version_s": "Única", "fecha_