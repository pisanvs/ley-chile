{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Ajentes postales de la Rep&#xFA;blica Lei n&#xFA;m. 1,196.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274166}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir, hasta la suma de cuatro mil ochocientos setenta i siete pesos cincuenta i dos centavos en pagar las comisiones que devengaron en el a&#xF1;o 1897 diversos ajentes postales de la Rep&#xFA;blica </div><br></div>", "i": 8274167}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 7 de febrero 1899.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br><br><br></div>", "i": 8274168}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1196", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1196"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AJENTES POSTALES DE LA REPUBLICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGENTES POSTALES REPUBLICA", "COMISION", "PAGO", "FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-02-07", "doble_articulado": false, "id_norma": "22464", "numero_fuente": "6221", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-02-07", "vigencias": [{"desde": "1899-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-02-07", "fin_