{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6281074}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.046 de 22 de diciembre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Belarmino Mu&#xF1;oz Gallardo y Nancy Barrientos G&#xE1;rnica para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea N&#xBA; 1 &quot;Francke - Centro - Rahue Alto&quot; de Osorno, cuyo trazado fue autorizado por resoluci&#xF3;n N&#xBA; 090 de 12 de junio de 1984 y modificado por resoluci&#xF3;n N&#xBA; 464 de 16 de septiembre de 1986, de esta Secretar&#xED;a Regional.-</div><br></div>", "i": 6281075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6281076}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1046 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1046 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-22", "doble_articulado": false, "id_norma": "170602", "numero_fuente": "32969", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-14", "vigencias": [{"desde": "1988-01-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-14", "fin_vigencia": ""}, "vigencias_version_norma