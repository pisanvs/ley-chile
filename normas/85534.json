{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6070603}, {"t": "<div><div class=\"p\">Por Decreto M.O.P. No. s 272 y 273, ambos de fecha 29 de septiembre de 1992, se expropiaron los lotes de terreno No.</div><div class=\"p\">s. 31 y 10, superficie 100 M2. y 340 M2., respectivamente, roles de aval&#xFA;os 33-46 y 245-16, de las Comunas de Coinco y Olivar, para la obra Camino Olivar Coinco, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Mario Peralta Arros y Juan Nu&#xF1;ez Soto, ascendente a las cantidades de $ 157.700 y $ 228.665.</div><br></div>", "i": 6070604}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6070605}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "272", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-272"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-29", "doble_articulado": false, "id_norma": "85534", "numero_fuente": "34405", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-02", "vigencias": [{"desde": "1992-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-01-19", "fecha_version": "1992-11-02", "fecha_actualizacion_texto": "1992-11-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructu