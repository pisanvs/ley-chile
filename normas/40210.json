{"html": [{"t": "<div><div class=\"p\">DELEGA FACULTADES QUE SE&#xD1;ALA</div><br><br></div>", "i": 7202630}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Que, mediante Resoluci&#xF3;n Ex. N&#xB0; 2.541, de fecha 24.07.96, el Director Regional del Servicio de Impuestos Internos de la VII Direcci&#xF3;n Regional Talca ha procedido a efectuar modificaciones a las Resoluciones Ex. N&#xB0;s 2.171, del 21.08.91 y 1.970, del 27.03.92, en virtud a lo dispuesto en la Resoluci&#xF3;n Ex. N&#xB0; 3.311 de fecha 16.07.96, publicada en el D.O. de fecha 22.07.96, emanada del Sr. Director del Servicio, en el sentido de agregar respectivamente en ambas Resoluciones los Resolutivos que en &#xE9;sta se especifican.-</div><br></div>", "i": 7202631}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 7202632}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2541 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2541 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL VII REGIÓN DEL MAULE"], "titulo_norma": "DELEGA FACULTADES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "DELEGACION", "FACULTAD", "DIRECTOR", "REGIONAL", "SERVICIO IMPUESTOS INTERNOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07-24", "doble_articulado": false, "id_norma": "40210", "numero_fuente": "35534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-08-05", "vigencias": [{"desde": "1996-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-08-05", "fin_vigencia": ""}, "v