{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6306621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;3.326, de 31 de julio del 2000, se expropi&#xF3; el lote de terreno N&#xBA;3, superficie 516 m2., rol de aval&#xFA;o 154-75, comuna de Casablanca, para la obra &apos;&apos;Concesi&#xF3;n Internacional Interconexi&#xF3;n Vial Santiago - Valpara&#xED;so - Vi&#xF1;a del Mar&apos;&apos;, Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Alberto Santib&#xE1;&#xF1;ez Vera, ascendente a la cantidad de $1.633.473.-</div><br></div>", "i": 6306622}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6306623}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3326", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3326"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-07-31", "doble_articulado": false, "id_norma": "177116", "numero_fuente": "36802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-02", "vigencias": [{"desde": "2000-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2000-11-02", "fecha_version": "2000-11-02", "fecha_actualizacion_texto": "2000-11-02", "tipo_tratado": ""}, "alertas": [], "al