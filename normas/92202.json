{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 8321373}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 1.404 de 06 de Octubre de 1989 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga la Resoluci&#xF3;n No. 971, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Frioaustral S.A., R.U.T.</div><div class=\"p\">No. 96.507.410-4, domiciliada en Valpara&#xED;so, para operar tres embarcaciones en construcci&#xF3;n, en el litoral de las Regiones III a VII y IX a XII, por renuncia de su titular. </div></div>", "i": 8321374}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 06 de Octubre de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8321375}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1404", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1404"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-06", "doble_articulado": false, "id_norma": "92202", "numero_fuente": "33498", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-17", "vigencias": [{"desde": "1989-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-10-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingres