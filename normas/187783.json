{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6343305}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xB0; 406, de 30 de Noviembre de 1984, se expropiaron los lotes N&#xB0;s. 10 y 11 y se constituy&#xF3; servidumbre en los lotes N&#xB0;s, 12, 13, 14, 15 y 18, roles de aval&#xFA;o 546-51 para los lotes 10,12, 13 y 14, 546-131 para los lotes ll y 18 y 546-87 para el lote 15, superficies 11.260 m&#xB2;., 3.146 m&#xB2;., 2.940 m&#xB2;., 915 m&#xB2;., 315 m&#xB2;., 1.380 comuna de La Uni&#xF3;n, X Regi&#xF3;n, para Agua Potable de La Uni&#xF3;n y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios don Te&#xF3;filo Grob Werner, Jos&#xE9; Ancapi Antihual y Linos de Chile S.A., ascendente a $ 375.570 para los lotes 10, 12, 13 y 14: $ 116.663 para los lotes 11 y 18 y $ 26.040 para el lote 15.</div><br></div>", "i": 6343306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6343307}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "406", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-406"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-11-30", "doble_articulado": false, "id_norma": "187783", "numero_fuente": "32060", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-02", "vigencias": [{"desde": "1985-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-02",