{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6558347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 4.373, de 20 de diciembre de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a ISMAEL MADARIAGA OLIVARES, para iniciar actividades pesqueras de transformaci&#xF3;n, autorizadas por la resoluci&#xF3;n citada en Visto, en orden a incorporar a su planta ubicada en Ruta 5 Norte aleda&#xF1;o a deslinde Barrio Industrial, comuna y provincia de Cha&#xF1;aral, III Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Picado de algas, los recursos hidrobiol&#xF3;gicos se&#xF1;alados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6558348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de diciembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6558349}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4373 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4373 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-20", "doble_articulado": false, "id_norma": "246607", "numero_fuente": "38368", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-20", "vigencias": [{"desde": "2006-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-01-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente