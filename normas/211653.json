{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7300852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.127, de 30 de mayo de 2003, de esta Subsecretar&#xED;a,&nbsp; modif&#xED;case&nbsp; el&nbsp; numeral&nbsp; 1&#xBA;&nbsp;  de&nbsp;  la resoluci&#xF3;n N&#xBA; 1.761 de 1996, y el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 1.443 de 1997, que autorizaron a PESQUERA BIO BIO S.A. para desarrollar actividades pesqueras con la nave &quot;Loa 24&quot;, en el sentido de incorporar, cuando corresponda, y actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Eslora de arqueo&nbsp;  51,81 m</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 12,20 m</div><br></div>", "i": 7300853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de mayo de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7300854}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1127", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1127"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-05-30", "fecha_derogacion": "2006-11-23", "doble_articulado": false, "id_norma": "211653", "numero_fuente": "37593", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-06-26", "vigencias": [{"desde": "2006-11-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003-06-26", "hasta": "2006-11-22", "tipo_version": "0", "tipo_ve