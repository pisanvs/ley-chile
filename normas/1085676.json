{"html": [{"t": "<div><br><div class=\"p\">PARTIDO LIBERAL DE CHILE</div></div>", "i": 9658810}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Vlado Mirosevic Verdugo, Presidente de la Directiva Central Provisional del Partido Liberal de Chile, en formaci&#xF3;n, con fecha 14 de diciembre de 2015, ha solicitado la constituci&#xF3;n legal del partido en la Regi&#xF3;n XV de Arica y Parinacota. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de 219 afiliaciones.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=8285857&amp;idVersion=\">art&#xED;culo 17&#xBA;</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=29994&amp;idParte=&amp;idVersion=\">ley N&#xBA; 18.603</a>, por resoluci&#xF3;n O-N&#xBA; 256, fecha 17 de diciembre de 2015.</div><br></div>", "i": 9658811}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Elizabeth Cabrera Burgos, Directora (S).</div></div>", "i": 9658812}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "256", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-256"}, {"tipo": "3", "numero": "O-256", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-256"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO LIBERAL DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 979101; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-17", "doble_articulado": false, "id_norma": "1085676", "numero_fuente": "41339", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-12-23", "vigencias": [{"desde": "2015-12-23", "hasta": "", "tipo_ver