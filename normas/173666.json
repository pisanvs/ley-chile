{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6294459}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.869, de 28 de abril de 2000, se modific&#xF3; el decreto MOP N&#xBA;2.998, de 30 de septiembre de 1999, que orden&#xF3; la expropiaci&#xF3;n y autoriz&#xF3; el convenio directo de precio del lote N&#xBA;15, en cuanto a que se dejan sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA;, 6&#xBA; y 7&#xBA; y se autoriza un nuevo convenio directo de precio suscrito con don Miguel Margas Garetto, en el que se reduce el monto de la indemnizaci&#xF3;n definitiva en la suma de $25.178.979.- </div></div>", "i": 6294460}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6294461}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1869", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1869"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-28", "doble_articulado": false, "id_norma": "173666", "numero_fuente": "36728", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-08-01", "vigencias": [{"desde": "2000-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_ingreso": "2000-08-01", "fecha_version": "2000-0