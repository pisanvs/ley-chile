{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 188, DE 1994</div><br><div class=\"p\">NOTIFICACION </div></div>", "i": 6339258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 252 de 22 Noviembre 1994, del Serviu V Regi&#xF3;n, se modific&#xF3; Resoluci&#xF3;n N&#xBA; 188 de 26 Septiembre 1994, relativa a expropiaci&#xF3;n parcial de inmueble rol aval&#xFA;o 9037-1, resto Fundo Centinela, Cerro La Virgen, San Antonio, de Miguel Solari Morchio y Otros, estableci&#xE9;ndose monto provisional indemnizaci&#xF3;n en $1.440.000, seg&#xFA;n informe de 7 de Noviembre de 1994 de Comisi&#xF3;n Tasadora integrada por arquitecto Osvaldo Mu&#xF1;oz Quintana y constructores civiles Sres. Pablo Caria Giurici y Alvaro Verdejo Vidal, que se pagar&#xE1; de contado.</div><br></div>", "i": 6339259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu V Regi&#xF3;n.</div><br></div>", "i": 6339260}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "252", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-252"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "MODIFICA RESOLUCION Nº 188, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-11-22", "doble_articulado": false, "id_norma": "186614", "numero_fuente": "35038", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-16", "vigencias": [{"desde": "1995-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-01-16", "fin_vigencia": ""}, "vigencias_version_norma":