{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,670.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 7249588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Aum&#xE9;ntase a mil ochocientos pesos ($ 1,800) la pensi&#xF3;n de gracia de que disfrutan cada una de las se&#xF1;oras Atala Rosa i Esilda Prat Chacon, a virtud de lo dispuesto en la lei n&#xFA;mero 930, de 8 de julio de 1897, i de que continuar&#xE1;n gozando en conformidad a la lei de montep&#xED;o militar.</div><br></div>", "i": 7249589, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, ocho de agosto de mil novecientos doce.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S.</div><br></div>", "i": 7249590}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2670", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2670"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-08-08", "doble_articulado": false, "id_norma": "137657", "numero_fuente": "10355", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-08-17", "vigencias": [{"desde": "1912-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-