{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6270069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 227 de 26 de Febrero de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deniega la autorizaci&#xF3;n solicitada por SOCIEDAD PESQUERA RAPEL LIMITADA, R.U.T. No.</div><div class=\"p\">79.785.120-5, domiciliada en la ciudad de Iquique, para prorrogar el plazo a que se refiere el numeral 5&#xB0; de la Resoluci&#xF3;n No. 1013, de 1989, de esta Subsecretar&#xED;a, en atenci&#xF3;n a lo dispuesto en el art&#xED;culo 7&#xB0;, del Decreto No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Cad&#xFA;case, en m&#xE9;rito de lo antes se&#xF1;alado y de conformidad a lo dispuesto en el art&#xED;culo y la norma antes citada, la Resoluci&#xF3;n No. 1013, de 1989, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6270070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de Febrero de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 6270071}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "227", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-227"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-02-26", "doble_articulado": false, "id_norma": "167104", "numero_fuente": "33913", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-03-08", "vigencias": [{"desde": "1991-03-08", "hasta": "", "tipo_version": "3"