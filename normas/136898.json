{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;102 EXENTO, DE 1999</div><br><br></div>", "i": 6170245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;102, de fecha 6 de abril de 1999, del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Iprosec, las adecuaciones al plan y programas de estudios de la carrera de Programaci&#xF3;n Computacional. En consecuencia, se modifica la resoluci&#xF3;n exenta del Ministerio de Educaci&#xF3;n N&#xBA;1.288 del 28 de mayo de 1986, en el sentido de incorporar dichas adecuaciones, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1999.</div><br></div>", "i": 6170246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de abril de 1999.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6170247}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "102 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-102 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº102 EXENTO, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-06", "doble_articulado": false, "id_norma": "136898", "numero_fuente": "36371", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-05-25", "vigencias": [{"desde": "1999-05-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-05-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p