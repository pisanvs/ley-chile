{"html": [{"t": "<div><div class=\"p\">AUTORIZA A LA SOCIEDAD PESQUERA COLOSO S.A. PARA AMPLIAR ACTIVIDADES PESQUERAS </div></div>", "i": 7266546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 35, de 21 de Enero de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la Sociedad Pesquera Coloso S.A., domiciliada en Santiago, para operar la embarcaci&#xF3;n denominada &quot;San Diego&quot;, en el litoral comprendido entre la I y la V Regi&#xF3;n, en laboles extractivas de los siguientes recursos: jurel, sardina espa&#xF1;ola, caballa y anchoa. </div></div>", "i": 7266547}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de Enero de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7266548}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "35", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-35"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A LA SOCIEDAD PESQUERA COLOSO S.A. PARA AMPLIAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-21", "doble_articulado": false, "id_norma": "163510", "numero_fuente": "32089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-05", "vigencias": [{"desde": "1985-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie