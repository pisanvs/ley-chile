{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N QUE FIJ&#xD3; LA DENSIDAD DE CULTIVO PARA LA AGRUPACI&#xD3;N DE CONCESIONES DE SALM&#xD3;NIDOS 56</div></div>", "i": 10305007}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 103, de 14 de enero de 2022, de esta Subsecretar&#xED;a, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1164106&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.323 de 2021</a>, de esta Subsecretar&#xED;a, que fija densidades m&#xE1;ximas de cultivo para la agrupaci&#xF3;n 56, fijando el n&#xFA;mero m&#xE1;ximo de ejemplares a ingresar por estructura de cultivo para los centros de cultivo que se indican en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10305008}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de enero de 2022.- M&#xF3;nica Orellana Vald&#xE9;s, Subsecretaria de Pesca y Acuicultura (S).</div><br></div>", "i": 10305009}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "103 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-103 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA RESOLUCIÓN QUE FIJÓ LA DENSIDAD DE CULTIVO PARA LA AGRUPACIÓN DE CONCESIONES DE SALMÓNIDOS 56", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2076853", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-14", "doble_articulado": false, "id_norma": "1171759", "numero_fuente": "43162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-01-26", "vigencias": [{"desde": "2022-01-26"