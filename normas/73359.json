{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6038654}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 6,49% anual durante el mes de mayo de 1997.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, en conformidad con&nbsp; lo dispuesto en el N&#xBA; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de mayo de 1997, fue de 6,50% anual. </div></div>", "i": 6038655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de junio de 1997.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6038656}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TASA DE INTERES PROMEDIO", "OPERACIONES DE CREDITO DE DINERO", "CAPTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-03", "doble_articulado": false, "id_norma": "73359", "numero_fuente": "35783", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-06", "vigencias": [{"desde": "1997-06-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente