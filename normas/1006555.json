{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8785741}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.086, de 11 de septiembre de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BAH&#xCD;A CORONEL S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Javier&quot;, en las &#xE1;reas mar&#xED;timas que a continuaci&#xF3;n se indican, donde podr&#xE1; extraer los siguientes recursos hidrobiol&#xF3;gicos: a) En el &#xE1;rea mar&#xED;tima comprendida entre la V a VII y XIV a X Regiones, por fuera del &#xE1;rea de reserva artesanal, con red de cerco: Alfonsino, Besugo; b) En el &#xE1;rea mar&#xED;tima comprendida entre la V a VII y XIV a X Regiones, por fuera de las 60 millas marinas, con arrastre de media agua: Alfonsino, Besugo.</div><br></div>", "i": 8785742}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de septiembre de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8785743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3086 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-3086 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2009-09-11", "fecha_derogacion": "2011-08-25", "doble_articulado": false, "id_norma": "1006555", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2009-09-28", "vigencias": [{"desde": "2011-08-25", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2009-09-28", "hasta