{"html": [{"t": "<div><div class=\"p\">NOTIFICACION</div><br><br></div>", "i": 6086885}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 1.034, de 08.11.89, de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186 de 1978, inmueble ubicado en calle Sierra Bella No. 2706, presunto rol aval&#xFA;os No. 614-38, comuna de San Joaqu&#xED;n, aparentemente dominio de don Vicente Cuevas Gonz&#xE1;lez. Comisi&#xF3;n integrada or peritos&nbsp; Sres. Miguel Haltenhoff Aenishanslin, constructor civil, Italo N&#xFA;&#xF1;ez N&#xFA;&#xF1;ez, arquitecto, y Sergio Rojas Ib&#xE1;&#xF1;ez, ingeniero civil, seg&#xFA;n informe de 17 de julio 1989, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 929.600.-, pagadera al contado. </div></div>", "i": 6086886}, {"t": "<div><div class=\"p\">Director SERVIU Metropolitano.</div><br></div>", "i": 6086887}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1034", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1034"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANISMO"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-11-08", "doble_articulado": false, "id_norma": "90814", "numero_fuente": "33536", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-12-01", "vigencias": [{"desde": "1989-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresad