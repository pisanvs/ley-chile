{"html": [{"t": "<div><div class=\"p\">PARTIDO SOCIALISTA DE CHILE </div></div>", "i": 6516737}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Camilo Escalona Medina, Presidente (S) del Partido Socialista de Chile, y Carlos Tapia Sieglitz y Oscar Sandoval Navarrete, Presidente y Secretario (S) del Tribunal Supremo de la colectividad, respectivamente, han comunicado la nueva composici&#xF3;n de su Directiva Central, la que est&#xE1; integrada por:</div><br><div class=\"p\">Directiva Central:</div><br><div class=\"p\">Presidente&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp; Ricardo N&#xFA;&#xF1;ez Mu&#xF1;oz</div><div class=\"p\">Secretario General&nbsp; :&nbsp; Camilo Escalona Medina</div><div class=\"p\">Tesorero&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp; Osvaldo Andrade Lara</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada en virtud de lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones, de fecha 27 de junio de 1988, por resoluci&#xF3;n O-N&#xBA; 4.381 de fecha 15 de febrero de 2005.</div><br></div>", "i": 6516738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 6516739}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4381", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-4381"}, {"tipo": "3", "numero": "O-4381", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-4381"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTIDO SOCIALISTA DE CHILE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO SOCIALISTA DE CHILE", "RICARDO NUÑEZ MUÑOZ", "PRESIDENTE", "DIRECTIVA CENTRAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": f