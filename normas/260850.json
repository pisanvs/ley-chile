{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7341914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;139 de fecha 30 de marzo del 2007, se expropi&#xF3; el lote de terreno N&#xBA;8, superficie 2.968 m&#xB2;, Rol N&#xBA;382-61, comuna de Pitrufqu&#xE9;n, IX Regi&#xF3;n para la obra &quot;Ingenier&#xED;a del Sistema de Riego de la Red Secundaria y Terciaria de Canales Proyecto Faja Maisan IX Regi&#xF3;n, Canal Mapu Quimey&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Flavio Jos Luis Bruna Beltr&#xE1;n, ascendente a la cantidad de $2.376.276.- para el lote N&#xBA;8.</div><br></div>", "i": 7341915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7341916}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "139 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-139 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-03-30", "doble_articulado": false, "id_norma": "260850", "numero_fuente": "38763", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-15", "vigencias": [{"desde": "2007-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2007-05-15", "fecha_version": "2007-05-15", "fecha_actua