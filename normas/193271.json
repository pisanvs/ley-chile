{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6364268}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.815, de 31 de octubre de 2001, se expropi&#xF3; el lote de terreno N&#xBA;76, superficie 64 m2., rol de aval&#xFA;o 692-36, comuna de Estaci&#xF3;n Central, para la obra Sistema Norte-Sur. Tramo G: Nudo Alameda. Sector: Km. 1.980,00 al Km. 2.220,00, Regi&#xF3;n Metropolitana, se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Sociedad Agr&#xED;cola y de Inversiones Banaz Limitada, ascendente a la cantidad de $22.655.417. </div></div>", "i": 6364269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6364270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1815", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1815"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-31", "doble_articulado": false, "id_norma": "193271", "numero_fuente": "37149", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-02", "vigencias": [{"desde": "2002-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-01-04", "fecha_version": "2002-01-02", "fecha_actualizacion_texto": "2002-01-02", "tipo_tratado": ""}, "alertas": [], "alerta