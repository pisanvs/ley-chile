{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6588764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.795, de 10 de octubre de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a JUAN ALBERTO HIDALGO ARAYA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Barranquilla, comuna de Caldera, provincia de Copiap&#xF3;, III Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Secado y Picado de algas los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6588765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de octubre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6588766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2795 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2795 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-10", "doble_articulado": false, "id_norma": "254981", "numero_fuente": "38609", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-09", "vigencias": [{"desde": "2006-11-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-11-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2006-