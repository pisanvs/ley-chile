{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6578545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.150, de 27 de julio de 2006, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 1.045, de 2006, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Caracterizaci&#xF3;n de la captura de pez espada (Xiphias gladius) realizada por la flota artesanal de las Regiones I a X, a&#xF1;o 2006&quot;, en el sentido de reemplazar la frase &quot;30 de abril&quot; por &quot;15 de agosto&quot;. </div></div>", "i": 6578546}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de julio de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6578547}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2150 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2150 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-27", "doble_articulado": false, "id_norma": "251998", "numero_fuente": "38533", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-07", "vigencias": [{"desde": "2006-08-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-08-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-08-07",