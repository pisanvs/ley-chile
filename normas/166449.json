{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6268052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 47 de fecha 17 de Enero de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones: de la Regi&#xF3;n Metropolitana, se autoriza a la Empresa de Transportes F&#xE9;nix Pullman Norte Limitada para efectuar todo tipo de servicios transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6268053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de Enero de 1985.- Carlos Rom&#xE1;n Toro Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6268054}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "47 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-47 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-17", "doble_articulado": false, "id_norma": "166449", "numero_fuente": "32084", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-01-30", "vigencias": [{"desde": "1985-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-01-30", "fin_v