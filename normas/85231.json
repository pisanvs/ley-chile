{"html": [{"t": "<div><div class=\"p\">REASUME MANDO DEL ESTADO</div><br><div class=\"p\">Santiago, 11 de Agosto de 1992.- Hoy se decret&#xF3; lo que sigue:</div><div class=\"p\">N&#xFA;m. 983.- Visto: Lo dispuesto en los art&#xED;culos 29&#xBA; y 32&#xBA;, N&#xBA;8 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile, Decreto:</div><br></div>", "i": 8317042}, {"t": "<div><div class=\"p\">Con ocasi&#xF3;n de m&#xED; regreso al pa&#xED;s, a contar de esta fecha, reasumo el mando del Estado.</div><br></div>", "i": 8317043}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR.- Presidente de la Rep&#xFA;blica.- Enrique Krauss Rusque, Ministro del Interior. Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Belisario Velasco Baraona, Subsecretario del Interior. </div></div>", "i": 8317044}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "983", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-983"}], "organismos": ["MINISTERIO DEL INTERIOR", "SUBSECRETARIA DEL INTERIOR"], "titulo_norma": "REASUME MANDO DEL ESTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-08-11", "doble_articulado": false, "id_norma": "85231", "numero_fuente": "34353", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-28", "vigencias": [{"desde": "1992-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-08-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-08-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu