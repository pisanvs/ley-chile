{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6479603}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 292, de fecha 31 de marzo de 2004, se expropi&#xF3; el lote de terreno N&#xBA; 1-A, superficie 840,68 m&#xB2;, rol N&#xBA; 331-58, comuna de R&#xED;o Negro, para la obra &quot;Camino Ruta U-72, sector Huilma - Riachuelo, tramo Km. 18,14000 al 33,91000&quot;, X Regi&#xF3;n y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietaria Mar&#xED;a Eugenia Mabel Rosas Vergara, ascendente a la cantidad de $12.041.618.</div><br></div>", "i": 6479604}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6479605}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "292", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-292"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-31", "doble_articulado": false, "id_norma": "225302", "numero_fuente": "37861", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-15", "vigencias": [{"desde": "2004-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2004-05-17", "fecha_version": "2004-05-15", "fecha_actualizacion_texto": "2004-05-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "est