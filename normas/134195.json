{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,129.- Santiago, 16 de diciembre&nbsp; de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 8342802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Elvira Lavin, v. de Cruzat, derecho para que contin&#xFA;e gozando de la pensi&#xF3;n mensual de treinta pesos que la lei de 20 de octubre de 1863 otorg&#xF3; a la viuda e hijas solteras de don Antonio Lavin.</div><br></div>", "i": 8342803}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8342804}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1129", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1129"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-16", "doble_articulado": false, "id_norma": "134195", "numero_fuente": "6177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-16", "vigencias": [{"desde": "1898-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-12-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fech