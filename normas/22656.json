{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; I.a Compa&#xF1;&#xED;a de Bomberos de Magallanes Lei n&#xFA;m. 1,446.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la primera compa&#xF1;&#xED;a de bomberos de Magallanes el permiso requerido por el art&#xED;culo 556 del C&#xF3;digo Civil para que pueda conservar, durante treinta a&#xF1;os, la propiedad del sitio que posee, signado con el n&#xFA;mero 1 en la manzana n&#xFA;mero 60 de la poblacion de Punta Arenas.</div><br></div>", "i": 5949195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 22 de Enero de 1901.- FEDERICO ERRAZURIZ E.- Francisco J. Herboso.</div><br></div>", "i": 5949196}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1446", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1446"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "1.A COMPAÑÍA DE BOMBEROS DE MAGALLANES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRIMERA COMPA IA BOMBEROS MAGALLANES", "BIEN RAIZ", "POSESION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-01-22", "doble_articulado": false, "id_norma": "22656", "numero_fuente": "6808", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-02-02", "vigencias": [{"desde": "1901-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vig