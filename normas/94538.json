{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6097360}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 536 de 29 de mayo 1989 de SERVIU Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme DL 2.186 de 1978, inmueble, ubicado en Ricardo Santa Cruz 714, presunto rol aval&#xFA;os 630-15, comuna de Santiago, aparentemente dominio de do&#xF1;a Lucia Vargas Silva. Comisi&#xF3;n integrada por peritos Ricardo Carvallo Rodr&#xED;guez y Luis del Pozo Concha, arquitectos y Ra&#xFA;l Varela Hern&#xE1;ndez, ingeniero civil, seg&#xFA;n informe de 2 de diciembre 1988, fij&#xF3; monto provisional indemnizaci&#xF3;n en $ 2.397.820.-, pagadera al contado. </div></div>", "i": 6097361}, {"t": "<div><div class=\"p\">- Director SERVIU Metropolitano.</div><br></div>", "i": 6097362}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "536", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-536"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIVIENDA Y URBANIZACIÓN REGION METROPOLITANA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-05-29", "doble_articulado": false, "id_norma": "94538", "numero_fuente": "33398", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-06-15", "vigencias": [{"desde": "1989-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-03-06", "fecha_vers