{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A CARREFOUR CHILE S.A.</div><div class=\"p\">(Extracto) </div></div>", "i": 6230532}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Regional Metropolitana Santiago Oriente del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA; Ex. 528 de 21 de enero de 2000, otorga la calidad de agente retenedor del Impuesto al Valor Agregado, a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n y hasta el 31 de julio del a&#xF1;o 2000, a Carrefour Chile S.A., RUT N&#xBA; 96.829.710-4, en las ventas de carne, de conformidad a la resoluci&#xF3;n N&#xBA; Ex. 5.087 del 28 de julio de 1999.-</div><br></div>", "i": 6230533}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Bernardo Seaman Gonz&#xE1;lez, Director Regional. </div></div>", "i": 6230534}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "528 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-528 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO ORIENTE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-21", "doble_articulado": false, "id_norma": "154933", "numero_fuente": "36582", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-07", "vigencias": [{"desde": "2000-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-02-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient