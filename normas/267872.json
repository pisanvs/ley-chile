{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6746163}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.372, de 27 de noviembre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a INDUSTRIA SEA CHANCE Y COMPA&#xD1;&#xCD;A LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta en camino El &#xC1;guila N&#xBA; 1405, Hualqui, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6746164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de noviembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6746165}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3372 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3372 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-27", "doble_articulado": false, "id_norma": "267872", "numero_fuente": "38945", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-26", "vigencias": [{"desde": "2007-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMG", "fecha_ingreso": "2007-12-26", "fecha_ver