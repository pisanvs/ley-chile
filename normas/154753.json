{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO N&#xB0; 101, DE 1986 </div></div>", "i": 6229956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 101, de 11 de Junio de 1986, se han aprobado para el Liceo Comercial A N&#xB0; 40, de Quilpu&#xE9;, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar de 1991, en las especialidades de: Contabilidad, Ventas y Publicidad y Secretariado Administrativo.</div><br></div>", "i": 6229957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6229958}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "101 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-101 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO N° 101, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-18", "doble_articulado": false, "id_norma": "154753", "numero_fuente": "32506", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-06-26", "vigencias": [{"desde": "1986-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-06-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-06-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin