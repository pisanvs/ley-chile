{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA </div></div>", "i": 8326038}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 103 de fecha 13 de Julio de 1989 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la C&#xE1;mara de Comercio de Diego de Almagro Asociaci&#xF3;n Gremial, inscrita bajo el n&#xFA;mero 1.088 del Registro que lleva este Ministerio, por haberse configurado de ella la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18 No. 2 letra c), del DL 2.757 de 1979. </div></div>", "i": 8326039}, {"t": "<div><div class=\"p\">Norman Bull de la Jara, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8326040}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "103", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-103"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA", "FOMENTO"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-13", "doble_articulado": false, "id_norma": "95379", "numero_fuente": "33449", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-16", "vigencias": [{"desde": "1989-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingre