{"html": [{"t": "<div><div class=\"p\">SUBSECRETARIA DE PESCA DEROGA RESOLUCIONES QUE INDICA </div></div>", "i": 8346054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 5, de 11 de Enero de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, der&#xF3;gase la resoluci&#xF3;n No. 683, de 1986, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la Sociedad Procesadora y Comercializadora de Alimentos Limitada, a operar una planta elaboradora de recursos hidrobiol&#xF3;gicos en las l&#xED;neas de elaboraci&#xF3;n de fresco - enfriado y congelado en el inmueble ubicado en Segunda Transversal No. 6030, Comuna de San Miguel, Santiago, por renuncia de su titular.</div><br></div>", "i": 8346055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de Enero de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8346056}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-01-11", "doble_articulado": false, "id_norma": "138280", "numero_fuente": "32988", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-05", "vigencias": [{"desde": "1988-02-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-05", "fin_vi