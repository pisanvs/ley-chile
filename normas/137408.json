{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8345377}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 786, de 17 de mayo de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a do&#xF1;a ELIANA OLGA MERCEDES LADE TAPIA, para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluci&#xF3;n N&#xBA; 568 de 1998, de esta Subsecretar&#xED;a.</div><div class=\"p\">&nbsp; &nbsp;  La peticionaria podr&#xE1; incorporar a la planta ubicada en Parcela &apos;&apos;A&apos;&apos;, Costa Tenglo Alto, Puerto Montt, X Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n que se indican el siguiente recurso hidrobiol&#xF3;gico: Fresco-refrigerado: Loco; Congelado: Loco.</div><div class=\"p\">La materia prima ser&#xE1; adquirida a pescadores artesanales debidamente autorizados.</div><br></div>", "i": 8345378}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de mayo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8345379}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "786", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-786"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-17", "doble_articulado": false, "id_norma": "137408", "numero_fuente": "36381", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-07", "vigencias": [{"desde": "1999-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-07", "fin_vigenci