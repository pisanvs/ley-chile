{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CERTIFICADO </div></div>", "i": 8928777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Subsecretario de Educaci&#xF3;n que suscribe, certifica que la Universidad Aut&#xF3;noma del Sur inscrita bajo el n&#xFA;mero C- N&#xB0; 35 del libro de Registro de Universidades, se ha adscrito al plan y programa de estudio de la carrera de Educaci&#xF3;n Parvularia conducente al grado acad&#xE9;mico de Licenciado en Educaci&#xF3;n y al t&#xED;tulo profesional Educador de P&#xE1;rvulos de la Universidad Arturo Prat, conforme lo establecido en el convenio que ambas universidades suscribieron con fecha 20 de Diciembre de 1993.</div><div class=\"p\">&nbsp; &nbsp; La carrera mencionada podr&#xE1; impartirse en la Universidad Aut&#xF3;noma del Sur a contar de 1994 en su sede autorizada en la ciudad de Temuco.</div><br></div>", "i": 8928778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; JULIO VALLADARES MU&#xD1;OZ</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Subsecretario de Educaci&#xF3;n</div><br></div>", "i": 8928779}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1791", "numero_fuente": "34896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-06-22", "vigencias": [{"desde": "1994-06-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "19