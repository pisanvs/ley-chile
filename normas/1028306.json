{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1, DE 2010</div><br></div>", "i": 9162437}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n N&#xBA; 1, de 22 de diciembre de 2010, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Tarapac&#xE1;, aprueba Contrato Ad-Refer&#xE9;ndum de Concesi&#xF3;n para operar una planta revisora Clase BA en la comuna de Iquique, y una planta revisora Clase AB en la comuna de Alto Hospicio, Regi&#xF3;n de Tarapac&#xE1; (Concesi&#xF3;n Uno), celebrado entre el Ministerio de Transportes y Telecomunicaciones a trav&#xE9;s de la referida Secretar&#xED;a Regional y &quot;A. Denham y C&#xED;a. Ltda.&quot;, con vigencia de ocho a&#xF1;os, contados desde la publicaci&#xF3;n del presente extracto en el Diario Oficial.- </div></div>", "i": 9162438}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alvaro Waldemar G&#xF3;mez Vega, Secretario Regional Ministerial de Transportes y Telecomunicaciones de Tarapac&#xE1;.</div></div>", "i": 9162439}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-22", "doble_articulado": false, "id_norma": "1028306", "numero_fuente": "40025", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-08-02", "vigencias": [{"desde": "201