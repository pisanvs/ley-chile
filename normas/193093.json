{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,283.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br><br></div>", "i": 8367073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se concede, por gracia, a la se&#xF1;ora Ester Ab&#xE9;, viuda del Archivero del Senado, don Eduardo P&#xE9;rez R., i a sus hijos menores, una pension mensual de doscientos pesos de que disfrutar&#xE1;n con arreglo a la Lei de Montep&#xED;o Militar.</div><br></div>", "i": 8367074}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como le&#xED; de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiuno de Setiembre de mil novecientos diecisiete.- Juan Luis Sanfuentes.- Ismael Tocornal.</div><br></div>", "i": 8367075}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3283", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3283"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-09-21", "doble_articulado": false, "id_norma": "193093", "numero_fuente": "11884", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-10-01", "vigencias": [{"desde": "1917-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1917-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1917-10-01", "fin_vigencia": "", "tipo_version": "3"}], 