{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6099733}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No.324 de 10 de julio de 1989, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes se autoriz&#xF3; a la Sucesi&#xF3;n Domingo Ghisoni Draghi, integrada por do&#xF1;a Sara Serafina Cvitanic Sapunar, do&#xF1;a Liliana Emilia Ghisoni Hutt, don Carlo Alberto Ghisoni Hutt y don Aldo Domingo Ghisoni Hutt, para efectuar servicio de transporte terrestre de pasajeros entre Osorno y Punta Arenas, en tr&#xE1;nsito por territorio argentino, el que se atender&#xE1; con dos frecuencias semanales, las que se efectuar&#xE1;n en los siguientes d&#xED;as:</div><div class=\"p\">Osorno - Punta Arenas: Martes - S&#xE1;bado Punta Arenas - Osorno: Mi&#xE9;rcoles - S&#xE1;bado.</div><br></div>", "i": 6099734}, {"t": "<div><div class=\"p\">Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6099735}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "324", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-324"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-10", "doble_articulado": false, "id_norma": "95353", "numero_fuente": "33468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-07", "vigencias": [{"desde": "1989-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig