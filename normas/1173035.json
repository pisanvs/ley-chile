{"html": [{"t": "<div><div class=\"p\">AUTORIZA A LA UNIVERSIDAD DE CHILE PARA EMITIR BOLETAS DE PRESTACI&#xD3;N DE SERVICIOS DE TERCEROS ELECTR&#xD3;NICAS EN LA FORMA QUE SE INDICA</div><br></div>", "i": 10313693}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 17 del 18 de febrero de 2022, que autoriza a Universidad de Chile, RUT N&#xBA; 80.910.000-1, para emitir Boletas de Prestaci&#xF3;n de Servicios de Terceros Electr&#xF3;nicas, en forma masiva, a contar del 1&#xBA; de marzo de 2022, siempre y cuando cumpla con los requisitos exigidos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10313694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Barraza Luengo, Director.</div><div class=\"p\"> </div><br></div>", "i": 10313695}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "17 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-17 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A LA UNIVERSIDAD DE CHILE PARA EMITIR BOLETAS DE PRESTACIÓN DE SERVICIOS DE TERCEROS ELECTRÓNICAS EN LA FORMA QUE SE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2090348", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-02-18", "doble_articulado": false, "id_norma": "1173035", "numero_fuente": "43187", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-02-24"