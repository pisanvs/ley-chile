{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7361989}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.597, de 19 de diciembre</div><div class=\"p\">de 2007, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA;</div><div class=\"p\">de la resoluci&#xF3;n exenta N&#xBA; 1.533, modificada por</div><div class=\"p\">resoluci&#xF3;n exenta N&#xBA; 2.729, ambas de 2007, de esta</div><div class=\"p\">Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD DE</div><div class=\"p\">ANTOFAGASTA para efectuar una pesca de investigaci&#xF3;n de</div><div class=\"p\">conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del</div><div class=\"p\">Proyecto denominado &quot;Seguimiento de la pesquer&#xED;a</div><div class=\"p\">artesanal de Anchoveta desarrollada por la flota artesanal, en sus &#xE1;reas de pesca y en la primera milla de la III Regi&#xF3;n, 2007&quot;, en el sentido de reemplazar a la embarcaci&#xF3;n artesanal &quot;Chelita I&quot; (RPA 1691) por la nave &quot;El Cid&quot; (RPA 950657).</div><br></div>", "i": 7361990}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de diciembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7361991}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3597 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3597 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-19", "doble_articulado": false, "id_norma": "268539",