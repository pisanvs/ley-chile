{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6272028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 81, de 09.12.87 de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a Dn. Manuel Santiago Arros Miranda, para efectuar todo tipo de servicios de Transportes de Pasajeros por calles y caminos, dentro del Territorio Nacional, a excepci&#xF3;n de los Servicios P&#xFA;blicos urbanos de Locomoci&#xF3;n Colectiva de Pasajeros. </div></div>", "i": 6272029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 09.12.87.- Juan Latife Saadi, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n (S).</div><br></div>", "i": 6272030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "81 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-81 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-09", "doble_articulado": false, "id_norma": "167677", "numero_fuente": "32943", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-12", "vigencias": [{"desde": "1987-12-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p