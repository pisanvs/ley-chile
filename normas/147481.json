{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8353330}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.287, de 29 de octubre de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;500, de 1997, de esta Subsecretar&#xED;a, en cuanto autoriz&#xF3; a la SOCIEDAD PESQUERA COLOSO S.A. para realizar actividades pesqueras extractivas con la nave &apos;&apos;Bandurria&apos;&apos; respecto de los recursos Anchoveta y Sardina espa&#xF1;ola, en el litoral de las III y IV Regiones, de conformidad con lo establecido en la letra b) del art&#xED;culo 143 del D.S. N&#xBA;430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8353331}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de octubre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8353332}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2287", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2287"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-29", "doble_articulado": false, "id_norma": "147481", "numero_fuente": "36512", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-12", "vigencias": [{"desde": "1999-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-11-12", "fin_vigencia": "", "tipo_ve