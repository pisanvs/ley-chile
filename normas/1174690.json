{"html": [{"t": "<div><div class=\"p\">DEJA SIN EFECTO RESOLUCIONES EXENTAS QUE INDICA</div></div>", "i": 10324437}, {"t": "<div><br><div class=\"p\"> </div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 715, de 7 de abril de 2022, de esta Subsecretar&#xED;a, d&#xE9;jese sin efecto las resoluciones exentas <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263274&amp;idVersion=2022-04-13\">N&#xB0; 2.228</a> y <a href=\"https://www.bcn.cl/leychile/navegar?idNorma=263265&amp;idVersion=2022-04-13\">N&#xB0; 2.220</a>, ambas de 2007, que autorizaron a Corpesca S.A., para realizar actividades extractivas en alta mar con las naves &quot;Angamos 2&quot;, matr&#xED;cula N&#xB0; 2486 y &quot;Angamos 4&quot; matr&#xED;cula N&#xB0; 2633, por configurarse la causal establecida en el art&#xED;culo 11.- letra a) del decreto supremo N&#xB0; 360, de 2005, del actual Ministerio de Econom&#xED;a, Fomento y Turismo.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br><br></div>", "i": 10324438, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de abril de 2022.- Julio Salas Guti&#xE9;rrez, Subsecretario de Pesca y Acuicultura.</div><div class=\"p\"> </div><br></div>", "i": 10324439}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "715 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-715 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIONES EXENTAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2112941", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-04-07", "doble_articula