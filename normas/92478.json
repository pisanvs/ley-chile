{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6091655}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta N&#xBA; 131 del 14 de enero de 1998, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, determin&#xF3; derechos aprovechamiento de aguas proporcionales que corresponden a Sector Excluido y a Sector Expropiado del predio &quot;Hijuela B del fundo El Batro, hoy La Paz&quot;, de la comuna de Casablanca, V Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Los derechos de aguas se extraen del Tranque Grande y de los derrames del Tranque El Manzano y de las aguas que escurren por las quebradas &quot;El Manzano&quot;, &quot;El Muelle&quot;, &quot;El Muelle Chico&quot;, &quot;Los C&#xF3;ndores&quot; y &quot;El Quillay&quot;.</div><br></div>", "i": 6091656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13 Ley N&#xB0; 18.377.- Director Nacional.</div><br></div>", "i": 6091657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "131 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-131 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHO DE APROVECHAMIENTO DE AGUAS", "CASABLANCA", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-14", "doble_articulado": false, "id_norma": "92478", "numero_fuente": "35980", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-02", "vigencias": [{"desde": "1998-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s":