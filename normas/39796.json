{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7202279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n exenta N&#xB0; 1.479 de 04.11.93, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se modific&#xF3; la Resoluci&#xF3;n Exenta N&#xB0; 529/89, que autoriz&#xF3; complementariamente a la empresa de origen argentino La Union del Sud Sociedad de Responsabilidad Limitada, para efectuar servicio internacional de transporte terrestre de pasajeros entre Zapala (Argentina) y Temuco (Chile), en el sentido de dejar establecido que esta Empresa queda autorizada para efectuar servicio de transporte de pasajeros entre Zapala-Neuqu&#xE9;n (Argentina) y Temuco-Concepci&#xF3;n (Chile) y viceversa, utilizando el paso fronterizo de Pino Hachado. La Empresa alternativamente, podr&#xE1; utilizar los pasos habilitados y situados al sur del mismo.- </div></div>", "i": 7202280}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. + </div></div>", "i": 7202281}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1479 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1479 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERVICIO PUBLICO TRANSPORTE PASAJEROS", "TRANSPORTE", "INTERNACIONAL", "UNION SUD SOCIEDAD RESPONSABILIDAD", "LIMITADA", "ZAPALA", "TEMUCO", "MODIFICACION", "AUTORIZACION", "PASO FRONTERIZO PINO HACHADO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-11-04", "doble_articulado": false, "id_norma": "39796", "numero_fuente":