{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,307, que suplementa el Presupuesto de Guerra.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,307.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7166543}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese un suplemento de cien mil pesos ($ 100,000) al &#xED;tem 68 de la partida 3.a del Presupuesto de Guerra vijente.</div><div class=\"p\">&nbsp; &nbsp; El gasto se deducir&#xE1; del producto del arrendamiento de terrenos fiscales de Magall&#xE1;nes.</div><br></div>", "i": 7166544}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado he tenido a bien aprobarlo i sancionarlo; por tanto prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago a veintidos de Setiembre de mil novecientos diecisiete.- JUAN LUIS SANFUENTES.- Pedro N. Montenegro. </div></div>", "i": 7166545}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3307", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3307"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEI NÚM. 3,307, QUE SUPLEMENTA EL PRESUPUESTO DE GUERRA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL DE LA NACION", "1917", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-09-22", "doble_articulado": false, "id_norma": "23885", "numero_fuente": "11878", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-09-24", "vigencias": [{"desde": "1917-09-24", "hasta": "", "tipo_version": "3", "tipo