{"html": [{"t": "<div><div class=\"p\">DESIGNA SUBSECRETARIO DE EDUCACION</div><div class=\"p\">N&#xFA;m. 470.- Santiago, 11 de marzo de 1990.- Visto: Lo dispuesto por el art&#xED;culo 32 No. 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile, Decreto:</div><br></div>", "i": 6087975}, {"t": "<div><div class=\"p\">Art&#xED;culo &#xFA;nico: Des&#xED;gnase a contar de esta fecha a Don Ra&#xFA;l Edgardo Allard Neumann en el cargo de Subsecretario de Educaci&#xF3;n P&#xFA;blica, quien por razones impostergables de buen servicio deber&#xE1; asumir de inmediato sus funciones. </div></div>", "i": 6087976}, {"t": "<div><div class=\"p\">An&#xF3;tese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- Ricardo Lagos Escobar, Ministro de Educaci&#xF3;n P&#xFA;blica.</div><div class=\"p\">Lo que comunico a Ud.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6087977}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "470", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-470"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DESIGNA SUBSECRETARIO DE EDUCACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-11", "doble_articulado": false, "id_norma": "91141", "numero_fuente": "33625", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-20", "vigencias": [{"desde": "1990-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-20", "fin_vigencia": ""}, "vigencias_version_norma"