{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DECRETO ALCALDICIO N&#xB0; 685, DE 23 DE AGOSTO DE 1994 </div></div>", "i": 5853188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.- Ex&#xED;mase del Pago de Derechos Municipales a las Construcciones de Vivienda financiadas por el Programa &quot;Densificaci&#xF3;n Habitacional&quot;, que se construye en la comuna de San Joaqu&#xED;n, por un plazo de 6 meses a contar de la publicaci&#xF3;n en el Diario Oficial.</div><div class=\"p\">&nbsp; &nbsp; 2.- Para el cumplimiento de lo se&#xF1;alado precedentemente se deber&#xE1; adjuntar el Certificado de Subsidio de &quot;Vivienda Progresiva I y II Etapa&quot;, y la superficie m&#xE1;xima que podr&#xE1; tener la construcci&#xF3;n ser&#xE1; de 24,25 mts2.</div><br></div>", "i": 5853189}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ram&#xF3;n Far&#xED;as Ponce, Alcalde Municipalidad de San Joaqu&#xED;n.</div><br></div>", "i": 5853190}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "685", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-685"}], "organismos": ["MUNICIPALIDAD DE SAN JOAQUÍN"], "titulo_norma": "DECRETO ALCALDICIO N° 685, DE 23 DE AGOSTO DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS MUNICIPALES", "MUNICIPALIDAD SAN JOAQUIN", "VIVIENDAS", "EXENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-08-23", "doble_articulado": false, "id_norma": "2580", "numero_fuente": "34965", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-09-13", "vigencias": [{"desde": "1994-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-09-13", "fin_vigencia": ""}, "vigencias_version_no