{"html": [{"t": "<div><br><div class=\"p\">EXIME A CONTRIBUYENTE DE TIMBRAJE DE PAGAR&#xC9;S Y FIJA REQUISITOS EN SU REEMPLAZO</div></div>", "i": 9104710}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 9, del 26 de enero de 2011, que exime a GMAC Comercial Automotriz Chile S.A. de la obligaci&#xF3;n de timbraje de pagar&#xE9;s establecida en el Art. 17 Inc. 2&#xBA; del D.L. N&#xBA; 3.475, de 1980, y fija requisitos en su reemplazo para resguardar el inter&#xE9;s fiscal.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2011.</div></div>", "i": 9104711}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-9 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXIME A CONTRIBUYENTE DE TIMBRAJE DE PAGARÉS Y FIJA REQUISITOS EN SU REEMPLAZO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-01-26", "doble_articulado": false, "id_norma": "1022461", "numero_fuente": "39873", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-31", "vigencias": [{"desde": "2011-01-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-01-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-01-31", "fin_vigenci