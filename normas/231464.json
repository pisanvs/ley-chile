{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 157, DE 2004 </div></div>", "i": 6501275}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 157 de 6 de julio de 2004, se han aprobado planes y programas experimentales de estudio a los establecimientos educacionales pertenecientes a la Fundaci&#xF3;n &quot;Padre Alvaro Lav&#xED;n&quot; del Hogar de Cristo para la Ense&#xF1;anza B&#xE1;sica, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2004.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en el presente decreto. </div></div>", "i": 6501276}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de octubre de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6501277}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "157", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-157"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 157, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-06", "doble_articulado": false, "id_norma": "231464", "numero_fuente": "37988", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-18", "vigencias": [{"desde": "2004-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ing