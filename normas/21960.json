{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Medidas contra el C&#xF3;lera Lei n&#xFA;m. 92.- Santiago, a 4 de Setiembre 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273713}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese hasta la suma de cincuenta mil pesos ($ 50,000) para la adopcion de medidas que tiendan a prevenir la propagacion de la epidemia del c&#xF3;lera.</div><br><br></div>", "i": 8273714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 8273715}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "92", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-92"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MEDIDAS CONTRA EL COLERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EPIDEMIAS", "COLERA", "PREVENCION", "FINANCIAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-09-04", "doble_articulado": false, "id_norma": "21960", "numero_fuente": "4612", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-09-04", "vigencias": [{"desde": "1893-09-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-09-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-09-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por