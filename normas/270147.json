{"html": [{"t": "<div><div class=\"p\">MODIFICA Y AUTORIZA TRANSFERENCIA DE CONCESI&#xD3;N DE ACUICULTURA </div></div>", "i": 7366675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n (M) 69, de 16 de enero de 2008, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div><br><div class=\"p\">&nbsp; &nbsp;  1.- Modif&#xED;case la resoluci&#xF3;n (M) N&#xBA;1449, de fecha 25 de julio de 2003, en la siguiente forma:</div><div class=\"p\">Reempl&#xE1;zase &#xED;ntegramente el numeral 4.- de la parte resolutiva, por el siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;4.- Esta concesi&#xF3;n de acuicultura se autoriza arrendar hasta el 1&#xBA; de noviembre del a&#xF1;o 2023&quot;. </div></div>", "i": 7366676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de marzo de 2008.- Por la Sra. Subsecretaria, Humberto Ram&#xED;rez Navarro, Subjefe Subsecretar&#xED;a de Marina.</div><br></div>", "i": 7366677}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "69", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-69"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "MODIFICA Y AUTORIZA TRANSFERENCIA DE CONCESIÓN DE\nACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-01-16", "doble_articulado": false, "id_norma": "270147", "numero_fuente": "39022", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-03-28", "vigencias": [{"desde": "2008-03-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-03-28", "fin_vigencia": ""}, "vigenc