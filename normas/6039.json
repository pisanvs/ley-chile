{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Except&#xFA;a disposiciones ley 5,005, mombramientos personal Superintendencia Salitre</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 386.- Santiago, 5 de Agosto de 1932.-</div><div class=\"p\">&nbsp; &nbsp; He acordado y dicto el siguiente Decreto-ley:</div><br></div>", "i": 7124010}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Decl&#xE1;rase que no regir&#xE1;n las disposiciones del</div><div class=\"p\">art&#xED;culo 6.o de la ley n&#xFA;mero 5,005, de 24 de Noviembre de 1931, para los efectos del nombramiento del personal de la Superintendencia del Salitre.</div><br></div>", "i": 7124011}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- CARLOS DAVILA.- Enrique Za&#xF1;artu P. </div></div>", "i": 7124012}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "386", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-386"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "EXCEPTUA DISPOSICIONES LEY 5,005, NOMBRAMIENTOS PERSONAL SUPERINTENDENCIA SALITRE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SUPERINTENDENCIA SALITRE", "PERSONAL", "NOMBRAMIENTOS", "VACANTES", "PROVEIMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-08-05", "doble_articulado": false, "id_norma": "6039", "numero_fuente": "16348", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-08-12", "vigencias": [{"desde": "1932-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-08-12", "fin_vigencia": ""}, "vigencias_v