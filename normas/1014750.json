{"html": [{"t": "<div><br><div class=\"p\">REANUDA FUNCIONAMIENTO DE JUNTAS INSCRIPTORAS QUE SE&#xD1;ALA Y MANTIENE SUSPENSI&#xD3;N DE OTRAS</div></div>", "i": 8935940}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Rean&#xFA;dase el funcionamiento a contar del d&#xED;a lunes 5 de julio de 2010, de las Juntas Inscriptoras de Olivar en la VI Regi&#xF3;n y de R&#xED;o Claro (Cumpeo) en la VII Regi&#xF3;n.</div><br><div class=\"p\">&nbsp; &nbsp;  Mant&#xE9;ngase la suspensi&#xF3;n para las Juntas Inscriptoras de Champa en la Regi&#xF3;n Metropolitana de Santiago; Constituci&#xF3;n, Parral, Pencahue, San Javier y Talca en la VII Regi&#xF3;n; y Dichato y Tir&#xFA;a en la VIII Regi&#xF3;n, hasta que se restablezcan las condiciones necesarias para su funcionamiento.</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n ordenada por resoluci&#xF3;n N&#xB0; O-1678 de 21 de junio de 2010.-</div><br></div>", "i": 8935941}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 8935942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1678", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1678"}, {"tipo": "3", "numero": "N° O-1678", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-N° O-1678"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "REANUDA FUNCIONAMIENTO DE JUNTAS INSCRIPTORAS QUE SEÑALA Y MANTIENE SUSPENSIÓN DE OTRAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-06-21", "doble_articulado": false, "id_norma": "1014750", "numero_fuente": "39694", "tipo_version": "3", "tipo_v