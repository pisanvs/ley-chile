{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede un suplemento al presupuesto del Interior.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1718.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente:</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274646}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese un suplemento de veinticinco mil pesos al &#xED;tem 3214, partida 89 del presupesto del Interior, para impresion del Diario Oficial i otras publicaciones.</div><br></div>", "i": 8274647}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 28 de Diciembre de 1904.- JERMAN RIESCO.- Emilio Bello C.</div><br></div>", "i": 8274648}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1718", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1718"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE UN SUPLEMENTO AL PRESUPUESTO DEL INTERIOR.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1904", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1904-12-28", "doble_articulado": false, "id_norma": "22873", "numero_fuente": "8095", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1904-12-28", "vigencias": [{"desde": "1904-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1904-12-28", "fin_vigencia": ""}, "vigencias_version_nor