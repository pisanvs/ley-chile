{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7168398}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1.o Desc&#xE1;rguense en las siguientes sumas los &#xED;tem que se indican del Presupuesto de Marina vigente:</div><div class=\"p\"> Cap&#xED;tulo VII, &#xED;tem 180... $ 100,000</div><div class=\"p\"> Cap&#xED;tulo XVII, &#xED;tem 459..&nbsp; &nbsp;  6,600</div><br></div>", "i": 7168399}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Aum&#xE9;ntese en la suma que se indica, el siguiente &#xED;tem:</div><div class=\"p\"> Cap&#xED;tulo XVI, &#xED;tem 434... $ 106,600 </div></div>", "i": 7168400}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta y uno de Diciembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez del Campo.- C.</div><div class=\"p\">O. Frodden.</div><br></div>", "i": 7168401}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4242", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4242"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1927", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-12-31", "doble_articulado": false, "id_norma": "24597", "numero_fuente": "14990", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-0