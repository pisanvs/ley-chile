{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7376642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.853, de 18 de julio de 2008, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 3.- de la resoluci&#xF3;n exenta N&#xBA; 905, de 2008, que autoriz&#xF3; a V &amp; P CONSULTORES EN RECURSOS NATURALES LIMITADA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Cambios temporales y espaciales en la alternancia de los recursos sardina com&#xFA;n y anchoveta, observados durante la temporada de pesca 2008, en la VIII Regi&#xF3;n: Georeferenciaci&#xF3;n, estructura de tallas y aspectos biol&#xF3;gicos&quot; en el sentido de extender el per&#xED;odo de ejecuci&#xF3;n de la pesca de investigaci&#xF3;n hasta el 9 de diciembre de 2008.</div><br></div>", "i": 7376643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7376644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1853 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1853 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-18", "doble_articulado": false, "id_norma": "275275", "numero_fuente": "39130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-08-05", "vigencias": [{"desde": "2008-08-05", "hasta": "", "tipo_version": "3", "tipo_version