{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,837, que autoriza la ereccion en Punta Arenas, de un monumento a don Waldo Seguel</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,837.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8276766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase a la Comision de Alcaldes de Magall&#xE1;nes para erijir, por suscricion popular, en la ciudad de Punta Arenas, un monumento a la memoria del ex-Juez Letrado del Territorio don Waldo Seguel.</div><br></div>", "i": 8276767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de Enero de 1922.- ARTURO ALESSANDRI.- Ismael Tocornal.</div><br></div>", "i": 8276768}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3837", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3837"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,837, QUE AUTORIZA LA ERECCION EN PUNTA ARENAS, DE UN MONUMENTO A DON WALDO SEGUEL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["WALDO SEGUEL", "PUNTA ARENAS", "MONUMENTO", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1922-01-19", "doble_articulado": false, "id_norma": "24285", "numero_fuente": "13200", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1922-02-13", "vigencias": [{"desde": "1922-02-13", "hasta": "", "ti