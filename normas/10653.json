{"html": [{"t": "<div><div class=\"p\">ACEPTA RENUNCIA VOLUNTARIA A CARGO QUE INDICA </div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 186.- Santiago, 24 de Mayo de 1995.- Vistos: Lo dispuesto por el Art&#xED;culo 32&#xB0;, N&#xB0; 9, de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp; D e c r e t o:</div><br><br></div>", "i": 5899221}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico: Ac&#xE9;ptase la renuncia voluntaria presentada por don Jorge Rosenblut Ratinoff, Rut.</div><div class=\"p\">6.243.657-3, al cargo de Subsecretario de Telecomunicaciones, a contar del 01 de junio de 1995. </div></div>", "i": 5899222}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- EDUARDO FREI RUIZ-TAGLE, Presidente de la Rep&#xFA;blica.- Narciso Irureta Aburto, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo para su conocimiento.- Saluda atentamente a Ud., Gregorio San Mart&#xED;n Ricci, Subsecretario de Telecomunicaciones.</div><br></div>", "i": 5899223}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "186", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-186"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TELECOMUNICACIONES"], "titulo_norma": "ACEPTA RENUNCIA VOLUNTARIA A CARGO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RENUNCIA VOLUNTARIA", "JORGE ROSENBLUT RATINOFF", "SUBSECRETARIA", "MINISTERIO TRANSPORTES TELECOMUNICACIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-24", "doble_articulado": false, "id_norma": "10653", "numero_fuente": "35188", "ti