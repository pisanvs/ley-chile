{"html": [{"t": "<div><div class=\"p\">&#xFEFF;&nbsp; &nbsp;  Pago de impuesto sobre licores</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Junio 2 de 1821.</div></div>", "i": 9927221}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Conforme a lo resuelto por el Excmo. Senado en acuerdo de esta fecha se declara, que por el de 26 de Enero de este a&#xF1;o se dej&#xF3; al arbitrio del cosechero el pagar el impuesto sobre licores o en dinero efectivo, i de ningun modo con las deudas contraidas, cuya indicacion se puso como fundamento de la decision. Sirva de adicion al Senado Consulto de 26 de Enero impreso en la Ministerial n&#xFA;m. 88.</div></div>", "i": 9927222}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon en la Contadur&#xED;a Mayor, Tesorer&#xED;a Jeneral, i comun&#xED;quese a la Intendencia.- O&apos;Higgins.- Dr. Rodr&#xED;guez.</div></div>", "i": 9927223}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Pago de impuesto sobre licores", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1821-06-02", "doble_articulado": false, "id_norma": "1117671", "numero_fuente": "1821", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1821-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1821-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1821-06-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "109697