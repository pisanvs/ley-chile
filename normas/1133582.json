{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xB0; 3.591 EXENTA, DEL 14 DE AGOSTO DE 2018</div></div>", "i": 10036043}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 3.120, del 28 de junio de 2019, del Director Nacional de Aduanas, se modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1122808&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 3.591, del 14 de agosto de 2018</a>, del mismo origen, sustituy&#xE9;ndose el numeral II, relativo a la fecha a partir de la cual se derogan las instrucciones que permiten la tramitaci&#xF3;n de una Declaraci&#xF3;n Almac&#xE9;n Particular de Importaci&#xF3;n para rotulaci&#xF3;n de calzado, en la forma que se indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).-</div></div>", "i": 10036044}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div></div>", "i": 10036045}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3120 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3120 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN N° 3.591 EXENTA, DEL 14 DE AGOSTO DE 2018", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1617971", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-06-28", "doble_articulado": false, "id_norma": "1133582", "numero_fuente": "42399", "tipo_version": "3", "tipo_version_s": "Única", "fecha_pub