{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8307318}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.448, de 31 de octubre de 1997,</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la</div><div class=\"p\">caducidad parcial, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de las siguientes Resoluciones: a) Resoluci&#xF3;n N&#xBA; 499 de 1994, en cuanto autoriz&#xF3; a&nbsp; SOCIEDAD PESQUERA COLOSO S.A., para operar la nave &quot;Costa Grande 5&quot; en el litoral de la III y IV Regiones; b) Resoluci&#xF3;n N&#xBA; 134 de 1995, en cuanto autoriz&#xF3; a Sociedad Pesquera Coloso S.A., para operar la nave &quot;Costa Grande 5&quot; en el litoral de la III y IV Regiones.</div><br></div>", "i": 8307319}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de octubre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8307320}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1448", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1448"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD PARCIAL", "AUTORIZACION", "PESCA", "SOCIEDAD PESQUERA COLOSO S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-10-30", "doble_articulado": false, "id_norma": "76852", "numero_fuente": "35911", "tipo_version": "2", "tipo_versi