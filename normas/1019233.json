{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9056060}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.336, de 4 de noviembre de 2010, de esta Subsecretar&#xED;a, modif&#xED;quese el numeral 1&#xBA; letra b) de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1014482&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.736 de 2010</a>, modificada mediante resoluciones exentas N&#xBA; 1810 y N&#xBA; 1893, ambas de 2010, todas de esta Subsecretar&#xED;a de Pesca, en el sentido de autorizar la distribuci&#xF3;n de 118 toneladas de Anchoveta y 187 toneladas de Sardina com&#xFA;n con cargo a la reserva establecida en el art&#xED;culo 2&#xBA; del decreto exento N&#xBA; 638 de 2010, del Ministerio de Econom&#xED;a, Fomento y Turismo, entre los beneficiarios individualizados en la resoluci&#xF3;n extractada.</div></div>", "i": 9056061}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de noviembre de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9056062}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3336 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3336 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-11-04", "doble_articulado": false, "id_norma": "1019233", "numero_fuente": "39807", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-11-11", "vigencias": [{"desde": "2010-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}