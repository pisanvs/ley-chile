{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8332108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 928, de 30 de junio de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 174, de 1998, de esta Subsecretar&#xED;a, que declar&#xF3; la caducidad de la resoluci&#xF3;n N&#xBA; 1.882 de 1989, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA MARBELLA LIMITADA (hoy Pesquera Marbella S.A.), para operar la nave &apos;&apos;Costa Grande 1&apos;&apos;, en el litoral de la III y IV Regiones, en virtud de haberse acreditado la operaci&#xF3;n de la se&#xF1;alada embarcaci&#xF3;n en el &#xE1;rea de pesca autorizada.</div><br></div>", "i": 8332109}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8332110}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "928", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-928"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MARBELLA LIMITADA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-06-30", "fecha_derogacion": "2001-01-26", "doble_articulado": false, "id_norma": "121801", "numero_fuente": "36121", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-07-23", "vigencias": [{"desde": "2001-01-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-07-23", "has