{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 466 EXENTO, DE 1998</div><br><br></div>", "i": 7232352}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 466 de fecha 27 de marzo de 1998 del Ministerio de Educaci&#xF3;n, se rectific&#xF3; el art&#xED;culo 1&#xBA; del decreto exento N&#xBA; 686 del 16 de diciembre de 1996, correspondiente a la Universidad de Ciencias de la Inform&#xE1;tica, inscrita en el Registro de Universidades C-N&#xBA; 32 de 1989, en el siguiente sentido:</div><div class=\"p\">Donde dice: &quot;Para ser impartidos a contar de 1995&quot;. Debe decir: &quot;Para ser impartido a contar desde 1997&quot;. </div></div>", "i": 7232353}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de abril de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7232354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "466 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-466 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 466 EXENTO, DE 1998", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD DE CIENCIAS DE LA INFORMATICA", "PROGRAMAS DE ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-03-27", "fecha_derogacion": "2020-01-01", "doble_articulado": false, "id_norma": "98180", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-04-23", "vigencias": [{"desde": "2020-01-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-04-23", "hasta": "2019-12-31", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_v