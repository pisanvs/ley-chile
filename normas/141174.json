{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA </div></div>", "i": 8348551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 492, de 13 de Mayo de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por un a&#xF1;o a contar del 28 de enero de 1988 el plazo fijado por el numera;</div><div class=\"p\">5&#xB0; de la resoluci&#xF3;n No. 56, de 1987, de esta Subsecretaria, que autoriz&#xF3; para desarrollar actividades pesqueras de cultivo a don Germ&#xE1;n Pedro Bueno Galaz, R.U.T. No. 7.129.760-8, con domicilio en Av. Salvador 615, Depto. 205, Providencia, Santiago, en raz&#xF3;n de haberse acreditado la ocurrencia de un caso fortuito. </div></div>", "i": 8348552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de Mayo de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8348553}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "492", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-492"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-13", "doble_articulado": false, "id_norma": "141174", "numero_fuente": "33081", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-27", "vigencias": [{"desde": "1988-05-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-05-27",