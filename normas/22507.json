{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Escuela de Bellas Artes Lei n&#xFA;m. 1,254.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de tres mil pesos en pagar las deudas pendientes de la Escuela de Bellas Artes i en atender a su servicio durante el a&#xF1;o 1899.</div><br><br></div>", "i": 5948706}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 19 de Agosto de 1899.- FEDERICO ERRAZURIZ.- Francisco J. Herboso.</div><br></div>", "i": 5948707}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1254", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1254"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "ESCUELA DE BELLAS ARTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ESCUELA BELLAS ARTES", "DEUDAS", "PAGO", "PRESIDENTE", "REPUBLICA", "FONDOS", "INVERSION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-08-19", "doble_articulado": false, "id_norma": "22507", "numero_fuente": "6381", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-08-23", "vigencias": [{"desde": "1899-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1899-08-23", "fin_vi