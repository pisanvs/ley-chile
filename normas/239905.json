{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6532158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.018, de 4 de julio de</div><div class=\"p\">2005, de esta Subsecretar&#xED;a, autor&#xED;zase a las</div><div class=\"p\">organizaciones de pescadores artesanales que se indica</div><div class=\"p\">en la resoluci&#xF3;n extractada, sometidas al R&#xE9;gimen</div><div class=\"p\">Artesanal de Extracci&#xF3;n en la unidad de pesquer&#xED;a de Merluza del sur de la XI Regi&#xF3;n, pertenecientes a la Flota Norte 1, a realizar actividades pesqueras extractivas durante el mes de julio, entre los d&#xED;as 4 a 7 de dicho mes, ambas fechas inclusive.</div><br></div>", "i": 6532159}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de julio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6532160}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2018 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2018 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-04", "doble_articulado": false, "id_norma": "239905", "numero_fuente": "38204", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-07", "vigencias": [{"desde": "2005-07-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-07", "fin_vigencia": "", "tipo_version": "3"}], "