{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTOS DE RESOLUCIONES </div></div>", "i": 8288967}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 753, de 27 de Junio 1991 de esta subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case la Resoluci&#xF3;n N&#xB0; 235, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA TUNQUEN S.A.; R.U.T. N&#xB0; 96.540.450-3, domiciliada en la ciudad de Santiago, para desarrollar actividades pesqueras en orden a operar una planta industrial en la IV Regi&#xF3;n, ubicada en la calle Baquedano N&#xB0; 802, Coquimbo, donde procesar&#xED;a en las l&#xED;neas de elaboraci&#xF3;n de salado y fresco, por renuncia de su titular. </div></div>", "i": 8288968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 27 de Junio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8288969}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "753", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-753"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "EXTRACTOS DE RESOLUCIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA TUNQUEN S.A.", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-27", "doble_articulado": false, "id_norma": "31652", "numero_fuente": "34013", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-10", "vigencias": [{"desde": "1991-07-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-07-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic