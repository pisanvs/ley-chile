{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6743160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 643, de 30 de octubre de 1995, se expropi&#xF3; el lote de terreno N&#xBA; 8, superficie 319 m2, rol de aval&#xFA;o 1165-35, comuna de Maip&#xFA;, para la obra Camino Autopista Santiago-San Antonio, sector Empalme I. Riquelme-Bif. Malloco y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Luis Alberto Vidal Avila, ascendente a la cantidad de $1.463.516. </div></div>", "i": 6743161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6743162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "643", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-643"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-30", "doble_articulado": false, "id_norma": "218631", "numero_fuente": "35331", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-01", "vigencias": [{"desde": "1995-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-12-15", "fecha_version": "1995-12-01", "fecha_actualizacion_texto": "1995-12-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6743160}, {"n": "Artí