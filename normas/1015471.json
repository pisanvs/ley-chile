{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 342 EXENTA, DE 2010</div></div>", "i": 8947180}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 342, del 18 de junio de 2010, la SEREMI MINVU Regi&#xF3;n de Coquimbo, sancion&#xF3; con una suspensi&#xF3;n de 1 a&#xF1;o de su calidad de Revisor Independiente de Obras de Edificaci&#xF3;n regida por la ley 20.071 al profesional arquitecto sr. Francisco Mandiola Lara, RUT 8.313.623-5. Ot&#xF3;rguese un plazo de 30 d&#xED;as contados de la fecha del presente extracto para recurrir a la comisi&#xF3;n de apelaciones del Registro.- </div></div>", "i": 8947181}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Secretario Regional Ministerial de Vivienda y Urbanismo Regi&#xF3;n de Coquimbo.</div></div>", "i": 8947182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "342 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-342 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN DE COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 342 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-06-18", "doble_articulado": false, "id_norma": "1015471", "numero_fuente": "39712", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-17", "vigencias": [{"desde": "2010-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-07-17", "fin_vigencia": "", "tipo_version": "3"}], "even