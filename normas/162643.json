{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6255957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluciones exentas N&#xB0;s 1441 de 10 de Octubre de 1984 y N&#xB0; 875 de 15 de Julio de 1985, conforme Art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a sector enajenado y sector expropiado predio: &quot;La Hiedra&quot; de la comuna de Renaico, IX Regi&#xF3;n; y derechos de aprovechamiento de aguas que corresponden a las parcelas N&#xB0; 1 a la 11, sitios N&#xB0; I al II, bienes comunes generales N&#xB0; 1 y 2 del proyecto de parcelaci&#xF3;n &quot;Campesinos Unidos&quot; formado por predio se&#xF1;alado. Los derechos de agua se extraen del Canal Santa Ana proveniente del Derivado Robler&#xED;a Norte. Publicaci&#xF3;n hecha conforme Art. 13 Ley N&#xB0; 18.377. </div></div>", "i": 6255958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6255959}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1441 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1441 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-10-10", "doble_articulado": false, "id_norma": "162643", "numero_fuente": "32237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-01", "vigencias": [{"desde": "1985-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08-01", "f