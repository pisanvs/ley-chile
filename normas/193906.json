{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div><br><br></div>", "i": 6366371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 109, de fecha 30 de noviembre del a&#xF1;o 2001, se aprob&#xF3; la reforma parcial al estatuto de la Cooperativa de Consumos Carabineros de Chile Limitada, en los t&#xE9;rminos que da testimonio la escritura p&#xFA;blica suscrita con fecha 13 de septiembre del a&#xF1;o 2001, ante el Notario de Santiago, don Gast&#xF3;n Iv&#xE1;n Santib&#xE1;&#xF1;ez Soto, Repertorio N&#xBA; 6169-2001. </div></div>", "i": 6366372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6366373}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "109", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-109"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "193906", "numero_fuente": "37164", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-19", "vigencias": [{"desde": "2002-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu