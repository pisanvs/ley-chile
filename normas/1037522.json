{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.200 EXENTA, DE 2011</div><br></div>", "i": 9238996}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.200, de 2 de noviembre de 2011, del Ministerio de Transportes y Telecomunicaciones, se rectific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1031513&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.981, de 2011</a>, de la misma autoridad, en el sentido de reemplazar en el punto 8.1.1, letra b, la frase &quot;noviembre de 2008&quot; por &quot;septiembre de 2011&quot;. Texto &#xED;ntegro se encuentra en la p&#xE1;gina web www.transantiago.gob.cl.- </div><br></div>", "i": 9238997}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Gloria Hutt Hesse, Ministra de Transportes y Telecomunicaciones (S). </div></div>", "i": 9238998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3200 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3200 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.200 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-11-02", "doble_articulado": false, "id_norma": "1037522", "numero_fuente": "40197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-02-25", "vigencias": [{"desde": "2012-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-02-25", "fin_vigenc