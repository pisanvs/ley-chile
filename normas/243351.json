{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.329 EXENTO, DE 2005 </div><br></div>", "i": 6545644}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto N&#xBA; 1.329 exento, de fecha 23 de septiembre de 2005, del Ministerio de Educaci&#xF3;n, se deja sin efecto la aprobaci&#xF3;n del plan y programas de estudios de la carrera de T&#xE9;cnico en Farmacia del Centro de Formaci&#xF3;n T&#xE9;cnica Crownliet, aprobada mediante decreto exento de Educaci&#xF3;n N&#xBA; 158, del 6 de marzo de 1995, a petici&#xF3;n de la propia entidad, por no haber sido impartida por un per&#xED;odo de m&#xE1;s cinco a&#xF1;os. Santiago, 18 de octubre de 2005.-</div><br></div>", "i": 6545645}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6545646}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1329 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1329 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.329 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-23", "doble_articulado": false, "id_norma": "243351", "numero_fuente": "38299", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-29", "vigencias": [{"desde": "2005-10-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-10-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-10-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "mod