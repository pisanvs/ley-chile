{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 821 EXENTO, DE 1998</div><br><br><br><br><br></div>", "i": 6132203}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 821, de fecha 7 de agosto de 1998, del Ministerio de Educaci&#xF3;n, se modific&#xF3; el decreto exento N&#xBA; 382 de 1998, correspondiente al Instituto Profesional Cepech, en el sentido de se&#xF1;alar que la carrera de Auditor&#xED;a (Jornada Vespertina) conducir&#xE1; al t&#xED;tulo profesional de Contador Auditor con salida intermedia conducente al t&#xED;tulo de T&#xE9;cnico de Nivel Superior de Contador General, para ser impartida en la ciudad de Santiago, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo. </div></div>", "i": 6132204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de agosto de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6132205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "821 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-821 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 821 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL CEPECH", "CARRERAS PROFESIONALES", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-07", "doble_articulado": false, "id_norma": "124927", "numero_fuente": "36173", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-26", "vigencias": [{"desde": "1998-09-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in