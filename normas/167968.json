{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA TRAFALGAR S.A. PARA DESARROLLAR ACTIVIDADES PESQUERAS </div></div>", "i": 7269109}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 268, de 13 de Mayo de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, pronunci&#xE1;ndose sobre presentaci&#xF3;n de 19 de Octubre de 1984, se autoriza a Pesquera Trafalgar S.A., domiciliada en Iquique, para operar la embarcaci&#xF3;n denominada &quot;Daslav&quot; en el litoral comprendido entre la I y la II Regi&#xF3;n, en faenas extractivas de jurel, sardina espa&#xF1;ola, caballa y anchoa.</div><br></div>", "i": 7269110}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de Mayo de 1985.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7269111}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "268", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-268"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA TRAFALGAR S.A. PARA DESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-13", "doble_articulado": false, "id_norma": "167968", "numero_fuente": "32176", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-05-22", "vigencias": [{"desde": "1985-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-05-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-05-22", "fin_vigencia": "", "tipo_version": "3"}], "