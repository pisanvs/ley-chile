{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Legacion en Uruguai i Paraguai Lei n&#xFA;m. 1,200.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir, por el presente a&#xF1;o, la suma necesaria para el mantenimiento de la Legacion en Uruguai i Paraguai, con el personal autorizado por la lei de presupuestos de 1898.</div><br><br></div>", "i": 5948579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 2 de Febrero de 1899.- FEDERICO ERRAZURIZ.- V. Blanco.</div><br></div>", "i": 5948580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1200", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1200"}], "organismos": ["MINISTERIO DE RELACIONES EXTERIORES, CULTO Y COLONIZACIÓN"], "titulo_norma": "LEGACION EN URUGUAI I PARAGUAI", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LEGACION", "URUGUAY", "PARAGUAY", "MANTENIMIENTO", "FONDOS", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-02-02", "doble_articulado": false, "id_norma": "22468", "numero_fuente": "6219", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-02-04", "vigencias": [{"desde": "1899-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"