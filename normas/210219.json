{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6696210}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante la resoluci&#xF3;n DGA N&#xBA; 4079 2002, el Director General de Aguas aprob&#xF3; el inventario p&#xFA;blico de extracciones autorizadas de aguas subterr&#xE1;neas de la Regi&#xF3;n de Antofagasta, dando as&#xED; cumplimiento a lo dispuesto en el Reglamento de Catastro P&#xFA;blico de Aguas. Dicha resoluci&#xF3;n se encuentra a disposici&#xF3;n de los interesados en las oficinas de la Direcci&#xF3;n Regional de Aguas (21 de Mayo 470, 2&#xBA; piso), en el Centro de Informaci&#xF3;n de Recursos H&#xED;dricos (Morand&#xE9; 59, 8&#xBA; piso, Santiago) y en la p&#xE1;gina web de la Direcci&#xF3;n General de Aguas (www.dga.cl).</div><br></div>", "i": 6696211}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4079", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4079"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "DIRECCIÓN GENERAL DE AGUAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGUAS SUBTERRANEAS", "SEGUNDA REGION", "INVENTARIO PUBLICO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO SIN PROMULGACION NI FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "210219", "numero_fuente": "37559", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-15", "vigencias": [{"desde": "2003-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_