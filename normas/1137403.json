{"html": [{"t": "<div><div class=\"p\">HOSPITAL DE MUJERES</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 10 de 1824.</div></div>", "i": 10064925}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Considerando que la continuada enfermedad de D. Estanislao Portales no le permite asistir personalmente al Hospital de mujeres que se halla a su cargo, por cuyo motivo ha decaido notablemente el servicio de este asilo de la humanidad; he venido en encargar provisoriamente el cuidado y asistencia de dicho hospital, a D. Manuel Ortuzar, mientras el expresado D. Estanislao se ponga en estado de poder asistirlo personalmente. Comun&#xED;quese e ins&#xE9;rtese en el Boletin.</div></div>", "i": 10064926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Ega&#xF1;a.</div></div>", "i": 10064927}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "HOSPITAL DE MUJERES", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1824-02-10", "doble_articulado": false, "id_norma": "1137403", "numero_fuente": "1824", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1824-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1824-02-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1824-02-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2019-10-24", "fecha_version": "1824-02-10", "fecha