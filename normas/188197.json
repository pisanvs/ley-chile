{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6344668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA; 948 de fecha 29 de junio del 2001, se expropiaron los lotes de terreno N&#xBA;s. 3 y 4, superficie 434 m&#xB2; y 991 m&#xB2;, respectivamente, rol de aval&#xFA;o N&#xBA; 148-29, comuna de Pemuco, para la obra &quot;Canal Matriz Pemuco - Diguill&#xED;n, Variante Camino Pemuco - Cartago, del Proyecto Laja Diguill&#xED;n&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Hugo Benedicto Fuentes Herrera, ascendente a la cantidad de $497.511.- </div></div>", "i": 6344669}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6344670}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "948 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-948 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-06-29", "doble_articulado": false, "id_norma": "188197", "numero_fuente": "37026", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-01", "vigencias": [{"desde": "2001-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2001-08-01", "fecha_version": "2001-08-01", "fecha_actualizacion_texto": "2001-08-01", "t