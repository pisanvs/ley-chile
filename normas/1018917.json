{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9028141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;1964, de fecha 30 de septiembre del 2010, se expropi&#xF3; el lote de terreno N&#xB0;s. 111 y 114, superficies 4.870 y 525 m2, respectivamente Rol N&#xBA;183-5, comuna de Arauco, VIII Regi&#xF3;n para la obra Camino Ruta P-40, Sector Arauco - Quiapo, Km. 15,96000 a Km. 31,00000, Regi&#xF3;n del B&#xED;o B&#xED;o, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario SILVOAGROPECUARIA FORESTAS REGNANS LIMITADA, ascendente a la cantidad de $4.503.834.- </div></div>", "i": 9028142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9028143}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1964 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1964 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-09-30", "doble_articulado": false, "id_norma": "1018917", "numero_fuente": "39799", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-11-02", "vigencias": [{"desde": "2010-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2010-11-03", "fecha_version": "2010-11-02", "actualizado_por": "98", "fecha_actual