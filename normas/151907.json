{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6221140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 782, de fecha 03 de Julio 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Luis H. Valenzuela D&#xED;az, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6221141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de Julio de 1987.- Carlos Rorn&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6221142}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "782 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-782 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-03", "doble_articulado": false, "id_norma": "151907", "numero_fuente": "32842", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-08-10", "vigencias": [{"desde": "1987-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-08-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-08-10", "fin_vigencia": "", "tipo_version": "