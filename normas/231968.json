{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6503079}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 541, de 6 de octubre de 2004, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme DL N&#xBA; 2.186, de 1978, del Lote N&#xBA; 27, correspondiente al inmueble ubicado en calle Suiza N&#xBA; 422, V. Suiza, Rol de aval&#xFA;o N&#xBA; 555-11, comuna de Cerrillos, de dominio de Ricardo Alberto Ossa Olivares y Mar&#xED;a Luisa Olivares Romero. Comisi&#xF3;n integrada por peritos Ram&#xF3;n Domingo Labarca, ingeniero civil; Patricia Zavala Contreras, constructor civil, y Fresia Mora Lepe, arquitecto, seg&#xFA;n informe de fecha 31 de marzo de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $31.314.920, pagadera al contado, cantidad aceptada por los propietarios.- </div></div>", "i": 6503080}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6503081}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "541", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-541"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "DISPONE EXPROPIACIONES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-06", "doble_articulado": false, "id_norma": "231968", "numero_fuente": "38000", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-02", "vigencias": [{"desde": "2004-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni