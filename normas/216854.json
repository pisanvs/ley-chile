{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6447012}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.510, de 15 de octubre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA EL GOLFO S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Polaris II&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a la Isla de Pascua, Islas Sala y G&#xF3;mez, Islas Desventuradas y Archipi&#xE9;lago de Juan Fern&#xE1;ndez, con palangre, donde podr&#xE1; capturar, por fuera del &#xE1;rea de reserva artesanal, los siguientes recursos hidrobiol&#xF3;gicos: At&#xFA;n aleta amarilla, At&#xFA;n aleta larga, At&#xFA;n ojos grandes, Bonito, Marrajo o tibur&#xF3;n, Tollo, At&#xFA;n chauchera, Marlin rayado, At&#xFA;n aleta azul, Azulejo, Marlin trompa corta, Marlin negro, Marlin azul o zuncho. </div></div>", "i": 6447013}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6447014}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2510 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2510 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-10-15", "fecha_derogacion": "2016-12-27", "doble_articulado": false, "id_norma": "216854", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-11-05", "vigencias": [{"desde": "2016-12-27", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2003