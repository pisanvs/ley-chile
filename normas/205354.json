{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6405223}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;65 del 26.11.02 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rech&#xE1;zase el recurso de reclamaci&#xF3;n interpuesto por SOCIEDAD PESQUERA IRINA LTDA. y por Pesquera Isladamas S.A., en contra de la resoluci&#xF3;n N&#xBA;1.126 de 2001 de la Subsecretar&#xED;a de Pesca, por no haberse acreditado fehacientemente la improcedencia de la aplicaci&#xF3;n de la sanci&#xF3;n establecida por dicha resoluci&#xF3;n en relaci&#xF3;n con la nave &quot;Lonquimay&quot;, de conformidad con lo dispuesto en el art&#xED;culo 12 inciso 4&#xBA; de la ley N&#xBA;19.713. </div></div>", "i": 6405224}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6405225}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "65 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-65 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-26", "doble_articulado": false, "id_norma": "205354", "numero_fuente": "37427", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-06", "vigencias": [{"desde": "2002-12-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendi