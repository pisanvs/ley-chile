{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 53, DE 1989</div><br><br></div>", "i": 6097659}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 53 de 27 de marzo de 1989 se ha aprobado a la Escuela Especial F No. 103 de Cha&#xF1;aral, de la III Regi&#xF3;n de Atacama, un plan de estudio especial de orientaci&#xF3;n laboral para alumnos con deficiencia mental, que se desarrollar&#xE1; con car&#xE1;cter experimental por un per&#xED;odo de 4 a&#xF1;os, a contar desde el a&#xF1;o escolar 1989. </div></div>", "i": 6097660}, {"t": "<div><div class=\"p\">Santiago, 12 de Abril de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6097661}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "53 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-53 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 53, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-04-12", "doble_articulado": false, "id_norma": "94629", "numero_fuente": "33357", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-26", "vigencias": [{"desde": "1989-04-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-04-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "1998-03-06", "fecha_version": "1989-04-26", "fecha_actualizacion_texto"