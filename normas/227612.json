{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6487608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 327 de 14 de junio de 2004 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 281 correspondiente a parte del inmueble ubicado en Michelson 504, presunto rol de aval&#xFA;o N&#xBA; 4140-15, comuna de San Miguel, aparente dominio de Inostroza Vda. de Ar&#xE1;nguiz Laura. Comisi&#xF3;n integrada por peritos Miguel Ortiz Bobadilla, Constructor Civil; Jimena Asenjo Burgos, Arquitecto y Pedro Almonacid Colin, Ingeniero Civil. Seg&#xFA;n informe de 30 de septiembre de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $35.525.610 pagadera al contado. </div></div>", "i": 6487609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6487610}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "327", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-327"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-14", "doble_articulado": false, "id_norma": "227612", "numero_fuente": "37910", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-15", "vigencias": [{"desde": "2004-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004