{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.397 EXENTO, DE 2005 </div></div>", "i": 6552518}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.397, fecha 30 septiembre de 2005 del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas al plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Diego Portales, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 2005, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera&nbsp;  :&nbsp; Asistente del Educador Diferencial con</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  menci&#xF3;n Deficiencia Mental y/o Trastornos</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Espec&#xED;ficos del Aprendizaje; cambia por:</div><div class=\"p\">Carrera&nbsp;  :&nbsp; Asistente T&#xE9;cnico del Educador Diferencial.</div><div class=\"p\">T&#xED;tulo&nbsp; &nbsp; :&nbsp; Asistente T&#xE9;cnico del Educador Diferencial</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (DEX. N&#xBA;83 del 04.03.94)</div><br></div>", "i": 6552519}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de noviembre de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6552520}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1397 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1397 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.397 EXENTO, DE 2005", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-09-30", "fecha_derogacion": "