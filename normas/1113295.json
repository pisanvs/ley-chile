{"html": [{"t": "<div><br><div class=\"p\">INFORMA SOBRE LA OBLIGACI&#xD3;N DE INSCRIPCI&#xD3;N EN EL REGISTRO DE TASADORES</div></div>", "i": 9872616}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Los profesionales ingeniero agr&#xF3;nomo, forestal o civil, que se describen en la resoluci&#xF3;n, podr&#xE1;n incorporarse en el Registro de Tasadores que lleva este Servicio, en la forma que se indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2018.</div></div>", "i": 9872617}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-1 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "INFORMA SOBRE LA OBLIGACIÓN DE INSCRIPCIÓN EN EL REGISTRO DE TASADORES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1330883; EXTRACTO; NORMA SIN FECHA DE PROMULGACIÓN NI PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1113295", "numero_fuente": "41950", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-01-06", "vigencias": [{"desde": "2018-01-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-01-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2018-01-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fe