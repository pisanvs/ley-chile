{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO NUMERO 86 EXENTO, DE 1994 </div></div>", "i": 8603698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 86 de fecha 4 de Marzo de 1994 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios Tur&#xED;sticos CET, las adecuaciones introducidas al plan y programas de estudios de la carrera de Administraci&#xF3;n de Hoteles y Restoranes, las que se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 517 de 1985. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1994.</div><br></div>", "i": 8603699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de Abril de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8603700}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "86 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-86 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO NUMERO 86 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "CENTRO ESTUDIOS TURISTICOS", "CET", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-03-04", "doble_articulado": false, "id_norma": "20095", "numero_fuente": "34915-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-07-15", "vigencias": [{"desde": "1994-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-07-15",