{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON MAX DIDIER VALDES PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 7263083}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 140, de 17 de Febrero de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Max Didier Vald&#xE9;s, c&#xE9;dula de identidad No. 6.934.323-6, de la Serena, domiciliado en Avenida Costanera sin Guanaqueros, para instalar y operar un establecimiento de cultivo de ostra del Pac&#xED;fico, en un&nbsp; rea de 30.000 m2 ubicada en Bah&#xED;a Guanaqueros, comuna de Coquimbo, Provincia de Elqui, IV Regi&#xF3;n.</div><br></div>", "i": 7263084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de Febrero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7263085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "140", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-140"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A DON MAX DIDIER VALDES PARA DESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-02-17", "fecha_derogacion": "1995-05-27", "doble_articulado": false, "id_norma": "158374", "numero_fuente": "32425", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-03-18", "vigencias": [{"desde": "1995-05-27", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-03-18", "hasta": "1995-05-26", "tipo_version": "0", "tipo_vers