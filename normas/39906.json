{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION EXENTA N&#xB0; 1680, DE 1991 </div></div>", "i": 6025312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xB0; 1680 de fecha 4 de Junio de 1991 del Ministerio de Educaci&#xF3;n, se declar&#xF3; que no se concede el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica CEYFOS organizado por la Sociedad Castillo y Jara Compa&#xF1;&#xED;a Ltda., ubicado en calle 21 de Mayo N&#xB0; 303 de Arica.</div><div class=\"p\">&nbsp; &nbsp; Por este mismo cuerpo legal, se elimin&#xF3; del libro de registro de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xB0; 211 de fecha 22 de octubre de 1990, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica CEYFOS de Arica.-</div><br></div>", "i": 6025313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6025314}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1680 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1680 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 1680, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA CEYFOS", "ARICA", "RECONOCIMIENTO OFICIAL", "REVOCACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-06-04", "doble_articulado": false, "id_norma": "39906", "numero_fuente": "34024", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-07-23", "vigencias": [{"desde": "1991-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-07-23", "fin_vigencia": ""}