{"html": [{"t": "<div><div class=\"p\">COMISARIA DE MAESTRANZA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 8 de 1828.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div><br><br></div>", "i": 10237570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0; Queda suprimida la Comisar&#xED;a de maestranza.</div><br><br></div>", "i": 10237571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; El Comisario de la misma pasar&#xE1; a la jeneral del ej&#xE9;rcito, a continuar sus servicios en clase de auxiliar debiendo el Inspector jeneral proponer los demas empleados de dicha oficina, segun el m&#xE9;rito y aptitud de cada una, para ser colocados segun convenga.</div><div class=\"p\">&nbsp; &nbsp;  El Ministro de la Guerra queda encargado del cumplimiento de este decreto del que se tomar&#xE1; razon, comunicar&#xE1; a quien corresponda y dispondr&#xE1; se imprima.</div><br><br></div>", "i": 10237572}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PINTO&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Obejero.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Pro-secretario.</div></div>", "i": 10237573}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE LA GUERRA"], "titulo_norma": "COMISARIA DE MAESTRANZA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1828-03-08", "doble_articulado": false, "id_norma": "1155973", "numero_fuente": "1828", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1828-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1828-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1828-03-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-06-04", "fecha_version": "1828-03-08", "fecha_actualizacion_texto": "2021-06-04", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10237570}, {"n": "Artículo 1°", "i": 10237571, "t": 6}, {"n": "Artículo 2°", "i": 10237572, "t": 6}, {"n": "Promulgación", "i": 10237573}]}