{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 193, DE 1988 </div></div>", "i": 7228748}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 193 de 14 de Diciembre de 1988 se ha modificado, a contar del a&#xF1;o escolar 1989, el decreto supremo-exento de Educaci&#xF3;n No. 235 de 1983, que aprob&#xF3; un plan especial de estudio al Liceo Experimental &quot;Manuel de Salas&quot; de Santiago, en la forma que indica el presente decreto.</div><br></div>", "i": 7228749}, {"t": "<div><div class=\"p\">Santiago, 03 de Enero de 1989.-</div><div class=\"p\">Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7228750}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "193 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-193 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 193, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-14", "doble_articulado": false, "id_norma": "94490", "numero_fuente": "33314", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-04", "vigencias": [{"desde": "1989-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "ALV", "fecha_ingreso": "1998-03-06", "fecha_version": "1989-03-04", "fecha_actualizacion_texto": "1989-03-04", "tip