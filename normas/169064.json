{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6276548}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 190, de 09 de octubre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a Hugo Espinoza Orellana, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6276549}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n de Atacama.</div><br></div>", "i": 6276550}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "190 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-190 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-09", "doble_articulado": false, "id_norma": "169064", "numero_fuente": "32909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-02", "vigencias": [{"desde": "1987-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "v