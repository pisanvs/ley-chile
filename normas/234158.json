{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6511054}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;842 de fecha 13 de diciembre de 2004 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n, conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 261 correspondiente al inmueble ubicado en Pir&#xE1;mide N&#xBA; 511, presunto rol de aval&#xFA;o N&#xBA; 4940-68, comuna de San Miguel, aparente dominio de Ra&#xFA;l Humberto Gonz&#xE1;lez Guzm&#xE1;n. Comisi&#xF3;n integrada por peritos Victoria Blanco Costa, arquitecto; Ver&#xF3;nica Olivier Valdebenito, arquitecto, y Nicol&#xE1;s Romero Morales, Ingeniero Comercial. Seg&#xFA;n informe de 20 de septiembre de 2004, fij&#xF3; monto provisional de indemnizaci&#xF3;n en $29.796.150.- pagadera al contado.</div><br><br></div>", "i": 6511055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Director Serviu Metropolitano.</div><br></div>", "i": 6511056}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "842", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-842"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-13", "doble_articulado": false, "id_norma": "234158", "numero_fuente": "38050", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-03", "vigencias": [{"desde": "2005-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ú