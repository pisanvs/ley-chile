{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8327227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 51 de 19 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o, a contar del 30 de septiembre de 1997, el plazo otorgado a don ANDRES JAVIER GUARACHE GOMEZ, para continuar operaciones pesqueras con la nave &quot;La Chimba&quot;, Matr&#xED;cula 2360, autorizada por las resoluciones N&#xBA; 1.149 de 1994 y N&#xBA; 669 de 1997, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 8327228, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so,19 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8327229}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "51", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-51"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "ANDRES JAVIER GUARACHE GOMEZ", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-01-19", "fecha_derogacion": "1999-11-18", "doble_articulado": false, "id_norma": "96319", "numero_fuente": "35990", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-02-13", "vigencias": [{"desde": "1999-11-18", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-02-13", "hasta": "1999-11-17", "tipo_version": "0", "tipo_version_s