{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6275513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.063, de 30 de marzo del 2000, se expropi&#xF3; el lote de terreno N&#xBA;3-A, superficie 960 m2, rol de aval&#xFA;o 312-36, comuna de Freire, para la obra Concesi&#xF3;n Internacional Ruta 5; Tramo:</div><div class=\"p\">Collipulli-Temuco, Novena Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Manuel Ernesto Villalba Cerda, ascendente a la cantidad de $4.292.891. </div></div>", "i": 6275514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6275515}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1063", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1063"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-30", "doble_articulado": false, "id_norma": "168735", "numero_fuente": "36663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-15", "vigencias": [{"desde": "2000-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2000-05-16", "fecha_version": "2000-05-15", "fecha_actualizacion_texto": "2000-05-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezad