{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;mero 4,500</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6210943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al archivero del Ministerio de Fomento, don Camilo Ulloa G&#xF3;mez, el goce de una pensi&#xF3;n de jubilaci&#xF3;n de quince mil pesos ($ 15,000). </div></div>", "i": 6210944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y, por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veinte de Diciembre de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez C.- Luis Schmidt. </div></div>", "i": 6210945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4500", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4500"}], "organismos": ["MINISTERIO DE FOMENTO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-12-20", "doble_articulado": false, "id_norma": "149042", "numero_fuente": "15254", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-12-21", "vigencias": [{"desde": "1928-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-12-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "