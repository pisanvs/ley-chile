{"html": [{"t": "<div><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 9122558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.910 de 15 de marzo del 2011, se public&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1023691&amp;idParte=0&amp;idVersion=\">Decreto Alcaldicio N&#xFA;m.494</a>, donde MODIFICA ORDENANZA SOBRE DERECHOS, CONCESIONES, PERMISOS Y SERVICIOS QUE INDICA , con los errores que se salvan a continuaci&#xF3;n: Primer Cuerpo, p&#xE1;gina tres, primera columna, donde dice &quot;... N&#xFA;m.494.- La Reina, 8 de marzo de 2010.- ...&quot; debe decir &quot;... N&#xFA;m.494.- La Reina, 8 de marzo de 2011.- ...&quot; y donde dice &quot; ... Decreto: 1.- Modificase la Ordenanza de la comuna de La Reina sobre derechos, concesiones, permisos y servicios, ... &quot; debe decir &quot;... Decreto: 1.- Rectif&#xED;case la Ordenanza de la comuna de La Reina sobre derechos, concesiones, permisos y servicios, ... &quot;.</div><br></div>", "i": 9122559, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "S/N", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-S/N"}], "organismos": ["MUNICIPALIDAD DE LA REINA"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1023804", "numero_fuente": "39911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-03-16", "vigencias": [{"desde": "2011-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci