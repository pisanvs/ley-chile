{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CREA, EN LA PLANTA DE OFICIALES DEL EJERCITO, CUARENTA PLAZAS DE CAPITANES DE ARMAS</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5963539}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;.- Cr&#xE9;anse, en la Planta de Oficiales del Ej&#xE9;rcito, cuarenta plazas de Capitanes de Armas. </div></div>", "i": 5963540}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2&#xB0;.- La presente ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial&quot;.</div><br></div>", "i": 5963541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y, por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, once de Septiembre de mil novecientos cuarenta y dos.- JUAN ANTONIO RIOS M.- A. Duhalde V. </div></div>", "i": 5963542}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "7279", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-7279"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL"], "titulo_norma": "CREA, EN LA PLANTA DE OFICIALES DEL EJERCITO,\nCUARENTA PLAZAS DE CAPITANES DE ARMAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CREACION", "PLANTA DE OFICIALES DEL EJERCITO", "CAPITANES DE ARMAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1942-09-11", "doble_articulado": false, "id_norma": "25470", "numero_fuente": "19358", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1942-09-12", "vigencias": [{"desde": "1942-09-12", "h