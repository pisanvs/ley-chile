{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6253688}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 430 de 14 de Abril de 1986, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n se autoriza a don Eduardo Antonio Campos Sep&#xFA;lveda para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6253689}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel Goloma Amaro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule. </div></div>", "i": 6253690}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "430 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-430 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-14", "doble_articulado": false, "id_norma": "161903", "numero_fuente": "32452", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-21", "vigencias": [{"desde": "1986-04-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-04-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-04-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [],