{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div><br></div>", "i": 8847581}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de enero de 2010, fue de 2,91% anual.</div><br></div>", "i": 8847582}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de enero de 2010.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 8847583}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-01-21", "doble_articulado": false, "id_norma": "1010377", "numero_fuente": "39567", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-01-22", "vigencias": [{"desde": "2010-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-01-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "3721", "fecha_ingreso": "2010-01-22", "fecha_version": "2010-01-22", "actualizado_por": "3721", "fecha_actualizacion_texto": "2010-01-22", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Enc