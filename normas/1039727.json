{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.009 EXENTA, DE 2012</div></div>", "i": 9254955}, {"t": "<div><br><div class=\"p\">Mediante resoluci&#xF3;n exenta N&#xBA; 4.009, de 25 de abril de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Sociedad de Capacitaci&#xF3;n Prima Limitada (Prima Capacitaci&#xF3;n)&quot;, RUT 76.012.842-2 contenida en la resoluci&#xF3;n exenta N&#xBA; 4.399 de 20 de junio de 2008, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9254956}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (PT).</div></div>", "i": 9254957}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4009 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4009 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 4.009 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-04-25", "doble_articulado": false, "id_norma": "1039727", "numero_fuente": "40256", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-05-08", "vigencias": [{"desde": "2012-05-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-05-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-05-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu