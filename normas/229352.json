{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6493188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.030, de 3 de agosto de</div><div class=\"p\">2004, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA LOTA</div><div class=\"p\">VEDDE LIMITADA ARIES Y COMPA&#xD1;IA C.P.A. para ampliar</div><div class=\"p\">actividades pesqueras extractivas con la nave &quot;La Ni&#xF1;a</div><div class=\"p\">I&quot;, en el &#xE1;rea mar&#xED;tima de las Regiones V, VI, VII, IX y</div><div class=\"p\">X, donde podr&#xE1; capturar, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, los siguientes recursos hidrobiol&#xF3;gicos: Sardina espa&#xF1;ola, Jurel fino, Sardina redonda, Agujilla, Bonito, Bacaladillo o mote, Cojinoba del norte, Cojinoba del sur, Dorado, Machuelo, Palometa, Anchoa blanca o Samasa y Vinciguerria.</div><br></div>", "i": 6493189}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6493190}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2030 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2030 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-08-03", "fecha_derogacion": "2005-02-21", "doble_articulado": false, "id_norma": "229352", "numero_fuente": "37940", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-08-19", "vigencias": [{"desde": "2005-02-21", "hasta": "",