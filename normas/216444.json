{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7304907}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.368, de 8 de octubre de 2003, de esta Subsecretar&#xED;a, modif&#xED;canse el numeral 3&#xBA; de la resoluci&#xF3;n N&#xBA; 350 de 1981, y el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 213 de 2000, ambas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA EL GOLFO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Mait&#xE9;n&quot;, en el sentido de incorporar y actualizar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">T.R.G. (Nacional)&nbsp; &nbsp; &nbsp; 150,48 t</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 6,70 m</div><br></div>", "i": 7304908}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de octubre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7304909}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2368 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2368 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-10-08", "fecha_derogacion": "2004-11-30", "doble_articulado": false, "id_norma": "216444", "numero_fuente": "37698", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-10-30", "vigencias": [{"desde": "2004-11-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"de