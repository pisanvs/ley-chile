{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6265307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 848 de fecha 02 de Diciembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a la Empresa de Transportes F&#xE9;nix Pullman Norte Limitada, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6265308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 09 de Diciembre de 1985.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial, Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6265309}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "848 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-848 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-12-02", "doble_articulado": false, "id_norma": "165657", "numero_fuente": "32355", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-24", "vigencias": [{"desde": "1985-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-24