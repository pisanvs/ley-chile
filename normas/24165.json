{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,674, que concede un ausilio al Hospital de Calbuco.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,674.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276615}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para ausiliar con la suma de tres mil pesos ($ 3,000) al Hospital de Calbuco a fin de que pueda verificar sus mas urjentes reparaciones.</div><br></div>", "i": 8276616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a siete de Octubre de mil novecientos veinte.- JUAN LUIS SANFUENTES.- Pedro Garcia de la Huerta.</div><br></div>", "i": 8276617}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3674", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3674"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3,674, QUE CONCEDE UN AUSILIO AL HOSPITAL DE CALBUCO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["HOSPITAL", "CALBUCO", "REPARACIONES", "AUXILIO", "CONSECION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1920-10-07", "doble_articulado": false, "id_norma": "24165", "numero_fuente": "12797", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1920-10-15", "vigencias": [{"desde": "1920-10-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia"