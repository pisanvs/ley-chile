{"html": [{"t": "<div><div class=\"p\">MINISTRO DE GUERRA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 4 de 1832.</div></div>", "i": 10249876}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Hall&#xE1;ndose vacante el empleo de Ministro de Estado en los departamentos de Guerra y Marina, vengo en nombrar, para que lo desempe&#xF1;e el gobernador interino de la plaza de Valpara&#xED;so, Coronel graduado don Ramon de la Cavareda, de cuya probidad y aptitudes estoi plenamente satisfecho.</div></div>", "i": 10249877}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese razon, publ&#xED;quese y circ&#xFA;lese.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  PRIETO. </div><div class=\"p\">&nbsp; &nbsp;  Joaquin Tocornal.</div></div>", "i": 10249878}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "MINISTRO DE GUERRA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-12-04", "doble_articulado": false, "id_norma": "1161852", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-12-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "17616", "fecha_ingreso": "2021-07-09", "fecha_version": "1832-12-04", "fecha_actualizacion_texto": "2021-07-09", "tipo_tratado": ""},