{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ley n&#xFA;m. 173.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 7162551}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. La participaci&#xF3;n que se concede a los empleados de las Aduanas de la Rep&#xFA;blica en el producido del impuesto por la ley n&#xFA;mero 121 de 18 de Noviembre de 1893, no podr&#xE1; exceder del treinta por ciento (30%) del sueldo que &#xE1; cada uno de ellos asigna a ley.</div><br></div>", "i": 7162552, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, o&#xED;do el Consejo de Estado, he tenido &#xE1; bien aprobarlo y sancionarlo; por tanto, ordeno se promulgu&#xE9; y lleve a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a quince de Enero de mil ochocientos noventa y cuatro.- JORGE MONTT.- Alejandro Vial.</div><br></div>", "i": 7162553}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "173", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-173"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "GRATIFICACION A LOS EMPLEADOS DE LAS ADUANAS.-SE FIJA UN MAXIMUN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADUANAS", "EMPLEADOS", "GRATIFICACION", "FIJACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-15", "doble_articulado": false, "id_norma"