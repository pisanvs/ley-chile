{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6474289}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 928, de&nbsp; 6 de abril de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SERVICIOS LOGISTICOS GASTRONOMICOS S.A., hoy R&#xED;o Puelo Comercial S.A., para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Villarrica N&#xBA; 311, Quilicura, Regi&#xF3;n Metropolitana, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n de Cocido, Fresco-enfriado y Fresco-refrigerado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6474290}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de abril de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6474291}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "928 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-928 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-04-06", "fecha_derogacion": "2005-04-08", "doble_articulado": false, "id_norma": "223944", "numero_fuente": "37839", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-04-19", "vigencias": [{"desde": "2005-04-08", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2004-04-19", "hasta": "2005-04-07", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2005-04-08", "fin_v