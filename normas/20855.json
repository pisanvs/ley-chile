{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 271 EXENTO, DE 1995 </div></div>", "i": 5943363}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 271 de fecha 2 de mayo de 1995, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica INACAP, las adecuaciones introducidas a los planes y programas de estudios de las carreras de Administraci&#xF3;n Industrial con menci&#xF3;n en Producci&#xF3;n y Abastecimiento y de Programaci&#xF3;n de Computadores, las que se insertaron en el Decreto Exento del Ministerio de Educaci&#xF3;n N&#xB0; 311 de 1991. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1995.</div><br></div>", "i": 5943364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 26 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943365}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "271 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-271 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 271 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INACAP", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-02", "doble_articulado": false, "id_norma": "20855", "numero_fuente": "35201", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-24", "vigencias": [{"desde": "1995-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-06-24",