{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE MACHAL&#xCD; </div></div>", "i": 6631543}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero, mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 5.866, del 20 de noviembre de 2007, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, determin&#xF3; la distribuci&#xF3;n de los derechos de aprovechamiento de agua del predio &quot;Los Chacayes&quot;, de la comuna de Machal&#xED;, VI Regi&#xF3;n, que provienen del canal Los Cipreses, expresados en unidad de volumen por unidad de tiempo y estableciendo que dichos derechos son consuntivos, de ejercicio permanente y continuo.</div><br><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; ley N&#xBA; 18.377.</div><br></div>", "i": 6631544}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Nacional (S).</div><br></div>", "i": 6631545}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5866 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5866 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE MACHALÍ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-20", "doble_articulado": false, "id_norma": "267022", "numero_fuente": "38926", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-01", "vigencias": [{"desde": "2007-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-01", "fin_vigencia": ""}, "vi