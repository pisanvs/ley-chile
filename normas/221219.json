{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6464440}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.263, de 31 de octubre de 2003, se dej&#xF3; sin efecto los decretos MOP N&#xBA; 406, de 26 de febrero de 1999, en lo que respecta a la expropiaci&#xF3;n de los lotes de terreno N&#xBA; s. 37 y 45-A; y N&#xBA; 3.438, de 16 de noviembre de 1999, que autoriz&#xF3; la consignaci&#xF3;n judicial de los lotes 37 y 45-A, correspondiente a la obra &quot;Camino Ruta O-60, Sector Monte&#xE1;guila - Yumbel Kms.</div><div class=\"p\">6.639 al 17.531,11&quot;. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA; 2.186, de 1978.</div><br></div>", "i": 6464441}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6464442}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1263", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1263"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-31", "doble_articulado": false, "id_norma": "221219", "numero_fuente": "37787", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-16", "vigencias": [{"desde": "2004-02-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "ur