{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 540 EXENTA, DE 2004 </div></div>", "i": 6529370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Con fecha 6 de junio de 2005, se dict&#xF3; resoluci&#xF3;n N&#xBA; Ex. 2.115 por la Directora Regional de la V Direcci&#xF3;n Regional Valpara&#xED;so, por la cual se deja sin efecto delegaci&#xF3;n de facultades efectuada en el funcionario Patricio Dom&#xED;nguez Figueroa mediante Res. Ex. 540 de 25-</div><div class=\"p\">10-2004. La misma resoluci&#xF3;n delega dichas facultades en la funcionaria Yolanda Campuzano Toro, t&#xE9;cnico fiscalizador grado 15&#xB0;, RUT N&#xBA; 7.054.777-5. </div></div>", "i": 6529371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Erica Morales Lartiga, Directora Regional. </div></div>", "i": 6529372}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2115 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2115 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "MODIFICA RESOLUCION Nº 540 EXENTA, DE 2004", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-06-06", "fecha_derogacion": "2009-04-30", "doble_articulado": false, "id_norma": "239060", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-06-11", "vigencias": [{"desde": "2009-04-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-06-11", "hasta": "2009-04-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2009-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vi