{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Municipalidad del Olivar i de Malloa Lei n&#xFA;m. 1,245.- Santiago, a 28 de Agosto de 1899.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Autor&#xED;zase a las Municipalidades del Olivar i de Malloa, del Departamento de Caupolican, para que cobren la contribucion de haberes en la parte que corresponda al segundo semestre del presente a&#xF1;o, con arreglo al aval&#xFA;o que riji&#xF3; en el a&#xF1;o pr&#xF3;ximo pasado.</div><br><br></div>", "i": 8274197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- Federico Err&#xE1;zuriz.- R. Silva Cruz.</div><br></div>", "i": 8274198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1245", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1245"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MUNICIPALIDAD DEL OLIVAR I DE MALLOA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD", "EL OLIVAR", "MALLOA", "CONTRIBUCIONES", "COBRO", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1899-08-28", "doble_articulado": false, "id_norma": "22498", "numero_fuente": "6385", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1899-08-28", "vigencias": [{"desde": "1899-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "