{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA N&#xFA;m. 32.- Santiago, 8 de Febrero de 1994.- Vistos: Lo dispuesto en el Art. 4&#xB0; del Decreto Ley N&#xB0; 2.974 de 1979</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br><br></div>", "i": 8957544}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Ministro de Fe para actuar en las<div class=\"n rnp\" id=\"rnp0\"><a href=\"#np0\">NOTA:</a></div> localidades ubicadas en la IV Regi&#xF3;n, en que no hayan Notarios ni Oficiales del Registro Civil, al siguiente funcionario: Vicente Rivera Lucero.</div><br><div class=\"np\" id=\"np0\"><a href=\"#rnp0\">NOTA:</a> <br>&nbsp; &nbsp;  La RES 32, Agricultura, publicada el 13.05.2000 modific&#xF3; la presente resoluci&#xF3;n en el sentido de eliminar a don Vicente Rivera Lucero como Ministro de Fe.<br></div></div>", "i": 8957545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Encargado de Oficina de Partes.</div><br></div>", "i": 8957546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "32", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-32"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO MINISTRO DE FE A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VICENTE RIVERA LUCERO", "MINISTRO FE", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-02-08", "doble_articulado": false, "id_norma": "32406", "numero_fuente": "