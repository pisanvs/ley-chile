{"html": [{"t": "<div><div class=\"p\">CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA EN LAS VENTAS DE MADERA </div></div>", "i": 6637579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VII Direcci&#xF3;n Regional Talca, del SII, por resoluci&#xF3;n exenta N&#xBA; 242, de 16 de enero de 2008, concede a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n y en forma indefinida, a Sociedad Oro Verde Limitada, RUT N&#xBA; 76.329.670-9, la calidad de Agente Retenedor del Impuesto al Valor Agregado en las ventas de madera, de acuerdo a la facultad establecida en la Res. Ex. N&#xBA; 4916/2000 de la Direcci&#xF3;n Nacional. </div></div>", "i": 6637580}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Talca, 16 de enero de 2008.- Mirtha Barra Paredes, Directora Regional.</div><br></div>", "i": 6637581}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "242 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-242 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VII DIRECCIÓN REGIONAL DE TALCA"], "titulo_norma": "CONCEDE CALIDAD DE AGENTE RETENEDOR DEL IVA EN LAS\nVENTAS DE MADERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-01-16", "doble_articulado": false, "id_norma": "268791", "numero_fuente": "38968", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-01-23", "vigencias": [{"desde": "2008-01-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-01-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-01-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p