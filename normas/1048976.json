{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9334227}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 376, de 8 de febrero de 2013, de esta Subsecretar&#xED;a, autor&#xED;zase a PESCA CHILE S.A. para ampliar actividades pesqueras extractivas con la nave f&#xE1;brica en construcci&#xF3;n &quot;BEC N&#xBA; 82/12&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 47&#xBA; LS y 57&#xBA; LS, por fuera de las l&#xED;neas de base recta, con palangre, los siguientes recursos hidrobiol&#xF3;gicos: Cabrilla com&#xFA;n, Cabrilla y Pejerrata o Granadero.</div></div>", "i": 9334228}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de febrero de 2013.- Maximiliano Alarma Carrasco, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9334229}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "376 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-376 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-02-08", "fecha_derogacion": "2014-10-28", "doble_articulado": false, "id_norma": "1048976", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-02-20", "vigencias": [{"desde": "2014-10-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2013-02-20", "hasta": "2014-10-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-10-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "201