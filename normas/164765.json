{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 12.882 EXENTA, DE 1999 </div></div>", "i": 6262601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 12.882, de 29 de diciembre de 1999, se ha aprobado al colegio &apos;&apos;The Mayflower School&apos;&apos; de Santiago, un plan y programa especial de estudio biling&#xFC;e, para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media, el que se aplicar&#xE1;, en ambos cursos, a partir del a&#xF1;o escolar 2000, seg&#xFA;n el decreto supremo de Educaci&#xF3;n N&#xBA; 220, de 1998, y sus modificaciones. </div></div>", "i": 6262602}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de marzo de 2000.- Juan Eduardo Garc&#xED;a-Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6262603}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12882 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12882 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 12.882 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "164765", "numero_fuente": "36636", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-10", "vigencias": [{"desde": "2000-04-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION