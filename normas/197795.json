{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 195 EXENTO, DE 2002 </div></div>", "i": 6380471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 195 de fecha 14 de marzo de 2002 del Ministerio de Educaci&#xF3;n, se autoriza a las sedes que se indican del Centro de Formaci&#xF3;n T&#xE9;cnica Centro Interamericano de Educaci&#xF3;n y Cultura CIDEC, para impartir plan y programas de estudios aprobados para la instituci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se se&#xF1;ala, a partir del a&#xF1;o 2002:</div><br><br><div class=\"p\">Sede N&#xBA; 1 - Antofagasta, N&#xBA; 15 - Valdivia y N&#xBA; 13 de Punta Arenas</div><br><div class=\"p\">Carrera&nbsp; : Asistente Ejecutivo</div><div class=\"p\">T&#xED;tulo&nbsp;  : Asistente Ejecutivo de Nivel Superior</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (Decreto exento N&#xBA; 572 del 27.08.01).</div><br></div>", "i": 6380472}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de abril de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6380473}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "195 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-195 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 195 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-14", "doble_articulado": false, "id_norma": "197795", "numero_fuente": "37252", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-07", "vigencias": [{"desde": "2002-05-07", "hasta": "", "tip