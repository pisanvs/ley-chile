{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION 203, DE 1983 </div></div>", "i": 8542674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 109, de 25 de Febrero de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 3&#xB0; de la resoluci&#xF3;n 203, de 10 de Junio de 1983, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a don Juan Ojeda Aguila, para operar una planta elaboradora de recursos hidrobiol&#xF3;gicos, en las l&#xED;neas de fresco y congelado en Punta Arenas, en el sentido de incluir los recursos raya y loco, entre las especies que puede utilizar como materia prima, en la elaboraci&#xF3;n de los productos mencionados.</div><br></div>", "i": 8542675}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de Febrero de 1985.- Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito, Subsecretario de Pesca Subrogante.</div><br></div>", "i": 8542676}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "109", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-109"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION 203, DE 1983", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-25", "doble_articulado": false, "id_norma": "157759", "numero_fuente": "32124", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-21", "vigencias": [{"desde": "1985-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-21", "fin_vigencia": ""}, "vigencias_version_