{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329908}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluc&#xF3;n N&#xBA; 629, de 4 de mayo de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto las resoluciones N&#xBA; 1.119 de 1989 y N&#xBA; 276 de 1994, ambas de esta Subsecretar&#xED;a, que autorizaron a TULIO HUMBERTO BARRIENTOS AVENDA&#xD1;O&nbsp; para instalar y operar un centro de cultivo ubicado en la Caleta Curahue, Estero Huildad, comuna de Quell&#xF3;n, X Regi&#xF3;n, por haberse puesto t&#xE9;rmino a la respectiva resoluci&#xF3;n de concesi&#xF3;n de acuicultura. </div></div>", "i": 8329909}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329910}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "629", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-629"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "QUELLON", "TULIO HUMBERTO BARRIENTOS AVENDA O", "DECIMA REGION", "DEROGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-04", "doble_articulado": false, "id_norma": "98909", "numero_fuente": "36063", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-05-13", "vigencias": [{"desde": "1998-05-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-05-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig