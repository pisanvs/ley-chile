{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL QUE INDICA </div></div>", "i": 6402349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 41, de 4 de Febrero de 1983, del</div><div class=\"p\">Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n se</div><div class=\"p\">cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n</div><div class=\"p\">Gremial de Due&#xF1;os de Camiones de Transporte Mar&#xED;timo y</div><div class=\"p\">Portuario de los Puertos de Penco y Lirqu&#xE9;n&quot;, inscrita</div><div class=\"p\">bajo el N&#xB0; 282 del Registro de Asociaciones Gremiales</div><div class=\"p\">por haberse configurado la causal contemplada en el</div><div class=\"p\">art&#xED;culo 18&#xB0; N&#xB0; 2 letra a) del decreto ley N&#xB0; 2.757, de 1979.</div><br></div>", "i": 6402350}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de Febrero de 1983.- Manuel Ren&#xE9; Concha Mart&#xED;nez, Coronel de Ej&#xE9;rcito, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6402351}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-41"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE\nASOCIACION GREMIAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1983-02-04", "doble_articulado": false, "id_norma": "204420", "numero_fuente": "31502", "tipo_version": "3", "tipo_