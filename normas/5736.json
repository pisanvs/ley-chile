{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Modifica Item Presupuesto Hacienda</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 86.- Santiago, 23 de junio de 1932.- La Junta de Gobierno ha acordado y dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; Decreto-ley:</div><br></div>", "i": 7123244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.o Suplem&#xE9;ntase el &#xED;tem 06-01-04-v, imprevistos de Hacienda, en la suma de $ 1.000,000.</div><div class=\"p\">&nbsp; &nbsp; 2.o Ded&#xFA;zcase esta cantidad de los &#xED;tem 02-01-03 y 02-02-03 en las sumas de $ 250,000 y $ 750,000, respectivamente, consultadas en el Presupuesto vigente. </div></div>", "i": 7123245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Refr&#xE9;ndese, t&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese.- CARLOS DAVILA.- Nolasco C&#xE1;rdenas.- A. Cabero.- J. Antonio R&#xED;os M.- Enrique Za&#xF1;artu P. </div></div>", "i": 7123246}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "86", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-86"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Modifica Item Presupuesto Hacienda", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1932", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-06-23", "doble_articulado": false, "id_norma": "5736", "numero_fuente": "16312", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-07-01", "vigencias": [{"desde": "1932-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-07-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-07-0