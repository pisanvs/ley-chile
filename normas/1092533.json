{"html": [{"t": "<div><br><div class=\"p\">MODIFICACIONES AL R&#xC9;GIMEN TRIBUTARIO DEL ART. 14 TER DE LA LEY SOBRE IMPUESTO A LA RENTA</div></div>", "i": 9715001}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xBA; 43, de fecha 11 de julio de 2016, que imparte instrucciones sobre las modificaciones efectuadas por <a href=\"https://www.leychile.cl/Navegar?idNorma=1067194&amp;idParte=0&amp;idVersion=\">ley 20.780</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1087342&amp;idParte=0&amp;idVersion=\">ley 20.899</a>, al r&#xE9;gimen tributario de las micro, peque&#xF1;as y medianas empresas, a partir del a&#xF1;o comercial 2017.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en el mes de julio, de 2016.</div></div>", "i": 9715002}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "43", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-43"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICACIONES AL RÉGIMEN TRIBUTARIO DEL ART. 14 TER DE LA LEY SOBRE IMPUESTO A LA RENTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1042449; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-07-11", "doble_articulado": false, "id_norma": "1092533", "numero_fuente": "41508", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-07-14", "vigencias": [{"desde": "2016-07-14", "hasta": "", "tipo_version":