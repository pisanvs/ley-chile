{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br></div>", "i": 8341401}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 591, de 15 de Junio de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2 de la resoluci&#xF3;n No. 226, de 03 de marzo de 1988, en el siguiente sentido: Donde dice &quot;un &#xE1;rea de 10.000 m2 de fondo de r&#xED;o&quot;, debe decir &quot;un &#xE1;rea de 100.000 m2 de fondo de r&#xED;o&quot;. </div></div>", "i": 8341402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de Junio de 1988.- Roberto Cabezas Bello Subsecretario de Pesca.</div><br></div>", "i": 8341403}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "591", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-591"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-06-15", "fecha_derogacion": "1989-12-18", "doble_articulado": false, "id_norma": "132271", "numero_fuente": "33101", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-06-21", "vigencias": [{"desde": "1989-12-18", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1988-06-21", "hasta": "1989-12-17", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1989-12-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-06-21", "fin_vigencia": "1989-12-17", "tipo_