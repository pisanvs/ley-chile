{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6202974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 18, de 15 de Abril de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n, se autoriza a la L&#xED;nea de Taxibuses Villa Triana Lourdes, para efectuar la prolongaci&#xF3;n de su Servicio por las calles que se indican: Federico Slater y Avda. Provincial de la Poblaci&#xF3;n Irene Frei de Rancagua, ida y regreso por las mismas calles, retornando a su recorrido habitual. </div></div>", "i": 6202975}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Rancagua, 15 de Abril de 1987.- Rigoberto G&#xF3;mez Lavin, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 6202976}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-18 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-04-15", "doble_articulado": false, "id_norma": "147045", "numero_fuente": "32752", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-22", "vigencias": [{"desde": "1987-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1