{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6077093}, {"t": "<div><div class=\"p\">El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de mayo de 1991, fue de 5,49% anual.</div><br></div>", "i": 6077094}, {"t": "<div><div class=\"p\">Santiago, 17 de mayo de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 6077095}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-05-17", "doble_articulado": false, "id_norma": "87745", "numero_fuente": "33971", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-05-18", "vigencias": [{"desde": "1991-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-05-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-05-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PGA", "fecha_ingreso": "1998-02-04", "fecha_version": "1991-05-18", "fecha_actualizacion_texto": "1991-05-18", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6077093}, {"n": "Artículo", "i": 6077094, "t": 6}, {"n": "Promu