{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 295 EXENTO, DE 2003</div><br><br></div>", "i": 6424690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;295 de 29 de abril de 2003, se ha aprobado a la Escuela &quot;San Antonio de Padua&quot; (Ex E N&#xBA;39), de Ollag&#xFC;e, II Regi&#xF3;n de Antofagasta, un plan de estudio biling&#xFC;e para 1&#xBA; y 2&#xBA; a&#xF1;o (NB. 1) de Ense&#xF1;anza B&#xE1;sica, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2003.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en el presente decreto. </div></div>", "i": 6424691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de mayo de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6424692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "295 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-295 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 295 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-04-29", "doble_articulado": false, "id_norma": "210612", "numero_fuente": "37567", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-05-26", "vigencias": [{"desde": "2003-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-05-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-05-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi