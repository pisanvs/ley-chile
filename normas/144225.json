{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6193570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 22, de 26 de Enero de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n, ha autorizado a don Gast&#xF3;n Alexis Rivera Espinoza, para efectuar toda clase de servicios de transporte de pasajeros, por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos de locomoci&#xF3;n colectiva urbanos, de acuerdo a lo dispuesto en el DS 163184.</div><br></div>", "i": 6193571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Temuco, 26 de Enero de 1987.- Oscar C&#xF3;rdova Jim&#xE9;nez, Secretario Regional Ministerial de Transportes y Telecomunicaciones IX Regi&#xF3;n.</div><br></div>", "i": 6193572}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "22", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-22"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-01-26", "doble_articulado": false, "id_norma": "144225", "numero_fuente": "32688", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-02-03", "vigencias": [{"desde": "1987-02-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-02-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-02-03", "fin_vigencia": "", "tipo_versio