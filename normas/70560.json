{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 340 EXENTO, DE 1997 </div></div>", "i": 6034185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento N&#xBA; 340 de fecha 20 de marzo de 1997 del Ministerio de Educaci&#xF3;n, se revoc&#xF3; el reconocimiento oficial y se elimin&#xF3; del Registro de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xBA; 217, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica La Serena, de la ciudad de La Serena, organizado por la Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica La Serena Ltda., dej&#xE1;ndose sin efecto el Decreto Exento de Educaci&#xF3;n N&#xBA; 101 del 20 de abril de 1992.</div><br></div>", "i": 6034186}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Santiago, 8 de abril de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6034187}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "340 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-340 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 340 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELIMINACION", "REGISTRO DE CENTROS DE FORMACION TECNICA", "CENTRO DE FORMACION TECNICA LA SERENA", "LA SERENA", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-20", "doble_articulado": false, "id_norma": "70560", "numero_fuente": "11.04.1997", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-11", "vigencias": [{"desde": "1997-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-11", "fin_vigencia": ""}, "vigencias_version_n