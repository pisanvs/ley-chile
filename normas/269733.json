{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7365514}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 517, de 22 de febrero de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a JUAN CARLOS ROMERO PINTO para iniciar actividades pesqueras transformaci&#xF3;n, para instalar y operar planta en quebrada Las Ca&#xF1;as, Comunidad Agr&#xED;cola Cuesta El Manzano, Coquimbo, para elaborar en l&#xED;neas proceso harina, aceite y harina de desechos, recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto resoluci&#xF3;n N&#xBA; 2.946, de 2007, de esta Subsecretar&#xED;a, en virtud del contenido de la presente resoluci&#xF3;n.</div><br></div>", "i": 7365515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de febrero de 2008.- Hiram Villagra Castro, Subsecretario de Pesca (S).</div><br></div>", "i": 7365516}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "517 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-517 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-02-22", "doble_articulado": false, "id_norma": "269733", "numero_fuente": "39007", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-03-08", "vigencias": [{"desde": "2008-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2