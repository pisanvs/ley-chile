{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,736.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8345773}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por el guardian tercero de la Polic&#xED;a de Seguridad de Santiago, don Manuel Molina Vergara, se le concede, por gracia, el derecho a retirarse del servicio de esa polic&#xED;a con una pension igual al sueldo de que actualmente goza. </div></div>", "i": 8345774}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, ocho de enero de mil novecientos trece.- Ramon Barros Luco.- Guillermo Barros.</div><br></div>", "i": 8345775}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2736", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2736"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-01-08", "doble_articulado": false, "id_norma": "137961", "numero_fuente": "10480", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-01-18", "vigencias": [{"desde": "1913-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-01-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1913-01-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_p