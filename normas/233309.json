{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6508086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta N&#xBA; 3.437, de 1 de diciembre de 2004, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 2.244 de 1999, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESCA CHILE S.A., para ampliar las actividades pesqueras extractivas con la nave &quot;Tuamapu&quot;, entre la I y III Regiones y entre los paralelos 41&#xBA;28,6&apos; L.S. y 47&#xB0;L.S., con palangre, sobre el recurso Besugo, y entre el paralelo 41&#xBA;28,6&apos; L.S. y el l&#xED;mite sur de la X Regi&#xF3;n, con palangre, sobre el recurso Reineta, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, de conformidad con lo informado mediante memoranda citada en Visto.</div><br></div>", "i": 6508087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de diciembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6508088}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3437 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3437 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-01", "doble_articulado": false, "id_norma": "233309", "numero_fuente": "38031", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-09", "vigencias": [{"desde": "2004-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "