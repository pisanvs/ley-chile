{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  EXTRACTO DE RESOLUCION </div></div>", "i": 6220023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 643, de 24 de Septiembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n, se autoriza a do&#xF1;a Esther del Carmen Mendoza S&#xE1;ez, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6220024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6220025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "643 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-643 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-24", "doble_articulado": false, "id_norma": "151529", "numero_fuente": "32.585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-01", "vigencias": [{"desde": "1986-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion