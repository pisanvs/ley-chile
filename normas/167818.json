{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6272626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 451, del 04 de Diciembre de 1987 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Primera Regi&#xF3;n Tarapac&#xE1;, se autoriza a Lidia Cataldo Uriona e Isa&#xED;as del Rosario Solar Salas para efectuar el servicio p&#xFA;blico urbano de locomoci&#xF3;n colectiva de pasajeros L&#xED;nea No. 9 de taxibuses de Iquique, cuyo trazado fue autorizado por resoluci&#xF3;n No. 313, del 26 de Agosto de 1987, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6272627}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Eliecer Aedo Rivera, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n Tarapac&#xE1;.</div><br></div>", "i": 6272628}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "451 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-451 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-12-04", "doble_articulado": false, "id_norma": "167818", "numero_fuente": "32945", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-15", "vigencias": [{"desde": "1987-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient