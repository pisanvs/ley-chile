{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 658 EXENTO, DE 2001 </div></div>", "i": 6389255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 658, de fecha 13 de septiembre de 2001, se declara aprobada a la Universidad Internacional Sek la modificaci&#xF3;n al Plan y a los Programas de estudio de la carrera de Derecho que se imparte en jornada diurna y vespertina en su sede de Santiago. Dicha aprobaci&#xF3;n rige a contar del 19 de julio de 2001, fecha del Certificado N&#xBA; 19/2001 extendido por el Consejo Superior de Educaci&#xF3;n. </div></div>", "i": 6389256}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de octubre de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6389257}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "658 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-658 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 658 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-13", "doble_articulado": false, "id_norma": "200554", "numero_fuente": "37309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-07-16", "vigencias": [{"desde": "2002-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2002-07-16", "fecha_version": "2002-07-16