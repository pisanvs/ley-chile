{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6253679}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 21 de 17 de Abril de 1986 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se autoriza a don Fernando Orueta Ansoleaga para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6253680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 16 de Abril de 1986.- Juan Latife Seadi, Secretario Regional Ministerial de Transportes y Telecomunicaciones, VI Regi&#xF3;n (S).</div><br></div>", "i": 6253681}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "21 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-21 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-17", "doble_articulado": false, "id_norma": "161900", "numero_fuente": "32452", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-21", "vigencias": [{"desde": "1986-04-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-04-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-04-21", "fin_vigencia": "", "tipo_versi