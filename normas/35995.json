{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8295156}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 997, de 26 de Octubre de 1994, de esta Subsecretar&#xED;a del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case la Resoluci&#xF3;n N&#xB0; 1374, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don ALFREDO EMILIANO CARCAMO GALINDO, para operar un establecimiento de cultivo ubicado en Punta Tep&#xFA;n, Isla Cail&#xED;n, Comuna de Quell&#xF3;n, Provincia de Chilo&#xE9;, X Regi&#xF3;n, en virtud de lo dispuesto en el art&#xED;culo 7&#xB0; del D.S. N&#xB0; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8295157}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Octubre de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8295158}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "997", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-997"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "ACUICULTURA", "ALFREDO", "EMILIANO CARCAMO GALINDO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-10-26", "doble_articulado": false, "id_norma": "35995", "numero_fuente": "35008", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-11-05", "vigencias": [{"desde": "1994-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vig