{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 407 EXENTO, DE 2000 </div></div>", "i": 6306269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 407 de fecha 29 de septiembre de 2000 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; a la Universidad Alberto Hurtado, el plan y los programas de estudio de la carrera de Psicolog&#xED;a, conducente al t&#xED;tulo profesional de Psic&#xF3;logo y al grado acad&#xE9;mico de Licenciado en Psicolog&#xED;a, para ser impartida a contar del a&#xF1;o 2001 en jornada diurna, en su Sede de la ciudad de Santiago, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo. </div></div>", "i": 6306270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de octubre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6306271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "407 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-407 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 407 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-29", "doble_articulado": false, "id_norma": "177008", "numero_fuente": "36799", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-28", "vigencias": [{"desde": "2000-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient