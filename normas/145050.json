{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 3.350, DE 1986 </div></div>", "i": 7254510}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n exenta de Educaci&#xF3;n No. 3.350 de fecha 09 de diciembre de 1986, del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se modific&#xF3; el art. 1&#xB0; de la Resoluci&#xF3;n Exenta de Educaci&#xF3;n No. 1.019 de 1985, en el sentido de introducir nueva red secuencial de asignaturas en las carreras que se indican, aplic&#xE1;ndose desde el a&#xF1;o 1986, en el Centro de Formaci&#xF3;n T&#xE9;cnica ESANE del Norte:</div><br><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; Administraci&#xF3;n de Empresas.</div><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; Programaci&#xF3;n de Aplicaciones.</div><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; An&#xE1;lisis de Sistemas.</div><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; Int&#xE9;rprete Ingl&#xE9;s - Alem&#xE1;n.</div><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; Secretariado Ejecutivo Biling&#xFC;e.</div><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; Turismo y Hoteler&#xED;a.</div><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; Contabilidad.</div><div class=\"p\">Carrera:&nbsp; &nbsp; &nbsp; Dise&#xF1;o Gr&#xE1;fico Publicitario.</div><br></div>", "i": 7254511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 7254512}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3350 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3350 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 3.350, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_trat