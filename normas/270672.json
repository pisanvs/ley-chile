{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N 1.630 EXENTA, DE 2008 </div></div>", "i": 7368175}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.630, de fecha 10 de marzo de 2008, del Ministerio de Educaci&#xF3;n, se elimina del Libro de Registro de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xBA; 362, de fecha 3 de julio de 2007, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Cescal (en formaci&#xF3;n) de la ciudad de Santiago, en raz&#xF3;n a que las observaciones formuladas al instrumento constitutivo de la persona jur&#xED;dica organizadora de la instituci&#xF3;n no fueron subsanadas satisfactoriamente.</div><br></div>", "i": 7368176}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de abril de 2008.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7368177}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1630 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1630 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN 1.630 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-03-10", "doble_articulado": false, "id_norma": "270672", "numero_fuente": "39045", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-04-24", "vigencias": [{"desde": "2008-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-04-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-04-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes"