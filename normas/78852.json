{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6053497}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 4, de 24 de Marzo de 1992, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IIa. Regi&#xF3;n, se adjudic&#xF3; a don Juan Salom&#xF3;n Moreno Rojas, la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar de la fecha de publicaci&#xF3;n del presente extracto, un establecimiento ubicado en calle Vivar No. 1451, de Calama, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de todo tipo de veh&#xED;culos motorizados, sus remolques y semirremolques, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 6053498}, {"t": "<div><div class=\"p\">Francisco Diaspro Silva. Secretario Regional Ministerial de Transpones y Telecomunicaciones (S), Regi&#xF3;n de Antofagasta. </div></div>", "i": 6053499}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-24", "doble_articulado": false, "id_norma": "78852", "numero_fuente": "34274", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-05-25", "vigencias": [{"desde": "1992-05-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-05-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-25