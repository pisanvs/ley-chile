{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6574416}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.334, de 17 de mayo de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a JUAN LUIS DIAZ COLLAO, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en calle Bilbao N&#xBA; A-8, Taltal, II Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga Seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6574417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de mayo de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6574418}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1334 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1334 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-17", "doble_articulado": false, "id_norma": "250896", "numero_fuente": "38501", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-30", "vigencias": [{"desde": "2006-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-06-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2006-06-30", "fecha_version": "2006-06-30", "fecha_actu