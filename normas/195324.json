{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 16.284 EXENTA, DE 2001 </div></div>", "i": 6371930}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 16.284 de 28 de diciembre del a&#xF1;o 2001, se ha aprobado al Instituto Alonso de Ercilla (Hermanos Maristas), comuna y provincia de Santiago, un plan de estudio para 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n.- </div></div>", "i": 6371931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6371932}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "16284 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-16284 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 16.284 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-28", "doble_articulado": false, "id_norma": "195324", "numero_fuente": "37205", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-08", "vigencias": [{"desde": "2002-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-03-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2002-03-08", "f