{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 31 EXENTO, DE 1994 </div></div>", "i": 5939931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 31, de 24 de enero de 1994, se ha aprobado, a contar del a&#xF1;o escolar 1994, al &quot;Colegio Shirayuri&quot; de la comuna de La Florida, Santiago, para impartir la signatura de Ciencias Naturales en 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, desagregada en la siguiente forma:</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; Biolog&#xED;a 2 clases semanales.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; F&#xED;sica 2 clases semanales.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; Qu&#xED;mica 2 clases semanales.</div><br><br></div>", "i": 5939932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 25 de Febrero de 1994.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5939933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "31", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-31"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 31 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO SHIRAYURI", "CIENCIAS NATURALES", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-24", "doble_articulado": false, "id_norma": "19794", "numero_fuente": "34805", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-03-03", "vigencias": [{"desde": "1994-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-03-03", "fin_vigencia": ""}