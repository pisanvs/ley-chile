{"html": [{"t": "<div><br><div class=\"p\">DECLARACIONES JURADAS FORMULARIOS Nos 1823 Y 1888</div></div>", "i": 9660881}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 106 del 24 de diciembre de 2015.</div><div class=\"p\">&nbsp; &nbsp;  Modifica Declaraciones Juradas Formularios N&#xFA;meros 1823 y 1888, y Certificados n&#xFA;meros 8 y 17, estableciendo nueva informaci&#xF3;n que deben presentar en las entidades facultadas para emitir productos financieros acogidos al art&#xED;culo 57 bis de la Ley sobre Impuesto a la Renta.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2015.</div></div>", "i": 9660882}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "106 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-106 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DECLARACIONES JURADAS FORMULARIOS Nos 1823 Y 1888", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 983022; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-24", "doble_articulado": false, "id_norma": "1086051", "numero_fuente": "41347", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-01-04", "vigencias": [{"desde": "2016-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci