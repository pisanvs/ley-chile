{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6526381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xBA; 530, de 31 de julio de 1996, se expropi&#xF3; el lote de terreno N&#xBA; 1 superficie 258 M2, rol de aval&#xFA;o 329-8, comuna de Puerto Montt, para la obra Mejoramiento Ruta 5 Sur, Sector Acceso Sura Pargua Urmeneta, Camino Panamericana Sur Rol 5, Sector Eje Petorca, Presidente Ib&#xE1;&#xF1;ez, y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietario Armando Marchesini Cremonini, ascendente a la cantidad de $29.386.192. </div></div>", "i": 6526382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6526383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "530", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-530"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07-31", "doble_articulado": false, "id_norma": "238064", "numero_fuente": "35557", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-09-02", "vigencias": [{"desde": "1996-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-09-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-05-16", "fecha_version": "1996-09-02", "fecha_actualizacion_texto": "1996-09-02", "tipo_tratado": ""}, "alertas": [], "alerta_global"