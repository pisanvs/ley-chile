{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DEL REGIMEN DE RETENCION DEL IVA A ABASTECEDORA DE COMBUSTIBLES S.A.</div><br></div>", "i": 6368883}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La XIII Direcci&#xF3;n Regional Metropolitana Santiago Centro del SII, por resoluci&#xF3;n N&#xBA; Ex. 180 de fecha, 18 de enero de 2002, excepciona a contar del d&#xED;a 1&#xBA; del mes siguiente al de la publicaci&#xF3;n de este extracto, a la contribuyente Abastecedora de Combustibles S.A., RUT.</div><div class=\"p\">N&#xBA; 91.806.000-6, del r&#xE9;gimen de retenci&#xF3;n del Impuesto al Valor Agregado en las compras de carne que realice de acuerdo con lo establecido en la resoluci&#xF3;n N&#xBA; Ex.</div><div class=\"p\">3.722/2000, de la Direcci&#xF3;n Nacional de este Servicio.</div><br><br></div>", "i": 6368884}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Hugo Horta Barahona, Director Regional. </div></div>", "i": 6368885}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "180 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-180 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL METROPOLITANA SANTIAGO CENTRO"], "titulo_norma": "EXCEPCIONA DEL REGIMEN DE RETENCION DEL IVA A;ABASTECEDORA DE COMBUSTIBLES S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-18", "doble_articulado": false, "id_norma": "194533", "numero_fuente": "37183", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-11", "vigencias": [{"desde": "2002-02-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen