{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6626257}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.818, de 28 de septiembre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;&#xCD;A PESQUERA CAMANCHACA S.A. para realizar actividades extractivas en alta mar con la nave &quot;Mar&#xED;a Jos&#xE9;&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">&nbsp; &nbsp;  Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; CB-6001</div><div class=\"p\">&nbsp; &nbsp;  Puerto de Matr&#xED;cula&nbsp; &nbsp;  Valpara&#xED;so</div><div class=\"p\">&nbsp; &nbsp;  Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2914</div><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; 60,43 m.</div><div class=\"p\">&nbsp; &nbsp;  T.R.G. (Internacional)&nbsp; 1447,00</div><div class=\"p\">&nbsp; &nbsp;  Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  12,00 m.</div><div class=\"p\">&nbsp; &nbsp;  Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 8,00 m.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.879, de 2006, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6626258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de septiembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 6626259}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2818 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2818 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tra