{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292300}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 409, de 28 de Abril de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la resoluci&#xF3;n N&#xB0; 684, de 1985, de esta Subsecretar&#xED;a, que autoriz&#xF3; a LEFERSA ALIMIENTOS S.A., R.U.T. N&#xB0; 91.277.222-1, en el sentido de reemplazar las coordenadas geogr&#xE1;ficas del centro de cultivo ubicado en Fiordo Pichicolo, R&#xED;o Negro, Comuna de Hualaihu&#xE9;, Provincia de Palena, X Regi&#xF3;n y que comprende una superficie de 24,5 hect&#xE1;reas, por las siguientes:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Latitud&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Longitud</div><div class=\"p\">&nbsp; &nbsp; &nbsp;  42&#xB0; 00&apos; 05&quot; S&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 72&#xB0; 35&apos; 38&quot; W</div><div class=\"p\">&nbsp; &nbsp; &nbsp;  42&#xB0; 00&apos; 20&quot; S&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 72&#xB0; 35&apos; 40&quot; W</div><div class=\"p\">&nbsp; &nbsp; &nbsp;  42&#xB0; 00&apos; 50&quot; S&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 72&#xB0; 36&apos; 00&quot; W</div><div class=\"p\">&nbsp; &nbsp; &nbsp;  42&#xB0; 00&apos; 50&quot; S&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 72&#xB0; 36&apos; 10&quot; W</div><br></div>", "i": 8292301}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de Abril de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292302}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "409", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-409"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materi