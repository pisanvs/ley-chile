{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8297628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.526, de 26 de Octubre de 1995,</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, cad&#xFA;case la</div><div class=\"p\">Resoluci&#xF3;n N&#xB0; 896, de 1989, de esta Subsecretar&#xED;a, que</div><div class=\"p\">autoriz&#xF3; a GENELMAR LIMITADA, para realizar actividades</div><div class=\"p\">pesqueras extractivas con las naves &quot;Altair&quot;, &quot;Ayquina&quot;</div><div class=\"p\">y &quot;Aymara&quot;, en virtud de lo dispuesto en la letra b) del</div><div class=\"p\">Art&#xED;culo 143 del D.S. N&#xB0; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8297629}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de Octubre de 1995.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8297630}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1526", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1526"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["GENELMAR LIMITADA", "CADUCIDAD", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-10-26", "doble_articulado": false, "id_norma": "37110", "numero_fuente": "35308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-11-04", "vigencias": [{"desde": "1995-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic