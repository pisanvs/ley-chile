{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 18, de 14 de enero de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto las Resoluciones N&#xBA; 513 de 1988 y N&#xBA; 980 de 1989, que autorizaron a&nbsp; PESQUERA MAR DEL SUR S.A., para operar la nave &quot;Mar del Sur III&quot;, en virtud de lo se&#xF1;alado en el art&#xED;culo 12 transitorio inciso 4 y por no haber dado cumplimiento a lo dispuesto en el inciso 5&#xBA; del mismo art&#xED;culo 12 del D.S. N&#xBA; 430, de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8300672}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so 14 de enero de 1997.-</div><br><div class=\"p\">&nbsp; &nbsp;  Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca. </div></div>", "i": 8300673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-18"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MAR DEL SUR S.A.", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-14", "doble_articulado": false, "id_norma": "60407", "numero_fuente": "35672", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-22", "vigencias": [{"desde": "1997-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-01-22", "fin_vigencia": ""}, "vigencias_ve