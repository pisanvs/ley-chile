{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6232177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 191, del 06 de noviembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Atacama, se autoriza a Ren&#xE9; Hidalgo Narrias para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6232178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 6232179}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "191 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-191 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-11-06", "doble_articulado": false, "id_norma": "155469", "numero_fuente": "32622", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-11-14", "vigencias": [{"desde": "1986-11-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-11-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-11-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vin