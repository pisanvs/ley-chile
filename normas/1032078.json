{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9201718}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.819, de 27 de octubre de 2011, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1022241&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 134, de 2011</a>, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a CORPESCA S.A. para operar por sustituci&#xF3;n la nave &quot;Corpesca 2&quot;, en el sentido de actualizar sus caracter&#xED;sticas n&#xE1;uticas:</div><br><div class=\"p\">&nbsp; &nbsp;  Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  3275</div><div class=\"p\">&nbsp; &nbsp;  Eslora de arqueo&nbsp; &nbsp; &nbsp; 40,83 m</div><div class=\"p\">&nbsp; &nbsp;  T.R.G. (Nacional)&nbsp; &nbsp; 536,00</div><div class=\"p\">&nbsp; &nbsp;  Capacidad de bodega&nbsp; 557,42 m&#xB3;</div><div class=\"p\">&nbsp; &nbsp;  Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  10,00 m</div></div>", "i": 9201719}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de octubre de 2011.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9201720}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2819 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2819 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-27", "doble_articulado": false, "id_norma": "1032078", "numero_fuente": "40103", "tipo_version": "3", "tipo