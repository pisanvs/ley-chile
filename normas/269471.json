{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A LOS CIPRESES S.A.</div><br></div>", "i": 7364958}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del S.I.I., por resoluci&#xF3;n DRE08/ N&#xBA; Ex. 1.280 de fecha 05-02-2008, otorga a Los Cipreses S.A. RUT N&#xBA; 96.980.810-2, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio sujeto en las ventas de productos hidrobiol&#xF3;gicos, establecido en la resoluci&#xF3;n N&#xBA; Ex.</div><div class=\"p\">3.311 de 30-06-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 7364959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ram&#xF3;n Concha Velis, Director Regional (S). </div></div>", "i": 7364960}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1280 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1280 EXENTA"}, {"tipo": "3", "numero": "DRE-08-1280 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-1280 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A LOS\nCIPRESES S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-02-05", "doble_articulado": false, "id_norma": "269471", "numero_fuente": "38997", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-