{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 9,585</div><br><div class=\"p\">ACLARA EL SENTIDO DE LA DISPOSICION DEL ARTICULO 261 DEL CODIGO ORGANICO DE TRIBUNALES</div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7172710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Decl&#xE1;rase que el sentido de la disposici&#xF3;n del art&#xED;culo 261 del C&#xF3;digo Org&#xE1;nico de Tribunales es el de que la incompatibilidad que consulta no rige con los abogados integrantes de los Tribunales Superiores ni con los abogados subrogantes de los jueces.</div><br></div>", "i": 7172711, "v": ["MODIFICACION", "CONCORDANCIA"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, once de Marzo de mil novecientos cincuenta.- GABRIEL GONZALEZ VIDELA.- Ruperto Puga. </div></div>", "i": 7172712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9585", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9585"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "ACLARA EL SENTIDO DE LA DISPOSICION DEL ARTICULO 261\nDEL CODIGO ORGANICO DE TRIBUNALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FUNCIONES", "JUDICIALES", "FISCALES", "SEMIFISCALES", "MUNICIPALES", "INCOMPATIBILIDAD", "ABOGADOS INTEGRANTES", "TRIBUNALES SUPERIORES", "ABOGADOS SUBROGANTES", "INAPLICABILIDAD", "CODIGO ORGANICO TRIBUNALES", "ACLARACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_pro