{"html": [{"t": "<div><div class=\"p\">SE DISPONE LA QUINCUAG&#xC9;SIMA SEXTA EMISI&#xD3;N DE OTORGAMIENTO DEL APORTE &#xDA;NICO DE CAR&#xC1;CTER REPARATORIO LEY N&#xBA; 20.874, A LAS PERSONAS QUE SE INDIVIDUALIZAN Y POR LOS MONTOS QUE EN CADA CASO SE INDICA</div></div>", "i": 10119004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 114, de 6 de abril de 2020, el Director Nacional del Instituto de Previsi&#xF3;n Social dispone el pago de la quincuag&#xE9;sima sexta emisi&#xF3;n de otorgamiento del Aporte &#xDA;nico de car&#xE1;cter Reparatorio <a href=\"https://www.leychile.cl/Navegar?idNorma=1083194&amp;idParte=&amp;idVersion=\">Ley N&#xBA; 20.874</a>, a las personas que se individualizan y por los montos que en cada caso se indica.- </div></div>", "i": 10119005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Patricio Coronado Rojo.</div></div>", "i": 10119006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "114 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-114 EXENTA"}], "organismos": ["MINISTERIO DEL TRABAJO Y PREVISIÓN SOCIAL", "SUBSECRETARÍA DE PREVISIÓN SOCIAL", "INSTITUTO DE PREVISIÓN SOCIAL"], "titulo_norma": "SE DISPONE LA QUINCUAGÉSIMA SEXTA EMISIÓN DE OTORGAMIENTO DEL APORTE ÚNICO DE CARÁCTER REPARATORIO LEY Nº 20.874, A LAS PERSONAS QUE SE INDIVIDUALIZAN Y POR LOS MONTOS QUE EN CADA CASO SE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1758585", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-04-06", "doble_articulado": false, "id_norma": "1145022", "numero_fuente": "42650", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publ