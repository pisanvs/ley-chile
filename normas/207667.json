{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7298118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 14, de fecha 24 de enero del a&#xF1;o 2003, se aprob&#xF3; la reforma parcial del estatuto de la Cooperativa de Servicio Nuevo Amanecer Persa B&#xED;o-B&#xED;o Limitada, cuya existencia fue autorizada por resoluci&#xF3;n N&#xBA; 83, de 28 de junio 1995, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en los t&#xE9;rminos que da testimonio el instrumento reducido a escritura p&#xFA;blica con fecha 6 de enero de 2003, ante don Gabriel Ogalde Rodr&#xED;guez, Notario P&#xFA;blico de San Miguel, anotada en el Repertorio bajo el n&#xFA;mero 08-03. </div></div>", "i": 7298119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Gast&#xF3;n Godoy Gonz&#xE1;lez, Jefe Departamento de Cooperativas (S), Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 7298120}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-01-24", "doble_articulado": false, "id_norma": "207667", "numero_fuente": "37487", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-02-17", "vigencias": [{"desde": "2003-02-17", "hasta": "", "tipo_version": "3", "tipo