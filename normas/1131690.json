{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 10024063}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.804, de 3 de mayo 2019, de este Servicio, se aprob&#xF3; la implementaci&#xF3;n de un procedimiento de fiscalizaci&#xF3;n para el recurso reineta (brama australis) en las Regiones del Maule y Biob&#xED;o.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n indicada, se encuentra publicado, con esta fecha, en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y de la Subsecretar&#xED;a de Pesca y Acuicultura.</div></div>", "i": 10024064}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  En Valpara&#xED;so, a 3 de mayo de 2019.- Alicia Gallardo Lagno, Directora Nacional Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 10024065}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1804 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1804 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1591367", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2019-05-03", "fecha_derogacion": "2020-03-10", "doble_articulado": false, "id_norma": "1131690", "numero_fuente": "42357", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2019-05-18", "vigencias": [{"desde": "2020-03-10", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2019-05-18", "hasta"