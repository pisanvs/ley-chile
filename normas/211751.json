{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6428968}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.240 de 10 de junio de 2003 de</div><div class=\"p\">esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA LANDES S.A.,</div><div class=\"p\">para ampliar actividades pesqueras extractivas con la</div><div class=\"p\">nave &quot;Coral I&quot;, en las &#xE1;reas mar&#xED;timas que en cada caso</div><div class=\"p\">se indican, por fuera del &#xE1;rea de reserva artesanal, con</div><div class=\"p\">arte de cerco, donde podr&#xE1; capturar los siguientes recursos hidrobiol&#xF3;gicos: a) Entre la V a VII Regiones, y en la X Regi&#xF3;n: Bonito, Cachurreta o barrilete, Cojinoba del sur, Machuelo o tritre; b) En la X Regi&#xF3;n: Agujilla, Caballa.</div><br></div>", "i": 6428969}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so,&nbsp; 10 de junio de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6428970}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1240", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1240"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-06-10", "doble_articulado": false, "id_norma": "211751", "numero_fuente": "37596", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-30", "vigencias": [{"desde": "2003-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-30", "fin_vigencia": ""}, "vigencias_version_nor