{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8317213}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n exenta N&#xBA; 118 de fecha 10 de diciembre de 1997, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se ha rechazado el Recurso de Reclamaci&#xF3;n interpuesto por Compa&#xF1;&#xED;a Pesquera San Bernardo S.A., Rut: 79.523.690-2 y confirmada la Resoluci&#xF3;n N&#xBA; 2.175 de 1996 de la Subsecretar&#xED;a de Pesca, que declar&#xF3; la caducidad de la Resoluci&#xF3;n N&#xBA; 1.129 de 1994 de esa Subsecretar&#xED;a, que autoriz&#xF3; a dicha empresa para desarrollar actividades pesqueras con la nave &quot;Santa Carmen&quot;.-</div><br></div>", "i": 8317214}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Oscar Landerretche Gacit&#xFA;a, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8317215}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "118 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-118 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RECURSO DE RECLAMACION", "COMPA IA PESQUERA SAN BERNARDO S.A.", "CADUCIDAD", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-10", "doble_articulado": false, "id_norma": "85625", "numero_fuente": "35956", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-05", "vigencias": [{"desde": "1998-01-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-05", "fin_vigencia": ""}, "vigencia