{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7341869}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;124 de fecha 30 de marzo del 2007, se expropi&#xF3; el lote de terreno N&#xBA;14, superficie 1.149 m&#xB2;, Rol N&#xBA;381-204, comuna de Pitrufqu&#xE9;n, IX Regi&#xF3;n para la obra &quot;Ingenier&#xED;a del Sistema de Riego de la Red Secundaria y Terciaria de Canales Proyecto Faja Maisan IX Regi&#xF3;n, Canal Mapu Quimey, Comuna de Pitrufqu&#xE9;n, Provincia de Caut&#xED;n IX Regi&#xF3;n&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Jorge Hermenegildo Huaraleo Marican, ascendente a la cantidad de $887.710.- para el lote N&#xBA;14.</div><br></div>", "i": 7341870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 7341871}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "124 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-124 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-03-30", "doble_articulado": false, "id_norma": "260835", "numero_fuente": "38763", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-15", "vigencias": [{"desde": "2007-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fec