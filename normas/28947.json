{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MONUMENTO A LAS GLORIAS DE LA INFANTERIA Por cuanto el Congreso Nacional ha tenido a bien </div></div>", "i": 5981356}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase a la Municipalidad de Providencia para erigir, por suscripci&#xF3;n popular, un monumento a las glorias de la Infanter&#xED;a.</div><br></div>", "i": 5981357}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veinticuatro de Septiembre de mil novecientos setenta.- EDUARDO FREI MONTALVA.- M&#xE1;ximo Pacheco G&#xF3;mez, Ministro de Educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda a Ud.- Ernesto Livacic Gazzano, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5981358}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17356", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17356"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "MONUMENTO A LAS GLORIAS DE LA INFANTERIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["APROBAR FACULTAD", "MUNICIPALIDAD PROVIDENCIA", "CONSTRUCCION", "MONUMENTO", "GRACIAS INFANTERIA", "ERECCION EL SIGUIENTE", "PROYECTO DE LEY:"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1970-09-24", "doble_articulado": false, "id_norma": "28947", "numero_fuente": "27759", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1970-09-30", "vigencias": [{"desde": "1970-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única