{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6596640}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.472, de 27 de diciembre de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 2.897 de 2002, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a ANTONIO DA VENEZIA RETAMALES, para desarrollar actividades pesqueras extractivas con la nave &quot;T&#xED;o Gringo&quot;, sobre el recurso Reineta, en el &#xE1;rea mar&#xED;tima correspondiente a la V Regi&#xF3;n, en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y lo informado en Informes T&#xE9;cnicos citados en Visto. </div></div>", "i": 6596641}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6596642}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3472 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3472 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-12-27", "doble_articulado": false, "id_norma": "257259", "numero_fuente": "38659", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-01-10", "vigencias": [{"desde": "2007-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-01-10", "fin_vigencia": "", "tipo_version":