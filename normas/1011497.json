{"html": [{"t": "<div><br><br><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n 2.413, del 28 de diciembre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3;:</div></div>", "i": 8890659}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=245703&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 1.412, del 28 de septiembre de 2005, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>, en el sentido de reemplazar el p&#xE1;rrafo 4.- por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;4.- El concesionario deber&#xE1; dar cabal cumplimiento al Proyecto T&#xE9;cnico y Cronograma de Actividades, aprobado por resoluci&#xF3;n exenta 882, del 1 de abril de 2005, modificada por la resoluci&#xF3;n exenta 2.585, del 2 de octubre de 2008, ambas del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, Subsecretar&#xED;a de Pesca.&quot;.</div><br></div>", "i": 8890660}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de febrero de 2010.- Felipe Garc&#xED;a-Huidobro Correa, Subsecretario de Marina Subrogante.</div></div>", "i": 8890661}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2413", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2413"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-12-28", "doble_articulado": false, "id_norma": "1011497", "numero_fuente": "39604", "tipo_v