{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 337 EXENTO DE 1993 </div></div>", "i": 5943897}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 337 de fecha 01 de Julio de 1993 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; a las sedes que se indican del Centro de Formaci&#xF3;n T&#xE9;cnica INACAP para impartir planes y programas de estudios aprobados para la instituci&#xF3;n, de las carreras y t&#xED;tulos t&#xE9;cnicos de nivel superior que se se&#xF1;alan, a partir del a&#xF1;o 1993.</div><div class=\"p\"> - Sede N&#xB0; 29 - Iquique:</div><div class=\"p\">&nbsp; &nbsp;  Carrera : Turismo (Decreto Exento N&#xB0; 418 de 1990).</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xED;tulo&nbsp; : T&#xE9;cnico en Turismo.</div><br><div class=\"p\"> - Sede N&#xB0; 28 - Concepci&#xF3;n:</div><div class=\"p\">&nbsp; &nbsp;  Carrera : Secretariado Ejecutivo Computacional</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (Decreto Exento N&#xB0; 311 de 1991).</div><div class=\"p\">&nbsp; &nbsp;  T&#xED;tulo&nbsp; : Secretariado (a) Ejecutivo (a)</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Computacional.</div><br></div>", "i": 5943898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 5943899}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "337", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-337"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 337 EXENTO DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INACAP", "TURISMO", "IQUIQUE", "SECRETARIADO EJECUTIVO COMPUTACIONAL", "CONCEPCION", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "PRIMERA REGION", "OCTAVA REGION"], 