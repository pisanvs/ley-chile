{"html": [{"t": "<div><div class=\"p\">DEROGA DECRETO SUPREMO N&#xBA; 2419, DE 22 DE AGOSTO DE 1963, EXPEDIDO POR EL MINISTERIO DE JUSTICIA</div><br><div class=\"p\">&nbsp; &nbsp;  SANTIAGO, 21 de Abril de 1972.- Hoy se decret&#xF3; lo que sigue:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xBA; 601.- Vistas las facultades que me confiere el art&#xED;culo 72 de la Constituci&#xF3;n Pol&#xED;tica del Estado, </div><div class=\"p\">&nbsp; &nbsp;  DECRETO:</div><br></div>", "i": 9054031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  DEROGASE el Decreto Supremo N&#xBA; 2419, de 22 de Agosto de 1963, de este Ministerio.</div><br></div>", "i": 9054032}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en la Recopilaci&#xF3;n que corresponda de la Contralor&#xED;a General de la Rep&#xFA;blica.- S. ALLENDE G.- Jorge Tapia V.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo digo a U. para su conocimiento.- Dios guarde a U.- Jos&#xE9; Antonio Viera Gallo, Subsecretario de Justicia. </div></div>", "i": 9054033}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "601", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-601"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "DEROGA DECRETO SUPREMO Nº 2419, DE 22 DE AGOSTO DE 1963, EXPEDIDO POR EL MINISTERIO DE JUSTICIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1972-04-21", "doble_articulado": false, "id_norma": "262104", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1972-06-07", "vigencias": [{"desde": "1972-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"