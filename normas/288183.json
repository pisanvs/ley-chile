{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 397 EXENTO, DE 2009 </div></div>", "i": 8460856}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 397, de 23 de enero de 2009, se han aprobado plan y programas especiales de estudio biling&#xFC;e para 7&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, al colegio &quot;The International Preparatory School&quot;, comuna de Lo Barnechea, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los Subsectores de Ingl&#xE9;s, Educaci&#xF3;n Matem&#xE1;tica, Estudio y Comprensi&#xF3;n de la Naturaleza y Estudio y Comprensi&#xF3;n de la Sociedad.</div><br></div>", "i": 8460857}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de marzo de 2009.- Juan Cavada Artigues, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 8460858}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "397 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-397 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 397 EXENTO, DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-23", "doble_articulado": false, "id_norma": "288183", "numero_fuente": "39315", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-03-18", "vigencias": [{"desde": "2009-03-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-03-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-03-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculac