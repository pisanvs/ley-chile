{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA MANUEL ANTONIO MATTA LA LOCALIDAD DE SAN FERNANDO, DEL DEPARTAMENTO DE COPIAPO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 8282300}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Denom&#xED;nase &quot;Manuel Antonio Matta&quot; a la localidad de San Fernando, del departamento de Copiap&#xF3;, provincia de Atacama&quot;.</div><br></div>", "i": 8282301}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintis&#xE9;is de diciembre de mil novecientos sesenta y tres.- JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 8282302}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "15450", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-15450"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DENOMINA MANUEL ANTONIO MATTA LA LOCALIDAD DE SAN\nFERNANDO, DEL DEPARTAMENTO DE COPIAPO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "LOCALIDAD MANUEL ANTONIO MATTA", "SAN FERNANDO", "COPIAPO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1963-12-26", "doble_articulado": false, "id_norma": "28186", "numero_fuente": "25726", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1963-12-27", "vigencias": [{"desde": "1963-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "196