{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,154.- Santiago, 29 de diciembre de 1898.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6161616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Decl&#xE1;rase, por gracia, que el capitan de Ej&#xE9;rcito, don Manuel Arismendi, tiene derecho a que su pensi&#xF3;n de invalidez le sea abonada como si se hubiese inhabilitado en actos de servicio, de conformidad con lo dispuesto en el art&#xED;culo 1&#xBA;, inciso 2.&#xBA; de la lei de 4 de febrero de 1893.</div><br></div>", "i": 6161617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Carlos Concha.</div><br></div>", "i": 6161618}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1154", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1154"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-12-29", "doble_articulado": false, "id_norma": "134201", "numero_fuente": "6190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-12-31", "vigencias": [{"desde": "1898-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-12-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-12-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc