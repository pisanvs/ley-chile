{"html": [{"t": "<div><div class=\"p\">EXTRACTOS DE EXPROPIACIONES</div><br><br></div>", "i": 6226859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alcaldesa de la I. Municipalidad de Providencia, mediante Decreto No. Ex. 891, de 11 de Agosto de 1986, dispone expropiaci&#xF3;n parcial, conforme Decreto Supremo No. 458, de Vivienda, de 1976, y Decretos Leyes 1.289, 2.186 y 3.464, de inmueble ubicado en Avda. Bilbao No. 2427, Rol de Aval&#xFA;os No. 3237-2, aparentemente de propiedad de do&#xF1;a Rosa Carrasco Requesens, para el ensanche de Avda. Bilbao. Deslindes parte expropiada: al Norte, 16,50 mts. Avda. Bilbao; al Sur, 16,50 mts. resto de la propiedad que se expropia; al Oriente, 5 mts. Rol No. 3237-3 y al Poniente, 5 mts. Rol No. 3237-1. Indemnizaci&#xF3;n provisional: $ 856.500.</div><br></div>", "i": 6226860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Carmen Grez de Anrique, Alcaldesa.- Jorge O. Herrera Ram&#xED;rez, Secretario Abogado Municipal. </div></div>", "i": 6226861}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "891 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-891 EXENTO"}], "organismos": ["MUNICIPALIDAD DE PROVIDENCIA"], "titulo_norma": "EXTRACTOS DE EXPROPIACIONES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-08-11", "doble_articulado": false, "id_norma": "153729", "numero_fuente": "32549", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-16", "vigencias": [{"desde": "1986-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic