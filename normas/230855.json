{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6499036}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;507 fecha 21 de septiembre de 2004 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n, conforme D.L. N&#xBA;2.186 de 1978, del Lote N&#xBA;19 correspondiente al inmueble ubicado en Suiza N&#xBA;340, V. Esperanza, presunto rol de aval&#xFA;o N&#xBA;543-7, comuna de Cerrillos, aparente dominio de Fuentes Bustamante Mar&#xED;a Elvira. Comisi&#xF3;n integrada por peritos Rodrigo Mella Ascar, Constructor Civil; Mauricio Encina Aguilera, Ingeniero Civil; y Mar&#xED;a Quiroga Gonz&#xE1;lez, Arquitecto. Seg&#xFA;n informe de 12 de abril de 2004, fij&#xF3; monto provisional indemnizaci&#xF3;n en $37.765.050.-, fij&#xE1;ndose como monto definitivo de com&#xFA;n acuerdo entre la Entidad expropiante y el expropiado la suma de $45.000.000.- pagadera al contado.</div><br></div>", "i": 6499037}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6499038}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "507", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-507"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-21", "doble_articulado": false, "id_norma": "230855", "numero_fuente": "37975", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-01", "vigencias": [{"desde": "20