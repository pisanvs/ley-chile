{"html": [{"t": "<div><div class=\"p\">AUTORIZA A EMISOR DE BOLETAS ELECTR&#xD3;NICAS </div></div>", "i": 6986298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 13, de 29 de enero de 2009, que autoriza a contribuyente como emisor de boletas electr&#xF3;nicas.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boletas electr&#xF3;nicas, a contar del mes de enero de 2009, al contribuyente RUT N&#xBA; 76.479.460-5.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2009.</div><br><br></div>", "i": 6986299}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "13 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-13 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A EMISOR DE BOLETAS ELECTRÓNICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-01-29", "doble_articulado": false, "id_norma": "286738", "numero_fuente": "39279", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-02-04", "vigencias": [{"desde": "2009-02-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-02-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-02-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi