{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7160069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 023 de fecha 13 de Enero de</div><div class=\"p\">1993 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el</div><div class=\"p\">art&#xED;culo 1&#xB0; del Decreto Exento N&#xB0; 50 de 1987 correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Umbrales de Santiago, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo 1&#xB0;: Autor&#xED;zase el funcionamiento del Centro de Formaci&#xF3;n T&#xE9;cnica que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala, cuyo fin es la docencia a nivel t&#xE9;cnico para egresados de ense&#xF1;anza media:</div><div class=\"p\">&nbsp; &nbsp; Nombre de la Instituci&#xF3;n: Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Umbrales de Santiago.</div><div class=\"p\">&nbsp; &nbsp; Domicilio: Santiago.</div><div class=\"p\">&nbsp; &nbsp; Organizador: Sociedad Instituto Umbrales Limitada o Umbrales Ltda.&quot;.</div><br></div>", "i": 7160070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de Abril de 1993.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7160071}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "23 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-23 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "INSTITUTO UMBRALES", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-01-13", "doble_articulado": false, "id_norma": "19713", "