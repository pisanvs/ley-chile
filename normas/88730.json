{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 740, DE 1990 </div></div>", "i": 6080396}, {"t": "<div><div class=\"p\">Apru&#xE9;base el Convenio de 10 de Octubre de 1990, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de La Calera que rectifica el Convenio de Traspaso de la Escuela F 230 de La Calera entregado a esa Corporaci&#xF3;n por Convenio aprobado por decreto de Educaci&#xF3;n No. 1.297 de 26 de Noviembre de 1986, en el sentido de dejar establecido la correcta ubicaci&#xF3;n, con sus verdaderos y actuales deslindes de acuerdo al Plano SU 241 archivado bajo el No. 34 del a&#xF1;o 1979, de propiedad Fiscal y cuyo t&#xED;tulo de dominio rola inscrito a fs. 1.579 vta. No. 2.240 de 1983 del Conservador de Bienes Ra&#xED;ces de Quillota.</div><div class=\"p\">Otras disposiciones en Convenio que se extracta.- </div></div>", "i": 6080397}, {"t": "<div><div class=\"p\">Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6080398}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "740", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-740"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO Nº 740, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-10", "doble_articulado": false, "id_norma": "88730", "numero_fuente": "33905", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-27", "vigencias": [{"desde": "1991-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-27", "fin_vigencia": ""}, "vig