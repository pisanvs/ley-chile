{"html": [{"t": "<div><div class=\"p\">MODIFICA D.S No 211, DE 1991</div><br><div class=\"p\">N&#xFA;m.191.- Santiago, 17 de Septiembre de 1992.- Visto: Lo dispuesto por el D.S No.211, de 1991, del Ministerio de Transportes y Telecomunicaciones,</div><br><div class=\"p\">Decreto:</div><br></div>", "i": 7219782}, {"t": "<div><div class=\"p\">Sustit&#xFA;yese el p&#xE1;rrafo final del art&#xED;culo 9&#xBA; del D.S No.211, antes referido, por el siguiente:</div><div class=\"p\">&quot;Tampoco regir&#xE1;n en las regiones Quinta y Sexta entre los d&#xED;as 15 de Septiembre de un a&#xF1;o y el 15 de Marzo del siguiente&quot;.</div><br></div>", "i": 7219783}, {"t": "<div><div class=\"p\">An&#xF3;tese, t&#xF3;mese raz&#xF3;n y publ&#xED;quese.- PATRICIO AYLWIN AZOCAR, Presidente de la Rep&#xFA;blica.- V. Germ&#xE1;n Correa D&#xED;az, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Depto. Administrativo. </div></div>", "i": 7219784}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "191", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-191"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "MODIFICA D.S No 211, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-09-17", "doble_articulado": false, "id_norma": "84685", "numero_fuente": "34386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-10-09", "vigencias": [{"desde": "1992-10-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci