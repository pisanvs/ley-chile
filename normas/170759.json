{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;5.415 EXENTA, DE 2000 </div></div>", "i": 6281536}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;5.415, de fecha 19 de mayo de 2000, del Ministerio de Educaci&#xF3;n, se declara que no se concedi&#xF3; el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica Victoria, organizado por la Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica Victoria Limitada, ubicado en calle Victoria N&#xBA;527 de San Bernardo.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, se elimina del Libro de Registro de Centros de Formaci&#xF3;n T&#xE9;cnica el N&#xBA;272 de fecha 5 de noviembre de 1999, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Victoria, de San Bernardo. </div></div>", "i": 6281537}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de junio de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6281538}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5415 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5415 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº5.415 EXENTA, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-19", "doble_articulado": false, "id_norma": "170759", "numero_fuente": "36688", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-13", "vigencias": [{"desde": "2000-06-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenci