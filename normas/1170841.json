{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10298160}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.184, de 24 de diciembre 2021, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado Avda. Pdte. Ib&#xE1;&#xF1;ez 1006, Rol Aval&#xFA;o N&#xBA; 288-39, comuna de Linares, superficie 23,72 m2 terreno, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Sind. Trab. Ind. Suplem. de Linares. Comisi&#xF3;n integrada por peritos Mar&#xED;a Letelier Bopp, Arquitecto; Claudia Poblete Ram&#xED;rez, Arquitecto, y &#xC1;lvaro Vergara Mej&#xED;as, ingeniero civil industrial, seg&#xFA;n informe de fecha 20 diciembre de 2021, tas&#xF3; lote en $11.770.952.-, se pagar&#xE1; de contado indemnizaci&#xF3;n provisional.- </div></div>", "i": 10298161}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule.</div><br></div>", "i": 10298162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1184 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1184 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2064565", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-24", "doble_articulado": false, "id_norma": "1170841", "numero_fuente": "43142", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-01-03", "vigenc