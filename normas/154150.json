{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6228112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 747 de 08 de Septiembre de 1987, de esta Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Norma Arriagada Andrade para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.- </div></div>", "i": 6228113}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6228114}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "747 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-747 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-09-08", "doble_articulado": false, "id_norma": "154150", "numero_fuente": "32874", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-21", "vigencias": [{"desde": "1987-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_po