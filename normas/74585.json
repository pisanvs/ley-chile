{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 461 EXENTO, DE 1997 </div></div>", "i": 6042252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 461, de fecha 21 de abril de 1997, del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica ESUCOMEX, las modificaciones al plan y programas de estudios de la carrera de Programaci&#xF3;n de Computadores, la que podr&#xE1; impartirse en la Sede N&#xBA; 1, a contar del a&#xF1;o 1997, con la siguiente denominaci&#xF3;n:</div><br><div class=\"p\">Carrera: Programaci&#xF3;n de Computadores, cambia por: Carrera: Computaci&#xF3;n.</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Computaci&#xF3;n con menci&#xF3;n en Programador de Aplicaciones o en Soporte Computacional. </div></div>", "i": 6042253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de mayo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6042254}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "461 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-461 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 461 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["APROBACION", "CENTRO DE FORMACION TECNICA ESUCOMEX", "MODIFICACION", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-07-18", "doble_articulado": false, "id_norma": "74585", "numero_fuente": "35829", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-07-30", "vigencias": [{"desde": "1997-07-30", "hasta": "", "tipo_version": "3", "tipo_version_