{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 546, DE 2000 </div></div>", "i": 6306038}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 546, de 21 de septiembre de 2000, se ha aprobado el Convenio de fecha doce de septiembre de 2000, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Panquehue, que modifica el Convenio de Traspaso de la Escuela B&#xE1;sica F N&#xBA; 80, de Panquehue, traspasada a dicha Corporaci&#xF3;n, por Convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA;583 de 11 de julio de 1986.</div><br></div>", "i": 6306039}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de octubre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6306040}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "546", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-546"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 546, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-21", "doble_articulado": false, "id_norma": "176944", "numero_fuente": "36797", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-10-26", "vigencias": [{"desde": "2000-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-10-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-10-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-10-26", "fecha_version": "2000-10-26