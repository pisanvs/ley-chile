{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION NUMERO 2.015 EXENTA, DE 1992, SOBRE DELEGACION DE FACULTADES </div></div>", "i": 7202512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 2.199, de 16-05-95, el Director Regional de la VIII Direcci&#xF3;n Regional Concepci&#xF3;n, ha procedido a modificar la parte dispositiva de la Resoluci&#xF3;n N&#xB0; Ex. 2.015 de fecha 25-03-92 de esta Direcci&#xF3;n Regional.</div><div class=\"p\">&nbsp; &nbsp; 1&#xB0; Reempl&#xE1;zase, en el inciso segundo de la letra a), la expresi&#xF3;n &quot;graves&quot; por la palabra &quot;compleja&quot;, y 2&#xB0; Supr&#xED;mese la letra d), pasando las letras f), g) y h) a ser d), f) y g), respectivamente.-</div><br><br></div>", "i": 7202513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Pablo Jara Alvarez, Director Regional (S). </div></div>", "i": 7202514}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2199 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2199 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA RESOLUCION NUMERO 2.015 EXENTA, DE 1992, SOBRE DELEGACION DE FACULTADES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "DELEGACION", "FACULTAD", "SERVICIO", "IMPUESTOS INTERNOS", "OCTAVA REGION", "DIRECTOR REGIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-16", "doble_articulado": false, "id_norma": "40105", "numero_fuente": "35176", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-25", "vigencias": [{"desde": "1995-05-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-25",