{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESION N&#xBA; 810E </div><br></div>", "i": 6213441}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su sesi&#xF3;n N&#xBA; 810E, celebrada el 16 de diciembre de 1999, adopt&#xF3; los siguientes acuerdos:</div><br><div class=\"p\">810E-01-991216 - Reelecci&#xF3;n de Vicepresidente del Consejo y del Banco Central de Chile.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reelegir a don Jorge Marshall Rivera en el cargo de Vicepresidente del Consejo y del Banco Central de Chile, por el plazo de dos a&#xF1;os, a contar del 7 de diciembre de 1999.</div><br></div>", "i": 6213442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 16 de diciembre de 1999.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6213443}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "810", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-810"}, {"tipo": "8", "numero": "810-E-01", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-810-E-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESION Nº 810E", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-16", "doble_articulado": false, "id_norma": "149712", "numero_fuente": "36544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-21", "vigencias": [{"desde": "1999-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen