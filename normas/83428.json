{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 111 EXENTO, DE 1990 </div></div>", "i": 7218764}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 111 de 26 de marzo de 1990 se ha aprobado un plan de estudio especial, a contar del a&#xF1;o escolar 1990 y por un per&#xED;odo de 6 a&#xF1;os, a la Escuela Especial Particular No. 1132 de Pe&#xF1;alol&#xE9;n, Regi&#xF3;n Metropolitana.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio correspondientes para el plan de estudio especial aprobado por el presente decreto.</div><br></div>", "i": 7218765}, {"t": "<div><div class=\"p\">Santiago, 05 de Abril de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7218766}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "111 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-111 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO N° 111 EXENTO, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-26", "doble_articulado": false, "id_norma": "83428", "numero_fuente": "33645", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-12", "vigencias": [{"desde": "1990-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-04-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-04-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "1998-01-08", "fecha_version": "1990-