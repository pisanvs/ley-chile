{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;390 EXENTO, DE 2006 </div></div>", "i": 6573295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 390 de fecha 6 de abril de 2006 de Educaci&#xF3;n, se aprueban planes y programas al Instituto Profesional Instituto Superior de Electr&#xF3;nica Gamma de la carrera profesional conducente al t&#xED;tulo que se indica, a contar del a&#xF1;o 2006, para la Casa Central Santiago.</div><br><div class=\"p\">&nbsp; &nbsp;  Carrera: Ingenier&#xED;a de Ejecuci&#xF3;n en Telem&#xE1;tica.</div><br><div class=\"p\">&nbsp; &nbsp;  T&#xED;tulo: Ingeniero de Ejecuci&#xF3;n en Telem&#xE1;tica. </div></div>", "i": 6573296}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de junio de 2006.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 6573297}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "390 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-390 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº390 EXENTO, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-06", "doble_articulado": false, "id_norma": "250613", "numero_fuente": "38490", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-16", "vigencias": [{"desde": "2006-06-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-06-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-06-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingres