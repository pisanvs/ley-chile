{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6176470}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 161, de 05 Febrero de 1988, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a V&#xED;ctor Leonidas Vega Vargas y Marcela Matamala C&#xE1;rdenas para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 1 &quot;Francke - Centro - Rahue Alto&quot; de Osorno, cuyo trazado fue autorizado por resoluci&#xF3;n No. 90, de 12 de Junio de 1984, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6176471}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Boldt Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n. </div></div>", "i": 6176472}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "161 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-161 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-05", "doble_articulado": false, "id_norma": "138785", "numero_fuente": "33002", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-22", "vigencias": [{"desde": "1988-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-02-22", "fin_vigencia": "", "tipo_version": "3"}],