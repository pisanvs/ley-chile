{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7214636}, {"t": "<div><div class=\"p\">Por decreto supremo de Educaci&#xF3;n exento No.13, de 14 de enero de 1992, se han aprobado para el colegio The Grange School, de Santiago, Planes especiales de Estudio para 5&#xBA; a 8&#xBA;a&#xF1;o de Ense&#xF1;anza B&#xE1;sica y para Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, los cuales ser&#xE1;n aplicados simult&#xE1;neamente a contar del a&#xF1;o escolar 1992, excepto en 2&#xBA; y 4&#xBA;s a&#xF1;os medios cuya aplicaci&#xF3;n se iniciar&#xE1; en 1993. La evaluaci&#xF3;n y promoci&#xF3;n de los alumnos de 5&#xBA; a 8&#xBA;a&#xF1;os de Educaci&#xF3;n B&#xE1;sica, y los de 1&#xBA; a 4&#xBA;s a&#xF1;os de Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica, se regir&#xE1; por las disposiciones oficiales vigentes sobre esta materia.</div><br></div>", "i": 7214637, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">Santiago, 7 de Febrero de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7214638}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "13 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-13 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-14", "doble_articulado": false, "id_norma": "79622", "numero_fuente": "34204", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-02-27", "vigencias": [{"desde": "1992-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1