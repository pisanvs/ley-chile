{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6476507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 507 de 31 de marzo del 2004, se expropiaron los lotes de terrenos N&#xBA; s. 19-D y 21-A, superficies 9,25 y 219,50 m&#xB2; respectivamente, rol N&#xBA; 325-33, comuna de R&#xED;o Negro, X Regi&#xF3;n para la obra &quot;Camino Ruta U-72, Sector Huilma - Riachuelo, Tramo Km.</div><div class=\"p\">18,14000 a 33,91000&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Bernardita del Carmen Monje G&#xF3;mez, ascendente a la cantidad de $325.030.- </div></div>", "i": 6476508}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6476509}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "507", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-507"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-03-31", "doble_articulado": false, "id_norma": "224592", "numero_fuente": "37850", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-03", "vigencias": [{"desde": "2004-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-05-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2004-05-03", "fecha_version": "2004-05-03", "fecha_actualizacion_texto": "2004-05-03", "tipo_tratado": ""},