{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8318699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 31, de 13 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la autorizaci&#xF3;n solicitada por PESQUERA EL GOLFO S.A., para ampliar sus actividades pesqueras autorizadas por Resoluciones N&#xBA; 200 de 1992 y N&#xBA; 225 de 1996, ambas de esta Subsecretar&#xED;a, con la nave &quot;Pelagos II&quot;, Matr&#xED;cula 2751, en la captura del recurso hidrobiol&#xF3;gico Orange roughy, por encontrarse su acceso transitoriamente cerrado, en virtud de lo dispuesto en el Art&#xED;culo 1&#xBA; del D.S. N&#xBA; 500 de 1997, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8318700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8318701}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "31", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-31"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA EL GOLFO S.A.", "AMPLIACION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-13", "doble_articulado": false, "id_norma": "88376", "numero_fuente": "35970", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-21", "vigencias": [{"desde": "1998-01-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inici