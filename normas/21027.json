{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 339 EXENTO, DE 1993 </div></div>", "i": 5943903}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 339 de fecha 1 de Julio de 1993 del Ministerio de Educaci&#xF3;n, se aprobaron las adecuaciones introducidas al plan y programas de estudio de la carrera Administraci&#xF3;n de Empresas con especialidad en proyectos y finanzas del Centro de Formaci&#xF3;n T&#xE9;cnica CENAFOM, las que se entienden incorporadas en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 1.597 de 1982 y N&#xB0; 1 de 1985, a contar del a&#xF1;o 1993. </div></div>", "i": 5943904}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 8 de Noviembre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943905}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "339 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-339 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 339 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLAN ESTUDIO", "PROGRAMA ESTUDIO", "CENAFOM", "CENTRO", "FORMACION TECNICA", "ADMINISTRACION EMPRESAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-07-01", "doble_articulado": false, "id_norma": "21027", "numero_fuente": "34749", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-12-27", "vigencias": [{"desde": "1993-12-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-12-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-12-27", "fin_vigencia": "", "tipo_ver