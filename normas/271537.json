{"html": [{"t": "<div><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N PARTIDO REGIONALISTA DE LOS INDEPENDIENTES </div></div>", "i": 7370972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Carlos Moraga Duque y Ricardo Fern&#xE1;ndez Sanhueza, Presidente y Secretario General del Partido Regionalista de los Independientes, respectivamente, han solicitado la constituci&#xF3;n legal del partido en la VIII Regi&#xF3;n del Biob&#xED;o, acompa&#xF1;ando 6.275 fichas de afiliaciones.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xBA; de la Ley N&#xBA; 18.603, por resoluci&#xF3;n O-N&#xBA; 0966 de fecha 22 de mayo de 2008. </div></div>", "i": 7370973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director. </div></div>", "i": 7370974}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "966", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-966"}, {"tipo": "3", "numero": "O-966", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-966"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN PARTIDO REGIONALISTA DE LOS INDEPENDIENTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO REGIONALISTA DE LOS INDEPENDIENTES", "OCTAVA REGION", "CONSTITUCION LEGAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-05-22", "doble_articulado": false, "id_norma": "271537", "numero_fuente": "39073", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-29", "vigencias": [{"desde": "2008-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"ini