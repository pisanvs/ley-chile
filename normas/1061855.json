{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">DELEGA FACULTAD QUE INDICA</div></div>", "i": 9440135}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n del Servicio de Impuestos Internos N&#xBA; 40, de 25 de abril de 2014, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Delega en el Subdirector de Recursos Humanos la facultad de dictar las resoluciones que ordenen el pago y determinen el monto de los beneficios a que se refieren los art&#xED;culos 4&#xBA;, 8&#xBA; y 9&#xBA; de la ley N&#xBA; 20.734.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril de 2014.</div></div>", "i": 9440136}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "40", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-40"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DELEGA FACULTAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-04-25", "doble_articulado": false, "id_norma": "1061855", "numero_fuente": "40847", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-05-03", "vigencias": [{"desde": "2014-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-05-03", "fin_vige