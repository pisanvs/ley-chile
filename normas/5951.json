{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 299.- Santiago, 6 de marzo de 1925.-</div><div class=\"p\">&nbsp; &nbsp; La Junta de Gobierno ha acordado y dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; DECRETO-LEI:</div><br></div>", "i": 8255986}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dense los siguientes suplementos a los &#xED;tem que se indican, del Presupuesto del Interior vijente:</div><div class=\"p\">&nbsp; &nbsp; Cuatrocientos mil pesos ($ 400,000) al &#xED;tem 1611, para gastos jenerales de palic&#xED;as;</div><div class=\"p\">&nbsp; &nbsp; Treinta mil pesos ($ 30,000), al &#xED;tem 5636, para pago de empleados suplentes e interinos; y</div><div class=\"p\">&nbsp; &nbsp; Cincuenta mil pesos ($ 50,000), al &#xED;tem 5652, para gratificacion del personal de la Presidencia de la Rep&#xFA;blica, Consejo de Estado y Ministerio.</div><br></div>", "i": 8255987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes y Decretos del Gobierno.- Emilio Bello C.- Pedro P. Dartnell E.- C. A. Ward.</div><br></div>", "i": 8255988}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "299", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-299"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GASTOS NACION", "A O", "1925", "MODIFICACION MINISTERIO INTERIOR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-03-06", "doble_articulado": false, "id_norma": "5951", "numero_fuente": "14209", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "