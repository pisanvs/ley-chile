{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 8.303 EXENTA, DE 2008 </div></div>", "i": 7382432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0;8.303, de 21 de noviembre de 2008, se ha complementado la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0;14695, de 2004, que aprob&#xF3; planes y programas especiales de estudio de 1&#xB0; a 4&#xB0; a&#xF1;o de ense&#xF1;anza media al Colegio Cumbres, de la comuna de Las Condes, de Santiago, en el sentido de agregar en el plan de formaci&#xF3;n general el subsector de formaci&#xF3;n cat&#xF3;lica para todos los cursos de ense&#xF1;anza media.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio del subsector de formaci&#xF3;n cat&#xF3;lica de 1&#xB0; a 4&#xB0; a&#xF1;o de ense&#xF1;anza media.</div><br></div>", "i": 7382433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de diciembre de 2008.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 7382434}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8303 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-8303 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 8.303 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-21", "doble_articulado": false, "id_norma": "283768", "numero_fuente": "39241", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-19", "vigencias": [{"desde": "2008-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic