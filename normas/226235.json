{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6482776}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.541, de 4 de junio de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD COMERCIAL MELINKA Y COMPA&#xD1;IA LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Bellavista N&#xBA; 059-A, Punta Arenas, XII Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Cocido, Fresco-enfriado y Congelado los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6482777}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6482778}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1541 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1541 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-04", "doble_articulado": false, "id_norma": "226235", "numero_fuente": "37882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-11", "vigencias": [{"desde": "2004-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso":