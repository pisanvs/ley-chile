{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE PROCEDIMIENTO QUE INDICA</div></div>", "i": 9809187}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 56, del 19 de junio de 2017, que se&#xF1;ala:</div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fija el procedimiento, forma y plazos para la aplicaci&#xF3;n y ejercicio de la facultad establecida en el <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=9510274&amp;idVersion=\">art&#xED;culo 60 bis</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=6374&amp;idParte=&amp;idVersion=\">C&#xF3;digo Tributario</a>.</div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, se incluir&#xE1; en el Bolet&#xED;n del SII correspondiente al mes de junio de 2017.</div><br></div>", "i": 9809188}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "56 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-56 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE PROCEDIMIENTO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1231957; EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-06-19", "doble_articulado": false, "id_norma": "1104570", "numero_fuente": "41793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-06-27", "vigencias": [{"desde": "2017-06-27", "hasta": "