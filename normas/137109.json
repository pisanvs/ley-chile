{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,501.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6170901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Adela Dubl&#xE9;, v. de Soto Correa, el goce de la pension que ha dejado de percibir en el lapso de tiempo comprendido entre la muerte de su marido, ocurrida el 31 de agosto de 1891, i el 15 de julio de 1896, en cuya fecha se le puso en posesion de su correspondiente montep&#xED;o militar.</div><br></div>", "i": 6170902}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintisiete de marzo de mil novecientos once.- Ramon Barros Luco.- Ramon Leon Luco.</div><br></div>", "i": 6170903}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2501", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2501"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-03-27", "doble_articulado": false, "id_norma": "137109", "numero_fuente": "9945", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-04-01", "vigencias": [{"desde": "1911-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1911-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1911-