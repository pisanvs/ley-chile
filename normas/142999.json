{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 2.852, DE 1986 </div><br><br><br></div>", "i": 8872031}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 2.852 de fecha 24 de Octubre de 1986 del Subsecretario de Educaci&#xF3;n P&#xFA;blica, se aprobaron las modificaciones introducidas al siguiente plan y programas de estudios del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Ciencias Tur&#xED;sticas e Idiomas, EDECTI, de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar de Agosto de 1986: Carrera: Turismo</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Turismo con menci&#xF3;n en Tr&#xE1;fico A&#xE9;reo de Pasajeros y Carga.</div><br></div>", "i": 8872032}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 8872033}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2852 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2852 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 2.852, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-10-24", "fecha_derogacion": "2004-11-12", "doble_articulado": false, "id_norma": "142999", "numero_fuente": "32664", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-01-06", "vigencias": [{"desde": "2004-11-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-01-06", "hasta": "2004-11-11", "tipo_version": "0", "tipo_version_s": "Texto Orig