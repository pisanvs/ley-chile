{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 319 EXENTO, DE 2003</div><br><br></div>", "i": 6426253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 319, de fecha 9 de mayo de</div><div class=\"p\">2003, del Ministerio de Educaci&#xF3;n, se modifica el</div><div class=\"p\">art&#xED;culo 3&#xBA; del decreto exento de Educaci&#xF3;n N&#xBA; 1.291, del 30 de diciembre de 2002, que revoc&#xF3; el reconocimiento oficial del Centro de Formaci&#xF3;n T&#xE9;cnica Agr&#xED;cola Sociedad Nacional de Agricultura, en el sentido que regir&#xE1; a partir del 15 de abril de 2003 y no a partir del 31 de diciembre de 2002, con el fin de no perjudicar la prosecuci&#xF3;n del t&#xED;tulo de los alumnos que se encontraban en proceso.</div><br></div>", "i": 6426254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de mayo de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6426255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "319 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-319 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 319 EXENTO, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-09", "doble_articulado": false, "id_norma": "211034", "numero_fuente": "37581", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-11", "vigencias": [{"desde": "2003-06-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia