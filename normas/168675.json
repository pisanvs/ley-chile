{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6275339}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;962, de 30 de marzo del 2000, se expropi&#xF3; el lote de terreno N&#xBA;18, superficie 262 m2, rol de aval&#xFA;o 19-66, comuna de San Gregorio &#xD1;iqu&#xE9;n, para la obra Concesi&#xF3;n Internacional Ruta 5; Tramo:</div><div class=\"p\">Talca-Chill&#xE1;n, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Tito Antonio S&#xE1;nchez Guerrero, ascendente a la cantidad de $761.069. </div></div>", "i": 6275340}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6275341}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "962", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-962"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-03-30", "doble_articulado": false, "id_norma": "168675", "numero_fuente": "36663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-15", "vigencias": [{"desde": "2000-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-05-15", "fecha_version": "2000-05-15", "fecha_actualizacion_texto": "2000-05-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura"