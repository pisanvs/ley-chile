{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6579412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 488, de fecha 30 de junio de 2006, se expropi&#xF3; el lote de terreno N&#xBA; 122, superficie 445,58 m2, Rol N&#xBA; 260-17, comuna de Salamanca, IV Regi&#xF3;n, para la obra &quot;Mejoramiento Ruta D-825, Limahuida-Almendrillo, sector Tahuinco-Salamanca Km.</div><div class=\"p\">13,14000 a Km. 23,49783, III Etapa&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario H&#xE9;ctor Eugenio Aguilar Oyarz&#xFA;n, ascendente a la cantidad de $3.421.506. </div></div>", "i": 6579413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6579414}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "488", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-488"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-30", "doble_articulado": false, "id_norma": "252257", "numero_fuente": "38540", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-16", "vigencias": [{"desde": "2006-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-08-16", "fecha_version": "2006-08-16", "fecha_actualizacion_texto": "2006-08-16", "tipo_tratado":