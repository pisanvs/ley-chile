{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA </div></div>", "i": 8315247}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA;439 - 9 de Marzo de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por el t&#xE9;rmino de 30 d&#xED;as a contar del 3 de Marzo de 1990, el plazo otorgado por la Resoluci&#xF3;n N&#xBA;154 de 1990 a don Enrique S&#xE1;nchez Ocampo, R.U.T. N&#xBA;2.129.131-5 domiciliado Bellavista 1215, Re&#xF1;aca, Vi&#xF1;a del Mar, para publicar el extracto a que se refiere el numeral N&#xBA;4 de la resoluci&#xF3;n citada, por haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8315248}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 9 de Marzo de 1990.- Roberto Cabezas Bello, Subsecretario de Pesca </div></div>", "i": 8315249}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "439", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-439"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-09", "doble_articulado": false, "id_norma": "83526", "numero_fuente": "33636", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-04-02", "vigencias": [{"desde": "1990-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-04-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-04-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":