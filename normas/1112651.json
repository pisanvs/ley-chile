{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 6.546 EXENTA, DE 11.12.2017</div></div>", "i": 9867112}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por el presente acto administrativo se ha modificado la <a href=\"https://www.leychile.cl/Navegar?idNorma=1075583&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 9.311, de 2014</a>, modificada por la resoluci&#xF3;n exenta N&#xB0; 5.282, de 2016, ambas del Ministerio de Educaci&#xF3;n, que aprobaron Planes y Programas Especiales de Estudio para los cursos de 1&#xB0; a 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media al Colegio Andr&#xE9;e English School, de la Comuna de La Reina, Provincia de Santiago, Regi&#xF3;n Metropolitana, en la forma que indica la presente resoluci&#xF3;n exenta.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba el Programa Especial de Estudio de la asignatura de Idioma Extranjero: Ingl&#xE9;s, para 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media.</div></div>", "i": 9867113}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de noviembre de 2017.- Valentina Karina Quiroga Canahuate, Subsecretaria de Educaci&#xF3;n.</div></div>", "i": 9867114}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "6546 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-6546 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 6.546 EXENTA, DE 11.12.2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1320482", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-12-11", "doble_articulado": false, "id_norma": "1112651", "numero_fuente": "419