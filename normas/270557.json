{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6644971}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 904 exenta, de fecha 10 de abril de 2008, de esta Subsecretar&#xED;a, prorr&#xF3;gase por 30 d&#xED;as h&#xE1;biles, contados desde la fecha de la presente resoluci&#xF3;n, el plazo para publicar en el Diario Oficial el extracto de la resoluci&#xF3;n N&#xBA; 269 de 2008, que autoriz&#xF3; a MARES CHILE LIMITADA, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Monitoreo de la pesquer&#xED;a de congrio dorado (Genypterus blacodes) y raya (Dipturus sp) en aguas interiores de la XII Regi&#xF3;n de Magallanes y Ant&#xE1;rtica Chilena&quot;. </div></div>", "i": 6644972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de abril de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6644973}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "904 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-904 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-10", "doble_articulado": false, "id_norma": "270557", "numero_fuente": "39039", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-04-17", "vigencias": [{"desde": "2008-04-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-04-17", "fin_vigencia": ""}, "vigencias_version_norm