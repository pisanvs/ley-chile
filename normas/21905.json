{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Impuestos de mojonazgo i sisa i de peaje </div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 32.- </div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 5946529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase a la Junta de Alcaldes de Tacna para rebajar los impuestos de mojonazgo y sisa y de peaje en la cantidad que acuerde, pudiendo suprimir estos impuestos o fijar las tarifas que determine.</div><br></div>", "i": 5946530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 4 de Febrero de 1893.- JORGE MONTT.- Francisco A. Pinto.</div><br></div>", "i": 5946531}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "32", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-32"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "IMPUESTOS DE MOJONAZGO I SISA I DE PEAJE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TACNA", "JUNTA ALCALDES", "IMPUESTOS", "REDUCCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-02-04", "doble_articulado": false, "id_norma": "21905", "numero_fuente": "4454", "tipo_