{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 12,000 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5971233}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase la glosa N.o 93 del &#xED;tem 12/05/11, &quot;Construcciones, Obras P&#xFA;blicas y Auxilios Extraordinarios&quot;, de la Direcci&#xF3;n de Arquitectura del Ministerio de Obras P&#xFA;blicas, de la ley n&#xFA;mero 12,000, de 29 de Diciembre de 1955, que aprob&#xF3; el Presupuesto de Entradas y Gastos de la Naci&#xF3;n correspondiente al a&#xF1;o 1956, por la siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;N.o 93.- Estadio de Peumo $ 1.000.000&quot;.</div><br></div>", "i": 5971234}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veinticinco de Agosto de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Adalberto Fern&#xE1;ndez F.</div><br></div>", "i": 5971235}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12101", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12101"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "MODIFICA LA LEY N.o 12,000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1956", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-08-25", "doble_articulado": false, "id_norma": "27032", "numero_fuente": "23554", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-09-21", "vigencias": [{"desde": "1956-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1956-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1956-09-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1956-09-21", "fecha_actualizacion_texto": "1956-09-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5971233}, {"n": "Artículo 1", "i": 5971234, "t": 6}, {"n": "Promulgación", "i": 5971235}]}