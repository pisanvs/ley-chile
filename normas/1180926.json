{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCI&#xD3;N SII N&#xB0; 119 EXENTA DE 2020</div></div>", "i": 10362511}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 72, del 31 de agosto de 2022, modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1150286&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta SII N&#xB0; 119, de 2020</a>, que establece la obligaci&#xF3;n de presentar declaraci&#xF3;n jurada sobre enajenaci&#xF3;n de entidades extranjeras con activos subyacentes en Chile por medio de formulario N&#xB0; 1921, en lo relativo a sus obligados, y reemplaza sus instrucciones.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento, est&#xE1; publicado en &quot;www.sii.cl&quot;.-</div></div>", "i": 10362512}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Hern&#xE1;n Andr&#xE9;s Frigolett C&#xF3;rdova, Director.</div></div>", "i": 10362513}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "72 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-72 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN SII N° 119 EXENTA DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2182519", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-08-31", "doble_articulado": false, "id_norma": "1180926", "numero_fuente": "43345", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-09-05", "vigencias": [{"desde": "2022-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia