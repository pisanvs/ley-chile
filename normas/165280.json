{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6264207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 435, de 21 Octubre 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a las personas que se individualizan para efectuar el servicio de taxi colectivo urbano que se indica a continuaci&#xF3;n:</div><br><div class=\"p\">LINEA N&#xB0; 34.- &quot;11 DE SEPTIEMBRE - HOSPITAL&quot;</div><br><div class=\"p\">&nbsp; &nbsp;  Ida: Terminal en Poblaci&#xF3;n 11 de Septiembre en calle Colo Colo, Mendoza, Tucapel, Almagro, Avda. Ricardo Vicu&#xF1;a, Hospital.</div><div class=\"p\">&nbsp; &nbsp;  Regreso: Circunvalaci&#xF3;n, Avda. Ricardo Vicu&#xF1;a, Col&#xF3;n, Lientur, Avda. Ercilla, Galvarino, Los Angeles, Colo Colo terminal en Poblaci&#xF3;n 11 de Septiembre.- </div></div>", "i": 6264208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Navarro Ruiz, Secretario Regional Ministerial Transportes y Telecomunicaciones, VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6264209}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "435 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-435 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-10-21", "doble_articulado": false, "id_norma": "165280", "numero_fuente": "32307", "tipo_version": "3