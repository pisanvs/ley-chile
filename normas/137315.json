{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,349.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171544}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados al pais por el teniente-coronel de la &#xE9;poca de la Independencia, don Jos&#xE9; Antonio Y&#xE1;&#xF1;ez, conc&#xE9;dese, por gracia, a su hija do&#xF1;a Ejidia Y&#xE1;&#xF1;ez v. de Larrain, derecho a percibir la pension de montep&#xED;o militar correspondiente al empleo de coronel, en vez de la de teniente-coronel que actualmente disfruta.</div><br></div>", "i": 6171545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, trece de agosto de mil novecientos diez.-</div><div class=\"p\">El&#xED;as Fern&#xE1;ndez A.- C&#xE1;rlos&nbsp; Larrain Claro. </div></div>", "i": 6171546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2349", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2349"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-08-13", "doble_articulado": false, "id_norma": "137315", "numero_fuente": "9769", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-08-16", "vigencias": [{"desde": "1910-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci