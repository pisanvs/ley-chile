{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">DEJA SIN EFECTO RESOLUCI&#xD3;N QUE INDICA</div></div>", "i": 9651489}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.164, de 20 de noviembre de 2015, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=1068808&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA;2.802, de 2014</a>, de esta Subsecretar&#xED;a, que modific&#xF3; las resoluciones exentas que aprobaron los programas de investigaci&#xF3;n de descarte para las pesquer&#xED;as de Sardina com&#xFA;n y Anchoveta, y su fauna acompa&#xF1;ante, para la flota artesanal en las &#xE1;reas mar&#xED;timas de la VIII, V, XIV y VII Regiones.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n se publicar&#xE1; en el sitio de dominio electr&#xF3;nico de esta Subsecretar&#xED;a y del Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 9651490, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de noviembre de 2015.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9651491}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3164 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-3164 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "DEJA SIN EFECTO RESOLUCIÓN QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "IdDO 970268"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "201