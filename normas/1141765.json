{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  NOMBRAMIENTO DE MINISTRO DE ESTADO EN LOS DEPARTAMENTOS QUE SE INDICAN.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Febrero 22 de 1825.</div></div>", "i": 10115666}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Habiendo aceptado la renuncia que ha hecho el Jeneral D. Francisco Antonio Pinto de los Ministerios de Relaciones Exteriores, del Interior y de la Guerra, vengo en nombrar para que le subrogue en los espresados departamentos a D. Francisco Ram&#xF3;n de Vicu&#xF1;a. T&#xF3;mese raz&#xF3;n, comun&#xED;quese e ins&#xE9;rtase en el Boletin.</div></div>", "i": 10115667}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Astorga.</div></div>", "i": 10115668}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "NOMBRAMIENTO DE MINISTRO DE ESTADO EN LOS DEPARTAMENTOS QUE SE INDICAN.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-02-22", "doble_articulado": false, "id_norma": "1141765", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1825-02-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1825-02-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2020-04-21", "fecha_version": "1825-02-22", "fecha_act