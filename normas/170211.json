{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 117 EXENTO, DE 2000 </div></div>", "i": 7270691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 117 de fecha 10 de abril de 2000 del Ministerio de Educaci&#xF3;n, se modific&#xF3; el art&#xED;culo 1&#xBA; del decreto exento de Educaci&#xF3;n N&#xBA; 35 del 16 de marzo de 1989 modificado por decreto exento de Educaci&#xF3;n N&#xBA; 168 del 21 de abril de 1993, que autoriza el funcionamiento del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela de Estudios Superiores ESES Alpes de Santiago, en el sentido de reemplazar la actual denominaci&#xF3;n por la siguiente:</div><div class=\"p\"> </div><div class=\"p\">Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Centro de Formaci&#xF3;n T&#xE9;cnica</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Alpes S.A.</div><div class=\"p\">Nombre de la Instituci&#xF3;n : Centro de Formaci&#xF3;n T&#xE9;cnica Alpes</div><div class=\"p\">Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Santiago</div><br></div>", "i": 7270692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de mayo de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7270693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "117 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-117 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 117 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-04-10", "doble_articulado": false,