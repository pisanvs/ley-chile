{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6039752}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 461, de 30 de abril de 1997, se expropiaron los lotes N&#xBA;s 14, 41 y 42, superficies 25.844 m2., 34.210 m2. y 276 m2., roles de aval&#xFA;o 2247-39 y 2228-7, comuna de Chill&#xE1;n, para la obra Camino Acceso Norte a Concepci&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Sergio Galaz Ulloa y Horacio Puentes Jaramillo y Otras, ascendente a las cantidades de $5.411.082.- para el lote N&#xBA; 14 y $37.179.694.- para los lotes N&#xBA;s 41 y 42.-</div><br></div>", "i": 6039753}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6039754}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "461", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-461"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "CHILLAN", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-30", "doble_articulado": false, "id_norma": "73711", "numero_fuente": "35791", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-16", "vigencias": [{"desde": "1997-06-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMR", "fecha_ingreso": "1997-06-30", "fecha_version": "1997-