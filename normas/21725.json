{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 712 EXENTO, 1993 </div></div>", "i": 5945960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 712 de 31 de diciembre de 1993, se han aprobado planes de estudio para la Educaci&#xF3;n B&#xE1;sica y Media Humanistico-Cientifica, al colegio Little College de Santiago, que se aplicar&#xE1;n a partir del a&#xF1;o 1993 en todos los cursos de Educaci&#xF3;n B&#xE1;sica y a partir de 1994 y gradualmente en Educaci&#xF3;n Media: 1er, a&#xF1;o 1994 - 2do. a&#xF1;o 1995 - 3er a&#xF1;o 1996 - 4to. a&#xF1;o 1997.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas que se contemplan en el plan de estudio aprobado en el art&#xED;culo anterior.</div><br></div>", "i": 5945961}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 31 de Diciembre de 1993.- Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945962}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "712", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-712"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 712 EXENTO, 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO LITTLE COLLEGE", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-12-31", "doble_articulado": false, "id_norma": "21725", "numero_fuente": "34797", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-02-22", "vigencias": [{"desde": "1994-02-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"