{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;337 EXENTO, DE 2008</div></div>", "i": 8953804}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;337, de fecha 5 de enero de 2008, del Ministerio de Educaci&#xF3;n, se deja sin efecto lo dispuesto en el Art&#xED;culo 2&#xBA; del <a href=\"https://www.leychile.cl/Navegar?idNorma=190951&amp;idParte=0&amp;idVersion=\">decreto exento de Educaci&#xF3;n N&#xBA;639, del 11 de septiembre de 2001</a>, en la parte pertinente al reconocimiento de la sede N&#xBA;8 de la ciudad de Punta Arenas, entre otras, del Centro de Formaci&#xF3;n T&#xE9;cnica Salesianos Don Bosco, debido a que nunca se iniciaron servicios educativos en dicha sede, por lo que no registra movimiento alguno desde su creaci&#xF3;n. Ello, a solicitud de la propia Instituci&#xF3;n.</div></div>", "i": 8953805, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de marzo de 2008.- Pilar Romaguera Gracia, Subsecretaria de Educaci&#xF3;n.</div><br></div>", "i": 8953806}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "337 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-337 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº337 EXENTO, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-01-05", "doble_articulado": false, "id_norma": "1015774", "numero_fuente": "39723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-30", "vigencias": [{"desde": "2010-07-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig