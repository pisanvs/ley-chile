{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8948552}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.970, de 2 de julio de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a GUIGUS S.A. para capturar, en loberas ubicadas en el &#xE1;rea mar&#xED;tima de la II y IV Regiones, en el plazo de 1 a&#xF1;o contado desde la fecha de la presente resoluci&#xF3;n, la cantidad total de 49 ejemplares de la especie Lobo marino com&#xFA;n, en la forma y condiciones se&#xF1;aladas en la resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  El solicitante designa como persona responsable de esta autorizaci&#xF3;n a don Guillermo Rodr&#xED;guez Ban.</div></div>", "i": 8948553}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de julio de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 8948554}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1970", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1970"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-07-02", "doble_articulado": false, "id_norma": "1015624", "numero_fuente": "39717", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-07-23", "vigencias": [{"desde": "2010-07-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-07-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-07-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [