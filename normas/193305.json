{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6364370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.941, de 30 de noviembre del 2001, se rectific&#xF3; el decreto MOP N&#xBA;1.468 de 28 de septiembre de 2001, que orden&#xF3; la expropiaci&#xF3;n entre otros en lote de terreno N&#xBA;560-H1, en el sentido de sustituir en la cl&#xE1;usula 2&#xAA; donde dice lote 559-H1 debe decir lote 560-H1. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.</div><br></div>", "i": 6364371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6364372}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1941", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1941"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-11-30", "doble_articulado": false, "id_norma": "193305", "numero_fuente": "37149", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-01-02", "vigencias": [{"desde": "2002-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-01-04", "fecha_version": "2002-01-02", "fecha_actualizacion_texto": "2002-01-02", "tipo_tratado": ""}, "alertas": [], "alerta_global": "