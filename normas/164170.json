{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS DE &quot;COMPA&#xD1;IA DE SEGUROS DE VIDA CONTINENTAL S.A.&quot; </div></div>", "i": 6260710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: que por resoluci&#xF3;n N&#xBA; 143 de 27.09.85 se aprob&#xF3; reforma de estatutos sociedad An&#xF3;nima &quot;Compa&#xF1;&#xED;a de Seguros de Vida Continental S.A.&quot;, en liquidaci&#xF3;n, que consta de la escritura p&#xFA;blica de 20 de Septiembre de 1985, otorgada en la Notar&#xED;a de Santiago de don Horacio Soissa B. La reforma consiste en: Modificar la raz&#xF3;n social la que en lo sucesivo ser&#xE1; &quot;Compa&#xF1;&#xED;a de Seguros de Vida Centenario S.A. en liquidaci&#xF3;n. </div></div>", "i": 6260711}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Septiembre de 1985. Ana Mar&#xED;a Siefer Navas, Secretario General.</div><br></div>", "i": 6260712}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "143", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-143"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE COMPAÑIA DE SEGUROS DE VIDA CONTINENTAL S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-09-27", "doble_articulado": false, "id_norma": "164170", "numero_fuente": "32289", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-10-05", "vigencias": [{"desde": "1985-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-10-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-10-05", "fi