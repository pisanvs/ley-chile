{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que concede un suplemento de 80,000 pesos al presupuesto del Ministerio del Interior, para gastos imprevistos</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 22 de Noviembre de 1901.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de ochenta mil pesos ($ 80,000) al &#xED;tem 15 de la partida 66, para gastos imprevistos del presupuesto del Ministerio del Interior.</div><br></div>", "i": 8274372}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de Rep&#xFA;blica.- JERMAN RIESCO.- Ismael Tocornal.</div><br></div>", "i": 8274373}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1482", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1482"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "QUE CONCEDE UN SUPLEMENTO DE 80,000 PESOS AL P`RESUPUESTO DEL MINISTERIO DEL INTERIOR, PARA GASTOS IMPREVISTOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1901", "MODIFICACION", "MINISTERIO", "INTERIOR", "SUPLEMENTO", "GASTOS IMPREVISTOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-11-22", "doble_articulado": false, "id_norma": "22684", "numero_fuente": "7078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-11-22", "vigencias": [{"desde": "1901-11-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}