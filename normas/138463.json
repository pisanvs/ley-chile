{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,958.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 7250178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Prorr&#xF3;gase en dieciocho meses los plazos se&#xF1;alados por la lei n&#xFA;mero 2,879, del 8 de febrero de 1914, para someter a la aprobacion del Gobierno los planos de las diferentes secciones del ferrocarril de Paniahue a Nilahue, de que son concesionarios los se&#xF1;ores don Eduardo Valdivieso Valdes i don Eduardo Err&#xE1;zuriz Larrain.</div><br></div>", "i": 7250179, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto,&nbsp; prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a quince de diciembre de mil novecientos catorce.- Ramon Barros Luco.- Julio Garc&#xE9;s.</div><br></div>", "i": 7250180}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2958", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2958"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-12-15", "doble_articulado": false, "id_norma": "138463", "numero_fuente": "11055", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-12-28", "vigencias": [{"desde": "1914-12-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1914-12-28", "fin_vigencia": "