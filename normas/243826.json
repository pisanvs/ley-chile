{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 394, DE 2005 </div></div>", "i": 6547913}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 394, de 5 de agosto de 2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se dispuso el inicio de la Puesta en Marcha definitiva de parte de la Concesi&#xF3;n Dos, adjudicada a &quot;Revisiones T&#xE9;cnicas Serviden Limitada&quot;, para operar en la comuna de Rancagua, una Planta Revisora Clase AB, dotada de cinco (5) l&#xED;neas de revisi&#xF3;n tipo liviana y dos (2) l&#xED;neas de revisi&#xF3;n tipo pesada, a contar del 6 de agosto de 2005. </div></div>", "i": 6547914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Pablo Pallamar Az&#xFA;a, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Sexta Regi&#xF3;n.</div><br></div>", "i": 6547915}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "394", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-394"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 394, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-08-05", "doble_articulado": false, "id_norma": "243826", "numero_fuente": "38308", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-10", "vigencias": [{"desde": "2005-11-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-10", "f