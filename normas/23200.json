{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,211, que habilita como puerto mayor terrestre el puerto menor de Huahum, dependiente de la Aduana de Valdivia.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,211.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953052}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Habil&#xED;tase como puerto mayor terrestre, dependiente de la Aduana de Valdivia, el puerto menor de Huahum.</div><br></div>", "i": 5953053}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 7 de Setiembre de 1909.- PEDRO MONTT.- Agustin Edwards.</div><br></div>", "i": 5953054}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2211", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2211"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NUM. 2,211, QUE HABILITA COMO PUERTO MAYO TERRESTRE EL PUERTO MENOR DE HUAHUM, DEPENDIENTE DE LA ADUANA DE VALDIVIA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PUERTO HUAHUM", "VALDIVIA", "PUERTO MAYOR", "HABILITACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-09-07", "doble_articulado": false, "id_norma": "23200", "numero_fuente": "9491", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-09-14", "vigencias": [{"desde": "1909-09-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":