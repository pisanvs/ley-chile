{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6317153}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 14, de 10 de enero de 2001, de esta Subsecretar&#xED;a, prorr&#xF3;gase hasta el 31 de octubre de 2001 el plazo otorgado a CORPESCA S.A. para desarrollar operaciones pesqueras con la nave &apos;&apos;Eperva 45&apos;&apos;, autorizada por las resoluciones N&#xBA; 69 y N&#xBA; 999, ambas de 2000, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 6317154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de enero de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6317155}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-14"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-01-10", "fecha_derogacion": "2001-10-09", "doble_articulado": false, "id_norma": "180434", "numero_fuente": "36864", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-01-17", "vigencias": [{"desde": "2001-10-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2001-01-17", "hasta": "2001-10-08", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2001-10-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-17", "fin_vigencia": "2001-10-08", "tipo_versi