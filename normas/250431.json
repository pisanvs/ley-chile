{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N&#xB0; 1.273 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 1273, celebrada el 8 de junio de 2006, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 6572611}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1273-01-060608 - Tasa de inter&#xE9;s para pago diferido de Derechos de Aduana.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; Se acord&#xF3;, en conformidad con lo establecido en la letra c) del art&#xED;culo 10 de la Ley N&#xB0; 18.634, que la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de Derechos de Aduana durante el semestre que expira el 31 de diciembre de 2006, ser&#xE1; de 7,6% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica. </div></div>", "i": 6572612}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de junio de 2006.- Miguel Angel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 6572613}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1273", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1273"}, {"tipo": "5", "numero": "1273-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1273-01"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESION N° 1.273", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BIENES DE CAPITAL", "DERECHOS ADUANEROS", "PAGO DIFERIDO", "TASA DE INTERES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-08", "doble_articulado": false, "id_norma": "250431", "numero_fuente": "38488", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-