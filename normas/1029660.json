{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9184193}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (exento) N&#xBA;1577 de fecha 29 de julio de 2011, se expropi&#xF3; el lote de terreno N&#xBA;14, superficie 748 m2, rol N&#xBA;67-205, comuna de Lago Ranco, para la obra &quot;Construcci&#xF3;n Puentes Caicayen y Hueinahue, camino Maihue Hueinahue - Rupumeica&quot;, Comunas de Futrono y Lago Ranco, Regi&#xF3;n de los R&#xED;os y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario MANUELA DEL CARMEN SANTIB&#xC1;&#xD1;EZ &#xD1;ANCUMIL, ascendente a la cantidad de $1.762.411.- </div></div>", "i": 9184194}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9184195}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1577 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1577 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-07-29", "doble_articulado": false, "id_norma": "1029660", "numero_fuente": "40062", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-09-15", "vigencias": [{"desde": "2011-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "2932", "fecha_ingreso": "2011-09-15", "fecha_version": "2011-09-15", "fecha_actua