{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO&nbsp; N&#xBA;532 EXENTO, DE 2000 </div></div>", "i": 6358585}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA;532 de 4 de diciembre de 2000, se ha aprobado, a partir del a&#xF1;o escolar 2001, al Colegio &quot;El Almendral&quot;, comuna San Pedro de la Paz, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, para que aplique de acuerdo al decreto supremo de Educaci&#xF3;n N&#xBA;40 de 1996 y su modificaci&#xF3;n, decreto supremo de Educaci&#xF3;n N&#xBA;240 de 1999, el plan de estudio para 7&#xBA; a&#xF1;o (NB.5) de Ense&#xF1;anza B&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en el presente decreto. </div></div>", "i": 6358586}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de diciembre de 2000.- Patricio Vilaplana Barberis, Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 6358587}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "532 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-532 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº532 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-04", "doble_articulado": false, "id_norma": "191946", "numero_fuente": "37118", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-23", "vigencias": [{"desde": "2001-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"i