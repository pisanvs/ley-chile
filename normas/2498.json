{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO </div></div>", "i": 5852925}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto Secc. 2da. N&#xB0; 501 de fecha 23 de Noviembre de 1992, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n total inmueble calle San Francisco 1802, comuna de Santiago, aparente dominio Banco Concepci&#xF3;n. Superficie aproximada 301,50 M2. Deslindes: Norte, 22,50 mts. calle &#xD1;uble; Sur, 22,50 mts. otro propietario; Oriente, 13,40 mts. otro propietario y Poniente 13,40 mts. Calle San Francisco. Indemnizaci&#xF3;n provisional $ 9.045.000.- pagadera contado.-</div><br></div>", "i": 5852926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Jaime Ravinet de la Fuente, Alcalde de Santiago. </div></div>", "i": 5852927}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "501", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-501"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "DECRETO EXPROPIATORIO", "BIEN RAIZ", "BIEN INMUEBLE", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-11-23", "doble_articulado": false, "id_norma": "2498", "numero_fuente": "34455-2", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-01-02", "vigencias": [{"desde": "1993-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1993-01-02", "fecha_actu