{"html": [{"t": "<div><div class=\"p\">EXTRACTO </div></div>", "i": 6432348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por circular N&#xBA; 37 de 14 de julio de 2003, de la Direcci&#xF3;n del Servicio, se han actualizado, recopilado, ampliado y/o modificado instrucciones referidas al D.F.L. N&#xBA;2, de 1959, sobre viviendas econ&#xF3;micas, en especial en materias relacionadas con el impuesto territorial, as&#xED; como sobre su fiscalizaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular se encuentra incluido en la p&#xE1;gina web de este Servicio en Internet (www.sii.cl) y, adem&#xE1;s, se publicar&#xE1; en el Bolet&#xED;n del Servicio del mes de julio de 2003.</div><br></div>", "i": 6432349}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Juan Toro Rivera, Director.</div><br></div>", "i": 6432350}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "37", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "CIR-37"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VIVIENDAS ECONOMICAS", "IMPUESTO TERRITORIAL", "INSTRUCCIONES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-07-14", "doble_articulado": false, "id_norma": "212669", "numero_fuente": "37612", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-07-18", "vigencias": [{"desde": "2003-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-07-18", "fin_vigencia": "", "tipo_version": "3"}], "