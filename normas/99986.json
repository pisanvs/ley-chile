{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6112886}, {"t": "<div><div class=\"p\">Por decreto MOP. No. 535, de 29 de abril de 1998, se expropiaron los lotes de terreno No.s. 4, 5, 6 y 12, superficies 3.076, 5.101, 7.740 y 4.392 m., roles de aval&#xFA;o 227-1 y 233-38, comuna de Santa Juana, para la obra Camino de la Madera, sector Bifurcaci&#xF3;n Diuqu&#xED;n-Santa Juana, Km.</div><div class=\"p\">22.500 al 31.251,47, y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Forestal Mininco S.A. y Juan F&#xE9;lix Jofr&#xE9; Soto y otro, ascendente a las cantidades de $ 3.654.042.- para los lotes No.s. 4, 5 y 6, y $ 4.002.811.- para el lote No. 12.</div><br></div>", "i": 6112887}, {"t": "<div><div class=\"p\">- Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br></div>", "i": 6112888}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "535", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-535"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SANTA JUANA", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-29", "doble_articulado": false, "id_norma": "99986", "numero_fuente": "36078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-01", "vigencias": [{"desde": "1998-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por"