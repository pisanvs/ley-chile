{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CERTIFICADO </div></div>", "i": 5844923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, a base de los antecedentes proporcionados por el Fondo Monetario Internacional y Corfo de New York certifica, a requerimiento de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante, para los efectos de lo dispuesto en el Art&#xED;culo N&#xB0; 116 del Decreto Supremo de la Subsecretar&#xED;a de Marina N&#xB0; 427, de 25 de junio de 1979, que la variaci&#xF3;n experimentada por el I.P.C. de los Estados Unidos de Am&#xE9;rica, entre el 1&#xB0; de diciembre de 1990 y el 30 de noviembre de 1991 fue de 2,9895%. </div></div>", "i": 5844924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 17 de diciembre de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 5844925}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIRECCION GENERAL DEL TERRITORIO MARITIMO Y DE MARINA MERCANTE", "PRESTACION SERVICIOS", "TARIFAS", "DERECHOS SERVICIOS", "REAJUSTE ANUAL", "IPC ESTADOS UNIDOS AMERICA", "CERTIFICACION", "VARIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-12-17", "doble_articulado": false, "id_norma": "1708", "numero_fuente": "34145", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-18", "vigencias": [{"desde": "1991-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-12-18", "fin_vig