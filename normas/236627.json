{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 987 EXENTA, DE 2005 </div><br></div>", "i": 6520228}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 987, de fecha 21 de marzo de 2005, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se otorga reconocimiento oficial a Escuela de Conductores Profesionales &quot;Plaza y D&#xED;az Limitada&quot;, para impartir cursos conducentes a la obtenci&#xF3;n de licencia de conducir profesional clases A2, A3 y A4, en la sede ubicada en Neptuno N&#xBA; 814-C, comuna de Lo Prado, y taller mec&#xE1;nico, ubicado en Abtao N&#xBA; 365, comuna de Quinta Normal.-</div><br></div>", "i": 6520229}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Silvio Albarr&#xE1;n Alb&#xE1;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6520230}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "987 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-987 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 987 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-21", "doble_articulado": false, "id_norma": "236627", "numero_fuente": "38121", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-29", "vigencias": [{"desde": "2005-03-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic