{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6312858}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;4.570, de 29 de septiembre del 2000, se expropi&#xF3; el lote de terreno N&#xBA;59, superficie 1.750 m2., rol de aval&#xFA;o N&#xBA;94-131 de la comuna de Pelarco, para la obra Camino Los Robles - Huencuecho - Bajo Perqu&#xED;n, Sector Los Robles - Huencuecho, Tramo Km.</div><div class=\"p\">24,090 a Km. 46,079.85 y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietario Carlos Patricio Ruiz Tagle Ortiz, ascendente a la cantidad de $603.922.- </div></div>", "i": 6312859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6312860}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4570", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-4570"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-29", "doble_articulado": false, "id_norma": "179167", "numero_fuente": "36838", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-12-15", "vigencias": [{"desde": "2000-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MEM", "fecha_ingreso": "2000-12-19", "fecha_version": "2000-12-15", "fecha_actualizacion_te