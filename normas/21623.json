{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 643, DE 1995 </div></div>", "i": 5945680}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 643 de 27 de Noviembre de 1995, se ha aprobado, a partir del a&#xF1;o escolar 1996, un plan especial de estudio al Colegio &quot;El Carmen Teresiano&quot;, de la comuna de Vitacura, que se aplicar&#xE1; en 1er. y 2do. a&#xF1;o de Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de la asignatura de Computaci&#xF3;n para los citados cursos. </div></div>", "i": 5945681}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de Diciembre de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "643 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-643 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 643, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO EL CARMEN TERESIANO", "VITACURA", "PLANES", "ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-11-27", "doble_articulado": false, "id_norma": "21623", "numero_fuente": "35347", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-12-21", "vigencias": [{"desde": "1995-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-12-21", "fin_vigencia": "", "tip