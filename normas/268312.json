{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7361442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.782, de 28 de diciembre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SUR AUSTRAL S.A. para realizar operaciones pesqueras a contar del 1&#xBA; de enero del a&#xF1;o 2008 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con la nave f&#xE1;brica denominada &quot;Ocean Dawn&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 47&#xB0; L.S. y 57&#xB0; L.S., por fuera de las l&#xED;neas de base recta, respecto de los recursos, en las &#xE1;reas y con las obligaciones establecidas en las respectivas autorizaciones. </div></div>", "i": 7361443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de diciembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7361444}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3782 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3782 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-28", "doble_articulado": false, "id_norma": "268312", "numero_fuente": "38958", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-01-11", "vigencias": [{"desde": "2008-01-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-01-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-01-11", "fin_vige