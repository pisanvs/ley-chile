{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xB0;62 EXENTA, DE 2007 </div></div>", "i": 6601283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 62, de 15 de enero de 2007, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xB0; 5 de la resoluci&#xF3;n N&#xB0; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo como combustible:</div><br><div class=\"p\">Empresa&nbsp; &nbsp; &nbsp;  Nombre&nbsp; &nbsp; &nbsp; &nbsp;  Direcci&#xF3;n&nbsp; &nbsp; &nbsp;  Ciudad</div><div class=\"p\">Habilitada&nbsp;  del Taller&nbsp; &nbsp;  del Taller&nbsp; &nbsp; Habilitada</div><br><div class=\"p\">G.L.P.&nbsp; &nbsp; &nbsp;  Distribuidora&nbsp;  Avenida&nbsp; &nbsp; &nbsp; La Serena</div><div class=\"p\">Motor&nbsp; &nbsp; &nbsp; &nbsp; Automotriz&nbsp; &nbsp;  Balmaceda</div><div class=\"p\">Ltda.&nbsp; &nbsp; &nbsp; &nbsp; Ovalle&nbsp; &nbsp; &nbsp; &nbsp;  N&#xB0; 2391</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  S.A.</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.</div><br></div>", "i": 6601284}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Danilo N&#xFA;&#xF1;ez Izquierdo, Subsecretario de Transportes.</div><br></div>", "i": 6601285}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "62 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-62 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION N°62 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [