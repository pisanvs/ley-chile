{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7229691}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta N&#xB0; 753 de 05 de Agosto de 1988 se cancela resoluci&#xF3;n N&#xB0; 449 de 25 de Marzo de 1987 de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la V Regi&#xF3;n que autoriz&#xF3; al Sr. Osvaldo Cartagena Morales para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en calle El Array&#xE1;n N&#xB0; 2460, Poblaci&#xF3;n, Albatros, Comuna de Algarrobo.</div><br></div>", "i": 7229692}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 05 de Agosto de 1988.- Hern&#xE1;n V&#xE1;squez Wacquez, Secretario Regional Ministerial de Transportes y Telecomunicaciones V Regi&#xF3;n.</div><br></div>", "i": 7229693}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "753 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-753 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-05", "doble_articulado": false, "id_norma": "95444", "numero_fuente": "33309", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-27", "vigencias": [{"desde": "1989-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-