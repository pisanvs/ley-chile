{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;mero 4,266</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6203512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Se declara de abono el tiempo de servicios que al capit&#xE1;n de Ej&#xE9;rcito, don Washington Bravo Bravo, le faltaba a la fecha de su fallecimiento para dejar a su familia derecho a montep&#xED;o, en conformidad a la ley n&#xFA;mero 3,029, de 9 de Septiembre de 1915&quot;.</div><br></div>", "i": 6203513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintisiete de Enero de mil novecientos veintiocho.- Carlos Ib&#xE1;&#xF1;ez del Campo.- Bartolom&#xE9; Blanche E. </div></div>", "i": 6203514}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4266", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4266"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-01-27", "doble_articulado": false, "id_norma": "147196", "numero_fuente": "15194", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-10-09", "vigencias": [{"desde": "1928-10-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1928-10-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1928-10-09", "fin_v