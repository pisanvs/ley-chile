{"html": [{"t": "<div><br><div class=\"p\">CREA DEPARTAMENTO DEPENDIENTE DEL DEPARTAMENTO SUBDIRECCI&#xD3;N DE RECURSOS HUMANOS</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 9644029}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 85, del 20 de octubre de 2015, que establece:</div><br><div class=\"p\">&nbsp; &nbsp;  Crea el Departamento de Desarrollo Organizacional, dependiente del Departamento Subdirecci&#xF3;n de Recursos Humanos, y sobre otras medidas que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2015.</div></div>", "i": 9644030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "85 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-85 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CREA DEPARTAMENTO DEPENDIENTE DEL DEPARTAMENTO SUBDIRECCIÓN DE RECURSOS HUMANOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN; IdDO 958823"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-10-20", "doble_articulado": false, "id_norma": "1083100", "numero_fuente": "41291", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-10-26", "vigencias": [{"desde": "2015-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-10-26", "fin_vigencia": ""}, "vigencias_version_n