{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,617.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172529}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Aum&#xE9;ntase, por gracia, a do&#xF1;a Concepcion Larrain, v. de Gana, esposa del sarjento-mayor de Ej&#xE9;rcito don Luis V&#xED;ctor Gana C., la pension de que actualmente disfruta, a mil doscientos pesos anuales ($ 1,200).</div><br></div>", "i": 6172530}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiseis de enero de mil novecientos doce.- Ramon Barros Luco.- Alejandro Rosselot.</div><br></div>", "i": 6172531}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2617", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2617"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-01-26", "doble_articulado": false, "id_norma": "137594", "numero_fuente": "10190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-01-27", "vigencias": [{"desde": "1912-01-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-01-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-01-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "