{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6262375}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 87 de fecha 28 de Enero de 1985, de la Secretaria Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a los se&#xF1;ores Antonio Gonz&#xE1;lez Olbaneja y Miguel Gonz&#xE1;lez Prior, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6262376}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de Enero de 1985.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial, Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6262377}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "87 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-87 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-28", "doble_articulado": false, "id_norma": "164705", "numero_fuente": "32096", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-13", "vigencias": [{"desde": "1985-02-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-13", "fin_vigencia": "", "tipo_version": "3"}], "even