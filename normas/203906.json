{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A GACM S.A. </div></div>", "i": 6695075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 25.- Certifico que la GACM S.A. RUT.</div><div class=\"p\">N&#xBA;96.989.170-0, cumple con los requisitos establecidos en la resoluci&#xF3;n Ex. N&#xBA;3.722 del 28 de julio de 2000 y que en consecuencia tiene la calidad de Agente retenedor del Impuesto al Valor Agregado, por el proceso de faenamiento de ganado y la comercializaci&#xF3;n de carne que efect&#xFA;e a contar del per&#xED;odo comprendido entre el 1&#xBA; del mes siguiente al de la publicaci&#xF3;n del extracto de la resoluci&#xF3;n en el Diario Oficial.- </div></div>", "i": 6695076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Erica Morales Lartiga, Director Regional (S). </div></div>", "i": 6695077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "25", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-25"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A GACM S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "203906", "numero_fuente": "37392", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-10-25", "vigencias": [{"desde": "2002-10-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-10-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-10-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe