{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Autoriza la inversion de $ 80,000 en el sostenimiento del Presidio de Santiago</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,325.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7165692}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta hasta ochenta mil pesos en el sostenimiento del Presidio de Santiago durante el presente a&#xF1;o.</div><br></div>", "i": 7165693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo, por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 18 de Julio de 1910.- El&#xED;as Fern&#xE1;ndez Albano.- Emiliano Figueroa.</div><br></div>", "i": 7165694}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2325", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2325"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "AUTORIZA LA INVERSIÓN DE $ 80.000 EN EL SOSTENIMIENTO DEL PRESIDIO DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESIDIO SANTIAGO", "MANTENCION", "FONDOS", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-07-18", "doble_articulado": false, "id_norma": "23256", "numero_fuente": "9749", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-07-22", "vigencias": [{"desde": "1910-07-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi