{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7343312}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.610 de 23 de mayo de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA SAN ANTONIO S.A., para realizar actividades extractivas en alta mar con la nave &quot;Vigri&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp;  CB-2944.</div><div class=\"p\">Puerto de matr&#xED;cula&nbsp; &nbsp; &nbsp; Valpara&#xED;so.</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2394.</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp;  28,14 m.</div><div class=\"p\">T.R.G. (Internacional)&nbsp;  208,18.</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 6,87 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  5,71 m.</div><br></div>", "i": 7343313}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de mayo de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7343314}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1610 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1610 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-05-23", "doble_articulado": false, "id_norma": "261412", "numero_fuente": "38779", "tipo_version": "3", "tipo_version_s": "Únic