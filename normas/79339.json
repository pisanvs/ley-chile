{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO No. 62 DE 1992 </div></div>", "i": 7214311}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 62 de 13 de marzo de 1992 se han modificado los decretos supremos exentos de Educaci&#xF3;n N&#xB0;s 257 de 1991 y 226 de 1983 que aprobaron planes y programas de estudio al Colegio Santiago College, de Santiago.</div><div class=\"p\">Adem&#xE1;s, se aprueba programa de estudio para la asignatura de Econom&#xED;a para 3&#xB0; y 4&#xB0; a&#xF1;o medio.</div><br></div>", "i": 7214312}, {"t": "<div><div class=\"p\">Santiago, 15 de Abril de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7214313}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "62 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-62 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO No. 62 DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-13", "doble_articulado": false, "id_norma": "79339", "numero_fuente": "34264", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-05-12", "vigencias": [{"desde": "1992-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-05-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MNV", "fecha_ingreso": "1997-12-