{"html": [{"t": "<div><div class=\"p\">AUTORIZA TRASLADO DE PLANTA</div><br><br><br></div>", "i": 8340084}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 935 de 05 de Septiembre de 1988 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a; Fomento y Reconstrucci&#xF3;n, se autoriza a Sociedad Lastra y Compa&#xF1;&#xED;a Limitada, domiciliada en Concepci&#xF3;n, para trasladar la planta autorizada por resoluci&#xF3;n No. 303, de 1986, de esta Subsecretar&#xED;a, ubicada en Talcahuano, calle 11 Norte No. 186, al Parque Industrial Escuadr&#xF3;n, Lotes C-17 y C-18, en la ciudad de Coronel, VIII Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  La presente autorizaci&#xF3;n es sin perjuicio de las que corresponda conferir a otras autoridades, de acuerdo a las disposiciones legales y reglamentarias vigentes o que se establezcan.</div><br></div>", "i": 8340085}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 05 de Septiembre de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8340086}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "935", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-935"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA TRASLADO DE PLANTA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-09-05", "fecha_derogacion": "1990-09-03", "doble_articulado": false, "id_norma": "130999", "numero_fuente": "33173", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1988-09-15", "vigencias": [{"desde": "1990-09-03", "hasta": "", "tipo_versi