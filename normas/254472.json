{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6587048}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.664, de 14 de septiembre de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A. para ampliar actividades extractivas con la nave &quot;Bucanero I&quot;, sobre el recurso hidrobiol&#xF3;gico Merluza de cola, en el &#xE1;rea mar&#xED;tima de la VII, IX y X Regiones, por fuera de la l&#xED;nea imaginaria trazada a una distancia de 60 millas marinas contadas desde las respectivas l&#xED;neas de base normales o rectas, seg&#xFA;n corresponda, con arrastre de media agua. </div></div>", "i": 6587049}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de septiembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6587050}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2664 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2664 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2006-09-14", "fecha_derogacion": "2012-08-31", "doble_articulado": false, "id_norma": "254472", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2006-10-21", "vigencias": [{"desde": "2012-08-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2006-10-21", "hasta": "2012-08-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2012-08-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inici