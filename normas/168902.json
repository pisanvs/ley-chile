{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 153 DE 1984 </div></div>", "i": 6276007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 153 de 14 de Septiembre de 1984 se han aprobado los programas de estudio para las asignaturas del Plan Electivo de los cursos de Ense&#xF1;anza Media Human&#xED;stico Cient&#xED;fica del Villa Mar&#xED;a Academy. Los programas aprobados corresponden a las asignaturas de:</div><div class=\"p\">Dactilograf&#xED;a, Matem&#xE1;tica Avanzada, Cultura General, Biolog&#xED;a General.</div><br></div>", "i": 6276008}, {"t": "<div><div class=\"p\">Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6276009}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "153 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-153 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 153 DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-09-14", "doble_articulado": false, "id_norma": "168902", "numero_fuente": "32108", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-02-27", "vigencias": [{"desde": "1985-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-02-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-02-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAL", "fecha_ingreso": "2000-05-18", "fecha_version": "1985-02-27", "fecha_actualiza