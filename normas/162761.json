{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON ALEJANDRO RODRIGUEZ CANCINO PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 7266207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 455, de 31 de Julio de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Alejandro Rodr&#xED;guez Cancino, RUT 9.861.851-1, domiciliado en Poblaci&#xF3;n Mirasol, calle Los Sauces N&#xB0; 115, Puerto Montt, para instalar y operar en el Fundo El Aval, ubicado en la localidad La Pasada, comuna de Maull&#xED;n, X Regi&#xF3;n, un secador artificial de algas. En el secado podr&#xE1; utilizar como materia prima pelillo y luga-luga. </div></div>", "i": 7266208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de Julio de 1985.- Roberto Verdugo Gomaz, Subsecretario de Pesca.</div><br></div>", "i": 7266209}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "455", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-455"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A DON ALEJANDRO RODRIGUEZ CANCINO PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-07-31", "fecha_derogacion": "1992-01-16", "doble_articulado": false, "id_norma": "162761", "numero_fuente": "32240", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-08-05", "vigencias": [{"desde": "1992-01-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-08-05", "hasta": "1