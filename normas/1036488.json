{"html": [{"t": "<div><br><div class=\"p\">ORDENA EXPROPIACI&#xD3;N DE INMUEBLE QUE INDICA</div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9227925}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n (ex.) N&#xBA; 4.806 del 19/12/2011, conforme al art&#xED;culo 51 ley 16.391, DL. 2.186/1978 y DS. 68/1991 de Vivienda y Urbanismo, para cumplir con los programas de construcci&#xF3;n de viviendas, Serviu Regi&#xF3;n de la Araucan&#xED;a, orden&#xF3; modificaci&#xF3;n de <a href=\"https://www.leychile.cl/Navegar?idNorma=1034261&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n (ex) N&#xBA; 4.663 de fecha 07/12/2011</a>, en el sentido que el valor a pagar al expropiado es la suma de $227.450.410. En todo lo dem&#xE1;s se mantiene plenamente vigencia la resoluci&#xF3;n modificada </div><br></div>", "i": 9227926}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Director (P y T), Serviu Regi&#xF3;n de la Araucan&#xED;a.</div></div>", "i": 9227927}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4806 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-4806 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN IX REGIÓN DE LA ARAUCANÍA"], "titulo_norma": "ORDENA EXPROPIACIÓN DE INMUEBLE QUE INDICA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-19", "doble_articulado": false, "id_norma": "1036488", "numero_fuente": "40162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-01-16", "vigencias": [{"desde": "2012-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen