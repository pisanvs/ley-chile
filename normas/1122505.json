{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA AL NOTARIO SR. JUAN CARLOS SAN MART&#xCD;N MOLINA, PARA EMITIR BOLETAS DE HONORARIOS ELECTR&#xD3;NICAS, EN LA FORMA QUE INDICA</div></div>", "i": 9945994}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 67, de 28 de agosto de 2018, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Se autoriza al Notario individualizado para emitir boletas de honorarios electr&#xF3;nicas, de acuerdo a las condiciones que se indican.</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2018.</div></div>", "i": 9945995}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "67 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-67 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA AL NOTARIO SR. JUAN CARLOS SAN MARTÍN MOLINA, PARA EMITIR BOLETAS DE HONORARIOS ELECTRÓNICAS, EN LA FORMA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1456364", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-08-28", "doble_articulado": false, "id_norma": "1122505", "numero_fuente": "42146", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-08-31", "vigencias": [{"desde": "2018-08-31", "hasta": "", "tipo_version": "3", "tipo_version_