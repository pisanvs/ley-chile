{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10192672}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xB0; 1455, de 16 de diciembre de 2020, se modific&#xF3; el numeral segundo del <a href=\"https://www.leychile.cl/Navegar?idNorma=240125&amp;idParte=&amp;idVersion=\">Decreto (Exento) MOP N&#xB0; 571, de 17 de junio de 2005</a>, quedando de la siguiente forma: lotes N&#xB0; 9 y 10, ubicados en la comuna de Futrono, figura a nombre de MAR&#xCD;A CECILIA YABAR D&#xC1;VILA, rol de aval&#xFA;o 72-183, superficies 642 y 389 m2. Complem&#xE9;ntese el informe de tasaci&#xF3;n emitido el 6 de junio de 2001, con acta modificatoria de fecha 16 de mayo de 2019, del Jefe Subdepto. Expropiaciones Direcci&#xF3;n de Vialidad Regi&#xF3;n de Los R&#xED;os.</div></div>", "i": 10192673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10192674}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1455 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1455 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1875496", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-12-16", "doble_articulado": false, "id_norma": "1154644", "numero_fuente": "42855", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-01-15", "vigencias": [{"desde": "2021-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-01-