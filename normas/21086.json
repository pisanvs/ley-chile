{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 368 EXENTO, DE 1996</div><br><br></div>", "i": 5944118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Supremo Exento de Educaci&#xF3;n N&#xB0; 368, de 5 de julio de 1996, se ha aprobado, para la Sede Almirante Barroso del Liceo Experimental Art&#xED;stico de Santiago, administrado por la Corporaci&#xF3;n Educacional de Desarrollo Art&#xED;stico, un plan especial de estudio que se aplicar&#xE1; en todos los niveles en forma simult&#xE1;nea, a contar del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas que conforman las distintas menciones en cada una de las &#xE1;reas que se se&#xF1;alan en el presente decreto.</div><br></div>", "i": 5944119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 15 de julio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5944120}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "368 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-368 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 368 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICEO EXPERIMENTAL ARTISTICO", "SANTIAGO", "REGION", "METROPOLITANA", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-07-05", "doble_articulado": false, "id_norma": "21086", "numero_fuente": "35521", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-20", "vigencias": [{"desde": "1996-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "