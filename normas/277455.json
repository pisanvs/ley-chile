{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 4.748 EXENTA, DE 2008 </div></div>", "i": 7378204}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 4.748, de 1 de julio de 2008, se han modificado las resoluciones exentas de Educaci&#xF3;n N&#xBA;s. 9.589, de 2001, y 3.269, de 2002, que aprobaron planes y programas especiales de estudio de 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Colegio San Ignacio El Bosque, comuna de Providencia, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s se aprueban programas de estudio para los Subsectores del Plan de Formaci&#xF3;n General y del Plan de Formaci&#xF3;n Diferenciada para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 7378205}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de agosto de 2008.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 7378206}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4748 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4748 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 4.748 EXENTA, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-01", "doble_articulado": false, "id_norma": "277455", "numero_fuente": "39157", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-09-06", "vigencias": [{"desde": "2008-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-09-06", "