{"html": [{"t": "<div><div class=\"p\">Traslacion de mercader&#xED;as fuera de la capital</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de Setiembre de 1814.</div></div>", "i": 10227871}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Noticioso el Gobierno de que varios comerciantes trasladan sus efectos de esta capital para afuera, escandalizando al P&#xFA;blico este movimiento que por otra le priva de lo necesario; ordena que ninguno pueda semejante traslacion, i que vuelvan los generosos esportados dentro de tercero dia, todo bajo la pena de Comiso.</div></div>", "i": 10227872}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Impr&#xED;mase: i el plazo corre desde la publicacion en El Monitor. - Carrera. - Uribe. - Mu&#xF1;oz.</div></div>", "i": 10227873}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "﻿Traslacion de mercaderías fuera de la capital", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1814-09-09", "doble_articulado": false, "id_norma": "1159368", "numero_fuente": "1814", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1814-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1814-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1814-09-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-05-17", "fecha_version": "1814-09-09", "fecha_actualizacion_texto": "2021-05-17", "