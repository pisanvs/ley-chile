{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUSTITUYE NOMBRE DE SOCIEDAD QUE INDICA </div></div>", "i": 6000714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico: Que por resoluci&#xF3;n N&#xB0; 244 de 11 de noviembre de 1992 se aprob&#xF3; la reforma de estatutos de la sociedad an&#xF3;nima &quot;Compa&#xF1;&#xED;a de Seguros Cruz del Sur S.A.&quot;, que consta de la escritura p&#xFA;blica de fecha 29 de octubre de 1992, otorgada ante el Notario P&#xFA;blico de Santiago, don F&#xE9;lix Jara Cadot.</div><div class=\"p\">&nbsp; &nbsp; La reforma consiste en:</div><div class=\"p\">&nbsp; &nbsp; Sustituir el nombre de la sociedad, la que en lo sucesivo se llamar&#xE1; &quot;Compa&#xF1;&#xED;a de Seguros Generales Cruz del Sur S.A.&quot;.</div><br></div>", "i": 6000715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 Noviembre 1992.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 6000716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "244", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-244"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SUSTITUYE NOMBRE DE SOCIEDAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["REFORMA ESTATUTARIA", "COMPA IA SEGUROS CRUZ DEL SUR SA", "ESTATUTOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-11-11", "doble_articulado": false, "id_norma": "31379", "numero_fuente": "34418", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-17", "vigencias": [{"desde": "1992-11-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v