{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 650.- Santiago, 21 de octubre de 1925.-</div><div class=\"p\">&nbsp; &nbsp; S. E. el Vice-Presidente de la Rep&#xFA;blica, de acuerdo con el Consejo de Ministros del Despacho, dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; DECRETO-LEI:</div><br></div>", "i": 8256496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zanse las palabras &quot;Conservador del Rejistro Electoral&quot; por la frase &quot;Conservador de Bienes Raices&quot;, en los incisos 2.o, 3.o, 4.o y 5.o del art&#xED;culo 55 del T&#xED;tulo VI, del decreto-lei n&#xFA;mero 542, de 19 de setiembre &#xFA;ltimo, sobre elecciones.</div><div class=\"p\">&nbsp; &nbsp; El presente decreto-lei empezar&#xE1; a rejir desde su fecha.</div><br></div>", "i": 8256497, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, rej&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de Leyes y Decretos del Gobierno.- Luis Barros Borgo&#xF1;o.- Manuel E. Velis. </div></div>", "i": 8256498}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "650", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-650"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ELECCIONES", "LEY GENERAL", "MODIFICACION", "MESAS RECEPTORAS SUFRAGIO", "CONTROL", "CONSERVADOR BIENES RAICES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-10-21", "doble_articulado": false, "id_norma": "6257", "numero_fuente": "14305", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-10-26", "vigencias": [{"desde": "1925-10-26",