{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7356359}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.880, de 3 de octubre de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;&#xCD;A PESQUERA CAMANCHACA S.A. para realizar actividades extractivas en alta mar con la nave &quot;Kings Bay&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CB-5322</div><div class=\"p\">Puerto de matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; Valpara&#xED;so</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2830</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  53,71 m.</div><div class=\"p\">T.R.G. (Internacional)&nbsp; &nbsp;  1197,00</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 11,00 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  7,25 m.</div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 2.880, de 2006, de esta Subsecretar&#xED;a.</div><br></div>", "i": 7356360}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de octubre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7356361}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2880 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2880 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacit