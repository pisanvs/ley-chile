{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,054 que concede un suplemento de 100,000 pesos para gastos de las c&#xE1;rceles</div><div class=\"p\">&nbsp; &nbsp; Lei num. 2,054.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5952673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de cien mil pesos ($ 100,000), al &#xED;tem 2,012, partida 23 del Presupuesto de Justicia, que consulta fondos para cubrir el mayor gasto que se ocasione en los diferentes servicios de los establecimientos penales.</div><br></div>", "i": 5952674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 10 de Diciembre de 1907.- PEDRO MONTT.- Domingo Amun&#xE1;tegui.</div><br></div>", "i": 5952675}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2054", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2054"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "LEI NUM. 2,054 QUE CONCEDE UN SUPLEMENTO DE 100,000 PESOS PARA GASTOS DE LAS CARCELES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1907", "MODIFICACION", "MINISTERIO", "JUSTICIA", "ESTABLECIMIENTOS PENALES", "GASTOS", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-12-10", "doble_articulado": false, "id_norma": "23093", "numero_fuente": "8976", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion