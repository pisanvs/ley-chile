{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA A INSTITUCIONES SIN FINES DE LUCRO, COMO RECEPTORAS DE ALIMENTOS CUYA COMERCIALIZACI&#xD3;N SEA INVIABLE</div></div>", "i": 9981079}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n Ex. del Servicio de Impuestos Internos N&#xB0; 129, de 19 de diciembre de 2018, que autoriza a instituciones sin fines de lucro como receptoras en forma gratuita de alimentos, cuya comercializaci&#xF3;n sea inviable.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes diciembre de 2018. </div></div>", "i": 9981080}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "129 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-129 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A INSTITUCIONES SIN FINES DE LUCRO, COMO RECEPTORAS DE ALIMENTOS CUYA COMERCIALIZACIÓN SEA INVIABLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1516709", "NORMA SIN PROMULGACIÓN", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-12-19", "doble_articulado": false, "id_norma": "1126995", "numero_fuente": "42237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-12-24", "vigencias": [{"desde": "2018-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2018-12-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2018-12-24", "fin_vigencia": "", "tipo_version