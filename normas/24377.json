{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,977, que concede derecho a jubilar a don Samuel Lillo</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,977.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5957619}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Conc&#xE9;dese, por gracia, al Pro-Rector de la Unversidad, don Samuel A. Lillo, el derecho a jubilar con una pension de quince mil pesos ($15,000) anuales.</div><br></div>", "i": 5957620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 de Agosto de 1923.-ARTURO ALESSANDRI.- Alcib&#xED;ades Roldan.</div><br></div>", "i": 5957621}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3977", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3977"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "LEI NUM. 3,977, QUE CONCEDE DERECHO A JUBILAR A DON SAMUEL LILLO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SAMUEL A. LILLO", "JUBILACION", "BENEFICIO", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-08-11", "doble_articulado": false, "id_norma": "24377", "numero_fuente": "13656", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-08-20", "vigencias": [{"desde": "1923-08-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1923-08-20", "fin_vigen