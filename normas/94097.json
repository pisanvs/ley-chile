{"html": [{"t": "<div><div class=\"p\">CERTIFICADO </div></div>", "i": 6096141}, {"t": "<div><div class=\"p\">El Banco Central de Chile, en conformidad a lo dispuesto en el N&#xBA; 5 del Capitulo lV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de octubre de 1989, fue de 8,65% anual.</div><br></div>", "i": 6096142}, {"t": "<div><div class=\"p\">Santiago, 18 de octubre de 1989.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6096143}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-18", "doble_articulado": false, "id_norma": "94097", "numero_fuente": "33500", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-10-19", "vigencias": [{"desde": "1989-10-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-10-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-10-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PMZ", "fecha_ingreso": "1998-03-05", "fecha_version": "1989-10-19", "fecha_actualizacion_texto": "1989-10-19", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6096141}, {"n": "Artículo", "i": 6096142, "t": 6}, {"n": "Promulg