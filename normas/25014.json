{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8277778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Desde el 1.o de Enero de 1932, los taqu&#xED;grafos segundos del Congreso Nacional tendr&#xE1;n el sueldo de diez y nueve mil quinientos pesos ($ 19,500) anuales que les fija la ley N.o 4,254, de 17 de Enero de 1928, sin perjuicio de las rebajas legales que les afecten.</div><br><br></div>", "i": 8277779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintinueve de Enero de mil novecientos treinta y dos.- JUAN E. MONTERO.- Marcial Mora M. </div></div>", "i": 8277780}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5046", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5046"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONGRESO NACIONAL", "SUELDO", "TAQUIGRAFOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-01-29", "doble_articulado": false, "id_norma": "25014", "numero_fuente": "16188", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-02-01", "vigencias": [{"desde": "1932-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos