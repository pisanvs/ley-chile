{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Constribucion de Haberes Lei n&#xFA;m. 1.090.- Santiago, a 14 de Octubre de 1898.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274092}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase a las municipalidades de San Vicente, Cobquecura, Pocillas i Ca&#xF1;ete, para que cobren en el presente a&#xF1;o la contribucion de haberes con arreglo al aval&#xFA;o que hizo en el a&#xF1;o 1896.</div><br><br></div>", "i": 8274093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8274094}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1090", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1090"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONSTRIBUCION DE HABERES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDAD", "SAN VICENTE", "COBQUECURA", "POCILLAS", "CA ETE", "CONTRIBUCION HABERES", "COBRO", "AVALUO A O 1896", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-10-14", "doble_articulado": false, "id_norma": "22402", "numero_fuente": "6125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-10-14", "vigencias": [{"desde": "1898-10-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-10-14", "fin_vigencia": ""}, "vigencias_versi