{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6384268}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 669, de 30 de abril de 2002, se expropi&#xF3; el lote de terreno N&#xBA; 93-2, superficie 613 m2, rol de aval&#xFA;o 276-132, comuna de Algarrobo, para la obra Red Vial Litoral Central. Enlace Algarrobo, Km. 28.900,00 al 29.300,00, Quinta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Mar&#xED;a Alicia del Carmen Aguilera Valdebenito, ascendente a la cantidad de $2.204.742.- para el lote N&#xBA; 93-2.</div><br></div>", "i": 6384269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6384270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "669 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-669 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-30", "doble_articulado": false, "id_norma": "198972", "numero_fuente": "37272", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-01", "vigencias": [{"desde": "2002-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MAS", "fecha_ingreso": "2002-06-06", "fecha_version": "2002-06-01", "fecha_actualizacion_texto": "2002-06-01", "tipo_tratado": ""}, "a