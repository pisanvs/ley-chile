{"html": [{"t": "<div><div class=\"p\">ACUERDO DE CLASIFICACION </div></div>", "i": 6498841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Visto: Lo dispuesto en el Decreto Ley No. 3.500, de 1980, en las Leyes Nos. 18.398, 18.420 y en los Decretos Supremos Nos. 31, 35 y 63, de 1985, 54 y 74, de 1986 y 19, de 1987, del Ministerio del Trabajo y Previsi&#xF3;n Social:</div><div class=\"p\">&nbsp; &nbsp;  La Comisi&#xF3;n Clasificadora de Riesgo acord&#xF3;, en la d&#xE9;cima sesi&#xF3;n extraordinaria, clasificar los dep&#xF3;sitos a plazo del Banco del Pac&#xED;fico en Categor&#xED;a A de Riesgo en atenci&#xF3;n al aumento de capital realizado con fecha 29 de marzo de 1989, clasificaci&#xF3;n que se ha efectuado considerando la informaci&#xF3;n financiera al 31 de marzo de 1989.</div><br></div>", "i": 6498842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de abril de 1989.- Juan Arizt&#xED;a Matte, Superintendente, Presidente de la Comisi&#xF3;n Clasificadora de Riesgo.</div><br></div>", "i": 6498843}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "S/N", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-S/N"}, {"tipo": "26", "numero": "10", "abreviacion": "RRO", "descripcion": "Reunión ordinaria", "compuesto": "RRO-10"}], "organismos": ["COMISIÓN CLASIFICADORA DE RIESGO"], "titulo_norma": "ACUERDO DE CLASIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-04-18", "doble_articulado": false, "id_norma": "230791", "numero_fuente": "33352", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-20", "vigencias": [{"desde": "1989-04-20", "hasta": "", "tipo_version": "3", "tipo_version_