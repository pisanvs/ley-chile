{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 11.128 EXENTA, DE 2012</div><br></div>", "i": 9326161}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 11.128, de 26 de diciembre de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Sociedad de Capacitaci&#xF3;n Jocap Limitada (Jocap Ltda.)&quot;, RUT 76.081.136-K, contenida en la resoluci&#xF3;n exenta N&#xBA; 1.074, de 21 de enero de 2010, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.- </div></div>", "i": 9326162}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional.</div></div>", "i": 9326163}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11128 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-11128 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 11.128 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-26", "doble_articulado": false, "id_norma": "1047969", "numero_fuente": "40457", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-12", "vigencias": [{"desde": "2013-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-01-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes