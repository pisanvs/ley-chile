{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 25 de Julio de 1892.- Por cuanto el Congreso Nacional ha aprobado lo siguiente </div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY</div></div>", "i": 10133014}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de veinte mil pesos ($20.000) en el mantenimiento de Lazaretos y atenci&#xF3;n de variolosof.</div></div>", "i": 10133015}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, o&#xED;do el Consejo de Estado, ha tenido &#xE1; bien aprobarlo; por tanto, prom&#xFA;lguese como ley de la Rep&#xFA;blica.- JORGE MONTT.- R. Barros Luco.</div></div>", "i": 10133016}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "Ley-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1892-07-25", "doble_articulado": false, "id_norma": "1145822", "numero_fuente": "4281", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1892-07-25", "vigencias": [{"desde": "1892-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1892-07-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1892-07-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2020-07-02", "fecha_version": "1892-07-25", "fecha_actualizacion_texto": "2020-07-02", "tipo_tratado": ""}, "alertas": [], "alerta_global"