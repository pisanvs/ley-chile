{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330097}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;601, de 29 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, rectif&#xED;quese el numeral 2&#xBA; letra a) de la resoluci&#xF3;n N&#xBA; 1.442, de 1997 de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA BIO BIO LIMITADA, hoy Pesquera B&#xED;o B&#xED;o S.A., para ampliar actividades pesqueras extractivas con la nave Bonn, en el sentido de eliminar la expresi&#xF3;n como fauna acompa&#xF1;ante de Merluza com&#xFA;n.</div><br></div>", "i": 8330098}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330099}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "601", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-601"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA BIO BIO LIMITADA", "PESQUERA BIO BIO S.A.", "AMPLIACION", "RECTIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-04-29", "fecha_derogacion": "2016-11-23", "doble_articulado": false, "id_norma": "99239", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-05-18", "vigencias": [{"desde": "2016-11-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-05-18", "hasta": "2016-11-22", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2016-11-23", "fin_vige