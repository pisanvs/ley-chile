{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 249 DE 17 DE JUNIO DE 1985 </div></div>", "i": 6264231}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto de la referencia se han aprobado Planes y Programas Especiales de Estudio para Segundo Ciclo de la Educaci&#xF3;n Media T&#xE9;cnico-Profesional, a contar del a&#xF1;o escolar 1985 y hasta el a&#xF1;o escolar 1988, inclusive, para el Liceo T&#xE9;cnico &quot;B&quot; No. 63, de Los Angeles.</div><br><div class=\"p\">&nbsp; &nbsp;  Especialidades:</div><div class=\"p\">&nbsp; &nbsp;  1.- Atenci&#xF3;n de P&#xE1;rvulos.</div><div class=\"p\">&nbsp; &nbsp;  2.- Atenci&#xF3;n Social.</div><div class=\"p\">&nbsp; &nbsp;  3.- Peluquer&#xED;a y Cosmetolog&#xED;a.</div><div class=\"p\">&nbsp; &nbsp;  4.- Tejidos.</div><div class=\"p\">&nbsp; &nbsp;  5.- Vestuario.</div><br></div>", "i": 6264232}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  28 de junio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6264233}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "249 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-249 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO DE EDUCACION No. 249\nDE 17 DE JUNIO DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-17", "doble_articulado": false, "id_norma": "165288", "numero_fuente": "32341", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-07", "vigencias": [{"desde": "1985-12-07", "hasta": "