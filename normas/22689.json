{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Declara libre de derechos de internacion el hiposulfito de soda.</div><div class=\"p\">&nbsp; &nbsp; Lei 1489</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se declara libre de derechos de internacion el hiposulfito de soda.</div><br></div>", "i": 5949303}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 9 de Diciembre de 1901.- JERMAN RIESCO.- Enrique Villegas.</div><br></div>", "i": 5949304}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1489", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1489"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "QUE DECLARA LIBRE DE DERECHOS DE INTERNACION EL HIPOSULFITO DE SODA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["HIPOSULFITO SODA", "DERECHOS INTERNACION", "LIBERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-09", "doble_articulado": false, "id_norma": "22689", "numero_fuente": "7094", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-11", "vigencias": [{"desde": "1901-12-1