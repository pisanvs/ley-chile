{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6191747}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP No. 1.784, de 30 de junio de 1999, se expropiaron los lotes de terreno No. s. 2-A y 2-B, superficies 347 y 60 m2., respectivamente, rol de aval&#xFA;o 12006-22, comuna de San Pedro de la Paz, para la obra Reposici&#xF3;n Puente B&#xED;o-B&#xED;o Antiguo, Ruta 160, Concepci&#xF3;n-San Pedro, sector San Pedro y se acord&#xF3; precio de indemnizaci&#xF3;n con su propietaria Eladia Hortencia Carvallo Ospital, ascendente a la cantidad de $ 24.938.550.</div><br></div>", "i": 6191748}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6191749}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1784", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1784"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-06-30", "doble_articulado": false, "id_norma": "143574", "numero_fuente": "36465", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-09-15", "vigencias": [{"desde": "1999-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-09-20", "fecha_version": "1999-09-15", "fecha_actualizacion_texto": "1999-09-15", "tipo_tratado": ""}, "alertas": [], "alert