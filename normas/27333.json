{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DECLARA FERIADO LEGAL EL DIA 20 DE SEPTIEMBRE DE 1958.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8280541}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Decl&#xE1;rase feriado legal el d&#xED;a s&#xE1;bado 20 de septiembre de 1958.&quot; </div></div>", "i": 8280542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, doce de septiembre de mil novecientos cincuenta y ocho.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Abel Vald&#xE9;s.</div><br></div>", "i": 8280543}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13009", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13009"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DECLARA FERIADO LEGAL EL DIA 20 DE SEPTIEMBRE DE\n1958.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FERIADO LEGAL", "20 SEPTIEMBRE", "20 SEPTIEMBRE", "1958"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1958-09-12", "doble_articulado": false, "id_norma": "27333", "numero_fuente": "24145", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1958-09-13", "vigencias": [{"desde": "1958-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1958-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1958-09-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente