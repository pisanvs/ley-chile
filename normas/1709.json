{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CERTIFICADO </div></div>", "i": 5844926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustable entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de diciembre de 1991, fue de 4,90% anual.</div><br></div>", "i": 5844927}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 23 de diciembre de 1991.- V&#xED;ctor Vial del R&#xED;o, Secretario General.</div><br></div>", "i": 5844928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TIP", "TASA INTERES PROMEDIO", "DIC. 1991", "OPERACIONES CREDITO DINERO", "OPERACIONES REAJUSTABLES", "CAPTACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-12-23", "doble_articulado": false, "id_norma": "1709", "numero_fuente": "34150", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-12-24", "vigencias": [{"desde": "1991-12-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-12-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-12-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1991-12-24", "fecha_actualizacion_texto": "1991-12-24", "tipo_tratado": ""}, "alertas": [], "alerta_globa