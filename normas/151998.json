{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8357129}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.458, de 21 de diciembre de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a JORGE DE JESUS ARANGUIZ TORO, para iniciar actividades pesqueras de transformaci&#xF3;n en orden a operar una planta ubicada en calle Presidente Alessandri s/n&#xBA;, Queil&#xE9;n, provincia de Chilo&#xE9;, X Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Fresco-refrigerado y Congelado: Chorito y Erizo. </div></div>", "i": 8357130}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de diciembre de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8357131}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2458", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2458"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-21", "doble_articulado": false, "id_norma": "151998", "numero_fuente": "36569", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-22", "vigencias": [{"desde": "2000-01-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-01-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2