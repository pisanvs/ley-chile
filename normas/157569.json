{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 1.050, DE 1984, QUE APRUEBA MODIFICACION DE CONVENIO DE TRASPASO DE LA ESCUELA BASICA G-1030 DE LA COMUNA DE NACIMIENTO </div></div>", "i": 6238879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto N&#xB0; 1.050, de 1984, se aprob&#xF3; una modificaci&#xF3;n al convenio de traspaso de la Escuela B&#xE1;sica G-1030, de Nacimiento, aprobado por decreto N&#xB0; 4.726, de 1981, que incide en la cl&#xE1;usula sexta. </div></div>", "i": 6238880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de Febrero de 1985.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6238881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1050", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1050"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO N° 1.050, DE 1984, QUE APRUEBA MODIFICACION DE CONVENIO DE TRASPASO DE LA ESCUELA BASICA G-1030 DE LA COMUNA DE NACIMIENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-22", "doble_articulado": false, "id_norma": "157569", "numero_fuente": "32122", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-15", "vigencias": [{"desde": "1985-03-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-03-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2