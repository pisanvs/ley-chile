{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n de gracia a do&#xF1;a Magdalena Ram&#xED;rez Hortuvia</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7169822}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia y por el plazo de diez a&#xF1;os, a do&#xF1;a Magdalena Ram&#xED;rez Hortuvia, una pensi&#xF3;n de mil doscientos pesos ($ 1,200) anuales. </div></div>", "i": 7169823}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintisiete de Enero de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Carlos O. Frodden. </div></div>", "i": 7169824}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4805", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4805"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "CONCEDE PENSIÓN DE GRACIA A DOÑA MAGDALENA RAMÍREZ HORTUVIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MAGDALENA RAMIREZ HORTUVIA", "PENSION GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-01-27", "doble_articulado": false, "id_norma": "24927", "numero_fuente": "15594", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-02-08", "vigencias": [{"desde": "1930-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-02-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1930-02