{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE SE&#xD1;ALA </div></div>", "i": 6183973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 775 de 05 de Mayo de 1988, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a las parcelas 1 a la 33, sitios 2 al 48 y Reservas CORA 1-A, 1-B, y R. CORA No. 2 del Proyecto de Parcelaci&#xF3;n &quot;Queri&quot;, formado por predio &quot;Hacienda Queri&quot; de la comuna de Colb&#xFA;n, VII Regi&#xF3;n. Los derechos de aguas se extraen de los canales Farto, Farto Bajo, Canal Patagua y Canal Matriz. Publicaci&#xF3;n hecha conforme Art. 13 Ley No. 18.377.-</div><br></div>", "i": 6183974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6183975}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "775 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-775 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE\nSEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-05-05", "doble_articulado": false, "id_norma": "140995", "numero_fuente": "33072", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-16", "vigencias": [{"desde": "1988-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-