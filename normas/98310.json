{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329292}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xBA;517, de 8 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deniega la solicitud de concesi&#xF3;n de acuicultura N&#xBA;94103022, presentada por LUIS OMAR ALMONACID SERON, para operar un centro de cultivo en un Sector denominado Conchas Blancas entre Punta Tanecuhe y Punta Co&#xF1;ao, comuna de Quinchao, provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en el art&#xED;culo 14 del D.S. N&#xBA;290 de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n y el art&#xED;culo 78 inciso 2&#xBA; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8329293}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 8 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "517", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-517"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "QUINCHAO", "LUIS OMAR ALMONACID SERON", "DECIMA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-08", "doble_articulado": false, "id_norma": "98310", "numero_fuente": "36048", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-04-24", "vigencias": [{"desde": "1998-04-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-04-24