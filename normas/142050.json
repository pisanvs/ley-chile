{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6187166}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. No. 36, de 27 de febrero de 1987, se expropiaron los lotes N&#xB0;s. 2; 3 y 4, cuyas superficies son 1.395 M2., 177 M2. y 1.308 M2., respectivamente,&#xA8; roles de aval&#xFA;os 231-11, 231-70 y 231-10, todos de la Comuna de Pur&#xE9;n, para la obra Alcantarillado de Pur&#xE9;n y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios David A. Torres Gaete, Mar&#xED;a M. Leal Torres y Juan B. Riffo Mora, ascendente a las cantidades de $ 70.587, $ 8.956, y $ 66.185.-</div><br></div>", "i": 6187167}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6187168}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "36", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-36"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-02-27", "doble_articulado": false, "id_norma": "142050", "numero_fuente": "32737", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-04-01", "vigencias": [{"desde": "1987-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "1999-09-01", "fecha_version": "1987-04-01", "fecha_actualizacion_texto": "1987-04-01", "tipo_trata