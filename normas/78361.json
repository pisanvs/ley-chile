{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 314, DE 1991 </div></div>", "i": 9048933}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 314 de fecha 26 de Noviembre de 1991 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Superior de Educaci&#xF3;n, Ciencia y Cultura Gabriela Mistral de Iquique, el plan y programas de estudio de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida en dicha ciudad, a contar del a&#xF1;o 1991:</div><div class=\"p\">Carrera: T&#xE9;cnico en Auditor&#xED;a con menci&#xF3;n en Inform&#xE1;tica.</div><div class=\"p\">T&#xED;tulo: T&#xE9;cnico en Auditor&#xED;a con menci&#xF3;n en Inform&#xE1;tica.- </div></div>", "i": 9048934}, {"t": "<div><div class=\"p\">Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 9048935}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "314 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-314 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO\nEXENTO No. 314, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-11-26", "doble_articulado": false, "id_norma": "78361", "numero_fuente": "34307", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-04", "vigencias": [{"desde": "1992-07-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-04", "fin_vigencia": "", "tipo_version