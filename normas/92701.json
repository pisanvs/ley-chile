{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 128, DE 1989 </div></div>", "i": 7227203}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No.128 de 14 de agosto de 1989 se ha rectificado el decreto supremo exento de Educaci&#xF3;n No.109 de 1989, que modific&#xF3; a contar del a&#xF1;o escolar 1989 el decreto supremo exento de Educaci&#xF3;n No.287 de 1981, que aprob&#xF3; planes para la Fundaci&#xF3;n Educacional Colegio de Los Sagrados Corazones de Manquehue, de Santiago, en el sentido de que en el Curso de Humanidades del Plan Diferenciado para 4to. a&#xF1;o medio, donde dice &quot;Biolog&#xED;a&quot; debe decir &quot;Psicolog&#xED;a&quot;.</div><br></div>", "i": 7227204}, {"t": "<div><div class=\"p\">Santiago, 25 de Agosto de 1989.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7227205}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "128 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-128 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 128, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-08-14", "doble_articulado": false, "id_norma": "92701", "numero_fuente": "33467", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-09-06", "vigencias": [{"desde": "1989-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-09-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-09-06", "fin_vigencia": "", "