{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6745555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 642, de fecha 29 de octubre de 2007, se expropi&#xF3; el lote de terreno N&#xBA; 2, superficie 852 m2, rol N&#xBA; 3218-88, comuna de San Juan de la Costa, X Regi&#xF3;n, para la obra: &quot;Reposici&#xF3;n Puente El Negro, Ruta U-52, Camino Contaco Loma de la Piedra, provincia de Osorno&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Yessenia del Carmen Jaramillo Gualaman, ascendente a la cantidad de $1.876.106.</div><br></div>", "i": 6745556}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6745557}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "642 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-642 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-29", "doble_articulado": false, "id_norma": "267126", "numero_fuente": "38926", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-01", "vigencias": [{"desde": "2007-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2007-12-04", "fecha_version": "2007-12-01", "fecha_actualizacion_texto": "2007-12-01", "tipo_tratado": ""}