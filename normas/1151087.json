{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 136 EXENTA, DE 2020</div></div>", "i": 10171229}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 136, de fecha 23 de octubre de 2020, establece procedimiento de verificaci&#xF3;n de antecedentes para determinar el cumplimiento de requisitos de procedencia del beneficio del <a href=\"https://www.leychile.cl/Navegar?idNorma=1147923&amp;idParte=10145879&amp;idVersion=\">art&#xED;culo 5</a> del art&#xED;culo primero de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1147923&amp;idParte=&amp;idVersion=\">ley N&#xBA; 21.252</a> para la protecci&#xF3;n de los ingresos de la clase media con motivo de la propagaci&#xF3;n de la enfermedad denominada Covid-19.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de este documento, est&#xE1; publicado en &quot;www.sii.cl&quot;.</div><div class=\"p\"> </div><br></div>", "i": 10171230}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "136 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-136 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 136 EXENTA, DE 2020", "fuente": "Diario Oficial", "resumenes": [], "materias": ["CORONAVIRUS COVID-19", "CORONAVIRUS", "COVID-19"], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1840418", "EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-10-23", "doble_articulado": false, "id_norma": "1151087", "numero_fuente": "42794", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-11-02", "vigencias