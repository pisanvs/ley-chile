{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 144.- Santiago, a 30 de Diciembre de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de cuatro mil quinientos pesos al &#xED;tem 7 de la partida 3.a del presupuesto del Ministerio del Interior, para fomento de la Biblioteca del Congreso.</div><br><br></div>", "i": 8273762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 8273763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "144", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-144"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Suplemento", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1893", "MODIFICACION MINISTERIO", "INTERIOR", "BIBLIOTECA CONGRESO", "FOMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-12-30", "doble_articulado": false, "id_norma": "22006", "numero_fuente": "4707", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-01-02", "vigencias": [{"desde": "1894-01-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-01-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-01-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion