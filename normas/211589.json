{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional, ha dado su aprobaci&#xF3;n al siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 8369093}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase, a contar desde el 17 de Diciembre de 1930 el nombre de Avenida Campo de Marte, de la ciudad de Santiago, por el de Avenida Sim&#xF3;n Bol&#xED;var&quot;.</div><br></div>", "i": 8369094}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, diecis&#xE9;is de Diciembre de mil novecientos treinta.- CARLOS IBA&#xD1;EZ C.- Carlos O. Fr&#xF6;dden. </div></div>", "i": 8369095}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4911", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4911"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "PROYECTO DE LEY:", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1930-12-16", "doble_articulado": false, "id_norma": "211589", "numero_fuente": "15849", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1930-12-16", "vigencias": [{"desde": "1930-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1930-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1930-12-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2003-06-24", "fecha_