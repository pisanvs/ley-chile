{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6407762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.875, de 17 de diciembre de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase que con fecha 6 de diciembre de 2002 han quedado sin efecto las resoluciones N&#xBA; 2.174 de 1996, N&#xBA; 132 de 1997, N&#xBA; 205 de 2000, N&#xBA; 1.297, N&#xBA; 1.887 y N&#xBA; 2.508, todas de 2001, de esta Subsecretar&#xED;a, que autorizaron a PESQUERA PLAYA BLANCA S.A., para desarrollar actividad extractiva con la nave Gangstad Junior, en conformidad con lo dispuesto en el art&#xED;culo 9&#xBA; de la ley N&#xBA; 19.713. Dicha nave queda permanente e irrevocablemente excluida de la actividad pesquera extractiva.</div><br></div>", "i": 6407763}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de diciembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6407764}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2875", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2875"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-12-17", "doble_articulado": false, "id_norma": "206126", "numero_fuente": "37440", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-21", "vigencias": [{"desde": "2002-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-12-21", "fin_vigenci