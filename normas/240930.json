{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6535923}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.114 de 12 de julio de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a CULTIVOS MARINOS SAN CRISTOBAL SOCIEDAD ANONIMA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Km. 895, Ruta 5 Norte, sector Punta Fr&#xF6;dden, caleta Los Patos, comuna y provincia de Copiap&#xF3;, III Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Congelado y Vivo, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6535924}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de julio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6535925}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2114 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2114 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-07-12", "fecha_derogacion": "2006-10-05", "doble_articulado": false, "id_norma": "240930", "numero_fuente": "38234", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-08-11", "vigencias": [{"desde": "2006-10-05", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-08-11", "hasta": "2006-10-04", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2006-10-05", "fin_vigencia