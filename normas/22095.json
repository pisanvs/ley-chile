{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTO Lei n&#xFA;m. 240.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de setecientos mil pesos al &#xED;tem 1 de la partida 45 del presupuesto del Ministerio de Industria i Obras P&#xFA;blicas, para la construccion de los ferrocarriles enumerados en la lei de 20 de Enero de 1888.</div><br><br></div>", "i": 5947255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Diciembre 1894.-JORJE MONTT.-El&#xED;as Fern&#xE1;ndez A.</div><br></div>", "i": 5947256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "240", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-240"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1894", "MODIFICACION", "MINISTERIO", "INDUSTRIA OBRAS PUBLICAS", "FERROCARRILES", "CONSTRUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-12-29", "doble_articulado": false, "id_norma": "22095", "numero_fuente": "5001", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-12-29", "vigencias": [{"desde": "1894-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-12-29", "fin_vigencia":