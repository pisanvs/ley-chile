{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6219078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 89 de fecha 20 de Noviembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se autoriza al Sr. Ra&#xFA;l Guill&#xE9;n Mu&#xF1;oz, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos dentro de territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6219079}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Guido M. Ram&#xED;rez Maturana, SEREMI de Transportes y Telecomunicaciones II Regi&#xF3;n.</div><br></div>", "i": 6219080}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "89 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-89 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-11-20", "doble_articulado": false, "id_norma": "151245", "numero_fuente": "32636", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-12-01", "vigencias": [{"desde": "1986-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingres