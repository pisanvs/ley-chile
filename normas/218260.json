{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6452059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.979, de 20 de noviembre de 2003, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n&nbsp; N&#xBA; 829&nbsp; de&nbsp; 2001, y el numeral 2&#xBA; de la resoluci&#xF3;n N&#xBA; 371 de 2003, ambas de esta Subsecretar&#xED;a, que autorizaron a SOUTHPACIFIC KORP S.A. para realizar actividades pesqueras extractivas con la nave &quot;Montserrat&quot;, en el sentido de incorporar y actualizar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; 672,58 m3</div><div class=\"p\">Potencia principal&nbsp; &nbsp; &nbsp;  1774,00 Hp</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp;  547,00 Hp.</div><br><br></div>", "i": 6452060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6452061}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2979 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2979 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-20", "doble_articulado": false, "id_norma": "218260", "numero_fuente": "37727", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-04", "vigencias": [{"desde": "2003-12-04", "hasta": "", "tipo_version": "3", "tipo_version