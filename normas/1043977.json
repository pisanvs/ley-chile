{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9296662}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;1809, de 30 de agosto de 2012, y de conformidad a lo dispuesto en el art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;71, superficie 76 m2., Rol N&#xBA;2409-45, para la obra &quot;MEJORAMIENTO RUTA T-35, LOS LAGOS &#x2013; VALDIVIA, SECTOR ANTILHUE &#x2013;VALDIVIA TRAMO 3&quot;, comuna de Valdivia, Regi&#xF3;n de Los R&#xED;os. La comisi&#xF3;n de peritos integrada por Sonia Catalina Gallegos Blanch, Patricio Fernando Casagrande Ulloa y Norman Calder&#xF3;n Pontiggia, fij&#xF3; el valor de tasaci&#xF3;n con fecha 15 de abril de 2010, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario ARNOLDO CORONADO ABURTO, en la cantidad de $1.258.855.- suma que se pagar&#xE1; al contado. </div></div>", "i": 9296663}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9296664}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1809 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1809 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-08-30", "doble_articulado": false, "id_norma": "1043977", "numero_fuente": "40364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-15", "vigencias": [{"desde": "2012-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-15", "fin_vigencia": ""}, "vigencias_version_