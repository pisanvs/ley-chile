{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9287283}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.023, de 18 de julio de 2012, de esta Subsecretar&#xED;a de Pesca, prorr&#xF3;gase por 30 d&#xED;as h&#xE1;biles, contados desde la fecha de la presente autorizaci&#xF3;n, el plazo para publicar en el Diario Oficial los extractos de las resoluciones exentas <a href=\"https://www.leychile.cl/Navegar?idNorma=1042662&amp;idParte=0&amp;idVersion=\">N&#xBA; 1.238</a>, <a href=\"https://www.leychile.cl/Navegar?idNorma=1042663&amp;idParte=0&amp;idVersion=\">N&#xBA; 1.240</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=1042664&amp;idParte=0&amp;idVersion=\">N&#xBA; 1.245</a>, todas de 2012, de esta Subsecretar&#xED;a, que otorgaron a RUBIO Y MAUAD LIMITADA, permisos extraordinarios de pesca para las unidades de pesquer&#xED;a de Langostino colorado y Langostino amarillo.</div><br></div>", "i": 9287284}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de julio de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9287285}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2023 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2023 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-18", "doble_articulado": false, "id_norma": "1042665", "numero_fuente": "40330", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-08-06", "vigencias": [{"desde": "2012-08-06", "hasta