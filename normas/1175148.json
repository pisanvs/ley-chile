{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10328296}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0;: DN-00760, de 8 de abril de 2022 se modific&#xF3; <a href=\"https://www.leychile.cl/Navegar?idNorma=1082259&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta n&#xFA;mero 8.228</a>, de 2015, del Servicio Nacional de Pesca y Acuicultura, que aprueba Programa Sanitario General para Uso de Antimicrobianos en la Salmonicultura y otros peces de cultivo.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n, se publicar&#xE1; en el sitio de dominio electr&#xF3;nico del Servicio Nacional de Pesca y Acuicultura y la Subsecretar&#xED;a de Pesca y Acuicultura.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10328297}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de abril de 2022.- Esteban Donoso Abarca, Director Nacional (S), Servicio Nacional de Pesca y Acuicultura.</div><br></div>", "i": 10328298}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "760", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-760"}, {"tipo": "3", "numero": "DN-00760 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-DN-00760 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2115895", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-04-08", "doble_articulado": false, "i