{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;mero 4,507</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEY:</div><br></div>", "i": 6211191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.-&nbsp; El&#xE9;vase, a contar desde el 1.o de Enero de 1929, a la cantidad anual de doce mil pesos, la pensi&#xF3;n de montep&#xED;o de que disfruta la hija viuda del ex Vicealmirante don Patricio Lynch, siendo de cargo fiscal este aumento.</div><br></div>", "i": 6211192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintid&#xF3;s de Diciembre de mil novecientos veintiocho.-&nbsp; Carlos Ib&#xE1;&#xF1;ez C.-&nbsp; C. O. Frodden.</div><br></div>", "i": 6211193}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4507", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4507"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-12-22", "doble_articulado": false, "id_norma": "149125", "numero_fuente": "15263", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-01-03", "vigencias": [{"desde": "1929-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1929-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1929-01-03", "fin_vigencia": "", "tipo_version": "3"}], "even