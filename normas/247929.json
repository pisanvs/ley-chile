{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 84 EXENTO, DE 2006 </div></div>", "i": 6563725}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA; 84, de 24 de enero de 2006, se ha aprobado plan y programas especiales de estudio biling&#xFC;e para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica al Colegio &quot;The International Preparatory School&quot;, comuna de Lo Barnechea, de Santiago.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en el presente decreto. </div></div>", "i": 6563726}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de marzo de 2006.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6563727}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "84 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-84 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 84 EXENTO, DE 2006", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-24", "doble_articulado": false, "id_norma": "247929", "numero_fuente": "38412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-13", "vigencias": [{"desde": "2006-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-03-13", "fecha_version": "2006-03-1