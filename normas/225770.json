{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6481157}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.346, de 11 de mayo de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a&nbsp; COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Bucanero I&quot;, en las &#xE1;reas mar&#xED;timas que en cada caso se indican, donde podr&#xE1; capturar el recurso hidrobiol&#xF3;gico que a continuaci&#xF3;n se se&#xF1;ala: a) en el &#xE1;rea mar&#xED;tima comprendida entre la VII a X Regiones, por fuera del &#xE1;rea de reserva artesanal, con cerco: Jibia; b) En el &#xE1;rea mar&#xED;tima comprendida entre la VII a X Regiones, con arrastre de media agua, por fuera de las 60 millas n&#xE1;uticas: Jibia.</div><br></div>", "i": 6481158}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de mayo de 2004.- Felipe&nbsp; Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6481159}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1346 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1346 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-05-11", "doble_articulado": false, "id_norma": "225770", "numero_fuente": "37872", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-05-29", "vigencias": [{"desde": "2004-05-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-05-29", "fin_vigencia": ""}, "vige