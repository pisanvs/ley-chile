{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6336676}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Lib&#xE9;rase del pago de contribuci&#xF3;n de bienes ra&#xED;ces al Hotel Pac&#xED;fico de Arica.</div><div class=\"p\">&nbsp; &nbsp;  Esta ley comenzar&#xE1; a regir desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 6336677}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a 30 de Mayo de mil novecientos treinta y dos.- JUAN E. MONTERO.- Luis Izquierdo.</div><br></div>", "i": 6336678}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5128", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5128"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-05-30", "doble_articulado": false, "id_norma": "185786", "numero_fuente": "16298", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-06-14", "vigencias": [{"desde": "1932-06-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1932-06-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1932-06-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-05