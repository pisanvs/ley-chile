{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; LEI N.&#xB0; 1,324 Lei n&#xFA;m. 1,324.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la &quot;Sociedad Francesa de Beneficencia de Iquique&quot; el requerido por el art&#xED;culo 556 del C&#xF3;digo Civil, para que pueda conservar, durante treinta a&#xF1;os, la posesion del bien raiz que tiene adquirido en la calle Ramir&#xE9;z de la ciudad de Iquique.</div><br><br></div>", "i": 5948880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 11 de Enero de 1900.- FEDERICO ERRAZURIZ.- Francisco J. Herbozo.</div><br></div>", "i": 5948881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1324", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1324"}], "organismos": ["MINISTERIO DE JUSTICIA E INSTRUCCIÓN PÚBLICA"], "titulo_norma": "LEI N.° 1,324", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTRUCCION FRANCESA BENEFICENCIA IQUIQUE", "BIEN", "RAIZ", "POSESION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-01-11", "doble_articulado": false, "id_norma": "22558", "numero_fuente": "6496", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-01-15", "vigencias": [{"desde": "1900-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi