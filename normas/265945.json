{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DE CALIDAD DE AGENTE RETENEDOR DEL IVA A EKONO S.A.</div><br></div>", "i": 6627837}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Direcci&#xF3;n Grandes Contribuyentes del SII, por resoluci&#xF3;n Ex. N&#xBA; 128 de 28 de septiembre de 2007, certifica que a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n al contribuyente Ekono S.A., RUT N&#xBA; 76.473.580-3, se le autoriz&#xF3; excepcionarse del r&#xE9;gimen de cambio de sujeto del IVA en venta de cigarros, cigarrillos y tabacos manufacturados, de acuerdo a lo establecido en la Res. Ex. N&#xBA; 22/2007 de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 09.02.2007.</div><br></div>", "i": 6627838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Bernardo Seaman Gonz&#xE1;lez, Director de la Direcci&#xF3;n Grandes Contribuyentes.</div><br><br><br></div>", "i": 6627839}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "128 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-128 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN GRANDES CONTRIBUYENTES"], "titulo_norma": "EXCEPCIONA DE CALIDAD DE AGENTE RETENEDOR DEL IVA A EKONO S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-09-28", "doble_articulado": false, "id_norma": "265945", "numero_fuente": "38896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-26", "vigencias": [{"desde": "2007-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-10-26", "fin_vigencia": ""}, "vig