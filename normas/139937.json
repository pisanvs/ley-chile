{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 3,261.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8347358}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En homenaje a las Embajadas Estraordinarias del Brasil, Uruguai y Paraguai, ante el Gobierno de Bolivia, de paso por nuestra Rep&#xFA;blica, decl&#xE1;rase dia feriado en Santiago el viernes 31 del presente mes.</div><br></div>", "i": 8347359}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veintiocho de agosto de mil novecientos diecisiete.- Juan Luis Sanfuentes.- Ismael Tocornal. </div></div>", "i": 8347360}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3261", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3261"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1917-08-28", "doble_articulado": false, "id_norma": "139937", "numero_fuente": "11860", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1917-08-29", "vigencias": [{"desde": "1917-08-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1917-08-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1917-08-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODI