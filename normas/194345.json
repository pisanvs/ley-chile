{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6368161}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 218 de 24 de enero de 2002 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA; 37 de 2002, que autoriz&#xF3; al&nbsp; Instituto de Fomento Pesquero, para efectuar una pesca de investigaci&#xF3;n de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Distribuci&#xF3;n espacio temporal de las capturas de Jurel en la I y II Regi&#xF3;n (Primera Etapa, 2002)&quot;, en el sentido de incorporar la embarcaci&#xF3;n artesanal &quot;Chone&quot;, a la n&#xF3;mina de naves participantes en la se&#xF1;alada pesca de investigaci&#xF3;n.</div><br></div>", "i": 6368162}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de enero de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6368163}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "218", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-218"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-01-24", "doble_articulado": false, "id_norma": "194345", "numero_fuente": "37176", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-02-02", "vigencias": [{"desde": "2002-02-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-02-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-02-02", "fin_vig