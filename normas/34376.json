{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291898}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 340, de 19 de Mayo de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase la n&#xF3;mina de especies hidrobiol&#xF3;gicas vivas de importaci&#xF3;n autorizada establecida en la Resoluci&#xF3;n N&#xB0; 531, de 1992, modificada y ampliada por la Resoluci&#xF3;n N&#xB0; 955, de 1992, ambas de esta Subsecretar&#xED;a en el sentido de incorporar en su numeral 2&#xB0;, relativo a las especies cuya importaci&#xF3;n s&#xF3;lo se autoriza para circuito cerrado, en su letra a), esto es, aquellos que se pueden importar en cualquier estado de desarrollo la especie &quot;Langosta de agua dulce, Cherax ternuinamus (Marr&#xF3;n)&quot;.</div><br></div>", "i": 8291899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 19 de Mayo de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8291900}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "340", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-340"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["IMPORTACION", "ESPECIES HIDROBIOLOGICAS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-05-19", "fecha_derogacion": "1994-11-18", "doble_articulado": false, "id_norma": "34376", "numero_fuente": "34573", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-05-25", "vigencias": [{"desde": "1994-11-18", "hasta": "", "tipo_version": "2", "tipo_version_s": "Ú