{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CERTIFICADO</div><br></div>", "i": 6453515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante que suscribo, certifica que la Universidad Central inscrita en el folio C N&#xBA; 4 del Libro de Registro de Universidades, ha presentado los plantes y programas de estudio de la carrera de Ingenier&#xED;a Civil en Computaci&#xF3;n e Inform&#xE1;tica, conducente al grado acad&#xE9;mico de Licenciado en Ciencias de la Ingenier&#xED;a y el t&#xED;tulo profesional de Ingeniero Civil en Computaci&#xF3;n e Inform&#xE1;tica y la carrera de ingenier&#xED;a de Ejecuci&#xF3;n en Inform&#xE1;tica, a la Universidad de Tarapac&#xE1; como entidad examinadora (art. 24&#xBA; DFL. N&#xBA; 1 de 1980) y revisados por &#xE9;sta han sido aprobados en tiempo y forma.</div><br></div>", "i": 6453516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 08 Feb. 1988.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; RAUL MOHR ARAY</div><div class=\"p\">&nbsp; &nbsp;  Subsecretario de Educaci&#xF3;n P&#xFA;blica (S)</div><br></div>", "i": 6453517}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-02-08", "doble_articulado": false, "id_norma": "218672", "numero_fuente": "33005", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-02-25", "vigencias": [{"