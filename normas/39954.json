{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 5.464 EXENTA, DE 1992 </div></div>", "i": 7202413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n Exenta N&#xB0; 1.784 de fecha 21 de Junio de 1995, el suscrito ha procedido a modificar la parte dispositiva de la Resoluci&#xF3;n N&#xB0; Ex. 5.464 de 8 de Septiembre de 1992 de esta II Direcci&#xF3;n Regional, en la forma siguiente:</div><div class=\"p\">&nbsp; &nbsp; a) En la letra a), P&#xE1;rrafo segundo del N&#xB0; 1 se reemplaza el vocablo &quot;grave&quot; por &quot;compleja&quot;.</div><div class=\"p\">&nbsp; &nbsp; b) Se suprime la letra d) del N&#xB0; 1 pasando las letras e), f), g) y h) del mismo numeral, a ser letras d), e), f) y g), respectivamente.-</div><br><br></div>", "i": 7202414}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Luis Lamperein Alarc&#xF3;n, Director Regional.- Sara Mandiola Salinas, Secretaria Regional.</div><br></div>", "i": 7202415}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1784 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1784 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA RESOLUCION N° 5.464 EXENTA, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "SERVICIO IMPUESTOS INTERNOS", "DIRECCION REGIONAL", "SEGUNDA REGION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-06-21", "doble_articulado": false, "id_norma": "39954", "numero_fuente": "35206-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-07-01", "vigencias": [{"desde": "1995-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":