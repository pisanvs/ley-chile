{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6458064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.547, de 31 de diciembre de 2003, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.023 de 2000, de esta Subsecretar&#xED;a, que autoriz&#xF3; a INDUSTRIA DE ALIMENTOS REAL Y COMPA&#xD1;IA LIMITADA a operar una planta de transformaci&#xF3;n en R&#xF3;mulo Correa N&#xBA; 02002, Punta Arenas, en virtud de lo dispuesto en el art&#xED;culo 7&#xBA; del D.S. N&#xBA; 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, y de lo informado por el Servicio Nacional de Pesca en Oficio citado en Visto.-</div><br></div>", "i": 6458065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6458066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3547 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3547 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-31", "doble_articulado": false, "id_norma": "219899", "numero_fuente": "37754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-01-08", "vigencias": [{"desde": "2004-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-01-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-01-08", "fin_vigencia": "", "tipo_version": "3"}