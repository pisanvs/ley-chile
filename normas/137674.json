{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,690.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese al mayor don Jos&#xE9; Antonio Monreal el abono de once meses i dieciocho dias que estuvo separado del Ej&#xE9;rcito por disolucion de la Escuela Militar i por reduccion del cuerpo en que servia.</div><br></div>", "i": 6172854}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, cuatro de setiembre de mil novecientos doce.- Ramon Barros Luco.- Claudio Vicu&#xF1;a S.</div><br></div>", "i": 6172855}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2690", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2690"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-09-04", "doble_articulado": false, "id_norma": "137674", "numero_fuente": "10371", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-09-05", "vigencias": [{"desde": "1912-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-09-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fe