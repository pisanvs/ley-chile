{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta la pensi&#xF3;n de que disfruta don Hip&#xF3;lito Mu&#xF1;oz P., ex-oficial del Correo de Traigu&#xE9;n.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 5960567}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Aum&#xE9;ntase, por gracia, a tres mil seiscientos pesos anuales, la pensi&#xF3;n de que actualmente difruta el ex-oficial 10 del Correo de Traigu&#xE9;n, don Hip&#xF3;lito Mu&#xF1;oz Pinto.</div><br></div>", "i": 5960568}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, trece de Diciembre de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Manuel Barros C. </div></div>", "i": 5960569}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4719", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4719"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Aumenta la pensión de que disfruta don Hipólito;Muñoz P., ex-oficial del Correo de Traiguén.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["HIPOLITO MU OZ PINTO", "PENSION", "REAJUSTE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-12-13", "doble_articulado": false, "id_norma": "24857", "numero_fuente": "15552", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-12-19", "vigencias": [{"desde": "1929-12-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v