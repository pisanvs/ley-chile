{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8328662}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;353, de 16 de marzo de 1998, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de la resoluciones N&#xBA;555 de 1984 y N&#xBA;891 de 1993, N&#xBA;1.214 de 1988 y N&#xBA;659 de 1993, todas de esta Subsecretar&#xED;a, en cuanto autorizan a PESQUERA COLOSO S.A., para desarrollar actividades pesqueras extractivas con las naves &quot;Roble&quot; e &quot;Intr&#xE9;pido&quot; en el litoral de las regiones III y IV.</div><br></div>", "i": 8328663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de marzo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8328664}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "353", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-353"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA COLOSO S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-03-16", "fecha_derogacion": "1999-10-18", "doble_articulado": false, "id_norma": "97360", "numero_fuente": "36021", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-03-21", "vigencias": [{"desde": "1999-10-18", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-03-21", "hasta": "1999-10-17", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1999-10-18