{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 604 EXENTO, DE 1996 </div></div>", "i": 7162107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 604 de 8 de noviembre de 1996, se ha sustituido, a partir del a&#xF1;o escolar 1997, el plan de estudio de 3&#xB0; y 4&#xB0; a&#xF1;o de ense&#xF1;anza media human&#xED;stico-cient&#xED;fica, establecido en el art&#xED;culo 1&#xB0; del decreto supremo exento de Educaci&#xF3;n N&#xB0; 374 de 1990, que aprob&#xF3; plan de estudio especial al Colegio Sagrados Corazones (Padres Franceses) de Talcahuano.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas de: Filosof&#xED;a y Formaci&#xF3;n Cristiana y Computaci&#xF3;n.</div><br></div>", "i": 7162108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de noviembre de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7162109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "604 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-604 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 604 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "MODIFICACION", "COLEGIO SAGRADOS", "CORAZONES", "TALCAHUANO", "OCTAVA REGION", "PROGRAMAS ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-11-19", "doble_articulado": false, "id_norma": "21548", "numero_fuente": "35631", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-03", "vigencias": [{"desde": "1996-12-03", "hasta": "", "tipo_version": "3"