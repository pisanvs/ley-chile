{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 569, de 21 de abril de 1997, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a EMPRESA PESQUERA</div><div class=\"p\">EPERVA S.A., para ampliar actividades pesqueras</div><div class=\"p\">extractivas autorizadas mediante Resoluciones N&#xBA; 1.543,</div><div class=\"p\">de 1990, N&#xBA; 1.132, de 1991, N&#xBA; 493, de 1993 y N&#xBA; 1.205,</div><div class=\"p\">de 1994, todas de esta Subsecretar&#xED;a de Pesca, en orden</div><div class=\"p\">a operar la nave &quot;Parinacota&quot;, matr&#xED;cula N&#xBA; 2.737, en el</div><div class=\"p\">litoral de la X Regi&#xF3;n, por fuera del &#xE1;rea de reserva</div><div class=\"p\">artesanal, donde podr&#xE1; extraer con red de Cerco, los siguientes recursos hidrobiol&#xF3;gicos: Anchoveta, Jurel, Merluza de cola y Sardina com&#xFA;n.</div><br></div>", "i": 8302876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de abril de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "569", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-569"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "EMPRESA PESQUERA EPERVA S.A.", "AMPLIACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-04-21", "doble_articulado": false, "id_no