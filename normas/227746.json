{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6488024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.879, de 9 de julio de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 3.079 de 2003, modificada mediante resoluci&#xF3;n N&#xBA; 225 de 2004, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a la PONTIFICIA UNIVERSIDAD CATOLICA DE VALPARAISO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Situaci&#xF3;n de la Pesquer&#xED;a de Alfonsino&quot;, en el sentido de incorporar a la nave &quot;Friosur IX &quot;, en calidad de reemplazante, a la n&#xF3;mina de naves participantes en la presente pesca de investigaci&#xF3;n.</div><br></div>", "i": 6488025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de julio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6488026}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1879 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1879 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-07-09", "doble_articulado": false, "id_norma": "227746", "numero_fuente": "37911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-07-16", "vigencias": [{"desde": "2004-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-07-16", "fin_vigen