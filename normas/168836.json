{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7269841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 401 de 12 de Abril de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n No. 2034, de 1989 de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a CARRASCO BADILLA SOCIEDAD LIMITADA, RUT No. 87.767.700-1, domiciliada en Puerto Montt, para instalar y operar un centro de cultivo de salm&#xF3;nidos en Chinquihue, Panitao Bajo, Puerto Montt, en el sentido de eliminar en el numeral 2 la autorizaci&#xF3;n otorgada respecto del recurso salm&#xF3;n sockeye (Oneorhynehus nerka).</div><br></div>", "i": 7269842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de Abril de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 7269843}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "401", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-401"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-04-12", "fecha_derogacion": "1994-09-20", "doble_articulado": false, "id_norma": "168836", "numero_fuente": "33950", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-04-23", "vigencias": [{"desde": "1994-09-20", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-04-23", "hasta": "1994-09-19", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia