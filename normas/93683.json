{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE LA RESOLUCION EXENTA No. 3.464, DE 1988 </div></div>", "i": 7228111}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 3.464 de fecha 22 de Diciembre de 1988 de la Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica, se insert&#xF3; en la resoluci&#xF3;n exenta de Educaci&#xF3;n No. 2.573 de 1982, del Centro de Formaci&#xF3;n T&#xE9;cnica CEPA de la III Regi&#xF3;n, las adecuaciones introducidas en la carrera de Secretariado Ejecutivo Biling&#xFC;e y se reemplazaron las normas de evaluaci&#xF3;n, promoci&#xF3;n y titilaci&#xF3;n aprobadas por resoluci&#xF3;n exenta de Educaci&#xF3;n No. 2.573 de 1982, las que podr&#xE1;n aplicarse a contar del segundo semestre acad&#xE9;mico 1988.- </div></div>", "i": 7228112}, {"t": "<div><div class=\"p\">Paulina Dittborn Cordua, Subsecretar&#xED;a de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7228113}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3464 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3464 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE LA RESOLUCION EXENTA No. 3.464, DE 1988", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-12-22", "fecha_derogacion": "2016-12-31", "doble_articulado": false, "id_norma": "93683", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-03-31", "vigencias": [{"desde": "2016-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-03-31", "hasta": "2016-12-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigenc