{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CABLE SUBMARINO ENTRE PUERTO MONTT I PUNTA ARENAS Lei n&#xFA;m. 345.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para contratar hasta por la suma de ciento ochenta i seis mil libras esterlinas la construccion de un cable submarino entre Puerto Montt i Punta Arenas.</div><div class=\"p\">&nbsp; &nbsp; Esta autorizacion durar&#xE1; por el t&#xE9;rmino de un a&#xF1;o.</div><br><br></div>", "i": 8273942}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 11 de Febrero de 1896.-JORJE MONTT.-O. Renjifo.</div><br></div>", "i": 8273943}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "345", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-345"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CABLE SUBMARINO ENTRE PUERTO MONTT I PUNTA ARENAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PUERTO MONTT", "PUNTA ARENAS", "CABLE SUBMARINO", "CONSTRUCCION", "FONDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-02-11", "doble_articulado": false, "id_norma": "22196", "numero_fuente": "5335", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-02-14", "vigencias": [{"desde": "1896-02-14", "hasta": "", "tipo_version": "3", "tipo_version