{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6180075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.397, del 31 de mayo de 1999, se expropiaron los lotes de terreno N&#xBA;s.18 y 64, superficies 248 y 436 m2., respectivamente, roles de aval&#xFA;o en tr&#xE1;mite, comunas de Empedrado y Constituci&#xF3;n para la obra Camino Ruta M-40, Santa Olga-Empedrado, Sector Santa Olga-Los Pellines, y se acord&#xF3; el precio de indemnizaci&#xF3;n con sus propietarios Mar&#xED;a del Carmen G&#xF3;mez Vald&#xE9;s y Humberto del Carmen Torres Bravo, ascendente a las cantidades de $195.307 y $203.198.- </div></div>", "i": 6180076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6180077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1397", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1397"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-31", "doble_articulado": false, "id_norma": "139898", "numero_fuente": "36428", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-08-02", "vigencias": [{"desde": "1999-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-08-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-08-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JCT", "fecha_ingreso": "1999-08-03", "fecha_version