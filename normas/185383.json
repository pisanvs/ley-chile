{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6335194}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;404, de 30 de marzo de 2001, se expropi&#xF3; el lote de terreno N&#xBA;45-A4, superficie 171 m&#xB2;, rol de aval&#xFA;o 88-6, comuna de Teno, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Santiago-Talca. Sector K: S&#xE9;ptima Regi&#xF3;n, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Rolando del Carmen Cofr&#xE9; Gonz&#xE1;lez, ascendente a la cantidad de $1.223.746. </div></div>", "i": 6335195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6335196}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "404", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-404"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "185383", "numero_fuente": "36962", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-15", "vigencias": [{"desde": "2001-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-05-22", "fecha_version": "2001-05-15", "fecha_actualizacion_texto": "2001-05-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabez