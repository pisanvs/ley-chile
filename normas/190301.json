{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 11.107 EXENTA, DE 2001 </div><br></div>", "i": 6352254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 11.107 de 25 de septiembre del a&#xF1;o 2001, se ha aprobado al Colegio &quot;The Angel&apos;s School&quot;, comuna de &#xD1;u&#xF1;oa, provincia de Santiago, un plan de estudio para 4&#xBA; a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para 4&#xBA; a&#xF1;o de ense&#xF1;anza media para los subsectores de idioma extranjero: Ingl&#xE9;s y Filosof&#xED;a.</div><br><br></div>", "i": 6352255}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Septiembre de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6352256}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11107", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11107"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 11.107 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-09-25", "doble_articulado": false, "id_norma": "190301", "numero_fuente": "37079", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-06", "vigencias": [{"desde": "2001-10-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-10-06", "fin_vigencia": "", "tipo_version": "3"}],