{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7292401}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.259 de 18 de junio de 2002 de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 92 de 1986, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a INDUSTRIAL PESQUERA CRISTALMAR LIMITADA, para operar la nave &quot;Propesca I&quot;, ello en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura, y del Memor&#xE1;ndum de la Divisi&#xF3;n de Desarrollo Pesquero de esta Subsecretar&#xED;a.</div><div class=\"p\">&nbsp; &nbsp;  Deni&#xE9;gase la ampliaci&#xF3;n de actividades pesqueras extractivas solicitada por Industrial Pesquera Cristalmar Limitada, conforme el m&#xE9;rito de la presente resoluci&#xF3;n.</div><br></div>", "i": 7292402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de junio de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7292403}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1259", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1259"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-06-18", "doble_articulado": false, "id_norma": "199621", "numero_fuente": "37291", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-24", "vigencias": [{"desde": "2002-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-24