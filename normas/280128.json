{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7379983}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.708, de 15 de octubre de 2008, de esta Subsecretar&#xED;a, d&#xE9;jese sin efecto la resoluci&#xF3;n exenta N&#xBA; 2.094, de 2008, de esta Subsecretar&#xED;a, que declar&#xF3; la caducidad total de las resoluciones exentas N&#xBA; 4.030, de 2005, y N&#xBA; 820, de 2008, ambas de esta Subsecretar&#xED;a, que autorizaron a don GIOVANNI ARANCIBIA FUENTES para desarrollar actividades pesqueras extractivas con la nave &quot;Isla Tab&#xF3;n&quot;, en virtud de haberse acreditado el pago de la patente &#xFA;nica pesquera correspondiente al a&#xF1;o 2008.</div><br></div>", "i": 7379984}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de octubre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7379985}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2708 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2708 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-15", "doble_articulado": false, "id_norma": "280128", "numero_fuente": "39194", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-10-22", "vigencias": [{"desde": "2008-10-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-10-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-10-22", "fin_vigencia": "", "tipo