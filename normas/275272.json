{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 5.660, DE 2008 </div></div>", "i": 6656292}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante la resoluci&#xF3;n N&#xBA; 5.660 de fecha 22 de julio de 2008 de la Direcci&#xF3;n Nacional de Aduanas, se modificaron las normas sobre la transmisi&#xF3;n electr&#xF3;nica del manifiesto de carga por v&#xED;a a&#xE9;rea, contenidas en la resoluci&#xF3;n 428 del 30 de enero de 2004, estableciendo, entre otras disposiciones, un plazo para la transmisi&#xF3;n del mensaje de las gu&#xED;as a&#xE9;reas. Estas modificaciones entran en vigencia a contar del 1 de agosto del a&#xF1;o en curso.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web del Servicio Nacional de Aduanas.</div><br><br></div>", "i": 6656293}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Mujica Montes, Director Nacional de Aduanas.</div><br><br></div>", "i": 6656294}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5660", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5660"}], "organismos": ["MINISTERIO DE HACIENDA", "DIRECCIÓN NACIONAL DE ADUANAS"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 5.660, DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-07-22", "doble_articulado": false, "id_norma": "275272", "numero_fuente": "39130", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-08-05", "vigencias": [{"desde": "2008-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-08-05", "fin_vigencia": ""}, "vigencias_v