{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,023.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161448}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a don Fernando Elizalde derecho de jubilar con arreglo a los a&#xF1;os de servicio que tenia al dejar el empleo de teniente del Resguardo de la Aduana de Valparaiso i al sueldo de que ent&#xF3;nces disfrutaba.</div><br></div>", "i": 6161449}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno que se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticinco de enero de mil ochocientos noventa i ocho.- FEDERICO ERRAZURIZ.- Alberto Gonz&#xE1;lez E.</div><br></div>", "i": 6161450}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1023", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1023"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-25", "doble_articulado": false, "id_norma": "134139", "numero_fuente": "5911", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-25", "vigencias": [{"desde": "1898-01-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-01-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-01-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendie