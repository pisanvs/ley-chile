{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A PEDRO REYES SAEZ</div><br><br></div>", "i": 6595102}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/Ex N&#xBA; 9.995 de fecha 23 de noviembre de 2006, otorga a don Pedro Reyes S&#xE1;ez, RUT N&#xBA;5.937.470-2, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de Productos Hidrobiol&#xF3;gicos, establecido en la resoluci&#xF3;n Ex. N&#xBA;3311, de 30-06-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 6595103}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 23 de noviembre de 2006.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6595104}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9995 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-9995 EXENTA"}, {"tipo": "3", "numero": "DRE-08-9995 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-9995 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A PEDRO REYES\nSAEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PEDRO REYES SAEZ", "AGENTE RETENEDOR DEL IVA", "VENTAS PRODUCTOS HIDROBIOLOGICOS", "OTORGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-23", "doble_articul