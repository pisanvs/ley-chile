{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE EXPROPIACION DE INMUEBLE </div></div>", "i": 6065959}, {"t": "<div><div class=\"p\">Por Decreto Secc. 2&#xAA; No. 1468 de 22 de Diciembre de 1989 Alcalde I. Municipalidad de Santiago dispone expropiaci&#xF3;n parcial inmueble calle Zenteno No. 373 Rol 535-3 comuna de Santiago aparentemente dominio Serviu Metropolitano. Superficie aprox. 140 m2. deslindes: Norte 7.30 mts. Otro propietario; Sur 8 mts., otro propietario; Oriente 18.30 mts. resto predio; Poniente 18.30 mts. Avda. Pdte. Bulnes. Indemnizaci&#xF3;n provisional $ 4.116.000.- pagadera contado. </div></div>", "i": 6065960}, {"t": "<div><div class=\"p\">M&#xE1;ximo Honorato Alamos. Alcalde de Santiago. </div></div>", "i": 6065961}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1468", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1468"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "EXTRACTO DE EXPROPIACION DE INMUEBLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-22", "doble_articulado": false, "id_norma": "83664", "numero_fuente": "33585", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-02-01", "vigencias": [{"desde": "1990-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "1998-01-09", "fecha_version": "1990-02-01", "fecha_actualizacion_texto": "1990-02-01", "tipo_tratado