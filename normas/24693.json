{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n, por gracia, al ex-guardi&#xE1;n de la C&#xE1;mara de Diputados, don Valent&#xED;n Lagos N&#xFA;&#xF1;ez.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8277442}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, al ex-guardi&#xE1;n de la C&#xE1;mara de Diputados don Valent&#xED;n Lagos N&#xFA;&#xF1;ez, una pensi&#xF3;n de tres mil pesos ($ 3,000) anuales. </div></div>", "i": 8277443}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta y uno de Julio de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.-_ Guillermo Edwards Matte. </div></div>", "i": 8277444}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4376", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4376"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE PENSION POR GRACIA, AL EX-GUARDIAN DE LA CAMARA DE DIPUTADOS, DON VALENTIN LAGOS NUÑEZ", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VALENTIN LAGOS NU EZ", "PENSION GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-07-31", "doble_articulado": false, "id_norma": "24693", "numero_fuente": "15146", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-08-10", "vigencias": [{"desde": "1928-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inic