{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6293763}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Comisi&#xF3;n, en su Sesi&#xF3;n N&#xB0; 213, celebrada el 09.06.2000, en virtud de lo previsto en el art&#xED;culo 11 de la Ley N&#xB0; 18.525, acord&#xF3; dar por terminada la investigaci&#xF3;n por subsidios en las importaciones de leche en polvo originarias de Polonia y Rep&#xFA;blica Checa. Este acuerdo fue puesto en conocimiento del Ministro de Hacienda por Of. Res. N&#xB0; CD-49, de 21 de junio de 2000.</div><br><div class=\"p\">&nbsp; &nbsp;  El aviso de esta investigaci&#xF3;n fue publicado en el Diario Oficial con fecha 11 de diciembre de 1999. </div></div>", "i": 6293764}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  LA COMISION </div></div>", "i": 6293765}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "23", "numero": "213", "abreviacion": "SES", "descripcion": "Sesion", "compuesto": "SES-213"}], "organismos": ["COMISIÓN NACIONAL ENCARGADA DE INVESTIGAR LA EXISTENCIA DE DISTORSIONES EN EL PRECIO DE LAS MERCADERÍAS IMPORTADAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-09", "doble_articulado": false, "id_norma": "173482", "numero_fuente": "36723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-07-26", "vigencias": [{"desde": "2000-07-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-07-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-07-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}