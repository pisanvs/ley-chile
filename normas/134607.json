{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9050853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico: Que por resoluci&#xF3;n N&#xBA; 163 de 29 de agosto de 1988, se aprob&#xF3; reforma de estatutos sociedad an&#xF3;nima &quot;La Interamericana Compa&#xF1;&#xED;a de Seguros Generales S.A.&quot;, que consta de escritura p&#xFA;blica de 25 de Julio de 1988, otorgada en la Notar&#xED;a de Santiago, de don Jaime Morand&#xE9; Orrego.</div><br><div class=\"p\">&nbsp; &nbsp;  La Reforma consiste en:</div><div class=\"p\">&nbsp; &nbsp;  1) Actualizar el capital social estableciendo que &#xE9;l asciende a la suma de $ 258.145.787, dividido en 60.450 acciones sin&nbsp; valor nominal.</div><br><div class=\"p\">&nbsp; &nbsp;  2) Aumentar de 5 a 7 el n&#xFA;mero de miembros del Directorio.</div><br><div class=\"p\">&nbsp; &nbsp;  3) Remunerar al Directorio con la cantidad que para tal efecto acuerde la Junta Ordinaria de Accionistas. </div></div>", "i": 9050854}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de Agosto de 1988.- Rodrigo O. Costa Aranda, Secretario General.</div><br><br></div>", "i": 9050855}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "163", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-163"}], "organismos": ["SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-29", "doble_articulado": false, "id_norma": "134607", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-10", "vigencias": [{"desde": "1988-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i