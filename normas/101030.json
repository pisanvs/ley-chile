{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330984}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;695, de 20 de mayo de 1998, de esta Subsecretar&#xED;a de Pesca&nbsp; del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA;1.503, de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA TREMAR S.A., para desarrollar actividades pesqueras extractivas con la nave &quot;Adri&#xE1;tico&quot;, hoy &quot;Cacique I&quot;, en el sentido de indicar que el plazo de inicio de operaciones en la X Regi&#xF3;n es de dos a&#xF1;os despu&#xE9;s de la publicaci&#xF3;n de la resoluci&#xF3;n, esto es, diciembre de 1999.</div><br></div>", "i": 8330985}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330986}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "695", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-695"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA TREMAR S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-05-20", "fecha_derogacion": "2001-12-22", "doble_articulado": false, "id_norma": "101030", "numero_fuente": "36086", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-06-10", "vigencias": [{"desde": "2001-12-22", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-06-10", "hasta": "2001-12-21", "tipo_ver