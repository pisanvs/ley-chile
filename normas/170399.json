{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6280433}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad a lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la primera quincena de Noviembre, fue de 4.97% anual. </div></div>", "i": 6280434}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 17.11.87.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6280435}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-17", "doble_articulado": false, "id_norma": "170399", "numero_fuente": "32923", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-18", "vigencias": [{"desde": "1987-11-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAS", "fecha_ingreso": "2000-06-07", "fecha_version": "1987-11-18", "fecha_actualizacion_texto": "1987-11-18", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6280433}, {"n": "Artículo", "i": 6280434, "t": 6}, {"n": "Promulgación",