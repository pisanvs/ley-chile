{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10314956}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 23, del 25 de febrero de 2022, que establece &quot;El Servicio de Impuestos Internos exime a Fundaci&#xF3;n Abr&#xE1;zame, Fundaci&#xF3;n Sonrisas, Fundaci&#xF3;n Nuestros Hijos y Fundaci&#xF3;n Reforestemos, de la obligaci&#xF3;n de autorizaci&#xF3;n previa de los certificados que deben emitirse conforme al decreto ley N&#xB0; 3.063, de 1979, y Ley N&#xB0; 19.885, siempre y cuando cumplan con los requisitos que se establecen.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10314957}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Barraza Luengo, Director. </div><br></div>", "i": 10314958}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "23 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-23 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2094168", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-02-25", "doble_articulado": false, "id_norma": "1173289", "numero_fuente": "43193", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-03-03", "vigencias": [{"desde": "2022-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}]