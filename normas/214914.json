{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7303852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.149, de 2 de septiembre de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PRODUCTOS MARINOS DE EXPORTACION S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, autorizadas por resoluciones N&#xBA; 84 de 1985 y N&#xBA; 467 de 1988, ambas de esta Subsecretar&#xED;a, en orden a operar en la planta ubicada en Avenida Presidente Alessandri N&#xBA; 750, Queil&#xE9;n, X Regi&#xF3;n, donde podr&#xE1; procesar, en las l&#xED;neas de elaboraci&#xF3;n de Cocido, Fresco-enfriado, Fresco-refrigerado, Congelado, Seco-salado, Ahumado, Conserva y Deshidratado, el recurso hidrobiol&#xF3;gico Abal&#xF3;n rojo.</div><br></div>", "i": 7303853}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 2 de septiembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7303854}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2149", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2149"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-02", "doble_articulado": false, "id_norma": "214914", "numero_fuente": "37664", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-09-20", "vigencias": [{"desde": "2003-09-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-09-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-09