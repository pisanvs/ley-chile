{"html": [{"t": "<div><div class=\"p\">CA&#xD1;AMO</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Enero 4 de 1833.</div><br><div class=\"p\">&nbsp; &nbsp;  Deseando el Gobierno fomentar, por cuantos medios est&#xE9;n a sus alcances, el cultivo del c&#xE1;&#xF1;amo, y persuadido al mismo tiempo que la calidad del que se produce en el pa&#xED;s es aventajada al extranjero, decreta.</div><br><br></div>", "i": 10255818}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0;&nbsp; Todos los buques de guerra nacionales se proveer&#xE1;n en lo sucesivo de la jarcia elavorada en el pais del c&#xE1;&#xF1;amo que en &#xE9;l se produce.</div><br><br></div>", "i": 10255819}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0;&nbsp; La Comisaria de marina proceder&#xE1; a fijar carteles, e insertar avisos en los peri&#xF3;dos, invitando a que se hagan propuestas por los fabricantes de Valpara&#xED;so, bajo las condiciones que con acuerdo del Comandante jeneral de armas, se anuncie por dicha oficina.</div><br><br></div>", "i": 10255820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  3.&#xB0;&nbsp; El Ministro de Marina queda encargado de la ejecucion de este decreto, que se comunicar&#xE1; a quienes corresponda.</div><br><br></div>", "i": 10255821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  PRIETO.&nbsp; &nbsp;  Ramon Cavareda.</div></div>", "i": 10255822}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE LA GUERRA"], "titulo_norma": "CAÑAMO", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1833-01-04", "doble_articulado": false, "id_norma": "1161704", "numero_fuente": "1833", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1833-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1833-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1833-01-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ingreso": "2021-07-30", "fecha_version": "1833-01-04", "fecha_actualizacion_texto": "1833-01-04", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 10255818}, {"n": "Artículo 1°", "i": 10255819, "t": 6}, {"n": "Artículo 2°", "i": 10255820, "t": 6}, {"n": "Artículo 3°", "i": 10255821, "t": 6}, {"n": "Promulgación", "i": 10255822}]}