{"html": [{"t": "<div><div class=\"p\">NOMBRA ALCALDE DE MAR AD-HON&#xD3;REM A LA PERSONA QUE SE INDICA</div></div>", "i": 10154647}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n D.G.T.M. y M.M. Ordinario N&#xBA; 1120/125 Vrs., del 14 de agosto de 2020, nombra Alcalde de Mar Ad-Hon&#xF3;rem a la persona que se indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div><br></div>", "i": 10154648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de agosto de 2020.- Por orden del Sr. Director General, Ren&#xE9; Rojas Cabrejos, Capit&#xE1;n de Nav&#xED;o, Subdirector.- Cristi&#xE1;n Pfeifer Rojas, Capit&#xE1;n de Nav&#xED;o JT, Jefe Depto. Jur&#xED;dico.&nbsp; &nbsp; </div><br></div>", "i": 10154649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "125", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-125"}, {"tipo": "3", "numero": "1120/125", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1120/125"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "NOMBRA ALCALDE DE MAR AD-HONÓREM A LA PERSONA QUE SE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1808538", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-14", "doble_articulado": false, "id_norma": "1148854", "numero_fuente": "42745", "tipo_version": "3", "tipo_version_s": "Ú