{"html": [{"t": "<div><div class=\"p\">ORDENA EXPROPIACION DE INMUEBLE QUE SE&#xD1;ALA</div><br><div class=\"p\">NOTIFICACION</div><br><br></div>", "i": 6148237}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 631 de 27 de noviembre de 1998 de Serviu Metropolitano, orden&#xF3;se expropiaci&#xF3;n, conforme D.L.</div><div class=\"p\">N&#xBA; 2.186 de 1978, el inmueble ubicado en Callej&#xF3;n Santa Laura entre Marcoleta y Rigoberto Jara, presunto rol de aval&#xFA;o N&#xBA; 117-140 comuna de Quilicura, de aparente dominio de Varios Propietarios. Comisi&#xF3;n integrada por peritos Sres. Juan Pagola Idiart y Gustavo Aguirre Asmussen, arquitectos y Sr. Jos&#xE9; Miguel Haltenhoff Aenishanslin, constructor civil seg&#xFA;n informe de 21 de septiembre de 1998 fij&#xF3; monto provisional de indemnizaci&#xF3;n en $973.776.888.- pagadera al contado.-</div><br></div>", "i": 6148238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6148239}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "631", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-631"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "REGIÓN METROPOLITANA DE SANTIAGO"], "titulo_norma": "ORDENA EXPROPIACION DE INMUEBLE QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-27", "doble_articulado": false, "id_norma": "129825", "numero_fuente": "36264", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-15", "vigencias": [{"desde": "1999-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc