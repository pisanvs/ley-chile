{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO No. 181 EXENTO, DE 1987 </div></div>", "i": 6221552}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 181 de 20 de agosto de 1987 se ha aprobado para el Liceo Industrial A-37 de Conchal&#xED;, Provincia de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para la Educaci&#xF3;n Media, modalidad T&#xE9;cnico-Profesional, que se aplicar&#xE1; a contar del a&#xF1;o 1987 y hasta el a&#xF1;o escolar de 1988.</div><br></div>", "i": 6221553}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 27 de Agosto de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 6221554}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "181 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-181 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO No. 181 EXENTO, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-20", "doble_articulado": false, "id_norma": "151965", "numero_fuente": "32865", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-07", "vigencias": [{"desde": "1987-09-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-01-24", "fecha_version": "1987-09-07", "fecha_actualizacion_te