{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 5.937 EXENTA, DE 2002 </div></div>", "i": 6384875}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 5.937 de 24 de mayo del a&#xF1;o 2002, se ha aprobado al Colegio Compa&#xF1;&#xED;a de Mar&#xED;a de Apoquindo, comuna de Las Condes, de Santiago, un plan de estudio para 3&#xBA; y 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para el Subsector de M&#xE9;todos y T&#xE9;cnicas de Investigaci&#xF3;n del Plan Diferenciado.</div><br></div>", "i": 6384876}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de mayo de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6384877}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5937 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-5937 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 5.937 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-24", "doble_articulado": false, "id_norma": "199167", "numero_fuente": "37285", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-17", "vigencias": [{"desde": "2002-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vi