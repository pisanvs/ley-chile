{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9305791}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xBA;2126 de 28 de septiembre de 2012, de conformidad lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;14, superficie 1957 m2, rol de Aval&#xFA;o N&#xBA;2325-1, comuna de Temuco, para la obra &quot;MEJORAMIENTO PASADAS URBANAS RUTA S-30-40 TEMUCO &#x2013; CARAHUE, TRAMO LABRANZA&quot;. La Comisi&#xF3;n de peritos, integrada por ENRIQUE VALLETE DE LA HARPE, YASCHALA MARIBEL Y&#xC1;&#xD1;EZ RIFFO Y MAR&#xCD;A SOLEDAD N&#xDA;&#xD1;EZ ARROYO, fij&#xF3; el valor de tasaci&#xF3;n con fecha 20 de julio de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietaria ALICIA REBECA RAM&#xCD;REZ ARANEDA, en la cantidad de $66.326.713.-, suma que se pagar&#xE1; al contado. </div></div>", "i": 9305792}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9305793}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2126 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2126 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-09-28", "doble_articulado": false, "id_norma": "1044794", "numero_fuente": "40386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-10-16", "vigencias": [{"desde": "2012-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-10-16", "fin_vigencia": ""}, "vigencias_version