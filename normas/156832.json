{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6236834}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 19 de fecha 07.02.85 del SERVIU V</div><div class=\"p\">Regi&#xF3;n de Valpara&#xED;so se dispuso expropiaci&#xF3;n conforme</div><div class=\"p\">articulo 87 Ley de Pavimentaci&#xF3;n Comunal N&#xB0; 8.946 y DL N&#xB0; 2.186, de 1978, de parte inmueble ubicado calle General del Canto s/n, rol de aval&#xFA;o N&#xB0; 24-8, comuna de Los Andes, en superficie de 47 metros cuadrados, de dominio se&#xF1;ora Eliana de La Cruz Canabes. Comisi&#xF3;n Tasadora integrada por arquitecto se&#xF1;or Osvaldo Mu&#xF1;oz Quintana y Constructores Civiles se&#xF1;ores Nino Bozzi Marcelli y Pablo Caria Giurici seg&#xFA;n informe de fecha 25.10.84 fij&#xF3; monto provisional indemnizaci&#xF3;n en la suma de $ 30.550. Indemnizaci&#xF3;n se pagar&#xE1; al contado.-</div><br></div>", "i": 6236835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Director.</div><br></div>", "i": 6236836}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "19", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-19"}], "organismos": ["SERVICIO DE VIVIENDA Y URBANIZACIÓN", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-02-07", "doble_articulado": false, "id_norma": "156832", "numero_fuente": "32110", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-01", "vigencias": [{"desde": "1985-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio