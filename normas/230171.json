{"html": [{"t": "<div><div class=\"p\">AUTORIZA A ORGANISMOS PUBLICOS COMO RECEPTORES DE DOCUMENTOS TRIBUTARIOS ELECTRONICOS </div></div>", "i": 6496463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 86, de fecha 08/09/04, se han autorizado como receptores electr&#xF3;nicos de Documentos Tributarios Electr&#xF3;nicos, a contar del mes de septiembre de 2004, a los Organismos P&#xFA;blicos RUT N&#xBA; 60.905.000-4, RUT N&#xBA; 72.222.000-5, RUT N&#xBA; 61.006.000-5, RUT N&#xBA; 61.008.000-6 y RUT N&#xBA; 61.938.800-3.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio Web del SII (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII septiembre de 2004. </div></div>", "i": 6496464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "86 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-86 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A ORGANISMOS PUBLICOS COMO RECEPTORES DE DOCUMENTOS TRIBUTARIOS ELECTRONICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ORGANISMOS PUBLICOS", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS", "RECEPTORES ELECTRONICOS", "PROCEDIMIENTOS DE OPERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-09-08", "doble_articulado": false, "id_norma": "230171", "numero_fuente": "37960", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-09-11", "vigencias": [{"desde": "2004-09-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"