{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6157269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 2.547, de 30 de noviembre de 1998, se expropiaron los lotes de terreno N&#xBA;s 5 y 7, superficies 860,10 y 5.401,33 m&#xB2; respectivamente, roles de aval&#xFA;o 21-3 y 21-18, comuna de Tierra Amarilla, para la obra Camino Ruta C-35, sector Paipote Cerrillos y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Felipe Venancio Inostroza Castillo y Zoila Beatriz Alicia Fuentes Vallejo, ascendente a la cantidad de $1.466.061 y $15.102.834.</div><br></div>", "i": 6157270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6157271}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2547", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2547"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-11-30", "doble_articulado": false, "id_norma": "132832", "numero_fuente": "36302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-03-01", "vigencias": [{"desde": "1999-03-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-03-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-03-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-03-02", "fecha_version": "1999-03-01", "fecha_actualizacion_texto": "1999-03-01", "tipo_tratado": ""}, "alertas