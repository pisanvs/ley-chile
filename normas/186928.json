{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6340150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n n&#xFA;mero 1.077, de 1 de junio de 2001, de esta Subsecretar&#xED;a, apru&#xE9;base la solicitud presentada por CRISTIAN IVAN RUIZ BUSTAMANTE, para transferir la autorizaci&#xF3;n de acuicultura otorgada por resoluci&#xF3;n N&#xBA; 2.446, de 2000, de esta Subsecretar&#xED;a, a Patagonia Salmon Farming S.A.</div><br><div class=\"p\">&nbsp; &nbsp;  El adquirente podr&#xE1; continuar operando la piscicultura ubicada en el sector Hu&#xE9;pil, comuna de Puc&#xF3;n, provincia de Caut&#xED;n, IX Regi&#xF3;n, para el cultivo de los recursos pertenecientes al grupo de especies Salm&#xF3;nidos y deber&#xE1; dar cumplimiento al proyecto t&#xE9;cnico y cronograma de actividades aprobado por resoluci&#xF3;n N&#xBA; 2.446, de 2000, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6340151}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de junio de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6340152}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1077", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1077"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-06-01", "doble_articulado": false, "id_norma": "186928", "numero_fuente": "36996", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-26", "vigencias": [{"desde": "2001-06-26", "hasta": "", "tipo_version": "3", "tipo_version_s"