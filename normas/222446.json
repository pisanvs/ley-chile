{"html": [{"t": "<div><div class=\"p\">APRUEBA REGLAMENTO SOBRE SUBVENCIONES MUNICIPALES </div></div>", "i": 6468959}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La I. Municipalidad de Mar&#xED;a Pinto pone en conocimiento de la comunidad que por decreto alcaldicio Ex. 21 de fecha 02/02/2004, fue aprobado el Reglamento que norma el procedimiento para el Otorgamiento de las Subvenciones Municipales.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de dicho Reglamento, est&#xE1; a disposici&#xF3;n de los interesados en la Oficina de Partes, en horario de atenci&#xF3;n de p&#xFA;blico (lunes a viernes, de 08:30 a 14:00 hrs.).</div><br></div>", "i": 6468960}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Jessica Mualim Fajuri, Alcaldesa de Mar&#xED;a Pinto </div></div>", "i": 6468961}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "21 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-21 EXENTO"}], "organismos": ["MUNICIPALIDAD DE MARIA PINTO"], "titulo_norma": "APRUEBA REGLAMENTO SOBRE SUBVENCIONES MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-02", "doble_articulado": false, "id_norma": "222446", "numero_fuente": "37810", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-03-13", "vigencias": [{"desde": "2004-03-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-03-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-03-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-03-15", "fecha_v