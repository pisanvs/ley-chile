{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9267795}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.592, de 13 de junio de 2012, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4.- del n&#xFA;mero 1 de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1036492&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 27, de fecha 2012</a>, de esta Subsecretar&#xED;a, en el sentido de incrementar en la letra a) la cuota de sardina austral autorizada a Fundaci&#xF3;n Chinquihue, en 24 toneladas, y de incrementar en la letra b) la cuota de sardina austral autorizada a Consultora Mares Chile Limitada, en 24 toneladas.</div><br></div>", "i": 9267796, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de junio de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9267797}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1592 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1592 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-13", "doble_articulado": false, "id_norma": "1041148", "numero_fuente": "40291", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-19", "vigencias": [{"desde": "2012-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-06-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-06-19", "fin_vigencia": "", "tipo_version