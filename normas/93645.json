{"html": [{"t": "<div><div class=\"p\">PRORROGA AUTORIZACION QUE INDICA </div></div>", "i": 8323398}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 310, de 7 de Marzo de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por seis meses a contar del 13 de enero de 1989, el plazo otorgado a Pesquera Gran Horizonte S.A., RUT No. 96.516.880-K, domiciliada en Santiago, para empezar a operar la embarcaci&#xF3;n &quot;Maracaibo&quot;, autorizada por la resoluci&#xF3;n No. 1.456, de 1987, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br></div>", "i": 8323399}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 7 de Marzo de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8323400}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "310", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-310"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "PRORROGA AUTORIZACION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-03-07", "doble_articulado": false, "id_norma": "93645", "numero_fuente": "33330", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-23", "vigencias": [{"desde": "1989-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"te