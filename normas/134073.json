{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8342715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 326 de 9 de marzo de 1999 de esta Subsecretar&#xED;a, modif&#xED;case las resoluciones del a&#xF1;o 1999, N&#xBA; 116, N&#xBA; 117 y N&#xBA; 118, todas en su numeral 2&#xBA;, correspondientes a SOCIEDAD PESQUERA COLOSO S.A., para ampliar actividades pesqueras con las naves &apos;&apos;Marga Marga&apos;&apos;, &apos;&apos;Yumbel&apos;&apos; y &apos;&apos;Til Til&apos;&apos;, respectivamente, en el sentido de incorporar a la ampliaci&#xF3;n de actividades la especie que se indica: Vinciguerria, en el litoral de la I y II Regiones.</div><br></div>", "i": 8342716}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de marzo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8342717}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "326", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-326"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-03-09", "fecha_derogacion": "2000-02-01", "doble_articulado": false, "id_norma": "134073", "numero_fuente": "36324", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-03-26", "vigencias": [{"desde": "2000-02-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-03-26", "hasta": "2000-01-31", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2000-02-01", "fin_vigencia": "