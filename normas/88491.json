{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6079221}, {"t": "<div><div class=\"p\">El Banco Central de Chile, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, fue de 8,52% anual durante el mes de septiembre de 1990.</div><div class=\"p\">Asimismo, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de septiembre de 1990, fue de 8,35% anual.</div><br></div>", "i": 6079222}, {"t": "<div><div class=\"p\">Santiago, 04 de octubre de 1990.- Mar&#xED;a Eliana Torres Contreras, Secretario General Subrogante.</div><br></div>", "i": 6079223}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-10-04", "doble_articulado": false, "id_norma": "88491", "numero_fuente": "33786", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-10-05", "vigencias": [{"desde": "1990-10-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-10-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-10-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso": "1998-02-09", "fecha