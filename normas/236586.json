{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6520100}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0; 137, de 29 de Febrero de 1996, se expropiaron los lotes de terreno N&#xB0;s. 15 y. 32, superficies 928 M2&nbsp; y 832 M2., roles de aval&#xFA;os 207- 16 y 220-25, comuna de San Javier, para la obra Camino Ruta 5, Longitudinal Sur, sector San Javier Parral I, Tramo A, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Arsenio Garrido Cerpa y otros e Irme Eliana Ram&#xED;rez S&#xE1;ez, ascendente a las cantidades de $45.220.786, para el lote N&#xB0; 15 y $19.064.752, para el lote N&#xB0; 32.</div><br></div>", "i": 6520101}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6520102}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "137", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-137"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-02-29", "doble_articulado": false, "id_norma": "236586", "numero_fuente": "35432", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-04-01", "vigencias": [{"desde": "1996-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-04-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-03-24", "fecha_version": "1996-04-01", "fecha_actuali