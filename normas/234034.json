{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6510477}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.430, de 30 de noviembre de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 6&#xBA; de la resoluci&#xF3;n N&#xBA; 289 de 2004, modificada mediante resoluciones N&#xBA; 1.718, N&#xBA; 2.431, N&#xBA; 3.058 y N&#xBA; 3.427, todas de 2004, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a MARES CHILE LIMITADA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Pesca de Investigaci&#xF3;n de Merluza del sur (Merluccius australis) en aguas interiores de la X Regi&#xF3;n&quot;, en el sentido de incrementar en 33,770 toneladas la cuota autorizada para el mes de diciembre a la Zona Chilo&#xE9;-Palena. </div></div>", "i": 6510478}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6510479}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3430 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3430 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-30", "doble_articulado": false, "id_norma": "234034", "numero_fuente": "38047", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-29", "vigencias": [{"desde": "2004-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"