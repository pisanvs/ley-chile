{"html": [{"t": "<div><br><div class=\"p\">RECTIFICACI&#xD3;N</div></div>", "i": 8934432}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  En la edici&#xF3;n del Diario Oficial N&#xBA; 39.685, de 14 de junio de 2010, se public&#xF3; extracto de <a href=\"https://www.leychile.cl/Navegar?idNorma=1014520&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta</a> que autoriza a las instituciones sin fines de lucro, como receptoras de alimentos cuya comercializaci&#xF3;n sea inviable, con el error que se salva a continuaci&#xF3;n: Cuerpo I, p&#xE1;gina nueve, tercera columna, donde dice: &quot;... Extracto de resoluci&#xF3;n ex. del Servicio de Impuestos Internos N&#xBA; 12 del 9 de junio de 2010, ...&quot;, debe decir: &quot;... Extracto de resoluci&#xF3;n ex. del Servicio de Impuestos Internos N&#xBA; 97 del 9 de junio de 2010, ...&quot;.</div><br></div>", "i": 8934433, "v": ["RECTIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "24", "numero": "133", "abreviacion": "REC", "descripcion": "Rectificación", "compuesto": "Rectificación-133"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "1014669", "numero_fuente": "39690", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-06-19", "vigencias": [{"desde": "2010-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-06-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-06-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu