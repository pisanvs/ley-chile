{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION DE EMISOR ELECTRONICO </div></div>", "i": 6567642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 42 de 17-abril-2006, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como emisor electr&#xF3;nico.</div><div class=\"p\">&nbsp; &nbsp; Se deroga autorizaci&#xF3;n otorgada a contribuyente RUT N&#xBA; 76.182.590-9, para operar como emisor de Documentos Tributarios Electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos de Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril de 2006.</div><br></div>", "i": 6567643}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "42 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-42 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACION DE EMISOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-17", "doble_articulado": false, "id_norma": "249105", "numero_fuente": "38442", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-22", "vigencias": [{"desde": "2006-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-04-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-04-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_