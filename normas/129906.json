{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6148444}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Partido &quot;Nacional&quot; declara con fecha 22 y 23 de Agosto de 1988 y para los efectos del p&#xE1;rrafo 2&#xB0; del Auto Acordado del Tribunal Calificador de Elecciones publicado en el Diario Oficial el 14 de Julio de 1988 que la Directiva Central tiene las siguientes modificaciones:</div><div class=\"p\">- Secretario Subrogante: Sr. Alejandro Guzm&#xE1;n Astete. - Se encuentran vacantes los cargos de Vice Presidentes que ocupaban los se&#xF1;ores Germ&#xE1;n Riesco Za&#xF1;artu y Juan Eduardo King Caldichoury.</div><div class=\"p\">- Conforme a la Resoluci&#xF3;n Exenta No. 4108 de 26.08.88. </div></div>", "i": 6148445}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Agosto de 1988.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6148446}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-26", "doble_articulado": false, "id_norma": "129906", "numero_fuente": "33159", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-08-30", "vigencias": [{"desde": "1988-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-08-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-08-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "