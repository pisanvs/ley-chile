{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que concede por el a&#xF1;o 1901 una gratificacion de mil pesos a cada uno de los profesores de C&#xF3;digo de Comercio de la Universidad.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7163118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por el presente a&#xF1;o, una gratificacion de mil pesos a cada uno de los profesores de C&#xF3;digo de Comercio de la Universidad.</div><br></div>", "i": 7163119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 16 de Diciembre de 1901.- JERMAN RIESCO.- Rafael Balmaceda.</div><br></div>", "i": 7163120}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1499", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1499"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "QUE CONCEDE POR EL AÑO 1901 UNA GRATIFICACIÓN DE MIL PESOS A CADA UNO DE LOS PROFESORES DE CÓDIGO DE COMERCIO DE LA UNIVERSIDAD", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PROFESORES", "UNIVERSIDAD", "CODIGO COMERCIO", "GRATIFICACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-12-16", "doble_articulado": false, "id_norma": "22697", "numero_fuente": "7100", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-12-18", "vigencias": [{"desde": "1901-12-18", "hasta": "", "tipo_version": "3", "tipo_version_