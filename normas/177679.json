{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;422 EXENTO, DE 2000 </div></div>", "i": 6308064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;422, de fecha 3 de octubre de 2000, del Ministerio de Educaci&#xF3;n, se aprueban las modificaciones introducidas a la carrera profesional de Comunicaci&#xF3;n Audivisual, conducente al t&#xED;tulo profesional de Comunicador Audiovisual y a la carrera t&#xE9;cnica de T&#xE9;cico en Comunicaci&#xF3;n Multimedia, conducente al t&#xED;tulo de T&#xE9;cnico de Nivel Superior en Comunicaci&#xF3;n Multimedia, de la Universidad del Pac&#xED;fico, las que regir&#xE1;n a contar del a&#xF1;o 2001.</div><br></div>", "i": 6308065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de octubre de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6308066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "422 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-422 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº422 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-03", "doble_articulado": false, "id_norma": "177679", "numero_fuente": "36810", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-11", "vigencias": [{"desde": "2000-11-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-11-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-11-11", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacio