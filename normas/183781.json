{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 60 EXENTA, DE 2001 </div></div>", "i": 6329650}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 60, de 4 de abril de 2001, de esta Secretar&#xED;a Regional Ministerial, se establece que deber&#xE1; dejar de operar y prestar servicios a partir del 11 de abril de 2001, la Planta de Revisi&#xF3;n T&#xE9;cnica de veh&#xED;culos motorizados y sus remolques N&#xBA; AB0505, concesionada a la Sociedad Centromotori Ltda., ubicada en calle Alberdi esquina Bulnes s/n, Quillota. </div></div>", "i": 6329651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Notif&#xED;quese y publ&#xED;quese.- Carlos Inostroza Bilbao, Secretario Regional Ministerial Transportes y Telecomunicaciones V Regi&#xF3;n.</div><br></div>", "i": 6329652}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "60 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-60 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 60 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-04-04", "doble_articulado": false, "id_norma": "183781", "numero_fuente": "36936", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-04-11", "vigencias": [{"desde": "2001-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-04-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-04-11", "fin_vigencia": "", "tip