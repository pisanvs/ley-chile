{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;273 EXENTO, DE 2004 </div></div>", "i": 6482309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 273, de fecha 28 de abril de 2004, de Educaci&#xF3;n, se autoriza a la Universidad de Aconcagua el cambio de entidad examinadora para la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Planificaci&#xF3;n y Desarrollo Social. Decl&#xE1;rase que la Universidad Cat&#xF3;lica de la Sant&#xED;sima Concepci&#xF3;n se ha constituido en nueva entidad examinadora de la mencionada carrera. </div></div>", "i": 6482310}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de mayo de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 6482311}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "273 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-273 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº273 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-28", "doble_articulado": false, "id_norma": "226072", "numero_fuente": "37877", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-04", "vigencias": [{"desde": "2004-06-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-06-04", "fecha_version": "2004-06-04", "fecha_actual