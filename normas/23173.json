{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,173, que autoriza la acu&#xF1;acion de la moneda creada por lei n&#xFA;m. 2,057</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,173.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7165577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para que continue haciendo acu&#xF1;ar la moneda creada por la lei n&#xFA;m. 2,057 de 9 de Diciembre de 1907, hasta completar la cantidad de diez millones de pesos, fijada en la misma lei.</div><div class=\"p\">&nbsp; &nbsp; No se acu&#xF1;ar&#xE1; moneda de cuarenta centavos. </div></div>", "i": 7165578, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 19 de Febrero de 1909.- PEDRO MONTT.- Luis Devoto A.</div><br></div>", "i": 7165579}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2173", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2173"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Lei núm. 2,173, que autoriza la acuñacion de la;moneda creada por lei núm. 2,057", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MONEDAS", "ACU ACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-02-19", "doble_articulado": false, "id_norma": "23173", "numero_fuente": "9320", "tipo_version": "3", "tipo_version_s": "Única", "fecha_