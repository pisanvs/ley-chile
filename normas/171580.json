{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6284277}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0;1.129, de 21 de junio de 2000, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xB0; de la resoluci&#xF3;n N&#xB0;100 de 2000, de esta Subsecretar&#xED;a, que fij&#xF3; la n&#xF3;mina de armadores y embarcaciones que cumplen con los requisitos legales para operar en la unidad de pesquer&#xED;a de Jurel Trachurus murphyi, declarada en estado de plena explotaci&#xF3;n y sometida a dicho r&#xE9;gimen de administraci&#xF3;n, en el litoral comprendido entre la V y IX regiones, se&#xF1;alada en el art&#xED;culo 1&#xB0; letra d) del DS N&#xB0;354 de 1993, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, en el &#xE1;rea se&#xF1;alada en sus respectivas autorizaciones, en el sentido de agregar lo siguiente:</div><br><div class=\"p\">Armador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Nave</div><div class=\"p\">ARAUCANIA DOS S.A. PESQUERA&nbsp; &nbsp;  Tucano</div><br></div>", "i": 6284278}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de junio de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6284279}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1129", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1129"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-21", "doble_articulado": false, "id_norma": "171580", "numero_fuente": "36