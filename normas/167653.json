{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6271955}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 964 de 30.11.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Jos&#xE9; Oyarzo Andrade, para efectuar el servicio de taxi colectivo de la L&#xED;nea No. 1 &quot;Bellavista - Techo para Todos&quot;, de Puerto Montt, cuyo trazado fue autorizado por resoluci&#xF3;n No. 82 de 07 de junio de 1984 y modificado por resoluci&#xF3;n No. 694, de 20 de agosto de 1987, de esta Secretar&#xED;a Regional. </div></div>", "i": 6271956}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Bold Quezada, Secretario Regional Ministerial de Transportes y Telecomunicaciones X Regi&#xF3;n.</div><br></div>", "i": 6271957}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "964 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-964 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-30", "doble_articulado": false, "id_norma": "167653", "numero_fuente": "32942", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-11", "vigencias": [{"desde": "1987-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-11", "fin_vigencia": "", "tipo_ver