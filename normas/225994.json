{"html": [{"t": "<div><div class=\"p\">APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES </div></div>", "i": 6481936}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La I. Municipalidad de Quinchao pone en conocimiento de la comunidad que por decreto alcaldicio N&#xBA; 1.011 de fecha 27.04.2004, fue aprobada la ordenanza que norma sobre los procedimientos a observar para el otorgamiento de las Subvenciones Municipales.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la citada ordenanza est&#xE1; a disposici&#xF3;n de quien lo solicite en Secretar&#xED;a Comunal de Planificaci&#xF3;n, cuyas oficinas est&#xE1;n ubicadas en calle Amun&#xE1;tegui N&#xBA; 014 de la ciudad de Achao.</div><br></div>", "i": 6481937}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Milton Moya Luchsinger, Alcalde.- Carmen Paz Barriga Soto, Secretaria Municipal.</div><br></div>", "i": 6481938}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1011", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1011"}], "organismos": ["MUNICIPALIDAD DE QUINCHAO"], "titulo_norma": "APRUEBA ORDENANZA SOBRE SUBVENCIONES MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-27", "doble_articulado": false, "id_norma": "225994", "numero_fuente": "37875", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-02", "vigencias": [{"desde": "2004-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones"