{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPRIME LA LETRA C DEL ARTICULO 7&#xB0; DE LA LEY N&#xB0; 8,047</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Honorable Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8278504}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1&#xB0;.- Supr&#xED;mese la letra c) del art&#xED;culo 7&#xB0; de la ley N&#xB0; 8,047, de 9 de Enero de 1945.</div><br></div>", "i": 8278505}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 2&#xB0;.- Autor&#xED;zase a la Municipalidad de Nogales para distribuir la suma de $ 120.000 consultada en la letra c), que se suprime, en la realizaci&#xF3;n de las obras a que se refieren las letras a) y b) del art&#xED;culo 7&#xB0; de dicha ley.</div><br></div>", "i": 8278506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 3&#xB0;.- La presente ley regir&#xE1; desde la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 8278507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta de Septiembre de mil novecientos cuarenta y ocho.- GABRIEL GONZALEZ VIDELA.- I. Holger T. </div></div>", "i": 8278508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "9101", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-9101"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SUPRIME LA LETRA C DEL ARTICULO 7° DE LA LEY N°\n8,047", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 8047", "FACULTAD", "MUNICIPALIDAD NOGALES", "PRESTAMO", "EMPRESTITO", "INVERSION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1948-09-30", "doble_articulado": false, "id_norma": "25917", "numero_fuente": "21189", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1948-10-28", "vigencias": [{"desde": "1948-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1948-10-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1948-10-28", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1948-10-28", "fecha_actualizacion_texto": "1948-10-28", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 8278504}, {"n": "Artículo 1", "i": 8278505, "t": 6}, {"n": "Artículo 2", "i": 8278506, "t": 6}, {"n": "Artículo 3", "i": 8278507, "t": 6}, {"n": "Promulgación", "i": 8278508}]}