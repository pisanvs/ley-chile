{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.040 EXENTA, DE 2010</div></div>", "i": 9029491}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.040, de fecha 15 de octubre del 2010, el Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, autoriz&#xF3; complementariamente a la empresa peruana &quot;Transportes Cruz del Sur S.A.C.&quot;, para efectuar servicio de transporte terrestre internacional de pasajeros entre Per&#xFA; y Chile y viceversa, atendiendo el servicio Lima (Per&#xFA;) / Santiago (Chile), utilizando los pasos fronterizos Concordia con dos (2) frecuencias semanales de ida y vuelta.- </div></div>", "i": 9029492}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Enrique L. Arce Klein, Unidad de Permisos Internacionales Subsecretar&#xED;a de Transportes.</div></div>", "i": 9029493}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3040 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3040 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.040 EXENTA, DE 2010", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-10-15", "doble_articulado": false, "id_norma": "1019080", "numero_fuente": "39801", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-11-04", "vigencias": [{"desde": "2010-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-11-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-11-