{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8807343}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.554, de 23 de otubre de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a EDUARDO SERGIO TOBAR CORVAL&#xC1;N para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar planta ubicada en Puente Tierra s/n, Km. 5,5, Tir&#xFA;a Sur, VIII Regi&#xF3;n, en las l&#xED;neas de proceso Cocido, Congelado, Alga seca y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div></div>", "i": 8807344}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de octubre de 2009.- Germ&#xE1;n Loyola Bast&#xED;as, Subsecretario de Pesca (S).</div></div>", "i": 8807345}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3554 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3554 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-23", "doble_articulado": false, "id_norma": "1008347", "numero_fuente": "39518", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-11-23", "vigencias": [{"desde": "2009-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-11-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2009-11-23", "fec