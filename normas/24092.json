{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,586, que posterga la fecha de la conversion met&#xE1;lica.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,586.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 7166854}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Se posterga hasta el 1.&#xB0; de Febrero pr&#xF3;ximo, el plazo fijado por la lei n&#xFA;m. 3,460, de 30 de Diciembre de 1918, para la conversion del papel moneda de curso forzoso.</div><br></div>", "i": 7166855}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta i uno de Diciembre de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Guillermo Subercaseaux.</div><br></div>", "i": 7166856}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3586", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3586"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "LEI NÚM. 3.586, QUE POSTERGA LA FECHA DE LA CONVERSION METÁLICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PAPEL MONEDA", "CONVERSION", "VIGENCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-12-31", "doble_articulado": false, "id_norma": "24092", "numero_fuente": "12558", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-12-31", "vigencias": [{"desde": "1919-12-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1919-12