{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE CLASIFICACI&#xD3;N DE ENFERMEDADES DE ALTO RIESGO</div><br></div>", "i": 9365096}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.741, de 9 de julio de 2013, de esta Subsecretar&#xED;a, se establece clasificaci&#xF3;n de enfermedades de alto riesgo, de conformidad con el <a href=\"https://www.leychile.cl/Navegar?idNorma=194194&amp;idParte=7289208&amp;idVersion=\">art&#xED;culo 3&#xB0; del DS N&#xB0; 319, de 2001</a>, y sus modificaciones, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, publicada &#xED;ntegramente en www.subpesca.cl y www.sernapesca.cl.</div></div>", "i": 9365097}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de julio de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div><br></div>", "i": 9365098}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1741 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1741 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "ESTABLECE CLASIFICACIÓN DE ENFERMEDADES DE ALTO RIESGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-07-09", "doble_articulado": false, "id_norma": "1052869", "numero_fuente": "40608", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-07-13", "vigencias": [{"desde": "2013-07-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-07-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-07-13", "fin