{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8318236}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;1.774, de 30 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la autorizaci&#xF3;n contenida en la resoluci&#xF3;n N&#xBA;730 de 1995, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA ATLANTICA LTDA., para operar la nave &quot;La Portada&quot;, matr&#xED;cula 2345, en virtud de lo dispuesto en el art&#xED;culo 143 literal b) de la Ley de Pesca y Acuicultura, por no haber iniciado la nave &quot;La Portada&quot; operaciones pesqueras dentro del plazo previsto en el numeral 5 de la resoluci&#xF3;n N&#xBA;730 de 1995, de esta Subsecretar&#xED;a.</div><br></div>", "i": 8318237}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez. Subsecretario de Pesca.</div><br></div>", "i": 8318238}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1774", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1774"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESQUERA ATLANTICA LTDA.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-30", "doble_articulado": false, "id_norma": "86894", "numero_fuente": "35961", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-10", "vigencias": [{"desde": "1998-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i