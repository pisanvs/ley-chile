{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 353 EXENTO, DE 1995 </div></div>", "i": 7161672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 353 de fecha 06 de Junio de 1995 del Ministerio de Educaci&#xF3;n, se modific&#xF3; el Decreto Exento N&#xB0; 223 del 07 de Abril de 1995, correspondiente al Instituto Profesional Carlos Casanueva, en el sentido de se&#xF1;alar que la carrera aprobada por el Consejo Superior de Educaci&#xF3;n, es la siguiente:</div><div class=\"p\"> Carrera:&nbsp; Gesti&#xF3;n en Educaci&#xF3;n No Formal, con</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  menciones en Desarrollo Social y</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Vulnerabilidad Social, conducente al</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  t&#xED;tulo profesional de Gestor en</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Educaci&#xF3;n No Formal.</div><br></div>", "i": 7161673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 21 de Junio de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161674}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "353 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-353 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 353 EXENTO, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO PROFESIONAL CARLOS CASANUEVA", "CARRERA", "PROFESIONAL", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1995-06-06", "fecha_derogacion": "2021-12-31", "doble_articulado": false, "id_norma": "21050", "numero_fuente": "3520