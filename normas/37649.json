{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298819}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 2.035, de 4 de diciembre de 1996,</div><div class=\"p\">de esta Subsecretar&#xED;a de Pesca del Ministerio de</div><div class=\"p\">Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la</div><div class=\"p\">solicitud de concesi&#xF3;n de acuicultura presentada por</div><div class=\"p\">JUAN QUINTEROS MU&#xD1;OZ, para un sector ubicado en Los</div><div class=\"p\">Coig#es, r&#xED;o Maull&#xED;n, comuna de Maull&#xED;n, provincia de</div><div class=\"p\">Llanquihue, X Regi&#xF3;n, en virtud de lo dispuesto en los</div><div class=\"p\">art&#xED;culos 10&#xB0; y 12&#xB0;, del D.S. N&#xB0; 290, de 1993, modificado por el D.S. N&#xB0; 604, de 1994, ambos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 8298820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 4 de diciembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298821}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2035", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2035"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION DE ACUICULTURA", "JUAN QUINTEROS MU OZ", "MAULLIN", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-04", "doble_articulado": false, "id_norma": "37649", "numero_fuente": "35640", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-13", "vigencias": [{"desde": "1996-1