{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.749 EXENTA, DE 2014</div></div>", "i": 9495066}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 3.749, de 15 de julio de 2014, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Enatep Capacitaci&#xF3;n SpA (Enatep SpA)&quot;, RUT. 76.279.769-0 contenida en la resoluci&#xF3;n exenta N&#xBA; 10.085 de 19 de diciembre de 2013, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del Art. 21 de la Ley 19.518.</div></div>", "i": 9495067}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marcia Pardo Gonz&#xE1;lez, Jefa del Departamento de Desarrollo y Regulaci&#xF3;n de Mercado (PT).</div></div>", "i": 9495068}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3749 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3749 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.749 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-07-15", "doble_articulado": false, "id_norma": "1065258", "numero_fuente": "40929", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-08-09", "vigencias": [{"desde": "2014-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014