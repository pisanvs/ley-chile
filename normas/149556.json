{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 103, DE 1987 </div></div>", "i": 7257620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 103 de 15 de Mayo de 1987 se ha aprobado para el Liceo Comercial B No. 61 de &#xD1;u&#xF1;oa, provincia de Santiago, Regi&#xF3;n Metropolitana, un plan y programa especial de estudio para la Educaci&#xF3;n Media, modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1; gradualmente a contar del a&#xF1;o escolar 1987 y hasta el a&#xF1;o escolar de 1992, en la Especialidad de Programaci&#xF3;n en Computaci&#xF3;n.</div><br></div>", "i": 7257621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Mayo de 1987.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7257622}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "103 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-103 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 103, DE 1987", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-05-15", "doble_articulado": false, "id_norma": "149556", "numero_fuente": "32786", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-03", "vigencias": [{"desde": "1987-06-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part":