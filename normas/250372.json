{"html": [{"t": "<div><div class=\"p\">Ley N&#xFA;m. 14,232</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A YOLANDA DIAZ HURTADO </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6572430}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Yolanda D&#xED;az Hurtado, una pensi&#xF3;n de cincuenta escudos (E&#xBA; 50) mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que demande la aplicaci&#xF3;n de esta ley se imputar&#xE1; al &#xED;tem de Pensiones del Presupuesto del Ministerio de Hacienda.</div><br></div>", "i": 6572431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a veinticinco de Octubre de mil novecientos sesenta.- JORGE ALESSANDRI RODRIGUEZ.- Eduardo Figueroa G.</div><br></div>", "i": 6572432}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14232", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14232"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA YOLANDA DIAZ HURTADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1960-10-25", "doble_articulado": false, "id_norma": "250372", "numero_fuente": "24802", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1960-11-24", "vigencias": [{"desde": "1960-11-24", "hasta": "", "tipo_version": "3", "tipo_versi