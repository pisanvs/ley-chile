{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div><br><br></div>", "i": 6427977}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA; 33, de fecha 8 de mayo de 2003, se aprob&#xF3; la disoluci&#xF3;n voluntaria de la Cooperativa Abierta de Vivienda Trabajadores del Carb&#xF3;n Limitada &quot;Carcop&quot;, que consta en la escritura p&#xFA;blica suscrita con fecha 11 de abril del a&#xF1;o 2003 ante do&#xF1;a Mariana Cabezas Figueroa, Notario P&#xFA;blico Suplente de do&#xF1;a Myriam S&#xE1;nchez Sep&#xFA;lveda, Titular de la Duod&#xE9;cima Notar&#xED;a de Coronel.</div><br></div>", "i": 6427978}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; Por orden del se&#xF1;or Subsecretario,&nbsp; Ra&#xFA;l Oliva Camadro, Jefe Departamento de Cooperativas, Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6427979}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "33", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-33"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-05-08", "doble_articulado": false, "id_norma": "211487", "numero_fuente": "37589", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-21", "vigencias": [{"desde": "2003-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-21", "fin_vigencia": ""}, "vigencias_ve