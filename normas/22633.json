{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Reconstruccion del cuartel del Batallon de Infanter&#xED;a &quot;Pudeto&quot; en Chillan</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,418.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5949117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de $ 70,176 en el pago de los trabajos de reconstruccion del cuartel del Batallon de Infanter&#xED;a &quot;Pudeto&quot;, en Chillan, i ejecucion de las obras complementarias del mismo edificio.</div><br><br></div>", "i": 5949118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 26 de Diciembre de 1900.- FEDERICO ERRAZURIZ E.- Arturo Besa.</div><br></div>", "i": 5949119}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1418", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1418"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "RECONTRUCCION DEL CUARTEL DE BATALLON DE INFANTERIA PUDETO EN CHILLAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CUARTEL BATALLON INFANTERIA PUDETO", "CHILLAN", "RECONSTRUCCION", "FONDOS", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-12-26", "doble_articulado": false, "id_norma": "22633", "numero_fuente": "6779", "tipo_version": "3", "tipo_version_s":