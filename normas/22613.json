{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Vestuario, equipo i mobiliario del ej&#xE9;rcito Lei n&#xFA;m. 1,392.- Santiago, a 29 de Noviembre de 1900.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7163045}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para que invierta hasta la suma de un millon de pesos en la adquisicion de vestuario i equipo para el Ej&#xE9;rcito i mobiliario para los Cuerpos.</div><div class=\"p\">&nbsp; &nbsp; Esta autorizacion ser&#xE1; por el t&#xE9;rmino de un a&#xF1;o.</div><br><br></div>", "i": 7163046}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Arturo Besa.</div><br></div>", "i": 7163047}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1392", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1392"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "VESTUARIO, EQUIPO I MOBILIARIO DEL EJÉRCITO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EJERCITO", "MOBILIARIO", "VESTUARIO", "EQUIPO", "ADQUISICION", "FONDOS", "INVERSION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-11-29", "doble_articulado": false, "id_norma": "22613", "numero_fuente": "6755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-11-29", "vigencias": [{"desde": "1900-11-29", "hasta": "", "tipo_version": "3", "t