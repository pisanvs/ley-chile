{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE RECEPTOR ELECTR&#xD3;NICO </div></div>", "i": 6631738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 143 de 27 de noviembre de 2007, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como receptor electr&#xF3;nico.</div><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n de la representante legal del contribuyente RUT N&#xBA; 76.735.340-5, se deroga autorizaci&#xF3;n otorgada como receptor de Documentos Tributarios Electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2007. </div></div>", "i": 6631739}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "143 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-143 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACIÓN DE RECEPTOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-27", "doble_articulado": false, "id_norma": "267087", "numero_fuente": "38927", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-03", "vigencias": [{"desde": "2007-12-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-12-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc