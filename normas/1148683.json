{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.528 DE 12.08.2020, DE LA DIRECCI&#xD3;N NACIONAL DE ADUANAS, QUE MODIFICA RESOLUCI&#xD3;N N&#xBA; 2.445 DE 31.07.2020</div></div>", "i": 10153315}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.528, de 12 de agosto de 2020, del Director Nacional de Aduanas, se modifica el plazo de vigencia de las disposiciones transitorias de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1148287&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.445 de 31 de julio de 2020</a>, de esta Direcci&#xF3;n Nacional.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10153316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de agosto de 2020.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><br></div>", "i": 10153317}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2528 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2528 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.528 DE 12.08.2020, DE LA DIRECCIÓN NACIONAL DE ADUANAS, QUE MODIFICA RESOLUCIÓN Nº 2.445 DE 31.07.2020", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1804454", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-08-12", "doble_articulado": false, "id_norma": "1148683", "numero_fuente": "42739", "tipo_version": "3", "t