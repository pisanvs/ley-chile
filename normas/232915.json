{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6506492}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.178, de 4 de noviembre de 2004, de esta Subsecretar&#xED;a, autor&#xED;zase a LEONIDAS MANSILLA ALMONACID, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en camino a Changuitad s/n, Curaco de V&#xE9;lez, Chilo&#xE9;, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Cocido, Fresco-Enfriado, Fresco-Refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6506493}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de noviembre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6506494}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3178 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3178 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-04", "doble_articulado": false, "id_norma": "232915", "numero_fuente": "38022", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-27", "vigencias": [{"desde": "2004-11-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-11-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-11-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "