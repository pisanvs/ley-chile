{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,729.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173705}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por don Ramon Antonio Vergara Donoso, conc&#xE9;desele, por gracia, una pension equivalente a la jubilacion que le corresponderia con arreglo al sueldo actual de que gozan los Ministros de Cortes de Apelaciones.</div><div class=\"p\">&nbsp; &nbsp;  Para determinar esta pension se computar&#xE1; el tiempo que el se&#xF1;or Vergara ha servido en la Caja de Cr&#xE9;dito Salitrero. </div></div>", "i": 6173706}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, dos de enero de mil novecientos trece.- Ramon Barros Luco.- E. Villegas E.</div><br></div>", "i": 6173707}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2729", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2729"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-01-02", "doble_articulado": false, "id_norma": "137956", "numero_fuente": "10468", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-01-03", "vigencias": [{"desde": "1913-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1