{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7288183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.410, de 4 de diciembre de 2001, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA;282 de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a&nbsp; BOLIVAR GUZMAN ACU&#xD1;A, s&#xF3;lo en lo que respecta a la autorizaci&#xF3;n para operar la nave &quot;Santa Isabel I&quot;, en virtud de lo se&#xF1;alado en el Art&#xED;culo 143 letra b) del D.S. N&#xBA;430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, por no haber operado la mencionada nave, por m&#xE1;s de doce meses en las pesquer&#xED;as autorizadas.</div><br></div>", "i": 7288184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de diciembre de 2001.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7288185}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2410", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2410"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-04", "doble_articulado": false, "id_norma": "192385", "numero_fuente": "37131", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-12-10", "vigencias": [{"desde": "2001-12-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-12-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-12-10", "fin_vigencia": "", "tipo_version