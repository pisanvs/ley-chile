{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6579807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.185, de 1 de agosto de 2006, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 385, modificada por resoluci&#xF3;n N&#xBA; 2.057, ambas de 2006, de esta Subsecretar&#xED;a, que autoriz&#xF3; a la UNIVERSIDAD DEL MAR para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Seguimiento de la pesquer&#xED;a artesanal de Anchoveta desarrollada por la flota artesanal, en sus &#xE1;reas de pesca y en la primera milla de la III Regi&#xF3;n, 2006&quot;, en el sentido de incorporar a la embarcaci&#xF3;n artesanal &quot;Mar&#xED;a I&quot;, RPA 901381, al listado de embarcaciones artesanales autorizadas a participar en la presente pesca de investigaci&#xF3;n.</div><br></div>", "i": 6579808}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de agosto de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6579809}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2185 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2185 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-08-01", "doble_articulado": false, "id_norma": "252382", "numero_fuente": "38544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-21", "vigencias": [{"desde": "2006-08-21