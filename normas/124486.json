{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6130834}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. No. 1.111, de 30 de julio de 1998, se expropiaron los lotes de terreno No. s.2, 18, 19, 76, 77 y 81, superficies 1.955; 873; 1.101; 1.243; 3.352 y 468,50 m2., respectivamente, roles de aval&#xFA;os 3283-35, 3357-1 y 3361-1, comuna de Temuco, obra Camino Mejoramiento Ruta S-269, Padre Las Casas Ni&#xE1;gara y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Alfredo Silva Silva, Fernando Kuscher Toledo y Javier Espinoza Ulloa, ascendente a las cantidades de $ 1.511.055, lote 2; $ 2.149.696, lotes 18 y 19 y $ 3.049.453, lotes 76, 77 y 81.</div><br></div>", "i": 6130835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6130836}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1111", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1111"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "TEMUCO", "NOVENA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-30", "doble_articulado": false, "id_norma": "124486", "numero_fuente": "36165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-15", "vigencias": [{"desde": "1998-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "in