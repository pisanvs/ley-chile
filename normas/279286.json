{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7379511}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.607, de 3 de octubre de 2008, de esta Subsecretar&#xED;a, decl&#xE1;rese la caducidad parcial de la resoluci&#xF3;n exenta N&#xBA; 1.133, de 1992, modificada mediante resoluci&#xF3;n exenta N&#xBA; 954, de 2007, ambas de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESQUERA EL GOLFO S.A. para realizar actividades pesqueras extractivas con la nave &quot;Saint John&quot;, sobre el recurso Besugo Epigonus crassicudus, en el &#xE1;rea mar&#xED;tima comprendida entre la V Regi&#xF3;n y el paralelo 41&#xB0;28,6&apos; L.S., todo ello en virtud de lo dispuesto en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura y de lo se&#xF1;alado en la resoluci&#xF3;n extractada. </div></div>", "i": 7379512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de octubre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7379513}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2607 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2607 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-03", "doble_articulado": false, "id_norma": "279286", "numero_fuente": "39184", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-10-10", "vigencias": [{"desde": "2008-10-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenci