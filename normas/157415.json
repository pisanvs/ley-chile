{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xB0; 102 DE 1985 </div></div>", "i": 6238423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n exenta N&#xB0; 102, de fecha 16 de Enero de 1985 del Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante, se modific&#xF3; la resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 3.352, de 1984, que autoriza impartir la carrera de Turismo, entre otras, a la sede N&#xB0; 3 de Vi&#xF1;a del Mar del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto CELLER, en el sentido de autorizar el cambio de red secuencial de asignaturas s&#xF3;lo por el a&#xF1;o 1984, quedando como a continuaci&#xF3;n se indica: Asignatura:</div><div class=\"p\">Dactilograf&#xED;a. Semestre: Primero. Se imparte en segundo semestre 1984.-</div><br></div>", "i": 6238424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Marta Stefanowsky Bandyra, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante.</div><br></div>", "i": 6238425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "102 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-102 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA N° 102 DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-16", "doble_articulado": false, "id_norma": "157415", "numero_fuente": "32119", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-03-12", "vigencias": [{"desde": "1985-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-03-12", "fin_vigencia": ""}, "vi