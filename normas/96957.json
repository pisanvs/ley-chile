{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6104741}, {"t": "<div><div class=\"p\">Por decreto MOP. N&#xB0; 1.134, de 28 de Noviembre de 1997, se expropiaron los lotes de terreno N&#xB0;s 16, 17 y 27-A, Canal San Jos&#xE9;, 1, Canal San Jos&#xE9; Ramal N&#xB0; 5 y 1, Canal San Jos&#xE9; Ramal N&#xB0; 7, superficies 1.370,1.560,520,888 y 1.352 M2. roles de aval&#xFA;o 591-66, 591-67, 590-46 y 591-3 comuna de Yungay, para la obra Proyecto Lajq Diguill&#xED;n, Area de Riego Yungay, Canal San Jos&#xE9; Ramal N&#xB0; 5 y Ramal N&#xB0; 7 y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Segundo Alfredo Mu&#xF1;oz Ocampo, Marina del Carmen Osses Osses y Omar del Carmen Vel&#xE1;squez Cifuentes, ascendente a las cantidades de $436.957, $451.647,&nbsp; &nbsp; $203.364,&nbsp; &nbsp; $301.650 y $877.820.-</div><br></div>", "i": 6104742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6104743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1134", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1134"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "YUNGAY", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-11-28", "doble_articulado": false, "id_norma": "96957", "numero_fuente": "36004", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-02", "vigencias": [{"desde": "1998-03-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-03-02", "fin_vigencia": ""}, "vigenci