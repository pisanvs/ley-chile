{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA RESOLUCION N&#xB0; 11, DE 1995</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 45.- Santiago, 19 de marzo de 1996.- Vistos: Lo dispuesto en el Art. 4&#xB0; del Decreto Ley N&#xB0; 2.974 de 1979.</div><div class=\"p\">&nbsp; &nbsp; R e s u e l v o:</div><br></div>", "i": 7194425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Modif&#xED;case la Resoluci&#xF3;n N&#xB0; 11 de 20 de Enero de 1995, que designa ministros de fe, en la forma siguiente:</div><div class=\"p\">&nbsp; &nbsp; X REGION:</div><div class=\"p\">&nbsp; &nbsp; Se eliminan a los siguientes funcionarios:</div><div class=\"p\">&nbsp; &nbsp; -Francisco Gonzalo V&#xE1;squez Rodolph</div><div class=\"p\">&nbsp; &nbsp; -Rafael Guillermo Rubi Aparicio</div><div class=\"p\">&nbsp; &nbsp; -Alberto Sol&#xED;s Sanda&#xF1;a</div><div class=\"p\">&nbsp; &nbsp; -Luis Samuel Letelier Quiroga</div><div class=\"p\">&nbsp; &nbsp; -Angel Mariano Valles Espinoza</div><div class=\"p\">&nbsp; &nbsp; Rectif&#xED;case el nombre de Octavio Arcides D&#xED;az Alvarado por el de Octavio Arcides Barr&#xED;a Alvarado.</div><br></div>", "i": 7194426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Luis Marambio Canales, Director Nacional.</div><br></div>", "i": 7194427}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "45", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-45"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "MODIFICA RESOLUCION N° 11, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MINISTRO FE", "DECIMA REGION", "NOMBRAMIENTO", "FRANCISCO GONZALO VASQUEZ RODOLPH", "RAFAEL GUILLERMO RUBI APARICIO", "ALBERTO SOLIS SANDA A", "LUIS SAMUEL LETELIER Q