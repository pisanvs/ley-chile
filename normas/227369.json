{"html": [{"t": "<div><div class=\"p\">BANCOS DE EMISION</div><br><div class=\"p\">Santiago, setiembre 10 de 1869</div><br><div class=\"p\">&nbsp; &nbsp;  (169) Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI </div></div>", "i": 9053070}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  ART&#xCD;CULO &#xDA;NICO.</div><br><div class=\"p\">&nbsp; &nbsp;  Agr&#xE9;guese al art&#xED;culo 28 de la lei de bancos de emision el siguiente inciso:</div><div class=\"p\">&nbsp; &nbsp;  Se escept&#xFA;an los s&#xE1;bados, en que podr&#xE1;n cerrar sus oficinas a las dos de la tarde.</div><br><br></div>", "i": 9053071, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el consejo de Estado, lo he aprobado i sancionado; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  JOSE JOAQUIN PEREZ.</div><div class=\"p\">&nbsp; &nbsp;  Melchor Concha i Toro.</div><br></div>", "i": 9053072}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "BANCOS DE EMISION", "fuente": "Boletin de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1869-09-10", "doble_articulado": false, "id_norma": "227369", "numero_fuente": "37; PAGINA 307", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1869-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1869-09-10", "fin_vigencia": ""}, "vigencias_versi