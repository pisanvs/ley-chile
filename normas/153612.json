{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 6226512}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 443, de fecha 27 de Mayo de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a don Juan Carlos Ponce Zorricueta, para efectuar todo tipo de servicios de Transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6226513}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de Mayo de 1986.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6226514}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "443 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-443 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-05-27", "doble_articulado": false, "id_norma": "153612", "numero_fuente": "32548", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-08-14", "vigencias": [{"desde": "1986-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-08-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-08-14", "fin_vigencia": "", "tipo_v