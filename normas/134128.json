{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 966.- Santiago, 22 de noviembre de 1897.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6161413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Consid&#xE9;rase, por gracia, para los efectos de la lei de 7 de febrero de 1895, que el coronel retirado, don Jos&#xE9; Antonio Varas, cuenta con cuarenta a&#xF1;os de servicios efectivos en el Ej&#xE9;rcito. </div></div>", "i": 6161414}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, dispongo que se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- Carlos A. Palacios Z.</div><br></div>", "i": 6161415}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "966", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-966"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-11-22", "doble_articulado": false, "id_norma": "134128", "numero_fuente": "5862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-11-24", "vigencias": [{"desde": "1897-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-11-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1897-11-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-03-30", "fecha_version": "18