{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Casa Orates de Santiago Lei n&#xFA;m. 890.- Santiago, a 26 de Diciembre de 1896.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273979}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a la Junta de Beneficencia de Santiago un auxilio estraordinario de cincuenta mil pesos a fin de que termine los trabajos que se ejecutan en la Casa de Orates de esta ciudad.</div><br><br></div>", "i": 8273980}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto en todas sus partes como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos Ant&#xFA;nez. </div></div>", "i": 8273981}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "890", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-890"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Casa Orates de Santiago", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUNTA BENEFICENCIA SANTIAGO", "CASA ORATES", "FONDOS", "DESTINACION", "TRABAJOS", "EJECUCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1896-12-26", "doble_articulado": false, "id_norma": "22239", "numero_fuente": "5590", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1896-12-26", "vigencias": [{"desde": "1896-12-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1896-12-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1896-12-26