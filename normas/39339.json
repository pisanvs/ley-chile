{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA PARTE DISPOSITIVA DE RESOLUCION N&#xB0; 2.034 EXENTA, DE 1992 </div></div>", "i": 7201831}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Res. Ex. N&#xB0; 828 de 23.05.95, se introducen las siguientes modificaciones en el dispositivo N&#xB0; 1 de la Res. Ex. N&#xB0; 2.034 del 09.09.92, publicado en el Diario Oficial del 26.09.92.</div><div class=\"p\">&nbsp; &nbsp; 1.- Reempl&#xE1;cese en el inciso segundo de la letra A) la expresi&#xF3;n &quot;graves&quot; por la palabra &quot;complejas&quot;, y 2.- Supr&#xED;mase la letra D), pasando las letras F), G) y H) a ser D), F) y G), respectivamente.</div><br><br></div>", "i": 7201832}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ram&#xF3;n Concha V&#xE9;lis, Director Regional.</div><br></div>", "i": 7201833}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "828 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-828 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA PARTE DISPOSITIVA DE RESOLUCION N° 2.034;EXENTA, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DIRECCION REGIONAL", "SERVICIO IMPUESTOS INTERNOS", "TERCERA REGION", "FACULTAD", "DELEGACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-05-23", "doble_articulado": false, "id_norma": "39339", "numero_fuente": "35191", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-06-12", "vigencias": [{"desde": "1995-06-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-06-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-06-12", "fin_vi