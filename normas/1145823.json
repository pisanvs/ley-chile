{"html": [{"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 1,379.- Santiago, 15 de noviembre de 1900.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE&nbsp; LEI:</div></div>", "i": 10132300}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Autorizase al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de cien mil pesos en adoptar medidas destinadas a combatir las enfermedades infecciosas. </div><br></div>", "i": 10132301}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido al Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i llev&#xE9;se a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- M. S&#xE1;nche Fontecilla.</div></div>", "i": 10132302}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "33", "numero": "1379", "abreviacion": "LEI", "descripcion": "Lei", "compuesto": "Lei-1379"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "PROYECTO DE LEI:", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-11-15", "doble_articulado": false, "id_norma": "1145823", "numero_fuente": "6743", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1900-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1900-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2020-06-30", "fecha_version": "1900-11-15", "fecha_actualizac