{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7194060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 19, del 30 de Junio de 1993, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se adjudic&#xF3; al se&#xF1;or Augusto Pino Sanhueza, la concesi&#xF3;n para operar hasta el 7 de septiembre de 1997, a contar de la fecha de publicaci&#xF3;n del presente extracto, un establecimiento ubicado en camino a Cayucupil de Ca&#xF1;ete, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de los veh&#xED;culos motorizados, remolques y semirremolques, seg&#xFA;n art&#xED;culo 7&#xB0; del D.S.</div><div class=\"p\">N&#xB0; 156/90 en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br></div>", "i": 7194061}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mauricio Leiva Chamorro, Secretario Regional Ministerial Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 7194062}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "19", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-19"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION REVISION TECNICA", "VEHICULOS MOTORIZADOS", "PLANTA REVISION TECNICA", "AUGUSTO PINO SANHUEZA", "REMOLQUES", "CA ETE", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-06-30", "doble_articulado": false, "id_norma": "32192", "numero_f