{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DELEGA EN EL JEFE DEL DEPARTAMENTO DE RESOLUCIONES REGIONAL LA FACULTAD QUE INDICA </div></div>", "i": 6027207}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n N&#xB0; Ex. 11.729 de 22 de Septiembre de 1994, el suscrito deleg&#xF3; en el Jefe del Departamento de Resoluciones Regional, la facultad de autorizar las disminuciones de capital solicitadas por las sociedades, conforme a lo dispuesto en el inciso final del Art. 69&#xB0; del C&#xF3;digo Tributario; de acuerdo a Resoluci&#xF3;n Ex. N&#xB0; 3.830 de fecha 30 de Agosto de 1994, de la Direcci&#xF3;n Nacional, que autoriza delegar en los funcionarios que se&#xF1;ala dicha facultad.-</div><br></div>", "i": 6027208}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Rolando G&#xE1;rate Ega&#xF1;a, Director Regional (S). </div></div>", "i": 6027209}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11729", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-11729"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DELEGA EN EL JEFE DEL DEPARTAMENTO DE RESOLUCIONES\nREGIONAL LA FACULTAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "SERVICIO IMPUESTOS INTERNOS", "DEPARTAMENTO RESOLUCIONES REGIONAL", "JEFE", "QUINTA REGION", "DIRECCION REGIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-22", "doble_articulado": false, "id_norma": "40567", "numero_fuente": "34979", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-09-30", "vigencias": [{"desde": "1994-09-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-09-30", "fin_