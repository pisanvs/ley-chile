{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 3.107 EXENTA, DE 2013</div></div>", "i": 9395862}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.107, de 17 de diciembre de 2013, se aprob&#xF3; el Procedimiento de uso de la Tarjeta bip!, que fija los t&#xE9;rminos y condiciones de uso y funcionamiento de la Tarjeta bip! como medio de acceso y pago al Sistema de Transporte P&#xFA;blico de Pasajeros de la Ciudad de Santiago. </div></div>", "i": 9395863}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Pedro Pablo Err&#xE1;zuriz Dom&#xED;nguez, Ministro de Transportes y Telecomunicaciones. </div></div>", "i": 9395864}, {"t": "<div><br><div class=\"p\">Texto &#xED;ntegro se encuentra en la p&#xE1;gina web www.dtpm.cl.</div></div>", "i": 9395865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3107 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3107 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 3.107 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-17", "doble_articulado": false, "id_norma": "1057861", "numero_fuente": "40748", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-01-04", "vigencias": [{"desde": "2014-01-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-01-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-01-04", "fin_vigencia": "", "tipo_ve