{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Que asigna una gratificacion de 2,400 pesos anuales al promotor fiscal de Nacimiento</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br></div>", "i": 5949368}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. El promotor fiscal de Nacimiento disfrutar&#xE1; de una gratificacion de dos mil cuatrocientos pesos anuales.</div><br></div>", "i": 5949369}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 3 de Enero de 1901.- JERMAN RIESCO.- Rafael Balmaceda.</div><br></div>", "i": 5949370}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1512", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1512"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "Que asigna una gratificacion de 2,400 pesos anuales;al promotor fiscal de Nacimiento", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NACIMIENTO", "PROMOTOR FISCAL", "GRATIFICACION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1902-01-03", "doble_articulado": false, "id_norma": "22708", "numero_fuente": "7114", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1902-01-07", "vigencias": [{"desde": "1902-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1902-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1902-01-07", "