{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA </div></div>", "i": 8326558}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 786, de 4 de Julio de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 1&#xB0; de la resoluci&#xF3;n No. 461, de 1988, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Ricardo Navarro Zapata, RUT No. 2.046.166-K, domiciliado en San Jos&#xE9;, Comuna de Calbuco, Casilla No. 13, para desarrollar actividades pesqueras de cultivo, en el sentido de reemplazar la expresi&#xF3;n &quot;3.000 m2. de fondo de mar&quot; por &quot;3.000 m2. de Sector de playa&quot;.</div><br></div>", "i": 8326559}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 4 de Julio de 1989.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8326560}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "786", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-786"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-04", "doble_articulado": false, "id_norma": "95680", "numero_fuente": "33436", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-07-31", "vigencias": [{"desde": "1989-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-07-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-07-31", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente