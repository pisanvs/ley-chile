{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 231, DE 1991</div><br><br></div>", "i": 7214887}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 231 de fecha 05 de Agosto de 1991 del Ministerio de Educaci&#xF3;n, se aprobaron las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica Sim&#xF3;n Bol&#xED;var de Santiago, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 1991, con la siguiente denominaci&#xF3;n:</div><div class=\"p\">Carrera: Secretariado Ejecutivo Menci&#xF3;n Computaci&#xF3;n.</div><div class=\"p\">T&#xED;tulo: Secretario (A) Ejecutivo (A) menci&#xF3;n Computaci&#xF3;n. </div></div>", "i": 7214888}, {"t": "<div><div class=\"p\">Santiago, 08 de Noviembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7214889}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "231 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-231 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 231, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-05", "doble_articulado": false, "id_norma": "79933", "numero_fuente": "34125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-11-25", "vigencias": [{"desde": "1991-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-11-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-11-25", "fin_vigencia"