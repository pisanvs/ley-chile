{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304668}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.017, de 11 de julio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de concesi&#xF3;n de acuicultura, solicitud N&#xBA; 95103145, presentada por MABEL DEL CARMEN ALVAREZ PINTO, para el centro de cultivo ubicado en Bah&#xED;a Yal, Comuna de Chonchi, Provincia de Chilo&#xE9;, X Regi&#xF3;n, conforme lo dispuesto en los art&#xED;culos N&#xBA; 10&#xBA;, letra c) N&#xBA; 2 y N&#xBA; 14, del D.S. N&#xBA; 290, de 1993, modificado por el D.S. N&#xBA; 604, de 1994, ambos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8304669}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de julio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304670}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1017", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1017"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "CONCESION DE ACUICULTURA", "MABEL DEL CARMEN ALVAREZ PINTO", "CHONCHI", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1997-07-11", "fecha_derogacion": "1998-03-21", "doble_articulado": false, "id_norma": "74359", "numero_fuente": "35820", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1997-07-19", "vigencias": [{"desde": "1998-03-21", "hasta": "", "tipo_version": "2", "tipo