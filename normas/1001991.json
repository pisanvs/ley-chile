{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.731 EXENTA,DE 2009</div></div>", "i": 8591912}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.731, de 4 de mayo de 2009, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n a la sociedad &quot;Cortez y Cortez Limitada&quot; (C &amp; C Ltda.) RUT 76.028.290-1, contenida en la resoluci&#xF3;n exenta N&#xBA; 3.143, de 12 de octubre de 2006, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 3, del art. 21 de la ley 19.518.</div></div>", "i": 8591913}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de mayo de 2009.- Fernando Rouliez Fleck, Director Nacional.</div></div>", "i": 8591914}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2731 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2731 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.731 EXENTA,DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-05-04", "doble_articulado": false, "id_norma": "1001991", "numero_fuente": "39357", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-05-09", "vigencias": [{"desde": "2009-05-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-05-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-05-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc