{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 15 EXENTO, DE 1996 </div></div>", "i": 5939533}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 15, de 15 de enero de 1996, se ha aprobado al Colegio &quot;El Patrocinio de San Jos&#xE9;&quot; de la comuna de Providencia, Santiago, un plan especial de estudio para la Ense&#xF1;anza Media Human&#xED;stico-Cient&#xED;fica, el cual se aplicar&#xE1; a partir del a&#xF1;o escolar 1996 en 1&#xB0;, 2&#xB0; y 3er. a&#xF1;o medio, y a partir del a&#xF1;o escolar 1997, en 4&#xB0; a&#xF1;o medio.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se derogan los decretos supremos exentos de Educaci&#xF3;n N&#xB0;s. 120 de 1982 y 132 de 1990.</div><br></div>", "i": 5939534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 24 de Enero de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5939535}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "15", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-15"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 15 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "COLEGIO EL PATROCINIO DE SAN JOSE", "PROVIDENCIA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-01-15", "doble_articulado": false, "id_norma": "19660", "numero_fuente": "35398", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-02-21", "vigencias": [{"desde": "1996-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-02-21", "f