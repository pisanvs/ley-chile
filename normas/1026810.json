{"html": [{"t": "<div><br><div class=\"p\">CERTIFICADO</div><br></div>", "i": 9152024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de junio de 2011, fue de 1,96% anual.</div></div>", "i": 9152025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de junio de 2011.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9152026}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-06-21", "doble_articulado": false, "id_norma": "1026810", "numero_fuente": "39993", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-06-23", "vigencias": [{"desde": "2011-06-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-06-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-06-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingreso": "2011-06-23", "fecha_version": "2011-06-23", "fecha_actualizacion_texto": "2011-06-23", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9152024}, {"n": "Artículo", "i