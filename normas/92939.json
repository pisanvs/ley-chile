{"html": [{"t": "<div><div class=\"p\">EXTRACTO EXPROPIACION </div></div>", "i": 6092873}, {"t": "<div><div class=\"p\">Alcalde, I. Municipalidad de Conchal&#xED;, modif&#xED;case el Decreto Alcaldicio Exento No. 298 del 12 de Julio de 1989 que ordena expropiaci&#xF3;n parcial conforme a Ley No. 18.695 Ley Org&#xE1;nica constitucional de Municipalidades y Memo. No. 964 del Depto. de Obras Municipales del inmueble ubicado en calle La Serena No. 776 -Rol de aval&#xFA;o No. 1045-36 aparentemente de propiedad de la Sociedad Inmobiliaria La Serena Ltda. en el sentido de rectificar el monto de $ 1.980.000 a $ 2.180.000, el pago de la indemnizaci&#xF3;n se har&#xE1; a Don Enrique Mayer Polak por poseer la representaci&#xF3;n legal de la Sociedad antes mencionada.</div><br></div>", "i": 6092874}, {"t": "<div><div class=\"p\">Fernando Alvarez G&#xE1;lvez, Alcalde. Neftal&#xED; Past&#xE9;n Ibarra, Secretario Municipal.</div><br></div>", "i": 6092875}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "298 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-298 EXENTO"}], "organismos": ["MUNICIPALIDAD DE CONCHALÍ"], "titulo_norma": "EXTRACTO EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-07-12", "doble_articulado": false, "id_norma": "92939", "numero_fuente": "33437", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-08-01", "vigencias": [{"desde": "1989-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-08-01", "fin_vigencia": "", "tipo_v