{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6569862}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 150, de 11 de abril de 2006, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA;2.186 de 1978, del Lote N&#xBA; 20, correspondiente a parte del inmueble ubicado en Avenida Larra&#xED;n N&#xBA; 7175, Rol de Aval&#xFA;o N&#xBA; 4700-8, comuna de La Reina, aparente dominio de do&#xF1;a Sara Rosa Leiva Rojas. Comisi&#xF3;n integrada por peritos se&#xF1;ores Juan Alfredo D&#xED;az Velasco, Arquitecto; Miguel Ortiz Bobadilla, Constructor Civil; y Jaime Jurgens Bittner, Ingeniero Civil. Seg&#xFA;n informe de 06 de enero de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $38.261.000, pagadera al contado. </div></div>", "i": 6569863}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6569864}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "150", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-150"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE SEÑALA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-11", "doble_articulado": false, "id_norma": "249637", "numero_fuente": "38463", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-15", "vigencias": [{"desde": "2006-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"