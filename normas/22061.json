{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CONSTRUCCION DE SALAS PARA ENAJENADOS Lei n&#xFA;m. 203.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente PROYECTO DE LEI:</div><br></div>", "i": 8273845}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cuarenta mil pesos en la construccion de cuatro salas para enajenados en el terreno anexo al edificio de la Casa de Orates de Santiago.</div><div class=\"p\">&nbsp; &nbsp; Autor&#xED;zase asimismo al Presidente de la Rep&#xFA;blica para que invierta hasta la suma de veinticinco mil pesos en el servicio del referido establecimiento.</div><br><br></div>", "i": 8273846}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 12 de Setiembre de 1894.-JORGE MONTT.- Enrique Mac-Iver.</div><br></div>", "i": 8273847}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "203", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-203"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONSTRUCCION DE SALAS PARA ENAJENADOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CASA ORATES", "FONDOS", "CONSTRUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-09-12", "doble_articulado": false, "id_norma": "22061", "numero_fuente": "4914", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-09-12", "vigencias": [{"desde": "1894-09-12", "hasta": "", "tipo_version":