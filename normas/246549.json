{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A ABDIEL SEPULVEDA PARRA </div></div>", "i": 6558179}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/N&#xBA; Ex. 139, de fecha 10-01-2006, revoca a don Abdiel Sep&#xFA;lveda Parra, RUT N&#xBA; 4.172.732-2, a partir de la fecha de esta publicaci&#xF3;n, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de Ganado Vivo, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 18 de la res. Ex. N&#xBA; 3.721 del 28-07-2000, de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos. </div></div>", "i": 6558180}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Sergio Flores Guti&#xE9;rrez, Director Regional. </div></div>", "i": 6558181}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "139 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-139 EXENTA"}, {"tipo": "3", "numero": "DRE-08-139 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-139 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A ABDIEL\nSEPULVEDA PARRA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-10", "doble_articulado": false, "id_norma": "246549", "numero_fuente": "38367", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-01-19", "vigencias": [{"desde": "2006-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Ún