{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 729 EXENTO, DE 1998</div><br><br><br></div>", "i": 6123843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 729 de 6 de julio de 1998, se ha aprobado al Colegio &apos;&apos;Andr&#xE9;e English School&apos;&apos; de la comuna de La Reina, de Santiago, Regi&#xF3;n Metropolitana, un plan de estudio para los&nbsp; cursos de 5&#xBA; a 8&#xBA; a&#xF1;o (NB.3 a NB.6) de Ense&#xF1;anza B&#xE1;sica, para que los aplique&nbsp; de acuerdo a la gradualidad que establece el decreto supremo de Educaci&#xF3;n N&#xBA; 40 de 1996 y sus modificaciones.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban los siguientes programas de estudio de los subsectores correspondientes a los cursos de 5&#xBA; a 8&#xBA; a&#xF1;o (NB.3 a NB.6) de Ense&#xF1;anza B&#xE1;sica.</div><br></div>", "i": 6123844}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de julio de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6123845}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "729 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-729 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 729 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO ANDREE ENGLISH SCHOOL", "LA REINA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-21", "doble_articulado": false, "id_norma": "122565", "numero_fuente": "36128", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "199