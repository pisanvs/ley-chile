{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; NOTIFICACION</div><br></div>", "i": 6511326}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 823 de 13 de diciembre de 2004 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme D.L. N&#xBA; 2.186 de 1978, del lote N&#xBA; 64 a correspondiente al inmueble ubicado en Av. Santa Rosa N&#xBA; 5340, presunto rol de aval&#xFA;o N&#xBA; 5238-129, comuna de San Joaqu&#xED;n, aparente dominio de Shell Chile SAC e I. Comisi&#xF3;n integrada por peritos Nancy S&#xE1;nchez Sep&#xFA;lveda, Arquitecto, Juan D&#xED;az Velasco, Arquitecto, y Fresia Mora Leppe, Arquitecto. Seg&#xFA;n informe de 21 de septiembre de 2004, fij&#xF3; monto provisional indemnizaci&#xF3;n en $30.096.350.- pagadera al contado.</div><br></div>", "i": 6511327}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6511328}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "823", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-823"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-12-13", "doble_articulado": false, "id_norma": "234210", "numero_fuente": "38050", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-01-03", "vigencias": [{"desde": "2005-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia"