{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO&nbsp; N&#xBA; 538&nbsp; EXENTO,&nbsp; DE 1997</div><br></div>", "i": 7211242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto exento N&#xBA; 538 de fecha 16 de mayo de 1997 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica Inacap, las adecuaciones al plan y programas de estudios de la carrera de An&#xE1;lisis de Sistemas. Modific&#xE1;ndose en consecuencia, el Decreto exento del Ministerio de Educaci&#xF3;n N&#xBA; 540 del 07 de noviembre de 1994, en el sentido de incorporar dichas adecuaciones, las que podr&#xE1;n aplicarse a contar del a&#xF1;o 1997, en las sedes que ya contaban con su autorizaci&#xF3;n. </div></div>", "i": 7211243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de julio de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7211244}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "538 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-538 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 538 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO DE FORMACION TECNICA", "INACAP", "PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "ANALISIS DE SISTEMAS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-05-16", "doble_articulado": false, "id_norma": "76322", "numero_fuente": "35892", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-16", "vigencias": [{"desde": "1997-10-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-16", "fi