{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;113 EXENTO, DE 2002 </div></div>", "i": 6373301}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;113 de fecha 6 de febrero de 2002, de Educaci&#xF3;n, se declara aprobada a la Universidad Francisco de Aguirre la siguiente carrera y grado acad&#xE9;mico que se indica:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; : Educaci&#xF3;n de P&#xE1;rvulos</div><div class=\"p\">Grado Acad&#xE9;mico&nbsp; &nbsp; : Licenciado en Educaci&#xF3;n</div><div class=\"p\">T&#xED;tulo Profesional : Educador de P&#xE1;rvulos.</div><br><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo 2&#xBA;: Dicha carrera podr&#xE1; ser impartida en jornada diurna en su Sede de la ciudad de La Serena, a partir del primer semestre del a&#xF1;o 2002, correspondiendo al Consejo Superior de Educaci&#xF3;n la verificaci&#xF3;n progresiva de su desarrollo.</div><br></div>", "i": 6373302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 7 de marzo de 2002.- Patricio Vilaplana Barberis, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6373303}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "113 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-113 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº113 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-02-06", "doble_articulado": false, "id_norma": "195681", "numero_fuente": "37215", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-03-20", "vigencias": [{"desde": "2002-03-20", "hasta": "