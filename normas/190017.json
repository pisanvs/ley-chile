{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6351404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.158 de fecha 31 de julio de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 4, superficie 1.303 m&#xB2;, rol de aval&#xFA;o N&#xBA; 536-322, comuna de La Uni&#xF3;n, para la obra &apos;&apos;Camino Conexi&#xF3;n La Uni&#xF3;n - Corral, Sector Bifurcaci&#xF3;n La Uni&#xF3;n, Empalme Ruta T-60, Km. 7,100 a Km.</div><div class=\"p\">8,500&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Clodett Pascalet Essmann Molina, ascendente a la cantidad de $33.470.017.</div><br></div>", "i": 6351405}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6351406}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1158", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1158"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-31", "doble_articulado": false, "id_norma": "190017", "numero_fuente": "37074", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-10-01", "vigencias": [{"desde": "2001-10-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-10-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-10-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2001-10-01", "fecha_version": "2001-10-01", "fecha_actualizacion_texto": "200