{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; EXTRACTO</div><br></div>", "i": 6445838}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 901, de 28 de octubre del a&#xF1;o 2003, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se aprueban forma y condiciones para autorizar modificaciones de recorrido de Servicios Urbanos de Transporte P&#xFA;blico Remunerado de Pasajeros Prestados Mediante Buses en Combinaci&#xF3;n con Metro (Licitaci&#xF3;n Metrob&#xFA;s 2002), contenida en Anexo denominado: &quot;Forma y Condiciones para la Autorizaci&#xF3;n de Modificaciones de Recorridos de Servicios Metrob&#xFA;s 2002&quot;, el que forma parte de dicha resoluci&#xF3;n y que se encuentra a disposici&#xF3;n de los interesados en las dependencias de esa Secretar&#xED;a Regional.</div><br></div>", "i": 6445839}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Silvio Albarr&#xE1;n Alb&#xE1;n, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6445840}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "901 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-901 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARIA REGIONAL MINISTERIAL REGION METROPOLITANA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LICITACION DE VIAS", "LOCOMOCION COLECTIVA", "SANTIAGO", "LICITACION METROBUS 2002", "MODIFICACION DE RECORRIDOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion":