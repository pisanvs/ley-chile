{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8304072}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 813, de 6 de junio de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, d&#xE9;jase sin efecto las Resoluciones N&#xBA; 1.028, de 1991 y N&#xBA; 879 de 1995, ambas de esta Subsecretar&#xED;a, que autorizaron a LEANDRO ANTONIO MIRET ROJAS, para instalar y operar el centro de cultivo ubicado en Bah&#xED;a Aucar, comuna de Quemchi, X Regi&#xF3;n, por haberse dejado sin efecto las respectivas Resoluciones de concesi&#xF3;n de acuicultura.</div><br></div>", "i": 8304073}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de junio de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8304074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "813", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-813"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DEROGACION", "AUTORIZACION", "LEANDRO ANTONIO MIRET ROJAS", "CENTRO DE CULTIVO", "QUEMCHI", "DECIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-06", "doble_articulado": false, "id_norma": "73661", "numero_fuente": "35793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-06-18", "vigencias": [{"desde": "1997-06-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-06-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-06-18", "fin_vigencia