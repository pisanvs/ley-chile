{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6050823}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 27, del 13 de marzo de 1992, de la</div><div class=\"p\">Secretar&#xED;a Regional Ministerial de Transportes y</div><div class=\"p\">Telecomunicaciones de la I Regi&#xF3;n, se adjudic&#xF3; a David</div><div class=\"p\">Humberto Avalos Berrocal, la concesi&#xF3;n para operar, por</div><div class=\"p\">un plazo de cinco a&#xF1;os a contar de la fecha de publicaci&#xF3;n</div><div class=\"p\">del presente extracto, un establecimiento ubicado en calle</div><div class=\"p\">Sotomayor 2080, de Iquique, destinado a la revisi&#xF3;n</div><div class=\"p\">t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de los</div><div class=\"p\">veh&#xED;culos que se se&#xF1;alen en el inciso primero del</div><div class=\"p\">art&#xED;culo 7&#xB0; del DS 156/90 del Ministerio, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.</div><br></div>", "i": 6050824}, {"t": "<div><div class=\"p\">Yerko Luksic Sandoval, Secretario Regional Ministerial Transportes y Telecomunicaciones I Regi&#xF3;n.</div><br></div>", "i": 6050825}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "27", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-27"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-13", "doble_articulado": false, "id_norma": "77594", "numero_fuente": "34362", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-09-08", "vigenci