{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;. 369 DE 1990 </div></div>", "i": 7231180}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 369 de 27 de</div><div class=\"p\">diciembre de 1990 se ha modificado el decreto supremo exento</div><div class=\"p\">de Educaci&#xF3;n No. 127 de 1988 que aprob&#xF3; plan y programas</div><div class=\"p\">experimentales de estudio de educaci&#xF3;n b&#xE1;sica para j&#xF3;venes y</div><div class=\"p\">adultos con retraso pedag&#xF3;gico a la Fundaci&#xF3;n de</div><div class=\"p\">Beneficiencia Hogar de Cristo en el sentido de agregar un</div><div class=\"p\">art&#xED;culo 7&#xB0; nuevo pasando a ser los actuales 7&#xB0;, 8&#xB0; y 9&#xB0;; art&#xED;culos 8&#xB0;, 9&#xB0; y 10&#xB0; respectivamente.</div><br></div>", "i": 7231181}, {"t": "<div><div class=\"p\">Santiago 20 de Febrero de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7231182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "369 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-369 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº. 369 DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-12-27", "doble_articulado": false, "id_norma": "96684", "numero_fuente": "33905", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-27", "vigencias": [{"desde": "1991-02-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-27", "fin_vigencia": ""}, "vige