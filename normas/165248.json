{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6264117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n Exenta No. 312 de fecha 28 de Noviembre de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la II Regi&#xF3;n, se autoriza a Tramaca, Sociedad de Responsabilidad Ltda., para efectuar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br><br></div>", "i": 6264118}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Guido M. Ram&#xED;rez Maturana, SEREMI de Transportes y Telecomunicaciones, II Regi&#xF3;n.</div><br></div>", "i": 6264119}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "312 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-312 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-11-28", "doble_articulado": false, "id_norma": "165248", "numero_fuente": "32339", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-12-05", "vigencias": [{"desde": "1985-12-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-12-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-12-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincula