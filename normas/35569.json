{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294187}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 779, de 2 de mayo de 1996, de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura presentada por SALMONES AUCAR</div><div class=\"p\">LTDA., domiciliada en Amun&#xE1;tegui N&#xB0; 72, 2&#xB0; piso,</div><div class=\"p\">Santiago, para un centro de cultivo ubicado al Sureste</div><div class=\"p\">de Punta Pindo, Isla Chel&#xED;n, Comuna de Castro, Provincia</div><div class=\"p\">de Chilo&#xE9;, X Regi&#xF3;n, por no dar cumplimiento el</div><div class=\"p\">respectivo proyecto t&#xE9;cnico a lo dispuesto en los</div><div class=\"p\">art&#xED;culos 78&#xB0; y 87&#xB0; de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8294188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 2 de mayo de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8294189}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "779", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-779"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SALMONES AUCAR LTDA", "CONCESION ACUICULTURA", "DECIMA REGION", "CASTRO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-02", "doble_articulado": false, "id_norma": "35569", "numero_fuente": "35463", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-05-10", "vigen