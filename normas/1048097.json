{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9327651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;3234, de 27 de diciembre de 2012, y de conformidad a lo dispuesto en el art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;2, superficie 719 m2., Rol N&#xBA;326-35, Comuna de Mariquina, para la obra &quot;CONSERVACI&#xD3;N PERI&#xD3;DICA PUENTE CALEL Y OCHOA, SECTOR PUENTE CALEL&quot;, Regi&#xF3;n de Los R&#xED;os. La comisi&#xF3;n de peritos integrada por Patricio Fernando Casagrande Ulloa, Norman Calder&#xF3;n Pontiggia y Soledad Nu&#xF1;ez Arroyo, fij&#xF3; el valor de tasaci&#xF3;n con fecha 14 de septiembre de 2009, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JOS&#xC9; LUIS CARIM&#xC1;N CARIM&#xC1;N, en la cantidad de $830.969.- suma que se pagar&#xE1; al contado. </div></div>", "i": 9327652}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9327653}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3234 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3234 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-12-27", "doble_articulado": false, "id_norma": "1048097", "numero_fuente": "40459", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-01-15", "vigencias": [{"desde": "2013-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-01-15", "fin_vigencia": ""}, "vigencias_ver