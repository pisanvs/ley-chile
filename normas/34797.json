{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8292483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 440, de 6 de Mayo de 1994, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 3&#xB0; de la Resoluci&#xF3;n N&#xB0; 178, de 1994, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SALMONES CHONCHI S.A., R.U.T. N&#xB0; 96.524.770-K, para ampliar actividades pesqueras de procesamiento, en el sentido de incorporar en su texto el siguiente p&#xE1;rrafo 4&#xB0;:</div><div class=\"p\">&nbsp; &nbsp; &quot;Los recursos Salm&#xF3;n del atl&#xE1;ntico, Salm&#xF3;n rey, Salm&#xF3;n cereza, Salm&#xF3;n del pac&#xED;fico, Trucha arco iris, Trucha caf&#xE9;, Trucha cabeza de acero, Turbot, Abal&#xF3;n, Osti&#xF3;n del norte y Ostra del pac&#xED;fico, deber&#xE1;n provenir de centros de cultivo autorizados&quot;.</div><br></div>", "i": 8292484}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 6 de Mayo de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8292485}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "440", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-440"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SALMONES CHONCHI S.A.", "AMPLIACION", "AUTORIZACION", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1994-05-06", "fecha_derogacion": "2005-05-26", "doble_articulado": false, "id_norma": "34797", "numero_fuente": "34868", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicaci