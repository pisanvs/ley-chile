{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,885, que autoriza la ereccion en Santiago de un monumento a Simon Bol&#xED;var</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,885.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8276789}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Autor&#xED;zase la ereccion en la capital de la Rep&#xFA;blica, por suscricion popular, de un monumento ecuestre en honor de Simon Bol&#xED;var. </div></div>", "i": 8276790}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 6 de Setiembre de 1922.- ARTURO ALESSANDRI.- Antonio Huneeus.</div><br></div>", "i": 8276791}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3885", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3885"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "Lei núm. 3,885, que autoriza la ereccion en Santiago;de un monumento a Simon Bolívar", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SIMON BOLIVAR", "MONUMENTO", "SANTIAGO", "ERECCION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1922-09-06", "doble_articulado": false, "id_norma": "24320", "numero_fuente": "13663", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-08-28", "vigencias": [{"desde": "1923-08-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia