{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 460.- Santiago, 31 de julio de 1925.-</div><div class=\"p\">&nbsp; &nbsp; El Presidente de la Rep&#xFA;blica, oido el Consejo de Secretarios de Estado, dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; DECRETO-LEI:</div><br></div>", "i": 8256243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Prorr&#xF3;gase hasta el 1.o de enero de 1926 el plazo fijado por Decreto-Lei n&#xFA;mero 26, de 3 de octubre de 1924, para que sea obligatoria la libreta de identidad personal.</div><br></div>", "i": 8256244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, comun&#xED;quese y publ&#xED;quese.- Alessandri.- Armando Jaramillo </div></div>", "i": 8256245}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "460", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-460"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LIBRETA IDENTIDAD PERSONAL", "OBLIGACION", "PLAZO", "AMPLIACION", "OBTENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-07-31", "doble_articulado": false, "id_norma": "6101", "numero_fuente": "14240", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-08-04", "vigencias": [{"desde": "1925-08-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1925-08-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1925-08-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1925-08-04", "fecha_actualizacion_texto": "1925-08-04", "tipo_tratado": ""}, "alertas": [], "alerta_global": "",