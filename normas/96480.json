{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA N&#xBA;. 26, DE 1990 </div></div>", "i": 8930018}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta de la referencia se han aprobado Planes y Programas de Estudio, para la Educaci&#xF3;n Media T&#xE9;cnico Profesional, a contar del a&#xF1;o escolar 1990 y hasta el a&#xF1;o escolar 1996, inclusive, para el Liceo C 12 &quot;Alcalde Sergio Gonz&#xE1;lez Guti&#xE9;rrez de Pozo Almonte&quot;.</div><br><div class=\"p\">Especialidades:</div><div class=\"p\">- Vestuario.</div><div class=\"p\">- Mec&#xE1;nica de Combusti&#xF3;n Interna y Automotriz.</div><br><br></div>", "i": 8930019}, {"t": "<div><div class=\"p\">Iquique.- Marco Antonio Castro Bernar, Secretario Ministerial de Educaci&#xF3;n I Regi&#xF3;n Tarapac&#xE1;. </div></div>", "i": 8930020}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "26 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-26 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SECRETARÍA REGIONAL MINISTERIAL I REGIÓN DE TARAPACÁ"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA Nº. 26, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "96480", "numero_fuente": "33888", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-02-07", "vigencias": [{"desde": "1991-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-02-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingr