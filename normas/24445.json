{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Ley N.o 4,070.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 5958196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Substit&#xFA;yese la palabra &quot;autorizado&quot;, puesta al final del art&#xED;culo 67 del Decreto-Ley N.o 556, de 26 de Septiembre de 1925, por la siguiente palabra &quot;pagado&quot;.</div><div class=\"p\">&nbsp; &nbsp; Esta Ley comenzar&#xE1; a regir desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5958197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como Ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a diecinueve de Junio de mil novecientos vientis&#xE9;is.- Emiliano Figueroa.- Jorge Silva Somarriva. </div></div>", "i": 5958198}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4070", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4070"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LEY GENERAL BANCOS", "MODIFICACION", "BANCOS COMERCIALES", "FONDOS RESERVA", "ESTABLECE"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1926-06-19", "doble_articulado": false, "id_norma": "24445", "numero_fuente": "14500", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1926-06-21", "vigencias": [{"desde": "1926-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1926-06-21", "fin_vigencia": ""}, "vigenci