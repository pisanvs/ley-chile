{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330172}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;617, de 30 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case la resoluci&#xF3;n N&#xBA;1.498 de 1997, de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA CORONEL S.A., para ampliar actividades pesqueras con la nave &quot;Antartic&quot;, en el sentido de reemplazar el inciso primero del&nbsp; numeral 2 por el siguiente:</div><div class=\"p\">&nbsp; &nbsp;  &quot;2. La interesada podr&#xE1; realizar actividades pesqueras con la nave &quot;Antartic&quot; en el litoral de la V a la VII y IX Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con red de cerco el recurso hidrobiol&#xF3;gico Merluza de cola.&quot; </div></div>", "i": 8330173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330174}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "617", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-617"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA CORONEL S.A.", "AMPLIACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-04-30", "fecha_derogacion": "1998-08-19", "doble_articulado": false, "id_norma": "99311", "numero_fuente": "36068", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-05-19", "vigencias"