{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE INDICA </div><br><br></div>", "i": 6183707}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 595 de 14 de Abril de 1988, conforme art. 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento Aguas proporcionales que corresponden a parcelas N&#xB0;s. 1 a la 5, sitios N&#xB0;s. 1 y 2 del Proyecto de Parcelaci&#xF3;n &quot;EI Aguila&quot;, de la comuna de Chill&#xE1;n, VIII Regi&#xF3;n, formado por predio &quot;Fundo San Miguel&quot;. Los derechos de agua se extraen del canal Cato derivado del r&#xED;o &#xD1;uble y Canal Santa Rosa derivado del r&#xED;o Chill&#xE1;n. Publicaci&#xF3;n hecha conforme art. 13 Ley No. 18.377. </div></div>", "i": 6183708}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6183709}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "595 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-595 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTO DE AGUAS QUE\nINDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-14", "doble_articulado": false, "id_norma": "140897", "numero_fuente": "33060", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-02", "vigencias": [{"desde": "1988-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio