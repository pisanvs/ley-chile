{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 337, DE 1984 </div></div>", "i": 8543824}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 112, de 06 de Febrero de 1.986, de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n 337, de 1984, de la Subsecretaria de Pesca, que autoriz&#xF3; a la sociedad &quot;Pesquera Luva Limitada&quot; para desarrollar actividades pesqueras, en orden a reemplazar el numeral 2&#xB0; por el siguiente: &quot;2&#xB0; la peticionaria podr&#xE1; instalar y operar una planta elaboradora de recursos hidrobiol&#xF3;gicos en conserva, congelado y deshidratado, en calle &#xD1;uble 190, Puerto Montt, Xa. Regi&#xF3;n. </div></div>", "i": 8543825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 06 de Febrero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 8543826}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "112", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-112"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 337, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-02-06", "doble_articulado": false, "id_norma": "155552", "numero_fuente": "32400", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-02-17", "vigencias": [{"desde": "1986-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_v