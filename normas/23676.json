{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Ampl&#xED;a el plazo del cual las Municipalidades pueden aprobar sus Presupuestos para el a&#xF1;o 1916</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,027.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8275868}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Ampl&#xED;ase hasta el 30 de Noviembre pr&#xF3;ximo, el plazo dentro del cual las Municipalidades pueden aprobar sus Presupuestos para el a&#xF1;o 1916.</div><br><br></div>", "i": 8275869}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 4 de Setiembre de 1915.- RAMON BARROS LUCO.- E. Villegas E.</div><br></div>", "i": 8275870}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3027", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3027"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "AMPLIA EL PLAZO DEL CUAL LAS MUNICIPALIDADES PUEDEN APROBAR SUS PRESUPUESTOS PARA EL AÑO 1916", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDADES", "PRESUPUESTO", "APROBACION", "PLAZO", "PRORROGA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1915-09-04", "doble_articulado": false, "id_norma": "23676", "numero_fuente": "11270", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1915-09-15", "vigencias": [{"desde": "1915-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}