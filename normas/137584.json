{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,601.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6172498}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados por el cabo segundo del batallon de Cazadores de la &#xE9;poca de la Independencia, don Matias Arellana, conc&#xE9;dese, por gracia, a su hja lej&#xED;tima do&#xF1;a Isabel Arellana, derecho a gozar de la pension de montep&#xED;o asignada a la familia de un teniente segundo de Ej&#xE9;rcito.</div><br></div>", "i": 6172499}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, once de enero de mil novecientos doce.- Ramon Barros Luco.- Alejandro Huneeus.</div><br></div>", "i": 6172500}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2601", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2601"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-01-11", "doble_articulado": false, "id_norma": "137584", "numero_fuente": "10177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-01-12", "vigencias": [{"desde": "1912-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1912-01-1