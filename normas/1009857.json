{"html": [{"t": "<div><br><div class=\"p\">DELEGA FACULTADES QUE INDICA Y DEROGA RESOLUCIONES QUE SE&#xD1;ALA</div><br></div>", "i": 8817866}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 207, de 29 de diciembre de 2009, que establece:</div><div class=\"p\">&nbsp; &nbsp;  Delega en el Jefe del Departamento de Defensa Judicial y Delitos Tributarios, las facultades que en ella se indican.</div><div class=\"p\">&nbsp; &nbsp;  Deroga, adem&#xE1;s, <a href=\"https://www.leychile.cl/Navegar?idNorma=1010989&amp;idParte=&amp;idVersion=2010-01-04\">resoluciones N&#xBA; 30, de 16 de marzo de 1981</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=281376&amp;idParte=&amp;idVersion=2010-01-04\">exenta N&#xBA; 145, de 12 de noviembre de 2008</a>, de esta Direcci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2009.</div><br><br><br></div>", "i": 8817867, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8817868}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "207 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-207 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUBSECRETARÍA DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DELEGA FACULTADES QUE INDICA Y DEROGA RESOLUCIONES QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-