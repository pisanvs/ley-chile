{"html": [{"t": "<div><div class=\"p\">PRESIDENTE DE LA REPUBLICA.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Setiembre 18 de 1831.</div></div>", "i": 10262734}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; En este dia, previas las formalidades de la lei, se ha recibido y entrado en ejercicio del mando Supremo de la Rep&#xFA;blica, como Presidente constitucional el Excmo. Sr. Jeneral de division don Joaquin Prieto.</div><div class=\"p\">&nbsp; &nbsp;  Lo comunico a U. S. de &#xF3;rden Suprema para su intelijencia, y a fin de que disponga U. S. su reconocimiento con la posible solemnidad en los pueblos de la comprension de su mando.</div></div>", "i": 10262735}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Dios guarde a U. S.</div><br><div class=\"p\">&nbsp; &nbsp;  R&#xFA;brica de S. E.</div><br><div class=\"p\">&nbsp; &nbsp;  Ramon Err&#xE1;zuriz.</div></div>", "i": 10262736}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "PRESIDENTE DE LA REPUBLICA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1831-09-18", "doble_articulado": false, "id_norma": "1160266", "numero_fuente": "1831", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1831-09-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1831-09-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1831-09-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_ing