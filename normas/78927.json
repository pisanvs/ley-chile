{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 77, DE 1992 </div></div>", "i": 6053683}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 77 de 31 de marzo de 1992 se ha aprobado, a contar del a&#xF1;o escolar 1992, un plan especial de estudio para los cursos de 5&#xB0; a 8&#xB0; a&#xF1;o b&#xE1;sico y 1&#xB0; a 4&#xB0; a&#xF1;o medio human&#xED;stico-cient&#xED;fica, al Colegio &quot;The British School&quot;, de Punta Arenas. Der&#xF3;gase el decreto supremo exento de Educaci&#xF3;n No. 1, de 1989, a contar de la vigencia del presente decreto. </div></div>", "i": 6053684}, {"t": "<div><div class=\"p\">Santiago, 30 de Abril de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6053685}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "77 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-77 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 77, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-03-31", "doble_articulado": false, "id_norma": "78927", "numero_fuente": "34269", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-05-18", "vigencias": [{"desde": "1992-05-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-05-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-05-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresa