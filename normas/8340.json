{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; FISCALIA </div></div>", "i": 5888565}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto M.O.P. N&#xB0; 54, de 28 de Marzo de 1991, se expropiaron los Lotes N&#xB0;s. 2 y 8, superficie 3.676 m2. y 1.952 m2, roles de aval&#xFA;o N&#xB0;s. 270-19 y 271-148, respectivamente, Comuna de Quintero, para la obra Camino Quintero-Conc&#xF3;n, Acceso Sur a Quintero, y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietario Felipe Urenda Panadero y Germ&#xE1;n del Carmen Vicencio Vicencio, ascendente a las cantidades de $ 439.182.- para el Lote 2 y $ 357.524.- para el Lote 8.-</div><br></div>", "i": 5888566}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 5888567}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "54", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-54"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS"], "titulo_norma": "FISCALIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["QUINTERO", "INMUEBLE", "EXPROPIACION", "CAMINO PUBLICO", "CAMINO QUINTERO-CONCON", "ACCESO SUR QUINTERO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-03-28", "doble_articulado": false, "id_norma": "8340", "numero_fuente": "33957", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-05-02", "vigencias": [{"desde": "1991-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1991-05-02", "fec