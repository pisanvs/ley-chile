{"html": [{"t": "<div><div class=\"p\">CREA CENTRO DE FORMACI&#xD3;N E INVESTIGACI&#xD3;N TRIBUTARIA DEL SERVICIO DE IMPUESTOS INTERNOS</div></div>", "i": 9847371}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n del Servicio de Impuestos Internos N&#xBA; 108, del 3 de noviembre de 2017, que establece:</div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Crea el Centro de Formaci&#xF3;n e Investigaci&#xF3;n Tributaria del Servicio de Impuestos Internos, define objetivos y forma de funcionamiento.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2017.</div></div>", "i": 9847372}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "108", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-108"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "CREA CENTRO DE FORMACIÓN E INVESTIGACIÓN TRIBUTARIA DEL SERVICIO DE IMPUESTOS INTERNOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1299230; NORMA SIN PROMULGACIÓN; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-11-03", "doble_articulado": false, "id_norma": "1110319", "numero_fuente": "41903", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-11-09", "vigencias": [{"desde": "2017-11-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-11-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-11