{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEY:</div><br><br></div>", "i": 7168402}, {"t": "<div><div class=\"p\"> &quot;Art&#xED;culo 1.o Desc&#xE1;rguense en las siguientes sumas los &#xED;tem que se indican del Presupuesto de Marina del presente a&#xF1;o:</div><div class=\"p\"> Cap&#xED;tulo XVIII, &#xED;tem 493. $ 20,000 Cap&#xED;tulo XVIII, &#xED;tem 498.&nbsp;  20,000 </div></div>", "i": 7168403}, {"t": "<div><div class=\"p\"> Art. 2.o Aum&#xE9;ntase en la siguiente suma el &#xED;tem que se indica:</div><div class=\"p\"> Cap&#xED;tulo XV, &#xED;tem 409.. $ 40,000 </div></div>", "i": 7168404}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta y uno de Diciembre de mil novecientos veintisiete.- Carlos Ib&#xE1;&#xF1;ez del Campo.- C.</div><div class=\"p\">O. Frodden.</div><br></div>", "i": 7168405}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4243", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4243"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1928", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1927-12-31", "doble_articulado": false, "id_norma": "24598", "numero_fuente": "14990", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-03", "vigencias": [{"desde": "1928-02-03", "hasta"