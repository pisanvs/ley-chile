{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6178058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.418, de 31 de mayo de 1999 se complement&#xF3; el decreto MOP N&#xBA; 44 de 25 de enero de 1999, agreg&#xE1;ndose en el N&#xBA; 4 despu&#xE9;s de &apos;&apos;14 de mayo de 1998&apos;&apos; la oraci&#xF3;n: modificada por la resoluci&#xF3;n D.G.O.P. N&#xBA; 1041 de 14 de abril de 1999, y se rectific&#xF3; el N&#xBA; 3 del referido decreto en lo que se refiere&nbsp; al rol de aval&#xFA;o del lote N&#xBA; 18, que es 6144-24 y no 6144-2, por lo que el nombre del propietario de los lotes 18 y 19 debe ser Leasing Andino SA y no Soc. Inmob. Inver Golan Ltda. como se indica en dicho decreto.-</div><br></div>", "i": 6178059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6178060}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1418", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1418"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-31", "doble_articulado": false, "id_norma": "139298", "numero_fuente": "36413", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-07-15", "vigencias": [{"desde": "1999-07-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-07-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-07-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JR