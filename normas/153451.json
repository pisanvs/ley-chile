{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON PEDRO SILVA SANTANA PARA INICIAR ACTIVIDADES PESQUERAS </div></div>", "i": 7259868}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 894 de 10 de Agosto de 1987 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Pedro Silva Santana, R.U.N. No. 4.758.823-5 de Santiago, domiciliado en Avenida General Bustamante No. 34, 4&#xB0; piso, Santiago, para iniciar actividades pesqueras de extracci&#xF3;n con la embarcaci&#xF3;n &quot;Constanza&quot; en las Regiones III a IX de los siguientes recursos hidrobiol&#xF3;gicos: Albacora o pez espada, Bacalao, Congrio dorado, Congrio negro y At&#xFA;n aleta larga.- </div></div>", "i": 7259869}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Roberto Cabezas Bello, Subsecretario de Pesca. </div></div>", "i": 7259870}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "894", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-894"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A DON PEDRO SILVA SANTANA PARA INICIAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-08-10", "doble_articulado": false, "id_norma": "153451", "numero_fuente": "32867", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-09-09", "vigencias": [{"desde": "1987-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-09-09