{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 317 DE 1990 </div></div>", "i": 6246841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 317 de 21 de noviembre de 1990 se ha aprobado, a la Escuela Particular No. 17, Hogar de Rehabilitaci&#xF3;n &quot;Don Orione&quot;, Alto Jahuel, Buin, de la Regi&#xF3;n Metropolitana, a contar del a&#xF1;o escolar 1991 programa de estudio para el nivel laboral destinado a proporcionar aprendizajes laborales a alumnas con retardo mental, de acuerdo a los objetivos que se indican para cada curso taller, &#xE1;rea y especialidad.</div><br></div>", "i": 6246842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br><br></div>", "i": 6246843}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "317 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-317 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 317 DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-11-21", "doble_articulado": false, "id_norma": "159878", "numero_fuente": "33858", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-01-03", "vigencias": [{"desde": "1991-01-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-01-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_i