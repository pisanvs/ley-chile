{"html": [{"t": "<div><div class=\"p\">AUTORIZA A SOCIEDAD GARCIA Y MIRANDA Y PE&#xD1;A LIMITADA &quot;ALMAR LIMITADA&quot; PARA DESARROLLAR ACTIVIDADES PESQUERAS </div><br></div>", "i": 6341986}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 253 de 13 de Marzo de 1986 de la Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a la Sociedad Garc&#xED;a, Miranda y Pe&#xF1;a Limitada Almar Limitada, domiciliaria en Santiago, para instalar y operar un cultivo de alga Gracilaria sp., en un sector de Puerto Aldea, Bah&#xED;a de Tongoy, Comuna de Coquimbo, Provincia de Elqui, en un &#xE1;rea de 120.000 m2.</div><br></div>", "i": 6341987}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de Marzo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6341988}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "253", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-253"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A SOCIEDAD GARCIA Y MIRANDA Y PEÑA LIMITADA ALMAR LIMITADA PARA DESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-03-13", "fecha_derogacion": "1989-05-04", "doble_articulado": false, "id_norma": "187435", "numero_fuente": "32433", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-03-27", "vigencias": [{"desde": "1989-05-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-03-27", "hasta": "1989-05-03", "tipo_versio