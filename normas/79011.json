{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309462}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 305, de 06 de Abril de 1992, de esta Subsecretaria de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se rectifica el numeral segundo de la Resoluci&#xF3;n No. 104 de 1992, de esta Subsecretar&#xED;a que autoriz&#xF3; a PESCA CHILE S.A., RUT No. 95.023.000-2 domiciliada en Santiago calle Estado No. 10, oficina 801, para ampliar actividades pesqueras de transformaci&#xF3;n, en el sentido que donde dice &quot;...Salm&#xF3;n com&#xFA;n Clupea bentincki&quot; debe decir &quot;... Sardina com&#xFA;n Clupea bentincki&quot;. </div></div>", "i": 8309463}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 06 de Abril de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8309464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "305", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-305"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-04-06", "doble_articulado": false, "id_norma": "79011", "numero_fuente": "34243", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-04-13", "vigencias": [{"desde": "1992-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-04-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-04-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_par