{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9440024}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA; 230, de 15 de abril de 2014, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1051958&amp;idParte=0&amp;idVersion=\">Decreto Exento MOP. N&#xBA;845, de 29 de mayo de 2013</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xBA;122, expropiado con motivo de la obra: &quot;Camino Reposici&#xF3;n Ruta 215-CH, Sector Bifurcaci&#xF3;n Aeropuerto Carlos Hott - Cruce Las Lumas, Tramo Km. 3,99292 al Km. 21,80000&quot;, Comuna y Provincia de Osorno. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijada mediante tasaci&#xF3;n de 28 de febrero de 2012, en la suma de $7.601.000, para el lote N&#xBA;122.</div></div>", "i": 9440025}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9440026}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "230 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-230 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-04-15", "doble_articulado": false, "id_norma": "1061827", "numero_fuente": "40846", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-05-02", "vigenc