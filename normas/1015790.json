{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 71, DE 1982</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 768 exenta.- Santiago, 5 de julio de 2010.- Vistos: Lo dispuesto en el art. 11 del decreto ley N&#xBA; 2.974 de 1979; la Ley N&#xBA; 18.910, Org&#xE1;nica de INDAP, modificada por la ley N&#xBA; 19.213,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div></div>", "i": 8955075}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la resoluci&#xF3;n N&#xBA; 71, de 17 de mayo de 1982, sobre la designaci&#xF3;n de Receptor Judicial, XI Regi&#xF3;n, modificada por resoluci&#xF3;n N&#xBA; 53, de 17 de mayo de 1988, en la siguiente forma:</div><br><div class=\"p\">-&nbsp; &nbsp; Se elimina al se&#xF1;or Mois&#xE9;s Espinoza Arriagada</div><div class=\"p\">-&nbsp; &nbsp; Se designa como Receptor Judicial al siguiente funcionario:</div><div class=\"p\">-&nbsp; &nbsp; Jorge Eduardo Rebolledo Palacios RUT 6.398.655-0</div><br></div>", "i": 8955076}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Ricardo Arizt&#xED;a de Castro, Director Nacional.</div><br></div>", "i": 8955077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "768 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-768 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO", "DIRECCIÓN NACIONAL"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 71, DE 1982", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-07-05", "doble_articulado": false, "id_norma": "1015790", "numero_fuente": "39724", "tipo_version": "3", "t