{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISORES ELECTRONICOS </div></div>", "i": 6546943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 113, de 28 de octubre de 2005, que autoriza a contribuyentes como emisores electr&#xF3;nicos.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisores de documentos tributarios electr&#xF3;nicos a los RUT 83.614.800-2, RUT 82.983.100-7, RUT 93.698.000-7, RUT 9.910.699-9, RUT 61.702.000-9 y RUT 50.143.670-4 a contar del mes de noviembre de 2005. En la oficina virtual del SII en Internet se podr&#xE1;n consultar los documentos que los contribuyentes est&#xE1;n autorizados a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de octubre de 2005.</div><br></div>", "i": 6546944}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "113 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-113 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISORES ELECTRONICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "EMISORES ELECTRONICOS", "AUTORIZACION", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-10-28", "doble_articulado": false, "id_norma": "243653", "numero_fuente": "38302", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-03", "vigencias": [{"desde": "2005-11-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-11-03", "fecha_version": "2005-11-03", "fecha_actualizacion_texto": "2005-11-03", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6546943}, {"n": "Artículo", "i": 6546944, "t": 6}]}