{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6590395}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.797 de 10 de octubre de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a JUAN ISAIAS ZULETA BRITO, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Cardones kil&#xF3;metro 800, Copiap&#xF3;, III Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Picado de algas los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6590396}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de octubre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6590397}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2797 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2797 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-10", "doble_articulado": false, "id_norma": "255444", "numero_fuente": "38621", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-23", "vigencias": [{"desde": "2006-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-11-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-11-23", "fecha_version": "2