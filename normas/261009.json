{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 263 EXENTO, DE 2004 </div></div>", "i": 8432253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento de Educaci&#xF3;n N&#xBA;263, de 27 de abril de 2004, se ha modificado, a partir del a&#xF1;o escolar 2004, el decreto exento de Educaci&#xF3;n N&#xBA;271 de 1997 que aprob&#xF3; plan y programas especiales de estudio para 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica al &quot;Colegio Brit&#xE1;nico St. Margaret&apos;s&quot; de Vi&#xF1;a del Mar, en el sentido de sustituir su plan de estudio por el que se indica en el presente decreto.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los Subsectores de Lenguaje y Comunicaci&#xF3;n y Educaci&#xF3;n Matem&#xE1;tica para 1&#xBA; a 4&#xBA; de Ense&#xF1;anza B&#xE1;sica. </div></div>", "i": 8432254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de junio de 2004.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n. </div></div>", "i": 8432255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "263 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-263 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 263 EXENTO, DE 2004", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-27", "doble_articulado": false, "id_norma": "261009", "numero_fuente": "38768", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-05-22", "vigencias": [{"desde": "2007-05-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "20