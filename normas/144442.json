{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA </div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 83.- Santiago, 21 de Julio de 1987.- Vistos: Lo dispuesto en el art&#xED;culo 4&#xB0; del Decreto Ley No. 2.974 de 1979,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br><br></div>", "i": 8964106}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase como Ministros de Fe para actuar en las localidades de la I y II Regi&#xF3;n en que no haya Notario ni Oficiales del Registro Civil, a los funcionarios del Instituto de Desarrollo Agropecuario, se&#xF1;ores:</div><div class=\"p\">- Ra&#xFA;l Donoso Fuentes</div><div class=\"p\">- Ledi Gonz&#xE1;lez Astorga</div><div class=\"p\">- ELIMINADO<span class=\"n\" id=\"n_0\">RES 73, AGRICULTURA<br>D.O. 06.05.2000</span></div><br></div>", "i": 8964107}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Sergio Retamal Iglesias, Vicepresidente Ejecutivo.</div><br></div>", "i": 8964108}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": true, "tipos_numeros": [{"tipo": "3", "numero": "83", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-83"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO MINISTROS DE FE A FUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-07-21", "doble_articulado": false, "id_norma": "144442", "numero_fuente": "32868", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-09-10", "vigencias": [{"desde": "2000-05-06", "hasta": "", "tipo_version": "2",