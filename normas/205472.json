{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6405820}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.760, de 29 de noviembre de 2002, de esta Subsecretar&#xED;a, modif&#xED;case la resoluci&#xF3;n N&#xBA; 2.609 de 2002, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Monitoreo de la pesquer&#xED;a artesanal de Merluza com&#xFA;n en las caletas artesanales del sector centro de la VIII Regi&#xF3;n&quot;, en el sentido de aumentar en 100 toneladas la captura autorizada para el cumplimiento del objetivo de la investigaci&#xF3;n, las que acrecer&#xE1;n la fracci&#xF3;n autorizada para el mes de diciembre.</div><br></div>", "i": 6405821}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de noviembre de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6405822}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2760", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2760"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-11-29", "doble_articulado": false, "id_norma": "205472", "numero_fuente": "37433", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-12-13", "vigencias": [{"desde": "2002-12-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-12-13", "fin_vigencia":