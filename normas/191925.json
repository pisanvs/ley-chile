{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA COJINOVA LTDA.</div><br><br></div>", "i": 6358486}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/N&#xBA; Ex. 1.782, de fecha 31 de agosto de 2001, revoca a Pesquera Cojinova Ltda., RUT. N&#xBA; 79.821.010-6, a partir del d&#xED;a 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, la calidad de agente retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las adquisiciones de Especies Hidrobiol&#xF3;gicas, de acuerdo a la facultad establecida en el dispositivo N&#xBA; 18&#xBA; de la resoluci&#xF3;n Ex. N&#xBA; 3.311/2000, de la Direcci&#xF3;n Nacional. </div></div>", "i": 6358487}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 31 de agosto de 2001.- Sergio Flores Guti&#xE9;rrez, Director Regional.</div><br></div>", "i": 6358488}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1782 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-1782 EXENTA"}, {"tipo": "3", "numero": "DRE-081782 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-081782 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A PESQUERA COJINOVA LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-08-31", "doble_articulado": false, "id_norma": "191925", "numero_fuente": "37117", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-22", "vigencia