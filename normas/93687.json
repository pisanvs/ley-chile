{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6095018}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 1.363 de 29 de diciembre de 1988, se adjudica a &quot;Planta de Revisi&#xF3;n T&#xE9;cnica Andaluc&#xED;a Sociedad An&#xF3;nima&quot; la concesi&#xF3;n para operar, por un plazo de cinco a&#xF1;os a contar del 01.01.89, un establecimiento ubicado en calle Jos&#xE9; Joaqu&#xED;n Aguirre N&#xB0; 849, de Conchal&#xED;, destinado a la revisi&#xF3;n t&#xE9;cnica y verificaci&#xF3;n de emisi&#xF3;n de contaminantes de buses y taxibuses cuyo &#xFA;ltimo d&#xED;gito de su placa patente &#xFA;nica sea impar, que presten servicio de transporte p&#xFA;blico en el Gran Santiago y de aqu&#xE9;llos cuyos servicios tengan origen o destino en esta ciudad, en la forma y condiciones que se se&#xF1;alan en el contrato que se aprueba.-</div><br><br></div>", "i": 6095019}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Manuel J. G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br><br></div>", "i": 6095020}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1363 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1363 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1988-12-29", "fecha_derogacion": "1992-09-02", "doble_articulado": false, "id_norma": "93687", "numero_fuente": "33261", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-01-02", "vigencias": [{"desde": "1992-09-02", "hasta": "", "tipo_version":