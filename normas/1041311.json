{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N ORDINARIA N&#xBA; 1687</div></div>", "i": 9269099}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile, en su sesi&#xF3;n ordinaria N&#xBA; 1687, celebrada el 21 de junio de 2012, adopt&#xF3; el siguiente Acuerdo:</div><br><div class=\"p\">1687-04-120621 &#x2013; Tasa de inter&#xE9;s para pago diferido de derechos de aduana.</div><br><div class=\"p\">&nbsp; &nbsp;  En conformidad con lo establecido en la letra c) del art&#xED;culo 10 de la ley N&#xB0; 18.634, la tasa de inter&#xE9;s que devengar&#xE1;n las cuotas de pago diferido de derechos de aduana durante el semestre que concluye el 31 de diciembre de 2012, ser&#xE1; de 6% anual, en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.</div></div>", "i": 9269100}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 21 de junio de 2012.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9269101}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1687", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1687"}, {"tipo": "5", "numero": "1687-04", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1687-04"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN ORDINARIA Nº 1687", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-21", "doble_articulado": false, "id_norma": "1041311", "numero_fuente": "40297", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-26", "vigencias": [{"desde": "2012-06-26", "hasta": ""