{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8553527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;1.227, de 3 de abril de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a CHILESAN SOCIEDAD AN&#xD3;NIMA para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en Lote 3, Quilquel s/n, Dalcahue, Chilo&#xE9;, X Regi&#xF3;n, para elaborar en l&#xED;neas de proceso Cocido, Fresco Enfriado, Fresco Refrigerado, Congelado, Conserva, Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div></div>", "i": 8553528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de abril de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8553529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1227 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-1227 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-04-03", "doble_articulado": false, "id_norma": "1001377", "numero_fuente": "39343", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-04-22", "vigencias": [{"desde": "2009-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-04-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-04-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingre