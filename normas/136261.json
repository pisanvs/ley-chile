{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,184.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br><br><br></div>", "i": 6168119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Se concede, por gracia a la viuda e hijos lej&#xED;timos del coronel graduado de Ej&#xE9;rcito don Jorje Wood Arellano, el derecho a una pension anual de montep&#xED;o de mil ochocientos pesos ($ 1,800) en vez de la que perciben actualmente.</div><div class=\"p\">&nbsp; &nbsp;  Esta pension rejir&#xE1; por la lei jeneral de montep&#xED;o militar&quot;.</div><br></div>", "i": 6168120}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintinueve de marzo de mil novecientos nueve.- Pedro Montt.- D. Za&#xF1;artu.</div><br></div>", "i": 6168121}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2184", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2184"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["LA PRESENTE LEY HA SIDO PUBLICADA EN EL D.OFICIAL CON EL N° 2134"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-03-29", "doble_articulado": false, "id_norma": "136261", "numero_fuente": "9367", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-04-21", "vigencias": [{"desde": "1909-04-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v