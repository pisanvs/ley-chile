{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9296381}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP Exento N&#xBA;1791 de 30 de agosto de 2012, de conformidad lo dispuesto en el Art. 105 del DFL MOP. N&#xBA;850 de 1997, se expropi&#xF3; el lote de terreno N&#xBA;39, superficie 11.998 m2, rol de Aval&#xFA;o N&#xBA;179-1, comuna de San Vicente, para la obra &quot;CONSTRUCCI&#xD3;N PUENTE EL TAMBO EN RUTA H &#x2013; 806, COMUNAS DE SAN VICENTE Y MALLOA&quot;. La Comisi&#xF3;n de peritos, integrada por NORMAN CALDER&#xD3;N PONTIGGIA OSCAR NAVEA MU&#xD1;OZ Y MAR&#xCD;A ISABEL DE JES&#xDA;S R&#xCD;OS MARCUELLO, fij&#xF3; el valor de tasaci&#xF3;n con fecha 30 de septiembre de 2011, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietario JORGE ROM&#xC1;N C&#xC1;DIZ, en la cantidad de $77.587.630.-, suma que se pagar&#xE1; al contado.</div></div>", "i": 9296383}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9296385}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1791 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1791 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-08-30", "doble_articulado": false, "id_norma": "1043959", "numero_fuente": "40364", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-09-15", "vigencias": [{"desde": "2012-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-09-15", "fin_vigencia": ""}, "vigencias_