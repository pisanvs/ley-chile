{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension Lei n&#xFA;m. 96.- Santiago, a 6 de Setiembre 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese por gracia al ex-soldado don Ramon Gonz&#xE1;lez el goce de una pension vitalicia de ciento cuarenta i cuatro pesos.</div><br><br></div>", "i": 5946761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Manuel Villamil Blanco.</div><br></div>", "i": 5946762}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "96", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-96"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["RAMON GONZALES", "PENSION VITALICIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-09-06", "doble_articulado": false, "id_norma": "21963", "numero_fuente": "4616", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-09-09", "vigencias": [{"desde": "1893-09-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-09-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-09-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-01-07", "fecha_version": "1893-09-09", "fecha_actualizaci