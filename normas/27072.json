{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N&#xB0; 10,475, DE 1952 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5971345}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Agr&#xE9;gase al art&#xED;culo 29&#xB0; de la ley N&#xB0; 10,475, de 8 de Septiembre de 1952, la siguiente frase final: &quot;y para los Operadores Cinematogr&#xE1;ficos&quot;. </div></div>", "i": 5971346}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, once de Octubre de mil novecientos cincuenta y seis.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Roberto Mu&#xF1;oz Urrutia.</div><br></div>", "i": 5971347}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "12203", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-12203"}], "organismos": ["MINISTERIO DE SALUD PÚBLICA Y PREVISIÓN SOCIAL"], "titulo_norma": "MODIFICA LA LEY N° 10,475, DE 1952", "fuente": "Diario Oficial", "resumenes": [], "materias": ["Operadores Cinematográficos", "Ley no. 10.475, Art. 29"], "terminos_libres": ["OPERADORES CINEMATOGRAFICOS", "JUBILACION", "CAJA PREVISION EMPLEADOS PARTICULARES", "TIEMPO COMPUTABLE", "REDUCCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1956-10-11", "doble_articulado": false, "id_norma": "27072", "numero_fuente": "23580", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1956-10-23", "vigencias": [{"desde": "1956-10-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_