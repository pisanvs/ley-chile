{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE PUENTE ALTO </div></div>", "i": 6515942}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta N&#xBA; 352 del 27 de enero de 2005, conforme art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, determin&#xF3; derechos de aprovechamiento de aguas de la Parcela N&#xBA; 1 de la Colonia &apos;&apos;Fernando Bozo Morand&#xE9;&apos;&apos;, comuna de Puente Alto, provincia de Cordillera, Regi&#xF3;n Metropolitana, estableciendo que estos derechos de aprovechamiento se reciben por el canal de Mena, derivado del canal Eyzaguirre, de la Asociaci&#xF3;n de Canalistas Sociedad del Canal de Maipo y son de car&#xE1;cter consuntivo, de ejercicio permanente y continuos.</div><br><br></div>", "i": 6515943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13&#xBA; ley N&#xBA; 18.377.- Director Nacional.</div><br></div>", "i": 6515944}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "352", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-352"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE PUENTE ALTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS DE APROVECHAMIENTO DE AGUAS", "PUENTE ALTO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-01-27", "doble_articulado": false, "id_norma": "235489", "numero_fuente": "38087", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-02-15", "vigencias": [{"desde": "2005-02-15", "hasta": "", "tipo_version": "3", "t