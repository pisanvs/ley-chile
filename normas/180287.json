{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6316693}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;5.021, de fecha 31 de octubre de 2000, se expropiaron los lotes de terreno N&#xBA;s. 81 y 83, superficies 33,0 m&#xB2; y 70,0 m&#xB2;, respectivamente, rol de aval&#xFA;o 112-59, comuna de Corral, para la obra &apos;&apos;Camino Longitudinal Costero Sur, Sector El Morro-Chaihuin II, Km.</div><div class=\"p\">15,755 a Km. 27,017&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Mar&#xED;a Ang&#xE9;lica Obando Ram&#xED;rez, ascendente a la cantidad de $3.281.083.</div><br></div>", "i": 6316694}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6316695}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5021", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-5021"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-31", "doble_articulado": false, "id_norma": "180287", "numero_fuente": "36862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-15", "vigencias": [{"desde": "2001-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-01-15", "fecha_version": "2001-01-15", "fecha_actualizacion_texto": "2001