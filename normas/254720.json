{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7333651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.959, de 23 de octubre de 2006, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones N&#xBA;2.019 y N&#xBA;2.543, ambas de 2001, N&#xBA;2.275 de 2004 y N&#xBA;638 de 2005, todas de esta Subsecretar&#xED;a, que autorizaron a BUENA PESCA S.A., para desarrollar actividades extractivas con la nave &quot;Nicomar&quot;, en virtud de lo dispuesto en el art&#xED;culo 143 letra d) de la Ley General de Pesca y Acuicultura y lo informado en Informe T&#xE9;cnico citado en Visto.</div><br><br></div>", "i": 7333652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de octubre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 7333653}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2959 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2959 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BUENA PESCA S.A", "ACTIVIDADES PESQUERAS", "NAVE NICOMAR", "CADUCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-23", "doble_articulado": false, "id_norma": "254720", "numero_fuente": "38602", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-10-31", "vigencias": [{"desde": "2006-10-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-10-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-10-31", "fin_vigencia": "", "t