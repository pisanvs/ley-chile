{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Enfermedades infecciosas Lei n&#xFA;m. 1,456.- Valparaiso, a 26 de Febrero de 1901.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 9042108}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para invertir hasta la suma de cien mil pesos, en adoptar medidas destinadas a combatir enfermedades infecciosas.</div><br></div>", "i": 9042109}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ E.- Juan Antonio Orrego.</div><br></div>", "i": 9042110}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1456", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1456"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "ENFERMEDADES INFECCIOSAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ENFERMEDADES INFECCIOSAS", "PRESIDENTE REPUBLICA", "INVERSION", "AUTORIZACION", "PROFILAXIS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1901-02-26", "doble_articulado": false, "id_norma": "22664", "numero_fuente": "6818", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1901-02-14", "vigencias": [{"desde": "1901-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1901-02-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1901-02-14", "fin_vigencia": "", "ti