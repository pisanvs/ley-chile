{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6149055}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decretos MOP N&#xB0;s. 2.064 y N&#xB0;2.066, de 30 de octubre de 1998, se expropiaron los lotes de terreno N&#xB0;s. 6, 12, 27 y 29, superficies 495, 167, 124 y 524 m2. respectivamente, roles de aval&#xFA;o 212-12, 210-52, 213-14 y 211-1, comuna de Rengo, para la obra Mejoramiento Ruta H-577, sector Rengo-Rinconada de Malambo y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Zunilda Ram&#xED;rez Allende y otros, Suc. Julia Gonz&#xE1;lez Rojas, Zunilda Orostegui Vivanco y Sucesi&#xF3;n Enrique Arredondo Portillo, ascendentes a las cantidades de $2.118.438.- para el lote 6, $523.398.- para el lote 12, $1.155.502.- para el lote 27 y $2.072.813.- para el lote 29.-</div><br></div>", "i": 6149056}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6149057}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2066", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2066"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-10-30", "doble_articulado": false, "id_norma": "130082", "numero_fuente": "36264", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-01-15", "vigencias": [{"desde": "1999-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-01-15", "fin_vigencia": "", "tipo_version": "3