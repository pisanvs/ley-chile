{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZO QUE INDICA</div><br><br></div>", "i": 8314020}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 920, de 30 de Julio de 1990, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 3 meses a contar de la fecha de publicaci&#xF3;n del extracto en el Diario Oficial de la presente resoluci&#xF3;n, el plazo fijado a Concar S.A., R.U.T.</div><div class=\"p\">No. 96.514.850-7, domiciliada en Valpara&#xED;so, en el numeral 1&#xB0; de la resoluci&#xF3;n No. 202, de 1990, de esta Subsecretar&#xED;a, para iniciar actividades pesqueras extractivas con la embarcaci&#xF3;n &quot;Mar&#xED;a Tamara&quot;, en raz&#xF3;n de haberse acreditado la ocurrencia de una causal de fuerza mayor.</div><br></div>", "i": 8314021}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 30 de Julio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314022}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "920", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-920"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA PLAZO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-30", "doble_articulado": false, "id_norma": "82681", "numero_fuente": "33742", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-10", "vigencias": [{"desde": "1990-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-10", "fin_vigencia": ""}, "vigencias_version_n