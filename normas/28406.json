{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA CALLE COMERCIO DE LA COMUNA DE CHANCO</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8282709}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- C&#xE1;mbiese el nombre de la calle &quot;Comercio&quot; de la comuna de Chanco, la que se denominar&#xE1; en el futuro calle &quot;Abd&#xF3;n Fuentealba Canales&quot;. </div></div>", "i": 8282710}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintiocho de Septiembre de mil novecientos sesenta y cinco.- EDUARDO FREI MONTALVA.- Bernardo Leighton G.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a U. para su conocimiento.- Dios gue. a U.- Juan Hamilton Depassier, Subsecretario del Interior.</div><br></div>", "i": 8282711}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "16337", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-16337"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA CALLE COMERCIO DE LA COMUNA DE\nCHANCO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE", "COMERCIO", "CHANCO", "ABDON FUENTEALBA CANALES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1965-09-28", "doble_articulado": false, "id_norma": "28406", "numero_fuente": "26259", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1965-10-07", "vigencias": [{"desde": "1965-10-07