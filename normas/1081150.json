{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9633396}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional del SII, por resoluci&#xF3;n Ex. N&#xBA; 77315048827 de fecha 18.08.2015, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=206978&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 1 del 03.01.2003</a>, que excepcion&#xF3; del r&#xE9;gimen de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de venta de madera, a contar de la fecha de la publicaci&#xF3;n de su extracto en el Diario Oficial, al contribuyente Sociedad Agr&#xED;cola y Forestal Imperial Limitada, RUT N&#xBA; 77.625.270-0, conforme a lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 4.916 de fecha 31.10.2000, de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos.</div><br></div>", "i": 9633397, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Christian Soto Torres, Director Nacional.</div></div>", "i": 9633398}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77315048827 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-77315048827 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "IdDO 940258"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-08-18", "doble_articulado": false, "id_norma": "1081150", "numero_fuente": "41248", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacio