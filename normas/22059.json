{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MONTEPIO Lei n&#xFA;m. 201.- Santiago, a 25 de Agosto de 1894.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se concede por gracia a do&#xF1;a Margarita Arteaga Alemparte la pension de montep&#xED;o que se&#xF1;ala la lei de 22 de Setiembre de 1890, a la hija soltera de un jeneral de division.</div><div class=\"p\">&nbsp; &nbsp; Esta pension es incompatible con el goce de cualquiera otra asignacion fiscal.</div><br><br></div>", "i": 5947134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.-S. Aldunate B.</div><br></div>", "i": 5947135}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "201", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-201"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "MONTEPIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MARGARITA ARTEAGA ALEMPARTE", "HIJA SOLTERA", "MONTEPIO", "MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-25", "doble_articulado": false, "id_norma": "22059", "numero_fuente": "4909", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-09-05", "vigencias": [{"desde": "1894-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"in