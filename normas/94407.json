{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 207, DE 1988 </div></div>", "i": 6096996}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 207 de 29 de diciembre de 1988 se ha aprobado, a partir del a&#xF1;o 1989, un plan especial de estudio para el Colegio Pedro de Valdivia, de Concepci&#xF3;n, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, para la Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas especiales para las asignaturas que se indican en el presente decreto. </div></div>", "i": 6096997}, {"t": "<div><div class=\"p\">Santiago, 20 de Enero de 1989.- Paulina Dittborn Cordua, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6096998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "207 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-207 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 207, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-12-29", "doble_articulado": false, "id_norma": "94407", "numero_fuente": "33295", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-02-10", "vigencias": [{"desde": "1989-02-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-02-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-02-10", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-03-06", "fecha_version": "1989-02-10", "fech