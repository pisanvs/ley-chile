{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 1,974.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se declara que la pension de doscientos pesos mensuales que asigna la lei n&#xFA;mero 1,085, de 14 de setiembre de 1898, a la viuda del teniente coronel don Jos&#xE9; Mar&#xED;a Marchant, debe entenderse concedida en favor de la viuda e hijas solteras del espresado militar, quienes disfrutar&#xE1;n de ella en conformidad a la lei jeneral de montep&#xED;o.</div><br></div>", "i": 6168024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I, por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, treinta i uno de julio de mil novecientos siete.- Pedro Montt.- Alejandro Lira.</div><br></div>", "i": 6168025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1974", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1974"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1907-07-31", "doble_articulado": false, "id_norma": "136236", "numero_fuente": "8864", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1907-08-01", "vigencias": [{"desde": "1907-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1907-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [