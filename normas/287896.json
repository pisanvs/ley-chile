{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 9.124 EXENTA,DE 2008</div><br></div>", "i": 8155981}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 9.124, de 23 de diciembre de 2008, se han aprobado planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de Ense&#xF1;anza Media, al Colegio Suizo, comuna de &#xD1;u&#xF1;oa, de Santiago, y deroga resoluciones exentas que se indican.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los Subsectores del Plan Com&#xFA;n y de los Subsectores Electivos que se indican en la presente resoluci&#xF3;n.</div></div>", "i": 8155982}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de enero de 2009.- Rosita Puga Hamilton, Jefa Divisi&#xF3;n de Educaci&#xF3;n General.</div></div>", "i": 8155983}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "9124 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-9124 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-23", "doble_articulado": false, "id_norma": "287896", "numero_fuente": "39306", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-03-07", "vigencias": [{"desde": "2009-03-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-03-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2009-03-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIF