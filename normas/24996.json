{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5961241}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Red&#xFA;cese en la suma de trescientos mil pesos ($ 300,000) el &#xED;tem E. 1103-a del Presupuesto Extraordinario del presente a&#xF1;o, que consulta cuatrocientos veinte mil pesos ($ 420,000) para la terminaci&#xF3;n del mercado pesquero de Valpara&#xED;so. </div></div>", "i": 5961242}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Establ&#xE9;cese un nuevo &#xED;tem en el mismo Presupuesto, a continuaci&#xF3;n del rubro E. 1102-a, con la siguiente glosa:</div><div class=\"p\">E. 1102-b) Para la realizaci&#xF3;n de las</div><div class=\"p\">&nbsp;  faenas de lavaderos de oro_____________&nbsp; $ 300,000.-</div><br></div>", "i": 5961243}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 3.o La presente ley regir&#xE1; desde su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 5961244}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, he tenido a bien aprobarlo y sancionarlo, por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diecisiete de Diciembre de mil novecientos treinta y uno.- JUAN E. MONTERO.- Herm&#xE1;n Echeverr&#xED;a. </div></div>", "i": 5961245}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "5013", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-5013"}], "organismos": ["MINISTERIO DE FOMENTO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GENERAL NACION", "1931", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1931-12-17", "doble_articulado": false, "id_norma": "24996", "numero_fuente": "16154", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1931-12-21", "vigencias": [{"desde": "1931-12-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1931-12-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1931-12-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "fecha_version": "1931-12-21", "fecha_actualizacion_texto": "1931-12-21", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 5961241}, {"n": "Artículo 1", "i": 5961242, "t": 6}, {"n": "Artículo 2", "i": 5961243, "t": 6}, {"n": "Artículo 3", "i": 5961244, "t": 6}, {"n": "Promulgación", "i": 5961245}]}