{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;3.833 EXENTO, DE 2008</div></div>", "i": 8538116}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;3.833, de fecha 22 de diciembre de 2008, del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones introducidas al plan y programas de estudio de la carrera de T&#xE9;cnico en Veterinaria del Centro de Formaci&#xF3;n T&#xE9;cnica MAGNOS, que se encuentran anexas y forman parte del presente decreto. Modif&#xED;case, en consecuencia, el decreto exento de Educaci&#xF3;n N&#xBA;332, de fecha 17 de enero de 2007, en el sentido de incorporar dichas adecuaciones.</div><div class=\"p\">Las adecuaciones que se aprueban mediante este decreto, podr&#xE1;n aplicarse a contar del a&#xF1;o 2009.</div></div>", "i": 8538117}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de abril de 2009.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n.</div></div>", "i": 8538118}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3833 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3833 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº3.833 EXENTO, DE 2008", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2008-12-22", "fecha_derogacion": "2017-08-31", "doble_articulado": false, "id_norma": "1001284", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2009-04-17", "vigencias": [{"desde": "2017-08-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2009-04-17", "hasta": "2017-08-30", "tipo_version": "0", "tipo_version_s": "T