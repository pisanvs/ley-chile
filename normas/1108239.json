{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xB0; 189 EXENTA, DE 2016, QUE ABRE PROCESO OTORGAMIENTO PERMISO OPERACI&#xD3;N PARA UN CASINO DE JUEGO EN COMUNA DE IQUIQUE</div></div>", "i": 9835327}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 435, de 21 de septiembre de 2017, Superintendencia de Casinos de Juego modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1090480&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 189, de 2016</a>, que declara abierto proceso otorgamiento permiso operaci&#xF3;n para un casino de juego en comuna de Iquique. Se fija nueva fecha de presentaci&#xF3;n ofertas t&#xE9;cnicas y econ&#xF3;micas el 4 de octubre de 2017, a las 11:00 horas, en Hotel Gran Palace, ubicado en calle Hu&#xE9;rfanos N&#xBA; 1178, comuna de Santiago.- </div></div>", "i": 9835328}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Vivien Villagr&#xE1;n Acu&#xF1;a, Superintendenta de Casinos de Juego.</div></div>", "i": 9835329}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "435 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-435 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE CASINOS DE JUEGO"], "titulo_norma": "MODIFICA RESOLUCIÓN N° 189 EXENTA, DE 2016, QUE ABRE PROCESO OTORGAMIENTO PERMISO OPERACIÓN PARA UN CASINO DE JUEGO EN COMUNA DE IQUIQUE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1277183; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-09-21", "doble_articulado": false, "id_norma": "1108239", "numero_fuente": "41866", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-09-23", "vigencia