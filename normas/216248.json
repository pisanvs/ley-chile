{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CERTIFICADO</div><br></div>", "i": 6444979}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Certifico que por Resoluci&#xF3;n N&#xBA;. E -057, de fecha 22 de Julio de 1991, se aprob&#xF3; la reforma introducida a los estatutos de la Administradora de Fondos de Pensiones El Libertador S.A., acordada en la Junta General Extraordinaria de Accionistas de dicha sociedad, celebrada el d&#xED;a 23 de Abril de 1991, otorgada ante el Notario de Santiago, don Ra&#xFA;l Undurraga Laso.</div><br><div class=\"p\">EXTRACTO</div><br><div class=\"p\">&nbsp; &nbsp;  Se aumenta el capital social de $ 603.533.164 correspondiente a 693.115 sin valor nominal, a $ 1.306.132.432 dividido en 1.072.735 acciones sin valor nominal.</div><br></div>", "i": 6444980}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de Julio de 1991.</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp;  JULIO BUSTAMANTE JERALDO</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Superintendente</div><br><br></div>", "i": 6444981}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "57", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-57"}, {"tipo": "3", "numero": "E-057", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-E-057"}], "organismos": ["SUPERINTENDENCIA DE ADMINISTRADORAS DE FONDOS DE PENSIONES", "FISCALÍA"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-22", "doble_articulado": false, "id_norma": "216248", "numero_fuente": "34032", "tipo_version": "3", "tipo_version_s": "Ún