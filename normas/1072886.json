{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.733 EXENTA, DE 2014</div><div class=\"p\">&nbsp; </div></div>", "i": 9543476}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por la presente resoluci&#xF3;n exenta se han aprobado planes y programas especiales de estudio de 1&#xBA; a 4&#xBA; a&#xF1;o de educaci&#xF3;n media, al Colegio &quot;La Maisonnette&quot;, comuna de Vitacura, provincia de Santiago, Regi&#xF3;n Metropolitana y deroga <a href=\"https://www.leychile.cl/Navegar?idNorma=182682&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 615, de 2001</a> y sus modificaciones. Adem&#xE1;s, se aprueba programa de estudio del Sector de Teor&#xED;a y Conocimiento (Filosof&#xED;a) para 3&#xBA; y 4&#xBA; a&#xF1;o de Educaci&#xF3;n Media del Plan de Formaci&#xF3;n General y los programas de estudio del Programa de Diploma de Bachillerato Internacional para los mismos cursos, que se indican en la presente resoluci&#xF3;n exenta.</div><br></div>", "i": 9543477, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de diciembre de 2014.- Gonzalo Mu&#xF1;oz Stuardo, Jefe Divisi&#xF3;n Educaci&#xF3;n General.</div></div>", "i": 9543478}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8733 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8733 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.733 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-12-12", "doble_articulado": false, "id_norma": "1072886", "numer