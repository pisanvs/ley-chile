{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">AUTORIZA A INSTITUCI&#xD3;N SIN FINES DE LUCRO COMO RECEPTORA DE ALIMENTOS CUYA COMERCIALIZACI&#xD3;N SEA INVIABLE</div></div>", "i": 9393842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 104, del 17 de diciembre de 2013, que autoriza a instituci&#xF3;n sin fines de lucro como receptora en forma gratuita de alimentos, cuya comercializaci&#xF3;n sea inviable.</div><div class=\"p\">&nbsp; &nbsp;  La entidad autorizada al efecto corresponde a Rol &#xDA;nico Tributario N&#xBA; 65.073.235-9.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en el sitio web del Servicio de Impuestos Internos (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII en el mes de diciembre de 2013.</div></div>", "i": 9393843}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "104 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-104 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A INSTITUCIÓN SIN FINES DE LUCRO COMO RECEPTORA DE ALIMENTOS CUYA COMERCIALIZACIÓN SEA INVIABLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-12-17", "doble_articulado": false, "id_norma": "1057517", "numero_fuente": "40738", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-12-21", "vigencias": [{"desde": "2013-12-21", "hasta": "", "tipo_version