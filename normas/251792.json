{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br><br></div>", "i": 6577851}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.525 de 20 de julio de 2006 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n total, conforme D.L. N&#xBA;2.186 de 1978, del inmueble ubicado en Lautaro Sitio 152, Manzana 6, sector C, presunto Rol de Aval&#xFA;o N&#xBA;4034-152, comuna de Quinta Normal, aparente dominio de don Guillermo Cuminao Neculqueo. Comisi&#xF3;n integrada por peritos In&#xE9;s Ot&#xE1;rola Castillo, Arquitecto, Mario Zamorano Villablanca, Arquitecto y Miguel Fern&#xE1;ndez C&#xE1;diz, Constructor Civil. Seg&#xFA;n informe de 13 de junio de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $886.400.- pagadera al contado.</div><br></div>", "i": 6577852}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 6577853}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3525 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3525 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACION PARCIAL DE INMUEBLES QUE INDICA NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-20", "doble_articulado": false, "id_norma": "251792", "numero_fuente": "38528", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-08-01", "vigencias": [{"desde": "2006-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vige