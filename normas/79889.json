{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6056023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. N&#xBA; 952, de 30 de septiembre de 1997, se expropiaron los lotes de terreno N&#xBA;s. 19 y 47, superficies 898 m&#xB2; y 109 &#xB2;, roles de aval&#xFA;os 47-34 y 47-90, comuna de La Estrella, obra Camino L&#xED;mite Regional (Rapel) - Alcones I, sector Litueche-La Rosa y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Miguel Luis Y&#xE1;&#xF1;ez D&#xED;az y Luis Ernesto Cifra Huerta, ascendente a las cantidades de $806.210 para el lote N&#xBA; 19 y $674.928, para el lote N&#xBA; 47.</div><br></div>", "i": 6056024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6056025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "952", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-952"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "LA ESTRELLA", "SEXTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-30", "doble_articulado": false, "id_norma": "79889", "numero_fuente": "35930", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-12-01", "vigencias": [{"desde": "1997-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMR", "fecha_ingreso": "1997-12-16",