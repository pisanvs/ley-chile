{"html": [{"t": "<div><div class=\"p\">AUTORIZA A RECEPTOR ELECTRONICO </div></div>", "i": 7343915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 62 de 1&#xBA; de junio de 2007, que autoriza a organismo p&#xFA;blico como receptor electr&#xF3;nico. Se autoriza como receptor de documentos tributarios electr&#xF3;nicos, a contar del mes de junio de 2007, al organismo p&#xFA;blico RUT 71.537.200-2.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio de 2007.</div><br></div>", "i": 7343916}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "62 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-62 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA A RECEPTOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-01", "doble_articulado": false, "id_norma": "261486", "numero_fuente": "38782", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-06-07", "vigencias": [{"desde": "2007-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-06-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-06-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "