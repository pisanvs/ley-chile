{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6425420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 341 de fecha 31 de marzo del 2003, se expropiaron los lotes de terrenos N&#xBA;s 2, 10, 11, 12, 13, 14, 15 y 18, superficies 592,70, 1.065,30, 3.167,50, 2.143,50, 319,70, 26,60, 1.445,30, 66,50 m2 respectivamente, Rol de Aval&#xFA;o N&#xBA;s 137-391 y 137-140, comuna de Paine, Regi&#xF3;n Metropolitana para la obra &quot;Camino Sin Rol, Sector Peralillo - Abrantes, Tramo Km. 0,00000 al 6,03921&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Marta Rosa Silva Vergara, ascendente a la cantidad de $23.862.151. </div></div>", "i": 6425421}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6425422}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "341", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-341"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-03-31", "doble_articulado": false, "id_norma": "210801", "numero_fuente": "37573", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-06-02", "vigencias": [{"desde": "2003-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-06-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "DVG", "fecha