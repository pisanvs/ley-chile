{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N.o 9,664, RELACIONADA CON PRESTAMO A LA MUNICIPALIDAD DE ACHAO.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Reempl&#xE1;zase en el art&#xED;culo 2.o de la ley N.o 9,664, de 4 de Octubre de 1950, la expresi&#xF3;n &quot;8%&quot; por la siguiente &quot;10%&quot;.</div><br></div>", "i": 8279147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Carlos Torres H.</div><br></div>", "i": 8279148}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10991", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10991"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MODIFICA LA LEY N.o 9,664, RELACIONADA CON PRESTAMO\nA LA MUNICIPALIDAD DE ACHAO.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "LEY 9", "664"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-30", "doble_articulado": false, "id_norma": "26510", "numero_fuente": "22412", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-11-29", "vigencias": [{"desde": "1952-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-11-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"