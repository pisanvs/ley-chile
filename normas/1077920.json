{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.219 EXENTA, DE 2015</div></div>", "i": 9602711}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.219, de 22 de mayo de 2015, se establecen las condiciones espec&#xED;ficas de operaci&#xF3;n y de utilizaci&#xF3;n de v&#xED;as para los servicios de transporte p&#xFA;blico urbano remunerado de pasajeros mediante buses que se presten al interior de la zona F (Unidad de Negocio N&#xBA; 7), del Sistema de Transporte P&#xFA;blico de Pasajeros de la Ciudad de Santiago, a partir del 01 de junio de 2015. Texto &#xED;ntegro de la resoluci&#xF3;n exenta N&#xBA; 1.219, de 2015, se encuentra en la p&#xE1;gina web www.dtpm.cl.</div><br></div>", "i": 9602712}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Cristian Bowen Garfias, Ministro de Transportes y Telecomunicaciones (s).</div></div>", "i": 9602713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1219 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1219 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.219 EXENTA, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-05-22", "doble_articulado": false, "id_norma": "1077920", "numero_fuente": "41168", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-05-28", "vigencias": [{"desde": "2015-05-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-05-28", "fin_vigencia": ""}, "vigencias_version_norma": [{"