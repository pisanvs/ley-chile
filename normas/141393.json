{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ley n&#xFA;m. 3,430</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;mero 3,430 </div></div>", "i": 9051024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a do&#xF1;a Mar&#xED;a Teresa G. De las Heras, nieta del jeneral de la Independencia, don Juan Gregorio de las Heras, una pension mensual de cien pesos ($ 100), en vez de la que actualmente disfruta, que le fue concedida por la lei de 26 de octubre de 1898, y de la cual gozar&#xE1; con arreglo a la lei de montep&#xED;o militar&quot;.</div><br></div>", "i": 9051025, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintitres de noviembre de mil novecientos dieciocho.- Juan Luis Sanfuentes.- V&#xED;ctor V. Robles. </div></div>", "i": 9051026}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3430", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3430"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "LEY NUM. 3,430", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1918-11-23", "doble_articulado": false, "id_norma": "141393", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1918-11-23", "vigencias": [{"desde": "1918-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1918-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1918-11-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "IMH", "fecha_ingreso": "1999-08-26", "fecha_version": "1918-11-23", "fecha_actualizacion_texto": "1918-11-23", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 9051024}, {"n": "Artículo UNICO", "i": 9051025, "t": 6}, {"n": "Promulgación", "i": 9051026}]}