{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xB0; 5, DE 1986</div><br><br></div>", "i": 7260126}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xB0; 405, de 14 de Mayo de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n N&#xB0; 05, de 02 de Enero de 1986, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a Alimentos Generales Limitada, para instalar y operar una planta elaboradora de recursos hidrobiol&#xF3;gicos en la l&#xED;nea de congelado, en Carlos Ossand&#xF3;n Sur 704, Parque Industrial La Reina, Santiago, en orden a incluir en el numeral 3&#xB0;, entre los recursos que puede emplear como materia prima, el denominado mero a bacalao.</div><br></div>", "i": 7260127}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de Mayo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7260128}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "405", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-405"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION N° 5, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-05-14", "fecha_derogacion": "1990-09-29", "doble_articulado": false, "id_norma": "153614", "numero_fuente": "32490", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-06-07", "vigencias": [{"desde": "1990-09-29", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-06-07", "hasta": "1990