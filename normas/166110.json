{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6266859}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;508, de 28 de febrero del 2000, se expropiaron los lotes de terreno N&#xBA;s 28 y 29, superficie 167 m2. y 191 m2., rol de aval&#xFA;o 231-2, comuna de Chimbarongo, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Santiago-Talca. Sector J. Sexta Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Sociedad Agr&#xED;cola Chimbarongo, ascendente a la cantidad total de $1.957.015.- </div></div>", "i": 6266860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6266861}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "508", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-508"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-02-28", "doble_articulado": false, "id_norma": "166110", "numero_fuente": "36641", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-04-15", "vigencias": [{"desde": "2000-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-04-19", "fecha_version": "2000-04-15", "fecha_actualizacion_texto": "2000-04-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n