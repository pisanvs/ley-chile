{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DECRETO N&#xB0; 296 EXENTO, DE 1994 </div></div>", "i": 5943578}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 296 de 6 de Julio de 1994, se han aprobado planes de estudio para la Ense&#xF1;anza B&#xE1;sica y Media Human&#xED;stico-Cient&#xED;fica del Colegio Sagrado Coraz&#xF3;n de Rancagua, VI Regi&#xF3;n, que se aplicar&#xE1;n a partir del a&#xF1;o escolar 1994, en todos los cursos de los dos niveles educativos.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio de las asignaturas del plan de estudio de ense&#xF1;anza b&#xE1;sica y del plan de estudio de ense&#xF1;anza media human&#xED;stico-cient&#xED;fica.</div><br></div>", "i": 5943579}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 21 de Julio de 1994.- Gonzalo Undurraga Mackenna, Subsecretario de Educaci&#xF3;n.-</div><br></div>", "i": 5943580}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "296", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-296"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DECRETO N° 296 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "SEXTA REGION", "COLEGIO SAGRADO CORAZON RANCAGUA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-07-06", "doble_articulado": false, "id_norma": "20926", "numero_fuente": "35007", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-11-04", "vigencias": [{"desde": "1994-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-11-04", "fin_vigenc