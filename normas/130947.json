{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  PRORROGA RESOLUCION QUE INDICA</div><br></div>", "i": 8339973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 865 de 23.08.88 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 6 meses a contar de 18.09.88, el plazo otorgado a Nutrition Chile Limitada, R.U.T. No.</div><div class=\"p\">79.662.780-0 domiciliada en Valpara&#xED;so, para empezar a operar el establecimiento de cultivo autorizado por la resoluci&#xF3;n No. 956, de 1987, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de un caso fortuito. </div></div>", "i": 8339974}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23.08.88.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8339975}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "865", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-865"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-23", "doble_articulado": false, "id_norma": "130947", "numero_fuente": "33162", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-02", "vigencias": [{"desde": "1988-09-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-09-02", "fin_vigencia": "", "tipo_version": "3"}], "event