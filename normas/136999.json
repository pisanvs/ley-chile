{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,300.-&nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8345192}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por don Ces&#xE1;reo Echeg&#xF3;yen, conc&#xE9;dese a su viuda e hijos una pension de gracia ascendente a un mil ochocientos pesos anuales.</div><br></div>", "i": 8345193}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, siete de marzo de mil novecientos diez.- Pedro Montt.-&nbsp; Ismael Tocornal.</div><br></div>", "i": 8345194}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2300", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2300"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-03-07", "doble_articulado": false, "id_norma": "136999", "numero_fuente": "9645", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-03-19", "vigencias": [{"desde": "1910-03-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-03-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1910-03-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "19