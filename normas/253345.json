{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6583049}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 653 de 31 de julio de 2006, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA; del decreto MOP N&#xBA; 1.290 de 31 de mayo de 1999, en la parte que se refiere al Convenio Directo de Precio</div><div class=\"p\">Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote N&#xBA; 56. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 56, fijada por la Comisi&#xF3;n de Peritos, con fecha 27 de junio de 1997, ascendente a la cantidad de $61.035.- lote N&#xBA; 56. </div></div>", "i": 6583050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6583051}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "653", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-653"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-07-31", "doble_articulado": false, "id_norma": "253345", "numero_fuente": "38566", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-09-15", "vigencias": [{"desde": "2006-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-09-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICA