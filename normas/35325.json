{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293587}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 660, de 11 de julio de 1994 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a SOCIEDAD COMERCIAL E INDUSTRIAL CUBILLOS Y HURTADO LIMITADA, R.U.T. N&#xB0; 78.354.450-4, para iniciar actividades pesqueras, en orden a operar una planta ubicada en calle Maip&#xFA; N&#xB0; 1221, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican,</div><div class=\"p\">&nbsp; _____________________________________________________</div><div class=\"p\"> | NOTA: VER DIARIO OFICIAL N&#xB0; 34.935 DEL DIA LUNES&nbsp; &nbsp; |</div><div class=\"p\"> |&nbsp; &nbsp; &nbsp;  08 DE AGOSTO DE 1994, PAGINA 11.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; |</div><div class=\"p\"> |_____________________________________________________|</div><br></div>", "i": 8293588}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 11 de Julio de 1994.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293589}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "660", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-660"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SOCIEDAD COMERCIAL INDUSTRIAL CUBILLOS HURTADO", "LIMITADA", "PESCA", "INDUSTRIA PESQUERA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-07-11", "doble_articulado": false, "id_norma": "35325", "numero_fuente": "3493