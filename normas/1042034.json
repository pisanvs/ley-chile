{"html": [{"t": "<div><br><div class=\"p\">MODIFICA RESOLUCI&#xD3;N N&#xBA; 2 EXENTA, DE 2011</div></div>", "i": 9278192}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1, de 9 de julio de 2012, de esta Direcci&#xF3;n Zonal de Pesca, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1031407&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2, de 2011</a>, de la Direcci&#xF3;n Zonal de Pesca de la XII Regi&#xF3;n, que estableci&#xF3; una veda biol&#xF3;gica para la especie Trucha de arroyo para las temporadas 2011 y 2013, en el sentido de reemplazar el numeral 2.- de la mencionada resoluci&#xF3;n, por el se&#xF1;alado en la resoluci&#xF3;n extractada.</div><br></div>", "i": 9278193}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Punta Arenas, 9 de julio de 2012.- Ricardo Radebach Varas, Director Zonal de Pesca XII Regi&#xF3;n de Magallanes y Ant&#xE1;rtica Chilena.</div></div>", "i": 9278194}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA", "DIRECCIÓN ZONAL DE PESCA XII REGIÓN"], "titulo_norma": "MODIFICA RESOLUCIÓN Nº 2 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-07-09", "doble_articulado": false, "id_norma": "1042034", "numero_fuente": "40317", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-07-21", "vigencias": [{"desde": "2012-07-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci