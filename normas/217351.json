{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6448849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xB0; 1.144 de fecha 30 de septiembre de 2003, se expropiaron los lotes de terreno N&#xB0;s 157, 157-B, 158-A y 159-A, superficies 1.238, 4.317, 7.381 y 848 m2, Rol N&#xB0;70-25, comuna de Galvarino, IX Regi&#xF3;n para la obra Camino Ruta S-10, sector Cruce Long.</div><div class=\"p\">(Lautaro)-Galvarino, Tramo Km. 0,000 al Km. 34,50853, correspondiente al Sub-Tramo V, Km. 25,837 al 34,50853 y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Susana del Carmen Escobar Vergara, ascendente a la entidad de $6.481.943.</div><br></div>", "i": 6448850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6448851}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1144 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1144 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-30", "doble_articulado": false, "id_norma": "217351", "numero_fuente": "37711", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-15", "vigencias": [{"desde": "2003-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-11-17", "fe