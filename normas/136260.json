{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,183.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6168116}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados durante la guerra contra el Per&#xFA; i Bolivia, por la cantinera do&#xF1;a Mercedes Devia, viuda de Gonz&#xE1;lez, conc&#xE9;desele, por gracia, una pension anual de trescientos sesenta pesos ($ 360) en vez de la que actualmente disfruta&quot;.</div><br></div>", "i": 6168117}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I, por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintinueve de marzo de mil novecientos nueve.- Pedro Montt.- D. Za&#xF1;artu.</div><br></div>", "i": 6168118}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2183", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2183"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1909-03-29", "doble_articulado": false, "id_norma": "136260", "numero_fuente": "9367", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1909-04-21", "vigencias": [{"desde": "1909-04-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1909-04-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1909-04-21", "fin_vigencia": "", "tipo_version": "