{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DESIGNA COMO RECEPTORES JUDICIALES A LOS FUNCIONARIOS QUE INDICA</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 48.- Santiago, 15 de Marzo de 1993.- Vistos: Lo dispuesto en el art&#xED;culo 11 del Decreto Ley N&#xB0; 2.974 de 1979,</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br></div>", "i": 6004436}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Des&#xED;gnase como Receptores Judiciales para que permanentemente practiquen las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del Decreto Ley citado, en la VIII Regi&#xF3;n, a los se&#xF1;ores:</div><br><div class=\"p\">&nbsp; -&nbsp; Erick Del Valle Arias</div><div class=\"p\">&nbsp; -&nbsp; Jos&#xE9; Lorenzo Duhart Fica </div></div>", "i": 6004437}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional.</div><br></div>", "i": 6004438}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "48", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-48"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "DESIGNA COMO RECEPTORES JUDICIALES A LOS\nFUNCIONARIOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRAMIENTO", "INSTITUTO DESARROLLO AGROPECUARIO", "INDAP", "OCTAVA REGION", "ERICK VALLE ARIAS", "JOSE LORENZO DUHART FICA", "RECEPTOR JUDICIAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-03-15", "doble_articulado": false, "id_norma": "32597", "numero_fuente": "34537", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publi