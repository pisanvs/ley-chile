{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8344670}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 685, de 22 de abril de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a EMPRESA PESQUERA SIRIUS ACHERNAR LTDA., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Cachagua I&apos;&apos;, matr&#xED;cula 1855, en el litoral de la I a IV Regiones, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con red de arrastre el recurso hidrobiol&#xF3;gico Langostino colorado. </div></div>", "i": 8344671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8344672}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "685", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-685"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1999-04-22", "fecha_derogacion": "2003-01-16", "doble_articulado": false, "id_norma": "136091", "numero_fuente": "36358", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1999-05-08", "vigencias": [{"desde": "2003-01-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1999-05-08", "hasta": "2003-01-15", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2003-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-05-08", "fin_vigencia": "2003-01-15", "tipo_version":