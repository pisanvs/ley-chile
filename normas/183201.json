{"html": [{"t": "<div><div class=\"p\">PRORROGA PLAZOS QUE INDICA </div></div>", "i": 6327651}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 874 de 16 de Julio de 1990 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se prorroga por 30 d&#xED;as a contar de la fecha de la presente Resoluci&#xF3;n, el plazo otorgado a Sociedad Gestora Pesquera Tiqui Ltda. y Compa&#xF1;&#xED;a CP A., R.U.T. No.</div><div class=\"p\">87.017.900-6, domiciliada en Almirante Se&#xF1;oret No. 151, Valpara&#xED;so, para publicar los extractos de las Resoluciones No. 1078, de 1989 y No. 17, de 1990, ambas de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la existencia de fuerza mayor.</div><br></div>", "i": 6327652}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de Julio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 6327653}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "874", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-874"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA PLAZOS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-07-16", "doble_articulado": false, "id_norma": "183201", "numero_fuente": "33737", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-03", "vigencias": [{"desde": "1990-08-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc