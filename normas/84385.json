{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;202, DE 1989 </div></div>", "i": 6067711}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xBA;202, de 6 de diciembre de 1989, se ha aprobado a la Escuela Diferencial E N&#xBA;153 de Conchal&#xED;, Regi&#xF3;n Metropolitana, un plan de estudio especial de orientaci&#xF3;n laboral para alumnos con deficiencia mental, por un per&#xED;odo de 6 a&#xF1;os, a contar desde el a&#xF1;o escolar 1990.</div><br></div>", "i": 6067712}, {"t": "<div><div class=\"p\">Santiago, 4 de Enero de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6067713}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "202 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-202 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº202, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-06", "doble_articulado": false, "id_norma": "84385", "numero_fuente": "33568", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-12", "vigencias": [{"desde": "1990-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-01-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-01-13", "fecha_version": "1990-01-12", "fecha_actualizacion_texto": "1990