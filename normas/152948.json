{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6224717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 294, de fecha 17 de junio de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la IV Regi&#xF3;n de Coquimbo, se autoriza a don Andr&#xE9;s Fernando Andreu Walker para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6224718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 21 de julio de 1986.- Jorge Vargas Borcosky, Secretario Regional. Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo. </div></div>", "i": 6224719}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "294 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-294 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-17", "doble_articulado": false, "id_norma": "152948", "numero_fuente": "32535", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-30", "vigencias": [{"desde": "1986-07-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-07-30", "fin_vigencia": "", "tipo_ver