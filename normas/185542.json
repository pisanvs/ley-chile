{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6335662}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;613, de 30 de marzo de 2001, se expropi&#xF3; el lote de terreno N&#xBA;3-A, superficie 1.802 m&#xB2;, rol de aval&#xFA;o 1503-106, comuna de Los Angeles, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo:</div><div class=\"p\">Chill&#xE1;n-Collipulli, Octava Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Segundo Fernando C&#xE1;rdenas Alvarez, ascendente a la cantidad de $4.170.721.</div><br></div>", "i": 6335663}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6335664}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "613", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-613"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-30", "doble_articulado": false, "id_norma": "185542", "numero_fuente": "36962", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-05-15", "vigencias": [{"desde": "2001-05-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-05-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-05-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-05-22", "fecha_version": "2001-05-15", "fecha_actualizacion_texto": "2001-05-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estru