{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9343730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;393, de 25 de marzo de 2013, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xB0;, 5&#xB0; y 6&#xB0;, del <a href=\"https://www.leychile.cl/Navegar?idNorma=1039139&amp;idParte=0&amp;idVersion=\">Decreto Exento MOP. N&#xB0;563, de 29 de marzo de 2012</a>, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xB0;13, expropiado con motivo de la obra: &quot;Reposici&#xF3;n Ruta 215-CH, Bifurcaci&#xF3;n Aeropuerto Carlos Hott - Cruce Las Lumas, desde el Km. 3,99292 al Km. 21,80000&quot;, Comuna de Osorno, X Regi&#xF3;n de Los Lagos. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n fijada mediante tasaci&#xF3;n de 08 de abril de 2011, en la suma de $4.440.000, para el lote N&#xB0;13.</div></div>", "i": 9343731}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9343732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "393 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-393 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-03-25", "doble_articulado": false, "id_norma": "1050140", "numero_fuente": "40534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-15", "vigencias": [{"desde": "2013-04-15", "hasta