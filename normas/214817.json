{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6440270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.962, de 21 de agosto de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Loa 24&quot;, en el Archipi&#xE9;lago de Juan Fern&#xE1;ndez, Isla de Pascua, Islas Desventuradas e Islas Sala y G&#xF3;mez, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar, con arrastre, los recursos hidrobiol&#xF3;gicos Alfonsino, Besugo, Besugo de Juan Fern&#xE1;ndez, Quimera, Camar&#xF3;n de profundidad, Camar&#xF3;n acorazado, Raya volant&#xED;n, Raya espinuda, Raya manchas blancas, Tollo narig&#xF3;n Apristurus nasatus, Tollo narig&#xF3;n Centroscymnus crepidater, Tollo negro Centroscyllium granulosum.</div><br></div>", "i": 6440271}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 21 de agosto de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6440272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1962 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1962 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-08-21", "fecha_derogacion": "2006-11-23", "doble_articulado": false, "id_norma": "214817", "numero_fuente": "37662", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2003-09-16", "vigencias": [{"desde": "2006-11-23", "hasta": "", "tipo_version": "2", "tipo_ve