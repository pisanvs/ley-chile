{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6306300}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;2.300 de 19 de octubre de 2000, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BIO BIO S.A., para ampliar las actividades pesqueras extractivas con la nave &apos;&apos;Gardar&apos;&apos;, en el &#xE1;rea mar&#xED;tima comprendida entre la I y la X Regiones, donde podr&#xE1; capturar con trampas, por fuera del &#xE1;rea de reserva artesanal, los siguientes recursos hidrobiol&#xF3;gicos: Centolla Lithodes wiracocha, Centolla Lithodes panamensis, Centolla Neolithodes diomedeae, Centoll&#xF3;n Paralomis papillata, Centoll&#xF3;n Paralomis longipes, Centoll&#xF3;n Paralomis otsuae y Centoll&#xF3;n Paralomis spinosissima.</div><br></div>", "i": 6306301}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de octubre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6306302}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2300", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2300"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-10-19", "fecha_derogacion": "2006-08-07", "doble_articulado": false, "id_norma": "177018", "numero_fuente": "36800", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2000-10-30", "vigencias": [{"desde": "2006-08-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2000-10-30", "hasta": "2006-08-06", "tipo