{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 90, DE 1990 </div></div>", "i": 7219283}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n No. 90 de 05 de marzo de 1990 se ha procedido a aprobar un Plan Especial de Estudio para Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica al Colegio Punta Arenas, de Punta Arenas, XII Regi&#xF3;n. Dicho plan se aplicar&#xE1; en 1&#xB0; y 2&#xB0; a&#xF1;o medio en 1990 y en 3&#xB0; y 4&#xB0; a&#xF1;o medio en 1991.</div><br></div>", "i": 7219284}, {"t": "<div><div class=\"p\">Santiago, 09 de marzo de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica. </div></div>", "i": 7219285}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "90 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-90 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 90, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-03-05", "doble_articulado": false, "id_norma": "84166", "numero_fuente": "33627", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-22", "vigencias": [{"desde": "1990-03-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "MNV", "fecha_ingreso": "1998-01-12", "fec