{"html": [{"t": "<div><div class=\"p\">MODIFICA DECRETO N&#xB0; 227 EXENTO, DE 2012, DEL MINISTERIO DE ECONOM&#xCD;A, FOMENTO Y TURISMO</div></div>", "i": 10198905}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xB0; 202100013, de 28 de enero de 2021, de este Ministerio, modif&#xED;case el art&#xED;culo 2&#xB0; del <a href=\"https://www.leychile.cl/Navegar?idNorma=1037697&amp;idParte=&amp;idVersion=\">decreto exento N&#xB0; 227 de 2012</a>, que estableci&#xF3; el R&#xE9;gimen Artesanal de Extracci&#xF3;n en las regiones de &#xD1;uble y del Biob&#xED;o para el periodo 2012-2026, en las pesquer&#xED;as de Anchoveta y Sardina com&#xFA;n, en el sentido de incorporar las organizaciones de pescadores artesanales que se indica, al mencionado r&#xE9;gimen de administraci&#xF3;n:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/119440.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10198906}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de enero de 2021.- Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><br></div>", "i": 10198907}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "202100013 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-202100013 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "MODIFICA DECRETO N° 227 EXENTO, DE 2012, DEL MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1889988", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-01-28", "doble