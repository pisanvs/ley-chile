{"html": [{"t": "<div><br><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 9973384}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.738, de 9 noviembre 2018, de Serviu Regi&#xF3;n del Maule, orden&#xF3; expropiaci&#xF3;n Parcial, conforme art&#xED;culo 51 ley 16.391, de inmueble ubicado en Chacra El Retiro PC 4 Sur, Rol Aval&#xFA;o N&#xBA; 167-263, comuna Maule, superficie terreno 1.380,69 metros cuadrados, deslindes seg&#xFA;n plano expropiaciones, propietario aparente Inmobiliaria Pocuro Limitada. Comisi&#xF3;n integrada por peritos Patricio Ulises Dur&#xE1;n Marcos, Arquitecto; Rodrigo Antonio Silva Lazo, Constructor Civil y Pedro Pablo Cruz Weston, Arquitecto, seg&#xFA;n informe tasaci&#xF3;n de 5 octubre 2018, fij&#xF3; monto provisional indemnizaci&#xF3;n en $80.080.020.-, pagados al contado.- </div></div>", "i": 9973385}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Claudio Daneck Mu&#xF1;oz, Director (S) Serviu Regi&#xF3;n del Maule. </div><br></div>", "i": 9973386}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3738 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3738 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN", "VII REGIÓN DEL MAULE"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1500109", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-11-09", "doble_articulado": false, "id_norma": "1126309", "numero_fuente": "42219", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-12-01", "vigencias": [{"desde": "2018-12-01", "