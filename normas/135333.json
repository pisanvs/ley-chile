{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,742.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6165086}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atencion a los servicios prestados al pais por el ministro de la Corte de Apelaciones de Santiago, don Jos&#xE9; Manuel Infante, conc&#xE9;dese, por gracia, a su viuda, una pension anual de mil quinientos pesos ($ 1,500), de la cual disfrutar&#xE1; con arreglo a las prescripciones de la lei de montep&#xED;o militar&quot;. </div></div>", "i": 6165087}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a 10 de agosto de mil novecientos cinco.- JERMAN RIESCO.- Antonio Huneeus.</div><br></div>", "i": 6165088}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1742", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1742"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1905-08-10", "doble_articulado": false, "id_norma": "135333", "numero_fuente": "8284", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1905-08-16", "vigencias": [{"desde": "1905-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1905-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1905-08-1