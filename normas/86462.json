{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS DE &quot;BOLSA DE CORREDORES BOLSA DE VALORES&quot; </div></div>", "i": 6073188}, {"t": "<div><div class=\"p\">Certifico: Que por Resoluci&#xF3;n Exenta No. 140 de fecha 30.06.92, se aprob&#xF3; la reforma de estatutos de la entidad denominada &quot;Bolsa de Corredores Bolsa de Valores&quot;, que consta de la escritura p&#xFA;blica de 27 de mayo de 1992, otorgada ante la Notario de Valpara&#xED;so, Mar&#xED;a Ester Astorga Lagos. La reforma consiste en aumentar el plazo de duraci&#xF3;n del cargo de director de 1 a 3 a&#xF1;os, sustituyendo al efecto el art&#xED;culo 29 de los estatutos sociales.</div><br></div>", "i": 6073189}, {"t": "<div><div class=\"p\"> Santiago, 30.06.92.</div><br><div class=\"p\">Rodrigo 0. Costa Aranda, Secretario General.</div><br></div>", "i": 6073190}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "140 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-140 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE BOLSA DE CORREDORES BOLSA DE VALORES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA S/N"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-30", "doble_articulado": false, "id_norma": "86462", "numero_fuente": "34317", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-07-16", "vigencias": [{"desde": "1992-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-07-16", "fin_vigencia": "", "tipo_version":