{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,676.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6172835}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, al Ministro de la Corte de Apelaciones de Talca, don Fidel Urrutia, para los efectos de su jubilaci&#xF3;n, el abono de once a&#xF1;os siete meses i once dias que estuvo separado del ejercicio judicial, desde el 4 de setiembre de 1891 hasta el 15 de abril de 1903, a causa de los sucesos pol&#xED;ticos de 1891. </div></div>", "i": 6172836}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, veintitres de agosto de mil novecientos doce.- Ramon Barros Luco.- E. Villegas E.</div><br><br></div>", "i": 6172837}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2676", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2676"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1912-08-23", "doble_articulado": false, "id_norma": "137666", "numero_fuente": "10369", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1912-09-03", "vigencias": [{"desde": "1912-09-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1912-09-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "