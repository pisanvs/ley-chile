{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 12.993 EXENTA, DE 2000 </div><br></div>", "i": 6318515}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 12.993, de 29 de diciembre del a&#xF1;o 2000, se ha aprobado al Colegio Craighouse, comuna de Lo Barnechea, de Santiago, un plan de estudio para 1&#xBA; y 2&#xBA; a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000.</div><div class=\"p\">Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en la presente resoluci&#xF3;n, excepto en los subsectores de Artes Visuales y Educaci&#xF3;n F&#xED;sica, cuyos programas son los oficiales aprobados por el Ministerio de Educaci&#xF3;n.</div><br></div>", "i": 6318516}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 29 de diciembre de 2000.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6318517}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12993 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12993 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 12.993 EXENTA, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-12-29", "doble_articulado": false, "id_norma": "180790", "numero_fuente": "36875", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-30", "vigencias": [{"desde": "2001-01-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini