{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 332, celebrada el 12 de enero de 1994, adopt&#xF3; el siguiente acuerdo:</div><div class=\"p\"> 332-04-940112 - Modifica Cap&#xED;tulo IV.B.8.3 del Compendio de Normas Financieras.</div><br></div>", "i": 5843625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Se acord&#xF3; reemplazar en el N&#xB0; 2 del Cap&#xED;tulo IV.B.8.3 &quot;Pagar&#xE9;s Reajustables del Banco Central de Chile con Pago en Cupones (P.R.C.)&quot; del Compendio de Normas Financieras, el guarismo &quot;300&quot; por &quot;400&quot;. </div></div>", "i": 5843626}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 12 de enero de 1994.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe.</div><br></div>", "i": 5843627}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "332", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-332"}, {"tipo": "5", "numero": "332-04", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-332-04"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICO QUE EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N° 332, CELEBRADA EL 12 DE ENERO DE 1994, ADOPTO EL SIGUIENTE ACUERDO: 332-04-940112 - MODIFICA CAPITULO IV.B.8.3 DEL COMPENDIO DE NORMAS FINANCIERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "COMPENDIO NORMAS FINANCIERAS", "PAGARE REAJUSTABLE", "PAGO", "CUPON"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-01-12", "doble_articulado": false, "id_norma": "185", "numero_fuente": "34765-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-01-15", "vigencias": [{"desde": "1994-