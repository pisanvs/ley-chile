{"html": [{"t": "<div><br><div class=\"p\">INSTALACION DEL CONGRESO CONSTITUYENTE.</div></div>", "i": 10044655}, {"t": "<div><br><br><div class=\"p\">El Ministro de Estado en el Departamento de Gobierno Director Supremo Delegado &amp;c.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Soberano Congreso Constituyente de la Nacion ha anunciado al Gobierno con fecha de ayer que se halla constituido y va a principiar sus sesiones. Por tanto ordeno, que se anuncie solemnemente este feliz acontecimiento por bando especial, y que se inserte el Boletin, para su circulacion. Dado en el Palacio Directorial de Santiago a 14 de Agosto de 1823.-</div></div>", "i": 10044656}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.- Jos&#xE9; Mar&#xED;a de Astorga, Subsecretario.</div></div>", "i": 10044657}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "36", "numero": "S/N", "abreviacion": "Bando", "descripcion": "Bando", "compuesto": "Bando-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "INSTALACION DEL CONGRESO CONSTITUYENTE", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-08-14", "doble_articulado": false, "id_norma": "1134125", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-08-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-08-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-08-14", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2019-08-08", "fecha_version": "1823-08-14", "fecha_actual