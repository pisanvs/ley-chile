{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 785 EXENTO, DE 2005 </div></div>", "i": 6535544}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 785, de fecha 15 de junio de 2005, del Ministerio de Educaci&#xF3;n, se modifica el art&#xED;culo 1&#xBA; del decreto exento de Educaci&#xF3;n N&#xBA; 32, del 8 de febrero de 1985, modificado por decreto exento de Educaci&#xF3;n N&#xBA; 467, del 10 de octubre de 1994, que autoriza el funcionamiento al Centro de Formaci&#xF3;n T&#xE9;cnica ALFA, en el sentido de reemplazar a los nuevos representantes legales de la sociedad organizadora del centro, por los siguientes:</div><br><div class=\"p\">Nombre de la Instituci&#xF3;n&nbsp;  :&nbsp;  Centro de formaci&#xF3;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  T&#xE9;cnica ALFA</div><div class=\"p\">Domicilio&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  Constituci&#xF3;n</div><div class=\"p\">Organizador&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  Sociedad Centro de</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Formaci&#xF3;n T&#xE9;cnica ALFA</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Limitada o C.F.T. ALFA</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Ltda.</div><div class=\"p\">Representantes legales&nbsp; &nbsp;  :&nbsp;  Don Claudio Carol Rold&#xE1;n</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Albornoz y/o do&#xF1;a Pamela</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Emma Alarc&#xF3;n Barahona,</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  conjunta o</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  separadamente.</div><br><br></div>", "i": 6535545}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 23 de junio de 2005.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6535546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "785 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-785 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_derogacion": "2021-01-01", "doble_articulado": false, "id_norma": "240823", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-08-05", "vigencias": [{"desde": "2021-01-01", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-08-05", "hasta": "2020-12-31", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2021-01-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-08-05", "fin_vigencia": "2020-12-31", "tipo_version": "0"}, {"inicio_vigencia": "2021-01-01", "fin_vigencia": "", "tipo_version": "2"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "DVG", "fecha_ingreso": "2005-08-05", "fecha_version": "2020-03-19", "actualizado_por": "1289", "fecha_actualizacion_texto": "2020-03-19", "tipo_tratado": ""}, "alertas": [{"clase": "derogado", "texto": "Derogado