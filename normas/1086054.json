{"html": [{"t": "<div><br><div class=\"p\">DECLARACI&#xD3;N JURADA FORMULARIO N&#xB0; 1861</div></div>", "i": 9661044}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 109 del 24 de diciembre de 2015.</div><div class=\"p\">&nbsp; &nbsp;  Reemplaza formato e instrucciones de Declaraci&#xF3;n Jurada Formulario n&#xFA;mero 1861; modifica la obligaci&#xF3;n de presentar declaraci&#xF3;n y deroga <a href=\"https://www.leychile.cl/Navegar?idNorma=220522&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n Ex. N&#xBA; 6 de 21 de enero de 2004</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de diciembre de 2015.</div><br></div>", "i": 9661045, "v": ["MODIFICACION"]}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "109 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-109 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DECLARACIÓN JURADA FORMULARIO N° 1861", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2015-12-24", "fecha_derogacion": "2016-12-31", "doble_articulado": false, "id_norma": "1086054", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2016-01-04", "vigencias": [{"desde": "2016-12-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2016-01-04", "hasta": "2016-12-30