{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6506931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 641, de 5 de noviembre de 2004, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n conforme D.L. N&#xBA; 2.186, de 1978, del Lote 235 correspondiente a parte del inmueble ubicado en Avenida Santa Rosa N&#xBA; 5585, presunto Rol de aval&#xFA;o N&#xBA; 5530-3, comuna de San Miguel, aparente dominio de Calzados y Textiles Caltex S.A. Comisi&#xF3;n integrada por peritos Ram&#xF3;n Domingo Labarca, ingeniero civil; Jimena Asenjo Burgos, arquitecta, y Gast&#xF3;n Bianchi Aqueveque, constructor civil. Seg&#xFA;n informe de fecha 22 de septiembre de 2004 fij&#xF3; monto provisional indemnizaci&#xF3;n en $36.325.600, pagadera al contado.</div><br></div>", "i": 6506932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Serviu Metropolitano.</div><br></div>", "i": 6506933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "641", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-641"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES QUE INDICA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-11-05", "doble_articulado": false, "id_norma": "233057", "numero_fuente": "38025", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-12-01", "vigencias": [{"desde": "2004-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio