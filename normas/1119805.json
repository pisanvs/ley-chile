{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 315 EXENTA, DE 1 DE JUNIO DE 2014</div></div>", "i": 9923807}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del SII, por resoluci&#xF3;n Ex. N&#xBA; 315, de fecha 01.06.2014, otorga la calidad de Agente Retenedor del Impuesto al Valor Agregado en las ventas de ganado vivo, a Agr&#xED;cola Santa In&#xE9;s de la Morera Limitada, RUT N&#xBA; 76.130.050-4. Dicho acto de autoridad regir&#xE1; a contar del d&#xED;a primero del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido en la resoluci&#xF3;n exenta SII N&#xBA; 3.721, del 28.07.2000, de la Direcci&#xF3;n Nacional del Servicio de Impuestos Internos, publicada en el Diario Oficial el 01.08.2000.</div></div>", "i": 9923808}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 12 de junio de 2018.- Mario Gonz&#xE1;lez Z&#xFA;&#xF1;iga, Director Regional.</div></div>", "i": 9923809}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "315 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-315 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL RANCAGUA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 315 EXENTA, DE 1 DE JUNIO DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1415886", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-06-01", "doble_articulado": false, "id_norma": "1119805", "numero_fuente": "42086", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2018-06-19", "vigencias": [{"desde": "2018-07-01", "hasta": "", "tipo_versi