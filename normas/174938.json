{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6298931}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.773, de 30 de junio de 2000, se expropi&#xF3; el lote de terreno N&#xBA;21, superficie 434 m&#xB2;., rol de aval&#xFA;o 325-33, comuna de R&#xED;o Negro, para la obra Camino Ruta U-72, Sector Huilma-Riachuelo, Tramo Km.</div><div class=\"p\">18,14000 a Km. 33,91000 y se acord&#xF3; precio de la indemnizaci&#xF3;n con su propietaria Bernardita del Carmen Monje G&#xF3;mez, ascendente a al cantidad de $328.811. </div></div>", "i": 6298932}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6298933}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2773", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2773"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-30", "doble_articulado": false, "id_norma": "174938", "numero_fuente": "36754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-01", "vigencias": [{"desde": "2000-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2000-09-06", "fecha_version": "2000-09-01", "fecha_actualizacion_texto": "2000-09-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n