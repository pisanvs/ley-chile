{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6468258}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 120, 3 de Mayo de 1983, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VII Regi&#xF3;n, se autoriza a El&#xED;as Coronado Cort&#xE9;s para efectuar todo tipo de servicios de transportes de pasajeros por las calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6468259}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Concepci&#xF3;n, 3 de Mayo de 1983.- Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicaciones, VII Regi&#xF3;n del B&#xED;o B&#xED;o. </div></div>", "i": 6468260}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "120 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-120 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1983-05-03", "doble_articulado": false, "id_norma": "222253", "numero_fuente": "31563", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1983-05-10", "vigencias": [{"desde": "1983-05-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1983-05-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1983-05-10", "fin_vigencia": "", "tipo_