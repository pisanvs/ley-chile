{"html": [{"t": "<div><div class=\"p\">AUTORIZA A DON MANUEL ARRIAGADA NEIRA PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br><br></div>", "i": 6265177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 607, de 13 de Diciembre de 1984, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a don Manuel Arriagada Neira, c&#xE9;dula de identidad N&#xB0; 110.926, de Puerto Montt, domiciliado en Pichi-Pelluco, manzana 47, casa 24, Puerto Montt, para instalar y operar un establecimiento de cultivo de alga Gracilaria spp., en el Estero Cheteb, comuna de Quell&#xF3;n, provincia de Chilo&#xE9;, X Regi&#xF3;n, en una superficie de 10.000 m2. de fondo de mar.</div><br></div>", "i": 6265178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de Diciembre de 1984.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6265179}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "607", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-607"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A DON MANUEL ARRIAGADA NEIRA PARA DESARROLLAR\nACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1984-12-13", "fecha_derogacion": "1989-09-12", "doble_articulado": false, "id_norma": "165617", "numero_fuente": "32067", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-01-10", "vigencias": [{"desde": "1989-09-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-01-10", "hasta":