{"html": [{"t": "<div><br><div class=\"p\">AUTORIZA EMISOR DE BOLETA ELECTR&#xD3;NICA</div></div>", "i": 8774526}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xB0; 123, de 26 de agosto de 2009, que autoriza a contribuyente como emisor de boleta electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boleta electr&#xF3;nica a contribuyente RUT 87.161.100-9, a contar del mes de agosto de 2009. En la Oficina Virtual del SII, en internet, se podr&#xE1;n consultar los documentos que el contribuyente est&#xE1; autorizado a emitir en forma electr&#xF3;nica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos, en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de agosto de 2009.</div></div>", "i": 8774527}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "123 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-123 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR DE BOLETA ELECTRÓNICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-08-26", "doble_articulado": false, "id_norma": "1005555", "numero_fuente": "39450", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2009-08-31", "vigencias": [{"desde": "2009-08-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2009-08-31", "fin_vigencia": ""}, "vig