{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7321714}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.026, de 5 de julio de 2005, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 893, de 1991, modificada mediante las resoluciones N&#xBA; 1.363, de 1992; N&#xBA; 605, de 1995; N&#xBA; 1.943, de 1999, y N&#xBA; 1.310, de 2004, todas de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOUTHPACIFIC KORP S.A. para desarrollar actividades pesqueras extractivas con la nave &quot;Libas&quot;, en el sentido de actualizar las siguientes caracter&#xED;sticas n&#xE1;uticas de la nave:</div><br><div class=\"p\">&nbsp; &nbsp;  Potencia principal&nbsp; &nbsp; &nbsp;  2434.00 Hp.</div><div class=\"p\">&nbsp; &nbsp;  Potencia auxiliar&nbsp; &nbsp; &nbsp; &nbsp; 886.00 Hp.</div><br></div>", "i": 7321715}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 5 de julio de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7321716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2026 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2026 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-05", "doble_articulado": false, "id_norma": "240169", "numero_fuente": "38213", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-18", "vigencias": [{"desde": "2005-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_