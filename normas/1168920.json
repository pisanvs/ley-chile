{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10289334}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xB0;1149, de 11 de noviembre de 2021, se modific&#xF3; y desisti&#xF3; parcialmente de la expropiaci&#xF3;n del lote N&#xB0;58L7, realizada por <a href=\"https://www.leychile.cl/Navegar?idNorma=1149524&amp;idParte=&amp;idVersion=\">Decreto Exento MOP. N&#xB0;794, de 02 de septiembre de 2020</a>, reduci&#xE9;ndose la superficie expropiada a 150,38 m2. para la ejecuci&#xF3;n de obra &quot;Proyecto L&#xED;nea 7 Metro S.A., Comuna de Providencia, Regi&#xF3;n Metropolitana&quot;. </div><br></div>", "i": 10289335}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Fiscal&#xED;a MOP.</div></div>", "i": 10289336}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1149 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1149 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2042253", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-11-11", "doble_articulado": false, "id_norma": "1168920", "numero_fuente": "43117", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-12-01", "vigencias": [{"desde": "2021-12-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2021-12-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2021-12-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinc