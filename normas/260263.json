{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 2.005, DE 2007 </div></div>", "i": 6607864}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante la resoluci&#xF3;n N&#xBA; 2.005 de fecha 19 de abril de 2007 de la Direcci&#xF3;n Nacional de Aduanas, se modific&#xF3; el Cap&#xED;tulo III del Compendio de Normas Aduaneras, estableciendo un procedimiento electr&#xF3;nico para la tramitaci&#xF3;n de los Formularios de Importaci&#xF3;n V&#xED;a Postal.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de esta resoluci&#xF3;n se encuentra en la p&#xE1;gina web del Servicio Nacional de Aduanas. </div></div>", "i": 6607865}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2005", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2005"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 2.005, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPENDIO DE NORMAS ADUANERAS", "FORMULARIOS DE IMPORTACION VIA POSTAL", "TRAMITACION", "PROCEDIMIENTO ELECTRONICO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-04-19", "doble_articulado": false, "id_norma": "260263", "numero_fuente": "38745", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-04-23", "vigencias": [{"desde": "2007-04-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-04-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-04-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_po