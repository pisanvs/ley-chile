{"html": [{"t": "<div><br><div class=\"p\">ACTUALIZA INSTRUCCIONES CONTENIDAS EN CIRCULAR N&#xBA; 25 DE 2008</div></div>", "i": 9133989}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de circular del Servicio de Impuestos Internos N&#xBA; 22 del 13 de abril de 2011, que actualiza instrucciones contenidas en <a href=\"https://www.leychile.cl/Navegar?idNorma=270874&amp;idParte=0&amp;idVersion=\">circular N&#xBA; 25 de 2008</a>, que imparte instrucciones sobre las modificaciones introducidas a los art&#xED;culos 41A, 41B, 41C, 41D, 69 N&#xBA; 3 y 84 de la Ley sobre Impuesto a la Renta por la ley N&#xBA; 20.171, de 2007 y otras normas relativas a la doble tributaci&#xF3;n internacional.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta circular est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de abril de 2011.</div></div>", "i": 9133990}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "22", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-22"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ACTUALIZA INSTRUCCIONES CONTENIDAS EN CIRCULAR Nº 25 DE 2008", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-04-13", "doble_articulado": false, "id_norma": "1024622", "numero_fuente": "39939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-04-18", "vigencias": [{"desde": "2011-04-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigen