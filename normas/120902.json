{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8331613}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 924, de 30 de junio de 1998 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad parcial de las resoluciones N&#xBA; 1235 de 1987 y N&#xBA; 846 de 1997, de esta Subsecretar&#xED;a, que autorizan a PESQUERA E INVERSIONES LIUCURA S.A., para desarrollar operaciones pesqueras con la nave &apos;&apos;Liucura&apos;&apos;, en el litoral de la III a VII regiones sobre los recursos Agujilla, Anchoveta, At&#xFA;n de aleta larga, Bonito, Caballa, Cabinza, Cochinilla, Cojinoba del norte, Jurel, Pampanito, Roncacho, Sardina com&#xFA;n, Sardina espa&#xF1;ola y Machuelo.</div><br></div>", "i": 8331614}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de junio de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8331615}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "924", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-924"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA INVERSIONES LIUCURA S.A.", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-06-30", "doble_articulado": false, "id_norma": "120902", "numero_fuente": "36108", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-07-08", "vigencias": [{"desde": "1998-07-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-07-08",