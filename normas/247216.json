{"html": [{"t": "<div><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A CONTRIBUYENTE QUE INDICA </div></div>", "i": 6560806}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La IV Direcci&#xF3;n Regional La Serena, revoca la calidad de agente retenedor del Impuesto al Valor Agregado en las Ventas que se indica, al contribuyente que se se&#xF1;ala:</div><br><div class=\"p\">Contribuyente&nbsp; &nbsp;  RUT N&#xBA;&nbsp; &nbsp;  Res. N&#xBA;&nbsp; Fecha&nbsp; &nbsp;  Venta de</div><div class=\"p\">Jos&#xE9; Antonio</div><div class=\"p\">Carvajal P&#xE9;rez&nbsp; 14.099.067-1&nbsp;  62&nbsp; &nbsp; 11/01/06&nbsp;  Harina</div><br><div class=\"p\">&nbsp; &nbsp;  A contar de la fecha de la publicaci&#xF3;n de este extracto en el Diario Oficial conforme a la facultad delegada en el dispositivo N&#xBA;17 de la resoluci&#xF3;n exenta N&#xBA; 5.282 de 30/11/2000, emanada de la Direcci&#xF3;n Nacional de este Servicio.</div><br></div>", "i": 6560807}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 11 de enero del 2006.- Alonso Vergara Arce, Director Regional (S).</div><br></div>", "i": 6560808}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "62", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-62"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IV DIRECCIÓN REGIONAL LA SERENA"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DEL IVA A\nCONTRIBUYENTE QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-01-11", "doble_articulado": false, "id_norma": "247216", "numero_fuente": "38386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006