{"html": [{"t": "<div><div class=\"p\">ESTRA&#xD1;AMIENTO DEL DIOCESANO.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Diciembre 22 de 1825.</div><br><div class=\"p\">&nbsp; &nbsp;  El Gobierno ha acordado y decreta:</div></div>", "i": 10207298}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1.&#xB0;&nbsp; El Obispo D. Jos&#xE9; Santiago Rodriguez ser&#xE1; estra&#xF1;ado del territorio de la Rep&#xFA;blica, saliendo en la noche de este dia para el puerto de Valparaiso a esperar posteriores &#xF3;rdenes.</div><div class=\"p\">&nbsp; &nbsp;  2.&#xB0;&nbsp; Para ayuda de costos de su viaje se proporcionar&#xE1; por la Tesorer&#xED;a jeneral la cantidad de seis mil pesos.</div><div class=\"p\">&nbsp; &nbsp;  3.&#xB0;&nbsp; Los motivos y documentos que han obligado a esta medida se publicar&#xE1;n inmediatamente.</div><div class=\"p\">&nbsp; &nbsp;  4.&#xB0;&nbsp; El Gobernador intendente de esta provincia queda encargado de la ejecucion de este decreto que lo comunicar&#xE1; oportunamente a dicho Obispo.</div></div>", "i": 10207299}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  INFANTE.</div><div class=\"p\">&nbsp; &nbsp;  Campino.</div></div>", "i": 10207300}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["MINISTERIO DE INTERIOR"], "titulo_norma": "ESTRAÑAMIENTO DEL DIOCESANO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1825-12-22", "doble_articulado": false, "id_norma": "1151800", "numero_fuente": "1825", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1825-12-22", "hasta": "", "tipo_ve