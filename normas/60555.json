{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8300954}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 105, de 22 de enero de 1997 de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, cad&#xFA;canse las Resoluciones N&#xBA; 298 y N&#xBA; 758 de</div><div class=\"p\">1989, de esta Subsecretar&#xED;a, en cuanto autorizaron a PESCA</div><div class=\"p\">SURIBERICA S.A., para operar la nave &quot;Isla Sof&#xED;a&quot;, en virtud de</div><div class=\"p\">lo dispuesto en el Art&#xED;culo 11 transitorio inciso 1&#xBA; y el</div><div class=\"p\">art&#xED;culo 143 letra b) del D.S. N&#xBA; 430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n y con el m&#xE9;rito de lo resuelto por la I. Corte de Apelaciones de Valpara&#xED;so. </div></div>", "i": 8300955}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 22 de enero de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8300956}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "105", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-105"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "PESQUERA SURIBERICA S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["Extracto"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-01-22", "doble_articulado": false, "id_norma": "60555", "numero_fuente": "35679", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-01-30", "vigencias": [{"desde": "1997-01-30", "hasta": "", "tipo_version": "3", "