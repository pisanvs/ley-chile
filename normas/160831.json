{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6250094}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 424 de 08 de Abril de 1985, de la Secretarla Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n se autoriza a Graciela Moreno Meri&#xF1;o para efectuar todo tipo de transporte de pasajeros por calles y caminos, dentro del territorio nacional a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6250095}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gladys Tapia Huerta, Secretario Regional Ministerial (S) de Transportes y Telecomunicaciones, Regi&#xF3;n del Maule.</div><br></div>", "i": 6250096}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "424 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-424 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-04-08", "doble_articulado": false, "id_norma": "160831", "numero_fuente": "32146", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-15", "vigencias": [{"desde": "1985-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-04-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CM