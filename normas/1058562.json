{"html": [{"t": "<div><br><div class=\"p\">ESTABLECE CUOTA ANUAL DE CAPTURA PARA EL RECURSO JIBIA XV-XII REGIONES, A&#xD1;O 2014</div></div>", "i": 9401970}, {"t": "<div><div class=\"p\">&nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 22, de 22 de enero de 2014, de este Ministerio, f&#xED;jase para el a&#xF1;o 2014 la siguiente cuota anual de captura para el recurso Jibia, a ser extra&#xED;da en el &#xE1;rea mar&#xED;tima comprendida entre la XV a la XII Regiones, seg&#xFA;n se indica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  <img class=\"img-responsive\" src=\"Navegar/imagen/JPG/36941.jpg\"></div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y Acuicultura y del Servicio Nacional de Pesca y Acuicultura.</div></div>", "i": 9401971}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de enero de 2014.- Edith Saa Collantes, Subsecretaria de Pesca y Acuicultura (S).</div></div>", "i": 9401972}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "22 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-22 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "ESTABLECE CUOTA ANUAL DE CAPTURA PARA EL RECURSO JIBIA XV-XII REGIONES, AÑO 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-01-22", "doble_articulado": false, "id_norma": "1058562", "numero_fuente": "40767", "tipo_version": "3", "tip