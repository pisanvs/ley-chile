{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DISPONE CAMBIO DE NOMBRE DE LA CALLE QUE INDICA DE LA CIUDAD DE LINARES</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8279738}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- La calle &quot;Matadero&quot; de la ciudad de Linares se denominar&#xE1;, en lo sucesivo, &quot;Januario Espinoza del Campo&quot;.</div><br></div>", "i": 8279739}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 11 de Febrero de mil novecientos cincuenta y cinco.- CARLOS IBA&#xD1;EZ DEL CAMPO.- Sergio Recabarren Valenzuela.</div><br></div>", "i": 8279740}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "11800", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-11800"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "DISPONE CAMBIO DE NOMBRE DE LA CALLE QUE INDICA DE\nLA CIUDAD DE LINARES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE", "LINARES", "MATADERO", "JANUARIO ESPINOZA DEL CAMPO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1955-02-11", "doble_articulado": false, "id_norma": "26815", "numero_fuente": "23082", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1955-02-24", "vigencias": [{"desde": "1955-02-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1955-02-24", "fin_vigencia": ""}, "vigen