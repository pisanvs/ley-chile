{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6108319}, {"t": "<div><div class=\"p\">&nbsp;  Por decreto M.O.P. N&#xBA; 179 de 27 de febrero de 1998, se expropiaron los lotes de terreno N&#xBA;s 1, 3-A y 4-A, canal El Oyente (incluye ramal N&#xBA;l) y. lote N&#xBA; 12-A, canal El Oyente, superficies 17.760, 1.122, 1.110 y 5.760 m2 respectivamente, roles de aval&#xFA;o 149- 27, 153-43, 153-2 y 157-13, comuna de Pemuco, para la obra Proyecto Laja Diguill&#xED;n, &#xE1;rea de riego Pemuco y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Mar&#xED;a lvet Sandoval Acu&#xF1;a y otro, Luis Alfonso Barrera Caries, Ana Isabel Rubilar Mart&#xED;nez y Francisco Antonio Riquelme Valdebenito, ascendentes a las cantidades de $7.756.956, $335.460, $308.167 y $1.773.402, respectivamente.-</div><br></div>", "i": 6108320}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6108321}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "179", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-179"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "PEMUCO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-27", "doble_articulado": false, "id_norma": "98144", "numero_fuente": "36040", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-04-15", "vigencias": [{"desde": "1998-04-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-04-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic