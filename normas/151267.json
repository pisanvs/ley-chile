{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6219141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 213 del 08.06.87, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones, de la IV Regi&#xF3;n de Coquimbo, se autoriza a don H&#xE9;ctor Alfredo Orrego Riquelme para efectuar todo tipo de servicios de transportes y pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6219142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La Serena, 08.06.87.- Jorge Vargas Borcosky, Secretario Regional Ministerial de Transportes y Telecomunicaciones IV Regi&#xF3;n de Coquimbo.</div><br></div>", "i": 6219143}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "213 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-213 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL IV REGIÓN COQUIMBO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-08", "doble_articulado": false, "id_norma": "151267", "numero_fuente": "32823", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-07-18", "vigencias": [{"desde": "1987-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-07-18", "fin_vigencia": "", "tipo_version": "3"}], "evento