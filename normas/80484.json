{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8311053}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 826 de 17 de Julio de 1991 de esta</div><div class=\"p\">Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y</div><div class=\"p\">Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad conforme con el</div><div class=\"p\">art&#xED;culo 7&#xB0; del Decreto Supremo No. 175, de 1980, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, de la resoluci&#xF3;n No. 498, de 1987, de esta Subsecretar&#xED;a que autoriz&#xF3; a don RENE AROS MANSILLA, R.U.T. No. 5.647.603-2, domiciliado en Villa Maull&#xED;n, Pasaje No. 1, casa No. 140, de Maull&#xED;n para desarrollar actividades pesquera de cultivo. </div></div>", "i": 8311054}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 17 de Julio de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8311055}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "826", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-826"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-17", "doble_articulado": false, "id_norma": "80484", "numero_fuente": "34035", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-08-05", "vigencias": [{"desde": "1991-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-08-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-08-05", "fin_vigencia": "", "tipo_versi