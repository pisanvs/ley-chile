{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6223260}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante Resoluci&#xF3;n Exenta No. 836 de 27 de Junio de 1986, conforme Art. 5&#xB0; Transitorio C&#xF3;digo de Aguas, determin&#xF3; Derechos Aprovechamiento de Aguas que corresponde a parcelas N&#xB0;s. 1 a la 18 y sitios A, B, E, F, G, I, J, K, L, M, N, y &#xD1; del Proyecto de Parcelaci&#xF3;n &quot;Santa Elba y Santa Laura&quot; formado por predios &quot;Fundo Santa Elba&quot; y &quot;Santa Laura&quot;, ubicados en la comuna de Melipilla, Regi&#xF3;n Metropolitana. Los Derechos de Aguas se extraen de los canales Codigua y Molina y Derrames del Fundo Mandinga y Los Acacios. Publicaci&#xF3;n hecha conforme Art. 13 Ley No.</div><div class=\"p\">18.377.</div><br></div>", "i": 6223261}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Ejecutivo.</div><br></div>", "i": 6223262}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "836 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-836 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS DE APROVECHAMIENTOS DE AGUAS QUE\nINDICAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-27", "doble_articulado": false, "id_norma": "152474", "numero_fuente": "32510", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-07-01", "vigencias": [{"desde": "1986-07-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-07-01", "fin_vigencia": ""}, "vigencias_version_no