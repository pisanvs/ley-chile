{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6055366}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta No. 3.669 de fecha 26 de noviembre de 1991 del Ministerio de Educaci&#xF3;n, se declar&#xF3; que no se concede el reconocimiento oficial al Centro de Formaci&#xF3;n T&#xE9;cnica Centro de Estudios e Ingenier&#xED;a de Sistemas CEEIS, organizado por la Sociedad CEEIS Ltda., ubicado en calle Freire No. 769 de la ciudad de Castro, y se elimin&#xF3; del Libro de registros de Centros de Formaci&#xF3;n T&#xE9;cnica el No. 214 de fecha 03 de marzo de 1991 correspondiente a esta instituci&#xF3;n.</div><br></div>", "i": 6055367}, {"t": "<div><div class=\"p\">Santiago, 29 de enero de 1992.- Ra&#xFA;l Allard Neumman, Subscretario de Educaci&#xF3;n.</div><br></div>", "i": 6055368}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3669 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3669 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-11-26", "doble_articulado": false, "id_norma": "79619", "numero_fuente": "34202", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-02-25", "vigencias": [{"desde": "1992-02-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-02-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-02-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1997-12-10", "fecha_version":