{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8312233}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xB0;. 1.197 de 03 de Septiembre de 1991, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, sustit&#xFA;yese el numeral 12&#xB0; de la resoluci&#xF3;n N&#xB0;. 1.023, de 1989, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don EDGAR CACERES SANDIVAR, R.U.T. N&#xB0;.</div><div class=\"p\">4.570.940-K, domiciliado en calle Serrano N&#xB0;. 433, Iquique, para ampliar actividades pesqueras, en el sentido de se&#xF1;alar que el &#xE1;rea de operaci&#xF3;n de las naves &quot;Genoveva I&quot; y &quot;Andrea I&quot; que se deniega, corresponde a las Regiones VIII, IX y X. </div></div>", "i": 8312234}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 03 de Septiembre de 1991.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8312235}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1197", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1197"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-09-03", "doble_articulado": false, "id_norma": "81318", "numero_fuente": "34071", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-20", "vigencias": [{"desde": "1991-09-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09-20", "fin_vigencia": "", "tipo_ver