{"html": [{"t": "<div><div class=\"p\">ACEPTA RENUNCIA A SE&#xD1;OR SUBSECRETARIO GENERAL DE GOBIERNO </div><div class=\"p\">N&#xFA;m. 2.- Santiago, 29 de Enero de 1990.- Visto: lo establecido en el art&#xED;culo 32 No. 9 de la Constituci&#xF3;n Pol&#xED;tica de la Rep&#xFA;blica de Chile, de 1980;</div><br><div class=\"p\">Decreto:</div><br><br></div>", "i": 6086175}, {"t": "<div><div class=\"p\">Ac&#xE9;ptase a contar del 11 de Marzo de 1990, la renuncia al cargo de Subsecretario General de Gobierno, presentada por el se&#xF1;or Teniente Coronel de Ej&#xE9;rcito, don Jaime Guillermo Garc&#xED;a Covarrubias.</div><br></div>", "i": 6086176}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, reg&#xED;strese y comun&#xED;quese.- AUGUSTO PINOCHET UGARTE, General de Ej&#xE9;rcito, Presidente de la Rep&#xFA;blica.- Cristian Labb&#xE9; Galilea, Ministro Secretario General de Gobierno.</div><br></div>", "i": 6086177}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2"}], "organismos": ["MINISTERIO SECRETARÍA GENERAL DE GOBIERNO"], "titulo_norma": "ACEPTA RENUNCIA A SEÑOR SUBSECRETARIO GENERAL DE GOBIERNO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-29", "doble_articulado": false, "id_norma": "90587", "numero_fuente": "33617", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-03-10", "vigencias": [{"desde": "1990-03-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-03-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-03-10", "fin_vigencia": "", "tipo_versi