{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8329899}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; Por resoluci&#xF3;n N&#xBA;619, de 30 de abril de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA LA PENINSULA S.A.&nbsp; para ampliar actividades pesqueras con la nave &apos;&apos;Loa 1&apos;&apos;, matr&#xED;cula 2276, autorizada por las resoluciones N&#xBA;163 y N&#xBA;857, ambas de 1997, de esta Subsecretar&#xED;a, en el litoral de la I a la IV Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar con red de cerco el recurso hidrobiol&#xF3;gico Bacaladillo o mote.</div><br></div>", "i": 8329900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de abril de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8329901}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "619", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-619"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA LA PENINSULA S.A.", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-04-30", "fecha_derogacion": "2002-11-07", "doble_articulado": false, "id_norma": "98906", "numero_fuente": "36063", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-05-13", "vigencias": [{"desde": "2002-11-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-05-13", "hasta": "2002-11-06", "tipo_version": "0", "tipo_ve