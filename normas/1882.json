{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5845419}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Banco Central de Chile, sobre la base de los antecedentes proporcionados por el Fondo Monetario Internacional y Corfo de Nueva York certifica, a requerimiento de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante, para los efectos de lo dispuesto en el Art&#xED;culo N&#xB0; 116 del Decreto Supremo de la Subsecretar&#xED;a de Marina N&#xB0; 427, de 25 de junio de 1979, que la variaci&#xF3;n experimentada por el Indice de Precios al Consumidor de los Estados Unidos de Am&#xE9;rica, entre el 1&#xB0; de diciembre de 1995 y el 30 de noviembre de 1996, fue de 3,3%.</div><br></div>", "i": 5845420}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 20 de diciembre de 1996.- Jorge Court Larenas, Ministro de Fe (S).</div><br></div>", "i": 5845421}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INDICE DE PRECIOS AL CONSUMIDOR", "ESTADOS UNIDOS DE AMERICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-12-20", "doble_articulado": false, "id_norma": "1882", "numero_fuente": "35648", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-23", "vigencias": [{"desde": "1996-12-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-12-23", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [],