{"html": [{"t": "<div><div class=\"p\">AUTO ACORDADO </div></div>", "i": 6663182}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se comunica que con fecha 14 de octubre de 2008, este Tribunal dict&#xF3; el &quot;Auto Acordado sobre Citaci&#xF3;n, Proceso de Reclamaciones de Nulidad, Solicitudes de Rectificaci&#xF3;n, Formaci&#xF3;n de Escrutinio General, Calificaci&#xF3;n y Proclamaci&#xF3;n de Candidatos Electos con motivo de las Elecciones Municipales&quot; y derog&#xF3; el Auto Acordado dictado con fecha 7 de octubre de 2004.</div><div class=\"p\">&nbsp; &nbsp;  El texto del nuevo Auto Acordado aparece publicado en la p&#xE1;gina web de este Tribunal, www.tribunalelectoral.cl.</div><br></div>", "i": 6663183}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mario Steffens Fortune, Secretario Relator. </div></div>", "i": 6663184}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "4", "numero": "S/N", "abreviacion": "AA", "descripcion": "Auto Acordado", "compuesto": "AA-S/N"}], "organismos": ["SEGUNDO TRIBUNAL ELECTORAL REGIÓN METROPOLITANA"], "titulo_norma": "AUTO ACORDADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-10-14", "doble_articulado": false, "id_norma": "280347", "numero_fuente": "39197", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-10-25", "vigencias": [{"desde": "2008-10-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-10-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-10-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}]