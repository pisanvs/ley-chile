{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede pensi&#xF3;n a don Luis Carrasco Escudero, ex-guardi&#xE1;n de la Polic&#xED;a de Tarapac&#xE1;.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br></div>", "i": 8277352}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia al ex-guardi&#xE1;n de la polic&#xED;a de Tarapac&#xE1;, don Luis Carrasco Escudero, el derecho a disfrutar de una pensi&#xF3;n mensual de retiro de ochenta pesos, con exclusi&#xF3;n de toda otra pensi&#xF3;n o asignaci&#xF3;n fiscal&quot;.</div><br></div>", "i": 8277353}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto en todas sus partes como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintitres de Enero de mil novecientos veintiocho.- CARLOS IBA&#xD1;EZ C.- Enrique Balmaceda. </div></div>", "i": 8277354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4260", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4260"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONCEDE PENSION A DON LUIS CARRASCO ESCUDERO, EX-GUARDIAN DE LA POLICIA DE TARAPACA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LUIS CARRASCO ESCUDERO", "PENSION RETIRO", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1928-01-23", "doble_articulado": false, "id_norma": "24611", "numero_fuente": "14990", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1928-02-03", "vigencias": [{"desde": "1928