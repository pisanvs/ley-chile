{"html": [{"t": "<div><div class=\"p\">MODIFICA LA LEY N.o 10.841 </div><br><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div></div>", "i": 5981656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico.- Reempl&#xE1;zase en el inciso primero del art&#xED;culo &#xFA;nico de la ley N.o 10.841, la expresi&#xF3;n &quot;2a. clase&quot;, por &quot;1a. clase&quot;.&quot;.</div><br><br></div>", "i": 5981657}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a treinta de Marzo de mil novecientos setenta y uno.- SALVADOR ALLENDE GOSSENS.- Am&#xE9;rico Zorrilla R.</div><div class=\"p\">&nbsp; &nbsp; Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud.- Patricio Morales Salinas, Subsecretario de Hacienda.</div><br></div>", "i": 5981658}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17421", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17421"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY N.o 10.841", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["APROBACION MODIFICACION", "LEY 10.841", "JUBILACION", "ADELA ARANGUIZ RAVANAL AL SIGUIENTE PROYECTO DE LEY:"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1971-03-30", "doble_articulado": false, "id_norma": "29002", "numero_fuente": "27920", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1971-04-13", "vigencias": [{"desde": "1971-04-13", "hasta": "", "tipo_