{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6746089}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.539, de 12 de diciembre</div><div class=\"p\">de 2007, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad</div><div class=\"p\">parcial de la resoluci&#xF3;n N&#xBA; 2.764 de 2007, de esta</div><div class=\"p\">Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a PESCA CHILE</div><div class=\"p\">S.A. para realizar actividades pesqueras extractivas con</div><div class=\"p\">una nave en construcci&#xF3;n, en el &#xE1;rea mar&#xED;tima del</div><div class=\"p\">litoral comprendido entre el paralelo 37&#xB0; L.S. y el</div><div class=\"p\">l&#xED;mite sur de la X Regi&#xF3;n, sobre el recurso Besugo</div><div class=\"p\">Epigonus crassicaudus, en virtud de lo dispuesto en el</div><div class=\"p\">art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 6746090}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de diciembre de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6746091}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3539 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3539 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-12", "doble_articulado": false, "id_norma": "267719", "numero_fuente": "38939", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-12-18", "vigencias": [{"desde": "200