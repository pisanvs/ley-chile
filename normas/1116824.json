{"html": [{"t": "<div><br><div class=\"p\">DELEGA FACULTADES QUE INDICA</div></div>", "i": 9903180}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  En virtud de lo dispuesto en la resoluci&#xF3;n exenta N&#xBA; 48, de 28-04-2006, del Director del Servicio de Impuestos Internos, la suscrita ha dictado la resoluci&#xF3;n exenta N&#xBA; 212, de 28-03-2018, delegando en los funcionarios indicados en lo resolutivo la facultad de autorizar a contribuyentes que lo soliciten, el pago diferido de los impuestos de la Ley de la Renta A&#xF1;o Tributario 2018 y deroga la <a href=\"https://www.leychile.cl/Navegar?idNorma=1101338&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 136, de fecha 21-03-2017</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se ha publicado en la oficina virtual del Servicio de Impuestos Internos en internet (www.sii.cl).</div><br></div>", "i": 9903181, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lidia Castillo Alarc&#xF3;n, Directora Regional.</div></div>", "i": 9903182}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "212 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-212 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "DELEGA FACULTADES QUE INDICA", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1377199", "EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2018-03-28", "fecha_derogacion": "2019-04-02", "doble_articulado": false, "id_norma": "1116824", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2018-04-06", "vigencias": [{"d