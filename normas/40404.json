{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DELEGA FACULTADES QUE INDICA </div></div>", "i": 6026744}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n N&#xB0; Ex. 3.848 de 30 de septiembre de 1994, el suscrito deleg&#xF3; en el Jefe del Departamento de Resoluciones Regional la facultad de autorizar las disminuciones de capital solicitadas por las sociedades conforme a lo dispuesto en el inciso final del Art. 69&#xB0; del C&#xF3;digo Tributario; de acuerdo a Resoluci&#xF3;n N&#xB0; Ex. 003830, de fecha 30 de agosto de 1994, de la Direcci&#xF3;n Nacional, que autoriza delegar en los funcionarios que se&#xF1;ala dichas facultades.-</div><br></div>", "i": 6026745}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Angel Mena Zapata, Director Regional.</div><br></div>", "i": 6026746}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3848", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3848"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DELEGA FACULTADES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SERVICIO IMPUESTOS INTERNOS", "JEFE DEPARTAMENTO RESOLUCIONES REGIONAL", "FACULTAD"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-30", "doble_articulado": false, "id_norma": "40404", "numero_fuente": "34986", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-10-08", "vigencias": [{"desde": "1994-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-10-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_vers