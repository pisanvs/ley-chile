{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 521 EXENTA, DE 2011</div><br></div>", "i": 9127845}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 521, de 3 de marzo de 2011, del Ministerio de Transportes y Telecomunicaciones, se prorroga hasta el 6 de enero de 2012 la vigencia de la <a href=\"https://www.leychile.cl/Navegar?idNorma=1006007&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.920 de 2009</a>, por la cual se establece Per&#xED;metro de Exclusi&#xF3;n en Zonas Urbanas que indica y se dispone del cumplimiento de condiciones espec&#xED;ficas de operaci&#xF3;n y de utilizaci&#xF3;n de v&#xED;as para servicios urbanos de transporte p&#xFA;blico de pasajeros prestados mediante buses en las v&#xED;as ubicadas dentro del mismo, situadas geogr&#xE1;ficamente en el conglomerado urbano de las comunas de Valpara&#xED;so, Vi&#xF1;a del Mar, Quilpu&#xE9;, Villa Alemana y Conc&#xF3;n.- </div></div>", "i": 9127846}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Pedro Pablo Err&#xE1;zuriz Dom&#xED;nguez, Ministro de Transportes y Telecomunicaciones.</div></div>", "i": 9127847}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "521 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-521 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 521 EXENTA, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO."], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-03-03", "doble_articulado": false, "id_norma": "1023974", "numero_fuente": "39919", "tipo_version": "3", "tipo_vers