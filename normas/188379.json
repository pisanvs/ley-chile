{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7284894}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.575, de 19 de julio de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a INDUSTRIA CONSERVERA AGROMAR LIMITADA, para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por resoluci&#xF3;n N&#xBA; 704 de 1995, en orden a incorporar a la planta ubicada en Vicencia N&#xBA; 203, poblaci&#xF3;n Santa Clara, Talcahuano, VIII Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n de Conservas, Semi- conservas, Congelados, Fresco-refrigerado, Deshidratado y Salado, el recurso hidrobiol&#xF3;gico Orange roughy.</div><div class=\"p\">&nbsp; &nbsp;  La materia prima deber&#xE1; provenir de pescadores industriales, debidamente autorizados.</div><br></div>", "i": 7284895}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de julio de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 7284896}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1575", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1575"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-07-19", "doble_articulado": false, "id_norma": "188379", "numero_fuente": "37034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-08-10", "vigencias": [{"desde": "2001-08-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-08-10", "fin_vig