{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7352765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.566, de 28 de agosto de 2007, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; inciso 1&#xBA; de la resoluci&#xF3;n exenta N&#xBA; 2.035 de 2007, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto FIP N&#xBA; 2007-16 denominado &quot;Evaluaci&#xF3;n hidroac&#xFA;stica de Merluza com&#xFA;n, a&#xF1;o 2007&quot;, en el sentido de se&#xF1;alar que la nave participante en la pesca de investigaci&#xF3;n podr&#xE1; extraer una cuota total de 125 toneladas de Merluza com&#xFA;n, en calidad de especie objetivo.</div><br></div>", "i": 7352766}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de agosto de 2007.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 7352767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2566 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2566 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-08-28", "doble_articulado": false, "id_norma": "264461", "numero_fuente": "38857", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-06", "vigencias": [{"desde": "2007-09-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigen