{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9341006}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP (Exento) N&#xBA;301, de 28 de febrero de 2013, y de conformidad a lo dispuesto en el art. 105 del DFL MOP N&#xBA;850 de 1997, se expropi&#xF3; el lote N&#xBA;20, superficie 10.000 m2, rol N&#xBA;1162-76, Comuna de Ancud, para la obra &quot;CONSTRUCCI&#xD3;N PUENTE SOBRE EL CANAL CHACAO Y ACCESOS&quot; PROVINCIA DE CHILO&#xC9;, REGION DE LOS LAGOS. La Comisi&#xF3;n de Peritos integrada por Sonia Catalina Gallegos Blanch, Norm&#xE1;n Estanislao Calder&#xF3;n Pontiggia y Patricio Fernando Casagrande Ulloa, fij&#xF3; el valor de tasaci&#xF3;n con fecha 17 de octubre de 2012, acord&#xE1;ndose la indemnizaci&#xF3;n con su propietaria JUAN AMADO ALMONACID C&#xC1;RDENAS, en la cantidad de $44.834.059.- suma que se pagar&#xE1; al contado.- </div></div>", "i": 9341007}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9341008}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "301 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-301 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-02-28", "doble_articulado": false, "id_norma": "1049766", "numero_fuente": "40522", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-04-01", "vigencias": [{"desde": "2013-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-04-01", "fin_vigencia": ""}, "vigencias_v