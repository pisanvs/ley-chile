{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8289057}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Extractos de Resoluciones Por resoluci&#xF3;n N&#xB0; 996, de 21 de Octubre de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o a contar del 27 de septiembre de 1992, el plazo otorgado a do&#xF1;a FLOR MARIA ALBORNOZ TOBAR, R.U.T. N&#xB0; 4.188.122-4, para operar un centro de cultivo del recurso Salm&#xF3;n plateado, en el numeral 5&#xB0; de la Resoluci&#xF3;n N&#xB0; 1268, de 1991, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor. </div></div>", "i": 8289058}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 21 de Octubre de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8289059}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "996", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-996"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FLOR MARIA ALBORNOZ", "PESCA", "AMPLIACION", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-21", "doble_articulado": false, "id_norma": "31699", "numero_fuente": "34414", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-12", "vigencias": [{"desde": "1992-11-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-11-12", "fin_vigencia": "