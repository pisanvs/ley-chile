{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6564452}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 454, de 9 de febrero de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a EXPORTADORA E IMPORTADORA DE PRODUCTOS MARINOS LIMITADA para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por las resoluciones citadas en Visto, en orden a incorporar a la planta ubicada en Campo Santo, Lote N&#xBA; 42, comuna de Hualqui, provincia de Concepci&#xF3;n, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de Alga seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6564453}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de febrero de 2006.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6564454}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "454 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-454 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-02-09", "doble_articulado": false, "id_norma": "248170", "numero_fuente": "38415", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-03-16", "vigencias": [{"desde": "2006-03-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-03-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-03-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente