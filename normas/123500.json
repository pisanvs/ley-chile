{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6126969}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alberto Espina Otero, Presidente del partido Renovaci&#xF3;n Nacional, y Bruno Baranda Ferran, Secretario del Tribunal Supremo de la colectividad, han informado la modificaci&#xF3;n en la composici&#xF3;n de la Directiva Central del partido, consistente en el nombramiento como primer Vicepresidente de don Alberto Cardemil Herrera, y como Secretario General de don Alberto Naudon del R&#xED;o, en reemplazo de los se&#xF1;ores Angel Fantuzzi Hern&#xE1;ndez y Juan Peribonio Poduje, respectivamente.</div><div class=\"p\">Publicaci&#xF3;n ordenada en virtud a lo establecido en el Auto Acordado del Tribunal Calificador de Elecciones de fecha 27 de junio de 1988, por resoluci&#xF3;n O N&#xBA; 0166, de fecha 13 de agosto de 1998.</div><br></div>", "i": 6126970}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de agosto de 1998.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div><br></div>", "i": 6126971}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "166", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-166"}, {"tipo": "3", "numero": "0-166", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-0-166"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PARTIDOS POLITICOS", "PARTIDO RENOVACION NACIONAL", "DIRECTIVA CENTRAL", "ALBERTO CARDEMIL HERRERA", "ALBERTO NAUDON DEL RIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-13", "doble_articulado": false, "id_norma": "123500", "numero_fuente": "36151", "tipo_version": "3", "tipo_version_s"