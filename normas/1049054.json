{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9334544}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 391, de 8 de febrero de 2013, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA BLUMAR S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Leopardo&quot;, en el &#xE1;rea mar&#xED;tima correspondiente a la VIII Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con arrastre de media agua, donde podr&#xE1; capturar el siguiente recurso hidrobiol&#xF3;gico: Vinciguerria.</div></div>", "i": 9334545}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de febrero de 2013.- Maximiliano Alarma Carrasco, Subsecretario de Pesca y Acuicultura (S.)</div></div>", "i": 9334546}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "391 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-391 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-02-08", "fecha_derogacion": "2014-09-30", "doble_articulado": false, "id_norma": "1049054", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-02-22", "vigencias": [{"desde": "2014-09-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2013-02-22", "hasta": "2014-09-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2014-09-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-02-22", "fin_vigencia": "2014-09-29", "tipo_version": "0"},