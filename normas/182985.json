{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 538 EXENTA, DE&nbsp; 2001 </div></div>", "i": 6326945}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 538, de fecha 23 de enero de 2001, del Ministerio de Educaci&#xF3;n, se declara que el Instituto Profesional de Ciencias y Artes INCA CEA, ha obtenido su plena autonom&#xED;a, con arreglo a las normas que lo rigen y, en consecuencia, puede otorgar independientemente toda clase de t&#xED;tulos profesionales, con excepci&#xF3;n de aquellos que conforme a la ley, requieran haber obtenido el grado de Licenciado. </div></div>", "i": 6326946}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de marzo de 2001.- Patricio Vilaplana Barberis, Subsecretario de Educaci&#xF3;n (S).</div><br></div>", "i": 6326947}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "538 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-538 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 538 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-01-23", "fecha_derogacion": "2020-07-11", "doble_articulado": false, "id_norma": "182985", "numero_fuente": "36917", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-03-20", "vigencias": [{"desde": "2020-07-11", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2001-03-20", "hasta": "2020-07-10", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2020-07-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "20