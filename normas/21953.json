{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Cl&#xED;nica de Matronas establecida en la casa de Maternidad de Santiago</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 84.- Santiago, a 28 de Agosto de 1893.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 8273684}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese la suma de diez mil pesos ($ 10,000) para el sostenimiento i demas gastos que demanden las reformas que se atienden en la cl&#xED;nica de matronas establecida en la Casa de Maternidad de Santiago.</div><br><br></div>", "i": 8273685}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORJE MONTT.- Pedro Montt.</div><br></div>", "i": 8273686}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "84", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-84"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CLINICA DE MATRONAS ESTABLECIDA EN LA CASA DE MATERNIDAD DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CASA MATERNIDAD", "CLINICA MATRONAS", "SANTIAGO", "FINANCIAMIENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-08-28", "doble_articulado": false, "id_norma": "21953", "numero_fuente": "4608", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-08-30", "vigencias": [{"desde": "1893-08-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-0