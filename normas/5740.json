{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Complementa ley 5,005</div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 88.- Santiago, Junio 23 de 1932- Vistas las consideraciones de la nota adjunta, la Junta de Gobierno ha acordado y dicta el siguiente</div><div class=\"p\">&nbsp; &nbsp; Decreto-Ley:</div><br></div>", "i": 7123250}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Agr&#xE9;gase al art&#xED;culo 6.o de la ley n&#xFA;mero 5,005, de 24 de Noviembre de 1931, la siguiente letra:</div><div class=\"p\">&nbsp; &nbsp; &quot;h) Las de los empleados del servicio de la Tesorer&#xED;a General de la Rep&#xFA;blica&quot;.</div><br></div>", "i": 7123251, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese raz&#xF3;n, reg&#xED;strese, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Bolet&#xED;n de las Leyes y Decretos del Gobierno.- CARLOS DAVILA.- A. Cabero.- Nolasco C&#xE1;rdenas.- Enrique Za&#xF1;artu.</div><br></div>", "i": 7123252}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "88", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-88"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Complementa ley 5,005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ADMINISTRACION PUBLICA", "TESORERIA GENERAL REPUBLICA", "PERSONAL", "GRATIFICACIONES", "PERMANENCIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1932-06-23", "doble_articulado": false, "id_norma": "5740", "numero_fuente": "16313", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1932-07-02", "vigencias": [{"desde": "1932-07-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci