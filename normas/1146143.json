{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.911, DE 27 DE MAYO DE 2020, DE LA DIRECCI&#xD3;N NACIONAL DE ADUANAS, QUE MODIFICA EL COMPENDIO DE NORMAS ADUANERAS</div></div>", "i": 10125920}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.911, de 27 de mayo de 2020, del Director Nacional de Aduanas, se modific&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1145425&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 1.746/2020</a>, rectificando el n&#xFA;mero de Anexo relativo al &quot;Formulario de Declaraci&#xF3;n de Admisi&#xF3;n Temporal Repuestos de Aeronave&quot;, por Anexo N&#xBA; 96.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10125921}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10125922}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1911 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1911 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.911, DE 27 DE MAYO DE 2020, DE LA DIRECCIÓN NACIONAL DE ADUANAS, QUE MODIFICA EL COMPENDIO DE NORMAS ADUANERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1768163; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-05-27", "doble_