{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0;27,DE 1988 </div></div>", "i": 8603825}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 27 de 07 de marzo de 1988 se ha modificado, a contar del a&#xF1;o escolar 1988, el decreto supremo exento de Educaci&#xF3;n No. 270 de 1985 que aprob&#xF3; planes y programas de estudio especiales al Liceo Polit&#xE9;cnico B No. 56 de Ca&#xF1;ete, provincia de Arauco, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, en las Especialidades de Contabilidad y Secretariado Administrativo, en el sentido de incorporar en el Plan Electivo de cada uno de los cursos 3&#xB0;, 4&#xB0; y 5&#xB0; a&#xF1;o la asignatura &quot;Taller de Dactilograf&#xED;a&quot; con 2 clases semanales.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio correspondiente a la asignatura &quot;Taller de Dactilograf&#xED;a&quot;.</div><br></div>", "i": 8603826}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de Marzo de 1988.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 8603827}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "27", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-27"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°27,DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-07", "doble_articulado": false, "id_norma": "132571", "numero_fuente": "33052", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-22", "vigencias": [{"desde": "1988-04-22