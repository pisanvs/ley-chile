{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6298850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.745, de 30 de junio de 2000 y en base a la facultad otorgada por el art&#xED;culo 105 del DFL MOP N&#xBA;85O, de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA;15.840, se expropi&#xF3; el lote de terreno N&#xBA;5, para la obra Camino Paso Fronterizo Radman, Kms. 0,00000 al 12,73728, Tierra del Fuego, que figura a nombre de Suc. Alfonso Simnovic Krstulovic, Rol de aval&#xFA;o 671-17, superficie 86.434,01 m2, comuna de Timaukel. La Comisi&#xF3;n de Peritos, fij&#xF3; con fecha 9 de julio de 1998, la indemnizaci&#xF3;n provisional en la cantidad de $2.247.284, la que se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.</div><br></div>", "i": 6298851}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6298852}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2745", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2745"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-06-30", "doble_articulado": false, "id_norma": "174911", "numero_fuente": "36754", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-01", "vigencias": [{"desde": "2000-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-01", "fin_vigencia": ""}, "vigencias_version_nor