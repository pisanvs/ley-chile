{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xB0; 5.853 EXENTA, DE 31 DE OCTUBRE DE 2017</div></div>", "i": 9851315}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por el presente acto administrativo, se ha autorizado, a contar del a&#xF1;o escolar 2018, la readecuaci&#xF3;n del plan y programas especiales de estudio de 1&#xB0; y 2&#xB0; a&#xF1;o de Educaci&#xF3;n Media, al Colegio de los Sagrados Corazones, Padres Franceses de Vi&#xF1;a del Mar, provincia y Regi&#xF3;n de Valpara&#xED;so.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio de la asignatura de Artes Interpretativas para 1&#xB0; y 2&#xB0; a&#xF1;o medio.</div></div>", "i": 9851316}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de noviembre de 2017.- Francisco Jeria Le&#xF3;n, Subsecretario de Educaci&#xF3;n (S).</div></div>", "i": 9851317}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5853 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5853 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 5.853 EXENTA, DE 31 DE OCTUBRE DE 2017", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1305056; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-10-31", "doble_articulado": false, "id_norma": "1111099", "numero_fuente": "41913", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-11-21", "vigencias": [{"desde": "2017-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-11-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-11-21", "fin