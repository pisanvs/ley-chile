{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 2.400 EXENTA, DE 2001 </div></div>", "i": 6328527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 2.400 de 21 de marzo del a&#xF1;o 2001, se ha aprobado al Colegio &apos;&apos;Nuestra Se&#xF1;ora del Huerto&apos;&apos;, comuna de San Joaqu&#xED;n, provincia de Santiago, un plan de estudio para 3&#xBA; a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2001.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores de la Formaci&#xF3;n Diferenciada que se indican en la presente resoluci&#xF3;n.</div><br></div>", "i": 6328528}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de marzo de 2001.- Juan Ruz Ruz, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6328529}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2400 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2400 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 2.400 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-03-21", "doble_articulado": false, "id_norma": "183456", "numero_fuente": "36927", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-03-31", "vigencias": [{"desde": "2001-03-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-03-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-03-31", "fin_vigencia": "", "tipo_version": "3"}], "