{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. 597, DE 1984</div><br><br></div>", "i": 8548951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 157, de 23 de Febrero de 1987, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica el numeral 2 de la resoluci&#xF3;n No. 597, de 12 de diciembre de 1984, de esta Subsecretar&#xED;a, en el sentido de sustituir la frase &quot;en una superficie de 40.000 m2. de fondo de mar&quot; por &quot;en una superficie de 40.024 m2. de fondo de mar&quot;.</div><br></div>", "i": 8548952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Febrero de 1987.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8548953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "157", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-157"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION No. 597, DE 1984", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1987-02-23", "fecha_derogacion": "1994-04-26", "doble_articulado": false, "id_norma": "145764", "numero_fuente": "32717", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1987-03-09", "vigencias": [{"desde": "1994-04-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1987-03-09", "hasta": "1994-04-25", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1994-04-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "198