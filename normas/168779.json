{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 18 EXENTO, DE 2000</div><br><br></div>", "i": 6275642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 18, de fecha 14 de enero de 2000, del Ministerio de Educaci&#xF3;n, se declara aprobado a la Universidad Alberto Hurtado el programa de Magister en Pol&#xED;tica Educativa, conducente al grado acad&#xE9;mico de Magister en Pol&#xED;tica Educativa, para ser impartido en su sede de la ciudad de Santiago, de conformidad al acuerdo adoptado por el Consejo Superior de Educaci&#xF3;n, con fecha 2 de diciembre de 1999.</div><br></div>", "i": 6275643}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 4 de febrero de 2000.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6275644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "18 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-18 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 18 EXENTO, DE 2000", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-01-14", "doble_articulado": false, "id_norma": "168779", "numero_fuente": "36664", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-05-16", "vigencias": [{"desde": "2000-05-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-05-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-05-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MEM", "fecha_ingreso": "2000-05-16", "fe