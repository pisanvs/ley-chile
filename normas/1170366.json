{"html": [{"t": "<div><div class=\"p\">RESOLUCI&#xD3;N N&#xBA; 2.945 EXENTA, DE 16.12.2021, DEL DIRECTOR NACIONAL DE ADUANAS, QUE PRORROGA EL PLAZO PARA EFECTUAR LA RENOVACI&#xD3;N DE CARN&#xC9;S ADUANEROS</div></div>", "i": 10295767}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.945, de 16.12.2021, del Director Nacional de Aduanas, se prorroga el plazo para efectuar la renovaci&#xF3;n de carn&#xE9;s aduaneros.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n exenta N&#xBA; 2.945, de 16.12.2021, se encuentra publicado en el sitio web del Servicio Nacional de Aduanas: www.aduana.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10295768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de diciembre de 2021.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div><div class=\"p\"> </div><br></div>", "i": 10295769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2945 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2945 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "RESOLUCIÓN Nº 2.945 EXENTA, DE 16.12.2021, DEL DIRECTOR NACIONAL DE ADUANAS, QUE PRORROGA EL PLAZO PARA EFECTUAR LA RENOVACIÓN DE CARNÉS ADUANEROS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2060670", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-16", "doble_articulado": false, "id_norma": "1170366", "numero_fuente": "43135", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-12-23", "vigencias": [{"desde": "2021-12-23", "hasta":