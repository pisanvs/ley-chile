{"html": [{"t": "<div><br><div class=\"p\">NOTIFICACI&#xD3;N</div></div>", "i": 10180246}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 5.422, de 23 de noviembre de 2020, Serviu Regi&#xF3;n de Valpara&#xED;so, dispuesto expropiaci&#xF3;n conforme al art&#xED;culo 51 ley 16.391 y decreto ley 2.186, de 1978, del inmueble signado como lote 2, Manzana H3, en el plano &quot;Proyecto Expropiaci&#xF3;n Lote Puertas Negras de la Comuna de Valpara&#xED;so&quot;, Regi&#xF3;n de Valpara&#xED;so, para la Ejecuci&#xF3;n del Proyecto &quot;Centro Infantil Comunitario Abierto, Puertas Negras, Valpara&#xED;so&quot; de Presunto Dominio de Sucesi&#xF3;n Juan Cartajena Amarales, rol aval&#xFA;o 2517-1. Comisi&#xF3;n Tasadora integrada por Marcelo Gonz&#xE1;lez Astengo, Carlos Julio Maximiliano Palma Urrutia, y a V&#xED;ctor Calvo Barros, seg&#xFA;n informe de agosto 2020 fij&#xF3; monto indemnizaci&#xF3;n provisional en $22.380.000, que ser&#xE1; pagada al contado.- </div></div>", "i": 10180247}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Director Serviu.</div><div class=\"p\"> </div><br></div>", "i": 10180248}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "5422 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-5422 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAÍSO"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1855442", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-11-23", "doble_articulado": false, "id_norma": "1152462", "numero_fuente"