{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6319423}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;232, de fecha 30 de noviembre de 2000, se expropi&#xF3; el lote de terreno N&#xBA;43-A, superficie 687,0 m&#xB2;, rol de aval&#xFA;o 2205-20, comuna de Puerto Montt, para la obra &quot;Camino Ruta 7 Chamiza-Quillaipe, Tramo Km.</div><div class=\"p\">4,83687 a Km. 15,84700&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Mar&#xED;a Lidia Soto N&#xFA;&#xF1;ez, ascendente a la cantidad de $1.326.385.-</div><br></div>", "i": 6319424}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6319425}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "232", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-232"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-11-30", "doble_articulado": false, "id_norma": "181047", "numero_fuente": "36877", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-02-01", "vigencias": [{"desde": "2001-02-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-02-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-02-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-02-02", "fecha_version": "2001-02-01", "fecha_actualizacion_texto": "2001-02-01", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estr