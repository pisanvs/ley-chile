{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; ACUERDO ADOPTADO POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xB0; 390</div><div class=\"p\">&nbsp; &nbsp; 390E-05-941129 - Modifica Cap&#xED;tulos III.A.1 y III.A.1.1 del Compendio de Normas Financieras </div></div>", "i": 5843697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Se acord&#xF3; incorporar como segunda &quot;Norma Transitoria&quot;, al final de los Cap&#xED;tulos III.A.1 y III.A.1.1 del Compendio de Normas Financieras, la siguiente:</div><div class=\"p\">&nbsp; &nbsp; &quot;Norma Transitoria El encaje mantenido al 29 de noviembre de 1994 en monedas extranjeras distintas al d&#xF3;lar de los Estados Unidos de Am&#xE9;rica, deber&#xE1; disminuirse de manera que, al 9 de enero de 1995, dicho encaje est&#xE9; constituido exclusivamente en d&#xF3;lares de los Estados Unidos de Am&#xE9;rica.&quot; </div></div>", "i": 5843698}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de noviembre de 1994.- V&#xED;ctor Vial del R&#xED;o, Ministro de Fe.</div><br></div>", "i": 5843699}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "390", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-390"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDO BANCO CENTRAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ACUERDO", "BANCO CENTRAL CHILE", "MODIFICACION", "COMPENDIO NORMAS FINANCIERAS", "ENCAJE BANCARIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-11-30", "doble_articulado": false, "id_norma": "217", "numero_fuente": "35030", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-12-01", "vigencias": [{"desde": "1994-12-01", "hasta": "", "tipo_version": "3", "