{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 284 EXENTO, DE 1996 </div></div>", "i": 7161482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 284, de 20 de mayo de 1996, se ha aprobado un plan especial de estudio para la ense&#xF1;anza b&#xE1;sica y media human&#xED;stico-cient&#xED;fica, al Colegio &quot;Padres Franceses&quot; de Vi&#xF1;a del Mar, que se aplicar&#xE1; a partir del a&#xF1;o escolar 1996.</div><div class=\"p\">&nbsp; &nbsp; Adem&#xE1;s, se aprueban programas de estudio para las asignaturas de F&#xED;sica y Computaci&#xF3;n.</div><br></div>", "i": 7161483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 29 de mayo de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161484}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "284 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-284 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 284 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES ESTUDIOS", "COLEGIO PADRES FRANCESES", "VI A DEL", "MAR", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-05-20", "doble_articulado": false, "id_norma": "20890", "numero_fuente": "35534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-08-05", "vigencias": [{"desde": "1996-08-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-08-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-08-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pend