{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION QUE INDICA </div></div>", "i": 6271940}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 1.412, de 30.11.87, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deroga la resoluci&#xF3;n No. 56, de 1979, de esta Subsecretar&#xED;a, en lo que se refiere a la autorizaci&#xF3;n concedida a trav&#xE9;s de dicho instrumento a don Delf&#xED;n C&#xE1;rcamo Alvarado, domiciliado en San Antonio 266, Ancud, para instalar y operar un establecimiento destinado a la crianza, cultivo, reproducci&#xF3;n y engorda de Ostra y Choro, en San Juan de Chadmo, Castro, Provincia de Chilo&#xE9;, X Regi&#xF3;n, por renuncia de su titular.</div><br></div>", "i": 6271941}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30.11.87.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 6271942}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1412", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1412"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DEROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-11-30", "doble_articulado": false, "id_norma": "167648", "numero_fuente": "32942", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-12-11", "vigencias": [{"desde": "1987-12-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-12-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-12-11"