{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6362439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 1.817, de 31 de octubre de 2001, se expropi&#xF3; el lote de terreno N&#xBA; 17-1, superficie 407 m2, rol de aval&#xFA;o 118-50, comuna de Quilicura, para la obra Camino Santiago-Colina-Los Andes, sector &quot;A&quot;, A. Vespucio-By Pass Colina, Regi&#xF3;n Metropolitana y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietario Arturo Jos&#xE9; Amen&#xE1;bar Vives, ascendente a la cantidad de $10.469.200.- el que se pagar&#xE1; mediante la entrega en compensaci&#xF3;n del terreno individualizado como lote N&#xBA; 17-2 en el plano y cuadro de compensaci&#xF3;n.</div><br></div>", "i": 6362440}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6362441}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1817", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1817"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-31", "doble_articulado": false, "id_norma": "192904", "numero_fuente": "37136", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-12-15", "vigencias": [{"desde": "2001-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingres