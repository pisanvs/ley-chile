{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8318251}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.782, de 30 de diciembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 51 de 1990 de esta Subsecretar&#xED;a, que autoriz&#xF3; a don ATILIO BERMUDEZ VALDERRAMA, para realizar actividades pesqueras extractivas con la nave &quot;Agua Luna&quot;, por no haber operado sobre la unidad de pesquer&#xED;a autorizada de conformidad a lo dispuesto en el art&#xED;culo 143 letras b) y d) de la Ley General de Pesca y Acuicultura. </div></div>", "i": 8318252}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8318253}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1782", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1782"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "ATILIO BERMUDEZ VALDERRAMA", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-30", "doble_articulado": false, "id_norma": "86900", "numero_fuente": "35961", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-01-10", "vigencias": [{"desde": "1998-01-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-01-10", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-01-10", "f