{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE EMISOR ELECTR&#xD3;NICO</div><br><br></div>", "i": 7354269}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;112 de 20 de septiembre de 2007, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como emisor electr&#xF3;nico.</div><br><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n del representante legal del contribuyente RUT N&#xBA; 76.071.330-9, se deroga autorizaci&#xF3;n otorgada para operar como emisor de Documentos Tributarios Electr&#xF3;nicos.</div><br><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de septiembre, de 2007. </div></div>", "i": 7354270}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "112 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-112 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "DEROGA AUTORIZACIÓN DE EMISOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-09-20", "doble_articulado": false, "id_norma": "264992", "numero_fuente": "38869", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-09-24", "vigencias": [{"desde": "2007-09-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-09-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "200