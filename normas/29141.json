{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DENOMINA &quot;MARTA BRUNET CARAVES&quot; AL LICEO DE NI&#xD1;AS N&#xB0; 1 DE CHILLAN</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5982211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Denom&#xED;nase &quot;Marta Brunet Caraves&quot; al Liceo de Ni&#xF1;as N&#xB0; 1, de Chill&#xE1;n.</div><br></div>", "i": 5982212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, diez de Enero de mil novecientos setenta y dos.- SALVADOR ALLENDE GOSSENS.- Mario Astorga Guti&#xE9;rrez, Ministro de Educaci&#xF3;n.-</div><div class=\"p\">&nbsp; &nbsp; Saluda a U.- Waldo Su&#xE1;rez Zambont, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5982213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "17601", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-17601"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "DENOMINA MARTA BRUNET CARAVES AL LICEO DE NIÑAS N° 1 DE CHILLAN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["NOMBRE", "LICEO NI AS MARTA BRUNET CARAVES", "CHILLAN"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1972-01-10", "doble_articulado": false, "id_norma": "29141", "numero_fuente": "28152", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1972-01-18", "vigencias": [{"desde": "1972-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni