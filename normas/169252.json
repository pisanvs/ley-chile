{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6277145}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 708, de 29 de Octubre de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza al Sr. Jos&#xE9; Amado Moreno Araneda para prestar todo tipo de servicios de transportes de pasajeros, por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6277146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gast&#xF3;n Alvarez Briones Secretario Regional Ministeriai de Transportes y Telecomunicaciones VIII Regi&#xF3;n del B&#xED;o B&#xED;o. </div></div>", "i": 6277147}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "708 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-708 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-29", "doble_articulado": false, "id_norma": "169252", "numero_fuente": "32919", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-13", "vigencias": [{"desde": "1987-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-13", "fin_vigencia": "", "tipo_ver