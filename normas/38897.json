{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DELEGA EN FUNCIONARIOS QUE INDICA, FACULTAD QUE SE&#xD1;ALA </div></div>", "i": 6022364}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n Ex. N&#xB0; 418 de 6 de Marzo de 1995, la suscrita deleg&#xF3; en funcionarios que en la ya citada Resoluci&#xF3;n se individualizan la facultad de autorizar las disminuciones de capital solicitadas por las Sociedades, de conformidad a lo dispuesto en el inciso final del Art&#xED;culo 69&#xB0; del C&#xF3;digo Tributario, todo ello de acuerdo a Resoluci&#xF3;n Ex. N&#xB0; 394 de 23 de Enero de 1995 del se&#xF1;or Director del Servicio, que autoriza a delegar en los funcionarios que se&#xF1;ala dicha facultad.-</div><br></div>", "i": 6022365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julia Altamirano Santib&#xE1;&#xF1;ez, Directora Regional. </div></div>", "i": 6022366}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "418", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-418"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DELEGA EN FUNCIONARIOS QUE INDICA, FACULTAD QUE\nSEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FACULTAD", "FUNCIONARIO", "SERVICIO IMPUESTOS INTERNOS", "DELEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-03-06", "doble_articulado": false, "id_norma": "38897", "numero_fuente": "35125", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-03-23", "vigencias": [{"desde": "1995-03-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-03-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-03-23", "fin_vigenci