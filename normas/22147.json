{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 296.- Santiago, a 4 de Setiembre de 1895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese, por gracia, a do&#xF1;a Petronila Due&#xF1;as v. de Herrera, hija del capitan de artiller&#xED;a de la Independencia don Rafael Due&#xF1;as, derecho para gozar de la pension vacante por fallecimiento de su se&#xF1;ora madre.</div><div class=\"p\">&nbsp; &nbsp; Esta pension cesar&#xE1; si alguna otra persona de la familia se presentare reclamando este derecho con arreglo a la lei.</div><br><br></div>", "i": 5947440}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- Jorje Montt.- Ismael Valdes Valdes.</div><br></div>", "i": 5947441}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "296", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-296"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PETRONILA DUE AS VIUDA DE HERRERA", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-09-04", "doble_articulado": false, "id_norma": "22147", "numero_fuente": "5208", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-09-10", "vigencias": [{"desde": "1895-09-10", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio