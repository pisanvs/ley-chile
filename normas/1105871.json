{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO</div></div>", "i": 9820769}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP N&#xB0; 711, de 13 de julio de 2017, se modific&#xF3; el numeral tercero del <a href=\"https://www.leychile.cl/Navegar?idNorma=1104746&amp;idParte=0&amp;idVersion=\">Decreto (Exento) MOP N&#xB0; 469, de 08 de junio de 2017</a>, en donde dice &quot;Resoluci&#xF3;n D.G.O.P. (Exenta) N&#xB0; 4993, de 24 de mayo de 2015&quot;, debe decir &quot;Resoluci&#xF3;n D.G.O.P. (Exenta) N&#xB0; 4993, de 24 de noviembre de 2015&quot;. </div></div>", "i": 9820770}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 9820771}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "711 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-711 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "SUBSECRETARÍA DE OBRAS PÚBLICAS", "FISCALÍA", "DIVISIÓN EXPROPIACIONES"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1249018; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2017-07-13", "doble_articulado": false, "id_norma": "1105871", "numero_fuente": "41823", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2017-08-01", "vigencias": [{"desde": "2017-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2017-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2017-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1795", "fe