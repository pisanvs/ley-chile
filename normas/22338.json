{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Sacos metaleros.- Se declaran libres de Derechos de Internacion</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,003.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5948135}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Decl&#xE1;ranse libres de derechos de aduanas los sacos vac&#xED;os metaleros.</div><br><br></div>", "i": 5948136}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, ordeno que se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 21 de Enero de 1898.- FEDERICO ERRAZURIZ.- Alberto Gonzalez E.</div><br></div>", "i": 5948137}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1003", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1003"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "Sacos metaleros.- Se declaran libres de Derechos de;Internacion", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SACOS METALEROS", "DERECHOS INTERNACION", "LIBERACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-01-21", "doble_articulado": false, "id_norma": "22338", "numero_fuente": "5908", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-21", "vigencias": [{"desde": "1898-01-21", "h