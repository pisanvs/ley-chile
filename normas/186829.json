{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6339849}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 947, de 15 de mayo de 2001, de esta Subsecretar&#xED;a, autor&#xED;zase a JUAN ALBERTO ARACENA MU&#xD1;OZ, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en calle Freire N&#xBA; 1214, Coyhaique, XI Regi&#xF3;n, donde podr&#xE1; procesar en las l&#xED;neas de elaboraci&#xF3;n que se indican, los siguientes recursos hidrobiol&#xF3;gicos: Ahumado y conserva: Salm&#xF3;n plateado, Trucha arcoiris, Salm&#xF3;n del Atl&#xE1;ntico y Salm&#xF3;n rey.</div><div class=\"p\">&nbsp; &nbsp;  Los recursos hidrobiol&#xF3;gicos Salm&#xF3;n del Atl&#xE1;ntico, Salm&#xF3;n plateado, Salm&#xF3;n rey y Trucha arcoiris, deber&#xE1;n provenir de centros de cultivos autorizados.</div><br></div>", "i": 6339850}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 15 de mayo de 2001.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6339851}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "947", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-947"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-15", "doble_articulado": false, "id_norma": "186829", "numero_fuente": "36994", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-06-23", "vigencias": [{"desde": "2001-06-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vig