{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; N&#xFA;m. 732.- Santiago, 1.o de diciembre de 1925.- Visto lo dispuesto en el decreto-lei n&#xFA;mero 618, de 17 de octubre pr&#xF3;ximo pasado, y de acuerdo con el Consejo de Ministros del Despacho,</div><div class=\"p\">&nbsp; &nbsp; dicto el siguiente DECRETO-LEI:</div><br></div>", "i": 8256534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo 1.o Agr&#xE9;gase al Presupuesto de Interior vijente, el siguiente &#xED;tem:</div><div class=\"p\">&nbsp; &nbsp; &quot;Para atender a los gastos que demande la celebracion del Centenario de Chilo&#xE9;, cien mil pesos ($ 100,000).&quot; </div></div>", "i": 8256535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art. 2.o Conc&#xE9;dese un suplemento de treinta mil pesos ($ 30,000) al &#xED;tem 5632 de la partida 12 del presupuesto del espresado Departamento </div></div>", "i": 8256536}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; T&#xF3;mese razon, comun&#xED;quese, publ&#xED;quese e ins&#xE9;rtese en el Boletin de las Leyes y Decretos del Gobierno.- Luis Barros Borgo&#xF1;o.- Manuel E. V&#xE9;lis.</div><br></div>", "i": 8256537}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "15", "numero": "732", "abreviacion": "DL", "descripcion": "Decreto Ley", "compuesto": "DL-732"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO GASTOS NACION", "A O", "1925", "MODIFICACION MINISTERIO INTERIOR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1925-12-01", "doble_articulado": false, "id_norma": "6314", "numero_fuente": "14336", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1925-12-01", "vigencias": [{"desde": "1925-12