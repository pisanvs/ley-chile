{"html": [{"t": "<div><div class=\"p\">AUTORIZA, POR CAUSA DE FUERZA MAYOR, LA APLICACI&#xD3;N DE MEDIDAS QUE INDICA</div></div>", "i": 10111036}, {"t": "<div><br><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 614, de 20 de marzo de 2020, del Servicio Nacional de Pesca y Acuicultura, se autoriza, por causa de fuerza mayor, la aplicaci&#xF3;n de medidas que indica.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la resoluci&#xF3;n se encuentra en los sitios de dominio electr&#xF3;nico del Servicio y de la Subsecretar&#xED;a de Pesca y Acuicultura.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10111037}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Alicia Gallardo Lagno, Directora Nacional.</div><br></div>", "i": 10111038}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "614", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-614"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA", "SERVICIO NACIONAL DE PESCA Y ACUICULTURA", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA, POR CAUSA DE FUERZA MAYOR, LA APLICACIÓN DE MEDIDAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1745670; EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2020-03-20", "fecha_derogacion": "2021-11-23", "doble_articulado": false, "id_norma": "1143843", "numero_fuente": "42617", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2020-03-28", "vigencias": [{"desde": "2021-11-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2020-03-28", "hasta": "2021-11-22", "tipo_version": "0", "tipo_versi