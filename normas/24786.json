{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Aumenta la pensi&#xF3;n de que actualmente disfruta do&#xF1;a Emilia Laing v. de Eusquiza</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de Ley:</div><br><br></div>", "i": 7169457}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Aum&#xE9;ntase, por gracia, a seis mil pesos anuales, la pensi&#xF3;n que actualmente disfruta do&#xF1;a Emilia Laing, viuda del capit&#xE1;n de fragata don Demetrio Eusquiza, de la que continuar&#xE1; gozando con arreglo a la Ley de Montep&#xED;o Militar.</div><br></div>", "i": 7169458}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, treinta y uno de Julio de mil novecientos veintinueve.- CARLOS IBA&#xD1;EZ C.- Carlos O. Fr&lt;odden. </div></div>", "i": 7169459}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "4628", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-4628"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "AUMENTA LA PENSION DE QUE ACTUALMENTE DISFRUTA DOÑA EMILIA LAING V. DE EUSQUIZA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EMILIA LAING VIUDA DE EUSQUIZA", "PENSION POR GRACIA", "REAJUSTE", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1929-07-31", "doble_articulado": false, "id_norma": "24786", "numero_fuente": "15448", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1929-08-14", "vigencias": [{"desde": "1929-08-14", "hasta": 