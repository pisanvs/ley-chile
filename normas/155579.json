{"html": [{"t": "<div><div class=\"p\">AUTORIZA AL INSTITUTO DE FOMENTO PESQUERO PARA DESARROLLAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 6232522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 111, de 06 de Febrero de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza al Instituto de Fomento Pesquero domiciliado en Santiago, para instalar y operar un establecimiento de cultivo de alga Gracilaria sp. en dos sectores ubicados en el lugar denominado Contao, Comuna de Hualaihu&#xE9;, Provincia de Palena, X Regi&#xF3;n de 70.000 m2 y 20.000 m2 respectivamente.</div><br></div>", "i": 6232523}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 06 de Febrero de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 6232524}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "111", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-111"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA AL INSTITUTO DE FOMENTO PESQUERO PARA\nDESARROLLAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-02-06", "fecha_derogacion": "1988-06-21", "doble_articulado": false, "id_norma": "155579", "numero_fuente": "32402", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-02-19", "vigencias": [{"desde": "1988-06-21", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-02-19", "hasta": "1988-06-20", "tipo_version": "0", "tipo_version_s": "Texto Origin