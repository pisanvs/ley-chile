{"html": [{"t": "<div><div class=\"p\">MODIFICA CONCESI&#xD3;N DE ACUICULTURA </div></div>", "i": 8440149}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n (M) 1.420, de 13/11/2008, modific&#xF3; Res. (M) 1.968/1996, transferida a su actual titular por Res. (M) 404/2002, de la siguiente forma: Donde dice: en el lugar denominado Estero Rulo, debe decir: ubicada en Estero Rulo, al Este de Punta Metrencue, superficie 15,00 H&#xE1;s.; coordenadas geogr&#xE1;ficas Carta S.H.O.A. N&#xBA; 7310, 4&#xAA; edici&#xF3;n, 1999 (Datum WGS-84).</div><br><div class=\"p\">V&#xE9;rtice A Lat. 41&#xB0;43&apos;.43,03&quot; S. Long. 73&#xB0;05.&apos;26,13&quot; W., </div><div class=\"p\">V&#xE9;rtice B Lat. 41&#xB0;43&apos;.18,51&quot; S. Long. 73&#xB0;05&apos;.14,83&quot; W., </div><div class=\"p\">V&#xE9;rtice C Lat. 41&#xB0;43&apos;.20,63&quot; S. Long. 73&#xB0;05.&apos;06,65&quot; W., </div><div class=\"p\">V&#xE9;rtice D Lat. 41&#xB0;43&apos;.42,08&quot; S. Long. 73&#xB0;05&apos;.16,54&quot; W. </div></div>", "i": 8440150}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de diciembre de 2008.- Humberto Ram&#xED;rez Navarro, Subjefe Subsecretar&#xED;a de Marina. </div></div>", "i": 8440151}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1420", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1420"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARIA DE MARINA"], "titulo_norma": "MODIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-11-13", "doble_articulado": false, "id_norma": "284398", "numero_fuente": "39252", "tipo_version": "3", "tipo_version_s": "Única