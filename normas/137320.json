{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 2,346.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br></div>", "i": 6171553}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados durante la &#xE9;poca de la Independencia por el teniente de Ej&#xE9;rcito, don Vicente Palomera, conc&#xE9;dese, por gracia, a su hija soltera do&#xF1;a Catalina Palomera i L&#xF3;pez derecho a disfrutar una pensi&#xF3;n anual de mil pesos ($ 1,000) en vez del montep&#xED;o de teniente que actualmente percibe.&quot; </div></div>", "i": 6171554}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, once de agosto de mil novecientos diez.-</div><div class=\"p\">El&#xED;as Fern&#xE1;ndez Albano.- C&#xE1;rlos Larrain Claro. </div></div>", "i": 6171555}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2346", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2346"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1910-08-11", "doble_articulado": false, "id_norma": "137320", "numero_fuente": "9774", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1910-08-22", "vigencias": [{"desde": "1910-08-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1910-08-22", "fin_vi