{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9363707}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.488, de 13 de junio de 2013, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA B&#xCD;O B&#xCD;O S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Biomar V&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la IV Regi&#xF3;n y el paralelo 41&#xBA;28,6&apos; L.S., por fuera del &#xE1;rea de reserva artesanal, con arrastre, los siguientes recursos hidrobiol&#xF3;gicos: Mict&#xF3;fido Triphoturus mexicanus, Mict&#xF3;fido Diogenichthys sp., Mict&#xF3;fido Ceratoscopelus sp., Mict&#xF3;fido Diaphus sp., Mict&#xF3;fido Gonichthys sp., Mict&#xF3;fido Gymnoscopelus sp., Mict&#xF3;fido Hygophum sp., Mict&#xF3;fido Lampadena sp., Mict&#xF3;fido Lampanyctus sp. y Mict&#xF3;fido Myctophum sp.</div></div>", "i": 9363708}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de junio de 2013.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9363709}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1488 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1488 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2013-06-13", "fecha_derogacion": "2013-12-24", "doble_articulado": false, "id_norma": "1052694", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2013-07-05", "vigencias": [{"desde": "2013-12-24", "hasta": "", "tipo_version": "2", "tipo_version