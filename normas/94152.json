{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br></div>", "i": 8324352}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n N&#xB0; 52, de 16 de Enero de 1989, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, fomento y Reconstrucci&#xF3;n, se modifica la resoluci&#xF3;n N&#xB0; 1.174, de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Pesquera Iquique S.A., R.U.T. N&#xB0; 91.123.000-3, domiciliada en Santiago, para ampliar actividades pesqueras de extracci&#xF3;n, en cuanto se sustituye en su numeral 2&#xB0; el nombre de la embarcaci&#xF3;n &quot;Transporteur&quot; por &quot;Curanipe&quot; y, en lo relativo a la matr&#xED;cula de dicha nave, el n&#xFA;mero &quot;2211&quot; por el n&#xFA;mero &quot;2549&quot;.</div><br></div>", "i": 8324353}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 16 de Enero de 1989.- Roberto C&#xE1;bezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8324354}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "52", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-52"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1989-01-16", "fecha_derogacion": "1996-12-24", "doble_articulado": false, "id_norma": "94152", "numero_fuente": "33282", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1989-01-26", "vigencias": [{"desde": "1996-12-24", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1989-01-26", "hasta": "1996-12-23", "tipo_v