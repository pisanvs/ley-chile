{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">ANEXA TABLAS DE COEFICIENTES GU&#xCD;AS DE TERRENO A PLANO DE PRECIOS DE LA COMUNA DE MELIPILLA CONTENIDO EN LA RESOLUCI&#xD3;N N&#xBA; 108 EXENTA, DE 2013&nbsp;  </div></div>", "i": 9500155}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 84, del 22 de agosto de 2014, que dispone:&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  An&#xE9;xese al plano de precios de terrenos de la comuna de Melipilla, contenido en la <a href=\"https://www.leychile.cl/Navegar?idNorma=1057855&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 108, de 27.12.2013</a>, las tablas de Coeficientes Gu&#xED;as de Terreno de dicha comuna.&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en internet, www.sii.cl, y aparecer&#xE1; en el Bolet&#xED;n del SIl, en el mes de agosto de 2014.</div></div>", "i": 9500156}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "84 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-84 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ANEXA TABLAS DE COEFICIENTES GUÍAS DE TERRENO A PLANO DE PRECIOS DE LA COMUNA DE MELIPILLA CONTENIDO EN LA RESOLUCIÓN Nº 108 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-08-22", "doble_articulado": fa