{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.256 EXENTO, DE 1997 </div></div>", "i": 6106721}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 1.256 de 31 de diciembre de 1997, se ha aprobado al Colegio &quot;British Royal School&quot; de La Reina, Regi&#xF3;n Metropolitana, un plan de estudio para 5&#xBA;, 6&#xBA;, 7&#xBA; y 8&#xBA; a&#xF1;o (NB.3 a NB.6) de Ense&#xF1;anza B&#xE1;sica, que se aplicar&#xE1; de acuerdo con lo se&#xF1;alado en el decreto supremo de Educaci&#xF3;n N&#xBA; 40 de 1996 y sus modificaciones.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los subsectores que se indican en el presente decreto. </div></div>", "i": 6106722}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de diciembre de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6106723}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1256 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1256 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.256 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO BRITISH ROYAL SCHOOL", "LA REINA", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-12-31", "doble_articulado": false, "id_norma": "97619", "numero_fuente": "36013", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-03-12", "vigencias": [{"desde": "1998-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia"