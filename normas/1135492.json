{"html": [{"t": "<div><div class=\"p\">CERTIFICADO N&#xB0; 11</div></div>", "i": 10049772}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Certifico que Productora y Comercializadora de Alimentos Marval Limitada, RUT 76.497.783-1, cumple los requisitos establecidos en la resoluci&#xF3;n exenta N&#xB0; 3.722, del 28/07/2000, de la Direcci&#xF3;n Nacional, publicada en el Diario Oficial del d&#xED;a 01/08/2000 y que, en consecuencia, tiene la calidad de Agente Retenedor del Impuesto al Valor Agregado en las ventas de carnes, a partir del 1&#xB0; del mes siguiente al de la publicaci&#xF3;n de este Certificado en el Diario Oficial.</div></div>", "i": 10049773}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Recoleta, 14 de agosto de 2019.- Vania Uarac Senn, Directora Regional.</div></div>", "i": 10049774}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "11", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-11"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN REGIONAL SANTIAGO NORTE"], "titulo_norma": "CERTIFICADO N° 11", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1645342"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-08-14", "doble_articulado": false, "id_norma": "1135492", "numero_fuente": "42442", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2019-08-30", "vigencias": [{"desde": "2019-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2019-09-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2019-09-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione