{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 154,DE 1988 </div></div>", "i": 6167308}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n No. 154 de 23 de septiembre de 1988 se ha prorrogado, a contar del presente a&#xF1;o escolar, la vigencia del decreto supremo exento de Educaci&#xF3;n No. 235 de 1983, que aprob&#xF3; un plan de estudio especial para los cursos de Educaci&#xF3;n General B&#xE1;sica y de Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica, al Liceo Experimental Manuel de Salas, de Santiago. Santiago, 04 de Octubre de 1988.-</div><br></div>", "i": 6167309}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Ren&#xE9; Salam&#xE9; Mart&#xED;n Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6167310}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "154 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-154 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 154,DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-09-23", "doble_articulado": false, "id_norma": "135992", "numero_fuente": "33208", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-10-29", "vigencias": [{"desde": "1988-10-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-10-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-10-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso":