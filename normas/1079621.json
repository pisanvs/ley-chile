{"html": [{"t": "<div><br><div class=\"p\">DELEGA FACULTADES QUE INDICA</div></div>", "i": 9622730}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta N&#xBA; 612, del 1 de julio de 2015, de la X Direcci&#xF3;n Regional Puerto Montt, que delega en los Jefes de Unidades de Osorno, Puerto Varas, Ancud y Castro, la facultad de aplicar las sanciones administrativas que correspondan respecto de las infracciones tributarias previstas y tipificadas en el art&#xED;culo 97 Nos 15 y 16 y en el art&#xED;culo 109, ambos del C&#xF3;digo Tributario, cuando no se haya reclamado de ellas, como asimismo, para conceder las condonaciones que se soliciten respecto de las sanciones que les corresponda aplicar, siempre que se cumplan las condiciones establecidas en las resoluciones e instrucciones dictadas al efecto.- </div></div>", "i": 9622731}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Cristian G&#xF3;mez Castillo, Director Regional. </div></div>", "i": 9622732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "612 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-612 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "X DIRECCIÓN REGIONAL PUERTO MONTT"], "titulo_norma": "DELEGA FACULTADES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-07-01", "doble_articulado": false, "id_norma": "1079621", "numero_fuente": "41209", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-07-17", "vigencias": [{"desde": "2015-07-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenc