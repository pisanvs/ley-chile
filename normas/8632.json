{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 69, DE 1988 </div></div>", "i": 7135506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento de Educaci&#xF3;n N&#xB0; 69 de 6 de abril de 1988 del Ministerio de Educaci&#xF3;n se autoriz&#xF3; el funcionamiento del Instituto Profesional del Maule cuyo domicilio legal es la ciudad de Talca.</div><div class=\"p\">&nbsp; &nbsp; El Instituto es organizado por la &quot;Sociedad Educacional del Maule Ltda.&quot; o &quot;EDUMAULE Ltda.&quot;, cuyo fin es la docencia en todas las profesiones del &#xE1;rea de la educaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp; Asimismo el decreto mencionado aprob&#xF3; el reglamento a que se refiere el Art. 6&#xB0; del D.F.L. N&#xB0; 5 de 1981 y las condiciones y requisitos para el otorgamiento de los t&#xED;tulos profesionales.-</div><br></div>", "i": 7135507, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 7135508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "69 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-69 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 69, DE 1988", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-06", "doble_articulado": false, "id_norma": "8632", "numero_fuente": "33064", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-05-06", "vigencias": [{"desde": "1988-05-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vi