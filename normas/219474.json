{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A KAISO KOGYO S.A.</div><br></div>", "i": 6456245}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE 08/N&#xBA; Ex. 2.479, de fecha 11 de diciembre de 2003, otorga a Kaiso Kogyo S.A., RUT. N&#xBA;99.521.230-7, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de productos hidrobiol&#xF3;gicos, establecido en la resoluci&#xF3;n N&#xBA; Ex-3311, de 30-06-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 6456246}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Flores Guti&#xE9;rrez, Director Regional </div></div>", "i": 6456247}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2479 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-2479 EXENTA"}, {"tipo": "3", "numero": "DRE-08-2479 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-2479 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A KAISO KOGYO\nS.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-12-11", "doble_articulado": false, "id_norma": "219474", "numero_fuente": "37744", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-12-26", "vi