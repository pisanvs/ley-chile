{"html": [{"t": "<div><div class=\"p\">CANCELA PERSONALIDAD JUR&#xCD;DICA A &quot;ASOCIACI&#xD3;N GREMIAL DE PROCESADORES Y EXPORTADORES DE ALIMENTOS CONGELADOS-AGEPCO A.G.&quot; </div></div>", "i": 7367617}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ministerial N&#xBA; 163, de fecha 31 de diciembre de 2007, se cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n Gremial de Procesadores y Exportadores de Alimentos Congelados-Agepco A.G.&quot;, inscrita bajo el N&#xBA; 1.719, por haberse configurado la causal contemplada en las letras b), c) y d) del n&#xFA;mero 2) del art&#xED;culo 18 del decreto ley N&#xBA;2.757, de 1979.</div><br></div>", "i": 7367618}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rodrigo Hern&#xE1;ndez Ben&#xED;tez, Jefe Unidad Asociaciones Gremiales y Martilleros.</div><br></div>", "i": 7367619}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "163", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-163"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION"], "titulo_norma": "CANCELA PERSONALIDAD JURÍDICA A ASOCIACIÓN GREMIAL DE PROCESADORES Y EXPORTADORES DE ALIMENTOS CONGELADOS-AGEPCO A.G.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-12-31", "doble_articulado": false, "id_norma": "270413", "numero_fuente": "39034", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-04-11", "vigencias": [{"desde": "2008-04-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-04-11", "fin_vigencia": ""}, "vigencia