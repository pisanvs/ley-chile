{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,770</div><br><div class=\"p\">CONCEDE PENSION, POR GRACIA, A DO&#xD1;A EMMA GUERRA HERRERA </div><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6589779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Conc&#xE9;dese, por gracia, a do&#xF1;a Emma Guerra Herrera, una pensi&#xF3;n de $ 1.500 mensuales.</div><div class=\"p\">&nbsp; &nbsp;  El gasto que importe esta ley se imputar&#xE1; al &#xED;tem de pensiones del Presupuesto del Ministerio de Hacienda. </div></div>", "i": 6589780}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a once de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 6589781}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10770", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10770"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "CONCEDE PENSION, POR GRACIA, A DOÑA EMMA GUERRA HERRERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-11", "doble_articulado": false, "id_norma": "255315", "numero_fuente": "22386", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-10-28", "vigencias": [{"desde": "1952-10-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-10-2