{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 101.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5946778}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de setenta mil pesos ($ 70,000) a la partida 38 del presupuesto de Hacienda, para gastos imprevistos.</div><br><br></div>", "i": 5946779}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 11 de Setiembre de 1893.- JORGE MONTT.- Alejandro Vial.</div><br></div>", "i": 5946780}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "101", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-101"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1893", "MODIFICACION GASTOS", "IMPREVISTOS", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-09-11", "doble_articulado": false, "id_norma": "21967", "numero_fuente": "4623", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-09-21", "vigencias": [{"desde": "1893-09-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-09-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1893-09-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "f