{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA YADRAN SOCIEDAD LIMITADA PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br><br></div>", "i": 7266075}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n No. 563, 9 Set. 1985 de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Yadr&#xE1;n Sociedad Limitada, domiciliada en Santiago, para operar la embarcaci&#xF3;n &quot;Yadr&#xE1;n III&quot;, en el litoral comprendido entre la X y XII Regi&#xF3;n en faenas extractivas de congrio colorado, congrio negro, congrio dorado, corvina, tollo, pejegallo, raya, mero, br&#xF3;tula, jurel, r&#xF3;balo, jaiba y centolla.</div><br></div>", "i": 7266076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 Set. 1985. Roberto Verdugo Gormaz, Subsecretario de Pesca </div></div>", "i": 7266077}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "563", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-563"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA YADRAN SOCIEDAD LIMITADA PARA\nAMPLIAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1985-09-09", "fecha_derogacion": "2000-10-23", "doble_articulado": false, "id_norma": "162350", "numero_fuente": "32278", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1985-09-23", "vigencias": [{"desde": "2000-10-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1985-09-23", "hasta": "2000-10-22", "tipo_version": "0", "tipo_v