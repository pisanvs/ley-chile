{"html": [{"t": "<div><div class=\"p\">APRUEBA REFORMA DE ESTATUTOS DE &quot;ISE COMPA&#xD1;IA DE SEGUROS GENERALES S.A.&quot; </div></div>", "i": 6070113}, {"t": "<div><div class=\"p\">Certifico: Que por resoluci&#xF3;n No. 173, de fecha 31.07.92, se aprob&#xF3; la reforma de estatutos de la sociedad an&#xF3;nima &quot;ISE Compa&#xF1;&#xED;a de Seguros Generales S.A.&quot;, que consta en la escritura p&#xFA;blica de fecha 27 de Julio de 1992, otorgada en la Notaria de Santiago de don Hugo Leonardo P&#xE9;rez Pousa. La reforma consiste en:</div><div class=\"p\">Disminuir de 7 a 5 el n&#xFA;mero de miembros del directorio. </div></div>", "i": 6070114}, {"t": "<div><div class=\"p\">Santiago, 31.07.92.- Rodrigo O. Costa Aranda, Secretario General.</div><br></div>", "i": 6070115}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "173", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-173"}], "organismos": ["MINISTERIO DE HACIENDA", "SUPERINTENDENCIA DE VALORES Y SEGUROS"], "titulo_norma": "APRUEBA REFORMA DE ESTATUTOS DE ISE COMPAÑIA DE SEGUROS GENERALES S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-07-31", "doble_articulado": false, "id_norma": "85327", "numero_fuente": "34340", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-12", "vigencias": [{"desde": "1992-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-08-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-08-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "MNV", "fecha_ingreso"