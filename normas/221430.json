{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A JULIO RENE VEGA CARVAJAL </div></div>", "i": 6465379}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA;46, de fecha 4 de febrero de 2004, otorga la calidad de Agente Retenedor de IVA en la actividad de la Construcci&#xF3;n a Julio Ren&#xE9; Vega Carvajal, RUT N&#xBA;2.766.677-9, resoluci&#xF3;n que entrar&#xE1; en vigencia a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido por la resoluci&#xF3;n Ex. N&#xBA;46 del 1 de septiembre del 2003, de la Direcci&#xF3;n Nacional.</div><br></div>", "i": 6465380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Luis Mu&#xF1;oz Arratia, Director Regional. </div></div>", "i": 6465381}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "46", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-46"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A JULIO RENE\nVEGA CARVAJAL", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-04", "doble_articulado": false, "id_norma": "221430", "numero_fuente": "37791", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-20", "vigencias": [{"desde": "2004-02-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-02-20", "fin_vigencia": "", "tip