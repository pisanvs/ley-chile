{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO DE EXPROPIACION </div></div>", "i": 6491376}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Secci&#xF3;n 2da. 1.170 de 30 de Octubre de 1987, Alcalde I. Municipalidad de Santiago, dispone expropiaci&#xF3;n total conforme D.S. 458 Vivienda y Urbanismo, Decretos Ley 1.289 y 2.186 inmueble Santo Domingo 3680, rol 282-7 Santiago, aparentemente dominio Yolanda A. Krumm Ahumada. Superficie aproximada 500 m2. Deslindes: Norte: 10 metros calle Santo Domingo; Sur: 10 mts. con Quinta Normal; Oriente: 50 mts. otro propietario; Poniente: 50 mts. otro propietario. Indemnizaci&#xF3;n provisional $1.945.000.- pagadera al contado.</div><br></div>", "i": 6491377}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Gustavo Alessandri V., Alcalde de Santiago. </div></div>", "i": 6491378}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1170", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1170"}], "organismos": ["MUNICIPALIDAD DE SANTIAGO"], "titulo_norma": "EXTRACTO DE DECRETO DE EXPROPIACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-10-30", "doble_articulado": false, "id_norma": "228806", "numero_fuente": "32921", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-11-16", "vigencias": [{"desde": "1987-11-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-11-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-11-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2004-