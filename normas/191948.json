{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 860 EXENTO, DE 2001 </div></div>", "i": 6358591}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 860 de 30 de octubre de 2001, se declara que la carrera profesional de Pedagog&#xED;a B&#xE1;sica impartida por la Universidad de Los Andes, ha cumplido con los requisitos necesarios para obtener la liberaci&#xF3;n de la examinaci&#xF3;n por parte de la entidad examinadora.</div><div class=\"p\">&nbsp; &nbsp;  De conformidad con el art&#xED;culo anterior, la Universidad de Los Andes est&#xE1; en condiciones de otorgar independientemente el t&#xED;tulo profesional de Profesor de Educaci&#xF3;n B&#xE1;sica con menci&#xF3;n en Castellano-Ciencias Sociales o en Ingl&#xE9;s.</div><br></div>", "i": 6358592}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de noviembre de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6358593}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "860 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-860 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 860 EXENTO, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-10-30", "doble_articulado": false, "id_norma": "191948", "numero_fuente": "37118", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-11-23", "vigencias": [{"desde": "2001-11-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-11-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "200