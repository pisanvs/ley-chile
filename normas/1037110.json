{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  CERTIFICADO</div></div>", "i": 9235919}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile certifica que la Tasa de Inter&#xE9;s Promedio (TIP) mensual de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as fue de 2,85% anual durante el mes de enero de 2012.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, de conformidad con lo dispuesto en el N&#xB0; 5 del Cap&#xED;tulo IV.B.8.1. del Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de entre 90 y 365 d&#xED;as, correspondiente a la segunda quincena de enero de 2012, fue de 2,37% anual.</div></div>", "i": 9235920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 6 de febrero de 2012.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div></div>", "i": 9235921}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "Certificado-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-02-06", "doble_articulado": false, "id_norma": "1037110", "numero_fuente": "40182", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-02-08", "vigencias": [{"desde": "2012-02-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-02-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-02-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones"