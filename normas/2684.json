{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 5853574}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto N&#xB0;1.056 de 22 de Octubre de 1993, la Municipalidad de Macul dispuso expropiaci&#xF3;n parcial del inmueble Rol 7535-1 ubicado en Exequiel Fern&#xE1;ndez N&#xB0; 3024, inscrito a fojas 17.515, N&#xB0;21.167 del Registro de Propiedad de 1978, Conservador de Bienes Ra&#xED;ces de Santiago, dominio aparente de don Ren&#xE9; Z&#xFA;&#xF1;iga Cifuentes. Objeto de la expropiaci&#xF3;n, dar cumplimiento a Plan Regulador Comunal. La indemnizaci&#xF3;n se pact&#xF3; de com&#xFA;n acuerdo en $ 66.450, la que se compens&#xF3; con derechos de edificaci&#xF3;n en resto de la misma propiedad.</div><br></div>", "i": 5853575}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; El Alcalde.</div><br></div>", "i": 5853576}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1056", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1056"}], "organismos": ["MUNICIPALIDAD DE MACUL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BIEN INMUEBLE", "EXPROPIACION", "REGION METROPOLITANA", "MACUL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-10-22", "doble_articulado": false, "id_norma": "2684", "numero_fuente": "34716-1", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-15", "vigencias": [{"desde": "1993-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_version": "1993-11-15", "f