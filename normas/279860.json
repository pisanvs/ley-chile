{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6662634}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 2.544, de 30 de septiembre de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a IMPORTADORA Y EXPORTADORA M.J. CHILE LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, para iniciar y operar planta ubicada en V&#xED;a Uno, sitio 2, manzana K, Km. 10, Bajo Molle, Iquique, I Regi&#xF3;n, para elaborar en la l&#xED;nea de proceso de alga seca, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6662635}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de septiembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 6662636}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2544 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2544 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-09-30", "doble_articulado": false, "id_norma": "279860", "numero_fuente": "39192", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-10-20", "vigencias": [{"desde": "2008-10-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-10-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-10-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2008-10-20", "