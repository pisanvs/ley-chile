{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9228115}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 41, del 10 de enero de 2012 esta Subsecretar&#xED;a, deni&#xE9;gase la solicitud CI Subpesca N&#xBA;13820-2011 del S.T.I. PESCADORES ARTESANALES, de Caleta Pichicuy, RSU N&#xBA; 05.07.032, de participar en el R&#xE9;gimen Artesanal de Extracci&#xF3;n por organizaciones pesquer&#xED;as artesanales de Anchoveta, Sardina com&#xFA;n y Jurel de la V Regi&#xF3;n, en virtud de lo dispuesto en la parte considerativa de la presente resoluci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de la presente resoluci&#xF3;n extractada se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y del Servicio Nacional de Pesca.</div></div>", "i": 9228116}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de enero de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div></div>", "i": 9228117}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "41 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-41 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-01-10", "doble_articulado": false, "id_norma": "1036506", "numero_fuente": "40163", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-01-17", "vigencias": [{"desde": "2012-01-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-01-17", "fin_vigenc