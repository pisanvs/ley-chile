{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9201008}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto Exento MOP. N&#xBA;3256, de 18 de octubre de 2011, se dej&#xF3; sin efecto los numerales 3&#xBA;, 4&#xBA;, 5&#xBA; y 6&#xBA;, del Decreto Exento MOP. N&#xBA;528, de 30 de abril de 2010, en la parte que se refiere al Convenio Directo de Precio Ad-Refer&#xE9;ndum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n del lote de terreno N&#xBA;6, expropiado con motivo de la obra &quot;Conservaci&#xF3;n Camino B&#xE1;sico, Achao - Quinchao - Chequi&#xE1;n, Sector Quinchao - Chequi&#xE1;n&quot;. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n, fijado el 8 de febrero de 2008, por la Comisi&#xF3;n de Peritos Tasadores en la suma de $330.000. </div></div>", "i": 9201009}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9201010}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3256 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-3256 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-18", "doble_articulado": false, "id_norma": "1031978", "numero_fuente": "40099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-11-02", "vigencias": [{"desde": "2011-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"ini