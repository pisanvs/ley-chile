{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Pension de Gracia Lei n&#xFA;m. 986.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br><br></div>", "i": 7162809}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese a do&#xF1;a Mar&#xED;a Eustaquia V&#xE1;zquez, madre viuda del capitan don Jos&#xE9; Ignacio Vial, la pension que el art. 12 de la lei de 22 de Diciembre de 1881 da a la madre viuda de capitan muerto en accion de guerra, de la que gozar&#xE1; con arreglo a la lei.</div><br><br></div>", "i": 7162810}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 29 de Diciembre de 1897.- FEDERICO ERRAZURIZ.- Patricio Larrain A.</div><br></div>", "i": 7162811}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "986", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-986"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION DE GRACIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MARIA EUSTAQUIA VAZQUEZ", "PENSION GRACIA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["LA PRESENTE LEY HA SIDO REPRODUCIDA EN EL D.OFICIAL Nº5907 DEL 20.01.1898"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-12-29", "doble_articulado": false, "id_norma": "22324", "numero_fuente": "5896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-01-07", "vigencias": [{"desde": "1898-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vi