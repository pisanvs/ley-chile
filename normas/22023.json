{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MEDIDAS CONTRA EL COLERA Lei n&#xFA;m. 162.-Santiago, a 19 de Enero de 1894.-Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273786}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de treinta mil pesos en la adopcion de las medidas necesarias para precaver la epidemia del c&#xF3;lera.</div><br><br></div>", "i": 8273787}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.-Pedro Montt.</div><br></div>", "i": 8273788}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "162", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-162"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "MEDIDAS CONTRA EL COLERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLERA", "EPIDEMIA", "FONDOS", "PREVENCION", "DESTINACION", "PRESIDENTE REPUBLICA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-01-19", "doble_articulado": false, "id_norma": "22023", "numero_fuente": "4721", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-01-19", "vigencias": [{"desde": "1894-01-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-01-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-01-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacion