{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8792276}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;3.351, de 8 de octubre de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIALIZADORA DE PRODUCTOS DEL MAR Y ALIMENTOS, GABRIEL MASHID &#xC1;LAMO &#xC1;LAMO EMPRESA INDIVIDUAL DE RESPONSABILIDAD LIMITADA, para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar planta ubicada en Avenida Las Industrias N&#xBA;1008, Barrio Industrial, Caldera, III Regi&#xF3;n, en la l&#xED;nea de proceso Conserva, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;janse sin efecto las <a href=\"https://www.leychile.cl/Navegar?idNorma=197241&amp;idParte=0&amp;idVersion=\">resoluciones N&#xBA;739 de 2002</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=217111&amp;idParte=0&amp;idVersion=\">N&#xBA;2576 de 2003</a>, ambas de esta Subsecretar&#xED;a.</div><br></div>", "i": 8792277, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 8 de octubre de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8792278}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3351 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3351 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-10-08", "doble_articulado": false, "id_norma": "1007358", "numero_fuente": "39492", "tipo_version": "3