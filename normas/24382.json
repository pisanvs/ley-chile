{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3 987, que concede un ausilio de $ 100,000 al Cuerpo de Bomberos de Santiago</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,987.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8276879}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Autor&#xED;zase al Presidente de la Rep&#xFA;blica para entregar, como ausilio estraordinario, por una sola vez, al Cuerpo de Bomberos de Santiago, la suma de cien mil pesos ($ 100,000).</div><br></div>", "i": 8276880}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de setiembre de 1923.-Arturo Alessandri.- Domingo Amun&#xE1;tegui.</div><br></div>", "i": 8276881}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3987", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3987"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 3 987, QUE CONCEDE UN AUSILIO DE $ 100,000 AL CUERPO DE BOMBEROS DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["SANTIAGO", "CUERPO BOMBEROS", "PRESIDENTE DE LA", "REPUBLICA", "AUXILIO EXTRAORDINARIO", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1923-09-28", "doble_articulado": false, "id_norma": "24382", "numero_fuente": "JAM", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1923-10-05", "vigencias": [{"desde": "1923-10-05", "