{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6253607}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 223 de 08 de Abril de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la X Regi&#xF3;n, se autoriza a Jos&#xE9; Ruiz Cer&#xF3;n y Humberto Asencio Soto para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 1 &quot;Bellavista - Techo Para Todos&quot; de Puerto Montt, cuyo trazado fue autorizado por resoluci&#xF3;n No. 82, de 07 de junio de 1984, de esta Secretar&#xED;a Regional.</div><br></div>", "i": 6253608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Enrique Brintrup Barrera, Secretario Regional Ministerial Transp. y Telec. X Regi&#xF3;n subrogante. </div></div>", "i": 6253609}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "223 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-223 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL X REGIÓN DE LOS LAGOS"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-08", "doble_articulado": false, "id_norma": "161877", "numero_fuente": "32451", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-19", "vigencias": [{"desde": "1986-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-04-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-04-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pe