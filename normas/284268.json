{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACI&#xD3;N</div><br><br></div>", "i": 6911521}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 7.938, de 15 de diciembre</div><div class=\"p\">de 2008, de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n</div><div class=\"p\">conforme D.L. N&#xBA; 2.186 de 1978, del Lote N&#xBA; 368,</div><div class=\"p\">correspondiente al inmueble ubicado en Av Oriente 3225</div><div class=\"p\">A. Pinto, Rol de Aval&#xFA;o N&#xBA; 1912-3, Comuna de San Joaqu&#xED;n, aparente dominio de Concha V&#xE1;squez Jos&#xE9; Servando. Comisi&#xF3;n integrada por peritos se&#xF1;ores Mario Zamorano Villablanca, Arquitecto; Ivanka Aliaga Jofr&#xE9;, Constructor Civil; y Soledad Herrera Z&#xFA;&#xF1;iga, Ingeniero Civil. Seg&#xFA;n informe de 18 de junio de 2008, fij&#xF3; monto provisional indemnizaci&#xF3;n en $40.959.068, pagadera al contado.</div><br></div>", "i": 6911522}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director (S) Serviu Metropolitano </div></div>", "i": 6911523}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7938 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7938 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "ORDENA EXPROPIACIONES DE INMUEBLES QUE INDICA; NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-15", "doble_articulado": false, "id_norma": "284268", "numero_fuente": "39251", "tipo_version": "3", "tipo_version_s": "Única", "fecha_p