{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7351347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.107, de 20 de julio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase a COMERCIAL ANDROC Y CIA. LTDA., para ampliar las actividades pesqueras de transformaci&#xF3;n autorizadas por las resoluciones citadas en Visto, en orden a incorporar a la planta ubicada en Camino Sur N&#xBA; 6403, Km. 6,5 Punta Arenas, XII Regi&#xF3;n, en las l&#xED;neas de proceso de Fresco-Enfriado, Congelado y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 7351348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de julio de 2007.- Mar&#xED;a Angela Barbieri Bellolio, Subsecretaria de Pesca (S). </div></div>", "i": 7351349}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2107 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2107 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-20", "doble_articulado": false, "id_norma": "263988", "numero_fuente": "38843", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-21", "vigencias": [{"desde": "2007-08-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-08-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-08-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_