{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 936 EXENTA, DE 2007 </div></div>", "i": 7343195}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 936, de 15 de mayo de 2007, se autoriz&#xF3;, de conformidad a lo dispuesto en el N&#xBA; 5 de la resoluci&#xF3;n N&#xBA; 65, de 2000, del Ministerio de Transportes y Telecomunicaciones, al taller que a continuaci&#xF3;n se individualiza para adecuar veh&#xED;culos al uso de gas licuado de petr&#xF3;leo como combustible:</div><br><div class=\"p\">&nbsp;  Empresa&nbsp; &nbsp; &nbsp;  Nombre del&nbsp;  Direcci&#xF3;n</div><div class=\"p\">&nbsp; Habilitada&nbsp; &nbsp;  Taller&nbsp; &nbsp; &nbsp;  del Taller&nbsp; &nbsp; &nbsp; Ciudad</div><br><div class=\"p\">AGS Automotive&nbsp; Automotora&nbsp;  Av. Vicu&#xF1;a</div><div class=\"p\">Gas Systems&nbsp; &nbsp;  Costabal&nbsp; &nbsp;  Mackenna</div><div class=\"p\">S.A.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  N&#xBA; 3500&nbsp; &nbsp; &nbsp; &nbsp; Santiago</div><br><div class=\"p\">&nbsp; &nbsp;  La autorizaci&#xF3;n tendr&#xE1; validez mientras se mantengan las referencias constatadas en su inspecci&#xF3;n.</div><br></div>", "i": 7343196}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Danilo N&#xFA;&#xF1;ez Izquierdo, Subsecretario de Transportes.</div><br></div>", "i": 7343197}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "936 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-936 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 936 EXENTA, DE 2007", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observacione