{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA;2.045, de 9 de junio de 2009, de esta Subsecretar&#xED;a, autor&#xED;zase a GLOBALPESCA S.A. para realizar actividades extractivas en alta mar, con la nave &quot;Isla Sof&#xED;a&quot;, cuyas caracter&#xED;sticas n&#xE1;uticas son las siguientes:</div><br><div class=\"p\">Se&#xF1;al distintiva&nbsp; &nbsp; &nbsp;  CB-4233</div><div class=\"p\">Puerto de Matr&#xED;cula&nbsp; &nbsp; Valpara&#xED;so</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 2636</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp;  48,45 m.</div><div class=\"p\">T.R.G. (Internacional) 653,47</div><div class=\"p\">Manga&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 9,20 m.</div><div class=\"p\">Puntal&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  4,50 m.</div><br></div>", "i": 8696785}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jese sin efecto totalmente la resoluci&#xF3;n exenta N&#xBA;3.316, de 2007, de esta Subsecretar&#xED;a de Pesca.</div><br></div>", "i": 8696786, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 9 de junio de 2009.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 8696787}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2045 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolucion-2045 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2009-06-09", "doble_arti