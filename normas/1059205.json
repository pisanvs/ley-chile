{"html": [{"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">ESTABLECE DECLARACI&#xD3;N JURADA QUE INDICA</div></div>", "i": 9404160}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 11 del 28 de enero de 2014.</div><div class=\"p\">&nbsp; &nbsp;  Establece obligaci&#xF3;n de presentar Declaraci&#xF3;n Jurada Anual sobre desembolsos y otras partidas o cantidades a que se refiere el inciso tercero del art&#xED;culo 21 de la Ley sobre Impuesto a la Renta y deroga <a href=\"https://www.leychile.cl/Navegar?idNorma=40471&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 4.845 de 1995</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la oficina virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de enero de 2014.</div><br></div>", "i": 9404161, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Alejandro Burr Ort&#xFA;zar, Director.</div></div>", "i": 9404162}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "11 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-11 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "ESTABLECE DECLARACIÓN JURADA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-01-28", "doble_articulado": false, "id_norma": "1059205", "numero_fuente": "40773", "tipo_version": "3", "tipo_version_s": "Única