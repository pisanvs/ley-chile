{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6342347}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento MOP N&#xBA;655, de 31 de mayo de 2001, se expropi&#xF3; el lote de terreno N&#xBA;27-1, superficie 65 m&#xB2;, rol de aval&#xFA;o 619-34, comuna de Molina, para la obra Concesi&#xF3;n Internacional Ruta 5. Tramo: Santiago - Talca. Sector N, S&#xE9;ptima Regi&#xF3;n y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Jorge Segundo Espina Valenzuela y otros, ascendente a la cantidad de $366.329.-</div><br></div>", "i": 6342348}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6342349}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "655 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-655 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-05-31", "doble_articulado": false, "id_norma": "187539", "numero_fuente": "37012", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-16", "vigencias": [{"desde": "2001-07-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-07-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "2001-07-16", "fecha_version": "2001-07-16", "fecha_actualizacion_texto": "2001-07-16", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estru