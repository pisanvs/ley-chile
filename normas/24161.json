{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,669, que declara feriado para Valparaiso el 20 de Setiembre de 1920.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,669.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 8276607}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Decl&#xE1;rase feriado para la provincia de Valparaiso, el dia 20 de Setiembre del presente a&#xF1;o. </div></div>", "i": 8276608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a trece de Setiembre de mil novecientos veinte.- JUAN LUIS SANFUENTES.- Pedro Garcia de la Huerta.</div><br></div>", "i": 8276609}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3669", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3669"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NÚM. 3.669, QUE DECLARA FERIADO PARA VALPARAISO EL 20 DE SETIEMBRE DE 1920", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FERIADO LEGAL", "VALPARAISO", "DECLARACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1920-09-13", "doble_articulado": false, "id_norma": "24161", "numero_fuente": "12773", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1920-09-16", "vigencias": [{"desde": "1920-09-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1920-09-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic