{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6590647}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.942, de 23 de octubre de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a FERNANDO EDUARDO COHN VALENZUELA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Pasaje Lovera s/n&#xBA;, El Arenal, Salida Norte, Valdivia, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Ahumado, Fresco-Enfriado y Fresco-Refrigerado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6590648}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de octubre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6590649}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2942 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2942 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-10-23", "doble_articulado": false, "id_norma": "255519", "numero_fuente": "38622", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-24", "vigencias": [{"desde": "2006-11-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-11-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JR