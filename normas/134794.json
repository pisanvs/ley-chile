{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 1,372.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><br><div class=\"p\">PROYECTO DE LEI:</div><br><br><br></div>", "i": 6163467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- En atenci&#xF3;n a los servicios prestados al pais por el vice-almirante don Manuel Blanco Encalada, conc&#xE9;dese, por gracia, a su nieta do&#xF1;a Carmen Villamil Blanco, una pension anual de mil quinientos pesos, de la cual gozar&#xE1; con arreglo a la lei de montep&#xED;o militar i con esclusion de toda otra pension fiscal.&quot; </div></div>", "i": 6163468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 14 de setiembre de 1900.- EL&#xCD;AS FERNANDEZ A.- Ricardo Matte P&#xE9;rez.</div><br></div>", "i": 6163469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1372", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1372"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1900-09-14", "doble_articulado": false, "id_norma": "134794", "numero_fuente": "6696", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1900-09-17", "vigencias": [{"desde": "1900-09-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1900-09-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia":