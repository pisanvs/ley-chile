{"html": [{"t": "<div><div class=\"p\">RESOLUCI&#xD3;N QUE ESTABLECE PARA EL A&#xD1;O 2022 LAS ACS QUE DEBEN DAR CUMPLIMIENTO AL REGLAMENTO FIJADO POR DS N&#xBA; 1 DE 2020, DE ESTE MINISTERIO</div></div>", "i": 10300136}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.454, de 30 de diciembre de 2021, de esta Subsecretar&#xED;a, establece resoluci&#xF3;n que establece para el a&#xF1;o 2022, las ACS que deben dar cumplimiento al <a href=\"https://www.leychile.cl/Navegar?idNorma=1154210&amp;idParte=&amp;idVersion=\">DS N&#xBA; 1 de 2020</a>, de este Ministerio, en la forma que indica la resoluci&#xF3;n extractada y publicada &#xED;ntegramente en las p&#xE1;ginas www.subpesca.cl y www.sernapesca.cl.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><br></div>", "i": 10300137}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de diciembre de 2021.- Alicia Gallardo Lagno, Subsecretaria de Pesca y Acuicultura.</div><br></div>", "i": 10300138}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3454 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3454 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "RESOLUCIÓN QUE ESTABLECE PARA EL AÑO 2022 LAS ACS QUE DEBEN DAR CUMPLIMIENTO AL REGLAMENTO FIJADO POR DS Nº 1 DE 2020, DE ESTE MINISTERIO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2068943", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-12-30", "doble_articulado": false, "id_norma": "1171095", "numero_fuente": "43147", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion":