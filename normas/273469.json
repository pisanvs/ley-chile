{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; RECTIFICACI&#xD3;N</div><br><br></div>", "i": 8191059}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rectif&#xED;case publicaci&#xF3;n efectuada en el Diario Oficial, referente al sistema de control de horas de trabajo para los trabajadores que se desempe&#xF1;an a bordo de veh&#xED;culos del plan transantiago, con la siguiente correcci&#xF3;n:</div><br><div class=\"p\">&nbsp; &nbsp;  &quot;Que, en edici&#xF3;n del d&#xED;a 06.06.2008, se public&#xF3; la resoluci&#xF3;n N&#xBA; 805, de 30.05.2008, de la Direcci&#xF3;n del Trabajo, en cuya numeraci&#xF3;n de sus art&#xED;culos se omite el n&#xFA;mero 7&#xBA; (s&#xE9;ptimo), es decir, se pasa del 6&#xBA; al 8&#xBA;, debiendo corresponderle al art&#xED;culo 8&#xBA;, el n&#xFA;mero 7&#xBA; y as&#xED; sucesivamente al resto de los art&#xED;culos.&quot;. </div></div>", "i": 8191060}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Christian Melis Valencia, Jefe Divisi&#xF3;n de Inspecci&#xF3;n.</div><br></div>", "i": 8191061}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["DIRECCIÓN DEL TRABAJO"], "titulo_norma": "RECTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN FECHA DE PROMULGACION", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "273469", "numero_fuente": "39103", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-07-03", "vigencias": [{"desde": "2008-07-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-07-03", "f