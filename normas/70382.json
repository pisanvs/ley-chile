{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8302199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 447, de 27 de marzo de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; deni&#xE9;gase la solicitud para ampliar actividades pesqueras extractivas en el litoral de la III, IV y X Regiones con una nave en construcci&#xF3;n denominada &quot;Carlinga&quot;, presentada por&nbsp; PESQUERA SAN FRANCISCO S.A., por haberse verificado las causales denegatorias se&#xF1;aladas en el art&#xED;culo 19 letras a), c) y e) de la Ley N&#xBA; 18.892 y sus modificaciones. </div></div>", "i": 8302200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de marzo de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8302201}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "447", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-447"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA SAN FRANCISCO S.A.", "AUTORIZACION", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-27", "doble_articulado": false, "id_norma": "70382", "numero_fuente": "35734", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-07", "vigencias": [{"desde": "1997-04-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-04-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-04-07", "fin_vigencia": "", "tipo_version