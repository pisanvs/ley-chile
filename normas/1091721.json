{"html": [{"t": "<div><br><div class=\"p\">FIJA NUEVO PLAZO PRESENTACI&#xD3;N DECLARACIONES JURADAS FORMULARIOS N&#xBA; 1847 Y 1926</div></div>", "i": 9709707}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xBA; 52, del 14 de junio de 2016, que establece.</div><div class=\"p\">&nbsp; &nbsp;  Fija nuevo plazo para presentar la Declaraci&#xF3;n Jurada anual sobre &quot;balance de 8 columnas y otros antecedentes&quot;, Formulario N&#xBA; 1847, y Declaraci&#xF3;n Jurada anual sobre &quot;base imponible de primera categor&#xED;a y datos contables balance&quot;, Formulario N&#xBA; 1926.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio de 2016.</div></div>", "i": 9709708}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "52 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-52 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "FIJA NUEVO PLAZO PRESENTACIÓN DECLARACIONES JURADAS FORMULARIOS Nº 1847 Y 1926", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1035252; EXTRACTO", "NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2016-06-14", "doble_articulado": false, "id_norma": "1091721", "numero_fuente": "41488", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2016-06-20", "vigencias": [{"desde": "2016-06-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_v