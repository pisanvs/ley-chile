{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; DELEGA EN EL JEFE DEL DEPARTAMENTO DE RESOLUCIONES REGIONAL LA FACULTAD QUE INDICA </div></div>", "i": 6025919}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mediante Resoluci&#xF3;n N&#xB0; Ex. 2.244 de 14 de Septiembre de 1994 el suscrito deleg&#xF3; en el Jefe del Departamento de Resoluciones Regional la facultad de autorizar las disminuciones de capital solicitadas por las sociedades, conforme a lo dispuesto en el inciso final del art. 69&#xB0; del C&#xF3;digo Tributario: de acuerdo a Resoluci&#xF3;n Ex. N&#xB0; 3830, de fecha 30 de Agosto de 1994, de la Direcci&#xF3;n Nacional, que autoriza delegar en los funcionarios que se&#xF1;ala dicha facultad.-</div><br></div>", "i": 6025920}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Mario Valenzuela Ram&#xED;rez, Director Regional. </div></div>", "i": 6025921}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2244", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2244"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DELEGA EN EL JEFE DEL DEPARTAMENTO DE RESOLUCIONES\nREGIONAL LA FACULTAD QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DELEGACION", "FACULTAD", "SERVICIO IMPUESTOS INTERNOS", "JEFE", "DIRECCION REGIONAL", "DEPARTAMENTO RESOLUCIONES REGIONAL", "NOVENA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-09-14", "doble_articulado": false, "id_norma": "40121", "numero_fuente": "34977", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-09-28", "vigencias": [{"desde": "1994-09-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-09-28", "fin_vigencia":