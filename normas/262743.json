{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6617095}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.741, de 7 de junio de 2007, de esta Subsecretar&#xED;a, autor&#xED;zase al SINDICATO DE TRABAJADORES INDEPENDIENTES DE BUZOS MARISCADORES, PESCADORES ARTESANALES Y AYUDANTES DE CALETA CHANAVAYA para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a instalar y operar una planta ubicada en Caleta Chanavaya, comuna y provincia de Iquique, I Regi&#xF3;n, donde podr&#xE1; elaborar en la l&#xED;nea de proceso de ALGA SECA, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6617096}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de junio de 2007.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6617097}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1741 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1741 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-06-07", "doble_articulado": false, "id_norma": "262743", "numero_fuente": "38815", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-07-18", "vigencias": [{"desde": "2007-07-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-07-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-07-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincul