{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 286, DE 1990</div><br><br><br></div>", "i": 6078428}, {"t": "<div><div class=\"p\">Por Decreto Exento No. 286 de fecha 26 de octubre de 1990 del Ministerio de Educaci&#xF3;n, se encarg&#xF3; al Instituto Profesional de Santiago la funci&#xF3;n de entidad examinadora para las carreras de Auditor&#xED;a y Administraci&#xF3;n de Empresas del Instituto Profesional de ENAC, para lo cual deber&#xE1;n suscribir un convenio en el que establecer&#xE1;n los derechos y obligaciones entre ambas partes.</div><br></div>", "i": 6078429}, {"t": "<div><div class=\"p\">Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n. </div></div>", "i": 6078430}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "286 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-286 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N°. 286, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-10-26", "fecha_derogacion": "1993-10-23", "doble_articulado": false, "id_norma": "88206", "numero_fuente": "33880", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-01-29", "vigencias": [{"desde": "1993-10-23", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-01-29", "hasta": "1993-10-22", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1993-10-23", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-01-29", "fin_vigencia": "1993-10-22", "tipo_version": "0"}, {"inicio_vigencia"