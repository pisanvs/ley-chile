{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7276589}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.910, de 6 de septiembre de 2000, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad parcial de la resoluci&#xF3;n N&#xBA; 507 de 1988, de esta Subsecretar&#xED;a, s&#xF3;lo en cuanto autoriz&#xF3; a VICENTE SAAVEDRA ALCAYAGA para operar la nave &apos;&apos;Guajache&apos;&apos; en el &#xE1;rea mar&#xED;tima de la I y II Regiones, respecto de los recursos hidrobiol&#xF3;gicos Albacora, At&#xFA;n aleta larga y At&#xFA;n aleta amarilla, de conformidad con lo establecido en la letra b) del art&#xED;culo 143 de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 7276590}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de septiembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 7276591}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1910", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1910"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-09-06", "doble_articulado": false, "id_norma": "175330", "numero_fuente": "36763", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-13", "vigencias": [{"desde": "2000-09-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-13", "fin_vigencia": "", "tipo_version": "3"}], "even