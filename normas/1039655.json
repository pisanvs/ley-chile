{"html": [{"t": "<div><br><div class=\"p\">ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.926</div></div>", "i": 9254594}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.926, celebrada el 5 de abril de 1989, adopt&#xF3; el siguiente acuerdo:</div><br><div class=\"p\">&nbsp; &nbsp;  1926-06-890405 - Modifica fecha de embarque estipulada en Acuerdo No. 1924-01-890328.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar en el inciso primero del n&#xFA;mero 1 del Acuerdo No. 1924-01-890328, la expresi&#xF3;n &quot;09 de abril&quot; por &quot;16 de abril&quot;.</div></div>", "i": 9254595}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 5 de abril de 1989.- Carmen Hermosilla Valencia Secretario General.</div></div>", "i": 9254596}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1926", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1926"}, {"tipo": "5", "numero": "1926-06", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "Acuerdo-1926-06"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE", "SECRETARIA GENERAL"], "titulo_norma": "ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.926", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-04-05", "doble_articulado": false, "id_norma": "1039655", "numero_fuente": "33340", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-04-06", "vigencias": [{"desde": "1989-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "