{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL CONSEJO EN SU SESI&#xD3;N ORDINARIA N&#xBA; 1.374</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xB0; 1.374, celebrada el 15 de noviembre de 2007, adopt&#xF3; el siguiente Acuerdo:</div><br></div>", "i": 7358917}, {"t": "<div><div class=\"p\">1374-04-071115 - Modifica Cap&#xED;tulo III.F.6 del Compendio de Normas Financieras</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar en el Cap&#xED;tulo III.F.6 del Compendio de Normas Financieras, la expresi&#xF3;n &quot;2007&quot; por &quot;2008&quot;.</div><br><div class=\"p\">&nbsp; &nbsp;  Esta modificaci&#xF3;n entrar&#xE1; en vigencia el 1 de enero de 2008.</div><br></div>", "i": 7358918}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 15 de noviembre de 2007.- Miguel &#xC1;ngel Nacrur Gazali, Ministro de Fe.</div><br></div>", "i": 7358919}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1374", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1374"}, {"tipo": "5", "numero": "1374-04", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1374-04"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDO ADOPTADO POR EL CONSEJO EN SU SESIÓN ORDINARIA Nº 1.374", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPENDIO DE NORMAS FINANCIERAS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-11-15", "doble_articulado": false, "id_norma": "266670", "numero_fuente": "38916", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-11-20", "vigencias": [{"desde": "2007-11-20", "hasta": "", "tipo_ve