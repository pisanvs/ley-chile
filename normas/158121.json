{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION EXENTA No. 150, DE 1986 </div><br><br></div>", "i": 6240886}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 150, de fecha 15 de enero de 1986, del Subsecretario de Educaci&#xF3;n P&#xFA;blica Subrogante se aprobaron las modificaciones introducidas al plan y programas de estudio del Centro de Formaci&#xF3;n T&#xE9;cnica La Frontera de Temuco de la carrera y t&#xED;tulo t&#xE9;cnico que se indica, para impartirse a contar de agosto de 1985:</div><div class=\"p\">&nbsp; &nbsp;  Carrera: Programaci&#xF3;n de Aplicaciones Computacionales.</div><div class=\"p\">&nbsp; &nbsp;  T&#xED;tulo: Programador de Aplicaciones Computacionales. </div></div>", "i": 6240887}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 26 de Marzo de 1986.- Ren&#xE9; Salam&#xE9; Mart&#xED;n, Subsecretario de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6240888}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "150 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-150 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE RESOLUCION EXENTA No. 150, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-01-15", "fecha_derogacion": "2000-12-04", "doble_articulado": false, "id_norma": "158121", "numero_fuente": "32462", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-05-05", "vigencias": [{"desde": "2000-12-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-05-05", "hasta": "2000-12-03", "tipo_versio