{"html": [{"t": "<div><div class=\"p\">EXTRACTO </div></div>", "i": 6302263}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n ministerial N&#xBA; 79, de fecha 11 de agosto del a&#xF1;o 2000, se autoriz&#xF3; la existencia y se aprobaron los estatutos de la Cooperativa de Trabajo en Servicios Tecnol&#xF3;gicos Agropecuarios y Comercializaci&#xF3;n Cumbre Mocohen Limitada, de San Esteban, Regi&#xF3;n de Valpara&#xED;so, en los t&#xE9;rminos que dan testimonio los instrumentos protocolizados con fecha 21 de marzo del a&#xF1;o 2000, ante el Notario de Vi&#xF1;a del Mar, don Ra&#xFA;l Tavolari V&#xE1;squez; y con fecha 5 de julio del a&#xF1;o 2000, ante el mismo Notario.</div><br></div>", "i": 6302264}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del Sr. Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas.</div><br></div>", "i": 6302265}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "79", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-79"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-08-11", "doble_articulado": false, "id_norma": "175988", "numero_fuente": "36769", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-22", "vigencias": [{"desde": "2000-09-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-09-22", "fin_vig