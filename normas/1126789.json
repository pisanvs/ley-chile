{"html": [{"t": "<div><br><div class=\"p\">PRORROGA EL PLAZO DE ATENCI&#xD3;N EN CANAL 16 VHF DE ONDAS M&#xC9;TRICAS</div></div>", "i": 9978107}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n D.G.T.M. y M.M. Ord. N&#xBA; 12600/446 Vrs., de fecha 13 de noviembre de 2018, prorroga el plazo de atenci&#xF3;n en canal 16 VHF de ondas m&#xE9;tricas, a todas las naves que naveguen en la jurisdicci&#xF3;n nacional.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en la p&#xE1;gina web de la Direcci&#xF3;n General del Territorio Mar&#xED;timo y de Marina Mercante (www.directemar.cl).</div></div>", "i": 9978108}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de noviembre de 2018.- Guillermo L&#xFC;ttges Mathieu, Vicealmirante, Director General.- M. Carolina Riesco Fuenzalida, Capit&#xE1;n de Corbeta JT, Jefe Depto Jur&#xED;dico. </div></div>", "i": 9978109}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12600", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12600"}, {"tipo": "3", "numero": "12600/446", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-12600/446"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA PARA LAS FUERZAS ARMADAS", "ARMADA DE CHILE", "DIRECCIÓN GENERAL DEL TERRITORIO MARÍTIMO Y DE MARINA MERCANTE"], "titulo_norma": "PRORROGA EL PLAZO DE ATENCIÓN EN CANAL 16 VHF DE ONDAS MÉTRICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1513117; EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2018-11-13", "doble_articulado": false, "id_norma": "1126789", "numero_fuente": "42232", "tipo_version": "3", "t