{"html": [{"t": "<div><div class=\"p\">DESIGNA A DON JORGE ANTONIO CORDERO SOTO COMO TESORERO PROVINCIAL DE CHILOE</div><br><div class=\"p\">&nbsp; &nbsp;  (Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de enero de 1998.- Hoy se resolvi&#xF3; lo que sigue:</div><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 351.- Vistos: el Art. 5&#xBA; del D.F.L. N&#xBA; 1, de 1994, del Ministerio de Hacienda y la Resoluci&#xF3;n N&#xBA; 520, de 1996, de la Contralor&#xED;a General de la Rep&#xFA;blica, dicto la siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  R e s o l u c i &#xF3; n:</div><br><br></div>", "i": 6102526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Des&#xED;gnase a don Jorge Antonio Cordero Soto, Rut.</div><div class=\"p\">8.894.835-1, Planta de T&#xE9;cnicos grado 14&#xBA; EU., para que se desempe&#xF1;e como Tesorero Provincial de Chilo&#xE9;. </div></div>", "i": 6102527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Roberto Cerri L&#xF3;pez, Tesorero General.</div><br><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo para su conocimiento.- Saluda a Ud., Mariana Guasp Sotomayor, Jefe Departamento Personal Subrogante.</div><br></div>", "i": 6102528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "351", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-351"}], "organismos": ["MINISTERIO DE HACIENDA", "TESORERÍA GENERAL DE LA REPÚBLICA"], "titulo_norma": "DESIGNA A DON JORGE ANTONIO CORDERO SOTO COMO TESORERO PROVINCIAL DE CHILOE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["TESORERO PROVINCIAL", "CHILOE", "DECIMA REGION", "JORGE ANTONIO CORDERO SOTO", "DESIGNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fe