{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6566768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 987, de 3 de abril de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA GRIMAR S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Parque Industrial Escuadr&#xF3;n Sur, manzana A, lote 10, Coronel, VIII Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso de Congelado, Fresco enfriado y Fresco refrigerado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada.</div><br></div>", "i": 6566769}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 3 de abril de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6566770}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "987 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-987 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-04-03", "doble_articulado": false, "id_norma": "248864", "numero_fuente": "38438", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-04-12", "vigencias": [{"desde": "2006-04-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-04-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-04-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_in