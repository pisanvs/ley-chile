{"html": [{"t": "<div><br><div class=\"p\">PANTEON.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Agosto 9 de 1832.</div></div>", "i": 10257122}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Conforme al <a href=\"https://www.leychile.cl/Navegar?idNorma=1066081&amp;idParte=9513229\">art. 4.&#xB0;</a> del <a href=\"https://www.leychile.cl/Navegar?idNorma=1066081&amp;idParte=&amp;idVersion=\">reglamento de administraci&#xF3;n del Panteon jeneral</a> de esta ciudad, vengo en nombrar para director de este establecimiento al ciudadano don Estanislao Portales, quien se recibir&#xE1; inmediatamente del cargo y propondr&#xE1; la persona que haya de desempe&#xF1;ar las funciones de tesorero.</div><br></div>", "i": 10257123}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Comun&#xED;quese a quienes corresponda e impr&#xED;mase.</div><br><div class=\"p\">&nbsp; &nbsp;  PRIETO. Joaquin Tocornal.</div></div>", "i": 10257124}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "PANTEON.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1832-08-09", "doble_articulado": false, "id_norma": "1161551", "numero_fuente": "1832", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1832-08-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1832-08-09", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1832-08-09", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "C