{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6220996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xB0; 981 de fecha 17 de Septiembre de 1986, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, se autoriza a los se&#xF1;ores Renato P&#xE9;rez Feli&#xFA; y Jorge Valdivia Mart&#xED;nez; y a Tom&#xE1;s Ilzauspe Irigoyen, para efectuar todo tipo de servicios de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros. </div></div>", "i": 6220997}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 24 de Septiembre de 1986.- Carlos Rom&#xE1;n Toro, Secretario Regional Ministerial Transportes y Telecomunicaciones Regi&#xF3;n Metropolitana.</div><br></div>", "i": 6220998}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "981 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-981 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-09-17", "doble_articulado": false, "id_norma": "151860", "numero_fuente": "32.591", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-10-08", "vigencias": [{"desde": "1986-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-10-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1986-10-08",