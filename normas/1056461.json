{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 8.904 EXENTA, DE 2013</div></div>", "i": 9386817}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 8.904, de 11 de noviembre de 2013, el Servicio Nacional de Capacitaci&#xF3;n y Empleo, dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Sociedad de Capacitaci&#xF3;n Integral IPS - Training Limitada (IPS - Training Ltda.)&quot;, RUT 76.103.725-0 contenida en la resoluci&#xF3;n exenta N&#xBA; 074 de 4 de enero de 2011, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del Art. 21 de la ley 19.518.</div></div>", "i": 9386818}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Bennett Urrutia, Director Nacional (S).</div></div>", "i": 9386819}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "8904 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-8904 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 8.904 EXENTA, DE 2013", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-11-11", "doble_articulado": false, "id_norma": "1056461", "numero_fuente": "40712", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-11-21", "vigencias": [{"desde": "2013-11-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2013-11-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2013-11-21", "fin_vigenci