{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7417143}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.220, de 11 de diciembre de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a GESAM CONSULTORES LTDA. para efectuar una liberaci&#xF3;n 5.000 alevines de Trucha caf&#xE9; Salmo trutta en sectores de R&#xED;o Juncal, V Regi&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Los ejemplares deber&#xE1;n provenir de Piscicultura del R&#xED;o Blanco &quot;Federico Albert Taupp&quot;, ubicado en Los Andes, V Regi&#xF3;n, autorizado por resoluci&#xF3;n N&#xBA; 1.280 de 1982, de esta Subsecretar&#xED;a.</div><br></div>", "i": 7417144}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 11 de diciembre de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca. </div></div>", "i": 7417145}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3220 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3220 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-12-11", "doble_articulado": false, "id_norma": "283860", "numero_fuente": "39242", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-12-20", "vigencias": [{"desde": "2008-12-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-12-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-12-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":