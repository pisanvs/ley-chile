{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 2,768.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6173690}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la cantidad de trescientos mil pesos ($ 300,000) en los gastos de reforzamiento de las defensas de la ciudad de Santiago contra las crecidas del rio Mapocho.</div><br></div>", "i": 6173691}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, veintiocho de enero de mil novecientos trece.- Ramon Barros Luco.- Oscar Viel.</div><br></div>", "i": 6173692}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2768", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2768"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1913-01-28", "doble_articulado": false, "id_norma": "137951", "numero_fuente": "10503", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1913-02-17", "vigencias": [{"desde": "1913-02-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1913-02-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1913-02-17", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione