{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6592615}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.105, de 16 de noviembre de 2006, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; de la resoluci&#xF3;n N&#xBA; 2.533 de 2006, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE INVESTIGACION PESQUERA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto &quot;Distribuci&#xF3;n y estructura de los recursos Anchoveta y Sardina com&#xFA;n entre los l&#xED;mites regionales de la VIII Regi&#xF3;n&quot;, en el sentido de disminuir a 2.500 toneladas la cuota m&#xE1;xima total del recurso Sardina com&#xFA;n autorizada a extraer en el marco de la citada pesca de investigaci&#xF3;n.</div><br></div>", "i": 6592616}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 16 de noviembre de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6592617}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3105 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3105 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-16", "doble_articulado": false, "id_norma": "256118", "numero_fuente": "38614", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-12-09", "vigencias": [{"desde": "2006-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-