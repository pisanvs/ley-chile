{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA NOMBRE A LA CALLE QUE INDICA DE LA COMUNA DE DO&#xD1;IHUE.</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el H. Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 8281658}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Denom&#xED;nase &quot;Subteniente Guillermo Valenzuela Matus&quot; la actual calle &quot;Colegio&quot;, de la comuna de Do&#xF1;ihue, en el departamento de Rancagua.&quot; </div></div>", "i": 8281659}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, seis de octubre de mil novecientos sesenta y uno.-</div><div class=\"p\">&nbsp; &nbsp; JORGE ALESSANDRI RODRIGUEZ.- S&#xF3;tero del R&#xED;o. </div></div>", "i": 8281660}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14668", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14668"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CAMBIA NOMBRE A LA CALLE QUE INDICA DE LA COMUNA DE\nDOÑIHUE.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "CALLE SUBTENIENTE GUILLERMO VALENZUELA MATUS", "DO IHUE", "RANCAGUA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1961-10-06", "doble_articulado": false, "id_norma": "27857", "numero_fuente": "25075", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1961-10-21", "vigencias": [{"desde": "1961-10-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio