{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6525328}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.225, de 26 de abril de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., para ampliar actividades pesqueras extractivas con la nave &quot;Mar&#xED;a Jos&#xE9;&quot;, en orden a realizar actividades pesqueras en el &#xE1;rea mar&#xED;tima comprendida entre la V a VII y IX a X Regiones, por fuera del &#xE1;rea de reserva artesanal, con cerco, donde podr&#xE1; capturar: Sardina espa&#xF1;ola, Caballa, Pampanito, Jibia y Machuelo o Tritre.</div><br></div>", "i": 6525329}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de abril de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6525330}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1225 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1225 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-04-26", "fecha_derogacion": "2012-08-31", "doble_articulado": false, "id_norma": "237784", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-05-11", "vigencias": [{"desde": "2012-08-31", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2005-05-11", "hasta": "2012-08-30", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2012-08-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-05-11", "fin_v