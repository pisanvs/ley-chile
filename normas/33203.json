{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8290365}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 113, de 19 de Febrero de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 2&#xB0; de la Resoluci&#xF3;n N&#xB0; 1.433, de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a INDUSTRIAL, COMERCIAL E INMOBILIARIA ARIES S.A., R.U.T. N&#xB0; 96.651.470-1, para modificar proyecto de construcci&#xF3;n de naves, en el sentido de se&#xF1;alar que los l&#xED;mites del &#xE1;rea de pesca autorizada para el recurso Jurel, Trachurus murphyi, indicado en la letra a) de dicho numeral es el litoral comprendido entre el l&#xED;mite norte de la V Regi&#xF3;n y el l&#xED;mite sur de la VII Regi&#xF3;n y la IX Regi&#xF3;n y no como all&#xED; se consigna.</div><br></div>", "i": 8290366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 19 de febrero de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8290367}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "113", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-113"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INDUSTRIAL COMERCIAL INMOBILIARIA ARIES SA", "MODIFICACION", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-02-19", "fecha_derogacion": "2005-02-21", "doble_articulado": false, "id_norma": "33203", "numero_fuente": "34506", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-03-03", "vigencias"