{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 292 EXENTO, DE 1993 </div></div>", "i": 7161506}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 292 de fecha 11 de Junio de 1993 del Ministerio de Educaci&#xF3;n se sustituy&#xF3; el inciso 1&#xB0; del art&#xED;culo 1&#xB0; del Decreto Exento de Educaci&#xF3;n N&#xB0; 191 de 05.12.88 correspondiente al Instituto Profesional La Araucana, por el siguiente nuevo:</div><div class=\"p\">&nbsp; &nbsp; &quot;Autor&#xED;zase el funcionamiento del Instituto Profesional que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala:</div><div class=\"p\">&nbsp; &nbsp; Nombre de la Instituci&#xF3;n: Instituto Profesional La Araucana.</div><div class=\"p\">&nbsp; &nbsp; Domicilio: Santiago.</div><div class=\"p\">&nbsp; &nbsp; Organizador: Sociedad Instituto Profesional La Araucana S.A.&quot; </div></div>", "i": 7161507}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7161508}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "292 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-292 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 292 EXENTO, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "INSTITUTO PROFESIONAL LA ARAUCANA", "SANTIAGO", "REGION METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-06-11", "fecha_derogacion": "2019-10-30", "doble_articulado": false, "id_norma": "20905", "numero_fuente": "34679", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-09-30", "