{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9495431}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.024, de 4 de agosto de 2014, de esta Subsecretar&#xED;a, d&#xE9;jese sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=1003622&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 2.031, de 2009</a>, que autoriz&#xF3; a GOBALPESCA S.A. para realizar actividades extractivas en alta mar, con la nave &quot;Isla Santa Clara&quot;, por configurarse conforme antecedentes se&#xF1;alados en la parte considerativa de la resoluci&#xF3;n extractada, la causal establecida en el art&#xED;culo 11.- letra a) del decreto supremo N&#xBA; 360, de 2005 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 9495432, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 4 de agosto de 2014.- Ra&#xFA;l S&#xFA;nico Galdames, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9495433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2024 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2024 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-08-04", "doble_articulado": false, "id_norma": "1065305", "numero_fuente": "40931", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-08-12", "vigencias": [{"desde": "2014-08-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "