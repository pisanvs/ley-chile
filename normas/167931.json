{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA TAIYO CHILE LTDA. PARA EFECTUAR PESCA EXPLORATORIA </div></div>", "i": 6272952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 255, de 10 de Mayo de 1985, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Taiyo Chile Ltda., domiciliada en Santiago, para realizar pesca exploratoria del recurso calamar, hasta el 30 de Diciembre de 1985, con las embarcaciones &quot;Guafo&quot;, &quot;Guamblin&quot; y &quot;Guaitecas&quot;, en la zona de las 200 millas desde las l&#xED;neas de Base Rectas, entre los paralelos 43&#xBA; a 57&#xBA; de Latitud Sur.</div><br></div>", "i": 6272953}, {"t": "<div><div class=\"p\">Santiago, 10 de Mayo de 1985.-</div><div class=\"p\">&nbsp; &nbsp;  Roberto Verdugo Gormaz, Subsecretario de Pesca. </div></div>", "i": 6272954}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "255", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-255"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA TAIYO CHILE LTDA. PARA EFECTUAR\nPESCA EXPLORATORIA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-05-10", "doble_articulado": false, "id_norma": "167931", "numero_fuente": "32173", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-05-17", "vigencias": [{"desde": "1985-05-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-05-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985