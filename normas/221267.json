{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOC. CONST. GARCES, GONZALEZ Y CIA. LTDA.</div><br></div>", "i": 6464570}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VI Direcci&#xF3;n Regional Rancagua del Servicio de Impuestos Internos, por resoluci&#xF3;n N&#xBA; 42 de fecha 4 de febrero de 2004 otorga la calidad de Agente Retenedor del IVA en la Actividad de la Construcci&#xF3;n a Soc. Const. Garc&#xE9;s, Gonz&#xE1;lez y C&#xED;a. Ltda. RUT N&#xBA; 77.222.790-6. Resoluci&#xF3;n que entrar&#xE1; en vigencia a contar del 1&#xBA; del mes siguiente al de esta publicaci&#xF3;n, de acuerdo a lo establecido por la resoluci&#xF3;n Ex. N&#xBA; 46 del 1 septiembre del 2003, de la Direcci&#xF3;n Nacional.-</div><br></div>", "i": 6464571}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Luis Mu&#xF1;oz Arratia, Director Regional.</div><br></div>", "i": 6464572}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "42", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-42"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VI DIRECCIÓN REGIONAL DE RANCAGUA"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DEL IVA A SOC. CONST.\nGARCES, GONZALEZ Y CIA. LTDA.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-04", "doble_articulado": false, "id_norma": "221267", "numero_fuente": "37786", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-02-14", "vigencias": [{"desde": "2004-02-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-02-14", "fin_vigencia": ""}, "vigencias_version_no