{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 256 EXENTO, DE 1997 </div></div>", "i": 6034717}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 256 de 5 de marzo de 1997, se ha aprobado al Colegio Biling&#xFC;e &quot;British Royal School&quot; de La Reina, Regi&#xF3;n Metropolitana, para aplicar, a contar desde el a&#xF1;o escolar 1997, de acuerdo a la gradualidad establecida en el art&#xED;culo 4&#xBA; del Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996, un plan de estudio para los cursos 1&#xBA; y 2&#xBA; a&#xF1;o (NB.1) y 3&#xBA; y 4&#xBA; a&#xF1;o (NB.2) de ense&#xF1;anza b&#xE1;sica.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para las asignaturas que se se&#xF1;alan en el presente decreto. </div></div>", "i": 6034718}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de marzo de 1997.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6034719}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "256 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-256 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 256 EXENTO, DE 1997", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BRITISH ROYAL SCHOOL", "LA REINA", "REGION METROPOLITANA", "PLAN DE ESTUDIO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-05", "doble_articulado": false, "id_norma": "70805", "numero_fuente": "35747", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-04-22", "vigencias": [{"desde": "1997-04-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Úni