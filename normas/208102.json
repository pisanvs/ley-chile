{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6415972}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 507, de 18 de febrero de 2003, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA PLAYA BLANCA S.A., para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Bah&#xED;a Calderilla S/N, Caldera, III Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de harina y aceite, los siguientes recursos hidrobiol&#xF3;gicos: Bacaladillo o mote, Jurel fino, Machuelo o tritre, Anchoveta blanca, Sardina redonda, Vinciguerria.</div><br></div>", "i": 6415973}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de febrero de 2003.- Jessica Fuentes Olmos, Subsecretario de Pesca (S).</div><br></div>", "i": 6415974}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "507", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-507"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-02-18", "doble_articulado": false, "id_norma": "208102", "numero_fuente": "37500", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-03-04", "vigencias": [{"desde": "2003-03-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-03-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-03-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-03-04", "f