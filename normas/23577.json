{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Rehabilita al Capitan de Nav&#xED;o don Luis G&#xF3;mez Carre&#xF1;o para acojerse a los beneficios de la lei n&#xFA;m.</div><div class=\"p\">2,040</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,898.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5954381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Rehabil&#xED;tase, por gracia, al Capitan de Nav&#xED;o don Luis G&#xF3;mez Carre&#xF1;o para acogerse la los beneficios de la lei de 9 de Setiembre de 1907. </div></div>", "i": 5954382}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 8 de Julio de 1914.- RAMON BARROS LUCO.-</div><div class=\"p\">R. Corbalan Melgarejo.</div><br></div>", "i": 5954383}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2898", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2898"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "REHABILITA AL CAPITAN DE NAVIO DON LUIS GOMEZ CARREÑO PARA ACOJERSE A LOS BENEFICIOS DE LA LEI NUM. 2,040", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LUIS GOMEZ CARRE O", "REHABILITACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1914-07-08", "doble_articulado": false, "id_norma": "23577", "numero_fuente": "10925", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1914-07-21", "vigencias": [{"desde": "1