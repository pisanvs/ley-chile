{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8327184}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 173 de 30 de enero de 1998, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por 90 d&#xED;as, a contar del 31 de diciembre de 1997, el plazo otorgado a PESQUERA MARBELLA S.A., para continuar realizando operaciones pesqueras con la nave &quot;Costa Grande 2&quot;, autorizada por la Resoluci&#xF3;n N&#xBA; 172 de 1982 y N&#xBA; 577 de 1997, de esta Subsecretar&#xED;a, respecto de las especies Anchoveta, Sardina espa&#xF1;ola y Jurel en la III y IV regiones, en virtud de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 8327185}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de enero de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8327186}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "173", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-173"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MARBELLA S.A.", "PLAZO", "AMPLIACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1998-01-30", "fecha_derogacion": "2000-06-24", "doble_articulado": false, "id_norma": "96271", "numero_fuente": "35989", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1998-02-12", "vigencias": [{"desde": "2000-06-24", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1998-02-12", "ha