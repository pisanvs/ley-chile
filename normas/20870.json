{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 276 EXENTO, DE 1996 </div></div>", "i": 5943412}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto exento N&#xB0; 276, de fecha 17 de mayo de 1996 del Ministerio de Educaci&#xF3;n, se sustituy&#xF3; el art&#xED;culo &#xFA;nico del <a href=\"https://www.leychile.cl/Navegar?idNorma=1049144&amp;idParte=&amp;idVersion=\">Decreto exento N&#xB0; 29</a> del 3 de febrero de 1983, correspondiente al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto de Massachusset Limitada, por el siguiente nuevo:</div><br><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico: Autor&#xED;zase el funcionamiento del Centro de Formaci&#xF3;n T&#xE9;cnica que se indica, organizado por la persona jur&#xED;dica que se se&#xF1;ala, cuyo fin es la docencia a nivel t&#xE9;cnico para egresados de ense&#xF1;anza media:</div><div class=\"p\">&nbsp; &nbsp; Nombre de la Instituci&#xF3;n: Centro de Formaci&#xF3;n T&#xE9;cnica Massachusetts.</div><div class=\"p\">&nbsp; &nbsp; Domicilio: Talca.</div><div class=\"p\">&nbsp; &nbsp; Organizador: Sociedad Centro de Formaci&#xF3;n T&#xE9;cnica Massachusetts Limitada o C.F.T. Massachusetts Limitada.&quot;.</div><br><br></div>", "i": 5943413}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 27 de junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5943414}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "276 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-276 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_derogacio