{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8309546}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. 18 de fecha 29 de Enero de 1992 del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la Personalidad Jur&#xED;dica de la Federaci&#xF3;n de Organizaciones Agr&#xED;colas de Malleco A.G. inscrita bajo el No. 89-9 del Registro que para tal efecto lleva este Ministerio, por haberse configurado respecto de ella, la causal de cancelaci&#xF3;n contemplada en art&#xED;culo 18 No. 2 letra a) del DL No. 2.757, de 1979.</div><br></div>", "i": 8309547}, {"t": "<div><div class=\"p\">Jorge Marshall Rivera, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 8309548}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "18", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-18"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE ECONOMIA, FOMENTO Y ECONSTRUCCION"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-01-29", "doble_articulado": false, "id_norma": "79179", "numero_fuente": "34223", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-03-20", "vigencias": [{"desde": "1992-03-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-03-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-03-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1997-12-09", "fecha_version": "1992-03-20", "fecha_actuali