{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8933111}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.606, de 17 de mayo de 2010, de esta Subsecretar&#xED;a, ampl&#xED;ese por doce meses, a contar del 1&#xBA; de marzo de 2010, el plazo otorgado en el numeral 5&#xBA; inciso 2&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=33477&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 153, de 1994</a>, y en el numeral 4&#xBA; inciso 2&#xBA; de la <a href=\"https://www.leychile.cl/Navegar?idNorma=214870&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 2.050, de 2003</a>, ambas de esta Subsecretar&#xED;a, que autorizaron a MAR&#xCD;A BAYCIC BAYCIC para desarrollar actividades pesqueras extractivas con la nave &quot;Don Mario&quot; en el &#xE1;rea mar&#xED;tima comprendida entre Cha&#xF1;aral y la VIII Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con arrastre, sobre el recurso Besugo, en virtud de haberse acreditado una circunstancia de fuerza mayor.</div></div>", "i": 8933112, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de mayo de 2010.- Pablo Galilea Carrillo, Subsecretario de Pesca.</div><br></div>", "i": 8933113}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1606 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1606 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2010-05-17", "fecha_derogacion": "2014-03-14", "doble_articulado": false, "id_norma": "1014404", "tipo_ve