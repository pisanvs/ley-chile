{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CAMBIA EL NOMBRE DE LA ESCUELA DE ROMERAL QUE INDICA, POR EL QUE SE&#xD1;ALA</div><div class=\"p\">&nbsp; &nbsp; El Congreso Nacional ha tenido a bien prestar su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5973023}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. La Escuela N&#xB0; 16 de Romeral, se denominar&#xE1; en la sucesivo &quot;Escuela N&#xB0; 16 Arturo Alessandri Palma&quot;.&quot; </div></div>", "i": 5973024}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintisiete de agosto de un mil novecientos cincuenta y nueve.- JORGE ALESSANDRI RODRIGUEZ.- Francisco Cereceda.</div><br></div>", "i": 5973025}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "13379", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-13379"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "CAMBIA EL NOMBRE DE LA ESCUELA DE ROMERAL QUE\nINDICA, POR EL QUE SEÑALA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAMBIO NOMBRE", "ESCUELA N 16 ARTURO ALESSANDRI PALMA", "ROMERAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1959-08-27", "doble_articulado": false, "id_norma": "27459", "numero_fuente": "24461", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1959-10-07", "vigencias": [{"desde": "1959-10-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1959-10-07", "fin_vigencia": ""}, "vigencias