{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6450914}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.924, de 19 de noviembre de 2003 de esta Subsecretar&#xED;a, autor&#xED;zase a PEDRO JULIO TAPIA BONILLA, para iniciar actividades pesqueras de transformaci&#xF3;n, en orden a operar una planta ubicada en La Serena N&#xBA; 058, Tongoy, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso Cocido, Fresco, Enfriado, Fresco refrigerado y Congelado, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6450915}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 19 de noviembre de 2003.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6450916}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2924 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2924 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-11-19", "doble_articulado": false, "id_norma": "217953", "numero_fuente": "37723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-29", "vigencias": [{"desde": "2003-11-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-11-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-11-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2003-12-01", "fech