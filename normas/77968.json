{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;185, DE 1992 </div></div>", "i": 6051566}, {"t": "<div><div class=\"p\">Por Decreto Exento N&#xBA;185 de fecha 30 de junio de 1992 del Ministerio de Educaci&#xF3;n, se derog&#xF3; el Decreto Exento de Educaci&#xF3;n N&#xBA;391 de 28 de diciembre de 1990, que autoriz&#xF3; el funcionamiento al Instituto Profesional CET de Santiago, organizado por el Instituto Profesional CET Sociedad de Responsabilidad Limitada, y se elimin&#xF3; del Libro de Registro de Institutos Profesionales el N&#xBA;81, correspondiente a la instituci&#xF3;n antes se&#xF1;alada.</div><br></div>", "i": 6051567}, {"t": "<div><div class=\"p\">Santiago, 14 de Agosto de 1992.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6051568}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "185 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-185 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº185, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-30", "doble_articulado": false, "id_norma": "77968", "numero_fuente": "34374", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-25", "vigencias": [{"desde": "1992-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-08-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-08-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_pa