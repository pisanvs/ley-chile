{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 313 EXENTA, DE 2015</div><div class=\"p\"> </div></div>", "i": 9585915}, {"t": "<div><div class=\"p\">&nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 313, de fecha 17 de febrero de 2015, del Departamento de Asuntos Internacionales, de la Subsecretar&#xED;a de Transportes, se autoriz&#xF3; a la empresa chilena &quot;Transportes Ghisoni Limitada&quot; para efectuar transporte internacional terrestre de pasajeros, por 5 meses, entre Punta Arenas (Chile) y R&#xED;o Gallegos (Argentina), y viceversa, utilizando el paso Monte Aymond con 1 (una) frecuencia semanal de ida y vuelta.</div></div>", "i": 9585916}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Alfredo Steinmeyer Espinosa, Abogado Departamento de Asuntos Internacionales Subsecretar&#xED;a de Transportes.</div></div>", "i": 9585917}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "313 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-313 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 313 EXENTA, DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-02-17", "doble_articulado": false, "id_norma": "1075874", "numero_fuente": "41122", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-04-01", "vigencias": [{"desde": "2015-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia