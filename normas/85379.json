{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION No. EX. 1.008, DE 1992 </div></div>", "i": 7220326}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n No. Ex. 2.632, de fecha veintiocho de julio de 1992, el suscrito ha procedido a modificar la Resoluci&#xF3;n No. Ex. 1.008, de fecha 25 de marzo de 1992, de esta IX Direcci&#xF3;n Regional, en la forma siguiente:</div><div class=\"p\">1.) En la letra &quot;a del numeral &quot; 1 &quot;, se intercala entre la expresi&#xF3;n &quot;N.s&quot; y la cifra &quot;10&quot;, los guarismos &quot;6&quot; y &quot;7&quot;, separados por una coma (,).</div><div class=\"p\">2.) En el No. 3, se intercala entre la expresi&#xF3;n &quot;N.s&quot; y la cifra &quot;10&quot;, los guarismos &quot;6&quot; y &quot;7&quot;, separados por una coma (,).</div><br></div>", "i": 7220327}, {"t": "<div><div class=\"p\">Mario Valenzuela Ram&#xED;rez, Director Regional.- Benedicto R&#xED;os Villablanca, Secretario Regional.</div><br></div>", "i": 7220328}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2632 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2632 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "MODIFICA RESOLUCION No. EX. 1.008, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-07-28", "doble_articulado": false, "id_norma": "85379", "numero_fuente": "34339", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-08-11", "vigencias": [{"desde": "1992-08-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia