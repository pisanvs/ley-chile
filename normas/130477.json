{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; MODIFICA ORDENANZA SOBRE DERECHOS MUNICIPALES </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Decreto:</div><br></div>", "i": 9074500}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Modif&#xED;case la Ordenanza sobre Derechos Municipales No. 84 de 14 de Enero de 1988 en lo siguiente:</div><div class=\"p\">&nbsp; &nbsp;  Reb&#xE1;jase la tasa del 0,5% de una Unidad Tributaria Mensual, que se&#xF1;ala el n&#xFA;mero 17 del Art&#xED;culo 12 de la Ordenanza Municipal, por una tasa del 0,4% y reempl&#xE1;cese dicho numerando 17 del Art&#xED;culo 12 por el que sigue:</div><div class=\"p\">&nbsp; &nbsp;  &quot;Extracci&#xF3;n de arena, ripio u otros materiales, de Bienes Nacionales de Uso P&#xFA;blico o de pozos lastreros de propiedad particular 0,4% de una UTM&quot;.-</div><br></div>", "i": 9074501}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Alcalde.</div><br></div>", "i": 9074502}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-S/N"}], "organismos": ["MUNICIPALIDAD DE PUDAHUEL"], "titulo_norma": "MODIFICA ORDENANZA SOBRE, DERECHOS MUNICIPALES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "130477", "numero_fuente": "33167", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-08", "vigencias": [{"desde": "1988-09-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-09-08", "fin_vigencia": "", "tipo_version": "3"}], "eve