{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACION DE EMISOR ELECTRONICO </div></div>", "i": 6589135}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 137, de fecha 10 de noviembre de 2006, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como emisor electr&#xF3;nico.</div><div class=\"p\">&nbsp; &nbsp;  Se deroga autorizaci&#xF3;n otorgada a contribuyente RUT N&#xBA; 76.517.940-8, para operar como emisor de Documentos Tributarios Electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de noviembre de 2006.</div><br><br></div>", "i": 6589136}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "137 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-137 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACION DE EMISOR ELECTRONICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-11-10", "doble_articulado": false, "id_norma": "255097", "numero_fuente": "38613", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-11-14", "vigencias": [{"desde": "2006-11-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-11-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-11-14", "fin_vigencia": "", "ti