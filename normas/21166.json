{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 405, DE 1992 </div></div>", "i": 7161801}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por decreto exento N&#xB0; 405 de fecha 03 de Diciembre de 1992, del Ministerio de Educaci&#xF3;n, se reemplazaron, a contar del a&#xF1;o 1992, las normas de evaluaci&#xF3;n, promoci&#xF3;n y titulaci&#xF3;n del Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Chileno Alem&#xE1;n de Cultura de San Antonio, que fueran aprobadas por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xB0; 3463 de 1988.</div><br></div>", "i": 7161802}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 7 de Abril de 1993.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161803}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "405 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-405 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 405, DE 1992", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "INSTITUTO CHILENO ALEMAN", "CULTURA SAN ANTONIO", "REGLAMENTO ACADEMICO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-12-03", "doble_articulado": false, "id_norma": "21166", "numero_fuente": "34554", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-04-30", "vigencias": [{"desde": "1993-04-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-04-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1993-04-30", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text":