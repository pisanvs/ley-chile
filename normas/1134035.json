{"html": [{"t": "<div><br><br><div class=\"p\">SUBROGACION DE LA CAMARA PARA PROPONER LOS EMPLEOS DE ADMINISTRACION DE JUSTICIA.</div><br><br><div class=\"p\">&nbsp; &nbsp;  EL DIRECTOR SUPREMO DEL ESTADO &amp;a.</div></div>", "i": 10042744}, {"t": "<div><br><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto de acuerdo con el Senado Conservador he decretado:</div><br><div class=\"p\">&nbsp; &nbsp;  Que la C&#xE1;mara de Justicia debe representar al Supremo Poder Judiciario para los efectos del art. 21 de la acta org&#xE1;nica de union.</div><br><div class=\"p\">&nbsp; &nbsp;  Por tanto ordeno que se publique por lei insert&#xE1;ndose en el Boletin. Dado en el Palacio Directorial de Santiago a 24 de Mayo de 1823.</div><br></div>", "i": 10042745}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Mariano de Ega&#xF1;a.</div></div>", "i": 10042746}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "SUBROGACION DE LA CAMARA PARA PROPONER LOS EMPLEOS DE ADMINISTRACION DE JUSTICIA.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-05-24", "doble_articulado": false, "id_norma": "1134035", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-05-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-05-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-05-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendient