{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Fija los derechos de internacion que pagar&#xE1;n los f&#xF3;sforos de madera</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,731.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953995}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Los f&#xF3;sforos de madera pagar&#xE1;n a su internacion un derecho de cuarenta centavos oro de 18 peniques, por cada kilo de peso bruto.</div><div class=\"p\">&nbsp; &nbsp; Esta lei comenzar&#xE1; a rejir sesenta dias despues de su promulgacion en el Diario Oficial.</div><br></div>", "i": 5953996}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto ordeno se promulgue i lleve a efecto en todas sus partes como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 31 de Diciembre de 1912.- RAMON BARROS LUCO.- Manuel Rivas Vicu&#xF1;a.</div><br></div>", "i": 5953997}], "proyectos": [{"categoria": "Proyectos de Modificación", "pls": [{"p": 0, "n": "", "enlace": "http://www.senado.cl/appsenado/templates/tramitacion/index.php?boletin_ini=12595-07", "informacion": "Promueve la simplificación legislativa", "nroBoletin": "12595-07"}]}], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2731", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2731"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "FIJA LOS DERECHOS DE INTERNACION QUE PAGARAN LOS FOSFOROS DE MADERA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["FOSFOROS MADERA", "DERECHOS INTERNACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita