{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8298741}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 1.986 de 28 de noviembre de 1996, de esta Subsecretar&#xED;a de Pesca, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n; deni&#xE9;gase la solicitud para ampliar actividades pesqueras extractivas en el litoral de las III y IV Regiones con la nave &quot;Puchuldiza&quot;, presentada por EMPRESA PESQUERA EPERVA S.A., por haberse verificado las causales denegatorias se&#xF1;aladas en el art&#xED;culo 19 letras a) y c) de la Ley N&#xB0; 18.892 y sus modificaciones.</div><br></div>", "i": 8298742}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 28 de noviembre de 1996.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8298743}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1986", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1986"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DENEGACION", "AMPLIACION", "EMPRESA PESQUERA EPERVA S.A.", "PESCA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-11-28", "doble_articulado": false, "id_norma": "37622", "numero_fuente": "35632", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-12-04", "vigencias": [{"desde": "1996-12-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-12-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-12-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vincu