{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6505190}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto M.O.P. N&#xBA; 901, de 5 de octubre de 2004, se dej&#xF3; sin efecto los numerales 3&#xB0;, 4&#xB0;, 5&#xB0; y 6&#xB0;, de decreto M.O.P. N&#xBA; 275, de 31 de marzo de 2004, en la parte que se refiere al Convenio de Directo Precio Ad - Referendum, a la suscripci&#xF3;n de la escritura de expropiaci&#xF3;n y en lo que respecta a la indemnizaci&#xF3;n. Cons&#xED;gnese judicialmente el monto provisional de la indemnizaci&#xF3;n del lote N&#xBA; 145-A. Fijada por la comisi&#xF3;n de peritos, con fecha 12 de septiembre de 2002, ascendente a la cantidad de $3.401.580.</div><br></div>", "i": 6505191}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6505192}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "901", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-901"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-05", "doble_articulado": false, "id_norma": "232557", "numero_fuente": "38011", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-15", "vigencias": [{"desde": "2004-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ing