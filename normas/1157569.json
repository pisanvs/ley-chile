{"html": [{"t": "<div><div class=\"p\">SOBRE QUE SE PROVEA DE VESTUARIO A LOS INVALIDOS</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Abril 16 de 1823</div></div>", "i": 10227743}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  50 Habi&#xE9;ndose observado la desnudez en que se hallan los individuos del cuerpo de invalidas, y siendo justo atender a estos meritorios individuos; proc&#xE9;dase desde luego a proveerles de una chaqueta, y un pantal&#xF3;n de pa&#xF1;o azul, un poncho, dos camisas, y una gorra tambi&#xE9;n de a&#xF1;o con el distintivo de dos sintas blancas.</div></div>", "i": 10227744}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE</div><div class=\"p\">&nbsp; &nbsp; &nbsp;  Rivera</div></div>", "i": 10227745}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "SOBRE QUE SE PROVEA DE VESTUARIO A LOS INVALIDOS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-04-16", "doble_articulado": false, "id_norma": "1157569", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-04-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-04-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-04-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289", "fecha_ingreso": "2021-05-17", "fecha_version": "1823-04-16", "fecha_actualizacion_texto": "2021-05-17", "tipo_tratado": ""}, "alert