{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8330926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 793, de 29 de mayo de 1998, de</div><div class=\"p\">esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a,</div><div class=\"p\">Fomento y Reconstrucci&#xF3;n, deni&#xE9;gase la solicitud de</div><div class=\"p\">concesi&#xF3;n de acuicultura N&#xBA; 95110238, presentada por</div><div class=\"p\">PEDRO JAIME BARRIA PEREZ, para operar un centro de</div><div class=\"p\">cultivo en Canal Puyuguapi, Paso Sibbald, Isla</div><div class=\"p\">Magdalena, Punta Trigue&#xF1;a, comuna de Cisnes, provincia</div><div class=\"p\">de Ays&#xE9;n, XI Regi&#xF3;n, conforme lo dispuesto&nbsp; en el</div><div class=\"p\">art&#xED;culo 78, inciso 2&#xBA;, de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8330927}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de mayo de 1998.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8330928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "793", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-793"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONCESION DE ACUICULTURA", "CISNES", "PEDRO JAIME BARRIA PEREZ", "DECIMOPRIMERA REGION", "DENEGACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-05-29", "doble_articulado": false, "id_norma": "100773", "numero_fuente": "36084", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-08", "vigencias": [{"desde": "1998-06-08", "hasta":