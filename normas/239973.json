{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION N&#xBA; 481 EXENTA, DE 2003</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 628 exenta.- Santiago, 4 de julio de 2005.- Vistos: Lo dispuesto en el art&#xED;culo 192 del C&#xF3;digo Tributario, dicto la siguiente,</div><br><div class=\"p\">&nbsp; &nbsp;  Resoluci&#xF3;n:</div><br></div>", "i": 8019188}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sustit&#xFA;yase en el art&#xED;culo primero transitorio de la resoluci&#xF3;n exenta N&#xBA; 481, de 15 de julio de 2003, del Ministerio de Hacienda, el guarismo &quot;2005&quot; por el guarismo &quot;2006&quot;.</div><br></div>", "i": 8019189}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Nicol&#xE1;s Eyzaguirre Guzm&#xE1;n, Ministro de Hacienda.</div><div class=\"p\">&nbsp; &nbsp;  Lo que transcribo a Ud. para su conocimiento.- Saluda atentamente a Ud., Mar&#xED;a Eugenia Wagner Brizzi, Subsecretaria de Hacienda.</div><br></div>", "i": 8019190}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "628 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-628 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA RESOLUCION Nº 481 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-07-04", "doble_articulado": false, "id_norma": "239973", "numero_fuente": "38207", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-11", "vigencias": [{"desde": "2005-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-11", "fin_vigencia": ""}, "vigencias_version