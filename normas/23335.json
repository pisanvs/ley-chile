{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Declara libre de derechos de aduana, durante diez a&#xF1;os, las duelas de roble i encina elaboradas para vasijas</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 2,507.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5953526}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO.- Se declaran libres de derechos de internacion, por el t&#xE9;rmino de diez a&#xF1;os, las duelas de roble i encina elaboradas para vasijas.</div><br></div>", "i": 5953527}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, o&#xED;do el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 28 de Junio de 1911.- RAMON BARROS LUCO.- Roberto S&#xE1;nchez.</div><br></div>", "i": 5953528}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "2507", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-2507"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "DECLARA LIBRE DE DERECHOS DE ADUANA, DURANTE DIEZ AÑOS, LAS DUELAS DE ROBLE I ENCINA ELABORADAS PARA VASIJAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["VASIJAS", "DUELAS ROBLE", "DUELAS ENCINA", "DERECHOS", "INTERNACION", "EXENCION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1911-06-28", "doble_articulado": false, "id_norma": "23335", "numero_fuente": "10020", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1911-07-03", "vigencias": [{"desde": "1911-07-03", "hasta": "", "tipo_version": "3"