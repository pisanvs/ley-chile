{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SUPLEMENTOS Lei n&#xFA;m. 310.- Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 5947482}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dense los suplementos que se espresan a los siguientes &#xED;tems de la partida 39 del presupuesto de Industria i Obras P&#xFA;blicas: Al &#xED;tem 3, para pagos de trasportes i fletes, cinco mil pesos ($ 5,000).</div><div class=\"p\">&nbsp; &nbsp; Al &#xED;tem 6, para pago de vi&#xE1;ticos de injenieros i otros empleados, i trasporte de los mismos, diez mil pesos ($ 10.000).</div><br><br></div>", "i": 5947483}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; En Santiago de Chile, a los 25 dias del mes de Octubre de 1895.- JORJE MONTT.- J. M. D&#xE1;vila B. </div></div>", "i": 5947484}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "310", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-310"}], "organismos": ["MINISTERIO DE INDUSTRIA Y OBRAS PÚBLICAS"], "titulo_norma": "SUPLEMENTOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1895", "MODIFICACION", "MINISTERIO", "INDUSTRIA - OBRAS PUBLICAS", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1895-10-25", "doble_articulado": false, "id_norma": "22161", "numero_fuente": "5244", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1895-10-26", "vigencias": [{"desde": "1895-10-26", "hasta": "", "t