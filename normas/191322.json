{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA; 169, DE 1990 </div></div>", "i": 6355947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto Supremo Exento de Educaci&#xF3;n N&#xBA; 169, de 20 de Junio de 1990, se aprob&#xF3; Plan Especial de Estudio al Colegio Arabe de Santiago que se aplicar&#xE1; a contar del a&#xF1;o escolar 1990 en todos los cursos de la Ense&#xF1;anza General B&#xE1;sica y de 1&#xBA; a 3er. a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico - Cient&#xED;fica y en el a&#xF1;o 1991 en 4o a&#xF1;o Medio.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo se aprobaron Planes Electivos que se ofrecer&#xE1;n en 3&#xBA; y 4&#xBA; en 1990 y en 1991, de acuerdo a normas que aqu&#xED; se sancionan.-</div><br></div>", "i": 6355948}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 02 de Julio de 1990.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6355949}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "169 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-169 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº 169, DE 1990", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-06-20", "doble_articulado": false, "id_norma": "191322", "numero_fuente": "33735", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-08-02", "vigencias": [{"desde": "1990-08-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-08-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-08-02", "fin_vigen