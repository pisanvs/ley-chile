{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 115 EXENTO, DE 2000</div><br><br></div>", "i": 6275869}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 115 de fecha 10 de abril de 2000 del Ministerio de Educaci&#xF3;n, se autoriz&#xF3; el funcionamiento de una nueva sede del Instituto Profesional de ENAC, ubicada en Avda. Apoquindo N&#xBA; 6471, comuna de Las Condes, de la ciudad de Santiago, para impartir la carrera profesional antes aprobada por la instituci&#xF3;n, a contar del a&#xF1;o 1999:</div><br><br><div class=\"p\">Carrera : Orientaci&#xF3;n Familiar, conducente al t&#xED;tulo</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; profesional de Orientador Familiar (decreto exento</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; de Educaci&#xF3;n N&#xBA; 1.072 del 07.12.98).</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Entidad examinadora: Pontificia Universidad</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Cat&#xF3;lica de Chile.</div><br></div>", "i": 6275870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 2 de mayo de 2000.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6275871}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "115 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-115 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 115 EXENTO, DE 2000", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-04-10", "fecha_derogacion": "2018-11-07", "doble_articulado": false, "id_norma": "168856", "tipo_version": "2", "tipo_version_s": "Última Versión", "fe