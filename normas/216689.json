{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE CHILE EN SU SESION N&#xBA; 1.092</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 1.092, celebrada el 30 de octubre de 2003, adopt&#xF3; los siguientes Acuerdos:</div><br></div>", "i": 6446562}, {"t": "<div><div class=\"p\">1092-02-031030 -&nbsp; Modifica Cap&#xED;tulo III.B.1 del Compendio de Normas Financieras.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; modificar el Cap&#xED;tulo III.B.1 del Compendio de Normas Financieras, reemplazando en la letra b) del N&#xBA; 4, la expresi&#xF3;n Pagar&#xE9;s de la Tesorer&#xED;a General de la Rep&#xFA;blica por Bonos y Pagar&#xE9;s emitidos por la Tesorer&#xED;a General de la Rep&#xFA;blica </div></div>", "i": 6446563}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de octubre de 2003.- Miguel Angel Nacrur Gazali, Ministro de Fe </div></div>", "i": 6446564}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1092", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1092"}, {"tipo": "5", "numero": "1092-02", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1092-02"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO DEL BANCO CENTRAL DE\nCHILE EN SU SESION Nº 1.092", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMPENDIO DE NORMAS FINANCIERAS", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-30", "doble_articulado": false, "id_norma": "216689", "numero_fuente": "37701", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-04", "vigencias": [{"d