{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;PARTIDO DEMOCRATA CRISTIANO&quot; </div></div>", "i": 6013360}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Gutenberg Mart&#xED;nez Ocamica y T&#xF3;mas Pablo Elorza, Presidentes de la Directiva Central y del Tribunal Supremo, respectivamente, del Partido Dem&#xF3;crata Cristiano han informado la actual composici&#xF3;n de la Directiva Central:</div><div class=\"p\"> Directiva Central:</div><div class=\"p\"> Presidente&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Gutenberg Mart&#xED;nez Ocamica</div><div class=\"p\"> 1&#xB0; Vicepresidente&nbsp; &nbsp; : Adolfo Zald&#xED;var Larra&#xED;n</div><div class=\"p\"> 2&#xB0; Vicepresidente&nbsp; &nbsp; : Pedro Goic Karmelic</div><div class=\"p\"> 3&#xB0; Vicepresidente&nbsp; &nbsp; : Felipe Sandoval Precht</div><div class=\"p\"> 4&#xB0; Vicepresidente&nbsp; &nbsp; : Mariana Aylwin Oyarz&#xFA;n</div><div class=\"p\"> 5&#xB0; Vicepresidente&nbsp; &nbsp; : Edmundo P&#xE9;rez Yoma</div><div class=\"p\"> Secretario General&nbsp;  : Genaro Arriagada Herrera</div><div class=\"p\"> Tesorero&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  : Jaime Arancibia Torres</div><div class=\"p\">&nbsp; &nbsp; Publicaci&#xF3;n ordenada en virtud del Auto Acordado del Tribunal Calificador de Elecciones de 27 de Junio de 1988, por Resoluci&#xF3;n O N&#xB0;894, de fecha 02 de Julio de 1993.</div><br></div>", "i": 6013361}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 02 de Julio de 1993.- Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director Servicio Electoral.</div><br></div>", "i": 6013362}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "894", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-894"}, {"tipo": "3", "numero": "O-0894", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-O-0894"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "PARTID