{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6382168}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;854, de 7 de mayo de 2002, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA ITATA S.A. para continuar desarrollando actividades pesqueras extractivas autorizadas a Pesquera Atacama S.A., Oce&#xE1;nica 1 S.A., Pesquera Confish S.A., Pesquera Al-Mar S.A. y Pesquera Quell&#xF3;n S.A.</div><div class=\"p\">&nbsp; &nbsp;  Asimismo, autor&#xED;zase a Pesquera Itata S.A. para continuar desarrollando actividades pesqueras de transformaci&#xF3;n autorizadas a Pesquera Atacama S.A. y Pesquera Confish S.A.</div><br></div>", "i": 6382169}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 7 de mayo de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6382170}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "854", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-854"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2002-05-07", "fecha_derogacion": "2002-08-28", "doble_articulado": false, "id_norma": "198340", "numero_fuente": "37263", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-05-20", "vigencias": [{"desde": "2002-08-28", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-05-20", "hasta": "2002-08-27", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2002-08-28", "fin_vigencia": ""}, "vigencias_version_no