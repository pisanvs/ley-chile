{"html": [{"t": "<div><br><div class=\"p\">REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA</div></div>", "i": 9633402}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  La IX Direcci&#xF3;n Regional de Temuco del SII, por resoluci&#xF3;n Ex N&#xBA; 77315048830 de fecha 18.08.2015, deja sin efecto la <a href=\"https://www.leychile.cl/Navegar?idNorma=220656&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n ex. N&#xBA;1.268 del 31.12.2003</a> que otorga la calidad de agente retenedor de cambio de sujeto de derecho del Impuesto al Valor Agregado en las operaciones de contrato de instalaci&#xF3;n o confecci&#xF3;n de especialidades que contraten, a contar de la fecha de esta publicaci&#xF3;n, al contribuyente Constructora Las Araucarias S.A., RUT N&#xBA;96.985.530-5, conforme a lo establecido en la res. ex. N&#xBA;142 de fecha 26.12.2005, de la Direcci&#xF3;n Nacional del Servicio, publicada en el Diario Oficial de fecha 29.12.2005.</div><br></div>", "i": 9633403, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Christian Soto Torres, Director Regional.</div></div>", "i": 9633404}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "77315048830 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-77315048830 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "IX DIRECCIÓN REGIONAL TEMUCO"], "titulo_norma": "REVOCA CALIDAD DE AGENTE RETENEDOR DE IVA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "IdDO 940261"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-08-18", "doble_articulado": false, "id_norma": "1081153", "numero_fuente": "41248", "tipo_version": "3", "ti