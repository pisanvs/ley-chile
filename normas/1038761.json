{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 2.877 EXENTA, DE 2012</div><br></div>", "i": 9247083}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 2.877, de 23 de marzo de 2012, el Servicio Nacional de Capacitaci&#xF3;n y Empleo dispone el cese de su inscripci&#xF3;n en el Registro Nacional de Organismos T&#xE9;cnicos de Capacitaci&#xF3;n de la entidad &quot;Centro de Capacitaci&#xF3;n Alcal&#xE1; Limitada (Alcal&#xE1; Capacitaci&#xF3;n)&quot;, RUT 76.976.510-7, contenida en la resoluci&#xF3;n exenta N&#xBA; 3.301, de 26 de mayo de 2009, por cuanto dej&#xF3; de cumplir con el requisito establecido en el N&#xBA; 2, del art. 21 de la ley 19.518.-</div></div>", "i": 9247084}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Francisco Ag&#xFC;ero Larrondo, Director Nacional Subrogante.</div></div>", "i": 9247085}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2877 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2877 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 2.877 EXENTA, DE 2012", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-03-23", "doble_articulado": false, "id_norma": "1038761", "numero_fuente": "40231", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-05", "vigencias": [{"desde": "2012-04-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-04-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-04-05", "fin_vigencia": "", "tipo_vers