{"html": [{"t": "<div><div class=\"p\">APRUEBA NUEVA DISTRIBUCION DE COMPETENCIAS EN MATERIA CIVIL EN JUZGADOS DE MENORES DE SANTIAGO </div></div>", "i": 6393696}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En sesi&#xF3;n del Tribunal Pleno de 29 de julio del a&#xF1;o 2002 de la I. Corte de Apelaciones de Santiago se aprueba la nueva distribuci&#xF3;n de competencias en materia civil en los Juzgados de Menores de Santiago, en los siguientes t&#xE9;rminos:</div><br><div class=\"p\">Segundo Juzgado de Menores : desde &quot;A&quot; a &quot;CAP&quot;</div><div class=\"p\">Tercer Juzgado de Menores&nbsp; : desde &quot;CAQ&quot; a &quot;FUR&quot;</div><div class=\"p\">Cuarto Juzgado de Menores&nbsp; : desde &quot;FUS&quot; a &quot;LOA&quot;</div><div class=\"p\">Quinto Juzgado de Menores&nbsp; : desde &quot;LOB&quot; a &quot;PAE&quot;</div><div class=\"p\">S&#xE9;ptimo Juzgado de Menores : desde &quot;PAF&quot; a &quot;SAM&quot;</div><div class=\"p\">Octavo Juzgado de Menores&nbsp; : desde &quot;SAN&quot; a &quot;Z&quot;</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (entera).</div><br><div class=\"p\">&nbsp; &nbsp;  La distribuci&#xF3;n anterior comenzar&#xE1; a regir a contar del 3 de septiembre del a&#xF1;o 2002.-</div><br></div>", "i": 6393697}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Patricia Castro Pardo, Secretaria.</div><br></div>", "i": 6393698}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "23", "numero": "S/N", "abreviacion": "SES", "descripcion": "Sesion", "compuesto": "SES-S/N"}], "organismos": ["CORTE DE APELACIONES DE SANTIAGO"], "titulo_norma": "APRUEBA NUEVA DISTRIBUCION DE COMPETENCIAS EN MATERIA CIVIL EN JUZGADOS DE MENORES DE SANTIAGO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["JUZGADOS DE MENORES", "DISTRIBUCION DE COMPETENCIA", "SANTIAGO"],