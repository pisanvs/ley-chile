{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;232, DE 1991 </div></div>", "i": 7214752}, {"t": "<div><div class=\"p\">Por Decreto Exento N&#xBA;232, de fecha 5 de Agosto de 1991 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; el plan y programa de estudio al Centro de Formaci&#xF3;n T&#xE9;cnica Instituto Superior de Computaci&#xF3;n, de la carrera y t&#xED;tulo t&#xE9;cnico de nivel superior que se indica, para ser impartida a contar del a&#xF1;o 1991:</div><div class=\"p\">Carrera: Secretariado Ejecuci&#xF3;n menci&#xF3;n Inform&#xE1;tica.</div><div class=\"p\">T&#xED;tulo: Secretario(a) Ejecutivo menci&#xF3;n Inform&#xE1;tica. </div></div>", "i": 7214753}, {"t": "<div><div class=\"p\">Santiago, 21 de Noviembre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7214754}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "232 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-232 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº232, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-05", "doble_articulado": false, "id_norma": "79727", "numero_fuente": "34186", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-02-06", "vigencias": [{"desde": "1992-02-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-02-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-02-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione