{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9094870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.889, de 27 de diciembre de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a PESQUERA SUR AUSTRAL S.A., para realizar operaciones pesqueras a contar del 1&#xBA; de enero del a&#xF1;o 2011 y hasta el 31 de diciembre del mismo a&#xF1;o, ambas fechas inclusive, con la nave f&#xE1;brica denominada &quot;Ocean Dawn&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 47&#xB0; L.S. y 57&#xB0; L.S., por fuera de las l&#xED;neas de base recta, respecto de los recursos, en las &#xE1;reas y con las obligaciones establecidas en las respectivas autorizaciones.</div></div>", "i": 9094871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 27 de diciembre de 2010.- Felipe Palacio Rives, Subsecretario de Pesca (S).</div></div>", "i": 9094872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3889 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-3889 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-12-27", "doble_articulado": false, "id_norma": "1021874", "numero_fuente": "39853", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2011-01-07", "vigencias": [{"desde": "2011-01-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2011-01-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2011-01-07", "fin_vigencia": "", "tip