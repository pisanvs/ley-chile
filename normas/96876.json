{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 185, DE 1991 </div></div>", "i": 7231461}, {"t": "<div><div class=\"p\">Por Decreto exento No. 185 de fecha 17 de julio de 1991 del Ministerio de Educaci&#xF3;n, se sustituyeron los incisos 2&#xB0; y siguientes del art&#xED;culo 2&#xB0; del Decreto Exento No. 10 de 1989, que autoriza el funcionamiento del Instituto Profesional de Ciencias y Artes INCACEA y se aprobaron las modificaciones al reglamento a que se refiere el art&#xED;culo 6&#xB0; del DFL No. 5 de 1981, sobre las condiciones para el otorgamiento de los t&#xED;tulos profesionales y t&#xE9;cnicos. </div></div>", "i": 7231462}, {"t": "<div><div class=\"p\">Santiago, 01 de Octubre de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7231463}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "185 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-185 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 185, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-17", "doble_articulado": false, "id_norma": "96876", "numero_fuente": "34099", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-10-24", "vigencias": [{"desde": "1991-10-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-10-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-10-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "u