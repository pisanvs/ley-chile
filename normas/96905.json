{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO N&#xBA; 29&nbsp; EXENTO, DE 1998</div><br></div>", "i": 7231491}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 29 de 20 de enero de 1998, se ha aprobado al Colegio &quot;The Thomas Jefferson School&quot; de Concepci&#xF3;n, VIII Regi&#xF3;n del B&#xED;o-B&#xED;o, para que a partir del a&#xF1;o escolar 1998 y en concordancia con la gradualidad de aplicaci&#xF3;n que establece el Decreto Supremo de Educaci&#xF3;n N&#xBA; 40 de 1996 y sus modificaciones, aplique los planes de estudio para los cursos de 1&#xBA; a 8&#xBA; a&#xF1;o (NB.1 a NB.6) de Ense&#xF1;anza B&#xE1;sica.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio de los subsectores y cursos de 1&#xBA; a 8&#xBA; a&#xF1;o (NB.1 a NB.6) de Ense&#xF1;anza B&#xE1;sica.</div><br></div>", "i": 7231492}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 28 de enero de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7231493}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "29 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-29 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 29 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO THE THOMAS JEFFERSON SCHOOL", "CONCEPCION", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-01-20", "doble_articulado": false, "id_norma": "96905", "numero_fuente": "35998", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion