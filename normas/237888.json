{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6525827}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 1.388, de 6 de mayo de 2005, de esta Subsecretar&#xED;a, d&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.383 de 2005, que incorpor&#xF3; el numeral 19 bis a la resoluci&#xF3;n N&#xBA; 3.729 de 2004, modificada mediante resoluciones N&#xBA; 181, N&#xBA; 861 y N&#xBA;1.062, todas de 2005, de la Subsecretar&#xED;a de Pesca, que autoriz&#xF3; a la UNIVERSIDAD DE VALPARAISO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del proyecto denominado &quot;Administraci&#xF3;n de un sistema de control de esfuerzo y desembarque de capturas en la pesquer&#xED;a artesanal de merluza del sur de la XI Regi&#xF3;n&quot;. </div></div>", "i": 6525828}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de mayo de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6525829}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1388", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1388"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-05-06", "doble_articulado": false, "id_norma": "237888", "numero_fuente": "38159", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-05-12", "vigencias": [{"desde": "2005-05-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-05-12", "fin_vigencia": ""}, "vige