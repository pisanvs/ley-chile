{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY NUMERO 14.171 Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 5974699}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &quot;Art&#xED;culo &#xFA;nico. Substit&#xFA;yese en el art&#xED;culo 137.o de la ley N.o 14.171, la frase &quot;6 a&#xF1;os&quot; por &quot;15 a&#xF1;os&quot;.&quot; </div></div>", "i": 5974700}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, publ&#xED;quese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a veintiocho de Diciembre de mil novecientos sesenta y uno.- JORGE ALESSANDRI RODRIGUEZ.- Luis Mackenna S.</div><br></div>", "i": 5974701}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "14820", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-14820"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "MODIFICA LA LEY NUMERO 14.171", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["BANCO CENTRAL CHILE", "CREDITOS", "MONEDA EXTRANJERA", "CONCESION", "BANCO ESTADO", "BANCOS COMERCIALES", "PLAZO", "CORPORACION FOMENTO PRODUCCION", "AMPLIACION", "INTERESES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1961-12-28", "doble_articulado": false, "id_norma": "27899", "numero_fuente": "25145", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1962-01-16", "vigencias": [{"desde": "1962-01-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1962-01-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigen