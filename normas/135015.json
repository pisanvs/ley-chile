{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCIONES QUE INDICA </div></div>", "i": 8343582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 233 de 03 de Marzo de 1988 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, der&#xF3;gase las resoluciones No. 207 y No. 723, de 1985, ambas de esta Subsecretar&#xED;a, que autorizaron a don Teddy Gari Harris Naour, R.U.T. No.</div><div class=\"p\">7.447.516-4, domiciliado en Niebla, calle Tornagaleones esquina Cochrane, Playa Grande, para desarrollar y ampliar actividades pesqueras de transformaci&#xF3;n, respectivamente, en una planta ubicada en Niebla, Valdivia, X Regi&#xF3;n, por renuncia de su titular. </div></div>", "i": 8343583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 03 de Marzo de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8343584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "233", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-233"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "DEROGA RESOLUCIONES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-03-03", "doble_articulado": false, "id_norma": "135015", "numero_fuente": "33019", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-03-12", "vigencias": [{"desde": "1988-03-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-03-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1988-03-12", "fin_vigen