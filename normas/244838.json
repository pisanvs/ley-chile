{"html": [{"t": "<div><div class=\"p\">EXTRACTO RESOLUCION (A) N&#xBA; 117, DE 2005</div><br><br><br></div>", "i": 8497557}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En cumplimiento de lo dispuesto en los decretos del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, N&#xBA; 291, de 11 de junio de 1999 y N&#xBA; 668, de 16 de noviembre de 1999, certifico que por resoluci&#xF3;n (A) N&#xBA; 117, de 5 de septiembre de 2005, del se&#xF1;or Vicepresidente Ejecutivo, se puso en ejecuci&#xF3;n el Acuerdo de Consejo N&#xBA; 2.365, de 2005, y modifica la resoluci&#xF3;n (A) N&#xBA; 84, de 2005, relativo al Comit&#xE9; de Asignaci&#xF3;n de Fondos - CAF y Comit&#xE9;s de Asignaci&#xF3;n Zonal de Fondos - CAZ.</div><div class=\"p\">&nbsp; &nbsp;  El texto completo de la antes referida resoluci&#xF3;n, estar&#xE1; a disposici&#xF3;n de los usuarios en la Secretar&#xED;a General de la Corporaci&#xF3;n y en las Direcciones Regionales.</div><br></div>", "i": 8497558}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 30 de noviembre de 2005.- Yerko Koscina Peralta, Secretario General.</div><br></div>", "i": 8497559}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "117", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-117"}], "organismos": ["CORPORACIÓN DE FOMENTO DE LA PRODUCCIÓN"], "titulo_norma": "EXTRACTO RESOLUCION (A) Nº 117, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2005-09-05", "fecha_derogacion": "2007-08-23", "doble_articulado": false, "id_norma": "244838", "numero_fuente": "38332", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2005-12-09", "vigencias"