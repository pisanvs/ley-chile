{"html": [{"t": "<div><div class=\"p\">Donativos patri&#xF3;ticos</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Diciembre 16 de 1817</div></div>", "i": 10238049}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Impr&#xED;mase en la Gazeta el informe i certificado de entero de los ministros de la tesorer&#xED;a jeneral por el que aparece la jenerosa oblacion al Estado del ciudadano don Jos&#xE9; Manuel Lecaros de 188 pesos 1&#xBD; real en plata de chafalon&#xED;a, i de 25 novillos gordos que ofrece poner en el paraje que se le designe, i ser&#xE1; en Casa-Blanca en poder del Alcalde don Pedro Jos&#xE9; P&#xE9;rez. D&#xE9;nsele las gracias al Ministerio de Hacienda a nombre de este Supremo Gobierno Delegado, para satisfaccion de la gratitud de su ofrenda.-</div></div>", "i": 10238050}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Cruz.-Dr. Villegas, secretario.</div></div>", "i": 10238051}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Donativos patrióticos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-12-16", "doble_articulado": false, "id_norma": "1159377", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-12-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-12-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-12-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "10418", "fecha_in