{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xBA;208, DE 1989 </div></div>", "i": 6067714}, {"t": "<div><div class=\"p\">Por decreto supremo exento de Educaci&#xF3;n N&#xBA;208, de 19 de diciembre de 1989, se ha autorizado, a contar del a&#xF1;o escolar 1990, a la Escuela D N&#xBA;190 de la Corporaci&#xF3;n Municipal de Pe&#xF1;alol&#xE9;n, por dos a&#xF1;os, para suprimir el Idioma Extranjero II Franc&#xE9;s, en los cursos de 7&#xBA; y 8&#xBA; a&#xF1;o de Educaci&#xF3;n General B&#xE1;sica.</div><br></div>", "i": 6067715}, {"t": "<div><div class=\"p\">Santiago, 4 de Enero de 1990.- Mar&#xED;a Sixtina Barriga Guzm&#xE1;n, Subsecretaria de Educaci&#xF3;n P&#xFA;blica.</div><br></div>", "i": 6067716}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "208 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-208 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "SUBSECRETARÍA DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO Nº208, DE 1989", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-12-19", "doble_articulado": false, "id_norma": "84386", "numero_fuente": "33568", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-12", "vigencias": [{"desde": "1990-01-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-01-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CQA", "fecha_ingreso": "1998-01-13", "fecha_version": "1990-01-12", "fecha_act