{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10224252}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xB0; 740, de fecha 9 de abril de 2021, de esta Secretar&#xED;a Regional, se aprob&#xF3; modificaci&#xF3;n a la <a href=\"https://www.leychile.cl/Navegar?idNorma=1057111&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 6.486, de 6 de diciembre de 2013</a>, que aprob&#xF3; el programa de ense&#xF1;anza para la obtenci&#xF3;n de licencia de conductor Clase B, a la Escuela de Conductores No Profesionales o Clase B &quot;San Osvaldo&quot;, en el sentido de aprobar su nuevo domicilio ubicado en calle Alcalde Jorge Monckeberg N&#xB0; 2290, comuna de Macul. En lo no modificado la resoluci&#xF3;n exenta N&#xB0; 6.486 se mantiene &#xED;ntegramente vigente.- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10224253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Eduardo Stephan Orellana, Secretario Regional Ministerial de Transportes y Telecomunicaciones (S) Regi&#xF3;n Metropolitana.</div><br></div>", "i": 10224254}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "740 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "Resolución-740 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1937705", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-04-09", "doble_articulado": false, "id_norma": "1159185", "numero_fuente": "42946", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "202