{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; PENSION Lei n&#xFA;m. 193.- Santiago, a 20 de Agosto de 1894.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br></div>", "i": 5947111}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Conc&#xE9;dese por gracia a do&#xF1;a Isabel Aliste, madre del alf&#xE9;rez don Enrique Stange, una pensi&#xF3;n vitalicia de veinte pesos mensuales, la que gozar&#xE1; en conformidad a la lei de montep&#xED;o militar.</div><br><br></div>", "i": 5947112}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORGE MONTT.-S. Aldunate B.</div><br></div>", "i": 5947113}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "193", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-193"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "PENSION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ISABEL ALISTE", "MONTEPIO MILITAR"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-20", "doble_articulado": false, "id_norma": "22052", "numero_fuente": "4900", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-08-25", "vigencias": [{"desde": "1894-08-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-08-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-08-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_p