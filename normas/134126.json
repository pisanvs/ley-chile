{"html": [{"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;m. 962.- Santiago, 16 de noviembre de 1897.- Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 6161407}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico.- Ab&#xF3;nase, por gracia, al coronel de Ej&#xE9;rcito, don An&#xED;bal Fr&#xED;as, para los efectos de su retiro, el tiempo que permaneci&#xF3; en la Escuela Militar en calidad de cadete, desde el 2 de marzo hasta el 4 de abril de 1866 i desde el 11 de marzo de 1869 hasta el 15 de setiembre de 1871, o sea, dos a&#xF1;os, siete meses i seis dias.</div><br></div>", "i": 6161408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, dispongo se promulgue i lleve a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C&#xE1;rlos A. Palacios Z.</div><br></div>", "i": 6161409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "962", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-962"}], "organismos": ["MINISTERIO DE GUERRA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1897-11-16", "doble_articulado": false, "id_norma": "134126", "numero_fuente": "5857", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1897-11-18", "vigencias": [{"desde": "1897-11-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1897-11-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1897-11-18", "fin_vigenci