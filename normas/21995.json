{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Suplemento Lei n&#xFA;m. 132.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha aprobado el siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br><br><br><br></div>", "i": 5946877}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese un suplemento de veinticinco mil pesos al &#xED;tem 4 de la partida 34 del presupuesto de Hacienda para la adquisicion, impresion i encuadernacion de libros i publicaciones de avisos i demas documentos correspondientes al Ministerio de Hacienda.</div><br><br></div>", "i": 5946878}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 18 de Diciembre de 1893.- JORJE MONTT.- Alejandro Vial.</div><br></div>", "i": 5946879}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "132", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-132"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "SUPLEMENTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1893", "MODIFICACION MINISTERIO", "HACIENDA PUBLICACIONES", "ENCUADERNACION", "IMPRESOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1893-12-18", "doble_articulado": false, "id_norma": "21995", "numero_fuente": "4696", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1893-12-18", "vigencias": [{"desde": "1893-12-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1893-12-18", "fin_vigencia": "