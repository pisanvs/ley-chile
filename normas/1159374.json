{"html": [{"t": "<div><div class=\"p\">Donativos patri&#xF3;ticos</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Diciembre 15 de 1817</div></div>", "i": 10234999}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  El secretario de Hacienda, a nombre del supremo Gobierno delegado, dar&#xE1; oficialmente las gracias al ciudadano don Pedro Chacon por la insigne oblacion de su persona, de todos sus bienes en caso preciso i de quinientos pesos de contado. Impr&#xED;mase su memorial con este decreto en la Gazeta para ejemplo, i para que los detractores de &#xE9;sta, que titulan est&#xE9;ril porque se llena en la mayor parte con decretos, vean los frutos que esos decretos van en el dia produciendo, e imiten los modelos del heroismo que les presentan sus benem&#xE9;ritos compatriotas.</div></div>", "i": 10235000}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  - T&#xF3;mese razon. - Astorga. - Villegas.</div></div>", "i": 10235001}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Donativos patrióticos", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-12-15", "doble_articulado": false, "id_norma": "1159374", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-12-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-12-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-12-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaci