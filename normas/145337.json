{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6197077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8.1 del Compendio de Normas Financieras certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables de 90 a 365 d&#xED;as, correspondiente a la segunda quincena de mayo de 1987, fue de 4.15% anual.</div><br></div>", "i": 6197078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 11 de junio de 1987.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6197079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE HACIENDA", "BANCO CENTRAL DE CHILE"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-11", "doble_articulado": false, "id_norma": "145337", "numero_fuente": "32794", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-12", "vigencias": [{"desde": "1987-06-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-12", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-12", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JCT", "fecha_ingreso": "1999-10-14", "fecha_version": "1987-06-12", "fecha_actualizacion_texto": "1987-06-12", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6197077}, {"n": "Artículo", "i": 6