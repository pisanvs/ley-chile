{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 430, DE 1998</div><br><br><br></div>", "i": 6135952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo de Educaci&#xF3;n N&#xBA; 430, de 27 de agosto de 1998, se ha aprobado el convenio de fecha 31 de julio de 1998, celebrado entre el Ministerio de Educaci&#xF3;n y la I. Municipalidad de Coquimbo, que rectifica el convenio de traspaso de la Escuela B&#xE1;sica D N&#xBA; 105 de Coquimbo, traspasada a dicha Corporaci&#xF3;n por convenio aprobado por decreto supremo de Educaci&#xF3;n N&#xBA; 10.053, de 15 de diciembre de 1981.</div><br></div>", "i": 6135953}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de octubre de 1998.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6135954}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "430", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-430"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 430, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONVENIO DE TRASPASO", "MINISTERIO DE EDUCACION", "MUNICIPALIDAD DE COQUIMBO", "ESCUELA BASICA D N 105", "RECTIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-08-27", "doble_articulado": false, "id_norma": "126109", "numero_fuente": "36190", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-10-17", "vigencias": [{"desde": "1998-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-10-17", "fin_vigencia": "", "tipo_version": "3"}],