{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6316947}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;5.015, de fecha 31 de octubre de 2000, se expropi&#xF3; el lote de terreno N&#xBA;8, superficie 1.743,8 m&#xB2;, rol de aval&#xFA;o 138-7, comuna de Chonchi, para la obra &apos;&apos;Camino Ruta 5, Sector Chonchi-Tara, Km. 1.205,160 a Km.</div><div class=\"p\">1.215,004&apos;&apos; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Hida Vargas Aguilar y Otros, ascendente a la cantidad de $1.216.804.</div><br></div>", "i": 6316948}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6316949}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "5015", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-5015"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-31", "doble_articulado": false, "id_norma": "180371", "numero_fuente": "36862", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-01-15", "vigencias": [{"desde": "2001-01-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-01-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-01-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CMV", "fecha_ingreso": "2001-01-16", "fecha_version": "2001-01-15", "fecha_actualizacion_texto": "2001-01-15", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructur