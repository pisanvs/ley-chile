{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO EXENTO N&#xB0; 243, de 1993 </div></div>", "i": 7161302}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 243, de fecha 25 de Mayo de 1993 del Ministerio de Educaci&#xF3;n, se aprobaron al Centro de Formaci&#xF3;n T&#xE9;cnica INACAP las adecuaciones introducidas al Plan y Programas de Estudio de la Carrera de Construcci&#xF3;n, las que se insertaron en la Resoluci&#xF3;n Exenta de Educaci&#xF3;n N&#xB0; 3.008 de 1988. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;os 1993.- </div></div>", "i": 7161303}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Julio Valladares Mu&#xF1;oz, Subsecretario de Educaci&#xF3;n. + </div></div>", "i": 7161304}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "243 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-243 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 243, DE 1993", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA INACAP", "MODIFICACION", "PLANES ESTUDIOS", "PROGRAMAS ESTUDIOS", "REGION", "METROPOLITANA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-05-25", "doble_articulado": false, "id_norma": "20784", "numero_fuente": "34799", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1994-02-24", "vigencias": [{"desde": "1994-02-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1994-02-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1994-02-24", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione