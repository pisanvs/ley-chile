{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6085858}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 301 de 27 de junio de 1989, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; al se&#xF1;or Carlos Ren&#xE9; Silva Puratic para efectuar servicio internacional de transporte terrestre de pasajeros en entre Punta Arenas (Chile) y R&#xED;o Gallegos (Argentina), por el Paso Monte Aymond con una frecuencia semanal, de ida y vuelta.</div><br></div>", "i": 6085859}, {"t": "<div><div class=\"p\">Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6085860}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "301 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-301 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-06-27", "doble_articulado": false, "id_norma": "90507", "numero_fuente": "33514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-06", "vigencias": [{"desde": "1989-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-11-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAL", "fecha_ingreso": "1998-02-23", "fecha_version": "1989-11-06", "fecha_actualizacion_texto": "1989-11-06", "tipo_tratado": ""}, "alertas": [], "alerta_glob