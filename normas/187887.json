{"html": [{"t": "<div><div class=\"p\">CORRIGE RESOLUCION N&#xBA; 103 EXENTA, DE 2001 </div></div>", "i": 6343624}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 136, de 20 de junio de 2001, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VI Regi&#xF3;n, se corrige la resoluci&#xF3;n exenta N&#xBA; 103, de 17 de abril de 2001, en el siguiente sentido: donde dice: &quot;concesionada a don Alejandro Denham N&#xFA;&#xF1;ez&quot;, debe decir: &quot;concesionada a Garaje Las Acacias Ltda., representada legalmente por don Alejandro Denham N&#xFA;&#xF1;ez&quot;.</div><br></div>", "i": 6343625}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Rancagua, 20 de junio de 2001.- Lincoln P&#xE9;rez Vera, Secretario Regional Ministerial de Transportes y Telecomunicaciones VI Regi&#xF3;n.</div><br></div>", "i": 6343626}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "136 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-136 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VI REGIÓN DEL LIBERTADOR GENERAL BERNARDO O\\u2019HIGGINS"], "titulo_norma": "CORRIGE RESOLUCION Nº 103 EXENTA, DE 2001", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-06-20", "doble_articulado": false, "id_norma": "187887", "numero_fuente": "37016", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-07-20", "vigencias": [{"desde": "2001-07-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-07-20", "fin_vigencia