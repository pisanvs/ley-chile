{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6505474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto Exento M.O.P. N&#xBA; 1.471, de 27 de</div><div class=\"p\">octubre de 2004, y en base a la facultad otorgada por el</div><div class=\"p\">art&#xED;culo 105 del D.F.L. M.O.P. N&#xB0;850 de 1997, que fij&#xF3; el texto actualizado de la ley N&#xBA; 15.840, se expropi&#xF3; el lote de terreno N&#xB0;14, para la obra Camino Puelo Paso El Bols&#xF3;n, sector Lago Taguatagua - Llanada Grande, Tramo Km. 12,530 a Km. 32,500, que figura a nombre de Diocares Hermosilla Graciela, rol de aval&#xFA;o 157-50, Comuna de Cocham&#xF3;, X Regi&#xF3;n, superficie 10.290 m2. La Comisi&#xF3;n de Peritos, fij&#xF3; con fecha 11 de marzo de 2003, en la cantidad de $1.029.000. La indemnizaci&#xF3;n se pagar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xB0;2.186, de 1978.</div><br></div>", "i": 6505475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div><br><br></div>", "i": 6505476}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1471 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1471 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-27", "doble_articulado": false, "id_norma": "232633", "numero_fuente": "38010", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-11-15", "vigencias": [{"desde": "2004-11-15", "hasta": "", "tipo_version": "3", "tipo_v