{"html": [{"t": "<div><div class=\"p\">AUTORIZA A PESQUERA TRANSANTARTIC LIMITADA PARA AMPLIAR ACTIVIDADES PESQUERAS</div><br><br></div>", "i": 7285495}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 260, de 17 de Marzo de 1986, de la Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se autoriza a Pesquera Transantartic Limitada, domiciliada en Santiago, para instalar y operar un establecimiento de cultivo en balsas y jaulas de salm&#xF3;n plateado, en dos sectores de porciones de agua, uno de 288.000 m2 ubicado en Bah&#xED;a Huenquillahue y el otro de 240.944m2 situado en Bah&#xED;a Huelmo, ambos de la comuna de Puerto Montt, provincia de Llanquihue, X Regi&#xF3;n.</div><br></div>", "i": 7285496}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 17 de Marzo de 1986.- Roberto Verdugo Gormaz, Subsecretario de Pesca.</div><br></div>", "i": 7285497}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "260", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-260"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "AUTORIZA A PESQUERA TRANSANTARTIC LIMITADA PARA AMPLIAR ACTIVIDADES PESQUERAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1986-03-17", "fecha_derogacion": "1989-12-26", "doble_articulado": false, "id_norma": "188956", "numero_fuente": "32430", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1986-03-24", "vigencias": [{"desde": "1989-12-26", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1986-03-24", "hast