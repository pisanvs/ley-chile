{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 6446199}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 117, de 8 de septiembre de 2003, Serviu Regi&#xF3;n Valpara&#xED;so dispuso expropiaci&#xF3;n parcial, conforme art&#xED;culo 87 ley 8.946 y decreto ley 2.186, de 1978, de inmueble ubicado en calle Condell N&#xB0; 52, rol aval&#xFA;o 195-34, comuna Quillota, de presunto dominio de Germ&#xE1;n Osorio Guerra. Comisi&#xF3;n tasadora integrada por Sres. Osvaldo Mu&#xF1;oz Quintana, arquitecto, Alvaro Verdejo Vidal, ingeniero constructor, y Pablo Caria Giurici, constructor civil, seg&#xFA;n informe de fecha 3 de abril de 2003, fij&#xF3; monto provisional indemnizaci&#xF3;n en $3.691.500.- que ser&#xE1; pagada al contado.</div><br></div>", "i": 6446200}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Regi&#xF3;n Valpara&#xED;so.</div><br></div>", "i": 6446201}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "117", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-117"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACIÓN V REGIÓN DE VALPARAISO"], "titulo_norma": "ORDENA EXPROPIACIONES PARCIALES DE INMUEBLES QUE SEÑALA; NOTIFICACION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-08", "doble_articulado": false, "id_norma": "216530", "numero_fuente": "37700", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-11-03", "vigencias": [{"desde": "2003-11-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"