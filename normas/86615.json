{"html": [{"t": "<div><div class=\"p\">DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA </div><div class=\"p\">N&#xFA;m. 316.- Santiago, 22 de Noviembre de 1991.- Vistos: Lo dispuesto en el art&#xED;culo 11 del decreto ley No. 2.974 de 1979.</div><br><div class=\"p\">Resuelvo:</div><br><br><br></div>", "i": 6073574}, {"t": "<div><div class=\"p\">Des&#xED;gnase como receptor judicial para que permanentemente practique las actuaciones inherentes a ese cargo en los juicios que se tramitan ante los Juzgados de Polic&#xED;a Local, en conformidad a las disposiciones del decreto ley citado y en la III Regi&#xF3;n a la funcionaria:</div><div class=\"p\">- Ramona del Carmen Soto Reyes.</div><br></div>", "i": 6073575}, {"t": "<div><div class=\"p\">T&#xF3;mese raz&#xF3;n, an&#xF3;tese, comun&#xED;quese y publ&#xED;quese en el Diario Oficial.- Hugo Ortega Tello, Director Nacional </div></div>", "i": 6073576}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "316", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-316"}], "organismos": ["MINISTERIO DE AGRICULTURA", "INSTITUTO DE DESARROLLO AGROPECUARIO"], "titulo_norma": "DESIGNA COMO RECEPTOR JUDICIAL A FUNCIONARIO QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-11-22", "fecha_derogacion": "1993-03-12", "doble_articulado": false, "id_norma": "86615", "numero_fuente": "34145", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1991-12-18", "vigencias": [{"desde": "1993-03-12", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1991-12-18", "hasta": "1993-03-11", "tipo_version": "0", "tipo_version_s": "Text