{"html": [{"t": "<div><br><div class=\"p\">SOLICITA CONSTITUCI&#xD3;N LEGAL DEL PARTIDO PROGRESISTA EN REGI&#xD3;N QUE INDICA</div></div>", "i": 9263792}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Marco Enr&#xED;quez-Ominami Gumucio y Cristian Warner Villagr&#xE1;n, Presidente y Secretario General de la Directiva Central del Partido Progresista, han solicitado la constituci&#xF3;n legal del partido en la IV Regi&#xF3;n de Coquimbo. La solicitud se&#xF1;ala acompa&#xF1;ar la cantidad de mil quinientas seis (1.506) fichas de afiliaci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n que se ordena para los efectos contemplados en el art&#xED;culo 17&#xB0; de la ley N&#xB0; 18.603, por resoluci&#xF3;n O - N&#xB0; 1.062, de fecha 1 de junio de 2012.- </div></div>", "i": 9263793}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Juan Ignacio Garc&#xED;a Rodr&#xED;guez, Director.</div></div>", "i": 9263794}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1062", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1062"}, {"tipo": "3", "numero": "O-1062", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-O-1062"}], "organismos": ["SERVICIO ELECTORAL"], "titulo_norma": "SOLICITA CONSTITUCIÓN LEGAL DEL PARTIDO PROGRESISTA EN REGIÓN QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-06-01", "doble_articulado": false, "id_norma": "1040804", "numero_fuente": "40281", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-06-07", "vigencias": [{"desde": "2012-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"in