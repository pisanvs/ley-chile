{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE EMISORES ELECTR&#xD3;NICOS </div></div>", "i": 7373069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA;76, de 12 de junio de 2008, que deroga autorizaci&#xF3;n otorgada a contribuyentes para operar como emisores electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n de los contribuyentes RUT</div><div class=\"p\">N&#xBA;11.684.595-4, 6.846.373-4, 76.007.123-4 y RUT N&#xBA;76.269.360-7 se deroga autorizaci&#xF3;n otorgada para operar como emisores de Documentos Tributarios Electr&#xF3;nicos.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio de 2008.</div><br></div>", "i": 7373070}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "76 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-76 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACIÓN DE EMISORES ELECTRÓNICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-06-12", "doble_articulado": false, "id_norma": "272478", "numero_fuente": "39089", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-06-17", "vigencias": [{"desde": "2008-06-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-06-17", "fin_vigencia": ""}, "vigencias