{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6115230}, {"t": "<div><div class=\"p\">Por decreto MOP No. 534, de 29 de abril de 1998, se expropiaron los lotes de terreno No. s 1 y 2 del sector By Pass Coigue y 3 del sector Plaza de Peaje y Pesaje Nicodahue Nacimiento, superficies 5.454 m2, 3.263 m2 y 22.335 m2, roles de aval&#xFA;o73-62, 73-77 y 305-3, comunas de Negrete y Nacimiento, para la obra Camino de la Madera, y se acord&#xF3; el valor de indemnizaci&#xF3;n con sus propietarios Sociedad Agr&#xED;cola Coigue Norte Limitada, Mario Francisco Pacheco Soto y Forestal R&#xED;o Vergara S.A., ascendente a las cantidades de $ 8.827.299.-, $ 5.281.166.- y $ 10.319.556.-, respectivamente.</div><br></div>", "i": 6115231}, {"t": "<div><div class=\"p\">Fiscal del Ministerio de Obras P&#xFA;blicas.</div><div class=\"p\">(1&#xB0;) </div></div>", "i": 6115232}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "534", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-534"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "NEGRETE", "NACIMIENTO", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-04-29", "doble_articulado": false, "id_norma": "120173", "numero_fuente": "36078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-06-01", "vigencias": [{"desde": "1998-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1998-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pen