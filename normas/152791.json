{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;96, DE 1999</div><br><br></div>", "i": 6224197}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n N&#xBA;96, de fecha 17 de diciembre de 1999, se autoriz&#xF3; la existencia y aprob&#xF3; el estatuto de la Cooperativa de Servicios Mineros Industrial Minera de Petorca Limitada, de la comuna de Petorca, en los t&#xE9;rminos que da testimonio el acta constitutiva protocolizada al final de los registros del notario p&#xFA;blico de Santiago Rub&#xE9;n Galecio G&#xF3;mez, bajo el N&#xBA;719-99, con fecha 4 de noviembre de 1999.</div><br></div>", "i": 6224198}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por orden del se&#xF1;or Subsecretario, Carlos Rubio Estay, Jefe Departamento de Cooperativas Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n.</div><br></div>", "i": 6224199}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "96", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-96"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE ECONOMIA", "FOMENTO Y RECONSTRUCCION", "DEPARTAMENTO DE COOPERATIVAS"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº96, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-17", "doble_articulado": false, "id_norma": "152791", "numero_fuente": "36574", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-01-28", "vigencias": [{"desde": "2000-01-28", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-01-28", "fin_vigencia":