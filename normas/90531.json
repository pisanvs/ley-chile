{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6085913}, {"t": "<div><br><div class=\"p\">Por resoluci&#xF3;n exenta No. 548 de 13 de octubre de 1989, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza en forma complementaria a la empresa argentina Transportes Automotores Chevallier S.A., para efectuar servicio internacional de transporte terrestre de pasajeros entre Buenos Aires (Argentina) y Vi&#xF1;a del Mar - Santiago (Chile), por paso Cristo Redentor, alternativa Puyehue, efectuando dos frecuencias semanales de ida y vuelta.</div><br></div>", "i": 6085914}, {"t": "<div><div class=\"p\">Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes.</div><br></div>", "i": 6085915}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "548 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-548 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-10-13", "doble_articulado": false, "id_norma": "90531", "numero_fuente": "33514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-11-06", "vigencias": [{"desde": "1989-11-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-11-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-11-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAL", "fecha_ingreso": "1998-02-23", "fecha_version": "1989-11-06", "fecha_actualizaci