{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6044270}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. N&#xB0;568, de 30 de junio de 1997, se expropiaron los lotes de terreno N&#xB0;s. 2, 3 y 4, superficies 1.799.65, 43,00 y 215,00 m2.</div><div class=\"p\">respectivamente, roles de avalu&#xF3; 180-54, 180-37 y 178-9, comuna de San Clemente, para la obra Camino La Raya Queri Rol J-693, Sector Puente Queri y se acord&#xF3; precio de indemnizaci&#xF3;n con sus propietarios Leonardo Alberto Reyes Garc&#xE9;s, V&#xED;ctor Nery Torres Espinoza y Rosa Edelia Cerpa Tapia y otros ascendentes a las cantidades de $5.231.433, $190.543.- y $290.916.</div><br></div>", "i": 6044271}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6044272}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "568", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-568"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "SAN CLEMENTE", "SEPTIMA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-06-30", "doble_articulado": false, "id_norma": "75282", "numero_fuente": "35843", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-08-16", "vigencias": [{"desde": "1997-08-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-08-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-08-16", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por