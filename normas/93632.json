{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 7228072}, {"t": "<div><div class=\"p\">Por Resoluci&#xF3;n Exenta No. 82, de 24 de febrero de 1989, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriza en forma complementaria a la empresa de origen argentino &quot;El R&#xE1;pido S.R.L.&quot;, para efectuar servicio internacional de transporte terrestre de pasajeros entre Buenos Aires (Argentina) y Lima (Per&#xFA;), en tr&#xE1;nsito por territorio chileno y viceversa, utilizando los pasos Caracoles (T&#xFA;nel Cristo Redentor) y Concordia, con un servicio semanal de ida y vuelta. </div></div>", "i": 7228073}, {"t": "<div><div class=\"p\">Santiago de Chile, 8 de Marzo de 1989.- Manuel G&#xE1;rate Meneses, Coronel, Subsecretario de Transportes. </div></div>", "i": 7228074}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "82 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-82 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1989-02-24", "doble_articulado": false, "id_norma": "93632", "numero_fuente": "33328", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1989-03-21", "vigencias": [{"desde": "1989-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1989-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1989-03-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": []