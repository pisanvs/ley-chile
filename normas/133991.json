{"html": [{"t": "<div><div class=\"p\">ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO CENTRAL DE CHILE EN SU SESION No. 1.860</div><br><div class=\"p\">&nbsp; &nbsp;  Certifico que el Comit&#xE9; Ejecutivo de este Banco Central de Chile en su Sesi&#xF3;n No. 1.860, celebrada el 11 de abril de 1988 adopt&#xF3; el siguiente acuerdo: </div></div>", "i": 6160881}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1860-01-880411 - Modifica Cap&#xED;tulo IV.B.7 del Compendio de Normas Financieras.</div><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; reemplazar en el No. 2 del Cap&#xED;tulo IV.B.7 &quot;Pagar&#xE9;s Reajustables del Banco Central de Chile&quot; del Compendio de Normas Financieras, el guarismo &quot;100&quot; por &quot;20.0&quot;.</div><br></div>", "i": 6160882}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de abril de 1988.- Carmen Hermosilla Valencia, Secretario General.</div><br></div>", "i": 6160883}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "1860", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1860"}, {"tipo": "5", "numero": "1860-01", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-1860-01"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "ACUERDO ADOPTADO POR EL COMITE EJECUTIVO DEL BANCO\nCENTRAL DE CHILE EN SU SESION No. 1.860", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-04-12", "doble_articulado": false, "id_norma": "133991", "numero_fuente": "33044", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-04-13", "vigencias": [{"desde": "1988-04-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única