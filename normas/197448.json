{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6379279}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;789, de 22 de abril de 2002, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de las resoluciones N&#xBA;311 de 1985, N&#xBA;8 de 1987, N&#xBA;264 de 1988 y N&#xBA;148 de 1998, todas de esta Subsecretar&#xED;a, que autorizaron a JUAN NEIRA ALTAMIRANO, en virtud de lo se&#xF1;alado en el art&#xED;culo 143 letras b) y d) del D.S.</div><div class=\"p\">N&#xBA;430 de 1991, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, esto es, no haber operado por m&#xE1;s de doce meses sucesivos en las pesquer&#xED;as autorizadas e incurrir en mora del pago de la patente &#xFA;nica pesquera. </div></div>", "i": 6379280}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 22 de abril de 2002.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6379281}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "789", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-789"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-22", "doble_articulado": false, "id_norma": "197448", "numero_fuente": "37249", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-03", "vigencias": [{"desde": "2002-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-03", "fin_vigencia": "",