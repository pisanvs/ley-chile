{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE RESOLUCION N&#xB0; 2.394 EXENTA, DE 1995 </div></div>", "i": 6026077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluc. Exenta N&#xB0; 2.394 de fecha 24 de Abril de 1995 del Ministerio de Educaci&#xF3;n, se declar&#xF3; que la Universidad Mariscal Sucre inscrita en el Registro de Universidades bajo el Folio C-N&#xB0; 27 de 1989, no cuenta actualmente con entidad examinadora en las carreras de Educaci&#xF3;n Parvularia y Psicolog&#xED;a y, por consiguiente, no est&#xE1; autorizada conforme a la Ley, para impartirlas. </div></div>", "i": 6026078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 17 de Mayo de 1995.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6026079}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2394", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2394"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE RESOLUCION N° 2.394 EXENTA, DE 1995", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["UNIVERSIDAD MARISCAL SUCRE", "EDUCACION PARVULARIA", "PSICOLOGIA", "CARRERA PROFESIONAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1995-04-24", "doble_articulado": false, "id_norma": "40175", "numero_fuente": "35177", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-05-26", "vigencias": [{"desde": "1995-05-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-05-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995-05-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones":