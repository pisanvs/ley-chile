{"html": [{"t": "<div><div class=\"p\">MODIFICA&nbsp; RESOLUCION&nbsp;  N&#xBA;535&nbsp; DE&nbsp; 02/09/2003,</div><div class=\"p\">POSTULACION LLAMADO 7/2003</div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; N&#xFA;m. 628 exenta.- Talca, 2 de octubre de 2003.-</div><div class=\"p\">Vistos: resoluci&#xF3;n exenta N&#xBA;535 de 02/09/03, que llam&#xF3; a postular al llamado 7/2003, Art. 9&#xBA; del D.S. N&#xBA;397 (V. y U.)</div><br><div class=\"p\">&nbsp; &nbsp;  R e s u e l v o:</div><br></div>", "i": 6442417}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  1&#xBA;.- Modif&#xED;case resoluci&#xF3;n exenta N&#xBA;535 de 02/09/03 en los siguientes t&#xE9;rminos:</div><br><div class=\"p\">Oferta 1.- Agr&#xE9;gase Recursos Disponibles 6.680 UF. Oferta 2.- Agr&#xE9;gase Recursos Disponibles 7.000 UF.</div><br><div class=\"p\">&nbsp; &nbsp;  Dem&#xE1;s estipulaciones se mantiene vigente resoluci&#xF3;n exenta 535.</div><br></div>", "i": 6442418}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Jacqueline Reyes Olea, Secretaria Regional Ministerial (S).</div><br></div>", "i": 6442419}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "628 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-628 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SECRETARÍA REGIONAL MINISTERIAL VII REGIÓN DEL MAULE"], "titulo_norma": "MODIFICA RESOLUCION Nº535 DE 02/09/2003,\nPOSTULACION LLAMADO 7/2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-02", "doble_articulado": false, "id_norma": "215487", "numero_fuente": "37678", "tipo_version": "3", "tipo