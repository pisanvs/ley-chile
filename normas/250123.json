{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6571576}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.288, de 10 de mayo de 2006, de esta Subsecretar&#xED;a, autor&#xED;zase a PROCESADORA DE ALIMENTOS OMEGA SEAFOODS LIMITADA, para ampliar actividades pesqueras de transformaci&#xF3;n, en orden a incorporar a la planta ubicada en Avenida Ger&#xF3;nimo M&#xE9;ndez N&#xBA; 2089, Barrio Industrial, Coquimbo, IV Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de proceso Fresco enfriado, Congelado y Cocido, los recursos hidrobiol&#xF3;gicos indicados en la resoluci&#xF3;n extractada. </div></div>", "i": 6571577}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de mayo de 2006.- Carlos Hern&#xE1;ndez Salas, Subsecretario de Pesca.</div><br></div>", "i": 6571578}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1288 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1288 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-05-10", "doble_articulado": false, "id_norma": "250123", "numero_fuente": "38479", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-02", "vigencias": [{"desde": "2006-06-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-06-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-06-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_