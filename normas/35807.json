{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294733}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 889, de 12 de Noviembre de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el n&#xFA;meral 1&#xB0; de la Resoluci&#xF3;n N&#xB0; 1674, de 1989, de esta Subsecretar&#xED;a, que estableci&#xF3; las caracter&#xED;sticas n&#xE1;uticas de las naves &quot;Corsario&quot; y &quot;Bucanero&quot;, de PESQUERA GUIMAR S.A. R.U.T. N&#xB0; 95.269.000-0, en el sentido de se&#xF1;alar que la capacidad de bodega de la nave &quot;Corsario&quot; es de 57,11 m3 y de la nave &quot;Bucanero&quot; 56,79 m3.</div><br></div>", "i": 8294734, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 12 de Noviembre de 1993.- Alvaro Briones Ram&#xED;rez, Subsecretario de Pesca Subrogante.</div><br></div>", "i": 8294735}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "889", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-889"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA GUIMAR S.A.", "MODIFICACION", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1993-11-12", "doble_articulado": false, "id_norma": "35807", "numero_fuente": "34725", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1993-11-25", "vigencias": [{"desde": "1993-11-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1993-11-25", "fin_vigencia": ""}, "vigencias_versi