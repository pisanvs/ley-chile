{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8294322}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por resoluci&#xF3;n N&#xB0; 811, de 20 de octubre de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, ampl&#xED;ase por un a&#xF1;o a contar del 10 de abril de 1993, el plazo otorgado a PESQUERA CHILE SUR S.A., R.U.T. N&#xB0; 96.565.200-0, para operar la planta industrial autorizada por la resoluci&#xF3;n N&#xB0; 317, de 1991, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de una fuerza mayor.</div><br><br></div>", "i": 8294323}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 20 de octubre de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8294324}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "811", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-811"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INDUSTRIA PESQUERA", "PESQUERA CHILE SUR S.A.", "AMPLIACION", "PLAZO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-10-20", "fecha_derogacion": "1995-06-16", "doble_articulado": false, "id_norma": "35622", "numero_fuente": "34708", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-11-05", "vigencias": [{"desde": "1995-06-16", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "1993-11-05", "hasta": "1995-06-15", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "1995-06-16", "fin_vigencia": ""}, "vig