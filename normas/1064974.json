{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9493096}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por Decreto M.O.P. (EXENTO) N&#xBA; 550 de 15 de julio de 2014, se desisti&#xF3; de la expropiaci&#xF3;n del lote N&#xBA;17, ordenada por el <a href=\"https://www.leychile.cl/Navegar?idNorma=1033636&amp;idParte=&amp;idVersion=\">Decreto MOP (Exento) N&#xBA;3636 de 11 de noviembre de 2011</a>, debido a que el lote expropiado no fue utilizado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del Decreto Ley N&#xBA; 2186, de 1978.</div><br></div>", "i": 9493097, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blica.</div></div>", "i": 9493098}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "550 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-550 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2014-07-15", "doble_articulado": false, "id_norma": "1064974", "numero_fuente": "40922", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2014-08-01", "vigencias": [{"desde": "2014-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2014-08-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2014-08-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "1289", "fecha_ingreso": "2014-08-01", "fecha