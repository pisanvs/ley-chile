{"html": [{"t": "<div><div class=\"p\">BANCOS DE EMISION</div><br><div class=\"p\">Santiago, junio 19 de 1875</div><br><div class=\"p\">&nbsp; &nbsp;  (136) Por cuanto el Congreso Nacional ha aprobado el siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI </div></div>", "i": 9053076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  ART&#xCD;CULO &#xDA;NICO.</div><br><div class=\"p\">&nbsp; &nbsp;  Agr&#xE9;guese al art&#xED;culo 28 de la lei de Bancos de Emision el siguiente inciso:</div><div class=\"p\">&nbsp; &nbsp;  Escept&#xFA;anse asimismo el dia primero de julio de cada a&#xF1;o, en que podr&#xE1;n mantener sus oficinas cerradas durante todo el dia.</div><div class=\"p\">&nbsp; &nbsp;  I por cuanto, oido el consejo de Estado, lo he aprobado i sancionado; por tanto, ordeno que se prom&#xFA;lgue i lleve a efecto como lei de la Rep&#xFA;blica. </div></div>", "i": 9053077, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  FEDERICO ERR&#xC1;ZURIZ Ram&#xF3;n Barros Luco </div></div>", "i": 9053078}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "S/N", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-S/N"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "BANCOS DE EMISION", "fuente": "Boletin de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1875-06-19", "doble_articulado": false, "id_norma": "227372", "numero_fuente": "43; PAGINA 209", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1875-06-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1875-06-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio