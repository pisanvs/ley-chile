{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9333424}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 291, de 1 de febrero de 2013, de esta Subsecretar&#xED;a, modif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=1037044&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 172, de 2012</a>, de esta Subsecretar&#xED;a que autoriz&#xF3; a la UNIVERSIDAD DE CONCEPCI&#xD3;N, para efectuar una pesca de investigaci&#xF3;n de prospecci&#xF3;n, de conformidad con los t&#xE9;rminos t&#xE9;cnicos de referencia del proyecto denominado &quot;Ecolog&#xED;a y biolog&#xED;a del Lobo marino com&#xFA;n Otaria flavescens en el Santuario Islote Lober&#xED;a de Cobquecura: fase 2012&quot;, en el sentido de ampliar su vigencia hasta el 23 de julio de 2013.</div></div>", "i": 9333425}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de febrero de 2013.- Felipe Palacio Rives, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9333426}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "291 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-291 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2013-02-01", "doble_articulado": false, "id_norma": "1048815", "numero_fuente": "40483", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2013-02-12", "vigencias": [{"desde": "2013-02-12", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigenci