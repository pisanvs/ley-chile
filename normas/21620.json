{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xB0; 642 EXENTO, DE 1994</div><br><br></div>", "i": 5945671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento de Educaci&#xF3;n N&#xB0; 642, de fecha 21 de Diciembre de 1994, se ha aprobado un Plan Especial de Estudio para Educaci&#xF3;n Media Human&#xED;stico-Cient&#xED;fica al Colegio &quot;Scuola Italiana Vittorio Montiglio&quot;, de la Comuna de Las Condes, Regi&#xF3;n Metropolitana, para ser aplicado en forma gradual a contar del a&#xF1;o 1995 en 1&#xB0; y 3&#xB0; de Ense&#xF1;anza Media, y en el a&#xF1;o 1996, en 2&#xB0; y 4&#xB0; A&#xF1;o de Ense&#xF1;anza Media.</div><br></div>", "i": 5945672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 30 de Diciembre de 1994.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 5945673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "642 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-642 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA"], "titulo_norma": "EXTRACTO DE DECRETO N° 642 EXENTO, DE 1994", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COLEGIO SCUOLA ITALIANA VITTORIO MONTIGLIO", "PLANES", "ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1994-12-21", "doble_articulado": false, "id_norma": "21620", "numero_fuente": "35070", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1995-01-18", "vigencias": [{"desde": "1995-01-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1995-01-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1995