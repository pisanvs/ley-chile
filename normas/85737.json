{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION</div><br><br></div>", "i": 8717192}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n exenta No. 774 de 21 de octubre de 1992 del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, se autoriz&#xF3; a la sociedad chilena Transportes Nar Bus Sociedad An&#xF3;nima (Nar Bus S.A.), para efectuar transporte internacional terrestre de pasajeros entre Concepci&#xF3;n-Temuco (Chile) y Zapala-Neuqu&#xE9;n (Argentina) por Paso Pino Hachado, efectuando dos frecuencias semanales de ida y vuelta.</div><br><br></div>", "i": 8717193}, {"t": "<div><div class=\"p\">- Sergio Gonz&#xE1;lez Tagle, Subsecretario de Transportes. </div></div>", "i": 8717194}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "774 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-774 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-10-21", "doble_articulado": false, "id_norma": "85737", "numero_fuente": "34408", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-11-05", "vigencias": [{"desde": "1992-11-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-11-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-11-05", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JAM", "fecha_ingreso": "1998-01-20", "fecha_version": "1992-11-05", "fecha_actua