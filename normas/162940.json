{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6256934}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xB0; 7 de fecha 22 de Julio de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n, se autoriza a Alejandro Denham y C&#xED;a. Ltda., para efectuar las revisiones t&#xE9;cnicas de los veh&#xED;culos de transporte de personas de m&#xE1;s de nueve (9) asientos, incluido el del conductor; de veh&#xED;culos motorizados de carga con capacidad para transportar m&#xE1;s de 1.750 kilos, sus remolques y semirremolques y los taxis, en el establecimiento ubicado en calle Sor Vicenta s/n&#xB0; de la ciudad de Los Angeles.</div><br></div>", "i": 6256935}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Francisco Navarro Ruiz, Secretario Regional Ministerial de Transportes y Telecomunicadones VIII Regi&#xF3;n del B&#xED;o B&#xED;o.</div><br></div>", "i": 6256936}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-22", "doble_articulado": false, "id_norma": "162940", "numero_fuente": "32243", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-08", "vigencias": [{"desde": "1985-08-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-08