{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.970, DE 23 DE ABRIL DE 2019, QUE REEMPLAZA RESOLUCI&#xD3;N N&#xB0; 7.306, 28 DE OCTUBRE DE 2009</div></div>", "i": 10020461}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 1.970, del 23 de abril de 2019, del Director Nacional de Aduanas, se reemplaz&#xF3; la <a href=\"https://www.leychile.cl/Navegar?idNorma=1008050&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 7.306, del 28.10.2009</a>, que conten&#xED;a las normas sobre las operaciones de &quot;alije&quot; para las descargas de petr&#xF3;leo y/o sus derivados.</div><div class=\"p\">&nbsp; &nbsp;  La resoluci&#xF3;n entra en vigencia el 1 de mayo de 2019.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n se encuentra publicado en el sitio web del Servicio Nacional de Aduanas (www.aduana.cl).</div></div>", "i": 10020462}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de abril de 2019.- Jos&#xE9; Ignacio Palma Sotomayor, Director Nacional de Aduanas.</div></div>", "i": 10020463}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1970 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1970 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO NACIONAL DE ADUANAS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN Nº 1.970, DE 23 DE ABRIL DE 2019, QUE REEMPLAZA RESOLUCIÓN N° 7.306, 28 DE OCTUBRE DE 2009", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1585385", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2019-04-23", "doble_articulado": false, "id_norma": "1131242", "numero_fuente": "42347", 