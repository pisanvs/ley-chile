{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE ASOCIACION GREMIAL QUE INDICA </div></div>", "i": 6249425}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 31, de 10 de marzo de 1986, del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se cancel&#xF3; la personalidad jur&#xED;dica de la &quot;Asociaci&#xF3;n Gremial de No Acad&#xE9;micos del Instituto Profesional de Valdivia&quot;, inscrita bajo el No. 1.402 del Registro de Asociaciones Gremiales que lleva este Ministerio, por haberse configurado respecto de ella la causal de cancelaci&#xF3;n contemplada en el art&#xED;culo 18&#xB0; No. 2, letra a), del DL 2.757.</div><br></div>", "i": 6249426}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Jorge Valenzuela Dur&#xE1;n, Coronel de Ej&#xE9;rcito, Subsecretario de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n. </div></div>", "i": 6249427}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "31", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-31"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE ECONOMÍA"], "titulo_norma": "EXTRACTO DE CANCELACION DE PERSONALIDAD JURIDICA DE\nASOCIACION GREMIAL QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-03-10", "doble_articulado": false, "id_norma": "160630", "numero_fuente": "32437", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1986-04-03", "vigencias": [{"desde": "1986-04-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1986-04-03", "fin_vigencia": ""}, "vi