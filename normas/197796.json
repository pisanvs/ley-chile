{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 4.295 EXENTA, DE 2002 </div></div>", "i": 6380474}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;4.295, de 8 de abril de 2002, se ha aprobado plan y programa de estudio para cuarto a&#xF1;o de Ense&#xF1;anza Media, Human&#xED;stico-Cient&#xED;fica al Colegio Compa&#xF1;&#xED;a de Mar&#xED;a de Santiago, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores del Plan Formaci&#xF3;n General y del Plan Formaci&#xF3;n Diferenciada, que se indican en la presente resoluci&#xF3;n </div></div>", "i": 6380475}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 22 de abril de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6380476}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "4295 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-4295 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 4.295 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-04-08", "doble_articulado": false, "id_norma": "197796", "numero_fuente": "37252", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-07", "vigencias": [{"desde": "2002-05-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-07", "fin_vigencia": "", "tipo_version": "3"}]