{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,753.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 8349394}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia y por el plazo de diez a&#xF1;os, a la viuda de don Ramon Luis Irarr&#xE1;zaval Vera una pension de tres mil pesos anuales.</div><br></div>", "i": 8349395}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a once de mayo de mil novecientos veintiuno.- Arturo Alessandri.- Pedro Aguirre Cerda.</div><br></div>", "i": 8349396}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3753", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3753"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1921-05-11", "doble_articulado": false, "id_norma": "142574", "numero_fuente": "12975", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1921-05-19", "vigencias": [{"desde": "1921-05-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1921-05-19", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1921-05-19", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "IMH", "fecha_ingreso": "1999-09-03", "fecha_versi