{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9311642}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.866, de 26 de octubre de 2012, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD PESQUERA PESSUR LIMITADA para ampliar actividades pesqueras extractivas con la nave &quot;Pesur I&quot; en el &#xE1;rea mar&#xED;tima comprendida entre los paralelos 33&#xBA; al 40&#xBA; L.S., con red de arrastre, por fuera del &#xE1;rea de reserva artesanal, los recursos hidrobiol&#xF3;gicos Pampanito, Caballa, Cojinoba moteada, Pejerrata y Vinciguerria.</div></div>", "i": 9311643}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 26 de octubre de 2012.- Pablo Galilea Carrillo, Subsecretario de Pesca y Acuicultura.</div></div>", "i": 9311644}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2866 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2866 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2012-10-26", "doble_articulado": false, "id_norma": "1045588", "numero_fuente": "40408", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-11-13", "vigencias": [{"desde": "2012-11-13", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-11-13", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-11-13", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "98", "fecha_ingre