{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 3.561 EXENTA, DE 2002 </div></div>", "i": 6379306}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 3.561 de 27 de marzo de 2002, se ha aprobado al Colegio Francisco de Miranda de Pe&#xF1;alol&#xE9;n, un plan de estudio para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media, que se aplicar&#xE1; a partir del a&#xF1;o escolar 2002.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueban programas de estudio para los Subsectores que se indican en la presente resoluci&#xF3;n. </div></div>", "i": 6379307}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 8 de abril de 2002.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6379308}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3561 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3561 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 3.561 EXENTA, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-03-27", "doble_articulado": false, "id_norma": "197457", "numero_fuente": "37249", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-05-03", "vigencias": [{"desde": "2002-05-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-05-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-05-03", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2002-05-03", "