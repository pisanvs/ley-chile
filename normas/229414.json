{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6493391}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 2.210, de 18 de agosto de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 4&#xBA; de la resoluci&#xF3;n N&#xBA; 2.079 de 2004, de esta Subsecretar&#xED;a de Pesca, que autoriz&#xF3; al CENTRO DE ESTUDIOS Y DESARROLLO PESQUERO SUR AUSTRAL LIMITADA para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &quot;Monitoreo y operaci&#xF3;n de la flota y distribuci&#xF3;n espacial de los recursos Anchoveta y Sardina com&#xFA;n en la X Regi&#xF3;n Sur, Isla de Chilo&#xE9;&quot;, en el sentido de incorporar a la embarcaci&#xF3;n artesanal Kokaleca II, a la n&#xF3;mina de naves participantes en la presente pesca de investigaci&#xF3;n. </div></div>", "i": 6493392}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de agosto de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6493393}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2210 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2210 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-08-18", "doble_articulado": false, "id_norma": "229414", "numero_fuente": "37943", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-08-23", "vigencias": [{"desde": "2004-08-23", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v