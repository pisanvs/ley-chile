{"html": [{"t": "<div><br><div class=\"p\">RECTIFICA CONCESI&#xD3;N DE ACUICULTURA</div><br><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n (M) 2.372, de fecha 4 de diciembre de 2009, Subsecretar&#xED;a de Marina, Ministerio de Defensa Nacional, se resolvi&#xF3; lo siguiente:</div></div>", "i": 8909680}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  I.- Rectif&#xED;case la <a href=\"https://www.leychile.cl/Navegar?idNorma=269241&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n 1.763, de fecha 27 de noviembre de 2007, del Ministerio de Defensa Nacional, Subsecretar&#xED;a de Marina</a>, que otorg&#xF3; Concesi&#xF3;n de Acuicultura de Porci&#xF3;n de Agua y Fondo de Mar, ubicada en Seno Reloncav&#xED;, al suroeste de Isla Capeguapi, comuna de Puerto Montt, provincia de Llanquihue, X Regi&#xF3;n de Los Lagos, en el siguiente sentido:</div><div class=\"p\">&nbsp; &nbsp;  Reempl&#xE1;zase en el numeral 8 de la parte resolutiva lo siguiente:</div><br><div class=\"p\">&nbsp; &nbsp;  Donde dice: &quot;art&#xED;culo 80 ter&quot;</div><div class=\"p\">&nbsp; &nbsp;  Debe decir: &quot;art&#xED;culo 80 bis&quot;</div></div>", "i": 8909681}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 2010.- Por la Sra. Subsecretaria, Felipe Garc&#xED;a-Huidobro Correa, Subjefe Subsecretar&#xED;a de Marina.</div></div>", "i": 8909682}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2372", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-2372"}], "organismos": ["MINISTERIO DE DEFENSA NACIONAL", "SUBSECRETARÍA DE MARINA"], "titulo_norma": "RECTIFICA CONCESIÓN DE ACUICULTURA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": fals