{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9574524}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 550, de 24 de febrero de 2015, de esta Subsecretar&#xED;a, establece que los centros de cultivo integrantes de la agrupaci&#xF3;n de concesiones 29 deber&#xE1;n someterse a la densidad de cultivo establecida por <a href=\"https://www.leychile.cl/Navegar?idNorma=1003741&amp;idParte=0&amp;idVersion=\">resoluci&#xF3;n N&#xBA; 1.449, de 2009, del Servicio Nacional de Pesca y Acuicultura</a>, o la resoluci&#xF3;n que la reemplace, en virtud del art&#xED;culo 5&#xBA; transitorio del DS N&#xBA; 4, de 2013, de este Ministerio.</div></div>", "i": 9574525}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 24 de febrero de 2015.- Alejandro Gertosio Ram&#xED;rez, Subsecretario de Pesca y Acuicultura (S).</div></div>", "i": 9574526}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "550 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-550 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA Y ACUICULTURA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-02-24", "doble_articulado": false, "id_norma": "1075207", "numero_fuente": "40097", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2015-03-03", "vigencias": [{"desde": "2015-03-03", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2015-03-03", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2015-03-03", "fin_vigencia": "", "tipo_version":