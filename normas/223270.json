{"html": [{"t": "<div><div class=\"p\">AREA DE RESTRICCION ACUIFERO SUR VIEJO COMUNA DE POZO ALMONTE, PROVINCIA DE IQUIQUE, I REGION </div></div>", "i": 6472041}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n DGA N&#xBA; 35, de fecha 4 de febrero de 2004, se ha declarado Area de Restricci&#xF3;n para extracciones de aguas subterr&#xE1;neas del sector hidrogeol&#xF3;gico del Acu&#xED;fero Sur Viejo, ubicado en la Comuna de Pozo Almonte, Provincia de Iquique, I Regi&#xF3;n. Los antecedentes se encuentran disponibles en las oficinas de la Direcci&#xF3;n General de Aguas.</div><br></div>", "i": 6472042}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Humberto Pe&#xF1;a T., Director General de Aguas. </div></div>", "i": 6472043}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "35", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-35"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "DIRECCIÓN GENERAL DE AGUAS"], "titulo_norma": "AREA DE RESTRICCION ACUIFERO SUR VIEJO COMUNA DE POZO\nALMONTE, PROVINCIA DE IQUIQUE, I REGION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AGUAS SUBTERRANEAS", "EXTRACCION", "POZO ALMONTE", "ACUIFERO SUR VIEJO", "AREA DE RESTRICCION", "PRIMERA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-02-04", "doble_articulado": false, "id_norma": "223270", "numero_fuente": "37826", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-04-01", "vigencias": [{"desde": "2004-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-04-01", "fin_vigencia": "",