{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6481613}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA; 327, de fecha 27 de abril del 2004, se expropi&#xF3; el lote de terreno N&#xBA; 57, superficie 2.673 m&#xB2;., Rol N&#xBA; 302-404, comuna de Cunco, IX Regi&#xF3;n para la obra &quot;Camino Ruta S-61, Sector Cunco-Melipeuco, tramo Km. 55,000 al Km. 87,46783, correspondiente al Sub-Tramo II Km. 62,784 al Km. 76,043&quot; y se acord&#xF3; el valor de la indemnizaci&#xF3;n con su propietario Valent&#xED;n Alejandro Morales Montiel, ascendente a la cantidad de $18.312.127.- para el lote N&#xBA; 57.</div><br></div>", "i": 6481614}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6481615}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "327", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-327"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-04-27", "doble_articulado": false, "id_norma": "225894", "numero_fuente": "37874", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-06-01", "vigencias": [{"desde": "2004-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-06-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-06-01", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2004-06-01", "fecha_version": "2004-06-01", "fecha_actualizacion_texto":