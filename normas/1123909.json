{"html": [{"t": "<div><div class=\"p\">&#xFEFF;&nbsp; &nbsp;  Derechos sobre la yerba</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago i Noviembre 4 de 1817.</div></div>", "i": 9965860}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  En fuerza de los nuevos fundamentos deducidos por el se&#xF1;or diputado de las Provincias Unidas, enti&#xE9;ndase por dos pesos en arroba el derecho &#xFA;ltimamente impuesto sobre la yerba introducida por mar en providencia de 23 de Octubre &#xFA;ltimo la que con &#xE9;sta se estampar&#xE1;n en la Gazeta, tom&#xE1;ndose razon que circular&#xE1; como la anterior, i poni&#xE9;ndose en noticia del se&#xF1;or diputado por secretar&#xED;a para los fines conducentes.-</div></div>", "i": 9965861}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  P&#xE9;rez.- Cruz.- Astorga.- Dr. Vill&#xE9;gas.</div></div>", "i": 9965862}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "0", "numero": "S/N", "abreviacion": "OTR", "descripcion": "OTRO", "compuesto": "OTRO-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "Derechos sobre la yerba", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1817-11-04", "doble_articulado": false, "id_norma": "1123909", "numero_fuente": "1817", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1817-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1817-11-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1817-11-04", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1795", "fecha_ingreso": "2018-11-14", "fecha_version": "1817-1