{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6546462}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto (exento) MOP N&#xBA; 993 de fecha 29 de septiembre de 2005, se expropi&#xF3; el lote de terreno N&#xBA; 9, superficie 1.788,6 m2, rol N&#xBA; 158-156, comuna de Cocham&#xF3;, X Regi&#xF3;n para la obra: &quot;Camino Puelo Paso El Bols&#xF3;n, Sector Llanada Grande - R&#xED;o Mapocho, Tramo Km.</div><div class=\"p\">32,500 al Km. 37,400&quot;, y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Natalia Pinto Albornoz, ascendente a la cantidad de $814.068.</div><br></div>", "i": 6546463}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6546464}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "993 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-993 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-29", "doble_articulado": false, "id_norma": "243493", "numero_fuente": "38301", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-11-02", "vigencias": [{"desde": "2005-11-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-11-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-11-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "DVG", "fecha_ingreso": "2005-11-02", "fecha_version": "2005-11-02", "fecha_actualizacion_texto": "2005-11-02", "tipo_tra