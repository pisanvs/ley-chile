{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6035607}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP N&#xBA; 279, de 31 de marzo de 1997, se expropiaron los lotes de terreno N&#xBA;s. 11 y 21, superficies 4.160 y 4.480 m2., Roles de aval&#xFA;o 403-5 y 403-13, comuna de Vicu&#xF1;a, para la obra Proyecto Embalse Puclaro, Sector La Polvada, II Etapa y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios, Mar&#xED;a del Tr&#xE1;nsito Traslavi&#xF1;a Garc&#xED;a y Ema C&#xE1;ceres, ascendentes a las cantidades de $4.464.185 y $10.930.409, respectivamente.-</div><br></div>", "i": 6035608}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6035609}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "279", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-279"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "INDEMNIZACION", "VICU A", "CUARTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-03-31", "doble_articulado": false, "id_norma": "71163", "numero_fuente": "45755", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-05-02", "vigencias": [{"desde": "1997-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CAV", "fecha_ingreso": "1997-05-16", "fecha_version": "199