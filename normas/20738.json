{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; EXTRACTO DE DECRETO N&#xB0; 230 EXENTO, DE 1996 </div></div>", "i": 7161238}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Decreto Exento N&#xB0; 230, de fecha 24 de abril de 1996 del Ministerio de Educaci&#xF3;n, se aprob&#xF3; al Centro de Formaci&#xF3;n T&#xE9;cnica Centro Nacional de Estudios Param&#xE9;dicos y Agropecuarios Propam, las adecuaciones al plan y programas de estudio de la carrera T&#xE9;cnico Agr&#xED;cola, modific&#xE1;ndose, en consecuencia, la Resoluci&#xF3;n Exenta N&#xB0; 2.871, de 1988. Dichas adecuaciones podr&#xE1;n aplicarse a contar del a&#xF1;o 1996.</div><br></div>", "i": 7161239}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Santiago, 12 de junio de 1996.- Jaime P&#xE9;rez de Arce Araya, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7161240}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "230 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-230 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO N° 230 EXENTO, DE 1996", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CENTRO FORMACION TECNICA", "CENTRO NACIONAL ESTUDIOS", "PARAMEDICOS AGROPECUARIOS PROPAM", "PLANES ESTUDIO", "PROGRAMAS ESTUDIO", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1996-04-24", "doble_articulado": false, "id_norma": "20738", "numero_fuente": "35508", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-07-05", "vigencias": [{"desde": "1996-07-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-07-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic