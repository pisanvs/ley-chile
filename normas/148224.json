{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6207439}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;2.866, de 30 de septiembre de 1999, se expropiaron los lotes de terreno N&#xBA;s. 96; 98; 101 y 108, superficies 4.875, 220, 183 y 379 m&#xB2; respectivamente, roles de aval&#xFA;os 214-35, 214-12 y 214-7, comuna de Monte Patria, para la obra Camino Ruta D-597, Monte Patria - Caren, Sector Juntas - Caren, y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios, Rudecindo Galleguillos Gallardo, Orlando del Carmen Villalobos Alvarez y Sucesi&#xF3;n Domingo Julio Ram&#xED;rez Ram&#xED;rez, ascendentes a las cantidades de $4.404.360.- para los lotes N&#xBA;s. 96 y 98, $641.604.- para el lote N&#xBA;101 y $1.174.902.- para el lote N&#xBA;108.- </div></div>", "i": 6207440}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6207441}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2866", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-2866"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-09-30", "doble_articulado": false, "id_norma": "148224", "numero_fuente": "36514", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-11-15", "vigencias": [{"desde": "1999-11-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-11-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-11-15", "fin_vigencia": "", "tipo_version": "3"}], "eve