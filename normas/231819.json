{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6502534}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.876 de 14 de octubre de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Loa 7&quot;, en el &#xE1;rea mar&#xED;tima comprendida entre la I y II Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, donde podr&#xE1; capturar, con cerco, los recursos: Jurel fino, Anchoa blanca, Sardina redonda, Vinciguerria y Jibia.</div><br></div>", "i": 6502535}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 14 de octubre de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6502536}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2876", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2876"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-10-14", "doble_articulado": false, "id_norma": "231819", "numero_fuente": "37996", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2004-10-27", "vigencias": [{"desde": "2004-10-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2004-10-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2004-10-27", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingreso": "20