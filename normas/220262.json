{"html": [{"t": "<div><div class=\"p\">EXTRACTO DEL DECRETO N&#xBA; 925 EXENTO, DE 2003 </div></div>", "i": 6459730}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 925 de fecha 17 de noviembre de 2003, de Educaci&#xF3;n, declara aprobada a la Universidad de Rancagua la siguiente carrera y grado acad&#xE9;mico que se indica:</div><br><div class=\"p\">Carrera: Pedagog&#xED;a en Educaci&#xF3;n Parvularia. Grado Acad&#xE9;mico: Licenciado en Educaci&#xF3;n.</div><div class=\"p\">Titulo Profesional: Educador de P&#xE1;rvulos, con menciones en Gesti&#xF3;n de&nbsp;  Programas Alternativos o Semipresenciales y en Gesti&#xF3;n de Programas con Agentes Educativos.</div><br><div class=\"p\">&nbsp; &nbsp;  Dicha carrera podr&#xE1; ser impartida en jornada diurna en su sede de la ciudad de Rancagua, a contar del primer semestre del a&#xF1;o 2004.</div><br></div>", "i": 6459731}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de diciembre de 2003.- Mar&#xED;a Ariadna Hornkohl Venegas, Subsecretaria de Educaci&#xF3;n </div></div>", "i": 6459732}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "925 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-925 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DEL DECRETO Nº 925 EXENTO, DE 2003", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2003-11-17", "fecha_derogacion": "2010-07-09", "doble_articulado": false, "id_norma": "220262", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-01-17", "vigencias": [{"desde": "2010-07-09", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde"