{"html": [{"t": "<div><div class=\"p\">EXTRACTO&nbsp; DE&nbsp; DECRETO&nbsp; N&#xBA; 339&nbsp; EXENTO, DE 1998</div><br></div>", "i": 7231366}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xBA; 339 de 4 de febrero de 1998, se ha autorizado al Colegio &quot;Coyancura&quot; de Santiago, para modificar los actuales planes y programas de estudio de 7&#xBA; y 8&#xBA; a&#xF1;o de Ense&#xF1;anza B&#xE1;sica, regidos por el decreto supremo de Educaci&#xF3;n N&#xBA; 4.002 de 1980 y sus modificaciones, complementado por el decreto supremo exento de Educaci&#xF3;n N&#xBA; 151 de 1992.</div><br><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para 7&#xBA; y 8&#xBA; a&#xF1;o b&#xE1;sico de la asignatura de Ingl&#xE9;s.</div><br></div>", "i": 7231367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 13 de febrero de 1998.- Juan Eduardo Garc&#xED;a-Huidobro S., Subsecretario de Educaci&#xF3;n (S). </div></div>", "i": 7231368}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "339 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-339 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 339 EXENTO, DE 1998", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PLANES DE ESTUDIO", "PROGRAMAS DE ESTUDIO", "COLEGIO COYANCURA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-02-04", "doble_articulado": false, "id_norma": "96828", "numero_fuente": "35997", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-02-21", "vigencias": [{"desde": "1998-02-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigenc