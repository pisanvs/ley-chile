{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 7311943}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.304, de 10 de mayo de 2004, de esta Subsecretar&#xED;a, modif&#xED;case el numeral 1&#xBA; de la resoluci&#xF3;n N&#xBA; 661 de 1993 de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA LANDES S.A. para desarrollar actividades pesqueras extractivas con la nave &quot;Araucan&#xED;a I&quot;, en el sentido de incorporar y actualizar, seg&#xFA;n corresponda, las siguientes caracter&#xED;sticas n&#xE1;uticas de &#xE9;sta:</div><br><div class=\"p\">Capacidad de bodega&nbsp; &nbsp; &nbsp; 350,00 m&#xB3;</div><div class=\"p\">Potencia principal&nbsp; &nbsp; &nbsp;  845,00 Hp.</div><div class=\"p\">Potencia auxiliar&nbsp; &nbsp; &nbsp; &nbsp; 46,00 Hp.</div><br></div>", "i": 7311944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 10 de mayo de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 7311945}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1304 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1304 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-05-10", "fecha_derogacion": "2005-05-07", "doble_articulado": false, "id_norma": "225529", "numero_fuente": "37868", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-05-25", "vigencias": [{"desde": "2005-05-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde":