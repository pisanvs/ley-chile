{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8306782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n N&#xBA; 1.266 de 25 de septiembre de 1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, decl&#xE1;rase la caducidad de las Resoluciones N&#xBA; 693, de 1994 y N&#xBA; 347, de 1995, ambas de esta Subsecretar&#xED;a, que autorizaron a PESQUERA BALZAK S.A., para iniciar y ampliar actividades pesqueras extractivas, respectivamente, con la nave &quot;Luminosa&quot;, por haberse configurado la causal prevista en el art&#xED;culo 143 letra b) de la Ley N&#xBA; 18.892 y sus modificaciones.</div><br></div>", "i": 8306783}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de septiembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8306784}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1266", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1266"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CADUCIDAD", "AUTORIZACION", "PESCA", "PESQUERA BALZAK S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1997-09-25", "doble_articulado": false, "id_norma": "76122", "numero_fuente": "35882", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1997-10-04", "vigencias": [{"desde": "1997-10-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1997-10-04", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1997-10-04", "fin_vigencia"