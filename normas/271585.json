{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6648926}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.137, de 30 de abril de 2008, de esta Subsecretar&#xED;a, autor&#xED;zase a AUSTRAL FOOD S.A. para ampliar actividades de transformaci&#xF3;n autorizadas por resoluci&#xF3;n citada en Visto, para incorporar a planta ubicada en Volc&#xE1;n L&#xE1;scar 781, Parque Industrial Lo Boza, Pudahuel, Regi&#xF3;n Metropolitana, en l&#xED;neas proceso fresco enfriado y congelado, el recurso hidrobiol&#xF3;gico Bacalao, Dissostichus mawsoni.</div><div class=\"p\">&nbsp; &nbsp;  D&#xE9;jase sin efecto la resoluci&#xF3;n N&#xBA; 1.031, de 2008, de esta Subsecretar&#xED;a.</div><br></div>", "i": 6648927}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 30 de abril de 2008.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div><br></div>", "i": 6648928}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1137 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1137 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-04-30", "doble_articulado": false, "id_norma": "271585", "numero_fuente": "39075", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-05-31", "vigencias": [{"desde": "2008-05-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-05-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-05-31", "fin_vigencia": ""