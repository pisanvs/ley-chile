{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6216900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 99, de 24 de octubre de 1984, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la III Regi&#xF3;n, se autoriza al Sr. Italo Herrera Espinoza, para efectuar el servicio de taxi colectivo urbano de la L&#xED;nea No. 9. &quot;Baquedano - Avenida Matta&quot;, cuyo trazado que a continuaci&#xF3;n se indica fue autorizado por resoluci&#xF3;n No. 27, de 18.06.84 de esta Secretar&#xED;a Regional.</div><div class=\"p\">Ida: Matta - Merced - Verdaguer - Lourdes - Baquedano - Concepci&#xF3;n.</div><div class=\"p\">Regreso: Concepci&#xF3;n - Carrera - Atacama - Merced - Talca - Ram&#xED;rez - Matta.-</div><br></div>", "i": 6216901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Sergio Antonio Acevedo Oyarce, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Atacama.</div><br></div>", "i": 6216902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "99 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-99 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL III REGIÓN DE ATACAMA"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1984-10-24", "doble_articulado": false, "id_norma": "150687", "numero_fuente": "32793", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-11", "vigencias": [{"desde": "1987-06-11", "hasta": "", "tipo_version": "3",