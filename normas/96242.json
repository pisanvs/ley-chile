{"html": [{"t": "<div><div class=\"p\">MODIFICA ORDENANZA QUE INDICA</div><br><div class=\"p\">N&#xFA;m. 129.- Romeral, 20 de Diciembre de 1991.- Vistos:</div><br><div class=\"p\">a) El decreto alcaldicio No. 001 de fecha 11.01.88.</div><div class=\"p\">b) El decreto exento No. 29 de fecha 23.01.89.</div><div class=\"p\">c) El decreto exento No. 85 de fecha 08.02.91.</div><div class=\"p\">d) El acuerdo No. 26 de fecha 19 de Diciembre de 1991 del Consejo de Desarrollo Comunal.</div><div class=\"p\">e) Las facultades que me confiere la Ley No. 18.695, Org&#xE1;nica Constitucional de Municipalidades y sus modificaciones posteriores, he acordado y:</div><br><div class=\"p\">Decreto:</div><br></div>", "i": 6102397}, {"t": "<div><div class=\"p\">Modif&#xED;case la Ordenanza Municipal No. 43, en el punto que se</div><div class=\"p\">indica, a contar de 02 de enero de 1992.</div><br><div class=\"p\">Art&#xED;culo 4&#xB0;.-</div><div class=\"p\">N&#xB0; 8, reb&#xE1;jase de 50% UTM a 25% UTM </div></div>", "i": 6102398}, {"t": "<div><div class=\"p\">C&#xFA;mplase, notif&#xED;quese, publ&#xED;quese y arch&#xED;vese.- Segundo Contardo Galdames, Alcalde.- Guillermo Montero Ram&#xED;rez, Secretario Municipal.</div><br></div>", "i": 6102399}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "129", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-129"}], "organismos": ["MUNICIPALIDAD DE ROMERAL"], "titulo_norma": "MODIFICA ORDENANZA QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-12-20", "doble_articulado": false, "id_norma": "96242", "numero_fuente": "34165", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacio