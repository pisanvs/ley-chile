{"html": [{"t": "<div><div class=\"p\">Ley n&#xFA;m. 10,733</div><br><div class=\"p\">RECONOCE EL TIEMPO QUE INDICA A DON GALO IRARRAZABAL B.</div><br><div class=\"p\">&nbsp; &nbsp;  Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  Proyecto de ley:</div><br></div>", "i": 6589761}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Art&#xED;culo &#xFA;nico. Recon&#xF3;cense, por gracia, y para todos los efectos legales, a don Galo Irarr&#xE1;zaval Barros, los siete a&#xF1;os que se desempe&#xF1;&#xF3; como dentista en los servicios de Correos y Tel&#xE9;grafos.</div><br></div>", "i": 6589762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a diez de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- Ignacio Lorca G.</div><br></div>", "i": 6589763}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10733", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10733"}], "organismos": ["MINISTERIO DE HACIENDA"], "titulo_norma": "RECONOCE EL TIEMPO QUE INDICA A DON GALO IRARRAZABAL B.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-10", "doble_articulado": false, "id_norma": "255309", "numero_fuente": "22384", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1952-10-25", "vigencias": [{"desde": "1952-10-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1952-10-25", "fin_vigencia": ""}, "vigencias_version_n