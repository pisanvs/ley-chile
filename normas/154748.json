{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO SUPREMO EXENTO N&#xB0; 72, DE 1986 </div></div>", "i": 6229944}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 72, de 14 de Mayo de 1986, se han aprobado para el Liceo Polit&#xE9;cnico &quot;La Providencia&quot; de Traigu&#xE9;n, IX Regi&#xF3;n en que se transformara la Escuela Agr&#xED;cola &quot;La Providencia&quot;, planes y programas especiales de estudio para la Educaci&#xF3;n Media, Modalidad T&#xE9;cnico - Profesional, que se aplicar&#xE1;n gradualmente a contar del a&#xF1;o escolar 1986 y hasta el a&#xF1;o escolar de 1991, en la Especialidad de M&#xFA;sico Instrumentista con menci&#xF3;n en:</div><br><div class=\"p\">1.- Flauta Traversa y Piccolo.</div><div class=\"p\">2.- Clarinete.</div><div class=\"p\">3.- Trompeta.</div><div class=\"p\">4.- Bugle.</div><div class=\"p\">5.- Sax&#xF3;fono.</div><div class=\"p\">6.- Tromb&#xF3;n de Varas y</div><div class=\"p\">7.- Fliscorno.</div><br></div>", "i": 6229945}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 18 de Junio de 1986.- Ren&#xE9; Salam&#xE9; Martin, Subsecretario de Educaci&#xF3;n.-</div><br></div>", "i": 6229946}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "72 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-72 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO SUPREMO EXENTO N° 72, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-06-18", "doble_articulado": false, "id_norma": "154748", "numero_fuente": "32506", "tipo_version": "3", "tipo_