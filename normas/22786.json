{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Concede permiso para conservar un bien raiz al Cuerpo de Bomberos de Ovalle</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 7164253}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Conc&#xE9;dese al &quot;Cuerpo de Bomberos de Ovalle&quot; el permiso requerido por el art&#xED;culo 556 del C&#xF3;digo Civil, para que pueda conservar, hasta por treinta a&#xF1;os, la posesion del bien raiz que tiene adquirido en dicha ciudad, en la calle Miguel Aguirre Perry.</div><br></div>", "i": 7164254}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a 31 de Julio de 1903.- JERMAN RIESCO.-</div><div class=\"p\">An&#xED;bal Sanfuentes.</div><br></div>", "i": 7164255}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1606", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1606"}], "organismos": ["MINISTERIO DE JUSTICIA"], "titulo_norma": "CONCEDE PERMISO PARA CONSERVAR UN BIEN RAIZ AL CUERPO DE BOMBEROS DE OVALLE", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CUERPO BOMBEROS OVALLE", "BIEN RAIZ", "OVALLE", "POSESION", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1903-07-31", "doble_articulado": false, "id_norma": "22786", "numero_fuente": "7653", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1903-08-04", "vigencias": [{"desde": "1903-08-04", "hasta": "", "t