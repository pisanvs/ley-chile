{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6317294}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.638 de 18 de diciembre de 2000 de esta Subsecretar&#xED;a, ampl&#xED;ase por un a&#xF1;o, a contar del 31 de agosto del 2000, el plazo otorgado en la resoluci&#xF3;n N&#xBA; 1.126 de 1998, de esta Subsecretar&#xED;a, a FLORIDOR DEL CARMEN ALMONACID OYARZO, para iniciar actividades pesqueras de transformaci&#xF3;n, en la planta ubicada en Ruta V-900, Maull&#xED;n-Carelmapu, Km. 15.545, Comuna de Maull&#xED;n, Provincia de Llanquihue, X Regi&#xF3;n, en virtud de haberse acreditado la ocurrencia de una situaci&#xF3;n de fuerza mayor.</div><br></div>", "i": 6317295}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de diciembre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca. </div></div>", "i": 6317296}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2638", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2638"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2000-12-18", "fecha_derogacion": "2003-03-07", "doble_articulado": false, "id_norma": "180480", "numero_fuente": "36865", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2001-01-18", "vigencias": [{"desde": "2003-03-07", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2001-01-18", "hasta": "2003-03-06", "tipo_version": "0", "tipo_version_s": "Texto Original"}], "vigencia": {"inicio_vigencia": "2003-0