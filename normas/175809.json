{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6301671}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;3.416, de 29 de octubre de 1999, se orden&#xF3; y aprob&#xF3; el plano y cuadro de expropiaci&#xF3;n de los lotes de terreno N&#xBA;s. 41-A y 43, y por decreto MOP N&#xBA;3.161, de 31 de julio de 2000, se autoriz&#xF3; el valor de la consignaci&#xF3;n provisional de la expropiaci&#xF3;n por la v&#xED;a judicial, en la cantidad de $1.831.750, para los lotes 41-A y 43, necesarios para la ejecuci&#xF3;n de la obra Camino Ruta O-60, Sector Monte&#xE1;guila - Yumbel, Km.</div><div class=\"p\">6.639,00 a Km. 17.531,11; el pago de la indemnizaci&#xF3;n se efectuar&#xE1; al contado. La publicaci&#xF3;n se efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto ley N&#xBA;2.186, de 1978.-</div><br></div>", "i": 6301672}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6301673}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "3416", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-3416"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-10-29", "doble_articulado": false, "id_norma": "175809", "numero_fuente": "36765", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-09-15", "vigencias": [{"desde": "2000-09-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-09-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2