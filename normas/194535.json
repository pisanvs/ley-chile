{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 987 EXENTO, DE 2001 </div></div>", "i": 7289620}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 987, de fecha 29 de noviembre de 2001, del Ministerio de Educaci&#xF3;n, se aprueban las adecuaciones al plan y programas de estudios de la carrera de Secretariado Ejecutivo Computacional del Centro de Formaci&#xF3;n T&#xE9;cnica Los Leones, que se encuentran anexas y forman parte del decreto. Modif&#xED;case, en consecuencia, el decreto exento del Ministerio de Educaci&#xF3;n N&#xBA; 133 del 29 de marzo de 1994, en el sentido de incorporar dichas adecuaciones.</div><div class=\"p\">&nbsp; &nbsp;  Las adecuaciones que se aprueban, podr&#xE1;n aplicarse a contar del a&#xF1;o 2002.</div><br><br></div>", "i": 7289621}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 31 de diciembre de 2001.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7289622}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "987 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-987 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 987 EXENTO, DE 2001", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2001-11-29", "fecha_derogacion": "2017-09-30", "doble_articulado": false, "id_norma": "194535", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2002-02-11", "vigencias": [{"desde": "2017-09-30", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "2002-02-11", "hasta": "2017-09-29", "tipo_version": "0", "tipo_version_s": "Texto Original"}],