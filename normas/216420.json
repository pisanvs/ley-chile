{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; CERTIFICADO</div><br></div>", "i": 8930759}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n P&#xFA;blica que suscribe, certifica que la Universidad Diego Portales inscrita en el folio C N&#xBA; 3 del Registro de Universidades del Ministerio de Educaci&#xF3;n P&#xFA;blica, ha presentado los planes y programas de estudio de la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Inform&#xE1;tica de Gesti&#xF3;n, conducente al t&#xED;tulo profesional de Ingeniero de Ejecuci&#xF3;n en Inform&#xE1;tica de Gesti&#xF3;n, a la Universidad de Tarapac&#xE1; como entidad examinadora (Art. 26&#xBA; D.F.L. N&#xBA; 1 de 1980) y estudiados por &#xE9;sta, han sido aprobados en tiempo y forma.</div><br></div>", "i": 8930760}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; RENE SALAME MARTIN</div><div class=\"p\">&nbsp; &nbsp; &nbsp; Subsecretario de Educaci&#xF3;n P&#xFA;blica</div><br></div>", "i": 8930761}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN PÚBLICA", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "216420", "numero_fuente": "32964", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-01-08", "vigencias": [{"desde": "1988-01-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-01-08", "fin_vigencia": "