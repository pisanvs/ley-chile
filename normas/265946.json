{"html": [{"t": "<div><div class=\"p\">EXCEPCIONA DEL CAMBIO DE SUJETO DEL IVA EN LAS VENTAS DE CIGARRILLOS </div></div>", "i": 6627840}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n Ex. N&#xBA; 7.672, de 9 de octubre de 2007, la V Direcci&#xF3;n Regional del Servicio de Impuestos Internos ha autorizado al contribuyente Jos&#xE9; Miguel Manzo y C&#xED;a. Ltda., RUT 80.584.300-4, para eximirse del cambio de sujeto del IVA en las ventas de cigarros y cigarrillos, en virtud de lo establecido en la resoluci&#xF3;n Ex. N&#xBA; 22, de 2007, a contar del d&#xED;a 1 del mes siguiente en que se publique este extracto en el Diario Oficial.</div><br></div>", "i": 6627841}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Erica Morales Lartiga, Directora Regional Valpara&#xED;so.</div><br></div>", "i": 6627842}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "7672 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-7672 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "V DIRECCIÓN REGIONAL DE VALPARAÍSO"], "titulo_norma": "EXCEPCIONA DEL CAMBIO DE SUJETO DEL IVA EN LAS VENTAS DE CIGARRILLOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-10-09", "doble_articulado": false, "id_norma": "265946", "numero_fuente": "38896", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-26", "vigencias": [{"desde": "2007-10-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-10-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-10-26", "fin_vigencia": "", "tipo_version