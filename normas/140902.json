{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><div class=\"p\">(Extracto) </div></div>", "i": 8348227}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 378, de 12 de Abril de 1988 de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 514, de 26 de mayo de 1987, de esta Subsecretar&#xED;a, que autoriz&#xF3; a don Iv&#xE1;n Eugenio Otey Gonz&#xE1;les, R.U.T. No.</div><div class=\"p\">6.208.633-5, domiciliado en Estero Chaular (rural) Ancud, para desarrollar actividades pesqueras de cultivo, en orden a sustituir las coordenadas geogr&#xE1;ficas que all&#xED; aparecen por las siguientes:</div><br><div class=\"p\">V&#xE9;rtice A Lat. 41&#xB0;47&apos;26,96 &quot;S Long. 73&#xB0;54&apos;35,74 &quot;W</div><br><div class=\"p\">V&#xE9;rtice B Lat. 41&#xB0;47&apos;26,83 &quot;S Long. 73&#xB0;54&apos;33,09 &quot;W</div><br><div class=\"p\">V&#xE9;rtice C Lat. 41&#xB0;47&apos;31,36 &quot;S Long. 73&#xB0;54&apos;32,74 &quot;W</div><br><div class=\"p\">V&#xE9;rtice D Lat. 41&#xB0;47&apos;31,49 &quot;S Long. 73&#xB0;54&apos;35,39 &quot;W </div></div>", "i": 8348228}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 12 de Abril de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8348229}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "378", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-378"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": fals