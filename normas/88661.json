{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8318782}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Resoluci&#xF3;n&nbsp; N&#xBA; 1.835,&nbsp; del 31 de diciembre de</div><div class=\"p\">1997, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el n&#xFA;meral 1&#xBA;, de la Resoluci&#xF3;n N&#xBA; 984, de 1989,&nbsp; de esta Subsecretar&#xED;a, que autoriz&#xF3; a PESQUERA MAR PROFUNDO LIMITADA, para realizar actividades pesqueras extractivas, en el sentido de se&#xF1;alar que las actuales caracter&#xED;sticas n&#xE1;uticas de la nave &quot;Arauco I&quot;, son las siguientes:</div><br><div class=\"p\">Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;Arauco I&quot;</div><div class=\"p\">Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2621 Valpara&#xED;so</div><div class=\"p\">Eslora de arqueo&nbsp; &nbsp; &nbsp; &nbsp; 54.19 m.</div><div class=\"p\">T.R.G. (Internacional)&nbsp; 802,87</div><div class=\"p\">Cap. de bodega&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 1271 m3</div><div class=\"p\">Arte de Pesca&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Cerco</div><br></div>", "i": 8318783}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 31 de diciembre de 1997.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8318784}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1835", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1835"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESCA", "PESQUERA MAR PROFUNDO LIMITADA", "MODIFICACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observacione