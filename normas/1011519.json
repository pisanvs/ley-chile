{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8891411}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 822, de 18 de febrero de 2010, de esta Subsecretar&#xED;a, autor&#xED;zase a SOCIEDAD WENDT FISH LIMITADA para iniciar actividades pesqueras de transformaci&#xF3;n, para instalar y operar una planta en Putemun, sector Tey, Parcela N&#xB0; 1, Castro, Chilo&#xE9;, X Regi&#xF3;n, donde podr&#xE1; elaborar en las l&#xED;neas de Cocido, Fresco-enfriado, Congelado, Conservas, Harina y Deshidratado, los recursos hidrobiol&#xF3;gicos indicados en resoluci&#xF3;n extractada.</div></div>", "i": 8891412}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 18 de febrero de 2010.- Jorge Chocair Santib&#xE1;&#xF1;ez, Subsecretario de Pesca.</div></div>", "i": 8891413}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "822 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-822 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2010-02-18", "doble_articulado": false, "id_norma": "1011519", "numero_fuente": "39605", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2010-03-08", "vigencias": [{"desde": "2010-03-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2010-03-08", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2010-03-08", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "1289",