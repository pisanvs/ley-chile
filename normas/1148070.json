{"html": [{"t": "<div><div class=\"p\">DESIGNA OFICIAL DE CUMPLIMIENTO TITULAR Y SUPLENTE PARA FINES QUE INDICA</div></div>", "i": 10147541}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta SII N&#xB0; 86, del 30 de julio de 2020, que designa oficial de cumplimiento titular y suplente para la coordinaci&#xF3;n e implementaci&#xF3;n del Sistema preventivo contra delitos funcionarios, lavado de activos y financiamiento del terrorismo. Modifica <a href=\"https://www.leychile.cl/Navegar?idNorma=1106642&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xB0; 71 de 2017</a>.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en internet (www.sii.cl).- </div><div class=\"p\">&nbsp; &nbsp;  </div></div>", "i": 10147542}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fernando Javier Barraza Luengo, Director Nacional.</div><br></div>", "i": 10147543}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "86 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-86 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DESIGNA OFICIAL DE CUMPLIMIENTO TITULAR Y SUPLENTE PARA FINES QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1794415", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-07-30", "doble_articulado": false, "id_norma": "1148070", "numero_fuente": "42723", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-08-05", "vigencias": [{"desde": "2020-08-05", "