{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE RESOLUCI&#xD3;N N&#xBA; 1.537 EXENTA, DE 2014</div></div>", "i": 9420164}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.537, de fecha 6 de marzo de 2014, de Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n Metropolitana, d&#xE9;jase sin efecto, la <a href=\"https://www.leychile.cl/Navegar?idNorma=1023292&amp;idParte=&amp;idVersion=\">resoluci&#xF3;n exenta N&#xBA; 330</a>, que aprueba programa de ense&#xF1;anza para obtenci&#xF3;n de licencia de conductor Clase B, Escuela de Conductores No Profesionales o Clase B &quot;Instituto de Capacitaci&#xF3;n Escuela de Conductores Jos&#xE9; Antonio Becerra Arce&quot;, RUT N&#xBA; 76.049.272-8, representada legalmente por el se&#xF1;or Jos&#xE9; Antonio Becerra Arce, RUT N&#xBA; 6.770.739-7, ubicada en Mapocho N&#xBA; 4086, comuna Quinta Normal.</div><br><br></div>", "i": 9420165, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Sergio Stephan Orellana, Secretario Regional Ministerial Transporte y Telecomunicaciones Regi&#xF3;n Metropolitana.</div></div>", "i": 9420166}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1537 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1537 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARÍA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL REGIÓN METROPOLITANA"], "titulo_norma": "EXTRACTO DE RESOLUCIÓN N° 1.537 EXENTA, DE 2014", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "f