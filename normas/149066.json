{"html": [{"t": "<div><div class=\"p\">ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESION N&#xBA; 805 </div><div class=\"p\">&nbsp; &nbsp;  Certifico que el Consejo del Banco Central de Chile en su Sesi&#xF3;n N&#xBA; 805, celebrada el 2 de diciembre de 1999, adopt&#xF3; los siguientes Acuerdos:</div><br></div>", "i": 6211009}, {"t": "<div><div class=\"p\">805-03-991202 - Sr. Andr&#xE9;s Reinstein Alvarez - Renuncia al cargo que indica.</div><br><div class=\"p\">&nbsp; &nbsp;  Se acord&#xF3; aceptar, a contar del 15 de enero del a&#xF1;o 2000, la renuncia presentada por el se&#xF1;or Andr&#xE9;s Reinstein Alvarez al cargo de representante del Banco Central de Chile ante el Consejo de la Comisi&#xF3;n Chilena del Cobre.</div><br></div>", "i": 6211010}, {"t": "<div><div class=\"p\">Santiago, 6 de diciembre de 1999.- Jorge Carrasco V&#xE1;squez, Ministro de Fe (S).</div><br></div>", "i": 6211011}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "5", "numero": "805", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-805"}, {"tipo": "5", "numero": "805-03-991202", "abreviacion": "ACD", "descripcion": "Acuerdo", "compuesto": "ACD-805-03-991202"}], "organismos": ["BANCO CENTRAL DE CHILE"], "titulo_norma": "ACUERDOS ADOPTADOS POR EL CONSEJO EN SU SESION Nº 805", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-02", "doble_articulado": false, "id_norma": "149066", "numero_fuente": "36534", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-12-09", "vigencias": [{"desde": "1999-12-09", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-12-09", "fin_vigencia": ""}, "vigencias_