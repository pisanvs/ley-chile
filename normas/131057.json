{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; PRORROGA RESOLUCION QUE INDICA</div><br></div>", "i": 8340211}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n No. 872, de 23 de Agosto de 1988, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, prorr&#xF3;gase por 6 meses a contar del 09 de agosto de 1988, el plazo otorgado a don Miguel Nenadovich del R&#xED;o, R.U.T. No. 3.949.126-5, domiciliado en calle San Antonio No. 427, 9&#xB0; piso, Santiago, para empezar a operar el establecimiento de cultivo autorizado por la resoluci&#xF3;n No. 706, de 1987, de esta Subsecretar&#xED;a, en raz&#xF3;n de haberse acreditado la ocurrencia de un caso fortuito. </div></div>", "i": 8340212}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Agosto de 1988.- Roberto Cabezas Bello, Subsecretario de Pesca.</div><br></div>", "i": 8340213}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "872", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-872"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "PRORROGA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1988-08-23", "doble_articulado": false, "id_norma": "131057", "numero_fuente": "33176", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1988-09-20", "vigencias": [{"desde": "1988-09-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1988-09-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "19