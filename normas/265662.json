{"html": [{"t": "<div><div class=\"p\">FIJA TARIFA DEL SERVICIO DE ASEO </div></div>", "i": 6700765}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se comunica a los usuarios del Servicio de Aseo de la comuna de Andacollo que de acuerdo al DS N&#xBA;69 del Ministerio de Econom&#xED;a, se fija la Tarifa de Aseo anualmente, a partir del a&#xF1;o 2008, en un 0,52 UTM, dando plazo desde el 22 de octubre de 2007 desde las 8:30 y hasta las 17:33 hrs. para presentar sus observaciones en la Municipalidad de Andacollo, ubicada en Plaza Videla N&#xBA;50, Andacollo.</div><br></div>", "i": 6700766}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Andacollo, octubre de 2007.- Jorge &#xD3;rdenes Gonz&#xE1;lez, Alcalde Municipalidad de Andacollo.</div><br></div>", "i": 6700767}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MUNICIPALIDAD DE ANDACOLLO"], "titulo_norma": "FIJA TARIFA DEL SERVICIO DE ASEO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["ANDACOLLO", "TARIFA DE ASEO", "ORDENANZA MUNICIPAL"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["NORMA SIN FECHA DE PROMULGACION"], "derogacion_tacita": [], "derogado": false, "doble_articulado": false, "id_norma": "265662", "numero_fuente": "38889", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-10-18", "vigencias": [{"desde": "2007-10-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2007-10-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2007-10-18", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "GMG", "fecha_ingreso": "2007-10-18", "fecha_version": "2007-10-18"