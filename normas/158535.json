{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA;12.864 EXENTA, DE 1999 </div><br></div>", "i": 6242133}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA;12.864 de 29 de diciembre de 1999, se ha aprobado al Colegio &apos;&apos;The English Institute&apos;&apos;, comuna de Providencia, de Santiago, un plan de estudio para segundo a&#xF1;o de ense&#xF1;anza media, el que se aplicar&#xE1; a partir del a&#xF1;o escolar 2000.</div><div class=\"p\">&nbsp; &nbsp;  Adem&#xE1;s, se aprueba programa de estudio para el subsector de Idioma Extranjero: Ingl&#xE9;s.</div><br></div>", "i": 6242134}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 3 de febrero de 2000.- Juan Eduardo Garc&#xED;a Huidobro S., Jefe Divisi&#xF3;n de Educaci&#xF3;n General. </div></div>", "i": 6242135}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "12864 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-12864 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº12.864 EXENTA, DE 1999", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-12-29", "doble_articulado": false, "id_norma": "158535", "numero_fuente": "36601", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-02-29", "vigencias": [{"desde": "2000-02-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-02-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-02-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODI