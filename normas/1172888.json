{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10312153}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xBA; 14 de 11 enero 2022, prohibi&#xF3; circulaci&#xF3;n veh&#xED;culos relativa a la actividad denominada &quot;Lanzamiento Actividades de Verano de la Comuna de Cochrane&quot;, y autoriz&#xF3; a la Municipalidad de Cochrane para realizar la siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - corte total de v&#xED;a en calle Esmeralda, entre calle Tte. Merino y calle Doctor Steffens de la comuna de Cochrane, desde las 14:00 hrs. hasta las 21:00 hrs. del d&#xED;a lunes 10 de enero de 2022.-</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10312154}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Francisco Lara Acevedo, Gobernador Regional (S), Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesor Jur&#xED;dico, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10312155}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "14 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-14 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2088545", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2022-01-11", "doble_articulado": false, "id_norma": "1172888", "numero_fuente": "43183", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2022-02-19", "vigencias": [{"desde": "2022-02-19", "hasta": "", "tipo_version