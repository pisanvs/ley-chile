{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6282900}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP N&#xBA;1.977, de 16 de mayo de 2000, se modific&#xF3; el decreto MOP N&#xBA;3.266, de 10 de octubre de 1999, que expropi&#xF3; el lote de terreno N&#xBA;47-B; para la obra Habilitaci&#xF3;n Nuevo Camino La P&#xF3;lvora Etapa I, Sector Ruta 68- Acceso Sur a Valpara&#xED;so, Camino La P&#xF3;lvora Rol F-724 F-730, Sector Placilla-Puertas Negras, que rectifica el nombre del expropiado que es Pedro Kavajin Damic, rol de aval&#xFA;o 9317-11, comuna de Valpara&#xED;so, V Regi&#xF3;n. La publicaci&#xF3;n se&nbsp; efect&#xFA;a en cumplimiento a lo dispuesto en el art&#xED;culo 7&#xBA; del decreto&nbsp; ley N&#xBA;2.186, de 1978.-</div><br></div>", "i": 6282901}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6282902}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1977", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1977"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-05-16", "doble_articulado": false, "id_norma": "171184", "numero_fuente": "36690", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-06-15", "vigencias": [{"desde": "2000-06-15", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2000-06-15", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2000-06-15", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculacione