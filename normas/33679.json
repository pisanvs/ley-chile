{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291004}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 195, de 31 de enero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a PESQUERA AGUA FRIA S.A., para continuar desarrollando, como sucesora legal, las actividades pesqueras autorizadas por esta Subsecretar&#xED;a de Pesca a Pesquera Andacollo 2 S.A., por Resoluci&#xF3;n N&#xB0; 1523, de 1995, de esta Subsecretar&#xED;a, en virtud de los documentos y disposiciones legales.</div><div class=\"p\">&nbsp; &nbsp; Previo a la operaci&#xF3;n de la nave, Pesquera Agua Fr&#xED;a S.A., deber&#xE1; inscribirla a su nombre en el Registro Nacional Pesquero Industrial que lleva el Servicio Nacional de Pesca.</div><br><br></div>", "i": 8291005}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 31 de enero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8291006}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "195", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-195"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PESQUERA AGUA FRIA S.A", "PESCA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1996-01-31", "fecha_derogacion": "2002-01-08", "doble_articulado": false, "id_norma": "33679", "numero_fuente": "35390", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1996-02-12", "vigencias": [{"desde": "2002-01-08", "hasta": "", "tipo_version": "2", "tipo_version_s": "Úl