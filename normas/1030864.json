{"html": [{"t": "<div><br><div class=\"p\">MODIFICA DECRETO N&#xBA; 202 EXENTO, DE 2011</div></div>", "i": 9193869}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 909, de 6 de octubre de 2011, de este Ministerio, modif&#xED;case el <a href=\"https://www.leychile.cl/Navegar?idNorma=1023243&amp;idParte=9114593&amp;idVersion=\">art&#xED;culo 1&#xBA; del decreto exento N&#xBA; 202, de 2011, del Ministerio de Econom&#xED;a, Fomento y Turismo</a>, que estableci&#xF3; la cuota anual de captura de la unidad de pesquer&#xED;a de erizo a ser extra&#xED;da en el &#xE1;rea mar&#xED;tima de la X y XI Regiones, a&#xF1;o 2011, en el sentido de reemplazar la distribuci&#xF3;n de la cuota en los t&#xE9;rminos indicados en decreto extractado.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro del presente decreto se publicar&#xE1; en los sitios de dominio electr&#xF3;nico de la Subsecretar&#xED;a de Pesca y del Servicio Nacional de Pesca.</div><br></div>", "i": 9193870, "v": ["MODIFICACION"]}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 6 de octubre de 2011.- Felipe Palacio Rives, Subsecretario de Pesca (S).</div></div>", "i": 9193871}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "909 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-909 EXENTO"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y TURISMO", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA DECRETO Nº 202 EXENTO, DE 2011", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-10-06", "doble_articulado": false, "id_norma": "1030864", "numero_fuente": "40084", "tipo_version": "3", "tipo_version_