{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,895 que consulta fondos para compra de materiales telegr&#xE1;ficos</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 1,895.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274817}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico . Conc&#xE9;dese un suplemento de sesenta mil pesos ($ 60,000) al &#xED;tem 2,938 de la partida 81 del presupuesto del Interior, destinado a la compra de materiales telegr&#xE1;ficos, fletes, construcciones i reparaciones de l&#xED;neas i pago de jornales.</div><br></div>", "i": 8274818}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, 17 de diciembre de 1906.- PEDRO MONTT.- V. Santa Cruz.</div><br></div>", "i": 8274819}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1895", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1895"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "LEI NUM. 1,895 QUE CONSULTA FONDOS PARA COMPRA DE MATERIALES TELEGRAFICOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PRESUPUESTO A O 1906", "MODIFICACION", "MATERIAL", "TELEGRAFICO", "COMPRA", "LINEAS TELEGRAFICAS", "REPARACIONES", "PAGO JORNALES", "SUPLEMENTO"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1906-12-17", "doble_articulado": false, "id_norma": "22988", "numero_fuente": "8678", "tipo_version": "3", "tipo_version_s": 