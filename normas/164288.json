{"html": [{"t": "<div><div class=\"p\">DEROGA RESOLUCION EXENTA No. 132, DE 1986</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 286 exenta.- Santiago, 11 de Abril de 1986. Vistos: El art&#xED;culo 118 de la Ley No. 18.290, Ley de Transito; el Decreto Supremo No. 275/80 y la Resoluci&#xF3;n No.</div><div class=\"p\">59/85, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, y teniendo presente nuevos antecedentes,</div><br><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br></div>", "i": 7266916}, {"t": "<div><div class=\"p\">1&#xB0;.- Der&#xF3;gase la Resoluci&#xF3;n Exenta No. 132 de 11 de Febrero de 1986, publicada en el Diario Oficial de fecha 24 de Febrero de 1986.</div><div class=\"p\">2&#xB0;.- La presente Resoluci&#xF3;n regir&nbsp; a contar de la fecha de su publicaci&#xF3;n en el Diario Oficial.</div><br></div>", "i": 7266917}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese, y publ&#xED;quese.- Carlos Roman Toro, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n Metropolitana.</div><div class=\"p\">Lo que transcribo para su conocimiento.- Saluda a Ud. Patricia Mu&#xF1;oz Villela, Jefe Administrativo. </div></div>", "i": 7266918}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "286 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-286 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "DEROGA RESOLUCION EXENTA No. 132, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-04-11", "doble_articulado": false, "id_norma": "164288", "