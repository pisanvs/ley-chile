{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION </div></div>", "i": 6217141}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 309, de 08 de Junio de 1987, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la VIII Regi&#xF3;n del B&#xED;o B&#xED;o, se autoriza a la Empresa de Buses Hualpen Limitada para prestar todo tipo de servicio de transporte de pasajeros por calles y caminos, dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blico urbanos de locomoci&#xF3;n colectiva de pasajeros.-</div><br></div>", "i": 6217142}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lucia M. Leiva Madariaga, Secretario Regional Ministerial de Transportes y Telecomunicaciones VIII Regi&#xF3;n subrogante.</div><br></div>", "i": 6217143}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "309 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-309 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL VIII REGIÓN DEL BIOBÍO"], "titulo_norma": "EXTRACTO DE RESOLUCION", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1987-06-08", "doble_articulado": false, "id_norma": "150757", "numero_fuente": "32797", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1987-06-16", "vigencias": [{"desde": "1987-06-16", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1987-06-16", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1987-06-16", "fin_vigencia": "", "tipo_version": "3"}], "eve