{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6128369}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP. No. 1.103, de 30 de julio de 1998, se expropiaron los lotes de terreno No. s. 50-A, 50-B, 50-C y 50-D, superficies 18.928, 7.380, 23.622 y 26.940 m2., Rol de Aval&#xFA;o No. 618-32, comuna de Tom&#xE9;, para la obra Camino Acceso Norte a Concepci&#xF3;n, Ramal Colector, sector Rafael - Agua Amarilla, Km. 9.980,00 al Km.</div><div class=\"p\">13.620,00, y se acord&#xF3; precio de la indemnizaci&#xF3;n con sus propietarios Angela Parra Montero, Mar&#xED;a Teresa Parra Montero y Mar&#xED;a Gladys Parra Montero, ascendente a las cantidades de $ 2.954.525.- para el lote No. 50-A; $ 1.392.416.- para el lote No. 50-B; $ 35.927.554.- para el lote No. 50-C y $ 7.506.997.- para el lote No. 50-D. </div></div>", "i": 6128370}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6128371}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1103", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1103"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["EXPROPIACION", "BIEN INMUEBLE", "TOME", "OCTAVA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1998-07-30", "doble_articulado": false, "id_norma": "123849", "numero_fuente": "36154", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1998-09-01", "vigencias": [{"desde": "1998-09-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1998-09-01", "fin_vigencia": ""}, "vigencias_version_norma"