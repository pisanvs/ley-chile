{"html": [{"t": "<div><div class=\"p\">DERECHOS DE AGUA EN COMUNA DE CASABLANCA</div><br><br></div>", "i": 7313177}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero, mediante resoluci&#xF3;n</div><div class=\"p\">exenta N&#xBA; 2.097, de 24 de junio de 2004, conforme</div><div class=\"p\">art&#xED;culo 5&#xBA; transitorio C&#xF3;digo Aguas, aclar&#xF3; y complement&#xF3; resoluci&#xF3;n exenta N&#xBA; 869, de 15 de julio de 1985, que aprob&#xF3; distribuci&#xF3;n de derechos de aprovechamiento de aguas del Proyecto de Parcelaci&#xF3;n &quot;Mundo Nuevo&quot;, de la comuna de Casablanca, provincia de Valpara&#xED;so, V Regi&#xF3;n, en el sentido de establecer que los derechos de aprovechamiento de aguas que se extraen de pozo profundo tienen la equivalencia que se indica, expresada en unidad de volumen por unidad de tiempo.</div><div class=\"p\">&nbsp; &nbsp;  Los derechos de aguas se extraen del pozo profundo de coordenadas 3320-7120 B-1.</div><div class=\"p\">&nbsp; &nbsp;  Publicaci&#xF3;n hecha conforme art&#xED;culo 13 ley N&#xBA; 18.377.</div><br></div>", "i": 7313178}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Director Nacional.</div><br></div>", "i": 7313179}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2097 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2097 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO", "DIRECCIÓN NACIONAL"], "titulo_norma": "DERECHOS DE AGUA EN COMUNA DE CASABLANCA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS DE APROVECHAMIENTO DE AGUAS", "CASABLANCA", "QUINTA REGION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2004-06-24", "do