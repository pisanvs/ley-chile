{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; CRUCERO &quot;ESMERALDA&quot; Lei n&#xFA;m. 213.-Santiago, a 14 de Noviembre de 1894.-Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br><br><br><br></div>", "i": 7162554}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; ARTICULO UNICO. Autor&#xED;zase al Presidente de la Rep&#xFA;blica para vender el crucero Esmeralda, de la Marina de Guerra Nacional, por la suma de doscientas veinte mil libras esterlinas (l 220,000), que invertir&#xE1; en la adquisicion de otra nave para la misma Marina.</div><br><br></div>", "i": 7162555}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.-JORJE MONTT.-Santiago Aldunate Bascu&#xF1;an.</div><br></div>", "i": 7162556}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "213", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-213"}], "organismos": ["MINISTERIO DE MARINA"], "titulo_norma": "CRUCERO ESMERALDA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CRUCERO ESMERALDA", "MARINA GUERRA NACIONAL", "PRESIDENTE REPUBLICA", "VENTA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-11-14", "doble_articulado": false, "id_norma": "22070", "numero_fuente": "4964", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-11-14", "vigencias": [{"desde": "1894-11-14", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-11-14", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigenc