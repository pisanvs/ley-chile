{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8343870}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 598, de 13 de abril de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad&nbsp; de&nbsp; la resoluci&#xF3;n N&#xBA;163, de 1980, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA QUELLON LTDA, para operar las naves &apos;&apos;Santa Mar&#xED;a&apos;&apos;, &apos;&apos;Cristina&apos;&apos;, &apos;&apos;Victoria&apos;&apos;, &apos;&apos;Mercedes&apos;&apos;, &apos;&apos;Isabel&apos;&apos;, &apos;&apos;Sarita&apos;&apos;, &apos;&apos;Ximena&apos;&apos; y &apos;&apos;Carmen&apos;&apos;, por no haber realizado operaciones de pesca por dos a&#xF1;os consecutivos, configur&#xE1;ndose la causal prevista en el art&#xED;culo 143 letra b) de la Ley General de Pesca y Acuicultura.</div><br></div>", "i": 8343871}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 13 de abril de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8343872}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "598", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-598"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-04-13", "doble_articulado": false, "id_norma": "135170", "numero_fuente": "36342", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-19", "vigencias": [{"desde": "1999-04-19", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-