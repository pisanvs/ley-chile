{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  CERTIFICADO</div><br></div>", "i": 6442028}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  El Subsecretario de Educaci&#xF3;n, quien suscribe, certifica que la carrera de Ingenier&#xED;a de Ejecuci&#xF3;n en Pesca aprobada por Certificado N&#xBA; 06/1230 de fecha 18 de Diciembre de 1989, que imparte el Instituto Profesional ZIPTER, ha modificado sus planes y programas de estudios, en el sentido de otorgar el t&#xED;tulo intermedio de T&#xE9;cnico Pesquero, los que revisados por la Universidad Arturo Prat como entidad examinadora, han sido aprobados en tiempo y forma.</div><br></div>", "i": 6442029}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; RAUL ALLARD NEUMANN</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Subsecretario de Educaci&#xF3;n</div><br></div>", "i": 6442030}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "GABINETE DEL SUBSECRETARIO"], "titulo_norma": "CERTIFICADO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-08-21", "doble_articulado": false, "id_norma": "215350", "numero_fuente": "34061", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-05", "vigencias": [{"desde": "1991-09-05", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-05", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09-05", "fin_vi