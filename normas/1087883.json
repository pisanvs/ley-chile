{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DEL DECRETO N&#xBA; 2.399 EXENTO, DE FECHA 16 DE DICIEMBRE DE 2015</div></div>", "i": 9679069}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento 2.399, de fecha 16 de diciembre de 2015, del Ministerio de Educaci&#xF3;n, se revoc&#xF3; el reconocimiento oficial del Centro de Formaci&#xF3;n T&#xE9;cnica Ceponal, otorgado por <a href=\"https://www.leychile.cl/Navegar?idNorma=84606&amp;idParte=&amp;idVersion=\">decreto exento N&#xBA; 78, de 1 de marzo de 1990</a>, modificado por <a href=\"https://www.leychile.cl/Navegar?idNorma=20473&amp;idParte=0&amp;idVersion=\">decreto exento N&#xBA; 160, de 21 de abril de 1993, ambos de Educaci&#xF3;n</a>, y se dej&#xF3; sin efecto la aprobaci&#xF3;n de las carreras t&#xE9;cnicas de nivel superior aprobadas para la instituci&#xF3;n.</div><div class=\"p\">&nbsp; &nbsp;  Lo dispuesto precedentemente, regir&#xE1; a contar de la total tramitaci&#xF3;n de este decreto.- </div><br></div>", "i": 9679070, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  </div><div class=\"p\">&nbsp; &nbsp;  Gonzalo Mu&#xF1;oz Stuardo, Subsecretario de Educaci&#xF3;n (S).</div></div>", "i": 9679071}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "2399 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-2399 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARÍA DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DEL DECRETO Nº 2.399 EXENTO, DE FECHA 16 DE DICIEMBRE DE 2015", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["IdDO 1000289"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2015-12-16", "doble_articulado": false, "