{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SERVICIO AGRICOLA Y GANADERO </div></div>", "i": 6023124}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Servicio Agr&#xED;cola y Ganadero, mediante resoluci&#xF3;n exenta N&#xB0; 702 de fecha 17 de Mayo de 1984, ratificada por resoluci&#xF3;n exenta N&#xB0; 610 de 29 de Abril de 1991, conforme art&#xED;culo 5&#xB0; Transitorio del C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento aguas proporcionales que corresponden al sector excluido del predio &quot;Chacra Pamela&quot;, de la comuna de Quilicura y derechos aprovechamiento de aguas que corresponden a las parcelas N&#xB0;s. 1 a 10 y sitios A, B, C, D, E, F, G, H, I y J del Proyecto de Parcelaci&#xF3;n &quot;Pamela&quot;, formado por el predio se&#xF1;alado, Los derechos de agua se extraen del Estero Las Cruces. Publicaci&#xF3;n hecha conforme art&#xED;culo 13. Ley 18.377, </div></div>", "i": 6023125}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Director Nacional.</div><br></div>", "i": 6023126}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "610", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-610"}], "organismos": ["MINISTERIO DE AGRICULTURA"], "titulo_norma": "SERVICIO AGRICOLA Y GANADERO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DERECHOS DE APROVECHAMIENTO DE AGUAS", "QUILICURA", "CHACRA PAMELA", "ESTERO LAS CRUCES"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-04-29", "doble_articulado": false, "id_norma": "39161", "numero_fuente": "33981", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-06-01", "vigencias": [{"desde": "1991-06-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia":