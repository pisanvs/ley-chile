{"html": [{"t": "<div><div class=\"p\">AVISO</div><br><br></div>", "i": 6364173}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Se pone en conocimiento del p&#xFA;blico que mediante decreto N&#xBA; E-1682/2001 de fecha 21 de diciembre del a&#xF1;o en curso, se promulg&#xF3; el Acuerdo N&#xBA; 87/2001 del H. Concejo Municipal, que aprob&#xF3; las modificaciones introducidas a la Ordenanza Local de Derechos Municipales por Concesiones, Permisos y/o Servicios, las que regir&#xE1;n a contar del uno de enero del a&#xF1;o 2002. El texto de la Ordenanza modificada se podr&#xE1; conocer a contar de la fecha de publicaci&#xF3;n del presente aviso en la Secretar&#xED;a Municipal.</div><br></div>", "i": 6364174}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Colina, 21 de diciembre de 2001. El Alcalde. </div></div>", "i": 6364175}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "7", "numero": "S/N", "abreviacion": "AVI", "descripcion": "Aviso", "compuesto": "AVI-S/N"}], "organismos": ["MUNICIPALIDAD DE COLINA"], "titulo_norma": "AVISO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2001-12-21", "doble_articulado": false, "id_norma": "193242", "numero_fuente": "37147", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2001-12-29", "vigencias": [{"desde": "2001-12-29", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2001-12-29", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2001-12-29", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "CNB", "fecha_ingreso": "2002-01-03", "fecha_version": "2001-12-29", "fecha_