{"html": [{"t": "<div><br><div class=\"p\">EXTRACTO DE DECRETO N&#xBA;1.143 EXENTO, DE 2009</div></div>", "i": 8707872}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;1.143, de fecha 16.06.09, del Ministerio de Educaci&#xF3;n, se ampl&#xED;a el reconocimiento oficial al Instituto Profesional Chileno Norteamericano, otorgado por decreto exento de Educaci&#xF3;n N&#xBA;2.429, del 10 de diciembre de 2007, en el sentido de aprobar la carrera que se indica conducente a los t&#xED;tulos que se se&#xF1;alan, a contar del a&#xF1;o 2009, en jornada vespertina:</div><br><div class=\"p\">Carrera&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; :&nbsp;  Traducci&#xF3;n Ingl&#xE9;s - Espa&#xF1;ol</div><div class=\"p\">T&#xED;tulo Profesional&nbsp;  :&nbsp;  Traductor Ingl&#xE9;s Espa&#xF1;ol</div><div class=\"p\">T&#xED;tulo T&#xE9;cnico de </div><div class=\"p\">Nivel Superior&nbsp; &nbsp; &nbsp;  :&nbsp;  T&#xE9;cnico en Asistente </div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  Traductor de Alta Gerencia</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  (Salida intermedia)</div><br></div>", "i": 8707873}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, 17 de junio de 2009.- Cristi&#xE1;n Mart&#xED;nez Ahumada, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 8707874}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1143 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-1143 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº1.143 EXENTO, DE 2009", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogaci