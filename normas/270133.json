{"html": [{"t": "<div><div class=\"p\">DEROGA AUTORIZACI&#xD3;N DE EMISOR ELECTR&#xD3;NICO </div></div>", "i": 7366628}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 35 de 20 de marzo de 2008, que deroga autorizaci&#xF3;n otorgada a contribuyente para operar como emisor electr&#xF3;mico.</div><br><div class=\"p\">&nbsp; &nbsp;  A petici&#xF3;n del contribuyente RUT 76.372.240-6, se deroga autorizaci&#xF3;n otorgada para operar como emisor de Documentos Tributarios Electr&#xF3;nicos.</div><div class=\"p\">El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de marzo de 2008.</div><br></div>", "i": 7366629}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "35 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-35 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "DEROGA AUTORIZACIÓN DE EMISOR ELECTRÓNICO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2008-03-20", "doble_articulado": false, "id_norma": "270133", "numero_fuente": "39021", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2008-03-27", "vigencias": [{"desde": "2008-03-27", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2008-03-27", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2008-03-27", "fin_vigencia": "", "tipo_vers