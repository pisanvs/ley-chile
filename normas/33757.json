{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8291076}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 208, de 24 de Marzo de 1993, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a COMPA&#xD1;IA PESQUERA CAMANCHACA S.A., R.U.T. N&#xB0; 93.711.000-6, domiciliada en calle Miraflores N&#xB0; 178, Piso 16, Santiago, para continuar desarrollando las actividades pesqueras autorizadas mediante todas las Resoluciones vigentes otorgadas por esta Subsecretar&#xED;a a Pesquera Roc&#xED;o S.A.</div><div class=\"p\">R.U.T. N&#xB0; 79.534.430-6, domiciliada en Iquique, por haberse fusionado esta &#xFA;ltima con la primera, seg&#xFA;n consta de las escrituras p&#xFA;blicas citadas en Vistos y en virtud de lo dispuesto en la Ley 18.046 sobre sociedades an&#xF3;nimas.</div><br><br></div>", "i": 8291077}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 24 de Marzo de 1993.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8291078}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "208", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-208"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARIA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["AUTORIZACION", "PESCA", "COMPA IA PESQUERA CAMANCHACA", "S.A.", "PESQUERA ROCIO S.A."], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1993-03-24", "fecha_derogacion": "2002-01-08", "doble_articulado": false, "id_norma": "33757", "numero_fuente": "34534", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1993-04-05", "