{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8293380}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 610, de 3 de abril de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, modif&#xED;case el numeral 1 de la Resoluci&#xF3;n N&#xB0; 763, de 1995, de esta Subsecretar&#xED;a, por la cual se autoriz&#xF3; a PESQUERA SAN JOSE S.A., para operar la nave &quot;Don Julio&quot;, en el sentido de se&#xF1;alar que sus actuales caracter&#xED;sticas n&#xE1;uticas son:</div><div class=\"p\"> Nombre&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &quot;Don Julio&quot;</div><div class=\"p\"> Matr&#xED;cula&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  2870</div><div class=\"p\"> Eslora de arqueo&nbsp; &nbsp; &nbsp; 58,94 m.</div><div class=\"p\"> Eslora total&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 66 m.</div><div class=\"p\"> T.R.G.&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 1.397</div><div class=\"p\"> Cap. de bodega&nbsp; &nbsp; &nbsp; &nbsp; 1.610,03 m3</div><div class=\"p\"> Arte de pesca&nbsp; &nbsp; &nbsp; &nbsp;  Cerco y arrastre de media agua</div><br></div>", "i": 8293381}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 3 de abril de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8293382}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "610", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-610"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MODIFICACION", "AUTORIZACION", "PESCA", "PESQUERA SAN JOSE S.A"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derog