{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; SOSTENIMIENTO DE LAZARETOS I ATENCION DE VARIOLOSOS Lei n&#xFA;m. 189.-Santiago, a 18 de Agosto de 1894.-Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8273842}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Se autoriza al Presidente de la Rep&#xFA;blica para invertir hasta la suma de veinte mil pesos ($ 20,000) en el sostenimiento de lazaretos i atencion de variolosos.</div><br><br></div>", "i": 8273843}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- JORGE MONTT.- Enrique Mac-Iver.</div><br></div>", "i": 8273844}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "189", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-189"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "SOSTENIMIENTO DE LAZARETOS I ATENCION DE VARIOLOSOS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["LAZARETOS", "MANTENCION", "VARIOLOSOS", "DESTINACION", "ATENCION", "PRESIDENTE REPUBLICA", "FONDOS", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1894-08-18", "doble_articulado": false, "id_norma": "22048", "numero_fuente": "4894", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1894-08-18", "vigencias": [{"desde": "1894-08-18", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1894-08-18", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1894-08-18", "fin_vi