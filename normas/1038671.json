{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 9245762}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por Decreto MOP. Exento N&#xBA;4590, de 16 de diciembre de 2011, se dej&#xF3; sin efecto la expropiaci&#xF3;n del lote de terreno N&#xB0;2, correspondiente al Estudio de Ingenier&#xED;a del Sistema de Riego de la Red Secundaria y Terciaria de Canales Faja Maisan, Obra: &quot;Canal Mapu Quimey&quot;, Derivados 2 y 2-3, ordenado a expropiar mediante <a href=\"https://www.leychile.cl/Navegar?idNorma=1031955&amp;idParte=0&amp;idVersion=\">Decreto MOP. Exento N&#xB0;3183, de 17 de octubre de 2011</a>, en consideraci&#xF3;n que el lote N&#xB0;2, se encuentra emplazado en tres inmuebles con distinta denominaci&#xF3;n y rol de aval&#xFA;o. </div><br></div>", "i": 9245763, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas.</div></div>", "i": 9245764}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "4590 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-4590 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2011-12-16", "doble_articulado": false, "id_norma": "1038671", "numero_fuente": "40228", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2012-04-02", "vigencias": [{"desde": "2012-04-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2012-04-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2012-04-02", "fin_vigencia": "", "tipo_version": "3"}], "ev