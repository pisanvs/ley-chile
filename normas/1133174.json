{"html": [{"t": "<div><br><div class=\"p\">OFICIOS ACOMPA&#xD1;ATORIOS.</div><br></div>", "i": 10035920}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Julio 22 de 1823.</div><br><div class=\"p\">&nbsp; &nbsp;  1.&#xB0; Queda abolida la costumbre de acompa&#xF1;arse oficio por los Ministros de Estado para el cumplimiento de providencias o decretos supremos.</div><br><div class=\"p\">&nbsp; &nbsp;  2.&#xB0; Todo decreto supremo sea de sustanciacion o dispositivo cualquiera que sea el Tribunal, corporacion o persona particular a quien se dirija, ser&#xE1; obedecido y cumplido sin necesidad de oficio acompa&#xF1;atorio Ins&#xE9;rtese en el Boletin.</div><br></div>", "i": 10035921}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  FREIRE.</div><br><div class=\"p\">&nbsp; &nbsp;  Ega&#xF1;a.</div><br></div>", "i": 10035922}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "OFICIOS ACOMPAÑATORIOS", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1823-07-22", "doble_articulado": false, "id_norma": "1133174", "numero_fuente": "1823", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1823-07-22", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1823-07-22", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1823-07-22", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "CONCORDANCIA", "url_part": "concordancia"}], "ingresado_por": "1795", "fecha_ingr