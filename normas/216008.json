{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 10.971 EXENTA, DE 2003 </div></div>", "i": 6444038}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta de Educaci&#xF3;n N&#xBA; 10.971 de 4 de septiembre del a&#xF1;o 2003, se han modificado las resoluciones exentas de Educaci&#xF3;n N&#xBA;s. 12.879 de 1999 y 4.086 de 1999, modificada por resoluci&#xF3;n exenta N&#xBA; 1.261 de 2002, que aprobaron planes y programas especiales de estudio para 1&#xBA; y 2&#xBA; a&#xF1;o de Ense&#xF1;anza Media al Instituto Hebreo, comuna de Las Condes, de Santiago, en la forma que se indica en la presente resoluci&#xF3;n.</div><br></div>", "i": 6444039}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 12 de septiembre de 2003.- Pedro Montt Leiva, Jefe Divisi&#xF3;n de Educaci&#xF3;n General.</div><br></div>", "i": 6444040}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "10971 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-10971 EXENTA"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 10.971 EXENTA, DE 2003", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["INSTITUTO HEBREO", "PLANES Y PROGRAMAS DE ESTUDIO", "APROBACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-09-04", "doble_articulado": false, "id_norma": "216008", "numero_fuente": "37687", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2003-10-17", "vigencias": [{"desde": "2003-10-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2003-10-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2003-10-17", "fin_vigencia": "",