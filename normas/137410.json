{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8345383}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA;924, de 20 de mayo de 1999, de esta Subsecretar&#xED;a, autor&#xED;zase a don MARCELO ERNESTO MANSILLA MENDOZA, para iniciar actividades pesqueras de transformaci&#xF3;n, en la forma y bajo las condiciones que a continuaci&#xF3;n se expresan.</div><div class=\"p\">&nbsp; &nbsp;  La peticionaria podr&#xE1; instalar y operar una planta ubicada en calle Eleuterio Ram&#xED;rez N&#xBA; 940 Interior Cardonal, Puerto Montt, donde podr&#xE1; procesar en las l&#xED;neas que se indican los siguientes recursos hidrobiol&#xF3;gicos: Ahumado: Salm&#xF3;n del Atl&#xE1;ntico, Trucha arcoiris, Trucha caf&#xE9;, Jurel.</div><br></div>", "i": 8345384}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 20 de mayo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8345385}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "924", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-924"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-05-20", "doble_articulado": false, "id_norma": "137410", "numero_fuente": "36381", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-06-07", "vigencias": [{"desde": "1999-06-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-06-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-06-07", "fin_v