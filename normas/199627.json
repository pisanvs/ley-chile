{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 469 EXENTO, DE 2002 </div></div>", "i": 7292407}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA;469 de fecha 30 de mayo de 2002 del Ministerio de Educaci&#xF3;n, se deja sin efecto la autorizaci&#xF3;n de funcionamiento de la Sede N&#xBA; 1 del Centro de Formaci&#xF3;n T&#xE9;cnica Escuela Superior de Comercio Exterior Santiago-Esces de la ciudad de Valpara&#xED;so, concedida por decreto exento de Educaci&#xF3;n N&#xBA; 54 del 19 de marzo de 1987, a petici&#xF3;n de la propia instituci&#xF3;n, en raz&#xF3;n a que dicha sede ha dejado de funcionar y ha trasladado a sus alumnos al Instituto Profesional Latinoamericano de Comercio Exterior- Iplacex.</div><br></div>", "i": 7292408}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 19 de junio de 2002.- Jos&#xE9; Weinstein Cayuela, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7292409}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "469 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-469 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 469 EXENTO, DE 2002", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2002-05-30", "doble_articulado": false, "id_norma": "199627", "numero_fuente": "37291", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2002-06-24", "vigencias": [{"desde": "2002-06-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2002-06-24", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2002-06-24", "fin_vigencia