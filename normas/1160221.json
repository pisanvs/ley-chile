{"html": [{"t": "<div><div class=\"p\">&#xFEFF;TEATRO.</div><br><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Octubre 15 de 1830.</div><br><div class=\"p\">&nbsp; &nbsp;  Deseando el Gobierno evitar los abusos que se han dejado notar en las representaciones teatrales, tanto en algunas obras que se han exhibido, como en la licencia con que suelen desempe&#xF1;ar los actores algunos pasajes, con desagrado del p&#xFA;blico y notable agravio de las buenas costumbres, he venido en decretar:</div></div>", "i": 10255139}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. 1.&#xB0; No podr&#xE1; exhibirse ni anunciarse por la compa&#xF1;&#xED;a dram&#xE1;tica o lirica pieza alguna que no sea revisada previamente por el Censor del teatro, y haya obtenido su aprobacion.</div></div>", "i": 10255140}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  Art. 2.&#xB0; N&#xF3;mbrase para este cargo al presb&#xED;tero, Rector del Instituto nacional, don Blas Reyes. Interin se publica un reglamento de teatro. Comun&#xED;quese.</div></div>", "i": 10255141}, {"t": "<div><br><div class=\"p\">&nbsp; &nbsp;  OVALLE.</div><br><div class=\"p\">&nbsp; &nbsp;  Portales.</div></div>", "i": 10255142}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "TEATRO.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1830-10-15", "doble_articulado": false, "id_norma": "1160221", "numero_fuente": "1830", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1830-10-15", "hasta": "", "tipo_version": "3", "ti