{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6307320}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 2.363 de 25 de octubre de 2000 de esta Subsecretar&#xED;a, modif&#xED;case el numeral 5&#xBA; de la resoluci&#xF3;n N&#xBA; 2.194 de&nbsp; 2000, de esta Subsecretar&#xED;a, que autoriz&#xF3; al INSTITUTO DE FOMENTO PESQUERO, para efectuar una pesca de investigaci&#xF3;n de conformidad con los T&#xE9;rminos T&#xE9;cnicos de Referencia del Proyecto denominado &apos;&apos;Pesca de Investigaci&#xF3;n del Jurel entre la III y la X Regiones&apos;&apos;, en el sentido de se&#xF1;alar que el l&#xED;mite m&#xE1;ximo de captura autorizado se incrementar&#xE1; para el mes de octubre en 4.343 toneladas para la Zona 1, comprendida entre la III y IV Regiones, y en 3.099 toneladas para la Zona 2, comprendida entre la V a la X Regiones.</div><br></div>", "i": 6307321}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 25 de octubre de 2000.- Daniel Albarr&#xE1;n Ruiz-Clavijo, Subsecretario de Pesca.</div><br></div>", "i": 6307322}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2363", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-2363"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2000-10-25", "doble_articulado": false, "id_norma": "177417", "numero_fuente": "36804", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2000-11-04", "vigencias": [{"desde": "2000-11-04", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "v