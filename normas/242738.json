{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6543146}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.203, de 28 de septiembre</div><div class=\"p\">de 2005, de esta Subsecretar&#xED;a, autor&#xED;zase a las</div><div class=\"p\">organizaciones de pescadores artesanales que se indica</div><div class=\"p\">en la resoluci&#xF3;n extractada, sometidas al R&#xE9;gimen</div><div class=\"p\">Artesanal de Extracci&#xF3;n en la unidad de pesquer&#xED;a de merluza del sur de la XI Regi&#xF3;n, para realizar actividades pesqueras extractivas durante el mes de septiembre entre los d&#xED;as 29 y 30 de dicho mes, ambas fechas inclusive.</div><div class=\"p\">&nbsp; &nbsp;  Deni&#xE9;gase la autorizaci&#xF3;n solicitada por el SINDICATO DE TRABAJADORES INDEPENDIENTES DE LA PESCA ARTESANAL ESFUERZO DEL MAR.</div><br></div>", "i": 6543147}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 28 de septiembre de 2005.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6543148}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3203 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3203 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-09-28", "doble_articulado": false, "id_norma": "242738", "numero_fuente": "38282", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-10-08", "vigencias": [{"desde": "2005-10-08", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"i