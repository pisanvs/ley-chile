{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;  NOTIFICACION</div><br></div>", "i": 7348951}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 3.882 de 19 de julio de 2007 de Serviu Metropolitano, se orden&#xF3; expropiaci&#xF3;n parcial, conforme D.L. N&#xBA; 2.186 de 1978, del inmueble ubicado en calle Vicu&#xF1;a Mackenna N&#xBA; 4115, presunto Rol de Aval&#xFA;o N&#xBA; 3400-117 comuna de Puente Alto, aparente dominio de Petroflex S.A.; correspondiente al Lote N&#xBA; 30, Tramo 2, del Proyecto Vial &quot;Habilitaci&#xF3;n Corredor de Transporte P&#xFA;blico Vicu&#xF1;a Mackenna&quot;. Comisi&#xF3;n integrada por peritos Luisa Aracena Hern&#xE1;ndez, Constructor Civil; Victoria Blanco Costa, arquitecto; y Fresia Mora Lepe, Arquitecto, seg&#xFA;n informe de 20 de septiembre de 2006, fij&#xF3; monto provisional indemnizaci&#xF3;n en $2.967.600, pagadera al contado.</div><br></div>", "i": 7348952}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Serviu Metropolitano.</div><br></div>", "i": 7348953}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "3882 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-3882 EXENTA"}], "organismos": ["MINISTERIO DE VIVIENDA Y URBANISMO", "SERVICIO DE VIVIENDA Y URBANIZACION REGION METROPOLITANA"], "titulo_norma": "NOTIFICACIÓN", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2007-07-19", "doble_articulado": false, "id_norma": "263146", "numero_fuente": "38827", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2007-08-01", "vigencias": [{"desde": "2007-08-01", "hasta": "", "tipo_version":