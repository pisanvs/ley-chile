{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6052601}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 577, de 17 de Junio de 1992, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se deja sin efecto la Resoluci&#xF3;n No. 1347, de 1989, prorrogada por la Resoluci&#xF3;n No. 1455, de 1990, ambas de esta Subsecretar&#xED;a, que autoriz&#xF3; a don SERGIO ROJAS MARIN, RUT No. 6.541.682-4, domiciliado en calle Urmeneta No. 801, Puerto Montt, X Regi&#xF3;n, para operar un establecimiento de cultivo en el Sector de Changue, R&#xED;o Maull&#xED;n, de la comuna de Maull&#xED;n, provincia de Llanquihue, X Regi&#xF3;n por renuncia total de su titular, ya individualizado. </div></div>", "i": 6052602}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 17 de Junio de 1992.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 6052603}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "577", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-577"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1992-06-17", "doble_articulado": false, "id_norma": "78468", "numero_fuente": "34303", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1992-06-30", "vigencias": [{"desde": "1992-06-30", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1992-06-30", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1992-06-30", "fin_vigencia": "", "tipo_version":