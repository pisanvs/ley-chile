{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO N&#xBA; 1.919 EXENTO, DE 2005 </div></div>", "i": 6560400}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto exento N&#xBA; 1.919, de fecha 28 de diciembre de 2005, del Ministerio de Educaci&#xF3;n, se deja sin efecto la autorizaci&#xF3;n de funcionamiento de la sede N&#xBA; 1 de Santiago y N&#xBA; 5 de Concepci&#xF3;n y la aprobaci&#xF3;n de los planes y programas de estudios de las carreras que no registran matr&#xED;cula por m&#xE1;s de cinco a&#xF1;os, del Centro de Formaci&#xF3;n T&#xE9;cnica Diego Portales.</div><br></div>", "i": 6560401}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 1 de febrero de 2006.- Pedro Montt Leiva, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 6560402}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "1919 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-1919 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN"], "titulo_norma": "EXTRACTO DE DECRETO Nº 1.919 EXENTO, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-12-28", "doble_articulado": false, "id_norma": "247107", "numero_fuente": "38383", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-02-07", "vigencias": [{"desde": "2006-02-07", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-02-07", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-02-07", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_por": "JRC", "fecha_ingres