{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; MODIFICA LA LEY N&#xB0; 10,475, RELACIONADA CON PREVISION DE LOS EMPLEADOS PARTICULARES</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobaci&#xF3;n al siguiente</div><div class=\"p\">&nbsp; &nbsp; Proyecto de ley:</div><br></div>", "i": 7173481}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Modif&#xED;case la redacci&#xF3;n del art&#xED;culo 2&#xB0; transitorio de la ley N&#xB0; 10,475, anteponiendo a su texto actual, la frase &quot;La Caja Aut&#xF3;noma de Amortizaci&#xF3;n de la Deuda P&#xFA;blica y&quot;. </div></div>", "i": 7173482, "v": ["MODIFICACION"]}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Y por cuanto he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como ley de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, veintinueve de Octubre de mil novecientos cincuenta y dos.- GABRIEL GONZALEZ VIDELA.- S&#xF3;tero del R&#xED;o.</div><br></div>", "i": 7173483}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "10989", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-10989"}], "organismos": ["MINISTERIO DE SALUBRIDAD, PREVISIÓN Y ASISTENCIA SOCIAL"], "titulo_norma": "MODIFICA LA LEY N° 10,475, RELACIONADA CON PREVISION\nDE LOS EMPLEADOS PARTICULARES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CAJA PREVISION EMPLEADOS PARTICULARES", "CAJA AUTONOMA AMORTIZACION DEUDA PUBLICA", "JUBILACION VOLUNTARIA", "BENEFICIOS", "CONCESION", "MODIFICA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1952-10-29", "doble_articulado": false, "id_norma": "26508", "numero_fuente": "22400", "tipo_version": "3", "tipo_ve