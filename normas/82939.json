{"html": [{"t": "<div><div class=\"p\">MODIFICA RESOLUCION QUE INDICA</div><br><br><br><br></div>", "i": 8314471}, {"t": "<div><div class=\"p\">Por resoluci&#xF3;n No. 733, 07 de Junio de 1990, de esta Subsecretar&#xED;a de pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, se modifica la Resoluci&#xF3;n No. 383, de 1990, de esta Subsecretar&#xED;a, que autoriz&#xF3; a Jos&#xE9; Andr&#xE9;s Medel Rivas, R.U.T. No. 6.995.965-2, domiciliado en Sector Huichamilla, Comuna de Maull&#xED;n, para operar un centro de cultivo de algas del g&#xE9;nero Gracilaria, en R&#xED;o San Pedro Nolasco, Comuna de Maull&#xED;n, Provincia de Llanquihue, X Regi&#xF3;n, en orden a se&#xF1;alar que el R.U.T. del interesado es el No. 6.995.965-2 y no el que se indica en el numeral 1 de la citada Resoluci&#xF3;n.</div><br></div>", "i": 8314472}, {"t": "<div><div class=\"p\">Valpara&#xED;so, 07 de Junio de 1990.- Andr&#xE9;s Couve Rioseco, Subsecretario de Pesca.</div><br></div>", "i": 8314473}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "733", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-733"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "MODIFICA RESOLUCION QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1990-06-07", "fecha_derogacion": "1993-10-04", "doble_articulado": false, "id_norma": "82939", "numero_fuente": "33694", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "1990-06-13", "vigencias": [{"desde": "1993-10-04", "hasta": "", "tipo_version": "2", "tipo_version_s": "Última Versión"}, {"desde": "19