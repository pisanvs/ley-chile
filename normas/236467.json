{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 466 EXENTA, DE 2005 </div><br></div>", "i": 6519673}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Mediante resoluci&#xF3;n exenta N&#xBA; 466, de 9 de marzo de 2005, del Servicio Nacional de Capacitaci&#xF3;n y Empleo, se cancel&#xF3; la autorizaci&#xF3;n otorgada al organismo t&#xE9;cnico intermedio para capacitaci&#xF3;n &quot;Organismo T&#xE9;cnico Intermedio para Capacitaci&#xF3;n de la Micro, Peque&#xF1;a y Mediana Empresa&quot;, atendido lo dispuesto en el art&#xED;culo 25 inciso tercero de la ley N&#xBA; 19.518.</div><br></div>", "i": 6519674}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 9 de marzo de 2005.- Jossie Esc&#xE1;rate M&#xFC;ller, Directora Nacional.</div><br></div>", "i": 6519675}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "466 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-466 EXENTA"}], "organismos": ["SERVICIO NACIONAL DE CAPACITACIÓN Y EMPLEO"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 466 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-03-09", "doble_articulado": false, "id_norma": "236467", "numero_fuente": "38116", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-03-21", "vigencias": [{"desde": "2005-03-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-03-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-03-21", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2005-03-21", "fe