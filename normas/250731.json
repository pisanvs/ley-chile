{"html": [{"t": "<div><div class=\"p\">AUTORIZA EMISOR BOLETAS ELECTRONICAS </div></div>", "i": 6573891}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Extracto de resoluci&#xF3;n exenta del Servicio de Impuestos Internos N&#xBA; 79, de 15 junio 2006, que autoriza a contribuyente como emisor de boletas electr&#xF3;nicas.</div><br><div class=\"p\">&nbsp; &nbsp;  Se autoriza como emisor de boletas electr&#xF3;nicas al contribuyente RUT 96.509.660-4 a contar del mes de junio de 2006.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta resoluci&#xF3;n est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl) y, adem&#xE1;s, aparecer&#xE1; en el Bolet&#xED;n del SII del mes de junio de 2006.</div><br></div>", "i": 6573892}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "79 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-79 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "AUTORIZA EMISOR BOLETAS ELECTRONICAS", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["CONTRIBUYENTES", "EMISORES ELECTRONICOS", "AUTORIZACION", "DOCUMENTOS TRIBUTARIOS ELECTRONICOS"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO", "NORMA SIN PROMULGACION"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-06-15", "doble_articulado": false, "id_norma": "250731", "numero_fuente": "38494", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-06-21", "vigencias": [{"desde": "2006-06-21", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-06-21", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-06-21", "fin_