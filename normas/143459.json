{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp;  Lei n&#xFA;mero 3,870.- Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente</div><br><div class=\"p\">&nbsp; &nbsp;  PROYECTO DE LEI:</div><br></div>", "i": 6191367}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  &quot;Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a don Francisco Sayago Moreno, actual administrador de la III Zona de los Ferrocarriles del Estado, el derecho a jubilar con goce de una pension anual de veinte mil pesos, equivalente al sueldo &#xED;ntegro de que disfruta actualmente en el desempe&#xF1;o de su empleo.&quot; </div></div>", "i": 6191368}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Y por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo y sancionarlo; por tanto, prom&#xFA;lguese y ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp;  Santiago, a seis de julio de mil novecientos veintidos.- Arturo Alessandri.- M. Letelier.</div><br></div>", "i": 6191369}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3870", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3870"}], "organismos": ["MINISTERIO DE FERROCARRILES"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1922-07-06", "doble_articulado": false, "id_norma": "143459", "numero_fuente": "13325", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1922-07-11", "vigencias": [{"desde": "1922-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1922-07-11", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1922-07-11", "fin_vigen