{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; FIJA PORCENTAJE DE COINCIDENCIA ENTRE UN TRAZADO TRONCAL Y EL CONJUNTO DE TRAZADOS DENOMINADOS VARIANTES N&#xFA;m. 037 exenta.- Antofagasta, 21 de Noviembre de 1991.- Vistos: El Decreto Supremo N&#xB0; 148 de 1991, P&#xE1;rrafo 5;</div><div class=\"p\">&nbsp; &nbsp; Resuelvo:</div><br><br><br><br></div>", "i": 7200892}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; 1.- El conjunto de trazados denominados variantes, deber&#xE1;n coincidir al menos en un 50% de su extensi&#xF3;n con el troncal.</div><div class=\"p\">&nbsp; &nbsp; 2.- Este porcentaje, ser&#xE1; aplicable a todas las ciudades comprendidas dentro de la Regi&#xF3;n de Antofagasta.</div><br><br></div>", "i": 7200893}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Gast&#xF3;n Viveros Viveros, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Regi&#xF3;n de Antofagasta.- </div></div>", "i": 7200894}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "37 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-37 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES"], "titulo_norma": "FIJA PORCENTAJE DE COINCIDENCIA ENTRE UN TRAZADO;TRONCAL Y EL CONJUNTO DE TRAZADOS DENOMINADOS VARIANTES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["PORCENTAJE VARIACION", "TRAZADO TRONCAL", "TRAZADOS", "VARIANTES", "ANTOFAGASTA II REGION", "SERVICIO PUBLICOS", "TRANSPORTES PASAJEROS", "LINEA DE TRANSPORTE PUBLICO", "PASAJEROS", "LOCOMOCION COLECTIVA"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "1991-11-21", "fecha_derogacion": "1999-09-04", "doble_articulado": false, "id_norma": "38045", "