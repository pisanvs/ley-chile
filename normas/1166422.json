{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10276104}, {"t": "<div><br><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Gobierno Regional Ays&#xE9;n, por Res. Ex. N&#xB0; 1.043 de 28 septiembre 2021, prohibi&#xF3; circulaci&#xF3;n de&nbsp; veh&#xED;culos que indica en condiciones que se&#xF1;ala, relativas a obras de Mejoramiento Ruta 243-CH Av. Baquedano Sector calle Victoria - Escuela Agr&#xED;cola, Coyhaique, y autoriz&#xF3; a empresa Conpax SpA para realizar siguiente intervenci&#xF3;n en v&#xED;a p&#xFA;blica:</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div><div class=\"p\">&nbsp; &nbsp;  - Corte total de calle Tucapel Jim&#xE9;nez entre Av. Baquedano y Escuela Agr&#xED;cola, por un plazo de 90 d&#xED;as corridos desde el d&#xED;a 28-09-2021.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; </div></div>", "i": 10276105}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Andrea Mac&#xED;as Palma, Gobernadora Regional, Gobierno Regional de Ays&#xE9;n.- Ximena Guti&#xE9;rrez Jaramillo, Asesora Jur&#xED;dica, Gobierno Regional de Ays&#xE9;n.</div><br></div>", "i": 10276106}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1043 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "Resolución-1043 EXENTA"}], "organismos": ["GOBIERNO REGIONAL DE AYSÉN DEL GENERAL CARLOS IBÁÑEZ DEL CAMPO"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 2024054", "EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2021-09-29", "doble_articulado": false, "id_norma": "1166422", "numero_fuente": "43077", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2021-10-14", "vigencias": [{"desde": "2021-10-14", "hasta": "