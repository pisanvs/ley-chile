{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6098796}, {"t": "<div><br><div class=\"p\">El Banco Central de Chile, en conformidad a lo dispuesto en el No. 5 del Cap&#xED;tulo IV.B.8. del. Compendio de Normas Financieras, certifica que la Tasa de Inter&#xE9;s Promedio (TIP) quincenal de captaci&#xF3;n para operaciones reajustables entre 90 y 365 d&#xED;as, correspondiente a la primera quincena de enero de 1990, fue de 9,98% anual.</div><br></div>", "i": 6098797}, {"t": "<div><div class=\"p\">Santiago, 19 de enero de 1990.- Mar&#xED;a Eliana Torres Contreras, Secretario General Subrogante.</div><br></div>", "i": 6098798}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "8", "numero": "S/N", "abreviacion": "CER", "descripcion": "Certificado", "compuesto": "CER-S/N"}], "organismos": ["BANCO CENTRAL DE CHILE", "SECRETARÍA GENERAL"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1990-01-19", "doble_articulado": false, "id_norma": "95058", "numero_fuente": "33575", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1990-01-20", "vigencias": [{"desde": "1990-01-20", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1990-01-20", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1990-01-20", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "PGA", "fecha_ingreso": "1998-03-09", "fecha_version": "1990-01-20", "fecha_actualizacion_texto": "1990-01-20", "tipo_tratado": ""}, "alertas": [], "alerta_global": "", "estructura": [{"n": "Encabezado", "i": 6098796}, {"n": "Artículo", "i": 6098797,