{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8343235}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n N&#xBA; 499, de 29 de marzo de 1999, de esta Subsecretar&#xED;a, decl&#xE1;rase la caducidad de la resoluci&#xF3;n N&#xBA; 1.370 de 1992, de esta Subsecretar&#xED;a, que autoriz&#xF3; a SOCIEDAD PESQUERA GUANAYE LIMITADA -hoy Pesquera Iquique Guanaye S.A.-, para operar la nave &apos;&apos;Juan Manuel&apos;&apos;, sobre las especies Anchoveta, Sardina espa&#xF1;ola, Jurel, Caballa, Roncacho, Machuelo o tritre, Sardina com&#xFA;n, en el litoral de la III y IV regiones. </div></div>", "i": 8343236}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 29 de marzo de 1999.- Juan Manuel Cruz S&#xE1;nchez, Subsecretario de Pesca.</div><br></div>", "i": 8343237}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "499", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-499"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1999-03-29", "doble_articulado": false, "id_norma": "134490", "numero_fuente": "36331", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1999-04-06", "vigencias": [{"desde": "1999-04-06", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1999-04-06", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1999-04-06", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_part": "modificacion"}], "ingresado_