{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO N&#xB0; 278, DE 1985 </div></div>", "i": 8604007}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto supremo exento de Educaci&#xF3;n N&#xB0; 278, de 25 de Junio de 1985, se ha aprobado al Colegio Saint John&apos;s de Concepci&#xF3;n un plan especial de estudio para 3&#xB0; y 4&#xB0; a&#xF1;o de Educaci&#xF3;n Media Human&#xED;stico Cient&#xED;fica, que se aplicar&#xE1; a contar del a&#xF1;o escolar 1985.</div><div class=\"p\">&nbsp; &nbsp;  La evaluaci&#xF3;n y promoci&#xF3;n de los alumnos se regir&#xE1; por las normas generales sobre la materia, con la adecuaci&#xF3;n que se se&#xF1;ala.</div><div class=\"p\">&nbsp; &nbsp;  Las situaciones no previstas en el presente decreto, ser&#xE1;n resueltas por la Direcci&#xF3;n de Educaci&#xF3;n Secundaria.</div><br></div>", "i": 8604008}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Santiago, 03 de Julio de 1985.- Ra&#xFA;l Mohr Aray, Subsecretario de Educaci&#xF3;n P&#xFA;blica subrogante. </div></div>", "i": 8604009}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "278 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-278 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO N° 278, DE 1985", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-06-25", "doble_articulado": false, "id_norma": "162627", "numero_fuente": "32237", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-08-01", "vigencias": [{"desde": "1985-08-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": 