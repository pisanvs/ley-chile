{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6256609}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta No. 895, de fecha 23 de Julio de 1985, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Va. Regi&#xF3;n, se autoriza a Juan Morales Gonz&#xE1;lez, para efectuar todo tipo de servicios de transportes de pasajeros por calles y caminos dentro del territorio nacional, a excepci&#xF3;n de los servicios p&#xFA;blicos urbanos de locomoci&#xF3;n colectiva de pasajeros.</div><br></div>", "i": 6256610}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 23 de Julio de 1985.- Hern&#xE1;n V&#xE1;squez Wacquez, Capit&#xE1;n de Nav&#xED;o, Secretario Regional Ministerial de Transportes y Telecomunicaciones, Va. Regi&#xF3;n.</div><br></div>", "i": 6256611}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "895 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-895 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL V REGIÓN DE VALPARAÍSO"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-07-23", "doble_articulado": false, "id_norma": "162838", "numero_fuente": "32236", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-07-31", "vigencias": [{"desde": "1985-07-31", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-07-31", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1985-07-31", "fin_vigencia": "", "tipo_version": "3"}], "ev