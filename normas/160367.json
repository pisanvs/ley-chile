{"html": [{"t": "<div><div class=\"p\">DETERMINA DERECHOS APROVECHAMIENTO DE AGUAS QUE INDICA </div></div>", "i": 6248600}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Servicio Agr&#xED;cola y Ganadero mediante resoluci&#xF3;n exenta No. 61 de 22 de Enero de 1985 que modific&#xF3; la resoluci&#xF3;n exenta No. 75 del 24 de Enero de 1984, conforme al art&#xED;culo 5&#xB0; transitorio C&#xF3;digo de Aguas, determin&#xF3; derechos de aprovechamiento de aguas proporcionales que corresponden a las parcelas No. 15 a la 30, sitios No. 9 al 17 del Proyecto de Parcelaci&#xF3;n &quot;La Patag&#xFC;illa&quot;, formado por predio &quot;Hijuela n&#xFA;mero cuatro ubicado en el predio denominado La Laguna&quot;. Los derechos de agua se extraen del canal Las Mercedes. Publicaci&#xF3;n hecha conforme art. 13 Ley 18.377.- </div></div>", "i": 6248601}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Director Ejecutivo.</div><br></div>", "i": 6248602}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "61 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-61 EXENTA"}], "organismos": ["MINISTERIO DE AGRICULTURA", "SERVICIO AGRICOLA Y GANADERO"], "titulo_norma": "DETERMINA DERECHOS APROVECHAMIENTO DE AGUAS QUE INDICA", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1985-01-22", "doble_articulado": false, "id_norma": "160367", "numero_fuente": "32136", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1985-04-01", "vigencias": [{"desde": "1985-04-01", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1985-04-01", "fin_vigencia": ""}, "vigencias_version_norma": [{"inic