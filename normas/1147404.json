{"html": [{"t": "<div><div class=\"p\">EXTRACTO</div></div>", "i": 10135497}, {"t": "<div><div class=\"p\"> </div><div class=\"p\">&nbsp; &nbsp;  Extracto de Circular del Servicio de Impuestos Internos N&#xBA; 45, de fecha 7 de julio de 2020, que imparte instrucciones sobre las modificaciones introducidas por la ley N&#xBA; 21.210 a los art&#xED;culos <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=9510132&amp;idVersion=\">41 F</a> y <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=9510133&amp;idVersion=\">41 G</a> de la <a href=\"https://www.leychile.cl/Navegar?idNorma=6368&amp;idParte=&amp;idVersion=\">Ley sobre Impuesto a la Renta</a>. Reemplaza, en lo pertinente, la Circular N&#xBA; 12, de 2015, y complementa la Circular N&#xBA; 40, de 2016.</div><div class=\"p\">&nbsp; &nbsp;  El texto &#xED;ntegro de esta Circular est&#xE1; publicado en la Oficina Virtual del Servicio de Impuestos Internos en Internet (www.sii.cl).</div></div>", "i": 10135498}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "9", "numero": "45", "abreviacion": "CIR", "descripcion": "Circular", "compuesto": "Circular-45"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "DIRECCIÓN NACIONAL"], "titulo_norma": "EXTRACTO", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["CVE 1784360", "EXTRACTO; NORMA SIN PROMULGACIÓN"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2020-07-07", "doble_articulado": false, "id_norma": "1147404", "numero_fuente": "42703", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2020-07-11", "vigencias": [{"desde": "2020-07-11", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2020-0