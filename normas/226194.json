{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6482656}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 1.515&nbsp; de 1 de junio de 2004 de esta Subsecretar&#xED;a, autor&#xED;zase a PACIFIC FISHERIES S.A. para ampliar actividades pesqueras extractivas con la nave &quot;Ligrunn&quot;, en las &#xE1;reas mar&#xED;timas que en cada caso se indican, donde podr&#xE1; capturar los recursos hidrobiol&#xF3;gicos que a continuaci&#xF3;n se se&#xF1;alan: a) Entre la V a VII Regiones, y en la X Regi&#xF3;n, por fuera del &#xE1;rea de reserva artesanal, con cerco: Jibia, Calamar, Pota del Atl&#xE1;ntico; b) Entre la V a VII Regiones, y en la X Regi&#xF3;n, por fuera de l&#xED;nea imaginaria trazada a una distancia de 60 millas marinas desde las l&#xED;neas de base rectas o normales, seg&#xFA;n corresponda, con arrastre de media agua: Jibia, Calamar, Pota del Atl&#xE1;ntico.</div><br></div>", "i": 6482657}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Valpara&#xED;so, 1 de junio de 2004.- Felipe Sandoval Precht, Subsecretario de Pesca.</div><br></div>", "i": 6482658}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "1515 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-1515 EXENTA"}], "organismos": ["MINISTERIO DE ECONOMÍA", "FOMENTO Y RECONSTRUCCION", "SUBSECRETARÍA DE PESCA"], "titulo_norma": "", "fuente": "", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": true, "fecha_promulgacion": "2004-06-01", "fecha_derogacion": "2012-04-17", "doble_articulado": false, "id_norma": "226194", "tipo_version": "2", "tipo_version_s": "Última Versión", "fecha_publicacion": "2004-06-09", "vigencias": [{"desde": "2012-04-17", "hasta": "", "tipo_versio