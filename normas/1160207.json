{"html": [{"t": "<div><div class=\"p\">MINISTROS&#x2013;NOMBRAMIENTOS.</div><br><div class=\"p\">&nbsp; &nbsp;  Santiago, Marzo 24 de 1831.</div></div>", "i": 10255431}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Como encargado del Poder Ejecutivo mientras el electo Presidente de la Rep&#xFA;blica, Jeneral de division y en jefe del ej&#xE9;rcito nacional, entra en el ejercicio de sus funciones, nombro para Ministro de Estado en los departamentos del Interior y Relaciones Exteriores, y en los de Guerra y Marina a don Diego Portales; y a don Manuel Rengifo en el departamento de Hacienda, pues que estoi plenamente satisfecho de las aptitudes y recomendables cualidades que distinguen a estos ciudadanos. Este decreto servir&#xE1; de suficiente t&#xED;tulo. </div></div>", "i": 10255432}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Refr&#xE9;ndese, t&#xF3;mese razon y comun&#xED;quese.</div><br><div class=\"p\">&nbsp; &nbsp;  ERRAZURIZ.&nbsp; &nbsp;  Manuel Carvallo.</div><div class=\"p\">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; Pro-secretario.</div></div>", "i": 10255433}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "S/N", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "Decreto-S/N"}], "organismos": ["NO ESPECIFICADO"], "titulo_norma": "MINISTROS–NOMBRAMIENTOS.", "fuente": "Boletín de Leyes y Decretos de Gobierno", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1831-03-24", "doble_articulado": false, "id_norma": "1160207", "numero_fuente": "1831", "tipo_version": "3", "tipo_version_s": "Única", "vigencias": [{"desde": "1831-03-24", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1