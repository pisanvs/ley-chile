{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE RESOLUCION N&#xBA; 239 EXENTA, DE 2005 </div></div>", "i": 6534139}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por resoluci&#xF3;n exenta N&#xBA; 239 de 14 de junio de 2005, de la Secretar&#xED;a Regional Ministerial de Transportes y Telecomunicaciones de la Regi&#xF3;n de Antofagasta, se fija para esa regi&#xF3;n, como fecha de entrada en vigencia de las normas contenidas en el decreto supremo N&#xBA; 211 de 1995, la fecha de publicaci&#xF3;n en el Diario Oficial de la presente resoluci&#xF3;n. </div></div>", "i": 6534140}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  - Enrique Viveros Jara, Secretario Regional Ministerial de Transportes y Telecomunicaciones Regi&#xF3;n de Antofagasta.</div><br></div>", "i": 6534141}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "239 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-239 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES", "SECRETARÍA REGIONAL MINISTERIAL II REGIÓN DE ANTOFAGASTA"], "titulo_norma": "EXTRACTO DE RESOLUCION Nº 239 EXENTA, DE 2005", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2005-06-14", "doble_articulado": false, "id_norma": "240399", "numero_fuente": "38219", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2005-07-25", "vigencias": [{"desde": "2005-07-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2005-07-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2005-07-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendiente