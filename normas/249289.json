{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 6568767}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Por decreto MOP (exento) N&#xBA;168 de fecha 31 de marzo del 2006, se expropi&#xF3; el lote de terreno N&#xBA;8, superficie 517,2 m2, Rol N&#xBA; 381-141, comuna de Pitrufqu&#xE9;n, IX Regi&#xF3;n para la obra &quot;Dise&#xF1;o Definitivo de la Red Secundaria y Terciaria de Canales de Riego Proyecto Faja Maisan, Obra Canal Quinque&quot; y se acord&#xF3; el valor de indemnizaci&#xF3;n con su propietaria Mar&#xED;a Eduvina Mu&#xF1;oz Bravo, ascendente a la cantidad de $350.320.- para el lote N&#xBA;8.</div><br></div>", "i": 6568768}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Fiscal del Ministerio de Obras P&#xFA;blicas. </div></div>", "i": 6568769}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "168 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-168 EXENTO"}], "organismos": ["MINISTERIO DE OBRAS PÚBLICAS", "FISCALÍA"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2006-03-31", "doble_articulado": false, "id_norma": "249289", "numero_fuente": "38452", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "2006-05-02", "vigencias": [{"desde": "2006-05-02", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "2006-05-02", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "2006-05-02", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "ingresado_por": "JRC", "fecha_ingreso": "2006-05-02", "fecha_version": "2006-05-02", "fecha_actualizacion_texto": "2006-