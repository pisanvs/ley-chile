{"html": [{"t": "<div><div class=\"p\">&#xA0;</div></div>", "i": 8299467}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Por Resoluci&#xF3;n N&#xB0; 380 de 26 de febrero de 1996, de esta Subsecretar&#xED;a de Pesca del Ministerio de Econom&#xED;a, Fomento y Reconstrucci&#xF3;n, autor&#xED;zase a Comercial e Inversiones Loanco Limitada, para ampliar actividades pesqueras, en orden a incorporar a la planta ubicada en Avenida Parque Fundici&#xF3;n, Sitio 8, Tongoy, IV Regi&#xF3;n, en las l&#xED;neas de elaboraci&#xF3;n de Congelado y Fresco-refrigerado, los siguientes recursos hidrobiol&#xF3;gicos: Reineta y Loco.</div><br></div>", "i": 8299468}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Valpara&#xED;so, 26 de febrero de 1996.- Patricio Bernal Ponce, Subsecretario de Pesca.</div><br></div>", "i": 8299469}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "380", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-380"}], "organismos": ["MINISTERIO DE ECONOMÍA, FOMENTO Y RECONSTRUCCIÓN"], "titulo_norma": "", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["COMERCIAL INVERSIONES LOANCO LIMITADA", "PESCA", "INDUSTRIA PESQUERA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1966-02-26", "doble_articulado": false, "id_norma": "38825", "numero_fuente": "35426", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1996-03-25", "vigencias": [{"desde": "1996-03-25", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1996-03-25", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1996-03-25", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [], "fecha_versio