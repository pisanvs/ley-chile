{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m 3,520, que concede derecho a jubilar a don Domingo V&#xED;ctor Santa Mar&#xED;a.</div><div class=\"p\">&nbsp; &nbsp; Lei n&#xFA;m. 3,520.-</div><div class=\"p\">&nbsp; &nbsp; Por cuanto el Congreso Nacional ha dado su aprobacion al siguiente proyecto de lei:</div><br></div>", "i": 5956078}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico.- Conc&#xE9;dese, por gracia, a don Domingo V&#xED;ctor Santa Mar&#xED;a, el derecho a jubilar con el setenta i cinco por ciento del sueldo que la lei asigna al Director Jeneral de Obras P&#xFA;blicas.</div><br></div>", "i": 5956079}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.</div><div class=\"p\">&nbsp; &nbsp; Santiago, a dieciocho de Julio de mil novecientos diecinueve.- JUAN LUIS SANFUENTES.- Pablo Ram&#xED;rez. </div></div>", "i": 5956080}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "3520", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-3520"}], "organismos": ["MINISTERIO DE INSTRUCCIÓN PÚBLICA"], "titulo_norma": "Lei núm 3,520, que concede derecho a jubilar a don;Domingo Víctor Santa María.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["DOMINGO VICTOR SANTA MARIA", "JUBILACION POR GRACIA", "CONCESION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1919-07-18", "doble_articulado": false, "id_norma": "24034", "numero_fuente": "12434", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1919-07-29", "vigencias": [{"desde": "1919-07-29", "hasta": "", "tipo_version":