{"html": [{"t": "<div><div class=\"p\">EXTRACTO DE DECRETO EXENTO No. 183, DE 1991 </div></div>", "i": 7215877}, {"t": "<div><br><div class=\"p\">Por decreto exento No. 183, de fecha 12 de Julio de 1991, del Ministerio de Educaci&#xF3;n, se sustituyeron los incisos 2&#xB0; y siguientes del art&#xED;culo 2&#xB0; del decreto exento No. 56 de 1990, que autoriza el funcionamiento del Instituto Profesional Esane del Norte y se aprobaron las modificaciones al reglamento a que se refiere el art&#xED;culo 6&#xB0; del DFL No. 5 de 1981, sobre las condiciones para el otorga miento de los t&#xED;tulos profesionales y t&#xE9;cnicos. </div></div>", "i": 7215878}, {"t": "<div><div class=\"p\">Santiago, 26 de Agosto de 1991.- Ra&#xFA;l Allard Neumann, Subsecretario de Educaci&#xF3;n.</div><br></div>", "i": 7215879}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "2", "numero": "183 EXENTO", "abreviacion": "DTO", "descripcion": "Decreto", "compuesto": "DTO-183 EXENTO"}], "organismos": ["MINISTERIO DE EDUCACIÓN", "SUBSECRETARIA DE EDUCACION"], "titulo_norma": "EXTRACTO DE DECRETO EXENTO No. 183, DE 1991", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": ["EXTRACTO"], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1991-07-12", "doble_articulado": false, "id_norma": "80994", "numero_fuente": "34076", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1991-09-26", "vigencias": [{"desde": "1991-09-26", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1991-09-26", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1991-09-26", "fin_vigencia": "", "tipo_version": "3"}], "eventos_pendientes": [], "vinculaciones": [{"text": "MODIFICACION", "url_par