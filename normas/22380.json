{"html": [{"t": "<div><div class=\"p\">&nbsp; &nbsp; Contribucion sobre Haberes Lei n&#xFA;m. 1,055.- Santiago, a 17 de Agosto de 1898.- Por cuanto el Congreso Nacional ha prestado su aprobacion al siguiente</div><div class=\"p\">&nbsp; &nbsp; PROYECTO DE LEI:</div><br></div>", "i": 8274064}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; Art&#xED;culo &#xFA;nico. Las Municipalidades que no hubieren nombrado en el presente a&#xF1;o las comisiones avaluadoras podr&#xE1;n cobrar la contribucion sobre haberes en la misma forma que lo hubieren hecho en el a&#xF1;o pr&#xF3;ximo pasado.</div><br><br></div>", "i": 8274065}, {"t": "<div><div class=\"p\">&nbsp; &nbsp; I por cuanto, oido el Consejo de Estado, he tenido a bien aprobarlo i sancionarlo; por tanto, prom&#xFA;lguese i ll&#xE9;vese a efecto como lei de la Rep&#xFA;blica.- FEDERICO ERRAZURIZ.- C. Walker Mart&#xED;nez.</div><br></div>", "i": 8274066}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "1", "numero": "1055", "abreviacion": "LEY", "descripcion": "Ley", "compuesto": "LEY-1055"}], "organismos": ["MINISTERIO DEL INTERIOR"], "titulo_norma": "CONTRIBUCION SOBRE HABERES", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": ["MUNICIPALIDADES", "HABERES", "COMISION", "COBRANZA", "AUTORIZACION"], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1898-08-17", "doble_articulado": false, "id_norma": "22380", "numero_fuente": "6078", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicacion": "1898-08-17", "vigencias": [{"desde": "1898-08-17", "hasta": "", "tipo_version": "3", "tipo_version_s": "Única"}], "vigencia": {"inicio_vigencia": "1898-08-17", "fin_vigencia": ""}, "vigencias_version_norma": [{"inicio_vigencia": "1898-08-17", "fin_vigencia": "", "tipo_ver