{"html": [{"t": "<div><div class=\"p\">INCLUYE A MUNICIPALIDAD DE LAUTARO EN RESOLUCION EXENTA No. 726, DE 1986</div><br><div class=\"p\">(Resoluci&#xF3;n)</div><br><div class=\"p\">&nbsp; &nbsp;  N&#xFA;m. 777 exenta.- Santiago, 30 de Julio de 1986.- Visto: Lo dispuesto en el Art&#xED;culo No. 9 de la Ley de Transito, en relaci&#xF3;n con la Ley 18.059; y la Ley 18.530,</div><div class=\"p\">&nbsp; &nbsp;  Resuelvo:</div><br><br></div>", "i": 7260582}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  Agr&#xE9;gase en el n&#xFA;mero 1&#xB0; de la Resoluci&#xF3;n Exenta No. 726/86, del Ministerio de Transportes y Telecomunicaciones, Subsecretar&#xED;a de Transportes, bajo el subt&#xED;tulo IX Regi&#xF3;n, a la Municipalidad de Lautaro. </div></div>", "i": 7260583}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  An&#xF3;tese, comun&#xED;quese y publ&#xED;quese.- Enrique Escobar Rodr&#xED;guez, General de Aviaci&#xF3;n, Ministro de Transportes y Telecomunicaciones.</div><div class=\"p\">Lo que transcribo para su conocimiento.- Saluda a Ud.- Patricia Mu&#xF1;oz Villela, Jefe Administrativo.</div><br><br></div>", "i": 7260584}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "777 EXENTA", "abreviacion": "RES", "descripcion": "Resolucion", "compuesto": "RES-777 EXENTA"}], "organismos": ["MINISTERIO DE TRANSPORTES Y TELECOMUNICACIONES", "SUBSECRETARIA DE TRANSPORTES"], "titulo_norma": "INCLUYE A MUNICIPALIDAD DE LAUTARO EN RESOLUCION EXENTA\nNo. 726, DE 1986", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "1986-07-30", "doble_articulado": false, "id_norma": "154638", "numero_fuente": "32544", "tipo_version": "3", "tipo_version_s": "Única", "fecha_publicaci