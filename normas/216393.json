{"html": [{"t": "<div><div class=\"p\">OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A MARITIMA CAPMAR S.A.</div><br></div>", "i": 8113119}, {"t": "<div><div class=\"p\">&nbsp; &nbsp;  La VIII Direcci&#xF3;n Regional Concepci&#xF3;n del SII, por resoluci&#xF3;n DRE08/N&#xBA; Ex 2.133, de fecha 16 de octubre de 2003, otorga a Mar&#xED;tima Capmar S.A., RUT N&#xBA; 96.963.350-7, la calidad de Agente Retenedor del Impuesto al Valor Agregado, del cambio de sujeto en las ventas de productos hidrobiol&#xF3;gicos, establecido en la resoluci&#xF3;n N&#xBA; EX-3.311, de 30-06-2000 de la Direcci&#xF3;n Nacional. La presente autorizaci&#xF3;n surtir&#xE1; efecto a partir del d&#xED;a primero del mes siguiente a la fecha de publicaci&#xF3;n de este extracto en el Diario Oficial y tendr&#xE1; vigencia indefinida.</div><br></div>", "i": 8113120}, {"t": "<div><div class=\"p\">Concepci&#xF3;n, 16 de octubre de 2003.-</div><div class=\"p\">&nbsp; &nbsp;  Sergio Flores Guti&#xE9;rrez, Director Regional. Ministerio de Justicia </div></div>", "i": 8113121}], "proyectos": [], "otrosSistemas": [], "jurisprudencia": [], "doctrina": [], "metadatos": {"tiene_notas": false, "tipos_numeros": [{"tipo": "3", "numero": "2133 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-2133 EXENTA"}, {"tipo": "3", "numero": "DRE-08-2133 EXENTA", "abreviacion": "RES", "descripcion": "Resolución", "compuesto": "RES-DRE-08-2133 EXENTA"}], "organismos": ["MINISTERIO DE HACIENDA", "SERVICIO DE IMPUESTOS INTERNOS", "VIII DIRECCIÓN REGIONAL DE CONCEPCIÓN"], "titulo_norma": "OTORGA CALIDAD DE AGENTE RETENEDOR DE IVA A MARITIMA\nCAPMAR S.A.", "fuente": "Diario Oficial", "resumenes": [], "materias": [], "terminos_libres": [], "categorias_norma": [], "nombres_uso_comun": [], "paises_tratados": [], "organismos_tratados": [], "observaciones": [], "derogacion_tacita": [], "derogado": false, "fecha_promulgacion": "2003-10-16", "doble_articulado": false, "id_norma": "216393", "numero_fuente": "37697